# Railway Environment Variables for Calculator Thailand
# Copy this file to .env.local (local development) or configure in Railway dashboard for production.
# Never commit real affiliate URLs or sensitive config to version control.

# ============================================================================
# AFFILIATE PARTNER URLS — ACCESSTRADE
# ============================================================================
# These are tracking URLs provided by ACCESSTRADE after signup and campaign setup.
# Format: https://[accesstrade-domain]/[campaign-id]?sub_id=[page-slug]
# Replace with real URLs from CMO once CAL-897 is complete.

# TTB Cash 2 Go — Personal Loan (ACCESSTRADE)
AFFILIATE_URL_TTB_CASH2GO=https://accesstrade.in.th

# KTC Brother Berm — Auto Loan (ACCESSTRADE)
AFFILIATE_URL_KTC_BROTHER_BERM=https://accesstrade.in.th

# เงินติดล้อ (Ngern Tid Lor) — Auto Loan (ACCESSTRADE)
AFFILIATE_URL_NGERN_TID_LOR=https://accesstrade.in.th

# TIPINSURE — Motor Insurance (ACCESSTRADE)
AFFILIATE_URL_TIPINSURE=https://accesstrade.in.th

# UOB TMRW — Credit Card (ACCESSTRADE)
AFFILIATE_URL_UOB_TMRW=https://accesstrade.in.th

# Krungsri Signature — Credit Card (ACCESSTRADE)
AFFILIATE_URL_KRUNGSRI_SIGNATURE=https://accesstrade.in.th

# Kept by Krungsri — Savings (ACCESSTRADE)
AFFILIATE_URL_KEPT_KRUNGSRI=https://accesstrade.in.th

