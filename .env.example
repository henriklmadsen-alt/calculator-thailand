# Railway Environment Variables for Calculator Thailand
# Copy this file to .env.local (local development) or configure in Railway dashboard for production.
# Never commit real affiliate URLs or sensitive config to version control.

# ============================================================================
# AFFILIATE PARTNER URLS — ACCESSTRADE
# ============================================================================
# These are tracking URLs provided by ACCESSTRADE after signup and campaign setup.
# Format: https://[accesstrade-domain]/[campaign-id]?sub_id=[page-slug]
# Replace with real URLs from CMO once CAL-897 is complete.

# TTB Cash 2 Go — Personal Loan (ACCESSTRADE)
AFFILIATE_URL_TTB_CASH2GO=https://accesstrade.in.th

# KTC Brother Berm — Auto Loan (ACCESSTRADE)
AFFILIATE_URL_KTC_BROTHER_BERM=https://accesstrade.in.th

# เงินติดล้อ (Ngern Tid Lor) — Auto Loan (ACCESSTRADE)
AFFILIATE_URL_NGERN_TID_LOR=https://accesstrade.in.th

# TIPINSURE — Motor Insurance (ACCESSTRADE)
AFFILIATE_URL_TIPINSURE=https://accesstrade.in.th

# UOB TMRW — Credit Card (ACCESSTRADE)
AFFILIATE_URL_UOB_TMRW=https://accesstrade.in.th

# Krungsri Signature — Credit Card (ACCESSTRADE)
AFFILIATE_URL_KRUNGSRI_SIGNATURE=https://accesstrade.in.th

# Kept by Krungsri — Savings (ACCESSTRADE)
AFFILIATE_URL_KEPT_KRUNGSRI=https://accesstrade.in.th

# ============================================================================
# AFFILIATE PARTNER URLS — INVOLVE ASIA
# ============================================================================
# These are tracking URLs provided by Involve Asia after signup and campaign setup.
# Replace with real URLs from CMO once CAL-897 is complete.

# Rabbit Care — Health Insurance (INVOLVE ASIA)
AFFILIATE_URL_RABBIT_CARE_HEALTH_CPL=https://app.involve.asia

# ============================================================================
# SITE CONFIGURATION
# ============================================================================

# Public site URL for canonical links and sitemap
PUBLIC_SITE_URL=https://www.kamnuanlek.com

# ============================================================================
# BREVO EMAIL (CAL-1070 — Email Capture + Transactional Email)
# ============================================================================
# Create free account at brevo.com → API Keys → Generate new key
# DNS: add SPF/DKIM records for noreply@kamnuanlek.com before going live
# Free tier: 300 emails/day, unlimited contacts
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@kamnuanlek.com
BREVO_SENDER_NAME=Kamnuanlek.com

# ============================================================================
# AI ADVISOR AUTH (CAL-1205)
# ============================================================================

# PostgreSQL — Railway: Settings → Variables → DATABASE_URL (auto-provisioned)
DATABASE_URL=

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=

# Google OAuth — console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://www.kamnuanlek.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook Login — developers.facebook.com → Your App → Facebook Login → Settings
# Valid OAuth Redirect URI: https://www.kamnuanlek.com/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Apple Sign In — developer.apple.com → Certificates, IDs → Services IDs
# Return URL: https://www.kamnuanlek.com/auth/apple/callback
# APPLE_PRIVATE_KEY: contents of the .p8 key file (escape newlines as \n)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ============================================================================
# STRIPE PAYMENTS (CAL-1266 — AI Advisor checkout, CAL-1267 — Webhook handler)
# ============================================================================
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
# dashboard.stripe.com → Products → create 3 one-time prices (THB)
# Basic: 399 THB, Premium: 699 THB, Master: 999 THB
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PREMIUM=
STRIPE_PRICE_ID_MASTER=
# dashboard.stripe.com → Developers → Webhooks → Add endpoint
# Endpoint URL: https://www.kamnuanlek.com/api/stripe/webhook
# Events to listen for: checkout.session.completed, customer.subscription.created,
#   customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed
# Copy the signing secret from the webhook detail page
STRIPE_WEBHOOK_SECRET=
