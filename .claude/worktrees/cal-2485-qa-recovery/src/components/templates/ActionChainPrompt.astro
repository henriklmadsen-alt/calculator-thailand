---
/**
 * Action Chain Prompt Component (Feature #3: Related Action Chains)
 *
 * Displays a contextual "next step" calculator suggestion after result.
 * Renders a subtle CTA card below the result.
 *
 * Props:
 * - calcPath: current calculator URL path (e.g., /คำนวณภาษี/)
 *
 * Behavior:
 * - Looks up calcPath in action-chains.ts
 * - If mapping exists: renders the action chain prompt card
 * - If no mapping: renders nothing (graceful no-op)
 * - Includes placeholder copy (UX designer will provide final text)
 */

import { getActionChain } from '../../data/action-chains';

interface Props {
  calcPath: string;
}

const { calcPath } = Astro.props;
const actionChain = getActionChain(calcPath);

// If no mapping, render nothing
if (!actionChain) {
  // Graceful no-op: empty fragment
}
---

{actionChain && (
  <div class="ct-action-chain">
    <div class="ct-action-chain-accent"></div>
    <div class="ct-action-chain-content">
      <span class="ct-action-chain-emoji" aria-hidden="true">
        {actionChain.emoji}
      </span>
      <div class="ct-action-chain-body">
        <p class="ct-action-chain-label">
          ขั้นตอนต่อไป:
        </p>
        <a href={actionChain.href} class="ct-action-chain-link">
          {actionChain.label}
          <svg class="ct-action-chain-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M9 18l6-6-6-6"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
)}

<style>
  .ct-action-chain {
    margin-top: 1rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 100%);
    border: 1px solid #bfdbfe;
    border-radius: 0.6rem;
    position: relative;
    overflow: hidden;
  }

  .ct-action-chain-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, #2563eb 0%, #1d4ed8 100%);
    flex-shrink: 0;
  }

  .ct-action-chain-content {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    flex: 1;
  }

  .ct-action-chain-emoji {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .ct-action-chain-body {
    flex: 1;
    min-width: 0;
  }

  .ct-action-chain-label {
    margin: 0;
    padding: 0;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
  }

  .ct-action-chain-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .ct-action-chain-link:hover {
    color: #1d4ed8;
  }

  .ct-action-chain-arrow {
    flex-shrink: 0;
    color: currentColor;
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .ct-action-chain {
      margin-top: 0.75rem;
      padding: 0.6rem;
      gap: 0.5rem;
    }

    .ct-action-chain-emoji {
      font-size: 1.25rem;
    }

    .ct-action-chain-link {
      font-size: 0.8125rem;
    }
  }
</style>
