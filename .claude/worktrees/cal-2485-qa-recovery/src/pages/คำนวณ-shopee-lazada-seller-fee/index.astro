---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าธรรมเนียม Shopee/Lazada Seller Fee ปี 2569 — Kamnuanlek';
const pageDescription = 'คำนวณค่าธรรมเนียมขายสินค้าบน Shopee และ Lazada ป้อนมูลค่าคำสั่งซื้อและอัตราธรรมเนียม ทราบค่าธรรมเนียมและรายได้สุทธิทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-shopee-lazada-seller-fee/`;

const faqData = [
  {
    question: 'ค่าธรรมเนียมผู้ขาย Shopee/Lazada คืออะไร?',
    answer: 'ค่าธรรมเนียมผู้ขาย (Seller Fee) คือค่าธรรมเนียมที่ Shopee หรือ Lazada หักจากยอดขายของแต่ละออเดอร์ โดยปกติอยู่ที่ 2–5.5% ขึ้นอยู่กับประเภทสินค้า เมื่อผู้ขายเลือกให้แพลตฟอร์มบรรจุสินค้า ค่า Fulfillment อาจเพิ่มเติม',
  },
  {
    question: 'ค่าธรรมเนียมคิดอย่างไร?',
    answer: 'ค่าธรรมเนียม = มูลค่าคำสั่งซื้อ × อัตราธรรมเนียม (%) ÷ 100 | รายได้สุทธิ = มูลค่าคำสั่งซื้อ − ค่าธรรมเนียม',
  },
  {
    question: 'ทำไมต้องคำนวณค่าธรรมเนียมล่วงหน้า?',
    answer: 'การคำนวณค่าธรรมเนียมล่วงหน้าช่วยให้ผู้ขายทราบกำไรสุทธิจริง สามารถกำหนดราคาขายให้เหมาะสมกับต้นทุน และวางแผนธุรกิจอย่างแม่นยำ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียม Shopee/Lazada Seller Fee',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-shopee-lazada-seller-fee">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-blue-100 bg-blue-50 p-4">
      <p class="text-sm font-semibold text-blue-700">คำนวณค่าธรรมเนียม Shopee/Lazada — ค่าธรรมเนียมผู้ขายออนไลน์</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: ค่าธรรมเนียม = มูลค่าออเดอร์ × อัตราธรรมเนียม% | รายได้สุทธิ = มูลค่าออเดอร์ − ค่าธรรมเนียม</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าธรรมเนียม Shopee/Lazada Seller Fee ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกมูลค่าคำสั่งซื้อและอัตราธรรมเนียมของ Shopee/Lazada เพื่อดูค่าธรรมเนียมที่หักและรายได้ที่สุทธิ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="shopee-form" class="space-y-5">
        <p id="shopee-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="shopee-amount" class="mb-1 block text-sm font-medium text-gray-700">มูลค่าคำสั่งซื้อ (บาท)</label>
            <input type="text" id="shopee-amount" inputmode="numeric" placeholder="เช่น 2,500"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="shopee-amount-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="shopee-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราธรรมเนียม (%)</label>
            <input type="text" id="shopee-rate" inputmode="decimal" placeholder="เช่น 3.5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="shopee-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
            <p class="mt-1 text-xs text-gray-500">ทั่วไป 2–5.5%</p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณค่าธรรมเนียม
        </button>
      </form>
    </div>

    <!-- Results Section -->
    <div id="shopee-results" class="mb-8 hidden rounded-lg border border-green-200 bg-green-50 p-6">
      <h2 class="mb-4 text-lg font-bold text-gray-900">ผลการคำนวณ</h2>
      <div class="space-y-3">
        <div class="flex justify-between border-b border-green-200 pb-2">
          <span class="text-gray-700">มูลค่าคำสั่งซื้อ</span>
          <span id="result-amount" class="font-semibold text-gray-900">0 บาท</span>
        </div>
        <div class="flex justify-between border-b border-green-200 pb-2">
          <span class="text-gray-700">อัตราธรรมเนียม</span>
          <span id="result-rate" class="font-semibold text-gray-900">0 %</span>
        </div>
        <div class="flex justify-between border-b border-red-300 pb-2 bg-red-50 p-2 rounded">
          <span class="font-medium text-red-700">ค่าธรรมเนียมที่หัก</span>
          <span id="result-fee" class="font-bold text-red-700">0 บาท</span>
        </div>
        <div class="flex justify-between bg-green-100 p-2 rounded font-bold">
          <span class="text-green-700">รายได้สุทธิจริง</span>
          <span id="result-net" class="text-green-700">0 บาท</span>
        </div>
        <div class="flex justify-between border-t border-green-200 pt-2 text-xs text-gray-600">
          <span>อัตราธรรมเนียมจริง</span>
          <span id="result-effective" class="font-semibold">0 %</span>
        </div>
      </div>
    </div>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="mb-4 text-lg font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="border-b border-gray-200 pb-4">
            <summary class="cursor-pointer font-semibold text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <p class="mt-2 text-sm text-gray-600">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <div class="mb-8 rounded-lg border border-amber-200 bg-amber-50 p-4">
      <p class="text-sm text-amber-800">
        <strong>หมายเหตุ:</strong> อัตราธรรมเนียมอาจแตกต่างตามประเภทสินค้า ประเภทร้าน และการใช้บริการเพิ่มเติมเช่น Shopee Fulfillment
      </p>
    </div>
  </article>

  <GuardedAdSlot position="after-content" class="my-8" />
  <RelatedCalculators currentPath="/คำนวณ-shopee-lazada-seller-fee/" limit={3} />
  <RelatedArticles limit={3} />
</BaseLayout>

<script>
  const form = document.getElementById('shopee-form') as HTMLFormElement;
  const resultsDiv = document.getElementById('shopee-results') as HTMLDivElement;
  const errorDiv = document.getElementById('shopee-error') as HTMLDivElement;

  const amountInput = document.getElementById('shopee-amount') as HTMLInputElement;
  const rateInput = document.getElementById('shopee-rate') as HTMLInputElement;

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');

      const amountStr = amountInput.value.replace(/,/g, '').trim();
      const rateStr = rateInput.value.trim();

      const amount = parseFloat(amountStr);
      const rate = parseFloat(rateStr);

      if (!amount || amount <= 0 || !rate || rate < 0 || rate > 100) {
        errorDiv.classList.remove('hidden');
        resultsDiv.classList.add('hidden');
        return;
      }

      const platformFee = Math.round((amount * rate / 100) * 100) / 100;
      const netRevenue = amount - platformFee;
      const effectiveRate = Math.round((platformFee / amount * 100) * 100) / 100;

      document.getElementById('result-amount')!.textContent = amount.toLocaleString('th-TH', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }) + ' บาท';
      document.getElementById('result-rate')!.textContent = rate.toFixed(2) + ' %';
      document.getElementById('result-fee')!.textContent = platformFee.toLocaleString('th-TH', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }) + ' บาท';
      document.getElementById('result-net')!.textContent = netRevenue.toLocaleString('th-TH', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }) + ' บาท';
      document.getElementById('result-effective')!.textContent = effectiveRate.toFixed(2) + ' %';

      resultsDiv.classList.remove('hidden');
    });
  }
</script>
