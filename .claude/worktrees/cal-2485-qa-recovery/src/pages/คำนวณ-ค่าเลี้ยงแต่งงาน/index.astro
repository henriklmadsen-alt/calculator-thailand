---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าเลี้ยงแต่งงาน 2569 | ราคาเมนูต่อคน | Kamnuanlek';
const pageDescription = 'คำนวณค่าเลี้ยงแต่งงาน โดยป้อนจำนวนแขก และราคาต่อหัว ออนไลน์ฟรี พร้อมคำแนะนำเลือกเมนูและสัดส่วนอาหาร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าเลี้ยงแต่งงาน/`;

const faqData = [
  {
    question: 'ประสบการณ์เลือกเมนูอาหารแต่งงาน?',
    answer: 'เมนูสำคัญสำหรับแต่งงาน: (1) ปีศาจอบสวน หรืออาหารนำ (2) ตัวเมนูหลัก: ได้เลือก 2-3 หลัก เช่น หมูย่าง ไก่ต้มครั่ง ปลากระพงทอด (3) ข้าวหอม (4) ซุปร้อน (5) ของหวาน: หวานไทย หรือเค้ก',
  },
  {
    question: 'ควรจัดสรรเมนูอาหารแต่งงานอย่างไร?',
    answer: 'แนะนำจัดสรร: น้ำยา 1 แก้ว ปีศาจ/ของคาวล่วงหน้า 1 ชิ้น เมนูหลัก 2 หลัก ข้าว ซุป และหวาน 1 หลัก ซึ่งคิดได้ประมาณ 1,200-1,500 บาท/คน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าเลี้ยงแต่งงาน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเลี้ยงแต่งงาน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าเลี้ยงแต่งงาน
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-pink-200 bg-pink-50 px-3 py-2">
      <p class="text-xs font-semibold text-pink-800">[เมนูอาหาร 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าเลี้ยงแต่งงาน โดยป้อนจำนวนแขกและราคาต่อหัว
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="guests" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนแขก (คน)
          </label>
          <input
            type="text"
            id="guests"
            inputmode="decimal"
            placeholder="เช่น 150"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 text-base"
          />
        </div>

        <div>
          <label for="price-per-person" class="block text-sm font-medium text-gray-700 mb-1">
            ราคาต่อคน (บาท)
          </label>
          <input
            type="text"
            id="price-per-person"
            inputmode="decimal"
            placeholder="เช่น 1200"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 text-base"
          />
        </div>

        <div>
          <label for="drinks" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าเครื่องดื่มแอลกอฮอล์ต่อคน (บาท)
          </label>
          <input
            type="text"
            id="drinks"
            inputmode="decimal"
            placeholder="เช่น 300"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 text-base"
          />
        </div>

        <div>
          <label for="service-charge-percent" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าเซอร์วิส (%)
          </label>
          <input
            type="text"
            id="service-charge-percent"
            inputmode="decimal"
            placeholder="เช่น 10"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 text-base"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-pink-600 text-white font-semibold rounded-md hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณรวม
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-8 border-t pt-6">
        <div class="grid gap-6 sm:grid-cols-3">
          <div class="text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าอาหาร</div>
            <div class="text-3xl font-bold text-pink-700" id="food-cost">-</div>
            <div class="text-xs text-gray-600">บาท</div>
          </div>
          <div class="text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าเครื่องดื่ม</div>
            <div class="text-3xl font-bold text-pink-700" id="drinks-cost">-</div>
            <div class="text-xs text-gray-600">บาท</div>
          </div>
          <div class="text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าเซอร์วิส</div>
            <div class="text-3xl font-bold text-pink-700" id="service-cost">-</div>
            <div class="text-xs text-gray-600">บาท</div>
          </div>
        </div>

        <div class="mt-6 bg-pink-50 rounded-lg p-6 text-center">
          <div class="text-sm text-gray-600 mb-2">ค่าเลี้ยงรวมทั้งหมด</div>
          <div class="text-5xl font-bold text-pink-700 mb-2">
            <span id="total-cost">-</span>
          </div>
          <div class="text-sm text-gray-600">บาท</div>
        </div>

        <div class="mt-4 text-sm text-gray-700 bg-blue-50 border border-blue-200 rounded p-4">
          <strong>รายละเอียด:</strong>
          <ul class="mt-2 space-y-1">
            <li>จำนวนแขก: <span id="show-guests">-</span> คน</li>
            <li>ค่าอาหารต่อคน: <span id="show-price">-</span> บาท</li>
            <li>ค่าเดือนเครื่องดื่ม: <span id="show-drinks-price">-</span> บาท/คน</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators />
    <RelatedArticles />
  </article>
</BaseLayout>

<script>
  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const guests = parseFloat(document.getElementById('guests')?.value || 0);
    const pricePerPerson = parseFloat(document.getElementById('price-per-person')?.value || 0);
    const drinks = parseFloat(document.getElementById('drinks')?.value || 0);
    const servicePercent = parseFloat(document.getElementById('service-charge-percent')?.value || 10);

    if (guests <= 0 || pricePerPerson <= 0) {
      alert('กรุณาป้อนจำนวนแขกและราคาต่อคน');
      return;
    }

    const foodCost = guests * pricePerPerson;
    const drinksCost = guests * drinks;
    const subtotal = foodCost + drinksCost;
    const serviceCost = subtotal * (servicePercent / 100);
    const totalCost = subtotal + serviceCost;

    document.getElementById('food-cost').textContent = Math.round(foodCost).toLocaleString('th-TH');
    document.getElementById('drinks-cost').textContent = Math.round(drinksCost).toLocaleString('th-TH');
    document.getElementById('service-cost').textContent = Math.round(serviceCost).toLocaleString('th-TH');
    document.getElementById('total-cost').textContent = Math.round(totalCost).toLocaleString('th-TH');

    document.getElementById('show-guests').textContent = guests.toLocaleString('th-TH');
    document.getElementById('show-price').textContent = pricePerPerson.toLocaleString('th-TH');
    document.getElementById('show-drinks-price').textContent = drinks.toLocaleString('th-TH');

    document.getElementById('result').classList.remove('hidden');
  });
</script>
