---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เครื่องคำนวณรถยนต์ — ผ่อนรถ ภาษีรถ ประกันภัย ต้นทุนจริง | Kamnuanlek"
  description="เครื่องคำนวณรถยนต์ฟรีครบชุด คำนวณค่างวดผ่อนรถ ภาษีรถประจำปี พ.ร.บ. ประกันภัยชั้น 1-3 ค่าน้ำมัน และต้นทุนการเป็นเจ้าของรถจริง อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เครื่องคำนวณรถยนต์ — ผ่อนรถ ภาษีรถ ประกันภัย ต้นทุนจริง", "item": "https://www.kamnuanlek.com/เครื่องคำนวณรถยนต์/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณรถยนต์</h1>
    <p class="text-xl text-gray-600 mb-12">
      วางแผนซื้อรถและคำนวณค่าใช้จ่ายในการครอบครองรถ ผ่อนรถ ภาษีรถ ค่าน้ำมัน และประกันภัย รวมไว้ในที่เดียว
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณผ่อนรถ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🚗</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณผ่อนรถ</h3>
        <p class="text-gray-600 mb-3">คำนวณค่างวดรายเดือน ราคารวมทั้งสิ้น และดอกเบี้ยที่ต้องจ่ายตลอดระยะเวลาสัญญา</p>
        <span class="text-primary-600 font-medium">คำนวณค่างวด →</span>
      </a>

      <a href="/คำนวณภาษีรถยนต์/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">📋</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณภาษีรถยนต์ประจำปี</h3>
        <p class="text-gray-600 mb-3">คำนวณภาษีรถยนต์ประจำปีตามขนาดเครื่องยนต์ (ซีซี) และประเภทรถ</p>
        <span class="text-primary-600 font-medium">คำนวณภาษีรถ →</span>
      </a>

      <a href="/คำนวณค่าน้ำมัน/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">⛽</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณค่าน้ำมัน</h3>
        <p class="text-gray-600 mb-3">คำนวณค่าน้ำมันรายเดือนตามระยะทางที่ขับและอัตราสิ้นเปลืองของรถ</p>
        <span class="text-primary-600 font-medium">คำนวณค่าน้ำมัน →</span>
      </a>

      <a href="/คำนวณค่าประกันรถ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🛡️</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณค่าประกันรถยนต์</h3>
        <p class="text-gray-600 mb-3">ประมาณเบี้ยประกันรถยนต์ชั้น 1 ตามมูลค่ารถและประวัติผู้ขับขี่</p>
        <span class="text-primary-600 font-medium">ประมาณเบี้ยประกัน →</span>
      </a>
    </div>

    <div class="p-6 bg-blue-50 border border-blue-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">ต้นทุนรวมการครอบครองรถยนต์</h2>
      <p class="text-gray-700 mb-4">ค่าใช้จ่ายรายเดือนโดยประมาณสำหรับรถราคา 1 ล้านบาท (ผ่อน 60 เดือน ดอกเบี้ย 4%):</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-4 bg-white rounded-lg text-center border border-blue-100">
          <p class="font-bold text-gray-900 text-lg">~18,400</p>
          <p class="text-gray-600 text-sm">บาท/เดือน ค่างวด</p>
        </div>
        <div class="p-4 bg-white rounded-lg text-center border border-blue-100">
          <p class="font-bold text-gray-900 text-lg">~1,500</p>
          <p class="text-gray-600 text-sm">บาท/เดือน ประกันภัย</p>
        </div>
        <div class="p-4 bg-white rounded-lg text-center border border-blue-100">
          <p class="font-bold text-gray-900 text-lg">~3,000</p>
          <p class="text-gray-600 text-sm">บาท/เดือน ค่าน้ำมัน</p>
        </div>
        <div class="p-4 bg-white rounded-lg text-center border border-blue-100">
          <p class="font-bold text-gray-900 text-lg">~500</p>
          <p class="text-gray-600 text-sm">บาท/เดือน ภาษีรถ</p>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/เปรียบเทียบสินเชื่อ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏦 คู่มือเปรียบเทียบสินเชื่อ</span>
          <p class="text-gray-600 text-sm mt-2">เปรียบเทียบสินเชื่อรถกับสินเชื่อบุคคล</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 ศูนย์รวมเครื่องคำนวณการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">เครื่องมือการเงินทุกประเภทในที่เดียว</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
