---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณการเพิ่มมูลค่าคอนโด 2569 | การเติบโตราคา | ค่าขายได้ | Kamnuanlek';
const pageDescription = 'คำนวณมูลค่าคอนโดในอนาคต ตามอัตราการเติบโตรายปี ประเมินกำไรจากการถือครองและขายคอนโด ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณการเพิ่มมูลค่าคอนโด/`;

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณการเพิ่มมูลค่าคอนโด',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณการเพิ่มมูลค่าคอนโด">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณการเพิ่มมูลค่าคอนโด ปี 2569
    </h1>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="condo-appreciation-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="condo-price" class="block text-sm font-medium text-gray-700 mb-1">ราคาซื้อคอนโด (บาท)</label>
            <input id="condo-price" type="text" inputmode="numeric" placeholder="เช่น 2,500,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="annual-growth" class="block text-sm font-medium text-gray-700 mb-1">อัตราเติบโต/ปี (%)</label>
            <input id="annual-growth" type="text" inputmode="decimal" placeholder="เช่น 3.5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" value="3.5" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="holding-years" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลาถือครอง (ปี)</label>
            <input id="holding-years" type="text" inputmode="numeric" placeholder="เช่น 10" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" value="10" />
          </div>
          <div>
            <label for="selling-cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าธรรมเนียมขาย (%)</label>
            <input id="selling-cost" type="text" inputmode="decimal" placeholder="เช่น 2" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" value="2" />
          </div>
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณการเพิ่มมูลค่า
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 mb-6">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">มูลค่าประมาณ</div>
            <div id="res-future-price" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-emerald-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">กำไรสุทธิ</div>
            <div id="res-net-profit" class="text-xl font-bold text-emerald-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ราคาซื้อเดิม</span>
            <span id="res-original-price" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">มูลค่าปัจจุบัน</span>
            <span id="res-current-value" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าธรรมเนียมขาย</span>
            <span id="res-transaction-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">เงินหลังขาย</span>
            <span id="res-net-amount" class="font-bold text-primary-700">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-700 font-semibold">กำไรทั้งหมด</span>
            <span id="res-total-profit" class="font-bold text-lg text-emerald-700">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ROI (%)</span>
            <span id="res-roi" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.dol.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมที่ดิน (dol.go.th)</a> — อัตราค่าธรรมเนียมการโอนและจดทะเบียนสิทธิ์</li>
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยสินเชื่อบ้านอ้างอิง MRR/MLR</li>
      </ul>
    </div>
    <RelatedCalculators currentHref="/คำนวณการเพิ่มมูลค่าคอนโด/" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#condo-appreciation-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const condoPrice = parseNumber(document.querySelector('#condo-price')?.value || '');
    const annualGrowth = parseNumber(document.querySelector('#annual-growth')?.value || '');
    const holdingYears = parseNumber(document.querySelector('#holding-years')?.value || '');
    const sellingCost = parseNumber(document.querySelector('#selling-cost')?.value || '');

    if (!(Number.isFinite(condoPrice) && condoPrice > 0 && Number.isFinite(annualGrowth) && annualGrowth >= 0 && Number.isFinite(holdingYears) && holdingYears > 0 && Number.isFinite(sellingCost) && sellingCost >= 0)) {
      results?.classList.add('hidden');
      return;
    }

    const rate = annualGrowth / 100;
    const futurePrice = condoPrice * Math.pow(1 + rate, holdingYears);
    const transactionCost = futurePrice * (sellingCost / 100);
    const netAmount = futurePrice - transactionCost;
    const totalProfit = netAmount - condoPrice;
    const roi = (totalProfit / condoPrice) * 100;

    document.querySelector('#res-future-price').textContent = formatCurrency(futurePrice);
    document.querySelector('#res-net-profit').textContent = formatCurrency(totalProfit);
    document.querySelector('#res-original-price').textContent = formatCurrency(condoPrice);
    document.querySelector('#res-current-value').textContent = formatCurrency(futurePrice);
    document.querySelector('#res-transaction-cost').textContent = formatCurrency(transactionCost);
    document.querySelector('#res-net-amount').textContent = formatCurrency(netAmount);
    document.querySelector('#res-total-profit').textContent = formatCurrency(totalProfit);
    document.querySelector('#res-roi').textContent = roi.toFixed(2) + '%';

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
