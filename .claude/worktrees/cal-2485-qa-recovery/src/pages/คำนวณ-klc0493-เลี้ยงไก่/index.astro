---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณต้นทุนการเลี้ยงไก่ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการเลี้ยงไก่เนื้อ ไก่ไข่ ค่าลูกไก่ อาหาร วัคซีน กำไรต่อรุ่น';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0493-เลี้ยงไก่/`;
const faqData = [
  { question: 'ไก่เนื้อกับไก่ไข่อย่างไหนกำไรดีกว่า?', answer: 'ไก่เนื้อคืนทุนเร็ว 45-50 วัน กำไร 5-15 บาท/กก. ไก่ไข่ให้รายได้สม่ำเสมอ 300+ วัน/ฝูง แต่ลงทุนสูงกว่า ไก่ไข่เหมาะระยะยาว ไก่เนื้อเหมาะต้องการเงินสดเร็ว' },
  { question: 'FCR (Feed Conversion Ratio) ของไก่เนื้อควรเป็นเท่าไหร่?', answer: 'FCR ไก่เนื้อมาตรฐาน 1.6-1.8 หมายความว่าต้องอาหาร 1.6-1.8 กก. เพื่อให้ไก่เพิ่มน้ำหนัก 1 กก. FCR ต่ำกว่า 1.6 ถือว่าดีมาก' },
  { question: 'โรคหลักไก่ที่ต้องระวังมีอะไรบ้าง?', answer: 'ไข้หวัดนก (H5N1) นิวคาสเซิล IB (Infectious Bronchitis) Marek กัมโบโร ต้องฉีดวัคซีนตามโปรแกรม ปิดระบบฟาร์ม biosecurity เข้มงวด' },
  { question: 'เลี้ยงไก่บ้านอารมณ์ดีจะได้ราคาสูงกว่าไหม?', answer: 'ไก่บ้านอารมณ์ดี ไก่ไข่อารมณ์ดี ราคาขายสูงกว่าไก่ฟาร์ม 30-80% ตลาดออร์แกนิก ร้านอาหารพรีเมียม โรงแรม มีความต้องการสูงและเติบโตต่อเนื่อง' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนการเลี้ยงไก่">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนการเลี้ยงไก่</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนและกำไรการเลี้ยงไก่ต่อรุ่นการผลิต</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="chicken_count" class="block text-sm font-medium text-gray-700 mb-1">จำนวนไก่ (ตัว)</label><input type="number" id="chicken_count" min="1" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="chick_price" class="block text-sm font-medium text-gray-700 mb-1">ราคาลูกไก่/ตัว (บาท)</label><input type="text" id="chick_price" inputmode="decimal" placeholder="เช่น 30" value="30" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="chicken_feed_head" class="block text-sm font-medium text-gray-700 mb-1">ค่าอาหาร+ยา/ตัว (บาท)</label><input type="text" id="chicken_feed_head" inputmode="decimal" placeholder="เช่น 100" value="100" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="chicken_sell_price" class="block text-sm font-medium text-gray-700 mb-1">ราคาขาย (บาท/ตัว)</label><input type="text" id="chicken_sell_price" inputmode="decimal" placeholder="เช่น 165" value="165" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวม/รุ่น</p><p id="chicken_total_cost" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">กำไร/รุ่น</p><p id="chicken_profit" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const count = parseFloat((document.getElementById('chicken_count') as HTMLInputElement).value) || 0;
      const chickPrice = parseFloat((document.getElementById('chick_price') as HTMLInputElement).value) || 0;
      const feedHead = parseFloat((document.getElementById('chicken_feed_head') as HTMLInputElement).value) || 0;
      const sellPrice = parseFloat((document.getElementById('chicken_sell_price') as HTMLInputElement).value) || 0;
      const costPerHead = chickPrice + feedHead;
      const totalCost = costPerHead * count;
      const totalRevenue = sellPrice * count;
      const profit = totalRevenue - totalCost;
      (document.getElementById('chicken_total_cost') as HTMLElement).textContent = Math.round(totalCost).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('chicken_profit') as HTMLElement).textContent = Math.round(profit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('chicken-farming-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
