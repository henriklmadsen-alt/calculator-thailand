---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เครื่องคำนวณสุขภาพ — BMI แคลอรี น้ำหนักมาตรฐาน คำนวณวันคลอด | Kamnuanlek"
  description="เครื่องคำนวณสุขภาพฟรี คำนวณ BMI น้ำหนักมาตรฐาน แคลอรีต่อวัน วันคลอด อายุครรภ์ และตัวชี้วัดสุขภาพสำหรับคนไทย อัปเดตตามเกณฑ์กรมอนามัย"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เครื่องคำนวณสุขภาพ — BMI แคลอรี น้ำหนักมาตรฐาน คำนวณวันคลอด", "item": "https://www.kamnuanlek.com/เครื่องคำนวณสุขภาพ/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณสุขภาพ</h1>
    <p class="text-xl text-gray-600 mb-12">
      คำนวณตัวชี้วัดสุขภาพได้ทันที BMI น้ำหนักที่เหมาะสม ปริมาณแคลอรีที่ต้องการ อายุ และเครื่องมือสำหรับคุณแม่ตั้งครรภ์ ทั้งหมดฟรีและแม่นยำ
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณ-bmi/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">⚖️</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณ BMI</h3>
        <p class="text-gray-600 mb-3">คำนวณดัชนีมวลกาย (BMI) และตรวจสอบว่าน้ำหนักของคุณอยู่ในเกณฑ์สุขภาพดีตามส่วนสูงหรือไม่</p>
        <span class="text-primary-600 font-medium">คำนวณ BMI →</span>
      </a>

      <a href="/คำนวณน้ำหนักที่เหมาะสม/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🎯</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณน้ำหนักที่เหมาะสม</h3>
        <p class="text-gray-600 mb-3">หาช่วงน้ำหนักที่เหมาะสมตามส่วนสูง อายุ และรูปร่าง</p>
        <span class="text-primary-600 font-medium">คำนวณ →</span>
      </a>

      <a href="/คำนวณแคลอรี/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🥗</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณแคลอรี</h3>
        <p class="text-gray-600 mb-3">คำนวณปริมาณแคลอรีที่ร่างกายต้องการต่อวัน ตามอายุ น้ำหนัก ส่วนสูง และระดับกิจกรรม</p>
        <span class="text-primary-600 font-medium">คำนวณแคลอรี →</span>
      </a>

      <a href="/คำนวณวันคลอด/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">👶</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณวันคลอด</h3>
        <p class="text-gray-600 mb-3">คำนวณวันกำหนดคลอดจากวันแรกของประจำเดือนครั้งสุดท้ายหรือวันปฏิสนธิ</p>
        <span class="text-primary-600 font-medium">คำนวณวันคลอด →</span>
      </a>

      <a href="/คำนวณอายุ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🎂</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณอายุ</h3>
        <p class="text-gray-600 mb-3">คำนวณอายุแบบแม่นยำเป็นปี เดือน และวัน เหมาะสำหรับเอกสารราชการและแบบฟอร์มทางการแพทย์</p>
        <span class="text-primary-600 font-medium">คำนวณอายุ →</span>
      </a>

      <a href="/คำนวณเงินเกษียณ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🌴</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณวางแผนเกษียณ</h3>
        <p class="text-gray-600 mb-3">คำนวณว่าต้องออมเงินเท่าไรเพื่อเกษียณอย่างสบายในประเทศไทย</p>
        <span class="text-primary-600 font-medium">วางแผนเกษียณ →</span>
      </a>
    </div>

    <div class="p-6 bg-pink-50 border border-pink-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">เกณฑ์ BMI (อ้างอิงสำหรับชาวเอเชีย)</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-4 bg-blue-100 rounded-lg text-center">
          <p class="text-2xl font-bold text-blue-700">ต่ำกว่า 18.5</p>
          <p class="text-gray-700 font-medium mt-1">น้ำหนักน้อยเกินไป</p>
        </div>
        <div class="p-4 bg-green-100 rounded-lg text-center">
          <p class="text-2xl font-bold text-green-700">18.5–22.9</p>
          <p class="text-gray-700 font-medium mt-1">ปกติ</p>
        </div>
        <div class="p-4 bg-yellow-100 rounded-lg text-center">
          <p class="text-2xl font-bold text-yellow-700">23–24.9</p>
          <p class="text-gray-700 font-medium mt-1">น้ำหนักเกิน</p>
        </div>
        <div class="p-4 bg-red-100 rounded-lg text-center">
          <p class="text-2xl font-bold text-red-700">25 ขึ้นไป</p>
          <p class="text-gray-700 font-medium mt-1">อ้วน</p>
        </div>
      </div>
      <p class="text-gray-600 text-sm mt-3">* ชาวเอเชียมีความเสี่ยงต่อสุขภาพที่ค่า BMI ต่ำกว่าชาวตะวันตกในระดับเดียวกัน</p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/เครื่องคำนวณการเงินชั้นยอด/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 เครื่องมือการเงิน 10 อันดับ</span>
          <p class="text-gray-600 text-sm mt-2">รวมเครื่องคำนวณวางแผนเกษียณ</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 เครื่องคำนวณการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">ภาษี สินเชื่อ และเครื่องมือออมเงิน</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
