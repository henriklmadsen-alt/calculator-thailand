---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณตารางล้างน้ำหล่อเย็นรถยนต์ ปี 2569 | ช่วงเปลี่ยนน้ำหล่อเย็น | Kamnuanlek';
const pageDescription = 'คำนวณช่วงเปลี่ยนน้ำหล่อเย็นรถยนต์ตามประเภทน้ำหล่อเย็นและระยะทาง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณตารางล้างน้ำหล่อเย็น/`;

const faqData = [
  {
    question: 'น้ำหล่อเย็นรถยนต์ควรเปลี่ยนทุกกี่กิโลเมตร?',
    answer: 'ขึ้นอยู่กับประเภทน้ำหล่อเย็น: น้ำหล่อเย็นแบบทั่วไป (สีเขียว) ควรเปลี่ยนทุก 30,000 กม. หรือ 2 ปี แบบ Extended-Life (สีส้ม/ชมพู) ทุก 60,000 กม. หรือ 5 ปี และแบบ OAT (Organic Acid Technology) ทุก 150,000 กม. ทั้งนี้ควรยึดเงื่อนไขที่ถึงก่อนระหว่างระยะทางและเวลา',
  },
  {
    question: 'น้ำหล่อเย็นสีเขียว สีส้ม และ OAT แตกต่างกันอย่างไร?',
    answer: 'น้ำหล่อเย็นสีเขียว (Conventional) ใช้สารยับยั้งการกัดกร่อนแบบ Inorganic มีอายุสั้นที่สุด เหมาะกับรถรุ่นเก่า น้ำหล่อเย็นสีส้ม (Extended-Life/HOAT) ผสมสารอินทรีย์และอนินทรีย์ อายุปานกลาง ส่วน OAT ใช้สารอินทรีย์ล้วน อายุยาวที่สุด เหมาะกับรถยนต์สมัยใหม่ ควรใช้ชนิดที่ผู้ผลิตรถแนะนำเท่านั้น',
  },
  {
    question: 'ผลเสียของการไม่เปลี่ยนน้ำหล่อเย็นตามกำหนดคืออะไร?',
    answer: 'น้ำหล่อเย็นที่เสื่อมสภาพสูญเสียคุณสมบัติยับยั้งการกัดกร่อน ทำให้เกิดสนิมในระบบหล่อเย็น เส้นยางน้ำเสื่อม เทอร์โมสตัทเสียหาย และที่ร้ายแรงที่สุดคือเสื่อมสภาพของหัวเสื้อสูบ ซึ่งมีค่าซ่อมสูงมาก การเปลี่ยนน้ำหล่อเย็นตามกำหนดช่วยประหยัดค่าซ่อมบำรุงในระยะยาวได้มาก',
  },
  {
    question: 'ควรล้างระบบหล่อเย็นก่อนเติมน้ำหล่อเย็นใหม่หรือไม่?',
    answer: 'แนะนำให้ล้างระบบหล่อเย็น (Coolant Flush) ก่อนเติมน้ำหล่อเย็นใหม่เสมอ เพื่อกำจัดตะกอน สนิม และน้ำหล่อเย็นเก่าที่เหลืออยู่ การล้างระบบทำให้น้ำหล่อเย็นใหม่ทำงานได้เต็มประสิทธิภาพและยืดอายุอุปกรณ์ในระบบหล่อเย็น โดยเฉพาะหม้อน้ำและปั๊มน้ำ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณตารางล้างน้ำหล่อเย็นรถยนต์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณตารางล้างน้ำหล่อเย็นรถยนต์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณตารางล้างน้ำหล่อเย็นรถยนต์
    </h1>
    <p class="text-gray-600 mb-6">
      คำนวณกำหนดการเปลี่ยนน้ำหล่อเย็นตามประเภทและระยะทาง พร้อมแจ้งเตือนเมื่อเกินกำหนด
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="calculator-form" class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="coolant-type" class="block text-sm font-medium text-gray-700 mb-1">
              ประเภทน้ำหล่อเย็น
            </label>
            <select
              id="coolant-type"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              <option value="conventional">ทั่วไป — สีเขียว (30,000 กม. / 2 ปี)</option>
              <option value="extended">Extended-Life — สีส้ม (60,000 กม. / 5 ปี)</option>
              <option value="oat">OAT — อินทรีย์ (150,000 กม.)</option>
            </select>
          </div>
          <div>
            <label for="last-change-year" class="block text-sm font-medium text-gray-700 mb-1">
              ปีที่เปลี่ยนครั้งล่าสุด (พ.ศ.)
            </label>
            <input
              type="text"
              id="last-change-year"
              inputmode="numeric"
              placeholder="เช่น 2567"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="last-change-month" class="block text-sm font-medium text-gray-700 mb-1">
              เดือนที่เปลี่ยนครั้งล่าสุด
            </label>
            <select
              id="last-change-month"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              <option value="1">มกราคม</option>
              <option value="2">กุมภาพันธ์</option>
              <option value="3">มีนาคม</option>
              <option value="4" selected>เมษายน</option>
              <option value="5">พฤษภาคม</option>
              <option value="6">มิถุนายน</option>
              <option value="7">กรกฎาคม</option>
              <option value="8">สิงหาคม</option>
              <option value="9">กันยายน</option>
              <option value="10">ตุลาคม</option>
              <option value="11">พฤศจิกายน</option>
              <option value="12">ธันวาคม</option>
            </select>
          </div>
          <div>
            <label for="last-mileage" class="block text-sm font-medium text-gray-700 mb-1">
              เลขไมล์ตอนที่เปลี่ยนครั้งล่าสุด (กม.)
            </label>
            <input
              type="text"
              id="last-mileage"
              inputmode="decimal"
              placeholder="เช่น 50000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="monthly-km" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะทางเฉลี่ยต่อเดือน (กม.)
            </label>
            <input
              type="text"
              id="monthly-km"
              inputmode="decimal"
              placeholder="เช่น 2000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="service-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าน้ำหล่อเย็น + ค่าล้างระบบ (บาท)
            </label>
            <input
              type="text"
              id="service-cost"
              inputmode="decimal"
              placeholder="เช่น 1500"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>
        <button
          type="button"
          id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ
        </button>
      </form>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-blue-700 font-medium mb-1">กำหนดเปลี่ยนครั้งถัดไป (ตามระยะ)</div>
            <div id="res-next-km" class="text-2xl font-bold text-blue-800">-</div>
            <div class="text-xs text-blue-600 mt-1">กิโลเมตร</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4">
            <div class="text-sm text-purple-700 font-medium mb-1">กำหนดเปลี่ยนครั้งถัดไป (ตามเวลา)</div>
            <div id="res-next-date" class="text-2xl font-bold text-purple-800">-</div>
            <div class="text-xs text-purple-600 mt-1">เดือน/ปี พ.ศ.</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4">
            <div class="text-sm text-green-700 font-medium mb-1">ระยะทางที่เหลือ</div>
            <div id="res-remaining-km" class="text-2xl font-bold text-green-800">-</div>
            <div class="text-xs text-green-600 mt-1">กิโลเมตร</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4">
            <div class="text-sm text-orange-700 font-medium mb-1">ค่าใช้จ่ายที่คาดการณ์</div>
            <div id="res-cost" class="text-2xl font-bold text-orange-800">-</div>
            <div class="text-xs text-orange-600 mt-1">บาท</div>
          </div>
        </div>
        <div id="status-panel" class="rounded-lg p-4 border">
          <div id="status-label" class="text-sm font-medium mb-1">สถานะน้ำหล่อเย็น</div>
          <div id="status-message" class="text-base font-semibold">-</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ความสำคัญของการเปลี่ยนน้ำหล่อเย็นตามกำหนด</h2>
      <p>
        น้ำหล่อเย็น (Coolant) ทำหน้าที่ควบคุมอุณหภูมิเครื่องยนต์และป้องกันการกัดกร่อนของโลหะในระบบหล่อเย็น
        เมื่อเวลาผ่านไป สารยับยั้งการกัดกร่อนในน้ำหล่อเย็นจะเสื่อมประสิทธิภาพ
        ทำให้ระบบหล่อเย็นเสี่ยงต่อความเสียหาย
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">กำหนดการเปลี่ยนน้ำหล่อเย็นตามประเภท</h3>
      <div class="bg-gray-50 rounded-lg p-4 my-4 space-y-2">
        <p class="font-medium">ทั่วไป (สีเขียว): ทุก 30,000 กม. หรือ 2 ปี (อย่างใดถึงก่อน)</p>
        <p class="font-medium">Extended-Life (สีส้ม): ทุก 60,000 กม. หรือ 5 ปี (อย่างใดถึงก่อน)</p>
        <p class="font-semibold text-primary-700">OAT: ทุก 150,000 กม. (ตรวจสอบตามคู่มือรถ)</p>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สัญญาณที่น้ำหล่อเย็นต้องเปลี่ยน</h3>
      <p>
        สัญญาณที่ควรระวัง ได้แก่ น้ำหล่อเย็นเปลี่ยนสีจากสีเดิมเป็นสีน้ำตาลหรือขุ่น
        ไฟเตือนอุณหภูมิเครื่องยนต์ขึ้น มีตะกอนหรือสนิมในน้ำหล่อเย็น
        และน้ำหล่อเย็นมีกลิ่นไหม้หรือกลิ่นผิดปกติ ควรตรวจสอบน้ำหล่อเย็นทุกครั้งที่เข้าศูนย์บริการ
      </p>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณตารางล้างน้ำหล่อเย็น/" />
    <RelatedCalculators currentHref="/คำนวณตารางล้างน้ำหล่อเย็น/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการทั่วไป
      กำหนดการเปลี่ยนน้ำหล่อเย็นที่แน่นอนควรอ้างอิงตามคู่มือรถยนต์ของผู้ผลิต
      ควรให้ช่างผู้เชี่ยวชาญตรวจสอบสภาพน้ำหล่อเย็นและระบบหล่อเย็นเป็นประจำ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number, decimals = 2): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: decimals, maximumFractionDigits: decimals }).format(n);
    }

    const THAI_MONTHS = [
      'มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน',
      'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม',
    ];

    // Max km and max years per coolant type
    const COOLANT_LIMITS: Record<string, { km: number; years: number }> = {
      conventional: { km: 30000, years: 2 },
      extended: { km: 60000, years: 5 },
      oat: { km: 150000, years: 999 }, // time-based N/A for OAT typically
    };

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const coolantType = (document.getElementById('coolant-type') as HTMLSelectElement).value;
      const lastYear = parseNum((document.getElementById('last-change-year') as HTMLInputElement).value);
      const lastMonth = parseInt((document.getElementById('last-change-month') as HTMLSelectElement).value, 10);
      const lastMileage = parseNum((document.getElementById('last-mileage') as HTMLInputElement).value);
      const monthlyKm = parseNum((document.getElementById('monthly-km') as HTMLInputElement).value);
      const serviceCost = parseNum((document.getElementById('service-cost') as HTMLInputElement).value);

      if (lastYear <= 0 || lastMileage <= 0 || monthlyKm <= 0) {
        alert('กรุณากรอกปีที่เปลี่ยน เลขไมล์ตอนเปลี่ยน และระยะทางต่อเดือน');
        return;
      }

      const limits = COOLANT_LIMITS[coolantType] ?? COOLANT_LIMITS['conventional'];
      const nextDueKm = lastMileage + limits.km;

      // Current total months in BE
      const now = new Date();
      const currentYear = now.getFullYear() + 543;
      const currentMonth = now.getMonth() + 1;
      const currentTotalMonths = currentYear * 12 + (currentMonth - 1);

      // Date-based due
      const lastTotalMonths = lastYear * 12 + (lastMonth - 1);
      const dateDueTotalMonths = lastTotalMonths + (limits.years < 100 ? limits.years * 12 : 9999);
      const dateDueYear = Math.floor(dateDueTotalMonths / 12);
      const dateDueMonth = (dateDueTotalMonths % 12) + 1;

      // Current mileage (estimated)
      const monthsElapsed = currentTotalMonths - lastTotalMonths;
      const currentMileageEst = lastMileage + monthsElapsed * monthlyKm;
      const remainingKm = Math.max(0, nextDueKm - currentMileageEst);

      // Months until km-based due
      const monthsUntilKm = monthlyKm > 0 ? remainingKm / monthlyKm : 999;
      const monthsUntilDate = dateDueTotalMonths < 9000 * 12 ? dateDueTotalMonths - currentTotalMonths : 999;
      const monthsUntilSooner = Math.min(monthsUntilKm, monthsUntilDate);

      (document.getElementById('res-next-km') as HTMLElement).textContent = fmt(nextDueKm, 0);
      (document.getElementById('res-next-date') as HTMLElement).textContent =
        limits.years < 100 ? `${THAI_MONTHS[dateDueMonth - 1]} ${dateDueYear}` : 'ไม่ใช้';
      (document.getElementById('res-remaining-km') as HTMLElement).textContent = fmt(remainingKm, 0);
      (document.getElementById('res-cost') as HTMLElement).textContent =
        serviceCost > 0 ? fmt(serviceCost, 0) : 'ไม่ระบุ';

      const panel = document.getElementById('status-panel') as HTMLElement;
      const label = document.getElementById('status-label') as HTMLElement;
      const message = document.getElementById('status-message') as HTMLElement;

      const isOverdue = monthsUntilSooner <= 0 || remainingKm <= 0;
      const isDueSoon = monthsUntilSooner <= 3 || remainingKm <= (monthlyKm > 0 ? monthlyKm * 3 : 6000);

      if (isOverdue) {
        panel.className = 'rounded-lg p-4 border border-red-300 bg-red-50';
        label.className = 'text-sm font-medium mb-1 text-red-700';
        label.textContent = 'สถานะน้ำหล่อเย็น — เกินกำหนดแล้ว!';
        message.className = 'text-base font-semibold text-red-800';
        message.textContent = 'น้ำหล่อเย็นเกินกำหนดเปลี่ยน — ควรนัดบริการโดยเร็ว';
      } else if (isDueSoon) {
        panel.className = 'rounded-lg p-4 border border-orange-300 bg-orange-50';
        label.className = 'text-sm font-medium mb-1 text-orange-700';
        label.textContent = 'สถานะน้ำหล่อเย็น — ใกล้ถึงกำหนด';
        message.className = 'text-base font-semibold text-orange-800';
        message.textContent = `ใกล้ถึงกำหนดเปลี่ยน — ควรนัดบริการภายใน ${fmt(Math.max(0, monthsUntilSooner), 1)} เดือน`;
      } else {
        panel.className = 'rounded-lg p-4 border border-green-300 bg-green-50';
        label.className = 'text-sm font-medium mb-1 text-green-700';
        label.textContent = 'สถานะน้ำหล่อเย็น — ยังอยู่ในเกณฑ์ดี';
        message.className = 'text-base font-semibold text-green-800';
        message.textContent = `น้ำหล่อเย็นยังใช้ได้อีกประมาณ ${fmt(remainingKm, 0)} กม. (${fmt(monthsUntilSooner, 1)} เดือน)`;
      }

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
    });

    document.querySelectorAll('#calculator-form input').forEach(input => {
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
