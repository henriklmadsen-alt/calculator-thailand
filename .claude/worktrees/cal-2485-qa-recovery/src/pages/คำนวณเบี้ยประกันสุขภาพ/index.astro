---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import AffiliateCard from '../../components/templates/AffiliateCard.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเบี้ยประกันสุขภาพ ประมาณการค่าเบี้ยรายเดือน 2569 | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าเบี้ยประกันสุขภาพออนไลน์ฟรี ประมาณการเบี้ยรายเดือนและรายปี เปรียบเทียบแบบพื้นฐาน มาตรฐาน พรีเมียม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเบี้ยประกันสุขภาพ/`;

const faqData = [
  {
    question: 'เบี้ยประกันสุขภาพ vs บัตรประกันสุขภาพรัฐ ต่างกันอย่างไร?',
    answer: 'บัตรประกันสุขภาพรัฐเป็นระบบสวัสดิการของรัฐ คนไทยส่วนใหญ่เข้า UC/SSS ฟรี ส่วนประกันสุขภาพเอกชนเป็นเพิ่มเติมสำหรับความครอบคลุมมากขึ้นและสิ่งอำนวยความสะดวกพิเศษ',
  },
  {
    question: 'ควรเลือกแบบพื้นฐานหรือพรีเมียม?',
    answer: 'แบบพื้นฐานเหมาะสำหรับคนหนุ่มสาวและคนมีสุขภาพดี แบบพรีเมียมเหมาะสำหรับผู้สูงอายุและคนที่เจ็บป่วยบ่อย คนปกติสามารถเลือกแบบมาตรฐาน',
  },
  {
    question: 'เบี้ยประกันสุขภาพสูงขึ้นเมื่ออายุมากขึ้นหรือไม่?',
    answer: 'ใช่ เบี้ยประกันสุขภาพเพิ่มขึ้นตามอายุ เพราะความเสี่ยงต่อการเจ็บป่วยเพิ่มขึ้น ผู้สูงอายุจึงจ่ายเบี้ยสูงกว่าคนหนุ่มสาว',
  },
  {
    question: 'เบี้ยประกันประกัน Deductible และ Coinsurance คืออะไร?',
    answer: 'Deductible คือจำนวนเงินที่คุณต้องจ่ายเองก่อน ประกันจะจ่าย Coinsurance คือเปอร์เซ็นต์ที่คุณจ่ายเองหลังเกิน Deductible ประกันจ่ายส่วนที่เหลือ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเบี้ยประกันสุขภาพ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณเบี้ยประกันสุขภาพ',
  description: 'ขั้นตอนการประมาณเบี้ยประกันสุขภาพส่วนบุคคล ตามอายุ ประวัติสุขภาพ และความครอบคลุมที่ต้องการ',
  step: [
    { '@type': 'HowToStep', name: 'ระบุอายุและเพศ', text: 'กรอกอายุปัจจุบัน เพศ (ชาย/หญิง) เบี้ยประกันสุขภาพเพิ่มขึ้นตามอายุ ควรทำประกันตั้งแต่อายุน้อยเพื่อเบี้ยต่ำกว่า โดยทั่วไปเบี้ยอายุ 20-30 ปี ต่ำกว่าอายุ 50+ ปี ถึง 3-5 เท่า' },
    { '@type': 'HowToStep', name: 'เลือกระดับความครอบคลุม', text: 'เลือกแผนประกัน: แผนพื้นฐาน (ผู้ป่วยใน IPD อย่างเดียว) แผนกลาง (IPD + OPD บางส่วน) หรือแผนครอบคลุม (IPD + OPD + ทันตกรรม + แว่นตา) ยิ่งครอบคลุมมาก เบี้ยยิ่งสูง' },
    { '@type': 'HowToStep', name: 'ระบุวงเงินคุ้มครองต่อปี', text: 'กำหนดวงเงินสูงสุดที่ต้องการต่อปี เช่น 1 ล้านบาท 3 ล้านบาท หรือ 5 ล้านบาท สำหรับห้องผู้ป่วยใน แนะนำวงเงินอย่างน้อย 1 ล้านบาทสำหรับโรงพยาบาลเอกชนในกรุงเทพ' },
    { '@type': 'HowToStep', name: 'ตรวจสอบข้อยกเว้นโรคเดิม', text: 'แจ้งประวัติสุขภาพ (โรคเดิมที่เป็นก่อนทำประกัน) บริษัทประกันอาจไม่คุ้มครองโรคที่มีมาก่อน (Pre-existing conditions) หรือเพิ่มเบี้ยสำหรับบางโรค' },
    { '@type': 'HowToStep', name: 'เปรียบเทียบและเลือกแผน', text: 'เปรียบเทียบเบี้ยและความครอบคลุมจากหลายบริษัท (AXA, MSIG, FWD, SE Life, Cigna) สามารถนำเบี้ยประกันสุขภาพไปลดหย่อนภาษีได้สูงสุด 25,000 บาทต่อปี (ตามกฎหมาย พ.ร.บ. ภาษีเงินได้)' },
  ],
};
---

<BaseLayout noGenericHowTo={true} title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเบี้ยประกันสุขภาพ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณเบี้ยประกันสุขภาพ
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2">
      <p class="text-xs font-semibold text-blue-800">[อัปเดตตามอัตราเบี้ย 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      ประมาณการเบี้ยประกันสุขภาพรายเดือนและรายปี เปรียบเทียบแบบพื้นฐาน มาตรฐาน และพรีเมียม
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <!-- Age Group -->
        <div>
          <label for="age-group" class="block text-sm font-medium text-gray-700 mb-1">
            กลุ่มอายุ
          </label>
          <select id="age-group" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base">
            <option value="young">วัยรุ่น (18-25)</option>
            <option value="adult" selected>วัยทำงาน (26-40)</option>
            <option value="middle">วัยกลางคน (41-60)</option>
            <option value="senior">ผู้สูงอายุ (60+)</option>
          </select>
        </div>

        <!-- Coverage Type -->
        <div>
          <label for="coverage-type" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทความครอบคลุม
          </label>
          <select id="coverage-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base">
            <option value="individual">บุคคลเดียว</option>
            <option value="couple">คู่สามี-ภรรยา</option>
            <option value="family">ครอบครัว</option>
          </select>
        </div>

        <!-- Family Members (shown when family is selected) -->
        <div id="family-members-row" class="hidden">
          <label for="family-members" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนสมาชิก
          </label>
          <input type="number" id="family-members" min="2" max="10" value="4" placeholder="เช่น 4" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
      </div>

      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
        ประมาณการเบี้ย
      </button>

      <!-- Results -->
      <div id="result" class="hidden mt-8">
        <!-- Plan Comparison -->
        <div class="grid gap-4 sm:grid-cols-3 mb-6">
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
            <h3 class="font-semibold text-blue-900 mb-2 text-sm">แบบพื้นฐาน</h3>
            <div class="text-2xl font-bold text-blue-700 mb-2" id="basic-monthly">-</div>
            <div class="text-xs text-gray-600 mb-3">บาท/เดือน</div>
            <div class="text-xs text-gray-700 space-y-1">
              <div>คุ้มครอง: <span id="basic-coverage">-</span> บาท</div>
              <div>Deductible: <span id="basic-deductible">-</span> บาท</div>
            </div>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-lg p-4">
            <h3 class="font-semibold text-green-900 mb-2 text-sm">แบบมาตรฐาน</h3>
            <div class="text-2xl font-bold text-green-700 mb-2" id="standard-monthly">-</div>
            <div class="text-xs text-gray-600 mb-3">บาท/เดือน</div>
            <div class="text-xs text-gray-700 space-y-1">
              <div>คุ้มครอง: <span id="standard-coverage">-</span> บาท</div>
              <div>Deductible: <span id="standard-deductible">-</span> บาท</div>
            </div>
          </div>

          <div class="bg-purple-50 border border-purple-200 rounded-lg p-4">
            <h3 class="font-semibold text-purple-900 mb-2 text-sm">แบบพรีเมียม</h3>
            <div class="text-2xl font-bold text-purple-700 mb-2" id="premium-monthly">-</div>
            <div class="text-xs text-gray-600 mb-3">บาท/เดือน</div>
            <div class="text-xs text-gray-700 space-y-1">
              <div>คุ้มครอง: <span id="premium-coverage">-</span> บาท</div>
              <div>Deductible: <span id="premium-deductible">-</span> บาท</div>
            </div>
          </div>
        </div>

        <!-- Annual Comparison -->
        <div class="bg-gray-50 rounded-lg p-4 mb-6">
          <h3 class="font-semibold text-gray-900 mb-3 text-sm">เปรียบเทียบเบี้ยรายปี</h3>
          <div class="grid gap-4 sm:grid-cols-3 text-center text-sm">
            <div>
              <div class="text-gray-600 mb-1">แบบพื้นฐาน</div>
              <div id="basic-annual" class="font-bold text-lg text-gray-900">-</div>
              <div class="text-xs text-gray-500">บาท/ปี</div>
            </div>
            <div>
              <div class="text-gray-600 mb-1">แบบมาตรฐาน</div>
              <div id="standard-annual" class="font-bold text-lg text-gray-900">-</div>
              <div class="text-xs text-gray-500">บาท/ปี</div>
            </div>
            <div>
              <div class="text-gray-600 mb-1">แบบพรีเมียม</div>
              <div id="premium-annual" class="font-bold text-lg text-gray-900">-</div>
              <div class="text-xs text-gray-500">บาท/ปี</div>
            </div>
          </div>
        </div>

        <!-- Advice -->
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-2">คำแนะนำ</h3>
          <ul class="text-sm text-gray-700 list-disc pl-5 space-y-1" id="recommendations">
            <li>แบบพื้นฐานเหมาะสำหรับคนหนุ่มสาว</li>
            <li>แบบมาตรฐานสมดุลระหว่างราคาและความครอบคลุม</li>
            <li>แบบพรีเมียมเหมาะสำหรับผู้สูงอายุและผู้มีความเสี่ยง</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ประกันสุขภาพเอกชน คืออะไร</h2>

      <p>
        ประกันสุขภาพเอกชนเป็นสัญญาประกันระหว่างคุณและบริษัทประกัน
        หากคุณป่วยหรือต้องรักษาพยาบาล ประกันจะจ่ายค่าใช้จ่ายเพื่อเยียวยาเบาภาระการเงิน
        ประกันสุขภาพรัฐเพียงอย่างเดียวอาจไม่เพียงพอหากคุณต้องการระดับบริการหรือสิ่งอำนวยความสะดวกที่สูงกว่า
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">แบบแผนประกันสุขภาพ 3 ระดับ</h3>

      <div class="overflow-x-auto my-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b-2 border-gray-300">
              <th class="py-2 pr-4">แบบแผน</th>
              <th class="py-2 pr-4">ลักษณะ</th>
              <th class="py-2">เหมาะสำหรับ</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 font-medium">แบบพื้นฐาน</td>
              <td class="py-2 pr-4">เบี้ยต่ำ ความครอบคลุมจำกัด Deductible สูง</td>
              <td class="py-2">คนหนุ่มสาวสุขภาพดี</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 font-medium">แบบมาตรฐาน</td>
              <td class="py-2 pr-4">เบี้ยปานกลาง ความครอบคลุมดี Deductible ต่ำ</td>
              <td class="py-2">คนทำงาน ครอบครัว ปกติ</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 font-medium">แบบพรีเมียม</td>
              <td class="py-2 pr-4">เบี้ยสูง ความครอบคลุมครบถ้วน Deductible 0</td>
              <td class="py-2">ผู้สูงอายุ คนมีเงิน เจ็บป่วยบ่อย</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่าง: คนอายุ 35 ปี เลือก แบบมาตรฐาน บุคคลเดียว</h3>

      <p class="text-gray-700 mb-3">
        สมมติว่าคุณอายุ 35 ปี อยู่ในวัยทำงาน ต้องการประกันสุขภาพแบบมาตรฐานสำหรับตัวเอง:
      </p>

      <div class="bg-blue-50 rounded-lg p-4 text-sm">
        <p class="font-semibold text-gray-900 mb-2">ผลการประมาณการ:</p>
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>เบี้ยรายเดือน: ~1,250 บาท</li>
          <li>เบี้ยรายปี: ~15,000 บาท</li>
          <li>ความครอบคลุมรักษาใน: 1,000,000 บาท</li>
          <li>ความครอบคลุมรักษานอก: 100,000 บาท</li>
          <li>Deductible: 2,500 บาท (จ่ายเองครั้งแรก)</li>
          <li>Coinsurance: 15% (จ่ายเอง 15% ประกันจ่าย 85%)</li>
        </ul>
      </div>

      <p class="text-gray-600 text-sm mt-3">
        เมื่อคุณรักษาพยาบาล คุณจ่ายเอง 2,500 บาท หลังจากนั้น ประกันจะจ่าย 85% คุณจ่าย 15% ของค่าใช้จ่ายที่เหลือ
      </p>
    </section>

    <div class="content-verified">
      <p>ตรวจสอบและอัพเดตโดยทีมผู้เชี่ยวชาญ Kamnuanlek | อัพเดตล่าสุด: เมษายน 2569</p>
    </div>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Related -->
    <AffiliateCard
      category="insurance"
      affiliateUrl="/go/rabbit-care-health-cpl/?sub_id=คำนวณเบี้ยประกันสุขภาพ"
      partnerName="Rabbit Care"
      ctaText="เปรียบเทียบประกันสุขภาพฟรี"
      subtext="รับใบเสนอราคาจากหลายบริษัทภายใน 2 นาที"
    />
    <RelatedArticles currentHref="/คำนวณเบี้ยประกันสุขภาพ/" />
    <RelatedCalculators currentHref="/คำนวณเบี้ยประกันสุขภาพ/" />

    <!-- Official References -->
    <section class="mb-8">
      <h3 class="mb-3 text-lg font-semibold text-gray-900">แหล่งอ้างอิงทางการ</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="https://www.oic.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">สำนักการประกันสังคม — ข้อมูลประกันสุขภาพ</a></li>
        <li><a href="https://www.thai-aia.com" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">สมาคมประกันชีวิตไทย — ข้อมูลสินค้าประกัน</a></li>
        <li><a href="https://www.moph.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">กระทรวงสาธารณสุข — ข้อมูลสุขภาพ</a></li>
      </ul>
    </section>

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการประมาณการเป็นเพียงการประมาณการเท่านั้น
      เบี้ยจริงขึ้นอยู่กับบริษัทประกัน ประวัติสุขภาพ อาชีพ และปัจจัยอื่น ๆ
      กรุณาติดต่อบริษัทประกันเพื่อได้เบี้ยที่แม่นยำ
    </div>
  </article>

  <script define:vars={{ siteUrl }}>
    import { compareAllPlans } from '../../lib/health-insurance-premium-calculator';

    function formatThaiNumber(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(num);
    }

    const ageGroupSelect = document.getElementById('age-group') as HTMLSelectElement;
    const coverageTypeSelect = document.getElementById('coverage-type') as HTMLSelectElement;
    const familyMembersInput = document.getElementById('family-members') as HTMLInputElement;
    const familyMembersRow = document.getElementById('family-members-row') as HTMLElement;

    // Show/hide family members input
    coverageTypeSelect.addEventListener('change', () => {
      familyMembersRow.classList.toggle('hidden', coverageTypeSelect.value !== 'family');
    });

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const result = compareAllPlans({
        ageGroup: ageGroupSelect.value as any,
        coverageType: coverageTypeSelect.value as any,
        familyMembers: parseInt(familyMembersInput.value) || 4,
      });

      // Update basic
      (document.getElementById('basic-monthly') as HTMLElement).textContent = formatThaiNumber(result.basic.monthlyPremium) + ' บาท';
      (document.getElementById('basic-coverage') as HTMLElement).textContent = formatThaiNumber(result.basic.hospitalizationLimit);
      (document.getElementById('basic-deductible') as HTMLElement).textContent = formatThaiNumber(result.basic.deductible);
      (document.getElementById('basic-annual') as HTMLElement).textContent = formatThaiNumber(result.basic.annualPremium);

      // Update standard
      (document.getElementById('standard-monthly') as HTMLElement).textContent = formatThaiNumber(result.standard.monthlyPremium) + ' บาท';
      (document.getElementById('standard-coverage') as HTMLElement).textContent = formatThaiNumber(result.standard.hospitalizationLimit);
      (document.getElementById('standard-deductible') as HTMLElement).textContent = formatThaiNumber(result.standard.deductible);
      (document.getElementById('standard-annual') as HTMLElement).textContent = formatThaiNumber(result.standard.annualPremium);

      // Update premium
      (document.getElementById('premium-monthly') as HTMLElement).textContent = formatThaiNumber(result.premium.monthlyPremium) + ' บาท';
      (document.getElementById('premium-coverage') as HTMLElement).textContent = formatThaiNumber(result.premium.hospitalizationLimit);
      (document.getElementById('premium-deductible') as HTMLElement).textContent = formatThaiNumber(result.premium.deductible);
      (document.getElementById('premium-annual') as HTMLElement).textContent = formatThaiNumber(result.premium.annualPremium);

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
      document.getElementById('affiliate-card')?.classList.remove('hidden');
      trackCalculatorUsed('health-insurance-premium');
    });

    // Allow Enter key
    [ageGroupSelect, coverageTypeSelect, familyMembersInput].forEach(el => {
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
