---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าเลี้ยงสัตว์ 2569 | ประเมินค่าใช้จ่ายสุนัขและแมวต่อเดือน | Kamnuanlek';
const pageDescription = 'คำนวณค่าเลี้ยงสัตว์เลี้ยงต่อเดือน สุนัขและแมว ค่าอาหาร ค่าสัตวแพทย์ ค่ากรูมมิ่ง ค่าทรายแมว ราคาตลาดไทยปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าเลี้ยงสัตว์/`;

const faqData = [
  {
    question: 'เลี้ยงสุนัขต่อเดือนใช้เงินเท่าไร?',
    answer: 'สุนัขพันธุ์เล็ก (ชิวาวา ปอมเมอเรเนียน) ค่าใช้จ่ายประมาณ 2,100–3,700 บาท/เดือน สุนัขพันธุ์กลาง (บีเกิล คอร์กี้) ประมาณ 3,100–5,550 บาท/เดือน สุนัขพันธุ์ใหญ่ (โกลเด้น ลาบราดอร์) ประมาณ 4,300–8,800 บาท/เดือน ขึ้นอยู่กับเกรดอาหารและบริการที่เลือก',
  },
  {
    question: 'เลี้ยงแมวต่อเดือนใช้เงินเท่าไร?',
    answer: 'แมวมีค่าใช้จ่ายประมาณ 1,700–3,550 บาท/เดือน รวมค่าอาหาร ค่าทรายแมว ค่าสัตวแพทย์ และอุปกรณ์ ถ้าเลือกอาหารเกรดพรีเมียมและมีประกันสัตว์เลี้ยง อาจสูงถึง 3,200–3,550 บาท/เดือน',
  },
  {
    question: 'ค่าสัตวแพทย์ต่อเดือนโดยเฉลี่ยเท่าไร?',
    answer: 'ค่าสัตวแพทย์เฉลี่ยต่อเดือน (คิดจากค่าตรวจสุขภาพประจำปี วัคซีน ถ่ายพยาธิ) สุนัขพันธุ์เล็ก ~500 บาท สุนัขพันธุ์กลาง ~700 บาท สุนัขพันธุ์ใหญ่ ~900 บาท แมว ~450 บาท ยังไม่รวมค่ารักษาเจ็บป่วยฉุกเฉิน',
  },
  {
    question: 'ประกันสัตว์เลี้ยงในไทยเดือนละเท่าไร?',
    answer: 'ประกันสัตว์เลี้ยงในไทยเบี้ยประมาณ 350–700 บาท/เดือน ขึ้นอยู่กับพันธุ์ อายุ และความคุ้มครอง ปัจจุบันมีหลายบริษัทให้บริการ เช่น แผนพื้นฐานคุ้มครองอุบัติเหตุ ไปจนถึงแผนครอบคลุมโรคทั่วไป',
  },
  {
    question: 'เลี้ยงสุนัขหรือแมวประหยัดกว่ากัน?',
    answer: 'โดยทั่วไปแมวมีค่าใช้จ่ายต่ำกว่าสุนัข เนื่องจากกินอาหารน้อยกว่า ไม่ต้องกรูมมิ่งบ่อย และไม่ต้องพาไปเดินเล่น แต่แมวมีค่าทรายแมวเพิ่มประมาณ 400 บาท/เดือน ค่าใช้จ่ายแมวใกล้เคียงสุนัขพันธุ์เล็ก',
  },
  {
    question: 'ค่าใช้จ่ายแรกเข้าเลี้ยงสัตว์มีอะไรบ้าง?',
    answer: 'ค่าใช้จ่ายแรกเข้า ได้แก่ ค่าตัวสัตว์เลี้ยง ค่าวัคซีนเข็มแรก (500–1,500 บาท) ค่าทำหมัน (1,500–5,000 บาท) อุปกรณ์เบื้องต้น (ชาม สายจูง กรง ที่นอน) ประมาณ 2,000–5,000 บาท รวมค่าแรกเข้าประมาณ 5,000–15,000 บาท ไม่รวมค่าตัวสัตว์',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าเลี้ยงสัตว์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเลี้ยงสัตว์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าเลี้ยงสัตว์ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ประเมินค่าใช้จ่ายเลี้ยงสุนัขหรือแมวต่อเดือน
      รวมค่าอาหาร ค่าสัตวแพทย์ ค่ากรูมมิ่ง ค่าอุปกรณ์ และค่าทรายแมว
      อ้างอิงราคาตลาดในประเทศไทย ปี 2569
    </p>

    <!-- Calculator Form -->
    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="pet-form" class="space-y-5">
        <p id="pet-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <!-- Pet Type -->
        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700">ประเภทสัตว์เลี้ยง</label>
          <div class="flex gap-3">
            <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-gray-300 px-4 py-3 transition-colors hover:bg-gray-50 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
              <input type="radio" name="pet-type" value="dog" checked class="h-4 w-4 text-primary-600 focus:ring-primary-500" />
              <span class="text-sm font-medium">🐕 สุนัข</span>
            </label>
            <label class="flex cursor-pointer items-center gap-2 rounded-lg border border-gray-300 px-4 py-3 transition-colors hover:bg-gray-50 has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
              <input type="radio" name="pet-type" value="cat" class="h-4 w-4 text-primary-600 focus:ring-primary-500" />
              <span class="text-sm font-medium">🐈 แมว</span>
            </label>
          </div>
        </div>

        <!-- Dog Size (visible only for dogs) -->
        <div id="dog-size-field">
          <label for="dog-size" class="mb-1 block text-sm font-medium text-gray-700">
            ขนาดสุนัข
          </label>
          <select
            id="dog-size"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64"
          >
            <option value="small">พันธุ์เล็ก (ชิวาวา, ปอม, ชิสุ) &lt; 10 กก.</option>
            <option value="medium" selected>พันธุ์กลาง (บีเกิล, คอร์กี้) 10–25 กก.</option>
            <option value="large">พันธุ์ใหญ่ (โกลเด้น, ลาบราดอร์) &gt; 25 กก.</option>
          </select>
        </div>

        <!-- Number of Pets -->
        <div>
          <label for="pet-count" class="mb-1 block text-sm font-medium text-gray-700">
            จำนวนสัตว์เลี้ยง
          </label>
          <select
            id="pet-count"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48"
          >
            <option value="1">1 ตัว</option>
            <option value="2">2 ตัว</option>
            <option value="3">3 ตัว</option>
            <option value="4">4 ตัว</option>
            <option value="5">5 ตัว</option>
          </select>
        </div>

        <!-- Food Quality -->
        <div>
          <label for="food-quality" class="mb-1 block text-sm font-medium text-gray-700">
            เกรดอาหาร
          </label>
          <select
            id="food-quality"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64"
          >
            <option value="budget">ประหยัด (อาหารเม็ดทั่วไป)</option>
            <option value="standard" selected>มาตรฐาน (แบรนด์คุณภาพ)</option>
            <option value="premium">พรีเมียม (Grain-free / Holistic)</option>
          </select>
        </div>

        <!-- Optional Costs -->
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-4 space-y-3">
          <p class="text-sm font-medium text-gray-700">ค่าใช้จ่ายเพิ่มเติม</p>
          <label class="flex cursor-pointer items-center gap-3">
            <input type="checkbox" id="include-grooming" checked class="h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
            <span class="text-sm text-gray-700">รวมค่ากรูมมิ่ง (อาบน้ำ ตัดขน ตัดเล็บ)</span>
          </label>
          <label class="flex cursor-pointer items-center gap-3">
            <input type="checkbox" id="include-insurance" class="h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
            <span class="text-sm text-gray-700">รวมค่าประกันสัตว์เลี้ยง</span>
          </label>
        </div>

        <button
          type="submit"
          id="pet-submit-btn"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          คำนวณค่าเลี้ยงสัตว์
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="pet-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลประเมินค่าเลี้ยงสัตว์</h2>

        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าใช้จ่ายรวมต่อเดือน</div>
            <div id="res-total-monthly" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าใช้จ่ายต่อตัว/เดือน</div>
            <div id="res-per-pet" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าใช้จ่ายรวมต่อปี</div>
            <div id="res-total-annual" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>

        <!-- Cost Breakdown -->
        <div>
          <h3 class="mb-3 text-sm font-semibold text-gray-700">รายละเอียดค่าใช้จ่ายต่อตัว/เดือน</h3>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">🍖 ค่าอาหาร</span>
              <span id="res-food" class="font-medium">-</span>
            </div>
            <div class="flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">🏥 ค่าสัตวแพทย์ (เฉลี่ย)</span>
              <span id="res-vet" class="font-medium">-</span>
            </div>
            <div id="row-grooming" class="flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">✂️ ค่ากรูมมิ่ง</span>
              <span id="res-grooming" class="font-medium">-</span>
            </div>
            <div class="flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">🧸 ค่าอุปกรณ์/ของเล่น</span>
              <span id="res-supplies" class="font-medium">-</span>
            </div>
            <div id="row-litter" class="hidden flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">🪣 ค่าทรายแมว</span>
              <span id="res-litter" class="font-medium">-</span>
            </div>
            <div id="row-insurance" class="hidden flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">🛡️ ค่าประกันสัตว์เลี้ยง</span>
              <span id="res-insurance" class="font-medium">-</span>
            </div>
            <div class="flex justify-between border-t-2 border-gray-300 py-2">
              <span class="font-semibold text-gray-700">รวมต่อตัว/เดือน</span>
              <span id="res-total-bottom" class="font-bold text-green-700">-</span>
            </div>
            <div id="row-multi" class="hidden flex justify-between py-1">
              <span class="font-semibold text-gray-700">รวมทั้งหมด (<span id="res-count-label">1</span> ตัว)</span>
              <span id="res-grand-total" class="font-bold text-green-700">-</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#pet-results" />

    <!-- Reference Table -->
    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">ตารางเปรียบเทียบค่าเลี้ยงสัตว์ต่อเดือน (อาหารเกรดมาตรฐาน)</h2>
      <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="px-4 py-3 text-left font-semibold text-gray-700">ประเภท</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">อาหาร</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">สัตวแพทย์</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">กรูมมิ่ง</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">อุปกรณ์</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">รวม</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-900">🐕 สุนัขเล็ก</td>
              <td class="px-4 py-3 text-right text-gray-700">1,500</td>
              <td class="px-4 py-3 text-right text-gray-700">500</td>
              <td class="px-4 py-3 text-right text-gray-700">500</td>
              <td class="px-4 py-3 text-right text-gray-700">300</td>
              <td class="px-4 py-3 text-right font-semibold text-green-700">2,800</td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-900">🐕 สุนัขกลาง</td>
              <td class="px-4 py-3 text-right text-gray-700">2,200</td>
              <td class="px-4 py-3 text-right text-gray-700">700</td>
              <td class="px-4 py-3 text-right text-gray-700">800</td>
              <td class="px-4 py-3 text-right text-gray-700">400</td>
              <td class="px-4 py-3 text-right font-semibold text-green-700">4,100</td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-900">🐕 สุนัขใหญ่</td>
              <td class="px-4 py-3 text-right text-gray-700">3,500</td>
              <td class="px-4 py-3 text-right text-gray-700">900</td>
              <td class="px-4 py-3 text-right text-gray-700">1,200</td>
              <td class="px-4 py-3 text-right text-gray-700">500</td>
              <td class="px-4 py-3 text-right font-semibold text-green-700">6,100</td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-900">🐈 แมว</td>
              <td class="px-4 py-3 text-right text-gray-700">1,200</td>
              <td class="px-4 py-3 text-right text-gray-700">450</td>
              <td class="px-4 py-3 text-right text-gray-700">350</td>
              <td class="px-4 py-3 text-right text-gray-700">250 + 400*</td>
              <td class="px-4 py-3 text-right font-semibold text-green-700">2,650</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-2 text-xs text-gray-500">* แมวมีค่าทรายแมวเพิ่มเติมประมาณ 400 บาท/เดือน | ราคาโดยประมาณ อาจแตกต่างตามพื้นที่และร้านค้า</p>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#pet-results" />

    <!-- Formula / How It Works -->
    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">วิธีประเมินค่าเลี้ยงสัตว์</h2>
      <p class="text-gray-700">
        เครื่องมือนี้ประเมินค่าใช้จ่ายรายเดือนจาก <strong>ราคาตลาดในประเทศไทย ปี 2569</strong>
        โดยแบ่งค่าใช้จ่ายออกเป็นหมวดหมู่หลัก:
      </p>
      <ol class="list-decimal space-y-1 pl-6 text-gray-700">
        <li><strong>ค่าอาหาร:</strong> คิดตามขนาดสัตว์และเกรดอาหาร (ประหยัด, มาตรฐาน, พรีเมียม)</li>
        <li><strong>ค่าสัตวแพทย์:</strong> ค่าตรวจสุขภาพประจำปี วัคซีน ถ่ายพยาธิ เฉลี่ยเป็นรายเดือน</li>
        <li><strong>ค่ากรูมมิ่ง:</strong> อาบน้ำ ตัดขน ตัดเล็บ ทำความสะอาดหู ตามความถี่ที่เหมาะสม</li>
        <li><strong>ค่าอุปกรณ์:</strong> ของเล่น ที่นอน ชามอาหาร สายจูง เฉลี่ยรายเดือน</li>
        <li><strong>ค่าทรายแมว:</strong> เฉพาะแมว ประมาณ 400 บาท/เดือน</li>
        <li><strong>ค่าประกันสัตว์เลี้ยง:</strong> (ตัวเลือก) เบี้ยประกันรายเดือนตามประเภทสัตว์</li>
      </ol>

      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">สูตรคำนวณ</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าใช้จ่ายต่อตัว/เดือน = ค่าอาหาร + ค่าสัตวแพทย์ + ค่ากรูมมิ่ง + ค่าอุปกรณ์ + ค่าทราย + ค่าประกัน</li>
