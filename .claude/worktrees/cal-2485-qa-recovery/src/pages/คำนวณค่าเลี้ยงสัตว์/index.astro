  <script type="module">
    import { calculatePetCost } from '../../lib/pet-cost-calculator.ts';

    function formatMoney(num) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(num)} บาท`;
    }

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    const form = document.getElementById('pet-form');
    const formError = document.getElementById('pet-form-error');
    const resultBox = document.getElementById('pet-results');
    const dogSizeField = document.getElementById('dog-size-field');

    // Show/hide dog size based on pet type
    document.querySelectorAll('input[name="pet-type"]').forEach((radio) => {
      radio.addEventListener('change', () => {
        const isDog = (document.querySelector('input[name="pet-type"]:checked')).value === 'dog';
        if (dogSizeField) {
          dogSizeField.style.display = isDog ? '' : 'none';
        }
      });
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      formError?.classList.add('hidden');

      if (typeof window.trackCalculatorStart === 'function') {
        window.trackCalculatorStart('pet_cost');
      }

      const petType = (document.querySelector('input[name="pet-type"]:checked'))?.value || 'dog';
      const dogSize = document.getElementById('dog-size')?.value || 'medium';
      const petCount = Number(document.getElementById('pet-count')?.value || '1');
      const foodQuality = document.getElementById('food-quality')?.value || 'standard';
      const includeGrooming = document.getElementById('include-grooming')?.checked || false;
      const includeInsurance = document.getElementById('include-insurance')?.checked || false;

      try {
        const result = calculatePetCost({
          petType,
          dogSize: petType === 'dog' ? dogSize : undefined,
          petCount,
          foodQuality,
          includeGrooming,
          includeInsurance,
        });

        setText('res-total-monthly', formatMoney(result.totalMonthly));
        setText('res-per-pet', formatMoney(result.totalPerPet));
        setText('res-total-annual', formatMoney(result.totalAnnual));

        setText('res-food', formatMoney(result.foodPerPet));
        setText('res-vet', formatMoney(result.vetPerPet));
        setText('res-grooming', formatMoney(result.groomingPerPet));
        setText('res-supplies', formatMoney(result.suppliesPerPet));
        setText('res-total-bottom', formatMoney(result.totalPerPet));

        // Grooming row
        const groomingRow = document.getElementById('row-grooming');
        if (groomingRow) {
          groomingRow.style.display = includeGrooming ? '' : 'none';
        }

        // Litter row (cats only)
        const litterRow = document.getElementById('row-litter');
        if (litterRow) {
          litterRow.classList.toggle('hidden', petType !== 'cat');
          setText('res-litter', formatMoney(result.litterPerPet));
        }

        // Insurance row
        const insuranceRow = document.getElementById('row-insurance');
        if (insuranceRow) {
          insuranceRow.classList.toggle('hidden', !includeInsurance);
          setText('res-insurance', formatMoney(result.insurancePerPet));
        }

        // Multi-pet row
        const multiRow = document.getElementById('row-multi');
        if (multiRow) {
          multiRow.classList.toggle('hidden', petCount <= 1);
          setText('res-count-label', String(petCount));
          setText('res-grand-total', formatMoney(result.totalMonthly));
        }

        resultBox?.classList.remove('hidden');
        resultBox?.scrollIntoView({ behavior: 'smooth', block: 'start' });

        if (typeof window.trackCalculatorComplete === 'function') {
          window.trackCalculatorComplete('pet_cost', result.totalMonthly);
        }
      } catch (_error) {
        formError?.classList.remove('hidden');
        resultBox?.classList.add('hidden');
      }
    });
  </script>
