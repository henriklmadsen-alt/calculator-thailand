---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransparencyPanel from '../../components/templates/TransparencyPanel.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';

const pageTitle = 'คำนวณต้นทุนโครงการงานไม้ 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนไม้ เครื่องมือ วัสดุ และค่าแรงสำหรับโครงการงานไม้ รู้ราคาขายที่เหมาะสมฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุน-โครงการงานไม้/`;

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนโครงการงานไม้',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  pageName="คำนวณต้นทุนโครงการงานไม้"
  categoryId="hobby"
  categoryName="งานอดิเรก/ศิลปะ"
  categorySlug="งานอดิเรก"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />

  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-4">คำนวณต้นทุนโครงการงานไม้</h1>

    <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนไม้ (บาท)</label>
          <input type="number" id="woodCost" placeholder="1000" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนเครื่องมือ (บาท)</label>
          <input type="number" id="tools" placeholder="500" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนสี/วาร์นิช (บาท)</label>
          <input type="number" id="finish" placeholder="300" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนฮาร์ดแวร์ (บาท)</label>
          <input type="number" id="hardware" placeholder="200" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนแก้ว/กระจก (บาท)</label>
          <input type="number" id="glass" placeholder="0" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนอื่นๆ (บาท)</label>
          <input type="number" id="other" placeholder="100" class="w-full border rounded px-3 py-2" />
        </div>
      </div>
      <button class="mt-6 w-full bg-blue-600 text-white py-2 rounded font-bold hover:bg-blue-700">
        คำนวณ
      </button>
    </div>

    <div id="result" class="hidden bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg shadow-lg p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">ผลลัพธ์</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ต้นทุนรวม</p>
          <p class="text-3xl font-bold text-blue-600" id="totalCost">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ราคาขายแนะนำ</p>
          <p class="text-3xl font-bold text-green-600" id="sellingPrice">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">กำไรโดยประมาณ</p>
          <p class="text-3xl font-bold text-green-600" id="profit">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
      </div>
    </div>

    <TransparencyPanel
      dataOrigin="การคำนวณจากต้นทุนวัสดุและเครื่องมือในโครงการงานไม้"
      lastUpdated="2026-04-22"
      accuracy="ความแม่นยำขึ้นอยู่กับต้นทุนที่ป้อนเข้า"
    />

    <GuardedAdSlot adUnitId="woodworking-calculator" position="bottom" />
    <RelatedCalculators />
  </div>

  <script is:inline>
    function calculate() {
      const totalCost = Math.round(
        (parseFloat(document.getElementById('woodCost').value) || 0) +
        (parseFloat(document.getElementById('tools').value) || 0) +
        (parseFloat(document.getElementById('finish').value) || 0) +
        (parseFloat(document.getElementById('hardware').value) || 0) +
        (parseFloat(document.getElementById('glass').value) || 0) +
        (parseFloat(document.getElementById('other').value) || 0)
      );
      const sellingPrice = Math.round(totalCost * 3);
      const profit = sellingPrice - totalCost;

      document.getElementById('result').classList.remove('hidden');
      document.getElementById('totalCost').textContent = totalCost.toLocaleString('th-TH');
      document.getElementById('sellingPrice').textContent = sellingPrice.toLocaleString('th-TH');
      document.getElementById('profit').textContent = Math.round(profit).toLocaleString('th-TH');
    }

    document.querySelector('button').addEventListener('click', calculate);
    document.querySelectorAll('input').forEach(input => {
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') calculate();
      });
    });

    window.addEventListener('load', () => {
      document.getElementById('woodCost').value = '1000';
      document.getElementById('tools').value = '500';
      document.getElementById('finish').value = '300';
      document.getElementById('hardware').value = '200';
      document.getElementById('glass').value = '0';
      document.getElementById('other').value = '100';
      calculate();
    });
  </script>
</BaseLayout>
