---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่ากายภาพบำบัด | Kamnuanlek';
const pageDescription = 'คำนวณค่ากายภาพบำบัด ค่าครั้ง จำนวนครั้ง ค่าอุปกรณ์ ตามอัตราโรงพยาบาลไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0406-ค่ากายภาพบำบัด/`;

const faqData = [
  { question: 'ค่ากายภาพบำบัดต่อครั้งเท่าไหร่?', answer: 'โรงพยาบาลรัฐ 100-300 บาทต่อครั้ง โรงพยาบาลเอกชน 500-1,500 บาทต่อครั้ง คลินิกกายภาพ 300-800 บาทต่อครั้ง' },
  { question: 'ต้องทำกายภาพบำบัดกี่ครั้ง?', answer: 'ขึ้นอยู่กับอาการ โดยทั่วไป 10-20 ครั้งต่อคอร์ส อาการเรื้อรังอาจต้องมากกว่า 30 ครั้ง แพทย์จะประเมินตามสภาพ' },
  { question: 'ประกันสุขภาพคลุมค่ากายภาพบำบัดไหม?', answer: 'ขึ้นอยู่กับแผนประกัน บางแผนครอบคลุมกายภาพบำบัดที่ถูกสั่งโดยแพทย์ ควรตรวจสอบเงื่อนไขก่อนทำ' },
  { question: 'กายภาพบำบัดที่บ้านทำได้ไหม?', answer: 'ได้ นักกายภาพบำบัดสามารถมาที่บ้านได้ ค่าบริการสูงกว่าปกติประมาณ 500-2,000 บาทต่อครั้ง ขึ้นอยู่กับระยะทาง' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่ากายภาพบำบัด">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่ากายภาพบำบัด</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่ากายภาพบำบัดรวมทั้งคอร์ส รวมค่าอุปกรณ์และการรักษา</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="session_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่ากายภาพบำบัดต่อครั้ง (บาท)</label><input type="text" id="session_cost" inputmode="decimal" placeholder="เช่น 600" value="600" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="sessions" class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้งที่ต้องทำ</label><input type="number" id="sessions" min="1" max="100" placeholder="เช่น 15" value="15" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="equipment" class="block text-sm font-medium text-gray-700 mb-1">ค่าอุปกรณ์ช่วยฟื้นฟู (บาท)</label><input type="text" id="equipment" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="transport_pt" class="block text-sm font-medium text-gray-700 mb-1">ค่าเดินทางต่อครั้ง (บาท)</label><input type="text" id="transport_pt" inputmode="decimal" placeholder="เช่น 100" value="100" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่ารักษาทั้งคอร์ส</p>
            <p id="treatment_total" class="font-bold">-</p>
          </div>
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าอุปกรณ์ + เดินทาง</p>
            <p id="extra_total" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">รวมค่ากายภาพบำบัด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const sessionCost = parseFloat((document.getElementById('session_cost') as HTMLInputElement).value) || 0;
      const sessions = parseInt((document.getElementById('sessions') as HTMLInputElement).value) || 1;
      const equipment = parseFloat((document.getElementById('equipment') as HTMLInputElement).value) || 0;
      const transport = parseFloat((document.getElementById('transport_pt') as HTMLInputElement).value) || 0;

      const treatmentTotal = sessionCost * sessions;
      const extraTotal = equipment + (transport * sessions);
      const total = treatmentTotal + extraTotal;

      (document.getElementById('treatment_total') as HTMLElement).textContent = treatmentTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('extra_total') as HTMLElement).textContent = extraTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('physical-therapy');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
