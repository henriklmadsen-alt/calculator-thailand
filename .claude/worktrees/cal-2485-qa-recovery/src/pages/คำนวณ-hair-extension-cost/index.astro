---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าเชื่อมผม 2569 | Hair Extension Cost | Kamnuanlek';
const pageDescription = 'คำนวณค่าเชื่อมผม เชื่อมสติกกี้ การบำรุง การถอด ต่อเดือนและต่อปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-hair-extension-cost/`;

const faqData = [
  { question: 'ราคาเฉลี่ยของบริการนี้คือเท่าไร?', answer: 'ราคาขึ้นอยู่กับร้าน ทำเล และระดับบริการ ใช้เครื่องคำนวณด้านบนเพื่อประมาณค่าใช้จ่ายตามตัวเลือกที่ต้องการ' },
  { question: 'ควรทำบริการนี้บ่อยแค่ไหน?', answer: 'ขึ้นอยู่กับประเภทบริการและสภาพของแต่ละคน โดยทั่วไปทุก 2-6 สัปดาห์ตามคำแนะนำของช่าง' },
  { question: 'มีวิธีประหยัดค่าใช้จ่ายอย่างไร?', answer: 'เลือกแพ็กเกจ สมัครสมาชิก หรือจองล่วงหน้าในช่วงโปรโมชั่น บางร้านมีส่วนลดสำหรับลูกค้าประจำ' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกรายละเอียดบริการที่ต้องการ เช่น ประเภท จำนวนครั้ง และตัวเลือกเสริม เครื่องจะคำนวณค่าใช้จ่ายรวมให้ทันที' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเชื่อมผม">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเชื่อมผมต่อเดือนและต่อปี</h1>
    <div class="mb-4 inline-block rounded-lg border border-fuchsia-200 bg-fuchsia-50 px-3 py-2">
      <p class="text-xs font-semibold text-fuchsia-800">[KLC-0778]</p>
    </div>
    <p class="text-gray-600 mb-6">คำนวณค่าเชื่อมผม เชื่อมสติกกี้ บำรุง และถอดขึ้นใหม่ต่อเดือนและต่อปี</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="initial-cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าเชื่อมเบื้องแรก (บาท)</label>
          <input type="text" id="initial-cost" inputmode="decimal" placeholder="เช่น 3000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="maintenance-cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าบำรุง/เดือน (บาท)</label>
          <input type="text" id="maintenance-cost" inputmode="decimal" placeholder="เช่น 500" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="duration-months" class="block text-sm font-medium text-gray-700 mb-1">เก็บไว้นานเดือน</label>
          <input type="text" id="duration-months" inputmode="decimal" placeholder="เช่น 3" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="removal-cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าถอด (บาท)</label>
          <input type="text" id="removal-cost" inputmode="decimal" placeholder="เช่น 500" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
      </div>

      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">คำนวณ</button>

      <div id="result" class="hidden mt-6">
        <div class="grid gap-4 sm:grid-cols-3 mb-6 text-center">
          <div>
            <div class="text-sm text-gray-600 mb-1">ต่อรอบ (3 เดือน)</div>
            <div id="per-round-cost" class="text-3xl font-bold text-primary-600">-</div>
          </div>
          <div>
            <div class="text-sm text-gray-600 mb-1">ต่อปี (4 รอบ)</div>
            <div id="yearly-cost" class="text-3xl font-bold text-primary-600">-</div>
          </div>
          <div>
            <div class="text-sm text-gray-600 mb-1">ต่อเดือนโดยเฉลี่ย</div>
            <div id="monthly-cost" class="text-3xl font-bold text-primary-600">-</div>
          </div>
        </div>
      </div>
    </div>

    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">[โฆษณา — AdSense]</div>

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ราคาเชื่อมผมเฉลี่ยในไทย</h2>
      <p>ค่าเชื่อมผมเบื้องแรกประมาณ 2,500-5,000 บาท ค่าบำรุง 300-800 บาท/เดือน ค่าถอด 300-800 บาท</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประเภทเชื่อมผม</h3>
      <ul class="list-disc pl-6 text-gray-700">
        <li><strong>เชื่อมเกล็ด/Tape:</strong> 2,000-3,500 บาท ถูกและปลอดภัย</li>
        <li><strong>เชื่อมสติกกี้/Bonded:</strong> 3,000-5,000 บาท ทนทาน</li>
        <li><strong>เชื่อมจํานวนเส้น:</strong> 2,500-4,000 บาท ติดแต่ละเส้น</li>
        <li><strong>เชื่อมแบบเย็บ:</strong> 1,500-3,000 บาท ประหยัดแต่เหนื่อย</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีประหยัด</h3>
      <ul class="list-disc pl-6 text-gray-700">
        <li>เลือกแบบเทปที่ถูกกว่า</li>
        <li>ดูแลตามวิธีที่ถูกต้อง ลดการมาบำรุง</li>
        <li>บำรุงที่บ้านด้วยผลิตภัณฑ์ราคาถูก</li>
        <li>เปรียบเทียบราคาหลายร้าน</li>
      </ul>
    </section>

    <RelatedArticles currentHref="/คำนวณ-hair-extension-cost/" />
    <RelatedCalculators currentHref="/คำนวณ-hair-extension-cost/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ราคาจริงอาจแตกต่างตามร้านและคุณภาพของผม
    </div>
  </article>

  <script>
    function formatCurrency(value: number): string {
      return new Intl.NumberFormat('th-TH', {
        style: 'currency',
        currency: 'THB',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(value);
    }

    document.getElementById('btn-calculate')?.addEventListener('click', () => {
      const initial = parseFloat((document.getElementById('initial-cost') as HTMLInputElement)?.value) || 0;
      const maintenance = parseFloat((document.getElementById('maintenance-cost') as HTMLInputElement)?.value) || 0;
      const duration = parseFloat((document.getElementById('duration-months') as HTMLInputElement)?.value) || 3;
      const removal = parseFloat((document.getElementById('removal-cost') as HTMLInputElement)?.value) || 0;

      const perRound = initial + (maintenance * duration) + removal;
      const yearly = perRound * 4;
      const monthly = yearly / 12;

      document.getElementById('per-round-cost')!.textContent = formatCurrency(perRound);
      document.getElementById('yearly-cost')!.textContent = formatCurrency(yearly);
      document.getElementById('monthly-cost')!.textContent = formatCurrency(monthly);
      document.getElementById('result')!.classList.remove('hidden');
    });
  </script>
</BaseLayout>
