---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าจ้างลาคลอด 98 วัน นายจ้าง 45 วัน + ประกันสังคม 90 วัน ปี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณค่าจ้างลาคลอดตามกฎหมายแรงงานไทย 98 วัน นายจ้างจ่าย 45 วัน ประกันสังคมจ่าย 50% ของฐานเงินเดือน SSF สูงสุด 90 วัน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าจ้างลาคลอด/`;

const faqData = [
  {
    question: 'ลาคลอดได้กี่วันตามกฎหมายไทย?',
    answer: 'พระราชบัญญัติคุ้มครองแรงงานกำหนดให้ลูกจ้างหญิงมีสิทธิลาคลอดได้ 98 วันตามปฏิทิน รวมวันหยุด โดยนับจากวันที่คลอดบุตรหรือก่อนคลอดก็ได้',
  },
  {
    question: 'นายจ้างต้องจ่ายค่าจ้างระหว่างลาคลอดกี่วัน?',
    answer: 'นายจ้างมีหน้าที่จ่ายค่าจ้างให้ลูกจ้างในช่วงลาคลอด 45 วันแรก ในอัตราค่าจ้างปกติ ส่วนอีก 45 วันที่เหลือ ประกันสังคมจะจ่ายสมทบในอัตรา 50% ของฐานค่าจ้าง (สูงสุด 15,000 บาท/เดือน) และอีก 8 วันที่เหลือเป็นวันลาโดยไม่ได้รับค่าจ้าง',
  },
  {
    question: 'ประกันสังคมจ่ายค่าลาคลอดอย่างไร?',
    answer: 'ประกันสังคม (มาตรา 50) จ่ายเงินทดแทนการขาดรายได้ในกรณีคลอดบุตรในอัตรา 50% ของค่าจ้างฐาน SSF สูงสุดไม่เกิน 15,000 บาท/เดือน เป็นระยะเวลา 90 วัน โดยมีเงื่อนไขต้องส่งเงินสมทบครบ 5 เดือนภายใน 15 เดือนก่อนคลอด',
  },
  {
    question: 'ฐานเงินเดือน SSF คืออะไร?',
    answer: 'ฐานเงินเดือน SSF คือค่าจ้างที่ใช้เป็นฐานในการคำนวณเงินสมทบประกันสังคม กฎหมายกำหนดไว้ที่ขั้นต่ำ 1,650 บาท/เดือน และสูงสุดไม่เกิน 15,000 บาท/เดือน แม้เงินเดือนจริงจะสูงกว่าก็ตาม',
  },
,
  { question: 'ค่าแรงขั้นต่ำปี 2569 อยู่ที่เท่าไร?', answer: 'ค่าแรงขั้นต่ำปี 2568-2569 กรุงเทพและปริมณฑล 370-400 บาท/วัน ต่างจังหวัดอยู่ที่ 330-370 บาท/วัน ขึ้นอยู่กับจังหวัด ตรวจสอบอัตราล่าสุดได้จากกระทรวงแรงงาน mol.go.th' },
  { question: 'เงินเดือนสุทธิคำนวณจากอะไรบ้าง?', answer: 'เงินเดือนสุทธิ = เงินเดือนรวม - ภาษีหัก ณ ที่จ่าย - เงินสมทบประกันสังคม (5% สูงสุด 750 บาท) - กองทุนสำรองเลี้ยงชีพ (ถ้ามี) นายจ้างจ่ายประกันสังคมเพิ่มอีกฝ่าย 5%' },
  { question: 'OT คำนวณอย่างไร?', answer: 'วันธรรมดา: 1.5 เท่าของค่าจ้างปกติต่อชั่วโมง | วันหยุด: 2 เท่า (ชั่วโมงปกติ) และ 3 เท่า (เกินเวลาปกติ) | ตามพระราชบัญญัติคุ้มครองแรงงาน พ.ศ. 2541' },
  { question: 'กองทุนสำรองเลี้ยงชีพมีประโยชน์อย่างไร?', answer: 'เป็นเงินออมระยะยาวที่นายจ้างสมทบ (1-15% ของค่าจ้าง) + ลดหย่อนภาษีได้สูงสุด 15% ของรายได้หรือ 500,000 บาท + ผลตอบแทนจากการลงทุน ดึงออกได้เมื่อออกจากงานหรือเกษียณ' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าจ้างลาคลอด',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าจ้างลาคลอด">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">🤱 สิทธิลาคลอดตามกฎหมายแรงงานไทย</p>
      <p class="mt-1 text-sm text-slate-700">ลาคลอดได้ 98 วัน — นายจ้างจ่าย 45 วัน + ประกันสังคมจ่าย 50% ของฐาน SSF สูงสุด 90 วัน</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อ้างอิง: พ.ร.บ. คุ้มครองแรงงาน มาตรา 41 และประกันสังคม มาตรา 50</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าจ้างลาคลอด ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือนและฐานเงินเดือน SSF เพื่อคำนวณค่าจ้างที่ได้รับระหว่างลาคลอด 98 วัน แยกส่วนนายจ้างและประกันสังคม
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="maternity-form" class="space-y-5">
        <p id="maternity-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="mat-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือน (บาท/เดือน)</label>
            <input type="text" id="mat-salary" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="mat-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="mat-ssf-base" class="mb-1 block text-sm font-medium text-gray-700">ฐานเงินเดือน SSF (บาท/เดือน)</label>
            <input type="text" id="mat-ssf-base" inputmode="numeric" placeholder="เช่น 15,000 (สูงสุด)"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">ฐาน SSF สูงสุด 15,000 บาท/เดือน</p>
            <p id="mat-ssf-base-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณค่าจ้างลาคลอด
        </button>
      </form>
    </div>

    <div id="maternity-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">นายจ้างจ่าย (45 วัน)</div>
            <div id="res-mat-employer" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ประกันสังคมจ่าย (90 วัน)</div>
            <div id="res-mat-ssf" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รวมที่ได้รับทั้งหมด</div>
            <div id="res-mat-total" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">อัตราค่าจ้างรายวัน (เงินเดือน ÷ 30)</span>
            <span id="res-mat-daily" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">อัตรา SSF รายวัน (50% ของฐาน SSF ÷ 30)</span>
            <span id="res-mat-ssf-daily" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">วันลาที่ไม่ได้รับค่าจ้าง</span>
            <span class="font-medium">8 วัน</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">วันลาทั้งหมด</span>
            <span class="font-medium">98 วัน</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าจ้างรายวัน = เงินเดือน ÷ 30</li>
        <li>นายจ้างจ่าย = ค่าจ้างรายวัน × 45 วัน</li>
        <li>ประกันสังคมจ่าย = (ฐาน SSF × 50%) ÷ 30 × 90 วัน</li>
        <li>รวม = นายจ้างจ่าย + ประกันสังคมจ่าย (อีก 8 วันไม่ได้รับ)</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณค่าจ้างลาคลอดบิดา/">คำนวณค่าจ้างลาคลอดบิดา</a></li>
        <li><a href="/คำนวณค่าจ้างลาป่วย/">คำนวณค่าจ้างลาป่วย</a></li>
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#maternity-results" />
    <RelatedArticles currentHref="/คำนวณค่าจ้างลาคลอด/" />
    <RelatedCalculators currentHref="/คำนวณค่าจ้างลาคลอด/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการตามกฎหมายแรงงานไทยและเงื่อนไขประกันสังคม สิทธิประโยชน์จริงอาจแตกต่างขึ้นอยู่กับเงื่อนไขการส่งเงินสมทบและนโยบายบริษัท กรุณาตรวจสอบกับสำนักงานประกันสังคมหรือนายจ้างโดยตรง
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }
    function setErr(id, msg) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.toggle('hidden', !msg);
    }

    const form = document.getElementById('maternity-form');
    const formError = document.getElementById('maternity-form-error');
    const resultBox = document.getElementById('maternity-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['mat-salary-error', 'mat-ssf-base-error'].forEach((id) => setErr(id, ''));

      const salary = parseNum(document.getElementById('mat-salary').value);
      const ssfBase = parseNum(document.getElementById('mat-ssf-base').value);

      let hasError = false;
      if (!Number.isFinite(salary) || salary <= 0) { setErr('mat-salary-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(ssfBase) || ssfBase <= 0 || ssfBase > 15000) { setErr('mat-ssf-base-error', 'กรอกฐาน SSF 1–15,000 บาท'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const dailyRate = salary / 30;
      const employerPay = dailyRate * 45;
      const ssfDailyRate = (ssfBase * 0.5) / 30;
      const ssfPay = ssfDailyRate * 90;
      const total = employerPay + ssfPay;

      setText('res-mat-employer', formatMoney(employerPay));
      setText('res-mat-ssf', formatMoney(ssfPay));
      setText('res-mat-total', formatMoney(total));
      setText('res-mat-daily', formatMoney(dailyRate));
      setText('res-mat-ssf-daily', formatMoney(ssfDailyRate));

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
