    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น ต้นทุนและผลผลิตจริงขึ้นอยู่กับสภาพแวดล้อม พื้นที่ สภาพอากาศ วิธีการปลูก และราคาตลาดในขณะนั้น กรุณาติดต่อสำนักงานส่งเสริมการเกษตรท้องถิ่นสำหรับข้อมูลเฉพาะพื้นที่
    </div>
  </article>

  <script>
    function calculateRiceFarming(raiSize: number, variety: string, isIrrigated: boolean, includeLabor: boolean, includeEquipment: boolean) {
      const costPerRai: Record<string, number> = {
        white: 13500, // white total
        sticky: 14200,
        jasmine: 15700,
        hybrid: 17500,
      };

      const baseTotal = raiSize * (costPerRai[variety] || 13500);

      // Adjust for irrigation
      const total = isIrrigated ? baseTotal : baseTotal - (raiSize * 600);

      // Adjust for labor
      const labor = includeLabor ? raiSize * 4000 : 0;

      // Adjust for equipment
      const equipment = includeEquipment ? raiSize * 2500 : 0;

      const totalCost = total + labor;

      const yieldPerRai: Record<string, number> = {
        white: 450,
        sticky: 400,
        jasmine: 350,
        hybrid: 600,
      };

      const pricePerKg: Record<string, number> = {
        white: 6,
        sticky: 7,
        jasmine: 9,
        hybrid: 6.5,
      };

      const yield_ = raiSize * (yieldPerRai[variety] || 450);
      const income = yield_ * (pricePerKg[variety] || 6);
      const profit = income - totalCost;
      const margin = income > 0 ? (profit / income) * 100 : 0;

      return {
        totalCost,
        yield_,
        income,
        profit,
        margin,
        labor,
        equipment,
      };
    }

    function formatCurrency(num: number): string {
      return new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(num);
    }

    const raiSizeInput = document.getElementById('raiSize') as HTMLInputElement;
    const varietySelect = document.getElementById('variety') as HTMLSelectElement;
    const irrigatedCheckbox = document.getElementById('irrigated') as HTMLInputElement;
    const laborCheckbox = document.getElementById('includeLabor') as HTMLInputElement;
    const equipmentCheckbox = document.getElementById('includeEquipment') as HTMLInputElement;

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const raiSize = parseFloat(raiSizeInput.value.replace(/,/g, '')) || 0;

      if (raiSize <= 0) {
        raiSizeInput.focus();
        return;
      }

      const variety = varietySelect.value;
      const isIrrigated = irrigatedCheckbox.checked;
      const includeLabor = laborCheckbox.checked;
      const includeEquipment = equipmentCheckbox.checked;

      const result = calculateRiceFarming(raiSize, variety, isIrrigated, includeLabor, includeEquipment);

      // Update display
      (document.getElementById('cost-prep') as HTMLElement).textContent = formatCurrency(raiSize * 1000);
      (document.getElementById('cost-seeds') as HTMLElement).textContent = formatCurrency(raiSize * 1700);
      (document.getElementById('cost-fert') as HTMLElement).textContent = formatCurrency(raiSize * 2800);
      (document.getElementById('cost-pest') as HTMLElement).textContent = formatCurrency(raiSize * 2000);
      (document.getElementById('cost-water') as HTMLElement).textContent = formatCurrency(isIrrigated ? raiSize * 600 : 0);
      (document.getElementById('cost-labor') as HTMLElement).textContent = formatCurrency(result.labor);
      (document.getElementById('cost-equip') as HTMLElement).textContent = formatCurrency(result.equipment);
      (document.getElementById('cost-harvest') as HTMLElement).textContent = formatCurrency(includeEquipment ? 0 : raiSize * 2000);
      (document.getElementById('cost-dry') as HTMLElement).textContent = formatCurrency(raiSize * 1000);

      (document.getElementById('total-cost') as HTMLElement).textContent = formatCurrency(result.totalCost);
      (document.getElementById('yield') as HTMLElement).textContent = result.yield_.toLocaleString('th-TH') + ' กก.';
      (document.getElementById('income') as HTMLElement).textContent = formatCurrency(result.income);
      (document.getElementById('profit') as HTMLElement).textContent = formatCurrency(result.profit);
      (document.getElementById('margin') as HTMLElement).textContent = Math.round(result.margin * 10) / 10 + '%';

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('rice-farming');
    });

    [raiSizeInput].forEach(input => {
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
