---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณต้นทุนการปลูกข้าวต่อไร่ 2569 | เครื่องคำนวณเกษตร | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการปลูกข้าวต่อไร่ฟรี ว่าว เมล็ด ปุ๋ย ยาเคมี แรงงาน ประมาณการกำไร พร้อมตัวอย่างการปลูกข้าวขาว ข้าวหอมมะลิ และข้าวลูกผสม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุนการปลูกข้าว/`;

const faqData = [
  {
    question: 'ต้นทุนการปลูกข้าวมีอะไรบ้าง?',
    answer: 'ต้นทุนการปลูกข้าวประกอบด้วย การเตรียมพื้นที่ (ไถ) เมล็ดข้าว ปุ๋ยเคมี ยาเคมีกำจัดศัตรูพืช แรงงาน ค่าน้ำชลประทาน (หากมีระบบชลประทาน) ค่าเช่าเครื่องจักร เก็บเกี่ยว อบแห้งและเก็บรักษา',
  },
  {
    question: 'ข้าวหอมมะลิให้กำไรมากกว่าข้าวขาวหรือไม่?',
    answer: 'ข้าวหอมมะลิมีราคาสูงกว่า (8-10 บาท/กก.) แต่ให้ผลผลิตต่ำกว่า (350-400 กก./ไร่) ส่วนข้าวขาวราคาต่ำกว่า (5-7 บาท/กก.) แต่ผลผลิตสูงกว่า (400-500 กก./ไร่) กำไรสุดท้ายขึ้นอยู่กับต้นทุนและราคาตลาด',
  },
  {
    question: 'ข้าวลูกผสมให้ผลผลิตสูงกว่าข้าวธรรมชาติจริงหรือ?',
    answer: 'ใช่ ข้าวลูกผสมให้ผลผลิตสูงกว่า (500-700 กก./ไร่) แต่ต้นทุนเมล็ดสูงกว่า (2,500-3,500 บาท/ไร่) เหมาะสำหรับผู้ปลูกที่มีปัจจัยการผลิตดีและพื้นที่เหมาะสม',
  },
  {
    question: 'วิธีลดต้นทุนการปลูกข้าวมีวิธีไหนบ้าง?',
    answer: 'วิธีลดต้นทุน ได้แก่ ใช้แรงงานของครอบครัว ร่วมกันเช่าเครื่องจักร ใช้ปุ๋ยหมักแทนปุ๋ยเคมี บ่อฉ่า ปลูกพืชสลับกับข้าว และเก็บรักษาเมล็ดข้าวเพื่อหลุดจากการซื้อเมล็ดใหม่ในปีต่อไป',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนการปลูกข้าว',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณต้นทุนการปลูกข้าวต่อไร่',
  description: 'ขั้นตอนการคำนวณต้นทุนการปลูกข้าวจากเตรียมพื้นที่ถึงเก็บเกี่ยว',
  step: [
    {
      '@type': 'HowToStep',
      name: 'กำหนดขนาดพื้นที่เพาะปลูก',
      text: 'กำหนดจำนวนไร่ที่ต้องการปลูก (1 ไร่ = 1,600 ตารางเมตร) เช่น 5 ไร่ 10 ไร่ หรือ 20 ไร่',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกพันธุ์ข้าวที่ต้องการปลูก',
      text: 'เลือกประเภทข้าว ได้แก่ ข้าวขาว ข้าวเหนียว ข้าวหอมมะลิ หรือข้าวลูกผสม ซึ่งมีต้นทุนและผลผลิตต่างกัน',
    },
    {
      '@type': 'HowToStep',
      name: 'ระบุสภาพพื้นที่ (ชลประทาน)',
      text: 'ระบุว่าพื้นที่มีระบบชลประทานหรือไม่ เพื่อคำนวณค่าน้ำและต้นทุนเพิ่มเติม',
    },
    {
      '@type': 'HowToStep',
      name: 'ระบุการใช้แรงงานและเครื่องจักร',
      text: 'เลือกว่าจะจ้างแรงงาน เช่าเครื่องจักร หรือใช้ของตัวเองเพื่อให้ได้ต้นทุนที่เหมาะสม',
    },
    {
      '@type': 'HowToStep',
      name: 'ได้รับผลลัพธ์ต้นทุนและประมาณการกำไร',
      text: 'เครื่องคำนวณจะแสดงต้นทุนรวม ผลผลิตโดยประมาณ รายได้จากการขาย และกำไรที่คาดว่าจะได้ร' },
  ],
};
---

<BaseLayout noGenericHowTo={true} title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนการปลูกข้าว">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณต้นทุนการปลูกข้าวต่อไร่
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2">
      <p class="text-xs font-semibold text-lime-800">[อัปเดตตามอัตราเกษตร 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณต้นทุนการปลูกข้าวออนไลน์ฟรี รวมทั้งเตรียมพื้นที่ เมล็ด ปุ๋ย ยาเคมี แรงงาน ประมาณการกำไร พร้อมตัวอย่างข้าวขาว ข้าวหอมมะลิ และข้าวลูกผสม
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div>
          <label for="raiSize" class="block text-sm font-medium text-gray-700 mb-1">
            ขนาดพื้นที่ (ไร่)
          </label>
          <input
            type="text"
            id="raiSize"
            inputmode="decimal"
            placeholder="เช่น 10"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div>
          <label for="variety" class="block text-sm font-medium text-gray-700 mb-1">
            พันธุ์ข้าว
          </label>
          <select id="variety" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base">
            <option value="white">ข้าวขาว (White Rice)</option>
            <option value="sticky">ข้าวเหนียว (Sticky Rice)</option>
            <option value="jasmine">ข้าวหอมมะลิ (Jasmine)</option>
            <option value="hybrid">ข้าวลูกผสม (Hybrid)</option>
          </select>
        </div>

        <div class="flex items-center">
          <input
            type="checkbox"
            id="irrigated"
            checked
            class="h-4 w-4 border-gray-300 text-primary-600 focus:ring-primary-500 rounded"
          />
          <label for="irrigated" class="ml-2 text-sm text-gray-700">
            มีระบบชลประทาน (Irrigated)
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="checkbox"
            id="includeLabor"
            class="h-4 w-4 border-gray-300 text-primary-600 focus:ring-primary-500 rounded"
          />
          <label for="includeLabor" class="ml-2 text-sm text-gray-700">
            จ้างแรงงาน (Hire Labor)
          </label>
        </div>

        <div class="flex items-center">
          <input
            type="checkbox"
            id="includeEquipment"
            checked
            class="h-4 w-4 border-gray-300 text-primary-600 focus:ring-primary-500 rounded"
          />
          <label for="includeEquipment" class="ml-2 text-sm text-gray-700">
            เช่าเครื่องจักร (Rent Equipment)
          </label>
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณต้นทุน
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6">
        <!-- Cost Breakdown -->
        <div class="mb-6">
          <h3 class="font-semibold text-gray-900 mb-3">รายละเอียดต้นทุน</h3>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div class="bg-gray-50 p-3 rounded">
              <p class="text-gray-600">เตรียมพื้นที่</p>
              <p id="cost-prep" class="text-lg font-semibold text-gray-900">-</p>
            </div>
            <div class="bg-gray-50 p-3 rounded">
              <p class="text-gray-600">เมล็ดข้าว</p>
              <p id="cost-seeds" class="text-lg font-semibold text-gray-900">-</p>
            </div>
            <div class="bg-gray-50 p-3 rounded">
              <p class="text-gray-600">ปุ๋ย</p>
              <p id="cost-fert" class="text-lg font-semibold text-gray-900">-</p>
            </div>
            <div class="bg-gray-50 p-3 rounded">
              <p class="text-gray-600">ยาเคมี</p>
              <p id="cost-pest" class="text-lg font-semibold text-gray-900">-</p>
            </div>
            <div class="bg-gray-50 p-3 rounded">
              <p class="text-gray-600">ค่าน้ำ</p>
              <p id="cost-water" class="text-lg font-semibold text-gray-900">-</p>
            </div>
            <div class="bg-gray-50 p-3 rounded">
              <p class="text-gray-600">แรงงาน</p>
              <p id="cost-labor" class="text-lg font-semibold text-gray-900">-</p>
            </div>
            <div class="bg-gray-50 p-3 rounded">
              <p class="text-gray-600">เช่าเครื่องจักร</p>
              <p id="cost-equip" class="text-lg font-semibold text-gray-900">-</p>
            </div>
            <div class="bg-gray-50 p-3 rounded">
              <p class="text-gray-600">เก็บเกี่ยว</p>
              <p id="cost-harvest" class="text-lg font-semibold text-gray-900">-</p>
            </div>
            <div class="bg-gray-50 p-3 rounded">
              <p class="text-gray-600">อบแห้งและเก็บรักษา</p>
              <p id="cost-dry" class="text-lg font-semibold text-gray-900">-</p>
            </div>
          </div>
        </div>

        <!-- Summary -->
        <div class="bg-blue-50 rounded-lg p-4 mb-6">
          <div class="text-center mb-4">
            <p class="text-sm text-gray-600 mb-1">ต้นทุนรวมต่อไร่</p>
            <p id="total-cost" class="text-4xl font-bold text-blue-600">-</p>
          </div>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div>
              <p class="text-gray-600">ผลผลิต</p>
              <p id="yield" class="text-lg font-semibold text-gray-900">- กก./ไร่</p>
            </div>
            <div>
              <p class="text-gray-600">รายได้</p>
              <p id="income" class="text-lg font-semibold text-green-600">-</p>
            </div>
            <div>
              <p class="text-gray-600">กำไร</p>
              <p id="profit" class="text-lg font-semibold text-green-700">-</p>
            </div>
            <div>
              <p class="text-gray-600">อัตรากำไร</p>
              <p id="margin" class="text-lg font-semibold text-green-700">-</p>
            </div>
          </div>
        </div>

        <!-- Note -->
        <div class="bg-yellow-50 rounded-lg p-4 border border-yellow-200 text-sm text-yellow-800">
          <p><strong>หมายเหตุ:</strong> ราคาตลาด ผลผลิต และต้นทุนเป็นประมาณการตามอัตรา 2024-2025 ต้นทุนจริงอาจแตกต่างไปตามสภาพภูมิศาสตร์ สภาพอากาศ และวิธีการปลูก</p>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ต้นทุนการปลูกข้าวมีอะไรบ้าง?</h2>

      <p>
        ต้นทุนการปลูกข้าว ประกอบด้วยหลายรายการตั้งแต่การเตรียมพื้นที่ เมล็ดข้าว ปุ๋ยเคมี ยาเคมีกำจัดศัตรูพืช แรงงาน น้ำชลประทาน เช่าเครื่องจักร เก็บเกี่ยว และอบแห้งเก็บรักษา ต้นทุนรวมอาจอยู่ที่ 10,000-20,000 บาทต่อไร่ (ขึ้นอยู่กับวิธีการปลูก)
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">รายละเอียดต้นทุนการปลูกข้าว</h3>

      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li><strong>เตรียมพื้นที่:</strong> การไถ ไล่ ทำแปลง ค่าประมาณ 800-1,200 บาท/ไร่</li>
        <li><strong>เมล็ดข้าว:</strong> พันธุ์ต่างๆ มีราคาต่างกัน ข้าวขาว 800-1,200 บาท/ไร่ ข้าวหอมมะลิ 1,500-2,000 บาท/ไร่ ข้าวลูกผสม 2,500-3,500 บาท/ไร่</li>
        <li><strong>ปุ๋ยเคมี:</strong> ประมาณ 2,000-3,500 บาท/ไร่ (ใส่ 2-3 ครั้งต่อฤดู)</li>
        <li><strong>ยาเคมี:</strong> ประมาณ 1,500-2,500 บาท/ไร่ สำหรับควบคุมศัตรูพืชและหญ้ากลา</li>
        <li><strong>ค่าน้ำ:</strong> ประมาณ 400-800 บาท/ไร่ หากมีระบบชลประทาน</li>
        <li><strong>แรงงาน:</strong> ประมาณ 3,000-5,000 บาท/ไร่ (หากจ้างแรงงาน)</li>
        <li><strong>เช่าเครื่องจักร:</strong> ประมาณ 2,000-3,500 บาท/ไร่ สำหรับไถ เก็บเกี่ยว ฯลฯ</li>
        <li><strong>อบแห้งและเก็บรักษา:</strong> ประมาณ 800-1,200 บาท/ไร่</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เปรียบเทียบผลผลิตและรายได้แต่ละพันธุ์</h3>

      <div class="overflow-x-auto my-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b-2 border-gray-300">
              <th class="py-2 pr-4">พันธุ์ข้าว</th>
              <th class="py-2 pr-4">ผลผลิต (กก./ไร่)</th>
              <th class="py-2 pr-4">ราคาตลาด (บาท/กก.)</th>
              <th class="py-2">รายได้โดยประมาณ</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4"><strong>ข้าวขาว</strong></td>
              <td class="py-2 pr-4">400-500</td>
              <td class="py-2 pr-4">5-7</td>
              <td class="py-2">2,000-3,500 บาท</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4"><strong>ข้าวเหนียว</strong></td>
              <td class="py-2 pr-4">400-450</td>
              <td class="py-2 pr-4">6-8</td>
              <td class="py-2">2,400-3,600 บาท</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4"><strong>ข้าวหอมมะลิ</strong></td>
              <td class="py-2 pr-4">350-400</td>
              <td class="py-2 pr-4">8-10</td>
              <td class="py-2">2,800-4,000 บาท</td>
            </tr>
            <tr>
              <td class="py-2 pr-4"><strong>ข้าวลูกผสม</strong></td>
              <td class="py-2 pr-4">500-700</td>
              <td class="py-2 pr-4">6-7</td>
              <td class="py-2">3,000-4,900 บาท</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีลดต้นทุนการปลูกข้าว</h3>

      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li><strong>ใช้แรงงานในครอบครัว:</strong> ลดค่าแรงงานได้ 30-40%</li>
        <li><strong>ร่วมกันเช่าเครื่องจักร:</strong> หากมีหลายคนปลูก สามารถลดค่าเช่าได้</li>
        <li><strong>ใช้ปุ๋ยหมัก:</strong> ลดค่าปุ๋ยเคมีได้ แต่ต้องเตรียมเพิ่มเติม</li>
        <li><strong>บ่อฉ่า:</strong> ลดค่ายาเคมี แต่ต้องเอาดีเอากำไรกับโรค</li>
        <li><strong>เก็บเมล็ดข้าว:</strong> ปลูกพันธุ์เดิมซ้ำ ลดค่าเมล็ด 50% ในปีถัดไป</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณ-ต้นทุนการปลูกข้าว/" />
    <RelatedCalculators currentHref="/คำนวณ-ต้นทุนการปลูกข้าว/" />

    <!-- Official References -->
    <section class="mb-8">
      <h3 class="mb-3 text-lg font-semibold text-gray-900">แหล่งอ้างอิงทางการ</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="https://www.doa.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">กรมส่งเสริมการเกษตร — ข้อมูลต้นทุนและเทคนิคการปลูกข้าว</a></li>
        <li><a href="https://www.rice.in.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">สำนักงานเมืองข้าว — ข้าวไทย พันธุ์ และข้อมูล</a></li>
        <li><a href="https://www.oae.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">สำนักงานเศรษฐกิจการเกษตร — ราคาและตลาดข้าว</a></li>
