---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ งบประมาณ Google Ads 2569 | Kamnuanlek';
const pageDescription = 'คำนวณงบประมาณ Google Ads โปรแกรม CPC/ROAS ประเมิน Cost per Lead/Sale และ ROI อย่างแม่นยำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-งบประมาณ-google-ads/`;

const faqData = [
  {
    question: 'Google Ads CPC และ ROAS คืออะไร?',
    answer: 'CPC (Cost Per Click) = ค่าต่อครั้งที่ลูกค้าคลิก ตัวอย่าง: ใช้ 1,000 บาท ได้ 100 clicks = 10 บาท/click ROAS (Return on Ad Spend) = ยอดขาย ÷ ค่า Ads ตัวอย่าง: ใช้ 1,000 บาท ขายได้ 5,000 = ROAS 5:1 (ลงทุน 1 ได้ 5)',
  },
  {
    question: 'ควรตั้ง Budget Google Ads เท่าไร?',
    answer: 'ขึ้นอยู่กับ CPC ในอุตสาหกรรม: E-commerce 5-50 บาท, B2B 50-200 บาท, Lead Gen 20-100 บาท เริ่มต้นแนะนำ 3,000-10,000 บาท/เดือน เพื่อเก็บข้อมูล ใช้เข้า Machine Learning Google',
  },
  {
    question: 'วิธีคำนวณ ROI Google Ads?',
    answer: 'ROI = (ยอดขาย - Cost Google Ads) ÷ Cost × 100 ตัวอย่าง: ใช้ 5,000 บาท ได้ยอดขาย 20,000 บาท = (20,000 - 5,000) ÷ 5,000 = 300% ROI',
  },
  {
    question: 'เพื่อให้ ROI Google Ads ดีขึ้น?',
    answer: 'ปรับปรุง Quality Score: Landing Page ความเร็ว Ad Relevance CTR ดี ตั้ง Target Keywords ที่แม่นยำ Negative Keywords เพื่อไม่เสิเสืียงค่า A/B Test: ทดลอง Ad Copy, Landing Page Bid Adjustment ตามอุปกรณ์อื่นๆ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบประมาณ Google Ads',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบประมาณ Google Ads">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      📢 คำนวณงบประมาณ Google Ads
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณงบประมาณ Google Ads โปรแกรม CPC/ROAS
      ประเมิน Cost per Lead/Sale และ ROI อย่างแม่นยำ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="ads-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="daily-budget" class="block text-sm font-medium text-gray-700 mb-1">
              งบประมาณต่อวัน (บาท)
            </label>
            <input
              type="text"
              id="daily-budget"
              inputmode="numeric"
              placeholder="เช่น 500"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="avg-cpc" class="block text-sm font-medium text-gray-700 mb-1">
              CPC เฉลี่ย (บาท)
            </label>
            <input
              type="text"
              id="avg-cpc"
              inputmode="numeric"
              placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="conversion-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Conversion Rate (%)
            </label>
            <input
              type="text"
              id="conversion-rate"
              inputmode="numeric"
              placeholder="เช่น 5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="avg-order-value" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าคำสั่งเฉลี่ย (บาท)
            </label>
            <input
              type="text"
              id="avg-order-value"
              inputmode="numeric"
              placeholder="เช่น 500"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="marketing-days" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนวันรัน Ads
          </label>
          <input
            type="text"
            id="marketing-days"
            inputmode="numeric"
            placeholder="เช่น 30"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณงบประมาณ
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ Google Ads</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">งบรวม</div>
            <div id="res-total-budget" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Clicks คาดหวัง</div>
            <div id="res-clicks" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Conversions</div>
            <div id="res-conversions" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดขายคาดหวัง</div>
            <div id="res-expected-revenue" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">งบต่อวัน</span>
            <span id="res-daily" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">CPC เฉลี่ย</span>
            <span id="res-cpc" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">Cost per Lead (CPL)</span>
            <span id="res-cpl" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">ROI %</span>
            <span id="res-roi" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">Google Ads: ลงทุนฉลาด ROI สูง</h2>

      <p>
        Google Ads เป็นช่องทางโฆษณาที่ทรงพลัง แต่ต้องวางแผนงบประมาณให้ถูกต้อง
        ตั้งเป้าหมาย CPA/ROAS ให้เหมาะสม แล้วติดตามผล ปรับปรุงอย่างต่อเนื่อง
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">CPC ตามอุตสาหกรรม</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>E-commerce</strong> — 5-30 บาท ขึ้นอยู่กับความแข่งขัน</li>
        <li><strong>B2B/Lead Gen</strong> — 50-300 บาท ค่ากว่า แต่值 Lead สูง</li>
        <li><strong>Local Business</strong> — 10-50 บาท การเอานอน ที่มีท้องถิ่น</li>
        <li><strong>App Download</strong> — 20-100 บาท โดยเฉพาะ iOS</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวชี้วัดสำคัญ</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>CTR (Click-Through Rate)</strong> — % clicks ÷ impressions ควร 1-5% ขึ้นกับ Industry</li>
        <li><strong>Quality Score</strong> — 1-10 ยิ่งสูง CPC ยิ่งต่ำ ต้องเพิ่ม Landing Page Quality</li>
        <li><strong>Conversion Rate</strong> — % visitors ซื้อ ควร 2-10% ทั่วไป</li>
        <li><strong>ROAS</strong> — Revenue ÷ Ad Spend ควร 3:1 ขึ้นไป เพื่อคุ้ม</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีปรับปรุง Google Ads</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ปรับปรุง Landing Page: ความเร็ว Design Mobile-friendly Call-to-Action ชัดเจน</li>
        <li>Keywords ที่เหมาะ: ใช้ Broad Match สำหรับ Data, Phrase/Exact ให้ Targeted</li>
        <li>Ad Copy Testing: ทดลอง Headline, Description หลาย Version</li>
        <li>Bid Strategy: ใช้ Target CPA/ROAS ให้ Google optimize ให้เอง</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-งบประมาณ-google-ads/" />
    <RelatedCalculators currentHref="/คำนวณ-งบประมาณ-google-ads/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ
      ผลจริงขึ้นอยู่กับ Quality Score, Landing Page, Target Audience
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('ads-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const dailyBudget = parseNum((document.getElementById('daily-budget') as HTMLInputElement).value);
      const avgCpc = parseNum((document.getElementById('avg-cpc') as HTMLInputElement).value);
      const conversionRate = parseNum((document.getElementById('conversion-rate') as HTMLInputElement).value);
      const avgOrderValue = parseNum((document.getElementById('avg-order-value') as HTMLInputElement).value);
      const marketingDays = parseNum((document.getElementById('marketing-days') as HTMLInputElement).value);

      if (dailyBudget <= 0) { (document.getElementById('daily-budget') as HTMLInputElement).focus(); return; }
      if (avgCpc <= 0) { (document.getElementById('avg-cpc') as HTMLInputElement).focus(); return; }
      if (conversionRate <= 0) { (document.getElementById('conversion-rate') as HTMLInputElement).focus(); return; }
      if (avgOrderValue <= 0) { (document.getElementById('avg-order-value') as HTMLInputElement).focus(); return; }
      if (marketingDays <= 0) { (document.getElementById('marketing-days') as HTMLInputElement).focus(); return; }

      const totalBudget = dailyBudget * marketingDays;
      const clicks = totalBudget / avgCpc;
      const conversions = (clicks * conversionRate) / 100;
      const expectedRevenue = conversions * avgOrderValue;
      const cpl = clicks > 0 ? totalBudget / conversions : 0;
      const roi = ((expectedRevenue - totalBudget) / totalBudget) * 100;

      (document.getElementById('res-total-budget') as HTMLElement).textContent = fmt(totalBudget) + ' บาท';
      (document.getElementById('res-clicks') as HTMLElement).textContent = clicks.toFixed(0);
      (document.getElementById('res-conversions') as HTMLElement).textContent = conversions.toFixed(0);
      (document.getElementById('res-expected-revenue') as HTMLElement).textContent = fmt(expectedRevenue) + ' บาท';
      (document.getElementById('res-daily') as HTMLElement).textContent = fmt(dailyBudget) + ' บาท';
      (document.getElementById('res-cpc') as HTMLElement).textContent = fmt(avgCpc) + ' บาท';
      (document.getElementById('res-cpl') as HTMLElement).textContent = fmt(cpl) + ' บาท';
      (document.getElementById('res-roi') as HTMLElement).textContent = roi.toFixed(1) + '%';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('google-ads-budget');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('google-ads-budget');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
