---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าจ้างรายวัน 2569 | แปลงเงินเดือนเป็นรายวัน พร้อมค่าโอที | Kamnuanlek';
const description = 'วิธีแปลงเงินเดือนเป็นค่าจ้างรายวัน หรือรายวันเป็นรายเดือน พร้อมคำนวณค่าโอทีและประกันสังคม อ้างอิง พ.ร.บ. คุ้มครองแรงงาน 2541';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าจ้างรายวัน-2569-แปลงเงินเดือน-ค่าโอที/`;

const faqData = [
  {
    question: 'แปลงเงินเดือนเป็นรายวันสูตรคืออะไร?',
    answer: 'ค่าจ้างรายวัน = เงินเดือน ÷ จำนวนวันทำงานต่อเดือน เช่น 15,000 ÷ 26 = 576.92 บาท/วัน หรือ 15,000 ÷ 22 = 681.82 บาท/วัน แล้วแต่จำนวนวันทำงานจริง',
  },
  {
    question: 'ค่าจ้างรายวันกับค่าจ้างรายเดือนต่างกันยังไงทางกฎหมาย?',
    answer: 'ลูกจ้างรายวันจะได้ค่าจ้างเฉพาะวันที่ทำงาน ส่วนลูกจ้างรายเดือนได้ค่าจ้างคงที่ทุกเดือน รวมวันหยุดนักขัตฤกษ์ด้วย ทำให้สิทธิค่าทำงานวันหยุดต่างกัน',
  },
  {
    question: 'ค่าจ้างต่อชั่วโมงคิดยังไง?',
    answer: 'ค่าจ้างต่อชั่วโมง = ค่าจ้างรายวัน ÷ 8 ชั่วโมง (สำหรับงาน 8 ชม./วัน) ค่านี้ใช้เป็นฐานคำนวณค่าโอที',
  },
  {
    question: 'เงินเดือน 15,000 คิดค่าประกันสังคมเท่าไร?',
    answer: 'เงินเดือน 15,000 บาท หักประกันสังคม 5% = 750 บาท/เดือน ซึ่งเป็นเพดานสูงสุดของการหักเงินสมทบประกันสังคมมาตรา 33',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-20"
  modifiedDate="2026-04-20"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    คำนวณค่าจ้างรายวัน 2569: แปลงเงินเดือนเป็นรายวัน พร้อมค่าโอทีและประกันสังคม
  </h1>

  <p>
    ลูกจ้างหลายคนต้องการรู้ว่าเงินเดือนของตัวเองเทียบเท่าค่าจ้างรายวันเท่าไร
    เพราะเป็นฐานสำคัญสำหรับคำนวณค่าโอที ค่าทำงานวันหยุด และตรวจสอบว่าค่าจ้างไม่ต่ำกว่าค่าแรงขั้นต่ำ
    บทความนี้อธิบายวิธีแปลงค่าจ้างทั้งสองทิศทาง พร้อมตัวอย่างเป็นเงินบาท
    และวิธีคำนวณค่าโอทีจากฐานค่าจ้างรายวัน อ้างอิง พ.ร.บ. คุ้มครองแรงงาน พ.ศ. 2541
  </p>

  <ArticleCalculatorCTA
    title="แปลงค่าจ้างรายวัน-รายเดือนทันที"
    description="กรอกเงินเดือนหรือค่าจ้างรายวัน เลือกจำนวนวันทำงาน เพื่อดูผลคำนวณพร้อมค่าโอที"
    href="/คำนวณค่าจ้างรายวัน/"
    buttonLabel="ไปที่เครื่องคำนวณค่าจ้างรายวัน"
  />

  <h2>สูตรแปลงเงินเดือนเป็นค่าจ้างรายวัน</h2>

  <p>
    <strong>ค่าจ้างรายวัน = เงินเดือน ÷ จำนวนวันทำงานต่อเดือน</strong>
  </p>

  <p>จำนวนวันทำงานขึ้นอยู่กับนโยบายบริษัท:</p>

  <ul>
    <li>ทำงาน 5 วัน/สัปดาห์ → ประมาณ 22 วัน/เดือน</li>
    <li>ทำงาน 6 วัน/สัปดาห์ → ประมาณ 26 วัน/เดือน</li>
  </ul>

  <h3>ตัวอย่าง: เงินเดือน 15,000 บาท</h3>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">จำนวนวันทำงาน</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ค่าจ้างรายวัน</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ค่าจ้างต่อชั่วโมง</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">22 วัน</td>
          <td class="border border-gray-200 px-3 py-2">15,000 ÷ 22 = 681.82 บาท</td>
          <td class="border border-gray-200 px-3 py-2">681.82 ÷ 8 = 85.23 บาท</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">26 วัน</td>
          <td class="border border-gray-200 px-3 py-2">15,000 ÷ 26 = 576.92 บาท</td>
          <td class="border border-gray-200 px-3 py-2">576.92 ÷ 8 = 72.12 บาท</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p>
    สังเกตว่าจำนวนวันทำงานมีผลอย่างมากต่อค่าจ้างต่อชั่วโมง
    ซึ่งเป็นฐานคำนวณค่าโอทีทั้งหมด จึงต้องใช้ตัวเลขที่ตรงกับวันทำงานจริง
  </p>

  <h2>สูตรแปลงค่าจ้างรายวันเป็นรายเดือน</h2>

  <p>
    <strong>เงินเดือน = ค่าจ้างรายวัน × จำนวนวันทำงานต่อเดือน</strong>
  </p>

  <h3>ตัวอย่าง: ค่าจ้าง 500 บาท/วัน</h3>

  <ul>
    <li>ทำงาน 22 วัน: 500 × 22 = <strong>11,000 บาท/เดือน</strong></li>
    <li>ทำงาน 26 วัน: 500 × 26 = <strong>13,000 บาท/เดือน</strong></li>
  </ul>

  <h2>คำนวณค่าโอทีจากค่าจ้างรายวัน</h2>

  <p>
    ค่าโอทีใช้ฐานค่าจ้างต่อชั่วโมง ซึ่งได้จาก ค่าจ้างรายวัน ÷ 8
    จากนั้นคูณตัวคูณตาม พ.ร.บ. คุ้มครองแรงงาน มาตรา 61–63:
  </p>

  <h3>ตัวอย่าง: ค่าจ้าง 500 บาท/วัน (ค่าจ้าง/ชม. = 62.50 บาท)</h3>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[560px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ประเภท OT</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ตัวคูณ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">คำนวณ (2 ชม.)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ค่าโอที</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">OT วันทำงาน (ม.61)</td>
          <td class="border border-gray-200 px-3 py-2">1.5 เท่า</td>
          <td class="border border-gray-200 px-3 py-2">62.50 × 1.5 × 2</td>
          <td class="border border-gray-200 px-3 py-2"><strong>187.50 บาท</strong></td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ทำงานวันหยุด (ม.62)</td>
          <td class="border border-gray-200 px-3 py-2">2 เท่า</td>
          <td class="border border-gray-200 px-3 py-2">62.50 × 2 × 2</td>
          <td class="border border-gray-200 px-3 py-2"><strong>250 บาท</strong></td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">OT วันหยุด (ม.63)</td>
          <td class="border border-gray-200 px-3 py-2">3 เท่า</td>
          <td class="border border-gray-200 px-3 py-2">62.50 × 3 × 2</td>
          <td class="border border-gray-200 px-3 py-2"><strong>375 บาท</strong></td>
        </tr>
      </tbody>
    </table>
  </div>

  <ArticleCalculatorCTA
    title="คำนวณค่าจ้างรายวันและค่าโอทีจากเงินเดือนจริงของคุณ"
    description="กรอกตัวเลขเงินเดือนหรือค่าจ้างรายวัน เพื่อดูค่าโอทีและรายได้รวม"
    href="/คำนวณค่าจ้างรายวัน/"
    buttonLabel="เปิดเครื่องคำนวณค่าจ้างรายวัน"
  />

  <h2>หักเงินสมทบประกันสังคม</h2>

  <p>
    ลูกจ้างทั้งรายวันและรายเดือนที่เข้ามาตรา 33 ต้องจ่ายเงินสมทบประกันสังคม 5% ของค่าจ้าง
    โดยมีเพดานที่ 15,000 บาท (สมทบสูงสุด 750 บาท/เดือน) และขั้นต่ำ 1,650 บาท (สมทบขั้นต่ำ 83 บาท/เดือน)
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[400px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">เงินเดือน</th>
          <th class="border border-gray-200 px-3 py-2 text-left">หัก 5%</th>
          <th class="border border-gray-200 px-3 py-2 text-left">รับสุทธิ</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">11,000</td>
          <td class="border border-gray-200 px-3 py-2">550</td>
          <td class="border border-gray-200 px-3 py-2">10,450</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">13,000</td>
          <td class="border border-gray-200 px-3 py-2">650</td>
          <td class="border border-gray-200 px-3 py-2">12,350</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">15,000</td>
          <td class="border border-gray-200 px-3 py-2">750</td>
          <td class="border border-gray-200 px-3 py-2">14,250</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">20,000</td>
          <td class="border border-gray-200 px-3 py-2">750 (เพดาน)</td>
          <td class="border border-gray-200 px-3 py-2">19,250</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>ข้อต่างระหว่างลูกจ้างรายวันกับรายเดือน</h2>

  <ul>
    <li><strong>รายวัน:</strong> ได้ค่าจ้างเฉพาะวันที่ทำงาน ไม่ทำไม่ได้เงิน วันหยุดนักขัตฤกษ์ขึ้นอยู่กับข้อตกลง</li>
    <li><strong>รายเดือน:</strong> ได้เงินเดือนคงที่ รวมวันหยุดนักขัตฤกษ์ ลาป่วยได้ค่าจ้าง</li>
    <li><strong>ค่าทำงานวันหยุด:</strong> ลูกจ้างรายวันได้ไม่น้อยกว่า 2 เท่า (ม.62) ลูกจ้างรายเดือนได้ 1 เท่า (เพราะวันหยุดได้ค่าจ้างอยู่แล้ว)</li>
  </ul>

  <h2>ตัวอย่างรายได้รวมต่อเดือน (รวมโอที)</h2>

  <p>สมมติค่าจ้าง 500 บาท/วัน ทำงาน 26 วัน มี OT วันทำงาน 15 ชม. และทำงานวันหยุด 8 ชม.:</p>

  <ol>
    <li>ค่าจ้างรายเดือน: 500 × 26 = <strong>13,000 บาท</strong></li>
    <li>OT วันทำงาน: 62.50 × 1.5 × 15 = <strong>1,406.25 บาท</strong></li>
    <li>ค่าทำงานวันหยุด: 62.50 × 2 × 8 = <strong>1,000 บาท</strong></li>
    <li>รายได้รวม: 13,000 + 1,406.25 + 1,000 = <strong>15,406.25 บาท</strong></li>
    <li>หักประกันสังคม (5% จาก 13,000): <strong>650 บาท</strong></li>
    <li>รายได้สุทธิ: 15,406.25 – 650 = <strong>14,756.25 บาท</strong></li>
  </ol>

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณค่าจ้างรายวัน/">คำนวณค่าจ้างรายวัน</a> แปลงเงินเดือนเป็นรายวันหรือรายวันเป็นรายเดือน</li>
    <li><a href="/คำนวณค่าโอที/">คำนวณค่าโอที</a> คำนวณค่าล่วงเวลา 1.5/2/3 เท่า</li>
    <li><a href="/คำนวณค่าแรงขั้นต่ำ/">คำนวณค่าแรงขั้นต่ำ</a> เช็กอัตราค่าแรงขั้นต่ำทุกจังหวัด</li>
    <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a> ดูเงินรับจริงหลังหักภาษีและประกันสังคม</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/คำนวณค่าโอที-2569-กฎหมายแรงงาน/">คำนวณโอที ปี 2569 ค่าล่วงเวลา 1.5/2/3 เท่า</a></li>
    <li><a href="/บทความ/คำนวณค่าแรงขั้นต่ำ-2569-รายวัน-รายเดือน-ทุกจังหวัด/">ค่าแรงขั้นต่ำ 2569 ทุกจังหวัด</a></li>
    <li><a href="/บทความ/คำนวณประกันสังคม-2569-มาตรา-33-39-40-เงินสมทบ/">คำนวณประกันสังคม 2569</a></li>
  </ul>
</BlogPostLayout>
