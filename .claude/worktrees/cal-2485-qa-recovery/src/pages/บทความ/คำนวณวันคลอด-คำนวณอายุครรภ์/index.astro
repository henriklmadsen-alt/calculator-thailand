const faqData = [
  {
    question: 'คำนวณวันคลอดจากประจำเดือนครั้งล่าสุดยังไง?',
    answer: 'ใช้หลัก Naegele โดยนับจากวันแรกของประจำเดือนครั้งล่าสุด (LMP) แล้วบวก 280 วัน หรือ 40 สัปดาห์ เพื่อได้วันครบกำหนดคลอดโดยประมาณ',
  },
  {
    question: 'ถ้ารู้วันปฏิสนธิ จะคำนวณวันคลอดได้ไหม?',
    answer: 'ได้ โดยทั่วไปจะประมาณเป็น 38 สัปดาห์หลังวันปฏิสนธิ (ประมาณ 266 วัน) ซึ่งสอดคล้องกับการนับอายุครรภ์ที่เริ่มจาก LMP',
  },
  {
    question: 'ทำไมวันคลอดที่คำนวณได้กับผลอัลตราซาวด์ไม่ตรงกัน?',
    answer: 'เพราะวันตกไข่จริงอาจไม่ตรงกับรอบ 28 วัน และรอบเดือนอาจไม่สม่ำเสมอ จึงใช้ผลอัลตราซาวด์ช่วงต้นครรภ์ช่วยปรับอายุครรภ์ให้แม่นยำขึ้น',
  },
  {
    question: 'ครบกำหนดคลอดตรงวันนั้นพอดีทุกคนไหม?',
    answer: 'ไม่จำเป็น วันกำหนดคลอดเป็นค่าประมาณ โดยการตั้งครรภ์ปกติอาจอยู่ในช่วงประมาณ 37-42 สัปดาห์ จึงควรใช้วันกำหนดคลอดเพื่อวางแผน ไม่ใช่เป็นเส้นตายแน่นอน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-19"
  modifiedDate="2026-04-19"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    คำนวณวันคลอด 2569: คำนวณอายุครรภ์และกำหนดคลอดอย่างไรให้ใช้งานได้จริง
  </h1>

  <p>
    ถ้าคุณกำลังค้นหาคำว่า <strong>คำนวณวันคลอด</strong>, <strong>คำนวณอายุครรภ์</strong>,
    หรือ <strong>วันครบกำหนดคลอดคิดยังไง</strong> บทความนี้สรุปวิธีนับแบบที่ใช้จริงในงานฝากครรภ์ให้เข้าใจง่าย
    โดยแยกทั้งกรณีที่เริ่มจากวันแรกของประจำเดือนครั้งล่าสุด และกรณีที่ทราบวันปฏิสนธิ
    เพื่อให้คุณวางแผนการตรวจครรภ์ การเตรียมคลอด และการลางานได้เป็นระบบมากขึ้น
  </p>

  <p>
    สิ่งสำคัญคือ “วันกำหนดคลอด” เป็นค่าประมาณ ไม่ใช่วันที่ต้องคลอดตรงเป๊ะทุกคน
    ดังนั้นการใช้เครื่องคำนวณควรเน้นเพื่อวางแผนและติดตามพัฒนาการครรภ์ร่วมกับการพบแพทย์ตามนัด
    โดยเฉพาะช่วงไตรมาสแรกที่ข้อมูลอัลตราซาวด์ช่วยยืนยันอายุครรภ์ได้ดีขึ้น
  </p>

  <ArticleCalculatorCTA
    title="คำนวณวันคลอดและอายุครรภ์จากข้อมูลของคุณทันที"
    description="กรอกวันแรกของประจำเดือนครั้งล่าสุดหรือวันปฏิสนธิ แล้วดูวันครบกำหนดคลอดโดยประมาณ"
    href="/คำนวณวันคลอด/"
    targetCalculator="due_date_pregnancy_age"
    buttonLabel="ไปที่เครื่องคำนวณวันคลอด"
  />

  <h2>หลักคำนวณวันคลอดที่ควรรู้ก่อนเริ่ม</h2>

  <p>
    แนวทางที่ใช้กันแพร่หลายคือการนับจาก <strong>วันแรกของประจำเดือนครั้งล่าสุด (LMP)</strong>
    แล้วบวก <strong>280 วัน (40 สัปดาห์)</strong> ซึ่งสอดคล้องกับแนวทางในแหล่งอ้างอิงทางการแพทย์
    และเป็นฐานเดียวกับเครื่องมือคำนวณวันคลอดส่วนใหญ่
  </p>

  <p>
    อีกวิธีคือ <strong>Naegele's Rule</strong> ที่เขียนให้นับง่ายในปฏิทิน:
    เอาวันแรกของ LMP <strong>บวก 7 วัน</strong>, <strong>ลบ 3 เดือน</strong>, และ <strong>บวก 1 ปี</strong>
    ซึ่งให้ผลเท่ากับการบวก 280 วันในทางปฏิบัติ
  </p>

  <ul>
    <li><strong>สูตรหลัก:</strong> วันครบกำหนดคลอด (EDD) = LMP + 280 วัน</li>
    <li><strong>สูตรปฏิทิน (Naegele):</strong> LMP + 7 วัน − 3 เดือน + 1 ปี</li>
    <li><strong>กรณีรู้วันปฏิสนธิ:</strong> โดยทั่วไปใช้ประมาณ 38 สัปดาห์หลังปฏิสนธิ (ประมาณ 266 วัน)</li>
  </ul>

  <p>
    หมายเหตุ: ค่า 266 วันเป็นการคำนวณเชิงตรรกะจากการนับอายุครรภ์แบบ LMP 280 วัน
    ร่วมกับข้อเท็จจริงที่การปฏิสนธิมักเกิดราว 2 สัปดาห์หลังเริ่มรอบเดือนในรอบมาตรฐาน
    จึงควรใช้เพื่อประมาณการเบื้องต้นและยืนยันกับทีมฝากครรภ์อีกครั้ง
  </p>

  <h2>วิธีนับอายุครรภ์ ณ วันที่ต้องการ</h2>

  <p>
    การนับอายุครรภ์ทำได้ด้วยหลักเดียวกัน คือดูว่าจาก LMP ถึง “วันที่ต้องการตรวจ” ผ่านไปกี่วัน
    แล้วแปลงเป็นสัปดาห์และวัน
  </p>

  <ul>
    <li><strong>อายุครรภ์ (วัน)</strong> = วันที่ตรวจ − LMP</li>
    <li><strong>อายุครรภ์ (สัปดาห์)</strong> = จำนวนวัน ÷ 7</li>
    <li><strong>เศษวัน</strong> = จำนวนวันที่เหลือหลังหาร 7</li>
  </ul>

  <p>
    ตัวอย่าง: ถ้า LMP คือ 20 มีนาคม 2026 และวันที่ตรวจคือ 19 เมษายน 2026 จะผ่านไป 30 วัน
    เท่ากับอายุครรภ์ <strong>4 สัปดาห์ 2 วัน</strong>
    วิธีนี้ช่วยให้คุณอ่านสมุดฝากครรภ์และติดตามนัดตรวจได้ง่ายขึ้น
  </p>

  <h2>ตัวอย่างคำนวณวันคลอดจริง (2 เคส)</h2>

  <h3>เคสที่ 1: คำนวณจาก LMP</h3>
  <p>
    สมมติวันแรกของประจำเดือนครั้งล่าสุดคือ <strong>1 มกราคม 2026</strong>
  </p>
  <ol>
    <li>ใช้สูตร EDD = LMP + 280 วัน</li>
    <li>1 มกราคม 2026 + 280 วัน = <strong>8 ตุลาคม 2026</strong></li>
  </ol>
  <p>
    ดังนั้นวันครบกำหนดคลอดโดยประมาณคือ <strong>8 ตุลาคม 2026</strong>
  </p>

  <h3>เคสที่ 2: ทราบวันปฏิสนธิ</h3>
  <p>
    สมมติทราบวันปฏิสนธิชัดเจนเป็น <strong>14 กุมภาพันธ์ 2026</strong>
  </p>
  <ol>
    <li>ใช้หลักประมาณ 38 สัปดาห์หลังปฏิสนธิ (266 วัน)</li>
    <li>14 กุมภาพันธ์ 2026 + 266 วัน = <strong>7 พฤศจิกายน 2026</strong></li>
  </ol>
  <p>
    จึงได้วันครบกำหนดคลอดโดยประมาณเป็น <strong>7 พฤศจิกายน 2026</strong>
  </p>

  <h2>เหตุผลที่วันกำหนดคลอดอาจคลาดเคลื่อน</h2>

  <ol>
    <li><strong>รอบเดือนไม่สม่ำเสมอ</strong><br />
      สูตรพื้นฐานมักอ้างอิงรอบเดือนมาตรฐาน 28 วัน หากรอบยาวหรือสั้นกว่านี้ วันตกไข่จริงอาจเลื่อน
      ทำให้วันคำนวณจาก LMP คลาดเคลื่อนได้
    </li>
    <li><strong>จำ LMP ไม่แน่ชัด</strong><br />
      หากจำวันที่เริ่มประจำเดือนครั้งล่าสุดไม่ได้หรือจำวันที่ผิด แม้เพียงไม่กี่วันก็ทำให้ผลขยับทั้งไทม์ไลน์
    </li>
    <li><strong>วันปฏิสนธิจริงต่างจากที่คาด</strong><br />
      แม้ในคนที่รอบเดือนค่อนข้างปกติ วันตกไข่ก็อาจไม่ตรงวันที่ 14 เสมอไป
    </li>
    <li><strong>ผลอัลตราซาวด์ช่วงต้นครรภ์</strong><br />
      แนวทางคลินิกใช้ข้อมูลอัลตราซาวด์ช่วงต้นครรภ์ช่วยยืนยันอายุครรภ์ เพราะให้ความแม่นยำดีกว่าเมื่อข้อมูล LMP ไม่ชัด
    </li>
    <li><strong>การตั้งครรภ์จากเทคโนโลยีช่วยการเจริญพันธุ์</strong><br />
      กรณีนี้สามารถใช้วันที่ปฏิสนธิ/วันที่ทราบแน่ชัดเป็นฐานกำหนด EDD ได้ตรงขึ้น
    </li>
  </ol>

  <h2>ใช้ผลคำนวณให้เกิดประโยชน์อย่างไร</h2>

  <p>
    เมื่อได้วันครบกำหนดคลอดและอายุครรภ์แล้ว แนะนำให้ใช้ผลลัพธ์ใน 3 เรื่องหลัก
  </p>

  <ul>
    <li><strong>วางแผนฝากครรภ์และตรวจตามไตรมาส</strong> เพื่อไม่พลาดช่วงตรวจสำคัญ</li>
    <li><strong>วางแผนงานและการลาคลอด</strong> โดยเผื่อช่วงคลอดก่อน/หลังกำหนด</li>
    <li><strong>ติดตามสุขภาพต่อเนื่อง</strong> เช่น น้ำหนักตัว การเคลื่อนไหว และสัญญาณเตือนที่ต้องพบแพทย์</li>
  </ul>

  <p>
    ถ้าต้องการจัดการข้อมูลส่วนตัวให้ครบขึ้น สามารถใช้
    <a href="/คำนวณอายุ/" data-preserve-utm>เครื่องคำนวณอายุ</a> สำหรับงานเอกสารวันเกิด,
    <a href="/คำนวณเงินเดือนสุทธิ/" data-preserve-utm>เครื่องคำนวณเงินเดือนสุทธิ</a> เพื่อวางแผนรายรับช่วงลาคลอด,
    และ <a href="/คำนวณเปอร์เซ็นต์/" data-preserve-utm>เครื่องคำนวณเปอร์เซ็นต์</a> เมื่อต้องคำนวณสัดส่วนค่าใช้จ่ายเตรียมคลอด
    ควบคู่กันได้ ส่วนการติดตามน้ำหนักระหว่างตั้งครรภ์ควรยึดเกณฑ์ที่แพทย์หรือคลินิกฝากครรภ์แนะนำเป็นหลัก
  </p>

  <ArticleCalculatorCTA
    title="พร้อมแล้วค่อยกรอกข้อมูลจริงเพื่อดูวันครบกำหนดคลอด"
    description="เริ่มจากวันแรกของประจำเดือนครั้งล่าสุด แล้วเทียบผลกับข้อมูลฝากครรภ์ของคุณ"
    href="/คำนวณวันคลอด/"
    targetCalculator="due_date_pregnancy_age"
    buttonLabel="เปิดเครื่องคำนวณวันคลอด"
    placement="mid_article_cta"
  />

  <h2>เครื่องคำนวณและบทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณวันคลอด/" data-preserve-utm>คำนวณวันคลอด</a> สำหรับดู EDD และอายุครรภ์จากข้อมูลวันที่</li>
    <li><a href="/คำนวณอายุ/" data-preserve-utm>คำนวณอายุ</a> ใช้จัดการข้อมูลวันเดือนปีเกิดในเอกสารต่าง ๆ</li>
    <li><a href="/คำนวณเงินเดือนสุทธิ/" data-preserve-utm>คำนวณเงินเดือนสุทธิ</a> เพื่อวางแผนรายรับช่วงเตรียมคลอดและลาคลอด</li>
    <li><a href="/บทความ/เงินเดือนสุทธิ-2569-คำนวณหัก-ประกันสังคม-ภาษี/" data-preserve-utm>บทความเงินเดือนสุทธิ</a> สำหรับเข้าใจยอดรับจริงหลังหักรายการสำคัญ</li>
    <li><a href="/บทความ/คำนวณเปอร์เซ็นต์-2569-ส่วนลด-กำไร/" data-preserve-utm>บทความคำนวณเปอร์เซ็นต์</a> สำหรับวางแผนงบประมาณเตรียมคลอด</li>
  </ul>

  <h2>แหล่งอ้างอิงทางการแพทย์</h2>

  <ul>
    <li>
      NHS (UK): Due date calculator และหลักการนับจากวันแรกของประจำเดือนครั้งล่าสุด
