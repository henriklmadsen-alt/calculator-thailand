const title = 'ภาษีที่ดิน 2569 | อัตราและวิธีคำนวณ | Kamnuanlek';
const description = 'สรุปภาษีที่ดินและสิ่งปลูกสร้างปี 2569: อัตราตามประเภทการใช้ประโยชน์ วิธีคำนวณทีละขั้น ตัวอย่างเงินภาษีจริง และจุดพลาดที่ควรเช็กก่อนจ่าย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
