const title = 'ดอกเบี้ยบัตรเครดิต 2569 คิดยังไง | ขั้นต่ำ 8% | ลดหนี้เร็ว';
const description = 'สรุปดอกเบี้ยบัตรเครดิตคิดยังไงปี 2569 ตามเกณฑ์ ธปท. พร้อมตัวอย่างจ่ายขั้นต่ำ 8% สูตรรายวัน จุดพลาดที่ทำให้หนี้ยืด และวิธีลดดอกเบี้ยให้หนี้ลดเร็ว';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณดอกเบี้ยบัตรเครดิต-2569-วิธีคิดและลดหนี้เร็ว/`;

const faqData = [
  {
    question: 'ดอกเบี้ยบัตรเครดิตปี 2569 เรียกเก็บได้สูงสุดเท่าไร?',
    answer: 'ตามข้อมูลความรู้ของธนาคารแห่งประเทศไทย ผู้ออกบัตรเรียกเก็บดอกเบี้ย ค่าปรับ ค่าบริการ และค่าธรรมเนียมรวมกันได้ไม่เกิน 16% ต่อปี',
  },
  {
    question: 'ดอกเบี้ยบัตรเครดิตคิดรายวันหรือรายเดือน?',
    answer: 'ตามแนวทางที่ ธปท. อธิบาย การคำนวณดอกเบี้ยกรณีจ่ายไม่เต็มจำนวนใช้หลักดอกเบี้ยรายวัน (อัตราต่อปี ÷ 365) แล้วคูณตามจำนวนวันจริงในแต่ละช่วงของรอบบิล',
  },
  {
    question: 'ปี 2569 ขั้นต่ำบัตรเครดิตยังเป็น 8% อยู่หรือไม่?',
    answer: 'ตามข่าว ธปท. ฉบับที่ 47/2568 มาตรการชั่วคราวยังคงอัตราชำระขั้นต่ำ 8% ของยอดคงค้างไปจนถึงวันที่ 31 ธันวาคม 2569',
  },
  {
    question: 'จ่ายขั้นต่ำทุกเดือน หนี้ลดไหม?',
    answer: 'หนี้ลดได้ แต่โดยมากลดช้า เพราะเงินที่จ่ายแต่ละเดือนไปชำระดอกเบี้ยบางส่วนก่อน ถ้าจ่ายมากกว่าขั้นต่ำได้จะช่วยลดดอกเบี้ยรวมและปิดหนี้เร็วกว่า',
  },
  {
    question: 'เบิกเงินสดจากบัตรเครดิตมีต้นทุนเพิ่มอะไรบ้าง?',
