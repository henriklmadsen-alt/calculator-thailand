---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'กู้บ้าน 2,500,000 บาท 30 ปี ค่างวดเท่าไร ต้องมีรายได้เท่าไร | Kamnuanlek';
const description = 'ตัวอย่างการคำนวณผ่อนบ้าน 2,500,000 บาท 30 ปี ดอกเบี้ย 3.5% ค่างวดรายเดือน เปรียบเทียบ 10-30 ปี และรายได้ที่ต้องมีตามเกณฑ์ธนาคาร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/กู้บ้าน-2500000-บาท-30-ปี/`;

const faqData = [
  {
    question: 'กู้บ้าน 2,500,000 บาท 30 ปี ค่าผ่อนเดือนละเท่าไร?',
    answer: 'วางดาวน์ 10% (250,000 บาท) กู้ 2,250,000 บาท ดอกเบี้ย 3.5% ค่าผ่อนประมาณ 10,095 บาท/เดือน ดอกเบี้ยรวมตลอดสัญญาประมาณ 1,384,200 บาท',
  },
  {
    question: 'ต้องมีเงินเดือนเท่าไรถึงจะกู้บ้าน 2.5 ล้านได้?',
    answer: 'ค่าผ่อน 10,095 บาท ÷ 40% = ต้องการรายได้สุทธิอย่างน้อย 25,238 บาท หรือเงินเดือนรวมประมาณ 28,000-30,000 บาทขึ้นไป',
  },
  {
    question: 'ผ่อนบ้าน 20 ปีดีกว่า 30 ปีไหม?',
    answer: 'ผ่อน 20 ปีค่าผ่อน 12,750 บาท/เดือน ดอกเบี้ยรวม 810,000 บาท ส่วนผ่อน 30 ปีค่าผ่อน 10,095 บาท/เดือน แต่ดอกเบี้ยรวม 1,384,200 บาท ต่างกัน 574,200 บาท',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    กู้บ้าน 2,500,000 บาท 30 ปี ค่างวดเท่าไร ต้องมีรายได้เท่าไร
  </h1>

  <p>
    เมื่อตัดสินใจซื้อคอนโดมิเนียมหรือบ้านราคา 2,500,000 บาท หลายคนต้องการรู้ว่า "ค่าผ่อนรายเดือนเท่าไร" และ "ต้องมีเงินเดือนเท่าไรจึงจะสามารถกู้ได้" บทความนี้แสดงตัวอย่างการคำนวณโดยละเอียด
  </p>

  <ArticleCalculatorCTA
    title="คำนวณผ่อนบ้าน"
    description="ใส่ราคาบ้าน เงินดาวน์ อัตราดอกเบี้ย คำนวณค่างวดและดอกเบี้ยรวม"
    href="/คำนวณผ่อนบ้าน/"
    buttonLabel="คำนวณผ่อนบ้านฟรี"
  />

  <h2>ตัวอย่าง: ซื้อบ้าน 2,500,000 บาท ผ่อน 30 ปี</h2>

  <ul>
    <li>ราคาคอนโด: 2,500,000 บาท</li>
    <li>ดาวน์ 10%: 250,000 บาท</li>
    <li>จำนวนกู้: 2,250,000 บาท</li>
    <li>ระยะเวลา: 30 ปี (360 เดือน)</li>
    <li>อัตราดอกเบี้ย: 3.5% ต่อปี (ปี 1-3 คงที่)</li>
  </ul>

  <p><strong>ขั้นตอนการคำนวณ:</strong></p>
  <ol>
    <li>อัตราดอกเบี้ยรายเดือน = 3.5% ÷ 12 = 0.2917% (r = 0.002917)</li>
    <li>ใช้สูตร: ค่าผ่อน = เงินกู้ × [r(1+r)^n] / [(1+r)^n - 1]</li>
    <li><strong>ค่าผ่อน ≈ 10,095 บาท/เดือน</strong></li>
    <li>ดอกเบี้ยทั้งหมด = (10,095 × 360) - 2,250,000 = <strong>1,384,200 บาท</strong></li>
  </ol>

  <h2>สรุปค่าใช้จ่ายบ้าน</h2>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">รายการ</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">จำนวน</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">ราคาเดิม</td><td class="border border-gray-200 px-3 py-2 text-right">2,500,000 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">เงินดาวน์ (10%)</td><td class="border border-gray-200 px-3 py-2 text-right">250,000 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">จำนวนกู้</td><td class="border border-gray-200 px-3 py-2 text-right">2,250,000 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">ค่าผ่อนรายเดือน</td><td class="border border-gray-200 px-3 py-2 text-right font-semibold">10,095 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ดอกเบี้ยสุทธิ</td><td class="border border-gray-200 px-3 py-2 text-right">1,384,200 บาท</td></tr>
      </tbody>
    </table>
  </div>

  <h2>เปรียบเทียบระยะเวลาผ่อนต่างๆ</h2>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">ระยะเวลา</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">ค่าผ่อน/เดือน</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">ดอกเบี้ยรวม</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">10 ปี (120 เดือน)</td><td class="border border-gray-200 px-3 py-2 text-right">24,300 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">666,000 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">15 ปี (180 เดือน)</td><td class="border border-gray-200 px-3 py-2 text-right">16,450 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">711,000 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">20 ปี (240 เดือน)</td><td class="border border-gray-200 px-3 py-2 text-right">12,750 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">810,000 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">30 ปี (360 เดือน)</td><td class="border border-gray-200 px-3 py-2 text-right font-semibold">10,095 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">1,384,200 บาท</td></tr>
      </tbody>
    </table>
  </div>

  <h2>รายได้ที่ต้องมี</h2>

  <p>ธนาคารกำหนดให้ค่าผ่อนบ้านไม่เกิน <strong>40-50%</strong> ของรายได้สุทธิ:</p>
  <ul>
    <li>ค่าผ่อน 10,095 บาท ÷ 40% = ต้องการรายได้สุทธิอย่างน้อย <strong>25,238 บาท</strong></li>
    <li>เงินเดือนรวมประมาณ 28,000-30,000 บาทขึ้นไป</li>
  </ul>

  <p>ตรวจสอบเงินเดือนสุทธิได้ที่ <a href="/คำนวณเงินเดือนสุทธิ/">เครื่องคำนวณเงินเดือนสุทธิ</a></p>

  <h2>วิธีผ่อนบ้านให้คุ้มค่า</h2>

  <ol>
    <li><strong>เพิ่มเงินดาวน์</strong> — ดาวน์มากขึ้น จำนวนกู้น้อยลง ดอกเบี้ยน้อยลง</li>
    <li><strong>กู้ในช่วงดอกเบี้ยต่ำ</strong> — อัตราดอกเบี้ยต่ำช่วยประหยัดได้มาก</li>
    <li><strong>เลือกระยะเวลาที่เหมาะสม</strong> — 20 ปีเป็นจุดสมดุลที่ดีสำหรับส่วนใหญ่</li>
    <li><strong>โปะบ้านเมื่อมีเงินพิเศษ</strong> — ลดเงินต้นเร็ว ดอกเบี้ยรวมลดลงมาก</li>
  </ol>

  <ArticleCalculatorCTA
    title="คำนวณผ่อนบ้านของคุณ"
    description="เปรียบเทียบค่าผ่อนและดอกเบี้ยรวมสำหรับทุกระยะเวลา"
    href="/คำนวณผ่อนบ้าน/"
    buttonLabel="คำนวณผ่อนบ้านตอนนี้"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
