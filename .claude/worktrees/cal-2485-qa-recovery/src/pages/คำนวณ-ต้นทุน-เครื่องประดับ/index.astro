---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransparencyPanel from '../../components/templates/TransparencyPanel.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';

const pageTitle = 'คำนวณต้นทุนการทำเครื่องประดับ 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนโลหะ อัญมณี ลูกปัด สำหรับสร้างเครื่องประดับ รู้ราคาขายที่เหมาะสมฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุน-เครื่องประดับ/`;

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนการทำเครื่องประดับ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  pageName="คำนวณต้นทุนการทำเครื่องประดับ"
  categoryId="hobby"
  categoryName="งานอดิเรก/ศิลปะ"
  categorySlug="งานอดิเรก"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />

  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-4">คำนวณต้นทุนการทำเครื่องประดับ</h1>

    <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนโลหะ (บาท)</label>
          <input type="number" id="metal" placeholder="500" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนอัญมณี (บาท)</label>
          <input type="number" id="gems" placeholder="300" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนเครื่องมือ (บาท)</label>
          <input type="number" id="tools" placeholder="200" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนลูกปัดและด้าย (บาท)</label>
          <input type="number" id="beads" placeholder="100" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนตัวล็อค/หนีบ (บาท)</label>
          <input type="number" id="clasps" placeholder="80" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนสี/ขัดเงา (บาท)</label>
          <input type="number" id="polish" placeholder="50" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนบรรจุภัณฑ์ (บาท)</label>
          <input type="number" id="packaging" placeholder="100" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนอื่นๆ (บาท)</label>
          <input type="number" id="other" placeholder="50" class="w-full border rounded px-3 py-2" />
        </div>
      </div>
      <button class="mt-6 w-full bg-blue-600 text-white py-2 rounded font-bold hover:bg-blue-700">
        คำนวณ
      </button>
    </div>

    <div id="result" class="hidden bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg shadow-lg p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">ผลลัพธ์</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ต้นทุนรวม</p>
          <p class="text-3xl font-bold text-blue-600" id="totalCost">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ราคาขายแนะนำ</p>
          <p class="text-3xl font-bold text-green-600" id="sellingPrice">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">กำไรต่อชิ้น</p>
          <p class="text-3xl font-bold text-green-600" id="profit">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
      </div>
    </div>

    <TransparencyPanel
      dataOrigin="การคำนวณจากต้นทุนวัสดุสำหรับเครื่องประดับ"
      lastUpdated="2026-04-22"
      accuracy="ความแม่นยำขึ้นอยู่กับต้นทุนที่ป้อนเข้า"
    />

    <GuardedAdSlot adUnitId="jewelry-calculator" position="bottom" />
    <RelatedCalculators />
  </div>

  <script is:inline>
    function calculate() {
      const totalCost = Math.round(
        (parseFloat(document.getElementById('metal').value) || 0) +
        (parseFloat(document.getElementById('gems').value) || 0) +
        (parseFloat(document.getElementById('tools').value) || 0) +
        (parseFloat(document.getElementById('beads').value) || 0) +
        (parseFloat(document.getElementById('clasps').value) || 0) +
        (parseFloat(document.getElementById('polish').value) || 0) +
        (parseFloat(document.getElementById('packaging').value) || 0) +
        (parseFloat(document.getElementById('other').value) || 0)
      );
      const sellingPrice = Math.round(totalCost * 3.5);
      const profit = sellingPrice - totalCost;

      document.getElementById('result').classList.remove('hidden');
      document.getElementById('totalCost').textContent = totalCost.toLocaleString('th-TH');
      document.getElementById('sellingPrice').textContent = sellingPrice.toLocaleString('th-TH');
      document.getElementById('profit').textContent = Math.round(profit).toLocaleString('th-TH');
    }

    document.querySelector('button').addEventListener('click', calculate);
    document.querySelectorAll('input').forEach(input => {
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') calculate();
      });
    });

    window.addEventListener('load', () => {
      document.getElementById('metal').value = '500';
      document.getElementById('gems').value = '300';
      document.getElementById('tools').value = '200';
      document.getElementById('beads').value = '100';
      document.getElementById('clasps').value = '80';
      document.getElementById('polish').value = '50';
      document.getElementById('packaging').value = '100';
      document.getElementById('other').value = '50';
      calculate();
    });
  </script>
</BaseLayout>
