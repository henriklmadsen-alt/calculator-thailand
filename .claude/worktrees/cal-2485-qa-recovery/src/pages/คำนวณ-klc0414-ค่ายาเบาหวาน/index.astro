---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่ายาเบาหวาน | Kamnuanlek';
const pageDescription = 'คำนวณค่ายาเบาหวาน ค่ายาแผนกลูโคส อินซูลิน ค่าติดตามน้ำตาล ต้นทุนรายเดือน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0414-ค่ายาเบาหวาน/`;

const faqData = [
  { question: 'ค่ายาเบาหวานเดือนละเท่าไหร่?', answer: 'ยาเบาหวานรับประทานชนิดพื้นฐาน 500-2,000 บาทต่อเดือน ยาฉีดอินซูลิน 1,500-5,000 บาทต่อเดือน ขึ้นอยู่กับชนิดยาและโรงพยาบาล' },
  { question: 'เครื่องวัดน้ำตาลราคาเท่าไหร่?', answer: 'เครื่องวัดน้ำตาลในเลือด 500-3,000 บาท แผ่นตรวจ (Test Strip) 30-60 บาทต่อแผ่น วัดวันละครั้งค่าใช้จ่ายประมาณ 1,000-2,000 บาทต่อเดือน' },
  { question: 'บัตรทองคลุมค่ายาเบาหวานไหม?', answer: 'ผู้มีสิทธิ์บัตรทองได้รับยาเบาหวานพื้นฐานฟรีที่โรงพยาบาลรัฐ แต่ยาใหม่หรือยาบางชนิดอาจต้องจ่ายเพิ่ม ขึ้นอยู่กับบัญชียาหลัก' },
  { question: 'เบาหวานชนิด 2 ป้องกันได้ไหม?', answer: 'เบาหวานชนิด 2 ป้องกันได้ด้วยการควบคุมน้ำหนัก ออกกำลังกาย และอาหาร กลุ่มเสี่ยงอาจลดโอกาสเกิดโรคได้ 58% ด้วยการเปลี่ยนวิถีชีวิต' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่ายาเบาหวาน">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่ายาเบาหวาน</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าใช้จ่ายรายเดือนสำหรับผู้ป่วยเบาหวาน</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="oral_meds" class="block text-sm font-medium text-gray-700 mb-1">ค่ายาเบาหวานรับประทาน/เดือน (บาท)</label><input type="text" id="oral_meds" inputmode="decimal" placeholder="เช่น 1200" value="1200" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="insulin" class="block text-sm font-medium text-gray-700 mb-1">ค่ายาฉีดอินซูลิน/เดือน (บาท)</label><input type="text" id="insulin" inputmode="decimal" placeholder="เช่น 0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="test_strips" class="block text-sm font-medium text-gray-700 mb-1">ค่าแผ่นตรวจน้ำตาล/เดือน (บาท)</label><input type="text" id="test_strips" inputmode="decimal" placeholder="เช่น 900" value="900" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="doctor_visits" class="block text-sm font-medium text-gray-700 mb-1">ค่าพบแพทย์/เดือน (บาท)</label><input type="text" id="doctor_visits" inputmode="decimal" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อเดือน</p>
            <p id="monthly_dm" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อปี</p>
            <p id="yearly_dm" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const oralMeds = parseFloat((document.getElementById('oral_meds') as HTMLInputElement).value) || 0;
      const insulin = parseFloat((document.getElementById('insulin') as HTMLInputElement).value) || 0;
      const testStrips = parseFloat((document.getElementById('test_strips') as HTMLInputElement).value) || 0;
      const doctorVisits = parseFloat((document.getElementById('doctor_visits') as HTMLInputElement).value) || 0;

      const monthlyDm = oralMeds + insulin + testStrips + doctorVisits;
      const yearlyDm = monthlyDm * 12;

      (document.getElementById('monthly_dm') as HTMLElement).textContent = monthlyDm.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('yearly_dm') as HTMLElement).textContent = yearlyDm.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('diabetes-medication-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
