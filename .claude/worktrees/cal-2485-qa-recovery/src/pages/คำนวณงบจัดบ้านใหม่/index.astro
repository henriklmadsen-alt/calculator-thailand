---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณงบจัดบ้านใหม่ 2569 | เฟอร์นิเจอร์ เครื่องใช้ไฟฟ้า ของตกแต่ง | Kamnuanlek';
const pageDescription = 'ประมาณค่าใช้จ่ายจัดบ้านใหม่ เฟอร์นิเจอร์หลัก เครื่องใช้ไฟฟ้า ของตกแต่ง ตามขนาดบ้านและระดับคุณภาพ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบจัดบ้านใหม่/`;

const faqData = [
  {
    question: 'งบจัดบ้านใหม่สำหรับคอนโด 30 ตร.ม. เท่าไร?',
    answer: 'สำหรับคอนโดขนาด 30 ตร.ม. ในระดับมาตรฐาน งบจัดบ้านอยู่ที่ประมาณ 80,000-150,000 บาท รวมเฟอร์นิเจอร์หลัก เครื่องใช้ไฟฟ้าจำเป็น และของตกแต่งพื้นฐาน',
  },
  {
    question: 'เครื่องใช้ไฟฟ้าอะไรบ้างที่จำเป็นสำหรับบ้านใหม่?',
    answer: 'เครื่องใช้ไฟฟ้าจำเป็น ได้แก่ ตู้เย็น เครื่องซักผ้า เครื่องปรับอากาศ เครื่องทำน้ำอุ่น และโทรทัศน์ รวมกันมีราคาตั้งแต่ 30,000-80,000 บาทขึ้นไป ขึ้นอยู่กับยี่ห้อและขนาด',
  },
  {
    question: 'ควรซื้อเฟอร์นิเจอร์ใหม่หรือมือสอง?',
    answer: 'สำหรับบ้านใหม่ แนะนำซื้อเฟอร์นิเจอร์มือสองสภาพดีหรือแบรนด์ affordable เช่น IKEA หรือแบรนด์ไทย เพื่อประหยัดงบ สามารถประหยัดได้ 30-60% เมื่อเทียบกับการซื้อใหม่ทั้งหมด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบจัดบ้านใหม่',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบจัดบ้านใหม่">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณงบจัดบ้านใหม่ 2569</h1>
    <p class="mb-6 text-gray-600">ประมาณค่าใช้จ่ายจัดบ้านใหม่ เฟอร์นิเจอร์หลัก เครื่องใช้ไฟฟ้า และของตกแต่ง</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="home-form" class="space-y-4">
        <div>
          <label for="area" class="mb-1 block text-sm font-medium text-gray-700">ขนาดบ้าน (ตร.ม.)</label>
          <input id="area" type="text" inputmode="numeric" placeholder="เช่น 35"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="homeType" class="mb-1 block text-sm font-medium text-gray-700">ประเภทที่อยู่อาศัย</label>
          <select id="homeType" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-auto">
            <option value="condo">คอนโดมิเนียม</option>
            <option value="house">บ้านเดี่ยว</option>
            <option value="townhouse">ทาวน์เฮาส์/ทาวน์โฮม</option>
          </select>
        </div>
        <fieldset>
          <legend class="mb-2 text-sm font-medium text-gray-700">ระดับคุณภาพ</legend>
          <div class="flex flex-wrap gap-2">
            <label class="quality-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors">
              <input type="radio" name="quality" value="budget" class="sr-only" /> ประหยัด
            </label>
            <label class="quality-pill cursor-pointer rounded-full border-2 border-primary-500 bg-primary-50 px-4 py-2 text-sm font-medium text-primary-700 transition-colors">
              <input type="radio" name="quality" value="standard" class="sr-only" checked /> มาตรฐาน
            </label>
            <label class="quality-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors">
              <input type="radio" name="quality" value="premium" class="sr-only" /> พรีเมียม
            </label>
          </div>
        </fieldset>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">งบจัดบ้านโดยประมาณ</h2>
        <div class="mb-6 rounded-lg bg-primary-50 p-4 text-center">
          <div class="mb-1 text-sm text-gray-600">งบรวมทั้งหมด</div>
          <div id="res-total" class="text-4xl font-bold text-primary-700 sm:text-5xl">-</div>
          <div class="mt-1 text-sm text-gray-500">บาท</div>
        </div>
        <div class="space-y-0">
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🛋️ เฟอร์นิเจอร์หลัก</span>
            <span id="res-furniture" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🏠 เครื่องใช้ไฟฟ้า</span>
            <span id="res-appliance" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🖼️ ของตกแต่งและอุปกรณ์</span>
            <span id="res-deco" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-700">🔧 ค่าติดตั้งและอื่นๆ</span>
            <span id="res-install" class="text-sm font-medium text-gray-900">-</span>
          </div>
        </div>
      </div>
    </div>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedCalculators currentHref="/คำนวณงบจัดบ้านใหม่/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n > 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  // base cost per sqm [furniture, appliance, deco, install] for standard
  const QUALITY_MULT: Record<string, number> = { budget: 0.6, standard: 1.0, premium: 2.0 };
  // base per sqm costs for standard condo
  const BASE_PER_SQM = { furniture: 1500, appliance: 1200, deco: 500, install: 300 };
  // house/townhouse multiplier (more rooms = more stuff)
  const TYPE_MULT: Record<string, number> = { condo: 1.0, house: 1.5, townhouse: 1.3 };

  document.querySelectorAll<HTMLLabelElement>('.quality-pill').forEach((pill) => {
    pill.querySelector('input')?.addEventListener('change', () => {
      document.querySelectorAll<HTMLLabelElement>('.quality-pill').forEach((p) => {
        p.classList.remove('border-primary-500', 'bg-primary-50', 'text-primary-700');
        p.classList.add('border-gray-200', 'text-gray-700');
      });
      pill.classList.remove('border-gray-200', 'text-gray-700');
      pill.classList.add('border-primary-500', 'bg-primary-50', 'text-primary-700');
    });
  });

  document.getElementById('home-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const area = parseNum((document.getElementById('area') as HTMLInputElement).value) || 30;
    const homeType = (document.getElementById('homeType') as HTMLSelectElement).value;
    const quality = (document.querySelector('input[name="quality"]:checked') as HTMLInputElement)?.value ?? 'standard';

    const qm = QUALITY_MULT[quality];
    const tm = TYPE_MULT[homeType];

    const furniture = BASE_PER_SQM.furniture * area * qm * tm;
    const appliance = BASE_PER_SQM.appliance * area * qm * tm;
    const deco = BASE_PER_SQM.deco * area * qm * tm;
    const install = BASE_PER_SQM.install * area * qm * tm;
    const total = furniture + appliance + deco + install;

    document.getElementById('res-total')!.textContent = fmt(total);
    document.getElementById('res-furniture')!.textContent = fmt(furniture);
    document.getElementById('res-appliance')!.textContent = fmt(appliance);
    document.getElementById('res-deco')!.textContent = fmt(deco);
    document.getElementById('res-install')!.textContent = fmt(install);
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
