import test from 'node:test';
import assert from 'node:assert/strict';
import { spawn } from 'node:child_process';
import { resolve } from 'node:path';
import { request as httpRequest } from 'node:http';

function sleep(ms) {
  return new Promise((resolveSleep) => setTimeout(resolveSleep, ms));
}

function requestWithHost(url, hostHeader) {
  return new Promise((resolveRequest, rejectRequest) => {
    const req = httpRequest(
      url,
      {
        method: 'GET',
        headers: {
          host: hostHeader,
        },
      },
      (res) => {
        res.resume();
        res.on('end', () => {
          resolveRequest({
            status: res.statusCode || 0,
            headers: res.headers,
          });
        });
      }
    );
    req.on('error', rejectRequest);
    req.end();
  });
}

let serverProcess;
let baseUrl;

test.before(async () => {
  const port = 4300 + Math.floor(Math.random() * 500);
  baseUrl = `http://127.0.0.1:${port}`;
  const serverPath = resolve(process.cwd(), 'server.mjs');

  serverProcess = spawn(process.execPath, [serverPath], {
    env: {
      ...process.env,
      PORT: String(port),
      PUBLIC_SITE_URL: 'https://www.kamnuanlek.com',
    },
    stdio: 'ignore',
  });

  let lastError;
  for (let attempt = 0; attempt < 50; attempt += 1) {
    try {
      const response = await fetch(`${baseUrl}/__release`, { redirect: 'manual' });
      if (response.status === 200) return;
    } catch (error) {
      lastError = error;
    }
    await sleep(100);
  }

  if (serverProcess) {
    serverProcess.kill();
  }
  throw new Error(`Server did not start in time: ${String(lastError || 'unknown error')}`);
});

test.after(() => {
  if (!serverProcess) return;
  if (!serverProcess.killed) {
    serverProcess.kill();
  }
});

test('returns 410 + noindex for blocked internal paths', async () => {
  const response = await fetch(`${baseUrl}/plans/`, { redirect: 'manual' });
  assert.equal(response.status, 410);
  assert.equal(response.headers.get('x-robots-tag'), 'noindex, nofollow, noarchive');
});

test('returns 410 for paths containing internal-note marker', async () => {
  const response = await fetch(`${baseUrl}/foo-internal-note-bar`, { redirect: 'manual' });
  assert.equal(response.status, 410);
  assert.equal(response.headers.get('x-robots-tag'), 'noindex, nofollow, noarchive');
});

test('keeps __release as noindex endpoint', async () => {
  const response = await fetch(`${baseUrl}/__release`, { redirect: 'manual' });
  assert.equal(response.status, 200);
  assert.equal(response.headers.get('x-robots-tag'), 'noindex, nofollow, noarchive');
});

test('returns 404 + noindex for unknown routes', async () => {
  const response = await fetch(`${baseUrl}/definitely-not-a-real-route`, { redirect: 'manual' });
  assert.equal(response.status, 404);
  assert.equal(response.headers.get('x-robots-tag'), 'noindex, nofollow, noarchive');
});

test('redirects legacy railway host to primary domain', async () => {
  const response = await requestWithHost(
    `${baseUrl}/คำนวณค่าไฟฟ้า/?ref=legacy`,
    'calculator-thailand-production.up.railway.app'
  );
  assert.equal(response.status, 301);
  assert.equal(
    response.headers.location,
    'https://www.kamnuanlek.com/%E0%B8%84%E0%B8%B3%E0%B8%99%E0%B8%A7%E0%B8%93%E0%B8%84%E0%B9%88%E0%B8%B2%E0%B9%84%E0%B8%9F%E0%B8%9F%E0%B9%89%E0%B8%B2/?ref=legacy'
  );
});
