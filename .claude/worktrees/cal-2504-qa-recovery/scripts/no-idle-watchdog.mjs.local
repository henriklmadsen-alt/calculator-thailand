#!/usr/bin/env node

import { appendFile, mkdir, writeFile } from 'node:fs/promises';
import path from 'node:path';
import { pathToFileURL } from 'node:url';

export const DEFAULT_LANES = ['CTO', 'CMO', 'UXDesigner', 'SEO Specialist'];
export const DEFAULT_STATUSES = ['todo', 'in_progress', 'in_review'];
export const DEFAULT_CHECKPOINT_SLA_MINUTES = 30;
export const DEFAULT_HARD_ESCALATION_SLA_MINUTES = 60;
export const DEFAULT_ALERT_COOLDOWN_MINUTES = 30;
export const WATCHDOG_TAG = '[watchdog:no-idle]';

export function parseArgs(argv) {
  const parsed = {};
  for (let i = 0; i < argv.length; i += 1) {
    const key = argv[i];
    if (!key.startsWith('--')) {
      continue;
    }

    const next = argv[i + 1];
    if (!next || next.startsWith('--')) {
      parsed[key.slice(2)] = true;
      continue;
    }

    parsed[key.slice(2)] = next;
    i += 1;
  }
  return parsed;
}

export function requiredEnv(env, name) {
  const value = env[name];
  if (!value || String(value).trim() === '') {
    throw new Error(`Missing required env var: ${name}`);
  }
  return value;
}

export function asInt(value, fallback) {
  if (value === undefined || value === null || value === '') {
    return fallback;
  }
  const parsed = Number.parseInt(String(value), 10);
  if (Number.isNaN(parsed)) {
    return fallback;
  }
  return parsed;
}

export function asCsvList(value, fallback) {
  if (!value || String(value).trim() === '') {
    return fallback;
  }
  return String(value)
    .split(',')
    .map((item) => item.trim())
    .filter(Boolean);
}

export function asBoolean(value) {
  if (typeof value === 'boolean') {
    return value;
  }
  if (typeof value === 'string') {
    const normalized = value.trim().toLowerCase();
    if (normalized === 'true' || normalized === '1' || normalized === 'yes') {
      return true;
    }
    if (normalized === 'false' || normalized === '0' || normalized === 'no') {
      return false;
    }
  }
  return Boolean(value);
}

export function normalizeCollection(payload) {
  if (Array.isArray(payload)) {
    return payload;
  }
  if (Array.isArray(payload?.value)) {
    return payload.value;
  }
  return [];
}

export function minutesBetween(newer, older) {
  return Math.max(0, Math.floor((newer.getTime() - older.getTime()) / 60000));
}

export function issuePrefixFromIdentifier(identifier) {
  if (!identifier || !identifier.includes('-')) {
    return 'CAL';
  }
  return identifier.split('-', 1)[0];
}

export function mentionForLane(laneName) {
  if (laneName === 'SEO Specialist') {
    return '@SEOSpecialist';
  }
  return `@${laneName.replace(/\s+/g, '')}`;
}

export function markdownSummary(report, prefix) {
  const lines = [];
  lines.push('# No-Idle Watchdog');
  lines.push('');
  lines.push(`- Run at: \`${report.runAt}\``);
  lines.push(`- Run id: \`${report.runId || 'n/a'}\``);
  lines.push(`- Checkpoint SLA: \`${report.checkpointSlaMinutes}\` minutes`);
  lines.push(`- Hard escalation SLA: \`${report.hardEscalationSlaMinutes}\` minutes`);
  lines.push(`- Lane count: \`${report.lanes.length}\``);
  lines.push('');
  lines.push('| Lane | State | Inactivity (min) | Freshest Issue | Action |');
  lines.push('| --- | --- | ---: | --- | --- |');

  for (const lane of report.lanes) {
    const issueCell = lane.freshestIssueIdentifier
      ? `[${lane.freshestIssueIdentifier}](/${prefix}/issues/${lane.freshestIssueIdentifier})`
      : 'none';
    lines.push(
      `| ${lane.laneName} | ${lane.state} | ${lane.inactivityMinutes ?? 'n/a'} | ${issueCell} | ${lane.action} |`,
    );
  }

  lines.push('');
  lines.push(`- Alerts posted: \`${report.alertsPosted}\``);
  lines.push(`- Alerts skipped by cooldown: \`${report.alertsSkippedCooldown}\``);
  lines.push(`- Errors: \`${report.errors.length}\``);

  if (report.errors.length > 0) {
    lines.push('');
    lines.push('## Errors');
    for (const error of report.errors) {
      lines.push(`- ${error}`);
    }
  }

  return `${lines.join('\n')}\n`;
}

export function buildIssueAlertComment({
  laneName,
  issueIdentifier,
  prefix,
  laneMention,
  inactivityMinutes,
  checkpointSlaMinutes,
  hardEscalationSlaMinutes,
  lastActivityAt,
  runAt,
  hardEscalation,
}) {
  const lines = [];
  lines.push(`## No-Idle Watchdog Alert ${WATCHDOG_TAG}`);
  lines.push(`<!-- lane-key:${laneName.replace(/\s+/g, '-').toLowerCase()} -->`);
  lines.push('');
  lines.push('Critical lane checkpoint SLA breach detected.');
  lines.push('');
  lines.push(`- Lane owner: ${laneMention}`);
  lines.push(`- Issue: [${issueIdentifier}](/${prefix}/issues/${issueIdentifier})`);
  lines.push(`- Last activity: \`${lastActivityAt}\``);
  lines.push(`- Inactivity: \`${inactivityMinutes}\` minutes`);
  lines.push(`- Checkpoint SLA: \`${checkpointSlaMinutes}\` minutes`);
  lines.push(`- Hard escalation SLA: \`${hardEscalationSlaMinutes}\` minutes`);
  lines.push(`- Observed at: \`${runAt}\``);
  lines.push('');

  if (hardEscalation) {
    lines.push(`Hard SLA breached. ${laneMention} @CEO post a checkpoint update immediately.`);
  } else {
    lines.push(`${laneMention} post a checkpoint update now with current status and next ETA.`);
  }

  lines.push('');
  return `${lines.join('\n')}\n`;
}

export function buildNoIssueAlertComment({
  laneName,
  laneMention,
  runAt,
  checkpointSlaMinutes,
  hardEscalationSlaMinutes,
}) {
  return [
    `## No-Idle Watchdog Alert ${WATCHDOG_TAG}`,
    `<!-- lane-key:${laneName.replace(/\s+/g, '-').toLowerCase()} -->`,
    '',
    'Critical lane has no active issue assigned, so checkpoint SLA cannot be enforced.',
    '',
    `- Lane owner: ${laneMention}`,
    `- Checkpoint SLA: \`${checkpointSlaMinutes}\` minutes`,
    `- Hard escalation SLA: \`${hardEscalationSlaMinutes}\` minutes`,
    `- Observed at: \`${runAt}\``,
    '',
    `${laneMention} @CEO assign an active critical issue to this lane immediately.`,
    '',
  ].join('\n');
}

export function createRuntimeConfig({ argv, env, now }) {
  const args = parseArgs(argv);
  const runAt = now.toISOString();

  return {
    args,
    dryRun: asBoolean(args['dry-run']),
    runAt,
    checkpointSlaMinutes: asInt(
      args['checkpoint-sla-minutes'] ?? env.NO_IDLE_CHECKPOINT_SLA_MINUTES,
      DEFAULT_CHECKPOINT_SLA_MINUTES,
    ),
    hardEscalationSlaMinutes: asInt(
      args['hard-sla-minutes'] ?? env.NO_IDLE_HARD_ESCALATION_SLA_MINUTES,
      DEFAULT_HARD_ESCALATION_SLA_MINUTES,
    ),
    cooldownMinutes: asInt(
      args['cooldown-minutes'] ?? env.NO_IDLE_ALERT_COOLDOWN_MINUTES,
      DEFAULT_ALERT_COOLDOWN_MINUTES,
    ),
    laneNames: asCsvList(args['lane-names'] ?? env.NO_IDLE_LANE_NAMES, DEFAULT_LANES),
    issueStatuses: asCsvList(args['issue-statuses'] ?? env.NO_IDLE_ACTIVE_STATUSES, DEFAULT_STATUSES),
    monitoredPriority: (args.priority || env.NO_IDLE_MONITORED_PRIORITY || 'critical').trim(),
    outputDir: args['output-dir'] || env.NO_IDLE_OUTPUT_DIR || 'reports/no-idle-watchdog',
    noIssueAlertTargetId:
      args['alert-issue-id'] || env.NO_IDLE_ALERT_ISSUE_ID || env.PAPERCLIP_TASK_ID || '',
  };
}

export async function runWatchdog({ env = process.env, argv = process.argv.slice(2), fetchImpl = fetch, now = new Date() } = {}) {
  const apiUrl = requiredEnv(env, 'PAPERCLIP_API_URL').replace(/\/+$/, '');
  const apiKey = requiredEnv(env, 'PAPERCLIP_API_KEY');
  const companyId = requiredEnv(env, 'PAPERCLIP_COMPANY_ID');
  const runId = env.PAPERCLIP_RUN_ID || '';

  const runtime = createRuntimeConfig({ argv, env, now });
  const {
    dryRun,
    runAt,
    checkpointSlaMinutes,
    hardEscalationSlaMinutes,
    cooldownMinutes,
    laneNames,
    issueStatuses,
    monitoredPriority,
    outputDir,
    noIssueAlertTargetId,
  } = runtime;

  async function apiRequest(method, endpoint, body, includeRunId = false) {
    const headers = {
      Authorization: `Bearer ${apiKey}`,
      'Content-Type': 'application/json',
    };

    if (includeRunId && runId) {
      headers['X-Paperclip-Run-Id'] = runId;
    }

    const response = await fetchImpl(`${apiUrl}${endpoint}`, {
      method,
      headers,
      body: body ? JSON.stringify(body) : undefined,
    });

    if (!response.ok) {
      const text = await response.text();
      throw new Error(`${method} ${endpoint} failed (${response.status}): ${text}`);
    }

    if (response.status === 204) {
      return null;
    }

    return response.json();
  }

  async function hasRecentWatchdogComment(issueId, laneName) {
    const commentsPayload = await apiRequest('GET', `/api/issues/${issueId}/comments?order=asc`);
    const comments = normalizeCollection(commentsPayload);
    const laneKey = `lane-key:${laneName.replace(/\s+/g, '-').toLowerCase()}`;
    const cutoff = new Date(now.getTime() - cooldownMinutes * 60000);

    for (let index = comments.length - 1; index >= 0; index -= 1) {
      const comment = comments[index];
      const body = String(comment.body || '');

      if (!body.includes(WATCHDOG_TAG) || !body.includes(laneKey)) {
        continue;
      }

      const createdAt = new Date(comment.createdAt);
      if (createdAt >= cutoff) {
        return true;
      }
      return false;
    }

    return false;
  }

  const [agentsPayload, issuesPayload] = await Promise.all([
    apiRequest('GET', `/api/companies/${companyId}/agents`),
    apiRequest(
      'GET',
      `/api/companies/${companyId}/issues?status=${encodeURIComponent(
        issueStatuses.join(','),
      )}&priority=${encodeURIComponent(monitoredPriority)}`,
    ),
  ]);

  const agents = normalizeCollection(agentsPayload);
  const issues = normalizeCollection(issuesPayload).filter(
    (issue) => issue.priority === monitoredPriority && issueStatuses.includes(issue.status),
  );
  const prefix = issuePrefixFromIdentifier(issues[0]?.identifier || 'CAL-0');

  const report = {
    runAt,
    runId,
    companyId,
    dryRun,
    checkpointSlaMinutes,
    hardEscalationSlaMinutes,
    cooldownMinutes,
    monitoredPriority,
    issueStatuses,
    laneNames,
    alertsPosted: 0,
    alertsSkippedCooldown: 0,
    lanes: [],
    errors: [],
  };

  for (const laneName of laneNames) {
    const laneMention = mentionForLane(laneName);
    const laneAgent = agents.find((agent) => agent.name === laneName);

    if (!laneAgent) {
      report.errors.push(`Lane agent not found: ${laneName}`);
      report.lanes.push({
        laneName,
        agentId: null,
        state: 'agent_missing',
        inactivityMinutes: null,
        freshestIssueIdentifier: null,
        action: 'error',
      });
      continue;
    }

    const laneIssues = issues.filter((issue) => issue.assigneeAgentId === laneAgent.id);
    if (laneIssues.length === 0) {
      let action = 'none';
      if (!dryRun && noIssueAlertTargetId) {
        const recentAlert = await hasRecentWatchdogComment(noIssueAlertTargetId, laneName);
        if (recentAlert) {
          action = 'cooldown_skip';
          report.alertsSkippedCooldown += 1;
        } else {
          const comment = buildNoIssueAlertComment({
            laneName,
            laneMention,
            runAt,
            checkpointSlaMinutes,
            hardEscalationSlaMinutes,
          });

          await apiRequest(
            'POST',
            `/api/issues/${noIssueAlertTargetId}/comments`,
            { body: comment },
            true,
          );
          action = 'alert_posted';
          report.alertsPosted += 1;
        }
      }

      report.lanes.push({
        laneName,
        agentId: laneAgent.id,
        issueCount: 0,
        state: 'no_active_issue',
        inactivityMinutes: null,
        freshestIssueIdentifier: null,
        action,
      });
      continue;
    }

    laneIssues.sort((left, right) => {
      const leftTime = new Date(left.lastActivityAt || left.updatedAt).getTime();
      const rightTime = new Date(right.lastActivityAt || right.updatedAt).getTime();
      return rightTime - leftTime;
    });

    const freshestIssue = laneIssues[0];
    const freshestTimestamp = new Date(freshestIssue.lastActivityAt || freshestIssue.updatedAt);
    const inactivityMinutes = minutesBetween(now, freshestTimestamp);
    const hardEscalation = inactivityMinutes >= hardEscalationSlaMinutes;
    const stale = inactivityMinutes >= checkpointSlaMinutes;

    let action = 'healthy';
    if (stale) {
      action = 'stale_detected';

      if (!dryRun) {
        const recentAlert = await hasRecentWatchdogComment(freshestIssue.id, laneName);
        if (recentAlert) {
          action = 'cooldown_skip';
          report.alertsSkippedCooldown += 1;
        } else {
          const comment = buildIssueAlertComment({
            laneName,
            issueIdentifier: freshestIssue.identifier,
            prefix,
            laneMention,
            inactivityMinutes,
            checkpointSlaMinutes,
            hardEscalationSlaMinutes,
            lastActivityAt: freshestIssue.lastActivityAt || freshestIssue.updatedAt,
            runAt,
            hardEscalation,
          });

          await apiRequest(
            'POST',
            `/api/issues/${freshestIssue.id}/comments`,
            { body: comment },
            true,
          );
          action = hardEscalation ? 'hard_alert_posted' : 'alert_posted';
          report.alertsPosted += 1;
        }
      }
    }

    report.lanes.push({
      laneName,
      agentId: laneAgent.id,
      issueCount: laneIssues.length,
      state: hardEscalation ? 'hard_breach' : stale ? 'breach' : 'healthy',
      inactivityMinutes,
      freshestIssueIdentifier: freshestIssue.identifier,
      freshestIssueId: freshestIssue.id,
      freshestIssueLastActivityAt: freshestIssue.lastActivityAt || freshestIssue.updatedAt,
      action,
    });
  }

  const outputPath = path.resolve(outputDir);
  await mkdir(outputPath, { recursive: true });

  const stamp = runAt.replace(/[:.]/g, '-');
  const jsonPath = path.join(outputPath, `${stamp}.json`);
  const markdownPath = path.join(outputPath, `${stamp}.md`);
  const latestJsonPath = path.join(outputPath, 'latest.json');
  const latestMarkdownPath = path.join(outputPath, 'latest.md');
  const eventsPath = path.join(outputPath, 'events.jsonl');
  const markdown = markdownSummary(report, prefix);

  await Promise.all([
    writeFile(jsonPath, `${JSON.stringify(report, null, 2)}\n`, 'utf8'),
    writeFile(markdownPath, markdown, 'utf8'),
    writeFile(latestJsonPath, `${JSON.stringify(report, null, 2)}\n`, 'utf8'),
    writeFile(latestMarkdownPath, markdown, 'utf8'),
    appendFile(eventsPath, `${JSON.stringify(report)}\n`, 'utf8'),
  ]);

  return { report, markdown };
}

async function main() {
  const { markdown } = await runWatchdog();
  console.log(markdown.trim());
}

if (process.argv[1] && import.meta.url === pathToFileURL(process.argv[1]).href) {
  main().catch((error) => {
    console.error(error instanceof Error ? error.message : String(error));
    process.exitCode = 1;
  });
}
