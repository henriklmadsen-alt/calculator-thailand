---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่า Spa ดูแลผม | Hair Spa Treatment Cost | Kamnuanlek';
const pageDescription = 'คำนวณค่าแมสผม ทรีทเมนต์ อบไอน้ำ ที่ spa ต่อเดือนและต่อปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-hair-spa-cost/`;

const faqData = [
  { question: 'ราคาเฉลี่ยของบริการนี้คือเท่าไร?', answer: 'ราคาขึ้นอยู่กับร้าน ทำเล และระดับบริการ ใช้เครื่องคำนวณด้านบนเพื่อประมาณค่าใช้จ่ายตามตัวเลือกที่ต้องการ' },
  { question: 'ควรทำบริการนี้บ่อยแค่ไหน?', answer: 'ขึ้นอยู่กับประเภทบริการและสภาพของแต่ละคน โดยทั่วไปทุก 2-6 สัปดาห์ตามคำแนะนำของช่าง' },
  { question: 'มีวิธีประหยัดค่าใช้จ่ายอย่างไร?', answer: 'เลือกแพ็กเกจ สมัครสมาชิก หรือจองล่วงหน้าในช่วงโปรโมชั่น บางร้านมีส่วนลดสำหรับลูกค้าประจำ' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกรายละเอียดบริการที่ต้องการ เช่น ประเภท จำนวนครั้ง และตัวเลือกเสริม เครื่องจะคำนวณค่าใช้จ่ายรวมให้ทันที' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่า Spa ดูแลผม">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่า Spa ดูแลผมต่อเดือน</h1>
    <div class="mb-4 inline-block rounded-lg border border-fuchsia-200 bg-fuchsia-50 px-3 py-2">
      <p class="text-xs font-semibold text-fuchsia-800">[KLC-0779]</p>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ค่าแมสผม/ครั้ง (บาท)</label>
          <input type="text" id="mask-cost" inputmode="decimal" placeholder="200" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้ง/เดือน</label>
          <input type="text" id="mask-freq" inputmode="decimal" placeholder="2" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ค่าทรีทเมนต์/ครั้ง (บาท)</label>
          <input type="text" id="treatment-cost" inputmode="decimal" placeholder="300" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้ง/เดือน</label>
          <input type="text" id="treatment-freq" inputmode="decimal" placeholder="1" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
      </div>

      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 text-base">คำนวณ</button>

      <div id="result" class="hidden mt-6 grid gap-4 sm:grid-cols-2 text-center">
        <div>
          <div class="text-sm text-gray-600 mb-1">รายเดือน</div>
          <div id="monthly" class="text-3xl font-bold text-primary-600">-</div>
        </div>
        <div>
          <div class="text-sm text-gray-600 mb-1">ต่อปี</div>
          <div id="yearly" class="text-3xl font-bold text-primary-600">-</div>
        </div>
      </div>
    </div>

    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">[โฆษณา]</div>

    <section class="prose prose-gray max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ประเภทบริการ Spa ดูแลผม</h2>
      <ul class="list-disc pl-6 text-gray-700">
        <li><strong>แมสผม:</strong> 150-400 บาท อบความชื้น ลดแหง</li>
        <li><strong>ทรีทเมนต์:</strong> 200-600 บาท บำรุงลึก ซ่อมแซม</li>
        <li><strong>ริดและสตรม:</strong> 300-800 บาท ยืดหยุ่นผม</li>
        <li><strong>เสกา/Keratin:</strong> 800-2,000 บาท ทำให้ผมเรียบ</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีประหยัด</h3>
      <ul class="list-disc pl-6 text-gray-700">
        <li>ใช้ผลิตภัณฑ์บ้าน ประหยัด 50-70%</li>
        <li>แมส ทรีทเมนต์สลับกัน ไม่ต้องทำเดือนละครั้ง</li>
        <li>หาแพ็กเกจ package ส่วนลด</li>
        <li>ตรวจสอบคุณภาพ แม่กำหนดราคา</li>
      </ul>
    </section>
  </article>

  <script>
    function formatCurrency(value: number): string {
      return new Intl.NumberFormat('th-TH', {
        style: 'currency',
        currency: 'THB',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(value);
    }

    document.getElementById('btn-calculate')?.addEventListener('click', () => {
      const maskCost = parseFloat((document.getElementById('mask-cost') as HTMLInputElement)?.value) || 0;
      const maskFreq = parseFloat((document.getElementById('mask-freq') as HTMLInputElement)?.value) || 0;
      const treatmentCost = parseFloat((document.getElementById('treatment-cost') as HTMLInputElement)?.value) || 0;
      const treatmentFreq = parseFloat((document.getElementById('treatment-freq') as HTMLInputElement)?.value) || 0;

      const monthly = (maskCost * maskFreq) + (treatmentCost * treatmentFreq);
      const yearly = monthly * 12;

      document.getElementById('monthly')!.textContent = formatCurrency(monthly);
      document.getElementById('yearly')!.textContent = formatCurrency(yearly);
      document.getElementById('result')!.classList.remove('hidden');
    });
  </script>
</BaseLayout>
