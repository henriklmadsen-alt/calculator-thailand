---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณต้นทุนการรักษาพยาบาล โรงพยาบาล 2569 | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าการรักษาพยาบาลที่โรงพยาบาล ออนไลน์ฟรี รวมค่าห้อง ผ่าตัด เอกซเรย์ เลือดตรวจ ยา ประมาณการทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนโรงพยาบาล/`;

const faqData = [
  {
    question: 'ต้นทุนการรักษาพยาบาลประกอบด้วยอะไรบ้าง?',
    answer: 'ประกอบด้วย ค่าห้องพยาบาล ค่าผ่าตัด/การตรวจ ค่าเอกซเรย์และอัลตราซาวด์ ค่าตรวจเลือด ค่ายา และค่าจ้างแพทย์ คิดรวมกันแล้วทำให้เกิดต้นทุนรวมของการรักษา',
    answer_en: 'Includes ward fees, procedure fees, imaging (X-ray, ultrasound), lab tests, medications, and doctor fees.',
  },
  {
    question: 'โรงพยาบาลรัฐ vs โรงพยาบาลเอกชน ต่างกันเท่าไหร่?',
    answer: 'โรงพยาบาลรัฐมักมีค่าใช้จ่ายต่ำกว่า 40-60% เมื่อเทียบกับโรงพยาบาลเอกชนสำหรับการรักษาแบบเดียวกัน อย่างไรก็ตาม โรงพยาบาลเอกชนอาจมีความสะดวกสบายและบริการพิเศษเพิ่มเติม',
    answer_en: 'Government hospitals cost 40-60% less than private hospitals for the same procedure, but may have longer wait times.',
  },
  {
    question: 'ประกันสุขภาพครอบคลุมค่าการรักษาที่โรงพยาบาลทั้งหมดหรือไม่?',
    answer: 'ขึ้นอยู่กับประเภทประกันสุขภาพและเงื่อนไขของเรา ประกันโรงพยาบาลมักครอบคลุม 70-85% ของค่าใช้จ่ายทั่วไป บางประเภทค่าใช้จ่ายอาจไม่ครอบคลุมเช่น ค่าห้องส่วนตัวส่วนเกิน',
    answer_en: 'Most health insurance covers 70-85% of hospital costs, but coverage depends on your policy type and limits.',
  },
  {
    question: 'เวลารักษาตัวนานเท่าไหร่ ต้นทุนจึงเริ่มสูงขึ้นอย่างมาก?',
    answer: 'ค่าห้องพยาบาลเป็นค่าใช้จ่ายหลักในการรักษาระยะยาว เวลานอนรักษาแต่ละวัน ค่าห้องจะเพิ่มขึ้นเรื่อยๆ ถ้านอนนานมากอาจมีค่าจ้างแพทย์หรือจ้างสังเกตการณ์เพิ่มเติม',
    answer_en: 'Ward fees accumulate daily; after 10+ days, total costs increase significantly. Medications and complications also add up.',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนการรักษาพยาบาล',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนโรงพยาบาล">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณต้นทุนการรักษาพยาบาล
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2">
      <p class="text-xs font-semibold text-blue-800">[อัปเดตตามอัตราโรงพยาบาล 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าการรักษาพยาบาลออนไลน์ฟรี ประมาณการต้นทุนรวม ค่าประกันสุขภาพ และค่าใช้จ่ายส่วนตัว
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <!-- Hospital Type -->
        <div>
          <label for="hospital-type" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทโรงพยาบาล
          </label>
          <select id="hospital-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base">
            <option value="government">โรงพยาบาลรัฐ</option>
            <option value="private">โรงพยาบาลเอกชน</option>
          </select>
        </div>

        <!-- Ward Type -->
        <div>
          <label for="ward-type" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทห้อง
          </label>
          <select id="ward-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base">
            <option value="general">ห้องทั่วไป</option>
            <option value="semiPrivate">ห้องครึ่งตัว</option>
            <option value="private">ห้องส่วนตัว</option>
          </select>
        </div>

        <!-- Days Admitted -->
        <div>
          <label for="days" class="block text-sm font-medium text-gray-700 mb-1">
            วันที่นอนรักษา
          </label>
          <input type="number" id="days" min="1" max="365" value="3" placeholder="เช่น 3" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>

        <!-- Procedure Type -->
        <div>
          <label for="procedure" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทการรักษา
          </label>
          <select id="procedure" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base">
            <option value="consultation">การตรวจเท่านั้น</option>
            <option value="minor">ผ่าตัดเล็ก</option>
            <option value="moderate">ผ่าตัดปานกลาง</option>
            <option value="major">ผ่าตัดใหญ่</option>
            <option value="veryMajor">ผ่าตัดใหญ่มาก</option>
          </select>
        </div>

        <!-- Imaging -->
        <div class="flex items-end">
          <label class="flex items-center">
            <input type="checkbox" id="imaging" class="w-4 h-4 border border-gray-300 rounded focus:ring-2 focus:ring-primary-500" />
            <span class="ml-2 text-sm font-medium text-gray-700">รวมค่าเอกซเรย์/อัลตราซาวด์</span>
          </label>
        </div>

        <!-- Labs -->
        <div class="flex items-end">
          <label class="flex items-center">
            <input type="checkbox" id="labs" class="w-4 h-4 border border-gray-300 rounded focus:ring-2 focus:ring-primary-500" />
            <span class="ml-2 text-sm font-medium text-gray-700">รวมค่าตรวจเลือด/แล็บ</span>
          </label>
        </div>

        <!-- Complications -->
        <div class="flex items-end">
          <label class="flex items-center">
            <input type="checkbox" id="complications" class="w-4 h-4 border border-gray-300 rounded focus:ring-2 focus:ring-primary-500" />
            <span class="ml-2 text-sm font-medium text-gray-700">มีภาวะแทรกซ้อน</span>
          </label>
        </div>
      </div>

      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
        คำนวณต้นทุน
      </button>

      <!-- Results -->
      <div id="result" class="hidden mt-8">
        <!-- Cost Breakdown -->
        <div class="bg-gray-50 rounded-lg p-4 mb-6">
          <h3 class="font-semibold text-gray-900 mb-4">รายละเอียดค่าใช้จ่าย</h3>
          <div class="space-y-3">
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">ค่าห้องพยาบาล</span>
              <span id="ward-fee" class="font-semibold text-gray-900">-</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">ค่าผ่าตัด/การรักษา</span>
              <span id="procedure-fee" class="font-semibold text-gray-900">-</span>
            </div>
            <div id="imaging-row" class="hidden flex justify-between text-sm">
              <span class="text-gray-600">ค่าเอกซเรย์/อัลตราซาวด์</span>
              <span id="imaging-fee" class="font-semibold text-gray-900">-</span>
            </div>
            <div id="lab-row" class="hidden flex justify-between text-sm">
              <span class="text-gray-600">ค่าตรวจเลือด/แล็บ</span>
              <span id="lab-fee" class="font-semibold text-gray-900">-</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">ค่ายา/ส่วนสนับสนุน</span>
              <span id="med-fee" class="font-semibold text-gray-900">-</span>
            </div>
            <div id="complication-row" class="hidden flex justify-between text-sm">
              <span class="text-gray-600">ค่าภาวะแทรกซ้อน</span>
              <span id="complication-fee" class="font-semibold text-gray-900">-</span>
            </div>
            <div class="border-t border-gray-200 pt-3 flex justify-between font-semibold">
              <span>รวมค่าใช้จ่ายทั้งหมด</span>
              <span id="total-cost" class="text-lg text-primary-600">-</span>
            </div>
          </div>
        </div>

        <!-- Insurance vs OOP -->
        <div class="grid gap-4 sm:grid-cols-2 mb-6">
          <div class="bg-green-50 rounded-lg border border-green-200 p-4">
            <div class="text-xs text-green-600 font-semibold mb-1">ประกันสุขภาพครอบคลุม (ประมาณ)</div>
            <div id="insurance-coverage" class="text-2xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-orange-50 rounded-lg border border-orange-200 p-4">
            <div class="text-xs text-orange-600 font-semibold mb-1">ค่าใช้จ่ายส่วนตัว (OOP)</div>
            <div id="oop-cost" class="text-2xl font-bold text-orange-700">-</div>
          </div>
        </div>

        <!-- Comparison (if showing both hospital types) -->
        <div id="comparison" class="hidden bg-blue-50 rounded-lg border border-blue-200 p-4">
          <h3 class="font-semibold text-gray-900 mb-3">เปรียบเทียบ: รัฐ vs เอกชน</h3>
          <div class="text-sm text-gray-700">
            <p class="mb-2">หากเลือกโรงพยาบาลรัฐแทนเอกชน คุณอาจประหยัดได้ประมาณ <span id="savings" class="font-semibold text-green-700">-</span></p>
          </div>
        </div>

        <!-- Tips -->
        <div class="bg-yellow-50 rounded-lg border border-yellow-200 p-4">
          <h3 class="font-semibold text-gray-900 mb-2">คำแนะนำ</h3>
          <ul id="tips" class="text-sm text-gray-700 list-disc pl-5 space-y-1">
            <li>จำนวนวันนอนรักษาส่งผลต่อค่าใช้จ่ายอย่างมากขนาดหนึ่ง</li>
            <li>ตรวจสอบความครอบคลุมประกันสุขภาพของคุณ</li>
            <li>ปรึกษาแพทย์เพื่อเข้าใจค่าใช้จ่ายที่แท้จริง</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ต้นทุนการรักษาพยาบาลที่โรงพยาบาลประกอบด้วยอะไร</h2>

      <p>
        ต้นทุนการรักษาพยาบาลที่โรงพยาบาลประกอบด้วยหลายส่วน ไม่ใช่แค่ค่าห้องพยาบาลเพียงอย่างเดียว
        ต้นทุนรวมได้แก่ ค่าห้อง ค่าการรักษา ค่าเอกซเรย์ ค่าตรวจเลือด และค่ายา
        การเข้าใจแต่ละส่วนจึงมีความสำคัญ เพื่อให้คุณสามารถวางแผนการเงินและประกันสุขภาพได้อย่างถูกต้อง
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประเภทของค่าใช้จ่ายรักษาพยาบาล</h3>

      <p>
        ค่าใช้จ่ายหลักมีดังนี้:
      </p>

      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li><strong>ค่าห้องพยาบาล:</strong> ค่ารายวันขึ้นอยู่กับประเภทห้อง (ทั่วไป ครึ่งตัว ส่วนตัว)</li>
        <li><strong>ค่าผ่าตัด/การรักษา:</strong> ขึ้นอยู่กับประเภทและความซับซ้อนของการรักษา</li>
        <li><strong>ค่าเอกซเรย์และอัลตราซาวด์:</strong> สำหรับการวินิจฉัยภาพ</li>
        <li><strong>ค่าตรวจเลือดและแล็บ:</strong> สำหรับการตรวจวิเคราะห์</li>
        <li><strong>ค่ายา:</strong> ยาที่ให้ระหว่างนอนรักษา</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ความแตกต่างระหว่างโรงพยาบาลรัฐและเอกชน</h3>

      <p>
        โรงพยาบาลรัฐและเอกชนมีความแตกต่างอย่างมากในด้านค่าใช้จ่าย:
      </p>

      <div class="overflow-x-auto my-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b-2 border-gray-300">
              <th class="py-2 pr-4">รายการ</th>
              <th class="py-2 pr-4">โรงพยาบาลรัฐ</th>
              <th class="py-2">โรงพยาบาลเอกชน</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ห้องทั่วไป (ต่อวัน)</td>
              <td class="py-2 pr-4">300 - 500 บาท</td>
              <td class="py-2">1,200 - 2,000 บาท</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ผ่าตัดปานกลาง</td>
              <td class="py-2 pr-4">8,000 - 12,000 บาท</td>
              <td class="py-2">25,000 - 40,000 บาท</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">บริการและสิ่งอำนวยความสะดวก</td>
              <td class="py-2 pr-4">พื้นฐาน</td>
              <td class="py-2">เพิ่มเติมและหรูหรา</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประกันสุขภาพและค่าใช้จ่าย</h3>

      <p>
        ประกันสุขภาพมักจะครอบคลุมค่าใช้จ่ายส่วนใหญ่ แต่ไม่ใช่ทั้งหมด
        ส่วนมากครอบคลุม 70-85% ของค่าใช้จ่าย ส่วนที่เหลือจึงต้องจ่ายเอง
        บางประเภทค่าใช้จ่ายเช่น ค่าห้องส่วนตัวพิเศษอาจไม่ครอบคลุม
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-8 mb-3">ตัวอย่างการคำนวณ: นอนรักษา 3 วัน ห้องครึ่งตัว ผ่าตัดปานกลาง</h3>

      <p class="text-gray-700 mb-3">
        สมมติว่าคุณต้องนอนรักษาที่โรงพยาบาลเอกชน 3 วัน ห้องครึ่งตัว สำหรับผ่าตัดปานกลาง พร้อมตรวจเลือดและเอกซเรย์:
      </p>

      <div class="bg-blue-50 rounded-lg p-4 mb-4 text-sm">
        <p class="font-semibold text-gray-900 mb-2">รายละเอียดค่าใช้จ่าย:</p>
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>ค่าห้องครึ่งตัว 3 วัน: 2,500 × 3 = 7,500 บาท</li>
          <li>ค่าผ่าตัดปานกลาง: 25,000 บาท</li>
          <li>ค่าเอกซเรย์/อัลตราซาวด์: 5,000 บาท</li>
          <li>ค่าตรวจเลือด: 3,500 บาท</li>
          <li>ค่ายา (3 วัน): 1,500 × 3 = 4,500 บาท</li>
          <li><strong>รวมทั้งสิ้น: 45,500 บาท</strong></li>
        </ul>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-4 text-sm">
        <p class="font-semibold text-gray-900 mb-3">การประมาณการประกันสุขภาพ:</p>
        <p class="text-gray-700 mb-2">หากประกันครอบคลุม 70%:</p>
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>ประกันจ่าย: 45,500 × 70% = 31,850 บาท</li>
          <li>คุณจ่ายเอง: 45,500 × 30% = 13,650 บาท</li>
        </ul>
      </div>

      <p class="text-gray-600 text-sm mt-3">
        <strong>หมายเหตุ:</strong> นี่เป็นการประมาณการเท่านั้น ค่าจริงอาจแตกต่างไปตามโรงพยาบาล ประเภทประกัน และภาวะสุขภาพของบุคคล
      </p>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณต้นทุนโรงพยาบาล/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนโรงพยาบาล/" />

    <!-- Official References -->
    <section class="mb-8">
      <h3 class="mb-3 text-lg font-semibold text-gray-900">แหล่งอ้างอิงทางการ</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="https://www.moph.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">กระทรวงสาธารณสุข — ข้อมูลโรงพยาบาลและค่าใช้จ่าย</a></li>
        <li><a href="https://www.tha.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">สมาคมโรงพยาบาลไทย — ข้อมูลประกาศค่าธรรมเนียมการรักษา</a></li>
