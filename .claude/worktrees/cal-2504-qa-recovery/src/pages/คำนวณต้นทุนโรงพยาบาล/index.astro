    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ค่าจริงอาจแตกต่างตามโรงพยาบาล ประเภทประกัน และการรักษาจริง
      กรุณาติดต่อโรงพยาบาลและประกันสุขภาพเพื่อได้ข้อมูลที่แม่นยำ
    </div>
  </article>

  <script define:vars={{ siteUrl }}>
    import { calculateHospitalCost, compareHospitalTypes } from '../../lib/hospital-cost-calculator';

    function formatThaiNumber(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(num);
    }

    const hospitalTypeSelect = document.getElementById('hospital-type') as HTMLSelectElement;
    const wardTypeSelect = document.getElementById('ward-type') as HTMLSelectElement;
    const daysInput = document.getElementById('days') as HTMLInputElement;
    const procedureSelect = document.getElementById('procedure') as HTMLSelectElement;
    const imagingCheckbox = document.getElementById('imaging') as HTMLInputElement;
    const labsCheckbox = document.getElementById('labs') as HTMLInputElement;
    const complicationsCheckbox = document.getElementById('complications') as HTMLInputElement;

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const days = parseInt(daysInput.value) || 1;

      const result = calculateHospitalCost({
        hospitalType: hospitalTypeSelect.value as 'government' | 'private',
        wardType: wardTypeSelect.value as 'private' | 'semiPrivate' | 'general',
        daysAdmitted: days,
        procedureType: procedureSelect.value as any,
        includeImaging: imagingCheckbox.checked,
        includeLabs: labsCheckbox.checked,
        hasComplications: complicationsCheckbox.checked,
      });

      // Update results
      (document.getElementById('ward-fee') as HTMLElement).textContent = formatThaiNumber(result.totalWardFee) + ' บาท';
      (document.getElementById('procedure-fee') as HTMLElement).textContent = formatThaiNumber(result.procedureFee) + ' บาท';
      (document.getElementById('imaging-fee') as HTMLElement).textContent = formatThaiNumber(result.imagingFee) + ' บาท';
      (document.getElementById('lab-fee') as HTMLElement).textContent = formatThaiNumber(result.labFee) + ' บาท';
      (document.getElementById('med-fee') as HTMLElement).textContent = formatThaiNumber(result.medicationFee) + ' บาท';
      (document.getElementById('complication-fee') as HTMLElement).textContent = formatThaiNumber(result.complicationFee) + ' บาท';

      // Toggle visibility
      (document.getElementById('imaging-row') as HTMLElement).classList.toggle('hidden', result.imagingFee === 0);
      (document.getElementById('lab-row') as HTMLElement).classList.toggle('hidden', result.labFee === 0);
      (document.getElementById('complication-row') as HTMLElement).classList.toggle('hidden', result.complicationFee === 0);

      (document.getElementById('total-cost') as HTMLElement).textContent = formatThaiNumber(result.subtotal) + ' บาท';
      (document.getElementById('insurance-coverage') as HTMLElement).textContent = formatThaiNumber(result.estimatedInsuranceCoverage) + ' บาท';
      (document.getElementById('oop-cost') as HTMLElement).textContent = formatThaiNumber(result.estimatedOOP) + ' บาท';

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('hospital-cost');
    });

    // Allow Enter key
    daysInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        document.getElementById('btn-calculate')!.click();
      }
    });
  </script>
</BaseLayout>
