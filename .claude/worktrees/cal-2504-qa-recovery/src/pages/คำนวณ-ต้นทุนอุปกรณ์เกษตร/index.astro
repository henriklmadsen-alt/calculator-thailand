---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณผลตอบแทนอุปกรณ์เกษตร 2569 | แทรกเตอร์ | Kamnuanlek';
const pageDescription = 'คำนวณผลตอบแทน ROI อุปกรณ์เกษตร แทรกเตอร์ เครื่องแยงข้าว ค่าเช่า รายได้ ต้นทุนการดำเนิน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุนอุปกรณ์เกษตร/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนอุปกรณ์เกษตร">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณผลตอบแทนอุปกรณ์เกษตร</h1>

    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2">
      <p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณผลตอบแทน ROI จากการลงทุนในอุปกรณ์เกษตร เช่น แทรกเตอร์ เครื่องแยงข้าว เครื่องสูบน้ำ ตามการเช่าออกและราคาตลาด
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div>
          <label for="equipmentType" class="block text-sm font-medium text-gray-700 mb-1">
            ชนิดอุปกรณ์
          </label>
          <select id="equipmentType" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base">
            <option value="tractor">แทรกเตอร์</option>
            <option value="thresher">เครื่องแยงข้าว</option>
            <option value="pumpset">เครื่องสูบน้ำ</option>
          </select>
        </div>

        <div>
          <label for="purchaseCost" class="block text-sm font-medium text-gray-700 mb-1">
            ราคาซื้อ (บาท)
          </label>
          <input
            type="text"
            id="purchaseCost"
            inputmode="decimal"
            placeholder="เช่น 800000"
            value="800000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div>
          <label for="usageDays" class="block text-sm font-medium text-gray-700 mb-1">
            วันใช้งานต่อปี
          </label>
          <input
            type="text"
            id="usageDays"
            inputmode="numeric"
            placeholder="เช่น 120"
            value="120"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div>
          <label for="rentalRate" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าเช่าต่อวัน (บาท)
          </label>
          <input
            type="text"
            id="rentalRate"
            inputmode="decimal"
            placeholder="เช่น 2000"
            value="2000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base"
      >
        คำนวณ ROI
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-blue-50 rounded-lg p-3">
            <p class="text-xs text-gray-600">ค่าบำรุงต่อปี</p>
            <p id="maintenance" class="text-lg font-bold text-gray-900">-</p>
          </div>
          <div class="bg-blue-50 rounded-lg p-3">
            <p class="text-xs text-gray-600">ค่าเสื่อมราคา</p>
            <p id="depreciation" class="text-lg font-bold text-gray-900">-</p>
          </div>
          <div class="bg-green-50 rounded-lg p-3">
            <p class="text-xs text-gray-600">รายได้จากค่าเช่า/ปี</p>
            <p id="annual-income" class="text-lg font-bold text-green-600">-</p>
          </div>
          <div class="bg-purple-50 rounded-lg p-3">
            <p class="text-xs text-gray-600">ROI ต่อปี</p>
            <p id="roi" class="text-lg font-bold text-purple-600">-</p>
          </div>
          <div class="bg-orange-50 rounded-lg p-3 col-span-2">
            <p class="text-xs text-gray-600">ระยะเวลาคืนทุน</p>
            <p id="payback" class="text-lg font-bold text-orange-600">-</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">อุปกรณ์เกษตรและ ROI</h2>
      <p>
        การลงทุนในอุปกรณ์เกษตรควรพิจารณา ROI อย่างดี โดยคำนึงถึงต้นทุนบำรุง ค่าเสื่อมราคา และรายได้จากการเช่าออกต่อคนไร่ใกล้เคียง
      </p>
    </section>
  </article>

  <script>
    function formatCurrency(num: number): string {
      return new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(num);
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const purchaseCost = parseFloat((document.getElementById('purchaseCost') as HTMLInputElement).value) || 0;
      const usageDays = parseFloat((document.getElementById('usageDays') as HTMLInputElement).value) || 120;
      const rentalRate = parseFloat((document.getElementById('rentalRate') as HTMLInputElement).value) || 2000;

      if (purchaseCost <= 0) return;

      const maintenance = purchaseCost * 0.1;
      const depreciation = purchaseCost / 10;
      const annualIncome = usageDays * rentalRate;
      const roi = (annualIncome / purchaseCost) * 100;
      const payback = purchaseCost / annualIncome;

      (document.getElementById('maintenance') as HTMLElement).textContent = formatCurrency(maintenance);
      (document.getElementById('depreciation') as HTMLElement).textContent = formatCurrency(depreciation);
      (document.getElementById('annual-income') as HTMLElement).textContent = formatCurrency(annualIncome);
      (document.getElementById('roi') as HTMLElement).textContent = Math.round(roi * 10) / 10 + '%';
      (document.getElementById('payback') as HTMLElement).textContent = Math.round(payback * 10) / 10 + ' ปี';

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('farm-equipment');
    });

    // Auto-calculate
    document.getElementById('btn-calculate')!.click();
  </script>
</BaseLayout>
