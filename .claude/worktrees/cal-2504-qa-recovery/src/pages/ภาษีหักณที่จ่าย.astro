---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ภาษีหัก ณ ที่จ่าย — อัตรา เมื่อไรต้องหัก วิธียื่น ภ.ง.ด.3 53 | Kamnuanlek"
  description="คู่มือภาษีหัก ณ ที่จ่ายไทยฉบับสมบูรณ์ อัตราค่าบริการ ค่าเช่า วิชาชีพ เมื่อไรต้องหัก วิธียื่น ภ.ง.ด.3 และ ภ.ง.ด.53 อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "ภาษีหัก ณ ที่จ่าย — อัตรา เมื่อไรต้องหัก วิธียื่น ภ.ง.ด.3 53", "item": "https://www.kamnuanlek.com/ภาษีหักณที่จ่าย/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">คู่มือภาษีหัก ณ ที่จ่าย</h1>

    <div class="mb-12 p-6 bg-orange-50 border border-orange-200 rounded-lg">
      <p class="text-lg text-gray-800">
        ภาษีหัก ณ ที่จ่าย หักจากการจ่ายเงินให้ผู้รับบริการ หากคุณจ่ายค่าบริการ ค่าเช่า หรือค่าวิชาชีพ คุณอาจต้องหักภาษี ณ ที่จ่ายและนำส่งกรมสรรพากร
      </p>
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">อัตราภาษีหัก ณ ที่จ่าย แยกตามประเภทการจ่าย</h2>
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ประเภทการจ่าย</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">อัตรา</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">แบบ</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {[
                { type: 'เงินเดือน/ค่าจ้าง', rate: 'ก้าวหน้า (อัตราภาษีเงินได้)', form: 'ภ.ง.ด.1' },
                { type: 'ค่าบริการ (บุคคลธรรมดา)', rate: '3%', form: 'ภ.ง.ด.3' },
                { type: 'ค่าบริการ (นิติบุคคล)', rate: '3%', form: 'ภ.ง.ด.53' },
                { type: 'ค่าเช่า (บุคคลธรรมดา)', rate: '5%', form: 'ภ.ง.ด.3' },
                { type: 'ค่าวิชาชีพ (แพทย์ ทนายความ ฯลฯ)', rate: '3%', form: 'ภ.ง.ด.3' },
                { type: 'ค่านายหน้า', rate: '3%', form: 'ภ.ง.ด.3 / ภ.ง.ด.53' },
                { type: 'ค่าขนส่ง/ค่าระวาง', rate: '1%', form: 'ภ.ง.ด.53' },
                { type: 'รางวัล/ลอตเตอรี่', rate: '5%', form: 'ภ.ง.ด.3' },
                { type: 'ดอกเบี้ย', rate: '15%', form: 'ภ.ง.ด.3 / ภ.ง.ด.53' },
                { type: 'เงินปันผล', rate: '10%', form: 'ภ.ง.ด.3 / ภ.ง.ด.53' },
                { type: 'ค่าลิขสิทธิ์', rate: '3%', form: 'ภ.ง.ด.3 / ภ.ง.ด.53' },
              ].map((row, i) => (
                <tr class={i % 2 === 0 ? '' : 'bg-gray-50'}>
                  <td class="px-4 py-3 text-gray-900">{row.type}</td>
                  <td class="px-4 py-3 font-semibold text-primary-600">{row.rate}</td>
                  <td class="px-4 py-3 text-gray-600">{row.form}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">กระบวนการภาษีหัก ณ ที่จ่าย</h2>
        <div class="space-y-4">
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <div class="flex-shrink-0 w-8 h-8 bg-orange-100 text-orange-700 rounded-full flex items-center justify-center font-bold text-sm">1</div>
            <div>
              <p class="font-semibold text-gray-900">จ่ายเงินให้ผู้รับบริการ</p>
              <p class="text-gray-600 text-sm">หากการจ่ายแต่ละครั้งเกิน 1,000 บาท</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <div class="flex-shrink-0 w-8 h-8 bg-orange-100 text-orange-700 rounded-full flex items-center justify-center font-bold text-sm">2</div>
            <div>
              <p class="font-semibold text-gray-900">หักภาษี ณ ที่จ่าย</p>
              <p class="text-gray-600 text-sm">หักอัตราภาษีที่ใช้บังคับจากยอดเงินรวม</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <div class="flex-shrink-0 w-8 h-8 bg-orange-100 text-orange-700 rounded-full flex items-center justify-center font-bold text-sm">3</div>
            <div>
              <p class="font-semibold text-gray-900">ออกหนังสือรับรองหัก ณ ที่จ่าย</p>
              <p class="text-gray-600 text-sm">มอบหนังสือรับรองการหักภาษี ณ ที่จ่ายแก่ผู้รับบริการ</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <div class="flex-shrink-0 w-8 h-8 bg-orange-100 text-orange-700 rounded-full flex items-center justify-center font-bold text-sm">4</div>
            <div>
              <p class="font-semibold text-gray-900">ยื่นและนำส่งภายในวันที่ 7 ของเดือนถัดไป</p>
              <p class="text-gray-600 text-sm">ยื่นแบบ ภ.ง.ด.3 หรือ ภ.ง.ด.53 และชำระภาษีที่หักไว้ต่อกรมสรรพากร</p>
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">ตัวอย่างการคำนวณ</h2>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <p class="font-semibold text-gray-900 mb-3">จ้างนักออกแบบฟรีแลนซ์ค่าจ้าง 30,000 บาท</p>
          <div class="space-y-2 text-gray-700">
            <div class="flex justify-between border-b pb-2">
              <span>ยอดตามใบแจ้งหนี้</span><span class="font-semibold">30,000 บาท</span>
            </div>
            <div class="flex justify-between border-b pb-2">
              <span>ภาษีหัก ณ ที่จ่าย 3%</span><span class="text-orange-600">- 900 บาท</span>
            </div>
            <div class="flex justify-between font-bold pt-1">
              <span>จ่ายให้นักออกแบบจริง</span><span class="text-primary-600">29,100 บาท</span>
            </div>
          </div>
          <p class="text-gray-600 text-sm mt-3">ภาษีหัก ณ ที่จ่าย 900 บาท ต้องนำส่งกรมสรรพากรภายในวันที่ 7 ของเดือนถัดไป พร้อมแบบ ภ.ง.ด.3</p>
        </div>
      </section>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">แหล่งข้อมูลที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/ปฏิทินภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📅 ปฏิทินภาษี</span>
          <p class="text-gray-600 text-sm mt-2">กำหนดยื่นภาษีทุกประเภท</p>
        </a>
        <a href="/ภาษีธุรกิจขนาดเล็ก/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏢 คู่มือภาษี SME</span>
          <p class="text-gray-600 text-sm mt-2">ภาษีทั้งหมดสำหรับธุรกิจขนาดเล็ก</p>
        </a>
        <a href="/เปรียบเทียบเครื่องคำนวณภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 เปรียบเทียบภาษี</span>
          <p class="text-gray-600 text-sm mt-2">อธิบายภาษีทุกประเภท</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
