---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ปฏิทินภาษี 2569 — กำหนดยื่นภาษีทุกประเภท | Kamnuanlek"
  description="ปฏิทินกำหนดยื่นภาษีไทยปี 2569 ครบทุกประเภท ภาษีเงินได้ VAT ภาษีหัก ณ ที่จ่าย ประกันสังคม ไม่พลาดกำหนดยื่นอีกต่อไป"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "ปฏิทินภาษี 2569 — กำหนดยื่นภาษีทุกประเภท", "item": "https://www.kamnuanlek.com/ปฏิทินภาษี/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">ปฏิทินภาษีไทย ปี 2569</h1>

    <div class="mb-12 p-6 bg-amber-50 border border-amber-200 rounded-lg">
      <p class="text-lg text-gray-800">
        การยื่นภาษีล่าช้าในไทยมีโทษปรับและเงินเพิ่ม ใช้ปฏิทินนี้วางแผนล่วงหน้าและปฏิบัติตามกฎหมายอย่างครบถ้วน
      </p>
    </div>

    <div class="space-y-8">
      {[
        {
          month: 'มกราคม',
          deadlines: [
            { date: '7 ม.ค.', tax: 'ภาษีหัก ณ ที่จ่าย (ธ.ค.)', desc: 'ภาษีหัก ณ ที่จ่ายจากการจ่ายเงินเดือนธันวาคม ยื่นต่อกรมสรรพากร' },
            { date: '15 ม.ค.', tax: 'ประกันสังคม (ธ.ค.)', desc: 'เงินสมทบประกันสังคมพนักงานประจำเดือนธันวาคม' },
          ]
        },
        {
          month: 'กุมภาพันธ์',
          deadlines: [
            { date: '7 ก.พ.', tax: 'ภาษีหัก ณ ที่จ่าย (ม.ค.)', desc: 'ภาษีหัก ณ ที่จ่ายจากการจ่ายเงินเดือนมกราคม' },
            { date: '15 ก.พ.', tax: 'ประกันสังคม (ม.ค.)', desc: 'เงินสมทบประกันสังคมพนักงานประจำเดือนมกราคม' },
            { date: '28 ก.พ.', tax: 'VAT (ภ.พ.30)', desc: 'ยื่นแบบ VAT ประจำเดือนมกราคม' },
          ]
        },
        {
          month: 'มีนาคม',
          deadlines: [
            { date: '31 มี.ค.', tax: 'ภาษีเงินได้บุคคลธรรมดา (กระดาษ)', desc: 'ยื่นภาษีเงินได้บุคคลธรรมดาประจำปีที่แล้ว' },
          ]
        },
        {
          month: 'เมษายน',
          deadlines: [
            { date: '8 เม.ย.', tax: 'ภาษีเงินได้บุคคลธรรมดา (e-Filing)', desc: 'ขยายเวลายื่นภาษีเงินได้บุคคลธรรมดาทางออนไลน์' },
            { date: '30 เม.ย.', tax: 'ภ.ง.ด.50 (ภาษีนิติบุคคล)', desc: 'ยื่นแบบภาษีเงินได้นิติบุคคล (รอบบัญชีสิ้นปี 31 ธ.ค.)' },
          ]
        },
        {
          month: 'สิงหาคม',
          deadlines: [
            { date: '31 ส.ค.', tax: 'ภาษีนิติบุคคลครึ่งปี (ภ.ง.ด.51)', desc: 'ชำระภาษีเงินได้นิติบุคคลล่วงหน้าครึ่งปี' },
          ]
        },
        {
          month: 'ทุกเดือน (วันที่ 7 ของเดือน)',
          deadlines: [
            { date: 'วันที่ 7 ของเดือน', tax: 'ภาษีหัก ณ ที่จ่าย', desc: 'ภาษีหัก ณ ที่จ่ายจากเดือนที่แล้ว (ภ.ง.ด.1 ภ.ง.ด.3 ภ.ง.ด.53)' },
            { date: 'วันที่ 15 ของเดือน', tax: 'ประกันสังคม', desc: 'เงินสมทบประกันสังคมเดือนที่แล้ว' },
            { date: 'วันสุดท้ายของเดือน', tax: 'VAT (ภ.พ.30)', desc: 'ยื่นแบบ VAT ประจำเดือนที่แล้ว (ธุรกิจที่จดทะเบียน)' },
          ]
        },
      ].map((section) => (
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <div class="bg-gradient-to-r from-amber-500 to-amber-600 px-6 py-3">
            <h3 class="text-lg font-bold text-white">{section.month}</h3>
          </div>
          <div class="divide-y divide-gray-100">
            {section.deadlines.map((d) => (
              <div class="flex gap-4 p-4">
                <div class="flex-shrink-0 w-24 text-center">
                  <span class="inline-block px-3 py-1 bg-amber-100 text-amber-800 rounded-full text-sm font-semibold">{d.date}</span>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">{d.tax}</p>
                  <p class="text-gray-600 text-sm mt-1">{d.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 p-6 bg-red-50 border border-red-200 rounded-lg">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">โทษปรับกรณียื่นล่าช้า</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 bg-white rounded-lg border border-red-100">
          <h3 class="font-semibold text-gray-900 mb-2">ยื่นภาษีนิติบุคคลล่าช้า</h3>
          <p class="text-gray-700 text-sm">เงินเพิ่ม 1.5% ต่อเดือน (สูงสุด 1.5 เท่าของภาษีที่ค้าง) + ปรับ 200 บาท กรณีไม่ยื่น</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-red-100">
          <h3 class="font-semibold text-gray-900 mb-2">ยื่น VAT ล่าช้า</h3>
          <p class="text-gray-700 text-sm">เงินเพิ่ม 1.5% ต่อเดือน + ปรับ 300 บาท พร้อมดอกเบี้ยภาษีค้างชำระ</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-red-100">
          <h3 class="font-semibold text-gray-900 mb-2">ยื่นภาษีหัก ณ ที่จ่ายล่าช้า</h3>
          <p class="text-gray-700 text-sm">เงินเพิ่ม 1.5% ต่อเดือน + ปรับ 100 บาท ต่อแบบ</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-red-100">
          <h3 class="font-semibold text-gray-900 mb-2">ยื่นภาษีเงินได้บุคคลธรรมดาล่าช้า</h3>
          <p class="text-gray-700 text-sm">เงินเพิ่ม 1.5% ต่อเดือนของภาษีค้าง + ปรับ 200 บาท</p>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องคำนวณภาษี</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/วิธีคำนวณภาษีเงินได้ไทย/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📚 คู่มือภาษีเงินได้</span>
          <p class="text-gray-600 text-sm mt-2">วิธีคำนวณภาษีเงินได้บุคคลธรรมดา</p>
        </a>
        <a href="/เปรียบเทียบเครื่องคำนวณภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 เปรียบเทียบภาษี</span>
          <p class="text-gray-600 text-sm mt-2">อธิบายภาษีทุกประเภท</p>
        </a>
        <a href="/ตรวจสอบหักลดหย่อนภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">✅ เช็กลิสต์ลดหย่อน</span>
          <p class="text-gray-600 text-sm mt-2">อย่าลืมสิทธิ์ลดหย่อน</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
