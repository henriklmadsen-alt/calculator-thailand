---
import BaseLayout from '../layouts/BaseLayout.astro';

const commonMistakes = [
  {
    title: 'ลืมหักค่าใช้จ่ายที่มีสิทธิ์',
    desc: 'หลายคนไม่ได้เรียกร้องค่าใช้จ่ายที่เกี่ยวกับงานทั้งหมด ทำให้เสียภาษีเกินความจำเป็น',
    solution: 'เก็บบันทึกค่าใช้จ่ายทางวิชาชีพทุกรายการ เช่น อุปกรณ์สำนักงาน อุปกรณ์ การศึกษา ฯลฯ',
    tip: 'ใช้เครื่องคำนวณภาษีของเราเพื่อดูผลกระทบเมื่อนำค่าลดหย่อนทั้งหมดมาคำนวณ'
  },
  {
    title: 'คำนวณค่าลดหย่อนส่วนตัวผิด',
    desc: 'บางคนลืมค่าลดหย่อนส่วนตัว 60,000 บาท หรือไม่ได้เรียกร้องค่าลดหย่อนผู้อยู่ในความดูแล',
    solution: 'ต้องรวมเสมอ: ค่าลดหย่อนส่วนตัว 60,000 บาท + ผู้อยู่ในความดูแลคนละ 20,000 บาท',
    tip: 'คำนวณใหม่ด้วยค่าลดหย่อนที่ถูกต้อง อาจประหยัดได้หลายพันบาท'
  },
  {
    title: 'ใช้อัตราภาษีผิด',
    desc: 'ใช้อัตราคงที่แทนอัตราก้าวหน้า ทำให้คำนวณภาษีเกิน',
    solution: 'ภาษีไทยเป็นอัตราก้าวหน้า: 5% สำหรับ 150,000 แรก, 10% สำหรับ 150,000 ถัดไป ฯลฯ',
    tip: 'ใช้เครื่องคำนวณของเราเพื่อใช้อัตราก้าวหน้าที่ถูกต้องโดยอัตโนมัติ'
  },
  {
    title: 'ลืมรวมแหล่งรายได้',
    desc: 'ลืมรวมรายได้ฟรีแลนซ์ การลงทุน หรือรายได้เสริมในยอดรวม',
    solution: 'รายงานรายได้ทุกประเภท: เงินเดือน ฟรีแลนซ์ เงินปันผล ค่าเช่า ดอกเบี้ย กำไรจากทุน',
    tip: 'แจกแจงแหล่งรายได้ทั้งหมดก่อนคำนวณเพื่อให้ครบถ้วน'
  },
  {
    title: 'คำนวณผิดช่วงเวลา',
    desc: 'คำนวณภาษีกลางปีแทนที่จะรอจนทราบรายได้สุดท้าย',
    solution: 'คำนวณภาษีหลังสิ้นปีภาษี (31 ธ.ค.) เมื่อทราบรายได้รวมแล้ว',
    tip: 'วางแผนรายไตรมาส แต่คำนวณสุดท้ายเมื่อปีสิ้นสุด'
  },
  {
    title: 'ไม่ใช้บัญชีลดหย่อนภาษี',
    desc: 'พลาดโอกาสลดรายได้ที่ต้องเสียภาษีผ่านบัญชีเกษียณ/ประกัน',
    solution: 'สมทบกองทุนเพื่อการเลี้ยงชีพ (RMF, SSF) เพื่อหักภาษี',
    tip: 'เพิ่มเงินสมทบในบัญชีลดหย่อนภาษีก่อนสิ้นปีเพื่อลดภาษีที่ต้องชำระ'
  },
  {
    title: 'สถานะการยื่นผิด',
    desc: 'ข้อมูลสถานภาพสมรส/ผู้อยู่ในความดูแลผิด ทำให้พลาดค่าลดหย่อน',
    solution: 'อัปเดตสถานะกับหน่วยงานราชการ: สมรส บุตร ผู้อยู่ในความดูแล',
    tip: 'ตรวจสอบว่าการเปลี่ยนแปลงสถานะสะท้อนในการคำนวณภาษีของคุณ'
  },
  {
    title: 'ชำระเงินก่อนคำนวณ',
    desc: 'จ่ายภาษีประมาณการโดยไม่ได้คำนวณยอดที่ต้องชำระจริงก่อน',
    solution: 'คำนวณเสมอก่อนชำระเพื่อทราบจำนวนที่ถูกต้อง',
    tip: 'ใช้เครื่องคำนวณของเราตรวจสอบยอดก่อนทำการชำระภาษี'
  },
];
---

<BaseLayout
  title="8 ข้อผิดพลาดภาษีที่คนไทยทำบ่อย — หลีกเลี่ยงและประหยัดภาษีได้ | Kamnuanlek"
  description="8 ข้อผิดพลาดภาษีเงินได้ที่คนไทยทำบ่อยที่สุด เรียนรู้วิธีคำนวณที่ถูกต้องและประหยัดเงินจากสิทธิ์ลดหย่อนที่พลาดไป อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "8 ข้อผิดพลาดภาษีที่คนไทยทำบ่อย — หลีกเลี่ยงและประหยัดภาษีได้", "item": "https://www.kamnuanlek.com/ผิดพลาดภาษีทั่วไป/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">8 ข้อผิดพลาดภาษีที่คนไทยทำบ่อยที่สุด</h1>

    <div class="mb-12 p-6 bg-red-50 border border-red-200 rounded-lg">
      <p class="text-lg text-gray-800">
        ผู้เสียภาษีไทยหลายหมื่นคนเสียภาษีเกินทุกปี เรียนรู้ข้อผิดพลาดที่พบบ่อยที่สุดและวิธีหลีกเลี่ยง
      </p>
    </div>

    <div class="space-y-8">
      {commonMistakes.map((mistake, idx) => (
        <div class="p-6 border border-gray-200 rounded-lg hover:shadow-lg transition-shadow">
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-red-100 text-red-700 rounded-full flex items-center justify-center font-bold">
              {idx + 1}
            </div>
            <div class="flex-grow">
              <h3 class="text-xl font-bold text-gray-900 mb-2">❌ {mistake.title}</h3>
              <p class="text-gray-600 mb-3"><strong>ปัญหา:</strong> {mistake.desc}</p>
              <p class="text-gray-600 mb-3"><strong>วิธีแก้:</strong> {mistake.solution}</p>
              <p class="p-3 bg-blue-50 rounded-lg border border-blue-200">
                <strong className="text-blue-900">💡 เคล็ดลับ:</strong> <span className="text-blue-800">{mistake.tip}</span>
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 p-8 bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl border border-green-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">✓ วิธีคำนวณที่ถูกต้อง</h2>
      <ol class="space-y-3 text-gray-700">
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">1.</span>
          <span>แจกแจงแหล่งรายได้ทั้งหมด (เงินเดือน ฟรีแลนซ์ การลงทุน ฯลฯ)</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">2.</span>
          <span>รวมค่าลดหย่อนส่วนตัว (60,000 บาท) + ค่าลดหย่อนผู้อยู่ในความดูแล (คนละ 20,000 บาท)</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">3.</span>
          <span>หักค่าลดหย่อนและค่าใช้จ่ายที่มีสิทธิ์ทั้งหมดออกจากรายได้รวม</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">4.</span>
          <span>ใช้อัตราภาษีก้าวหน้า: 5%, 10%, 15%, 20%, 25%, 30-37%</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">5.</span>
          <span>ใช้เครื่องคำนวณของเราตรวจสอบและหลีกเลี่ยงข้อผิดพลาดในการคำนวณ</span>
        </li>
      </ol>
    </div>

    <div class="mt-12 p-6 bg-blue-50 border border-blue-200 rounded-lg">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">พร้อมคำนวณอย่างถูกต้องหรือยัง?</h2>
      <p class="text-gray-700 mb-4">
        หยุดเดาและเริ่มคำนวณอย่างมั่นใจ เครื่องคำนวณของเราช่วยหลีกเลี่ยงข้อผิดพลาดเหล่านี้:
      </p>
      <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-semibold">
        ใช้เครื่องคำนวณภาษีเงินได้ →
      </a>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">แหล่งข้อมูลที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/วิธีคำนวณภาษีเงินได้ไทย/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📚 คู่มือคำนวณภาษี</span>
          <p class="text-gray-600 text-sm mt-2">คำแนะนำทีละขั้นตอนสำหรับการคำนวณภาษี</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 ศูนย์รวมเครื่องคำนวณการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">รวมเครื่องมือการเงินครบชุด</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
