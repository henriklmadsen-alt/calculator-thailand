---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'ภาษีที่ดินและสิ่งปลูกสร้างคืออะไร?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ภาษีที่ดินและสิ่งปลูกสร้างเป็นภาษีรายปีที่เรียกเก็บจากผู้ครอบครองที่ดิน บ้าน หรืออสังหาริมทรัพย์อื่นๆ คิดตามราคาประเมินของกรมธนารักษ์'
      }
    },
    {
      '@type': 'Question',
      name: 'บ้านหลังแรกต้องเสียภาษีที่ดินไหม?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'บ้านหลังแรกที่ใช้เป็นที่อยู่อาศัยหลัก มูลค่าไม่เกิน 50 ล้านบาท ได้รับยกเว้นภาษี ถ้ามูลค่าเกิน 50 ล้านบาท เสียเฉพาะส่วนที่เกิน ในอัตรา 0.02-0.1%'
      }
    },
    {
      '@type': 'Question',
      name: 'ที่ดินว่างเปล่าเสียภาษีอัตราเท่าไหร่?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ที่ดินว่างเปล่าหรือใช้ประโยชน์น้อย เสียภาษีในอัตรา 0.3-0.7% ขึ้นอยู่กับมูลค่าของที่ดิน และอาจเพิ่มขึ้นทุก 3 ปีถ้ายังว่างเปล่า'
      }
    }
  ]
};
---

<BaseLayout
  title="คำนวณภาษีที่ดินและสิ่งปลูกสร้าง 2569 — อัตราภาษีและยกเว้นบ้านหลังแรก | Kamnuanlek"
  description="คำนวณภาษีที่ดินและสิ่งปลูกสร้างไทย อัตราที่อยู่อาศัย เกษตรกรรม พาณิชยกรรม และที่ดินรกร้าง พร้อมเงื่อนไขยกเว้นบ้านหลังแรก อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "คำนวณภาษีที่ดินและสิ่งปลูกสร้าง 2569 — อัตราภาษีและยกเว้นบ้านหลังแรก", "item": "https://www.kamnuanlek.com/คำนวณภาษีที่ดินและสิ่งปลูกสร้าง/"}
    ]
  }</script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">คู่มือภาษีที่ดินและสิ่งปลูกสร้าง ปี 2569</h1>

    <div class="mb-12 p-6 bg-green-50 border border-green-200 rounded-lg">
      <p class="text-lg text-gray-800">
        ภาษีที่ดินและสิ่งปลูกสร้างรายปีของไทยส่งผลต่อเจ้าของอสังหาริมทรัพย์ทุกราย เรียนรู้ว่าคุณต้องชำระเท่าไรและบ้านของคุณได้รับยกเว้นภาษีหรือไม่
      </p>
      <a href="/คำนวณภาษีที่ดินและสิ่งปลูกสร้าง/" class="inline-block mt-4 px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-medium">
        ใช้เครื่องคำนวณภาษีที่ดิน →
      </a>
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">อัตราภาษีแยกตามประเภทอสังหาริมทรัพย์</h2>
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ประเภทอสังหาริมทรัพย์</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">อัตราภาษี</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">หมายเหตุ</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b">
                <td class="px-4 py-3 font-semibold text-gray-900">ที่อยู่อาศัยหลัก (ชื่อผู้ครอบครอง)</td>
                <td class="px-4 py-3 text-green-600 font-semibold">ยกเว้นไม่เกิน 50 ล้านบาท</td>
                <td class="px-4 py-3 text-gray-600">ต้องมีชื่อในทะเบียนบ้าน</td>
              </tr>
              <tr class="border-b bg-gray-50">
                <td class="px-4 py-3 font-semibold text-gray-900">ที่อยู่อาศัยเพิ่มเติม</td>
                <td class="px-4 py-3 text-gray-700">0.02% – 0.1%</td>
                <td class="px-4 py-3 text-gray-600">คิดจากราคาประเมิน</td>
              </tr>
              <tr class="border-b">
                <td class="px-4 py-3 font-semibold text-gray-900">พาณิชยกรรม / ให้เช่า</td>
                <td class="px-4 py-3 text-gray-700">0.3% – 0.7%</td>
                <td class="px-4 py-3 text-gray-600">ใช้สำหรับสร้างรายได้</td>
              </tr>
              <tr class="border-b bg-gray-50">
                <td class="px-4 py-3 font-semibold text-gray-900">ที่ดินเกษตรกรรม</td>
                <td class="px-4 py-3 text-gray-700">0.01% – 0.1%</td>
                <td class="px-4 py-3 text-gray-600">ใช้ทำการเกษตรจริง</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-semibold text-gray-900">ที่ดินว่างเปล่า / ไม่ได้ใช้ประโยชน์</td>
                <td class="px-4 py-3 text-orange-600 font-semibold">0.3% – 0.7% (เพิ่มขึ้นทุก 3 ปี)</td>
                <td class="px-4 py-3 text-gray-600">มาตรการจูงใจให้พัฒนาที่ดิน</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">ภาษีที่ดินและสิ่งปลูกสร้างคืออะไร?</h3>
            <p class="text-gray-700 text-sm">ภาษีรายปีที่เก็บจากผู้ครอบครองที่ดิน บ้าน หรืออสังหาริมทรัพย์ คิดตามราคาประเมินของกรมธนารักษ์</p>
          </div>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">บ้านหลังแรกต้องเสียภาษีที่ดินไหม?</h3>
            <p class="text-gray-700 text-sm">บ้านหลักที่ผู้ครอบครองมีชื่อในทะเบียนบ้าน มูลค่าไม่เกิน 50 ล้านบาท ได้รับยกเว้นภาษี</p>
          </div>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">ที่ดินว่างเปล่าเสียภาษีเท่าไหร่?</h3>
            <p class="text-gray-700 text-sm">0.3% เริ่มต้น และเพิ่มทุก 3 ปีจนถึง 3% สูงสุด ถ้าที่ดินยังว่างเปล่าต่อเนื่อง</p>
          </div>
        </div>
      </section>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือที่เกี่ยวข้องกับอสังหาริมทรัพย์</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/เครื่องคำนวณอสังหาริมทรัพย์/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏠 เครื่องคำนวณอสังหาริมทรัพย์</span>
          <p class="text-gray-600 text-sm mt-2">เครื่องคำนวณอสังหาฯ ทุกประเภท</p>
        </a>
        <a href="/คู่มือซื้อบ้านครั้งแรก/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏠 คู่มือซื้อบ้านครั้งแรก</span>
          <p class="text-gray-600 text-sm mt-2">คู่มือสำหรับผู้ซื้อบ้านมือใหม่</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 ศูนย์รวมการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">เครื่องมือการเงินทุกประเภท</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
