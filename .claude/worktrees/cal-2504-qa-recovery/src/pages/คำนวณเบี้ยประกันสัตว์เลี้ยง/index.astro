---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเบี้ยประกันสัตว์เลี้ยง 2569 | ประกันสุนัข แมว ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันสัตว์เลี้ยง 2569 สำหรับสุนัขและแมว ตามอายุ สายพันธุ์ และความคุ้มครองที่เลือก ค่ารักษาพยาบาล การผ่าตัด และความรับผิด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเบี้ยประกันสัตว์เลี้ยง/`;

const faqData = [
  {
    question: 'ประกันสัตว์เลี้ยงครอบคลุมอะไรบ้าง?',
    answer: 'ประกันสัตว์เลี้ยงในไทยมักครอบคลุม: ค่ารักษาพยาบาลเมื่อเจ็บป่วยหรืออุบัติเหตุ ค่าผ่าตัดฉุกเฉิน ค่ายา ค่าชันสูตร บางแผนรวมค่าฝังยาคุมกำเนิด และความรับผิดหากสัตว์ทำให้บุคคลอื่นได้รับบาดเจ็บ',
  },
  {
    question: 'ประกันสัตว์เลี้ยงในไทยมีบริษัทไหนบ้าง?',
    answer: 'ปัจจุบันมีหลายบริษัทในไทยที่ออกประกันสัตว์เลี้ยง เช่น Dhipaya (ทิพยประกัน) AXA และบางบริษัทร่วมกับคลินิกสัตว์ เบี้ยเริ่มต้น 1,500-5,000 บาท/ปี ขึ้นกับแผนและสายพันธุ์',
  },
  {
    question: 'สายพันธุ์มีผลต่อเบี้ยประกันไหม?',
    answer: 'ใช่ สายพันธุ์ที่มีความเสี่ยงโรคสูง เช่น French Bulldog (ปัญหาทางเดินหายใจ) Persian (ปัญหาไต) Golden Retriever (มะเร็ง) มักมีเบี้ยสูงกว่าสายพันธุ์ทั่วไปหรือลูกผสม 20-40%',
  },
  {
    question: 'ประกันสัตว์เลี้ยงคุ้มค่าไหม?',
    answer: 'คุ้มค่าสำหรับสัตว์เลี้ยงที่มีความเสี่ยงสูง หรือเจ้าของที่ต้องการความสบายใจ ค่าผ่าตัดฉุกเฉินในไทยอาจสูงถึง 20,000-100,000 บาท ซึ่งประกันช่วยลดภาระได้มาก',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเบี้ยประกันสัตว์เลี้ยง 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเบี้ยประกันสัตว์เลี้ยง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณการเบี้ยประกันสัตว์เลี้ยงในไทย</p>
      <p class="mt-1 text-sm text-slate-700">อ้างอิงตลาดประกันสัตว์เลี้ยงไทยปี 2569 ผลลัพธ์เป็นการประมาณการ</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณเบี้ยประกันสัตว์เลี้ยง 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">ประมาณเบี้ยประกันสุนัขและแมว ตามอายุ สายพันธุ์ และระดับความคุ้มครองที่เลือก</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูลสัตว์เลี้ยง</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>

        <div>
          <label for="pet-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทสัตว์เลี้ยง</label>
          <select id="pet-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="1.0">สุนัขพันธุ์ทั่วไป/ลูกผสม</option>
            <option value="1.3">สุนัขพันธุ์แท้ความเสี่ยงสูง (French Bulldog, Pug)</option>
            <option value="1.1">สุนัขพันธุ์แท้ทั่วไป (Golden Retriever, Labrador)</option>
            <option value="0.9">แมวพันธุ์ทั่วไป/ลูกผสม</option>
            <option value="1.2">แมวพันธุ์แท้ (Persian, Scottish Fold)</option>
          </select>
        </div>

        <div>
          <label for="pet-age" class="block text-sm font-medium text-gray-700 mb-1">อายุสัตว์เลี้ยง (ปี)</label>
          <select id="pet-age" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="1.0">น้อยกว่า 2 ปี (ลูก)</option>
            <option value="1.0" selected>2-6 ปี (วัยกลาง)</option>
            <option value="1.3">7-10 ปี (วัยชรา)</option>
            <option value="1.6">มากกว่า 10 ปี (สูงอายุ)</option>
          </select>
        </div>

        <div>
          <label for="plan" class="block text-sm font-medium text-gray-700 mb-1">แผนความคุ้มครอง</label>
          <select id="plan" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="1500">แผนพื้นฐาน — ค่ารักษา 20,000 บาท/ปี (~1,500 บาท/ปี)</option>
            <option value="3000" selected>แผนมาตรฐาน — ค่ารักษา 50,000 บาท/ปี (~3,000 บาท/ปี)</option>
            <option value="5500">แผนครอบคลุม — ค่ารักษา 100,000 บาท/ปี (~5,500 บาท/ปี)</option>
          </select>
        </div>

        <button type="button" id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">
          คำนวณเบี้ยประกัน
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 mb-4 text-center">
        <p class="text-sm text-primary-700 mb-1">เบี้ยประกันประมาณการรายปี</p>
        <p class="text-4xl font-bold text-primary-700" id="total-premium">-</p>
        <p class="text-sm text-primary-600 mt-1" id="monthly-premium">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b border-gray-200">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ทำไมควรทำประกันสัตว์เลี้ยง?</h2>
      <p>ค่ารักษาสัตว์เลี้ยงในไทยเพิ่มสูงขึ้นต่อเนื่อง โดยเฉพาะการผ่าตัดฉุกเฉิน การรักษามะเร็ง หรือการรักษาโรคเรื้อรัง อาจมีค่าใช้จ่ายสูงถึงหลักหมื่นหรือแสนบาท ประกันสัตว์เลี้ยงช่วยให้เจ้าของตัดสินใจรักษาได้โดยไม่กังวลเรื่องค่าใช้จ่าย</p>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณเบี้ยประกันสัตว์เลี้ยง/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ อัตราจริงขึ้นกับบริษัทประกันและสุขภาพของสัตว์เลี้ยง
    </div>
  </article>

  <script>
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const breedFactor = parseFloat((document.getElementById('pet-type') as HTMLSelectElement).value);
      const ageFactor = parseFloat((document.getElementById('pet-age') as HTMLSelectElement).value);
      const basePremium = parseFloat((document.getElementById('plan') as HTMLSelectElement).value);
      const total = basePremium * breedFactor * ageFactor;

      const rows = [
        ['เบี้ยฐานตามแผน', '', `${fmt(basePremium)} บาท`],
        ['ตัวคูณตามสายพันธุ์', `× ${breedFactor}`, `${fmt(basePremium * breedFactor)} บาท`],
        ['ตัวคูณตามอายุ', `× ${ageFactor}`, `${fmt(total)} บาท`],
        ['เบี้ยรวมประมาณการ/ปี', '', `<strong>${fmt(total)} บาท</strong>`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td>
          <td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td>
        </tr>`).join('');

      (document.getElementById('total-premium') as HTMLElement).textContent = fmt(total) + ' บาท/ปี';
      (document.getElementById('monthly-premium') as HTMLElement).textContent = `≈ ${fmt(total/12)} บาท/เดือน`;
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
