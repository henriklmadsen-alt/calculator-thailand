---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเป้าหมายทุนการศึกษา 2569 | ออมเพื่อค่าเรียนบุตร | Kamnuanlek';
const pageDescription = 'คำนวณเงินออมรายเดือนที่จำเป็นเพื่อครอบคลุมค่าการศึกษาของบุตรในอนาคต รวมเงินเฟ้อค่าเล่าเรียนและผลตอบแทนการลงทุน อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเป้าหมายทุนการศึกษา/`;

const faqData = [
  {
    question: 'ค่าเล่าเรียนในไทยเพิ่มขึ้นปีละเท่าไร?',
    answer: 'ค่าเล่าเรียนในไทยโดยเฉลี่ยเพิ่มขึ้น 4-6% ต่อปี สูงกว่าอัตราเงินเฟ้อทั่วไปประมาณ 2 เท่า โรงเรียนนานาชาติและมหาวิทยาลัยเอกชนอาจปรับขึ้นสูงกว่า 8-10% ต่อปีในบางปี การวางแผนด้วยอัตราเงินเฟ้อค่าเล่าเรียน 5% เป็นค่ากลางที่เหมาะสม',
  },
  {
    question: 'ควรลงทุนในอะไรเพื่อกองทุนการศึกษาบุตร?',
    answer: 'ขึ้นอยู่กับระยะเวลาที่เหลือ หากลูกอายุน้อยกว่า 10 ปี สามารถลงทุนในกองทุนรวมหุ้นได้เพื่อผลตอบแทนสูง หากใกล้ถึงเวลาเรียน (3-5 ปี) ควรค่อยๆ ลดความเสี่ยงเปลี่ยนเป็นตราสารหนี้และเงินฝาก กองทุน SSF/LTF ก็เป็นตัวเลือกที่ดีเพราะลดหย่อนภาษีได้',
  },
  {
    question: 'หากมีเงินออมอยู่แล้ว จะลดภาระรายเดือนได้มากแค่ไหน?',
    answer: 'เงินออมที่มีอยู่แล้วจะเติบโตตามผลตอบแทนและลดเงินออมรายเดือนที่ต้องการ เช่น มีเงิน 200,000 บาท ผลตอบแทน 7% ในอีก 15 ปีจะกลายเป็นประมาณ 551,000 บาท ซึ่งลดเงินออมรายเดือนได้อย่างมีนัยสำคัญ',
  },
  {
    question: 'ควรเริ่มออมเพื่อการศึกษาบุตรตั้งแต่เมื่อไร?',
    answer: 'ยิ่งเร็วยิ่งดี เริ่มตั้งแต่บุตรแรกเกิดให้ระยะเวลาออม 18 ปี ซึ่งช่วยลดภาระรายเดือนอย่างมาก หากเริ่มเมื่อบุตรอายุ 10 ปีและมีระยะเวลาเพียง 8 ปี เงินออมรายเดือนจะสูงกว่าเกือบสองเท่า',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเป้าหมายทุนการศึกษา',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเป้าหมายทุนการศึกษา">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเป้าหมายทุนการศึกษา 2569 — ออมเพื่อค่าเรียนบุตร
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณเงินออมรายเดือนที่จำเป็นเพื่อสะสมทุนการศึกษาให้บุตร รวมเงินเฟ้อค่าเล่าเรียนและผลตอบแทนจากการลงทุน เริ่มวางแผนตั้งแต่วันนี้เพื่อลดภาระในอนาคต
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="edu-fund-form" class="space-y-5">
        <p id="edu-fund-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div>
          <label for="edu-cost-today" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าการศึกษาที่ต้องการในมูลค่าวันนี้ (บาท)
          </label>
          <input
            type="text"
            id="edu-cost-today"
            inputmode="numeric"
            placeholder="เช่น 500,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p id="edu-cost-today-error" class="mt-1 hidden text-sm text-red-600"></p>
          <p class="mt-1 text-xs text-gray-500">ค่าเล่าเรียนทั้งหมดที่ต้องการในมูลค่าปัจจุบัน (ยังไม่ปรับเงินเฟ้อ)</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="child-current-age" class="block text-sm font-medium text-gray-700 mb-1">
              อายุบุตรปัจจุบัน (ปี)
            </label>
            <input
              type="number"
              id="child-current-age"
              min="0"
              max="17"
              placeholder="เช่น 3"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="child-current-age-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="school-start-age" class="block text-sm font-medium text-gray-700 mb-1">
              อายุที่เริ่มเรียน (ปี)
            </label>
            <input
              type="number"
              id="school-start-age"
              min="1"
              max="25"
              value="18"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="edu-inflation" class="block text-sm font-medium text-gray-700 mb-1">
              เงินเฟ้อค่าเล่าเรียน (% ต่อปี)
            </label>
            <input
              type="text"
              id="edu-inflation"
              inputmode="decimal"
              placeholder="เช่น 5"
              value="5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="edu-return" class="block text-sm font-medium text-gray-700 mb-1">
              ผลตอบแทนการลงทุน (% ต่อปี)
            </label>
            <input
              type="text"
              id="edu-return"
              inputmode="decimal"
              placeholder="เช่น 7"
              value="7"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="edu-existing-savings" class="block text-sm font-medium text-gray-700 mb-1">
              เงินออมที่มีอยู่แล้ว (บาท)
            </label>
            <input
              type="text"
              id="edu-existing-savings"
              inputmode="numeric"
              placeholder="เช่น 50,000"
              value="0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          id="edu-fund-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณทุนการศึกษา</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าเล่าเรียนในอนาคต</div>
            <div id="res-edu-future-cost" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ออมรายเดือนที่ต้องการ</div>
            <div id="res-edu-monthly-savings" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ระยะเวลาออม</div>
            <div id="res-edu-save-years" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-yellow-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินออมรวมทั้งหมด</div>
            <div id="res-edu-total-saved" class="text-xl font-bold text-yellow-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าเล่าเรียนมูลค่าวันนี้</span>
            <span id="res-edu-today-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินเฟ้อค่าเล่าเรียน</span>
            <span id="res-edu-inflation-display" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">มูลค่าเงินออมที่มีอยู่ ณ วันเริ่มเรียน</span>
            <span id="res-edu-existing-fv" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณเป้าหมายทุนการศึกษา</h2>
      <p>
        การวางแผนทุนการศึกษาต้องคำนึงถึงเงินเฟ้อค่าเล่าเรียนที่สูงกว่าเงินเฟ้อทั่วไป และผลตอบแทนจากการลงทุนที่จะช่วยให้เงินเติบโต
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรที่ใช้</h3>
      <p>
        ค่าเล่าเรียนในอนาคต = ค่าเล่าเรียนวันนี้ × (1 + เงินเฟ้อ)^จำนวนปี<br/>
        เงินออมรายเดือนที่ต้องการ = PMT ให้ FV = ค่าเล่าเรียนในอนาคต - FV ของเงินออมที่มีอยู่
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่าง</h3>
      <p>
        ค่าเล่าเรียน 500,000 บาทวันนี้ ลูก 3 ขวบ เริ่มเรียน 18 ปี (15 ปีข้างหน้า) เงินเฟ้อ 5%<br/>
        ค่าเล่าเรียนในอนาคต = 500,000 × 1.05^15 ≈ 1,039,000 บาท<br/>
        หากลงทุนได้ 7%/ปี ต้องออมประมาณ 3,500-4,000 บาท/เดือน
      </p>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณเป้าหมายทุนการศึกษา/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ค่าใช้จ่ายจริงอาจแตกต่างกัน ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('edu-fund-form') as HTMLFormElement;
    const formError = document.getElementById('edu-fund-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const costToday = parseNum((document.getElementById('edu-cost-today') as HTMLInputElement).value);
      const childAge = parseInt((document.getElementById('child-current-age') as HTMLInputElement).value);
      const schoolAge = parseInt((document.getElementById('school-start-age') as HTMLInputElement).value) || 18;
      const eduInflation = parseNum((document.getElementById('edu-inflation') as HTMLInputElement).value) || 5;
      const investReturn = parseNum((document.getElementById('edu-return') as HTMLInputElement).value) || 7;
      const existingSavings = parseNum((document.getElementById('edu-existing-savings') as HTMLInputElement).value);

      if (costToday <= 0) {
        formError.classList.remove('hidden');
        (document.getElementById('edu-cost-today') as HTMLInputElement).focus();
        return;
      }
      if (isNaN(childAge) || childAge < 0) {
        formError.classList.remove('hidden');
        (document.getElementById('child-current-age') as HTMLInputElement).focus();
        return;
      }

      trackCalculatorStart('edu-fund');

      const yearsToSchool = Math.max(0, schoolAge - childAge);
      const monthsToSchool = yearsToSchool * 12;

      // Future value of education cost
      const futureCost = costToday * Math.pow(1 + eduInflation / 100, yearsToSchool);

      // FV of existing savings
      const monthlyRate = investReturn / 100 / 12;
      const existingFV = existingSavings * Math.pow(1 + monthlyRate, monthsToSchool);

      // Required amount from monthly savings
      const needed = Math.max(0, futureCost - existingFV);

      // PMT to reach needed
      let monthlyNeeded: number;
      if (monthsToSchool <= 0) {
        monthlyNeeded = 0;
      } else if (Math.abs(monthlyRate) < 0.0000001) {
        monthlyNeeded = needed / monthsToSchool;
      } else {
        monthlyNeeded = needed * monthlyRate / (Math.pow(1 + monthlyRate, monthsToSchool) - 1);
      }

      const totalSaved = monthlyNeeded * monthsToSchool + existingSavings;

      (document.getElementById('res-edu-future-cost') as HTMLElement).textContent = fmt(futureCost) + ' บาท';
      (document.getElementById('res-edu-monthly-savings') as HTMLElement).textContent = fmt(monthlyNeeded) + ' บาท';
      (document.getElementById('res-edu-save-years') as HTMLElement).textContent = yearsToSchool + ' ปี';
      (document.getElementById('res-edu-total-saved') as HTMLElement).textContent = fmt(totalSaved) + ' บาท';
      (document.getElementById('res-edu-today-cost') as HTMLElement).textContent = fmt(costToday) + ' บาท';
      (document.getElementById('res-edu-inflation-display') as HTMLElement).textContent = eduInflation.toFixed(1) + '% ต่อปี';
      (document.getElementById('res-edu-existing-fv') as HTMLElement).textContent = fmt(existingFV) + ' บาท';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('edu-fund');
      trackCalculatorUsed('edu-fund');
    });
  </script>
</BaseLayout>
