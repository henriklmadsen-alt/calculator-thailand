---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าใช้จ่ายบัตรเดบิตในต่างประเทศ 2569 | ค่าธรรมเนียม FX บัตรเดบิต | Kamnuanlek';
const pageDescription = 'คำนวณค่าใช้จ่ายจริงเมื่อรูดบัตรเดบิตในต่างประเทศ รวมค่า FX fee และ cross-border fee';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าใช้จ่ายบัตรเดบิตต่างประเทศ/`;

const faqData = [
  {
    question: 'FX fee และ cross-border fee ของบัตรเดบิตไทยคืออะไร?',
    answer: 'FX fee คือค่าธรรมเนียมแลกเปลี่ยนเงินตราต่างประเทศที่ธนาคารเรียกเก็บเพิ่มจากอัตราแลกเปลี่ยนกลาง (mid-rate) ส่วน cross-border fee คือค่าธรรมเนียมที่ Visa/Mastercard เรียกเก็บสำหรับธุรกรรมข้ามประเทศ ทั้งสองรวมกันมักอยู่ที่ 2.5-3.5% ของยอดใช้จ่าย',
  },
  {
    question: 'บัตรเดบิตธนาคารไทยเหมาะกับการใช้ต่างประเทศไหม?',
    answer: 'ใช้ได้แต่มีต้นทุนสูง เพราะมี FX fee 1.5-2.5% บวก cross-border fee 1% บวกความเสี่ยงจาก DCC (Dynamic Currency Conversion) อีก 3-5% ถ้าเลือก "ชำระเป็นสกุลท้องถิ่น" เสมอจะดีกว่า หรือใช้บัตรเดินทางพิเศษที่มี FX fee ต่ำกว่า',
  },
  {
    question: 'DCC คืออะไร และควรหลีกเลี่ยงอย่างไร?',
    answer: 'DCC (Dynamic Currency Conversion) คือเมื่อเครื่อง POS ในต่างประเทศเสนอให้ชำระเป็นสกุลเงินบาทแทน โดยใช้อัตราที่แย่กว่ามาก ควรปฏิเสธและเลือก "Pay in local currency" เสมอ เพื่อให้ธนาคารไทยคำนวณอัตราแลกเปลี่ยนแทน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าใช้จ่ายบัตรเดบิตในต่างประเทศ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าใช้จ่ายบัตรเดบิตต่างประเทศ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณค่าใช้จ่ายบัตรเดบิตในต่างประเทศ 2569</h1>
    <p class="mb-6 text-gray-600">คำนวณยอดที่หักจากบัญชีจริงเมื่อรูดบัตรเดบิตในต่างประเทศ รวม FX fee และ cross-border fee</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc-form" class="space-y-4">
        <div>
          <label for="spend-amount" class="mb-1 block text-sm font-medium text-gray-700">ยอดใช้จ่าย (สกุลเงินต่างประเทศ เช่น USD)</label>
          <input id="spend-amount" type="text" inputmode="decimal" placeholder="เช่น 100"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="ex-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราแลกเปลี่ยน (บาทต่อ 1 USD)</label>
          <input id="ex-rate" type="text" inputmode="decimal" value="36"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="fx-fee" class="mb-1 block text-sm font-medium text-gray-700">FX fee (%)</label>
          <input id="fx-fee" type="text" inputmode="decimal" value="1.5"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="cb-fee" class="mb-1 block text-sm font-medium text-gray-700">Cross-border fee (%)</label>
          <input id="cb-fee" type="text" inputmode="decimal" value="1"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="rounded-lg bg-gray-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอด THB (mid-rate)</div>
            <div id="res-base" class="text-2xl font-bold text-gray-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่า FX fee</div>
            <div id="res-fx" class="text-2xl font-bold text-orange-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่า cross-border fee</div>
            <div id="res-cb" class="text-2xl font-bold text-red-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดที่หักจริงจากบัญชี</div>
            <div id="res-total" class="text-2xl font-bold text-primary-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณค่าใช้จ่ายบัตรเดบิตต่างประเทศ/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n > 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + v.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  document.getElementById('calc-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const spend = parseNum((document.getElementById('spend-amount') as HTMLInputElement).value);
    const rate = parseNum((document.getElementById('ex-rate') as HTMLInputElement).value);
    const fxPct = parseNum((document.getElementById('fx-fee') as HTMLInputElement).value);
    const cbPct = parseNum((document.getElementById('cb-fee') as HTMLInputElement).value);
    if (!spend || !rate) return;

    const baseTHB = spend * rate;
    const fxFeeAmt = baseTHB * (fxPct / 100);
    const cbFeeAmt = baseTHB * (cbPct / 100);
    const total = baseTHB + fxFeeAmt + cbFeeAmt;

    document.getElementById('res-base')!.textContent = fmt(baseTHB);
    document.getElementById('res-fx')!.textContent = fmt(fxFeeAmt);
    document.getElementById('res-cb')!.textContent = fmt(cbFeeAmt);
    document.getElementById('res-total')!.textContent = fmt(total);
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
