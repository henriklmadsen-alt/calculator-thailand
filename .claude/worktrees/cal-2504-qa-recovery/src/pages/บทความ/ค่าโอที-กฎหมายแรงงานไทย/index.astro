---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'ค่าโอทีตามกฎหมายแรงงานไทย คิดยังไง 1.5x 2x 3x | Kamnuanlek';
const description = 'อธิบายอัตราค่าโอทีตามพระราชบัญญัติคุ้มครองแรงงาน 2569 ว่าเมื่อไหรได้ 1.5 เท่า 2 เท่า หรือ 3 เท่า พร้อมตัวอย่างคำนวณ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ค่าโอที-กฎหมายแรงงานไทย/`;

const faqData = [
  {
    question: 'ค่าโอทีกฎหมายแรงงานไทยกำหนดอย่างไร?',
    answer: 'พระราชบัญญัติคุ้มครองแรงงาน กำหนดให้โอทีวันธรรมดาได้ 1.5 เท่า โอทีวันหยุดนักขัตฤกษ์ได้ 3 เท่า (หรือ 2 เท่าในบางกรณี) ของอัตราค่าจ้างต่อชั่วโมง',
  },
  {
    question: 'ค่าโอทีคำนวณจากเงินเดือนส่วนไหน?',
    answer: 'คำนวณจากค่าจ้างพื้นฐาน ไม่รวมโบนัส ค่าคอมมิชชั่น หรือเบี้ยพิเศษ โดยแบ่งเงินเดือนด้วยจำนวนชั่วโมงทำงานต่อเดือน เพื่อได้ค่าแรงต่อชั่วโมง',
  },
  {
    question: 'ผู้บริหารได้ค่าโอทีไหม?',
    answer: 'ไม่เสมอไป กฎหมายยกเว้นผู้จัดการและผู้บังคับบัญชาระดับสูงที่มีอำนาจในการจ้างงาน ควรตรวจสอบสัญญาจ้างและปรึกษาฝ่าย HR',
  },
  {
    question: 'นายจ้างบังคับให้ทำโอทีได้ไหม?',
    answer: 'กฎหมายกำหนดว่าการทำโอทีต้องได้รับความยินยอมจากลูกจ้าง ยกเว้นกรณีฉุกเฉินหรือเหตุจำเป็น นายจ้างไม่สามารถบังคับให้ทำโอทีโดยไม่ได้รับความยินยอมล่วงหน้า',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  modifiedDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    ค่าโอทีตามกฎหมายแรงงานไทย คิดยังไง 1.5x 2x 3x
  </h1>

  <p>
    ค่าโอที (Overtime Pay) คือเงินที่นายจ้างจ่ายเพิ่มสำหรับการทำงานนอกเวลาปกติ
    กฎหมายแรงงานไทยกำหนดอัตราค่าโอทีชัดเจนว่าสถานการณ์ใดได้เท่าไร
    ใช้ <a href="/คำนวณค่าโอที/">เครื่องคำนวณค่าโอที</a> ของเราเพื่อคำนวณค่าโอทีที่คุณควรได้รับ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณค่าโอทีของคุณตามกฎหมาย"
    description="ใส่เงินเดือนและชั่วโมงโอที แล้วดูว่าควรได้รับเงินเพิ่มเท่าไร"
    href="/คำนวณค่าโอที/"
    buttonLabel="คำนวณค่าโอทีตอนนี้"
  />

  <h2>อัตราค่าโอทีตามกฎหมายแรงงานไทย</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[560px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">สถานการณ์</th>
          <th class="border border-gray-200 px-3 py-2 text-left">อัตราค่าโอที</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ตัวอย่าง</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">โอทีวันธรรมดา (ทำเกิน 8 ชม./วัน)</td><td class="border border-gray-200 px-3 py-2 font-semibold text-blue-700">1.5 เท่า</td><td class="border border-gray-200 px-3 py-2">วันจันทร์–ศุกร์ หลัง 17:00</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ทำงานในวันหยุดนักขัตฤกษ์ (ทั้งวัน)</td><td class="border border-gray-200 px-3 py-2 font-semibold text-orange-700">2 เท่า</td><td class="border border-gray-200 px-3 py-2">วันสงกรานต์ ปีใหม่ ฯลฯ</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">โอทีในวันหยุดนักขัตฤกษ์ (เกินเวลาปกติ)</td><td class="border border-gray-200 px-3 py-2 font-semibold text-red-700">3 เท่า</td><td class="border border-gray-200 px-3 py-2">ทำเกิน 8 ชม. ในวันหยุดราชการ</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ทำงานในวันหยุดประจำสัปดาห์</td><td class="border border-gray-200 px-3 py-2 font-semibold text-orange-700">2 เท่า</td><td class="border border-gray-200 px-3 py-2">วันเสาร์หรืออาทิตย์ (ขึ้นกับนายจ้าง)</td></tr>
      </tbody>
    </table>
  </div>

  <h2>วิธีคำนวณค่าแรงต่อชั่วโมงสำหรับโอที</h2>

  <p>
    ก่อนคำนวณค่าโอที ต้องหาค่าแรงพื้นฐานต่อชั่วโมงก่อน:
  </p>

  <div class="not-prose my-4 rounded-lg border border-gray-200 bg-gray-50 p-4">
    <p class="font-semibold text-gray-900">ค่าแรงต่อชั่วโมง = เงินเดือน ÷ (วันทำงาน/เดือน × 8 ชั่วโมง)</p>
    <p class="mt-2 text-gray-600">เช่น เงินเดือน 20,000 บาท ทำงาน 20 วัน/เดือน</p>
    <p class="text-gray-600">ค่าแรง/ชม. = 20,000 ÷ (20 × 8) = 20,000 ÷ 160 = <strong>125 บาท/ชั่วโมง</strong></p>
  </div>

  <h2>ตัวอย่างคำนวณค่าโอทีแต่ละอัตรา</h2>

  <p>ที่เงินเดือน 20,000 บาท (ค่าแรง 125 บาท/ชม.) ทำโอที 5 ชั่วโมง:</p>

  <ul>
    <li><strong>โอทีวันธรรมดา (1.5x):</strong> 125 × 1.5 × 5 = <strong>937.50 บาท</strong></li>
    <li><strong>โอทีวันหยุดนักขัตฤกษ์ (2x):</strong> 125 × 2 × 5 = <strong>1,250 บาท</strong></li>
    <li><strong>โอทีชั่วโมงเพิ่มในวันหยุดนักขัตฤกษ์ (3x):</strong> 125 × 3 × 5 = <strong>1,875 บาท</strong></li>
  </ul>

  <h2>สิ่งที่ต้องตรวจสอบในบัญชีเงินเดือน</h2>

  <ul>
    <li>ค่าโอทีต้องแยกรายการชัดเจนจากเงินเดือนพื้นฐาน</li>
    <li>ตรวจสอบว่าอัตราที่ใช้ถูกต้องตามสถานการณ์ (วันธรรมดา / วันหยุด)</li>
    <li>ค่าแรงที่ใช้คำนวณต้องเป็นค่าจ้างพื้นฐาน ไม่ใช่รวมโบนัส</li>
    <li>หากเชื่อว่าได้รับค่าโอทีผิด ให้ติดต่อฝ่าย HR หรือกรมสวัสดิการและคุ้มครองแรงงาน</li>
  </ul>

  <ArticleCalculatorCTA
    title="คำนวณค่าโอทีที่คุณควรได้รับ"
    description="ใส่เงินเดือน ชั่วโมงโอที และประเภทวัน แล้วดูยอดเงินที่ถูกต้องตามกฎหมาย"
    href="/คำนวณค่าโอที/"
    buttonLabel="คำนวณค่าโอทีตอนนี้"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณค่าโอที/">คำนวณค่าโอที</a> ตรวจสอบค่าโอทีที่ควรได้รับ</li>
    <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a> หักประกันสังคมและภาษี</li>
    <li><a href="/คำนวณค่าแรงขั้นต่ำ/">คำนวณค่าแรงขั้นต่ำ</a> อัตราค่าแรงตามจังหวัด</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/เงินเดือน-20000-โอที-10-ชั่วโมง/">เงินเดือน 20,000 บาท ทำโอที 10 ชั่วโมง/เดือน ได้เพิ่มเท่าไร</a></li>
    <li><a href="/บทความ/คำนวณค่าโอที-2569-กฎหมายแรงงาน/">คำนวณค่าโอที 2569 ตามกฎหมายแรงงาน</a></li>
  </ul>

  <h2>แหล่งอ้างอิง</h2>
  <ul>
    <li><a href="https://www.labour.go.th" target="_blank" rel="noopener noreferrer">กระทรวงแรงงาน (Ministry of Labour)</a></li>
    <li><a href="https://www.dol.go.th" target="_blank" rel="noopener noreferrer">กรมสวัสดิการและคุ้มครองแรงงาน</a></li>
  </ul>
</BlogPostLayout>
