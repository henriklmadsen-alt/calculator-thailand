---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'วิธีวัด BMI อย่างถูกต้อง และแปลผลตามมาตรฐาน WHO | Kamnuanlek';
const description = 'อธิบายวิธีวัด BMI อย่างถูกต้องตามมาตรฐาน WHO 2569 พร้อมตารางแปลผล เกณฑ์สำหรับคนไทย และคำแนะนำเมื่อ BMI เกินเกณฑ์';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/วิธีวัด-bmi-อย่างถูกต้อง/`;

const faqData = [
  {
    question: 'BMI คืออะไร และวัดได้อย่างไร?',
    answer: 'BMI (Body Mass Index) คือดัชนีมวลกาย คำนวณจาก น้ำหนัก (กิโลกรัม) ÷ ส่วนสูง (เมตร)² ใช้ประเมินว่าน้ำหนักตัวอยู่ในเกณฑ์ปกติหรือไม่',
  },
  {
    question: 'เกณฑ์ BMI ของ WHO สำหรับคนไทยคืออะไร?',
    answer: 'WHO กำหนดให้ BMI 18.5–24.9 คือน้ำหนักปกติ ต่ำกว่า 18.5 คือน้ำหนักน้อย 25–29.9 คือน้ำหนักเกิน และ 30 ขึ้นไปคืออ้วน สำหรับคนเอเชียมักใช้เกณฑ์เข้มขึ้น คือน้ำหนักเกินเริ่มที่ BMI 23',
  },
  {
    question: 'BMI มีข้อจำกัดอะไรบ้าง?',
    answer: 'BMI ไม่ได้แยกระหว่างมวลกล้ามเนื้อกับไขมัน นักกีฬาหรือผู้ที่ออกกำลังกายหนักอาจมี BMI สูงแม้ไม่อ้วน และ BMI ไม่บอกตำแหน่งของไขมัน ควรวัดรอบเอวร่วมด้วย',
  },
  {
    question: 'ควรวัด BMI บ่อยแค่ไหน?',
    answer: 'สำหรับผู้ใหญ่ทั่วไปควรวัด BMI ทุก 3–6 เดือน หากกำลังควบคุมน้ำหนักอาจวัดทุกเดือน และควรวัดในเวลาเดียวกันทุกครั้งเพื่อเปรียบเทียบผลได้ถูกต้อง',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  modifiedDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    วิธีวัด BMI อย่างถูกต้อง และแปลผลตามมาตรฐาน WHO
  </h1>

  <p>
    BMI (Body Mass Index) หรือดัชนีมวลกาย เป็นตัวชี้วัดหลักที่แพทย์และสถาบันสาธารณสุขใช้ประเมินน้ำหนักตัวว่าอยู่ในเกณฑ์ปกติหรือไม่
    วิธีคำนวณคือหารน้ำหนักตัว (กิโลกรัม) ด้วยส่วนสูงยกกำลังสอง (เมตร)
    บทความนี้จะอธิบายวิธีวัด BMI อย่างถูกต้อง และวิธีแปลผลตามมาตรฐาน WHO
  </p>

  <ArticleCalculatorCTA
    title="คำนวณ BMI ของคุณได้เลย"
    description="กรอกน้ำหนักและส่วนสูง แล้วดูว่า BMI ของคุณอยู่ในเกณฑ์ไหน"
    href="/คำนวณ-bmi/"
    buttonLabel="ไปที่เครื่องคำนวณ BMI"
  />

  <h2>สูตรคำนวณ BMI</h2>

  <p>
    สูตรที่ใช้ทั่วโลกมีเพียงสูตรเดียว คือ:
  </p>

  <div class="not-prose my-4 rounded-lg border border-gray-200 bg-gray-50 p-4 text-center text-lg font-semibold text-gray-900">
    BMI = น้ำหนัก (กก.) ÷ ส่วนสูง (ม.)²
  </div>

  <p>
    ตัวอย่าง: น้ำหนัก 65 กิโลกรัม สูง 170 เซนติเมตร (1.70 เมตร)
  </p>

  <ul>
    <li>BMI = 65 ÷ (1.70 × 1.70)</li>
    <li>BMI = 65 ÷ 2.89</li>
    <li><strong>BMI = 22.5 (อยู่ในเกณฑ์ปกติ)</strong></li>
  </ul>

  <h2>เกณฑ์การประเมิน BMI โดย WHO</h2>

  <p>
    WHO กำหนดเกณฑ์ BMI สำหรับผู้ใหญ่ทั่วไปไว้ดังนี้ ประเทศไทยและประเทศส่วนใหญ่ใช้เกณฑ์นี้เป็นมาตรฐานหลัก:
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">หมวดหมู่</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ค่า BMI</th>
          <th class="border border-gray-200 px-3 py-2 text-left">คำอธิบาย</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">น้ำหนักน้อย</td><td class="border border-gray-200 px-3 py-2">ต่ำกว่า 18.5</td><td class="border border-gray-200 px-3 py-2">ควรปรึกษาแพทย์เรื่องโภชนาการ</td></tr>
        <tr class="bg-green-50"><td class="border border-gray-200 px-3 py-2">น้ำหนักปกติ</td><td class="border border-gray-200 px-3 py-2">18.5–24.9</td><td class="border border-gray-200 px-3 py-2">ช่วงปกติที่แนะนำสำหรับผู้ใหญ่</td></tr>
        <tr class="bg-yellow-50"><td class="border border-gray-200 px-3 py-2">น้ำหนักเกิน</td><td class="border border-gray-200 px-3 py-2">25.0–29.9</td><td class="border border-gray-200 px-3 py-2">ควรปรึกษาแพทย์เรื่องการควบคุมน้ำหนัก</td></tr>
        <tr class="bg-orange-50"><td class="border border-gray-200 px-3 py-2">อ้วน ระดับ 1</td><td class="border border-gray-200 px-3 py-2">30.0–34.9</td><td class="border border-gray-200 px-3 py-2">ความเสี่ยงสูงต่อโรคเรื้อรัง</td></tr>
        <tr class="bg-red-50"><td class="border border-gray-200 px-3 py-2">อ้วน ระดับ 2+</td><td class="border border-gray-200 px-3 py-2">35 ขึ้นไป</td><td class="border border-gray-200 px-3 py-2">ความเสี่ยงสูงมาก ควรพบแพทย์ทันที</td></tr>
      </tbody>
    </table>
  </div>

  <h2>เกณฑ์พิเศษสำหรับคนเอเชียและคนไทย</h2>

  <p>
    องค์การอนามัยโลก (WHO) ได้ระบุว่าคนเอเชียมีความเสี่ยงต่อโรคเรื้อรังที่ค่า BMI ต่ำกว่าชาวตะวันตก
    ดังนั้นสำหรับคนไทยและเอเชีย เกณฑ์ที่ใช้มักเข้มกว่า:
  </p>

  <ul>
    <li>BMI ต่ำกว่า 18.5 = น้ำหนักน้อย</li>
    <li>BMI 18.5–22.9 = น้ำหนักปกติ</li>
    <li>BMI 23.0–24.9 = น้ำหนักเกิน (เริ่มเฝ้าระวัง)</li>
    <li>BMI 25.0 ขึ้นไป = อ้วน (ควรพบแพทย์)</li>
  </ul>

  <h2>ข้อจำกัดของ BMI ที่ควรรู้</h2>

  <p>
    BMI เป็นเครื่องมือคัดกรองเบื้องต้น ไม่ใช่การวินิจฉัยทางการแพทย์ ข้อจำกัดสำคัญได้แก่:
  </p>

  <ul>
    <li><strong>ไม่แยกมวลกล้ามเนื้อกับไขมัน</strong> นักกีฬาอาจมี BMI สูงแต่ไม่ได้อ้วน</li>
    <li><strong>ไม่บอกตำแหน่งไขมัน</strong> ไขมันหน้าท้องอันตรายกว่าไขมันส่วนอื่น</li>
    <li><strong>ไม่เหมาะกับเด็กและผู้สูงอายุ</strong> ควรใช้เกณฑ์อื่นเสริม</li>
    <li><strong>ไม่คำนึงถึงเพศ</strong> ผู้หญิงมักมีไขมันสูงกว่าผู้ชายที่ BMI เท่ากัน</li>
  </ul>

  <p>
    ควรวัดรอบเอวร่วมด้วย เพราะรอบเอวเกิน 90 ซม. (ผู้ชาย) หรือ 80 ซม. (ผู้หญิง) บ่งชี้ความเสี่ยงสูงต่อโรคเบาหวานและโรคหัวใจ
  </p>

  <ArticleCalculatorCTA
    title="ลองคำนวณ BMI ของคุณตอนนี้"
    description="ใช้เครื่องคำนวณ BMI ของเรา พร้อมคำแปลผลตามเกณฑ์คนไทย"
    href="/คำนวณ-bmi/"
    buttonLabel="คำนวณ BMI ฟรี"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณ-bmi/">คำนวณ BMI</a> สำหรับตรวจสอบดัชนีมวลกายของคุณ</li>
    <li><a href="/คำนวณแคลอรี่/">คำนวณแคลอรี่</a> ช่วยวางแผนโภชนาการควบคู่กับ BMI</li>
    <li><a href="/คำนวณค่าไฟฟ้า/">คำนวณค่าไฟฟ้า</a> สำหรับวางแผนค่าใช้จ่ายรายเดือน</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/bmi-27-หมายความว่าอะไร/">BMI 27 หมายความว่าอะไร ต้องลดน้ำหนักอีกเท่าไร</a></li>
    <li><a href="/บทความ/bmi-คำนวณค่าดัชนีมวลกาย-วิธีลดน้ำหนัก/">BMI คำนวณค่าดัชนีมวลกาย วิธีลดน้ำหนัก</a></li>
  </ul>

  <h2>แหล่งอ้างอิง</h2>
  <ul>
    <li><a href="https://www.moph.go.th" target="_blank" rel="noopener noreferrer">กระทรวงสาธารณสุข (Ministry of Public Health)</a></li>
    <li><a href="https://www.who.int/news-room/fact-sheets/detail/obesity-and-overweight" target="_blank" rel="noopener noreferrer">WHO — Obesity and overweight fact sheet</a></li>
  </ul>
</BlogPostLayout>
