---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'วิธีคำนวณเปอร์เซ็นต์ สูตรครบทุกรูปแบบ พร้อมตัวอย่าง | Kamnuanlek';
const description = 'เรียนรู้สูตรคำนวณเปอร์เซ็นต์ 3 รูปแบบหลัก หาเปอร์เซ็นต์ของจำนวน หาว่า A เป็น % เท่าไรของ B และหาการเปลี่ยนแปลง พร้อมตัวอย่างจริงในชีวิตประจำวัน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/วิธีคำนวณเปอร์เซ็นต์/`;

const faqData = [
  {
    question: 'สูตรคำนวณเปอร์เซ็นต์พื้นฐานคืออะไร?',
    answer: 'หา X% ของ Y ใช้สูตร (X ÷ 100) × Y เช่น 20% ของ 1,500 = (20 ÷ 100) × 1,500 = 300',
  },
  {
    question: 'วิธีหาว่า A เป็นกี่เปอร์เซ็นต์ของ B?',
    answer: 'ใช้สูตร (A ÷ B) × 100 เช่น 300 เป็นกี่% ของ 1,500 = (300 ÷ 1,500) × 100 = 20%',
  },
  {
    question: 'วิธีคำนวณการเปลี่ยนแปลงเปอร์เซ็นต์?',
    answer: 'ใช้สูตร ((ค่าใหม่ - ค่าเดิม) ÷ ค่าเดิม) × 100 เช่น ราคาจาก 500 เป็น 600 เพิ่มขึ้น ((600-500) ÷ 500) × 100 = 20%',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    วิธีคำนวณเปอร์เซ็นต์ สูตรครบทุกรูปแบบ พร้อมตัวอย่าง
  </h1>

  <p>
    เปอร์เซ็นต์เป็นแนวคิดทางคณิตศาสตร์ที่ใช้บ่อยมากในชีวิตประจำวัน ตั้งแต่การดูแลสุขภาพ การช้อปปิ้ง การกำหนดภาษี ไปจนถึงการประเมินผลการศึกษา บทความนี้จะสอนวิธีการคำนวณเปอร์เซ็นต์ทั้ง 3 รูปแบบหลัก พร้อมตัวอย่างจริง
  </p>

  <ArticleCalculatorCTA
    title="เครื่องคำนวณเปอร์เซ็นต์"
    description="คำนวณเปอร์เซ็นต์ทุกรูปแบบ ส่วนลด VAT การเปลี่ยนแปลง ทันที"
    href="/คำนวณเปอร์เซ็นต์/"
    buttonLabel="คำนวณเปอร์เซ็นต์ฟรี"
  />

  <h2>เปอร์เซ็นต์คืออะไร</h2>

  <p>
    เปอร์เซ็นต์ (Percent, %) คือการแสดงจำนวนใดๆ เป็นส่วนหนึ่งของ 100 ตัวอย่างเช่น 50% หมายถึง 50 ส่วนจาก 100 ส่วน หรือเท่ากับ 1/2 นั่นเอง
  </p>

  <h2>สูตรการคำนวณเปอร์เซ็นต์ 3 รูปแบบ</h2>

  <h3>1. หาเปอร์เซ็นต์ของจำนวน (หา X% ของ Y)</h3>

  <div class="my-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
    <p class="text-center font-medium text-gray-900">สูตร: (เปอร์เซ็นต์ ÷ 100) × จำนวนทั้งหมด</p>
  </div>

  <p><strong>ตัวอย่าง:</strong> หา 20% ของ 1,500 บาท</p>
  <ul>
    <li>(20 ÷ 100) × 1,500 = 0.2 × 1,500 = <strong>300 บาท</strong></li>
  </ul>

  <h3>2. หาว่า A เป็นเปอร์เซ็นต์เท่าไรของ B</h3>

  <div class="my-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
    <p class="text-center font-medium text-gray-900">สูตร: (A ÷ B) × 100</p>
  </div>

  <p><strong>ตัวอย่าง:</strong> 300 บาท คิดเป็นกี่% ของ 1,500 บาท</p>
  <ul>
    <li>(300 ÷ 1,500) × 100 = 0.2 × 100 = <strong>20%</strong></li>
  </ul>

  <h3>3. หาการเปลี่ยนแปลงเปอร์เซ็นต์ (% Change)</h3>

  <div class="my-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
    <p class="text-center font-medium text-gray-900">สูตร: ((ค่าใหม่ - ค่าเดิม) ÷ ค่าเดิม) × 100</p>
  </div>

  <p><strong>ตัวอย่าง:</strong> ราคาสินค้าเพิ่มจาก 500 บาทเป็น 600 บาท เพิ่มขึ้นกี่%</p>
  <ul>
    <li>((600 - 500) ÷ 500) × 100 = (100 ÷ 500) × 100 = <strong>20%</strong></li>
  </ul>

  <h2>ตัวอย่างการนำไปใช้ในชีวิตจริง</h2>

  <p><strong>ส่วนลดเวลาช้อปปิ้ง:</strong> เสื้อราคา 1,200 บาท ลดราคา 25% ต้องจ่ายเท่าไร</p>
  <ul>
    <li>ส่วนลด = 25% ของ 1,200 = 300 บาท</li>
    <li>ราคาหลังลด = 1,200 - 300 = <strong>900 บาท</strong></li>
  </ul>

  <p><strong>คะแนนสอบ:</strong> สอบได้ 72 คะแนนจากทั้งหมด 90 คะแนน ได้ร้อยละเท่าไร</p>
  <ul>
    <li>(72 ÷ 90) × 100 = <strong>80%</strong></li>
  </ul>

  <p><strong>ภาษีมูลค่าเพิ่ม (VAT):</strong> สินค้ามูลค่า 1,000 บาท ต้องจ่ายภาษี 7%</p>
  <ul>
    <li>ภาษี = 7% ของ 1,000 = 70 บาท</li>
    <li>ราคารวม = 1,000 + 70 = <strong>1,070 บาท</strong></li>
  </ul>

  <h2>เคล็ดลับการคำนวณเปอร์เซ็นต์ให้เร็ว</h2>

  <ul>
    <li>เปอร์เซ็นต์ 50% = ÷ 2</li>
    <li>เปอร์เซ็นต์ 25% = ÷ 4</li>
    <li>เปอร์เซ็นต์ 10% = ÷ 10</li>
    <li>เปอร์เซ็นต์ 20% = ÷ 5</li>
  </ul>

  <ArticleCalculatorCTA
    title="คำนวณเปอร์เซ็นต์ทุกรูปแบบ"
    description="ใส่ตัวเลข เลือกประเภทการคำนวณ ได้ผลลัพธ์ทันที"
    href="/คำนวณเปอร์เซ็นต์/"
    buttonLabel="เปิดเครื่องคำนวณ"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
