---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../data/categories';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
};

const { category } = Astro.props;
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageUrl = `${siteUrl}/หมวดหมู่/${category.slug}/`;

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'หน้าแรก',
      item: siteUrl + '/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'หมวดหมู่',
      item: siteUrl + '/หมวดหมู่/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: category.name,
    },
  ],
};
---

<BaseLayout
  title={category.metaTitle}
  description={category.metaDescription}
  canonical={pageUrl}
  pageName={category.name}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />

  <!-- Breadcrumb Navigation -->
  <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-500">
    <ol class="flex items-center gap-1.5 flex-wrap">
      <li>
        <a href="/" class="hover:text-primary-600 transition-colors">หน้าแรก</a>
      </li>
      <li class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span>หมวดหมู่</span>
      </li>
      <li class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-gray-900 font-medium">{category.name}</span>
      </li>
    </ol>
  </nav>

  <!-- Category Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-4xl">{category.icon}</span>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900">
        {category.name}
      </h1>
    </div>
    <p class="text-gray-600 text-lg leading-relaxed max-w-3xl">
      {category.description}
    </p>
  </div>

  <!-- Calculator Grid -->
  <section class="mb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">
      เครื่องคำนวณในหมวดนี้ ({category.calculators.length} รายการ)
    </h2>
    <div class="grid gap-4 sm:gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {category.calculators.map((calc) => (
        <a
          href={calc.href}
          class="calc-card group relative block p-5 sm:p-6 bg-white rounded-2xl shadow-card hover:shadow-card-hover border border-gray-100 hover:border-primary-200"
        >
          {calc.tag && (
            <span class={`absolute top-4 right-4 text-[10px] font-semibold px-2 py-0.5 rounded-full ${calc.tagColor}`}>
              {calc.tag}
            </span>
          )}
          <div class="text-3xl mb-3">{calc.icon}</div>
          <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary-600 transition-colors mb-1.5">
            {calc.title}
          </h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            {calc.desc}
          </p>
          <div class="mt-4 flex items-center text-primary-600 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
            เปิดเครื่องคำนวณ
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Related Articles -->
  {category.articles.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-5">
        บทความที่เกี่ยวข้อง
      </h2>
      <div class="space-y-4">
        {category.articles.map((article) => (
          <a
            href={`/บทความ/${article.slug}/`}
            class="block bg-white rounded-lg shadow-sm border border-gray-200 p-5 hover:shadow-md hover:border-primary-200 transition-all group"
          >
            <h3 class="text-base font-bold text-gray-900 group-hover:text-primary-600 transition-colors mb-1.5">
              {article.title}
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              {article.description}
            </p>
            <span class="inline-flex items-center text-sm text-primary-600 font-medium mt-2">
              อ่านบทความ
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Browse Other Categories -->
  <section class="mb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">
      หมวดหมู่อื่นๆ
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {categories
        .filter((c) => c.slug !== category.slug)
        .map((c) => (
          <a
            href={`/หมวดหมู่/${c.slug}/`}
            class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-center"
          >
            <div class="text-2xl mb-1">{c.icon}</div>
            <div class="text-sm font-medium text-gray-700">{c.name.replace('เครื่องคำนวณ', '').replace('เครื่องมือคำนวณ', '').trim()}</div>
          </a>
        ))}
    </div>
  </section>

  <!-- Back to Homepage -->
  <div class="text-center py-6 border-t border-gray-100">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-primary-600 hover:text-primary-800 font-medium transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      กลับหน้าแรก — ดูเครื่องคำนวณทั้งหมด
    </a>
  </div>
</BaseLayout>
