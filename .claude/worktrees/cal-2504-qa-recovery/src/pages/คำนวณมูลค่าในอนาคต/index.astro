---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณมูลค่าในอนาคต (Future Value) 2569 | Kamnuanlek';
const pageDescription = 'คำนวณมูลค่าเงินในอนาคตจากเงินต้น ออมรายเดือน และอัตราดอกเบี้ยทบต้น';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณมูลค่าในอนาคต/`;

const faqData = [
  {
    question: 'มูลค่าในอนาคต (Future Value) คืออะไร?',
    answer: 'Future Value คือมูลค่าของเงินในอนาคต โดยคำนึงถึงดอกเบี้ยทบต้น เช่น เงิน 100,000 บาทที่ดอกเบี้ย 7% ต่อปี ใน 10 ปีจะมีมูลค่า 196,715 บาท เป็นหลักพื้นฐานของการวางแผนการเงิน',
  },
  {
    question: 'ดอกเบี้ยทบต้นต่างจากดอกเบี้ยธรรมดาอย่างไร?',
    answer: 'ดอกเบี้ยธรรมดาคำนวณจากเงินต้นเดิมตลอด ส่วนดอกเบี้ยทบต้นคำนวณจากเงินต้นรวมดอกเบี้ยที่สะสม ทำให้เงินเติบโตแบบเลขชี้กำลัง ยิ่งเวลานานยิ่งต่างกันมาก',
  },
  {
    question: 'ควรใช้ FV ในการวางแผนอะไรบ้าง?',
    answer: 'ใช้ FV ในการวางแผนเกษียณ กองทุนการศึกษาบุตร เป้าหมายการออมต่างๆ และการประเมินผลตอบแทนการลงทุน ช่วยให้รู้ว่าเงินที่ออมวันนี้จะเพิ่มเป็นเท่าไหร่ในอนาคต',
  },
  {
    question: 'ความถี่ของดอกเบี้ยทบต้นส่งผลอย่างไร?',
    answer: 'ยิ่งทบต้นบ่อย ยิ่งได้รับดอกเบี้ยมากขึ้น ทบต้นรายเดือนให้ผลดีกว่ารายปีที่อัตราเดียวกัน เครื่องคำนวณนี้ใช้ดอกเบี้ยทบต้นรายเดือน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณมูลค่าในอนาคต',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณมูลค่าในอนาคต">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-indigo-100 bg-indigo-50 p-4">
      <p class="text-sm font-semibold text-indigo-700">🔮 คำนวณมูลค่าในอนาคต (Future Value)</p>
      <p class="mt-1 text-sm text-slate-700">สูตร FV = PV(1+r)^n + PMT × [(1+r)^n − 1] ÷ r | ดอกเบี้ยทบต้นรายเดือน</p>
      <p class="mt-1 text-xs font-medium text-indigo-800">เงินวันนี้จะเป็นเท่าไหร่ในอนาคต? คำนวณได้ทันที</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณมูลค่าในอนาคต ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินต้น อัตราดอกเบี้ย ออมต่อเดือน และระยะเวลา เพื่อดูมูลค่าของเงินในอนาคต
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="fv-form" class="space-y-5">
        <p id="fv-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fv-principal" class="mb-1 block text-sm font-medium text-gray-700">เงินต้นเริ่มต้น (บาท)</label>
            <input type="text" id="fv-principal" inputmode="numeric" placeholder="เช่น 100,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">ใส่ 0 ถ้าเริ่มต้นจากศูนย์</p>
          </div>
          <div>
            <label for="fv-monthly" class="mb-1 block text-sm font-medium text-gray-700">ออมเพิ่มต่อเดือน (บาท)</label>
            <input type="text" id="fv-monthly" inputmode="numeric" placeholder="เช่น 5,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">ใส่ 0 ถ้าไม่มีออมเพิ่ม</p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fv-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราผลตอบแทน (% ต่อปี)</label>
            <input type="text" id="fv-rate" inputmode="numeric" placeholder="เช่น 7"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="fv-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="fv-years" class="mb-1 block text-sm font-medium text-gray-700">ระยะเวลา (ปี)</label>
            <input type="text" id="fv-years" inputmode="numeric" placeholder="เช่น 20"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="fv-years-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณมูลค่าในอนาคต
        </button>
      </form>
    </div>

    <div id="fv-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-4">
          <div class="rounded-lg bg-indigo-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">มูลค่าอนาคต</div>
            <div id="res-fv-total" class="text-xl font-bold text-indigo-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินต้นรวม</div>
            <div id="res-fv-principal" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ดอกเบี้ยสะสม</div>
            <div id="res-fv-interest" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-purple-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินเติบโต</div>
            <div id="res-fv-growth" class="text-xl font-bold text-purple-700">-</div>
          </div>
        </div>
        <p id="fv-status" class="rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>FV เงินต้น = PV × (1 + r)^n</li>
        <li>FV เงินออมรายเดือน = PMT × [(1+r)^n − 1] ÷ r</li>
        <li>FV รวม = FV เงินต้น + FV เงินออม</li>
        <li>โดย r = ดอกเบี้ยรายเดือน (% ต่อปี ÷ 12), n = จำนวนเดือน</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#fv-results" />
    <RelatedArticles currentHref="/คำนวณมูลค่าในอนาคต/" />
    <RelatedCalculators currentHref="/คำนวณมูลค่าในอนาคต/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ ผลตอบแทนจริงอาจแตกต่างตามประเภทการลงทุนและสภาวะตลาด
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return 0;
      const n = Number(s);
      return Number.isFinite(n) && n >= 0 ? n : 0;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('fv-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('fv-error').classList.add('hidden');
      ['fv-rate-error','fv-years-error'].forEach(id => setErr(id, ''));

      const pv = parseNum(document.getElementById('fv-principal').value);
      const pmt = parseNum(document.getElementById('fv-monthly').value);
      const annualRate = parseNum(document.getElementById('fv-rate').value);
      const years = parseNum(document.getElementById('fv-years').value);

      let hasError = false;
      if (!annualRate || annualRate <= 0) { setErr('fv-rate-error', 'กรอกอัตราผลตอบแทน'); hasError = true; }
      if (!years || years <= 0) { setErr('fv-years-error', 'กรอกระยะเวลา'); hasError = true; }
      if (pv <= 0 && pmt <= 0) { document.getElementById('fv-error').classList.remove('hidden'); document.getElementById('fv-results').classList.add('hidden'); return; }
      if (hasError) { document.getElementById('fv-error').classList.remove('hidden'); document.getElementById('fv-results').classList.add('hidden'); return; }

      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('future-value-calculator');
      const r = annualRate / 100 / 12;
      const n = years * 12;
      const fvPrincipal = pv * Math.pow(1 + r, n);
      const fvPmt = pmt * (Math.pow(1 + r, n) - 1) / r;
      const fv = fvPrincipal + fvPmt;
      const totalPrincipal = pv + pmt * n;
      const interest = fv - totalPrincipal;
      const growthPct = totalPrincipal > 0 ? (interest / totalPrincipal * 100) : 0;

      setText('res-fv-total', formatMoney(fv));
      setText('res-fv-principal', formatMoney(totalPrincipal));
      setText('res-fv-interest', formatMoney(interest));
      setText('res-fv-growth', `+${growthPct.toFixed(1)}%`);

      const statusEl = document.getElementById('fv-status');
      statusEl.className = 'rounded-lg bg-indigo-50 p-3 text-sm font-medium text-indigo-800 border border-indigo-200';
      statusEl.textContent = `เงิน ${formatMoney(totalPrincipal)} ที่ดอกเบี้ย ${annualRate}%/ปี ใน ${years} ปีจะเติบโตเป็น ${formatMoney(fv)} (ดอกเบี้ยสะสม ${formatMoney(interest)})`;

      document.getElementById('fv-results').classList.remove('hidden');
      document.getElementById('fv-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('future-value-calculator');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('future-value-calculator');
    });
  </script>
</BaseLayout>
