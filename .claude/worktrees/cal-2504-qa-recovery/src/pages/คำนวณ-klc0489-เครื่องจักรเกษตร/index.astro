---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าเครื่องจักรและอุปกรณ์การเกษตร | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนเครื่องจักรเกษตร รถไถ รถเกี่ยว ค่าเช่าเครื่องจักร ค่าเสื่อมราคา ต้นทุนต่อไร่';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0489-เครื่องจักรเกษตร/`;
const faqData = [
  { question: 'ซื้อหรือเช่าเครื่องจักรการเกษตรดีกว่ากัน?', answer: 'เช่าดีกว่าถ้าใช้งานน้อยกว่า 50 วัน/ปี ซื้อดีกว่าถ้าใช้งานมากกว่า 100 วัน/ปี หรือมีพื้นที่มากกว่า 50 ไร่ คำนวณจากค่าเช่าสะสม vs ค่าเสื่อมราคา' },
  { question: 'รถไถนา 4WD ราคาเท่าไหร่?', answer: 'รถไถนา 4WD ขนาด 35-45 แรงม้า ราคา 400,000-700,000 บาท พร้อมอุปกรณ์ต่อพ่วง รถไถเดินตาม 30,000-80,000 บาท อายุการใช้งาน 10-15 ปี' },
  { question: 'ค่าซ่อมบำรุงเครื่องจักรเกษตรเฉลี่ยเท่าไหร่?', answer: 'ค่าซ่อมบำรุงเฉลี่ย 5-10% ของมูลค่าเครื่องจักรต่อปี เปลี่ยนน้ำมันทุก 100-200 ชั่วโมง อะไหล่สำคัญ เช่น ใบมีดไถ สายพาน กรองอากาศ ควรสต็อกไว้' },
  { question: 'โดรนการเกษตรคืนทุนได้ไหม?', answer: 'โดรนพ่นสารเกษตรราคา 150,000-400,000 บาท รับจ้างพ่นยา 200-400 บาท/ไร่ ถ้าพ่น 5-10 ไร่/วัน 200 วัน/ปี รายได้ 200,000-800,000 บาท/ปี คืนทุน 1-2 ปี' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเครื่องจักรและอุปกรณ์การเกษตร">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนเครื่องจักรการเกษตร</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าเสื่อมราคาและต้นทุนเครื่องจักรต่อฤดูกาล</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="machine_value" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าเครื่องจักร (บาท)</label><input type="text" id="machine_value" inputmode="decimal" placeholder="เช่น 500000" value="500000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="machine_life" class="block text-sm font-medium text-gray-700 mb-1">อายุการใช้งาน (ปี)</label><input type="number" id="machine_life" min="1" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="machine_fuel_year" class="block text-sm font-medium text-gray-700 mb-1">ค่าน้ำมันเชื้อเพลิงต่อปี (บาท)</label><input type="text" id="machine_fuel_year" inputmode="decimal" placeholder="เช่น 30000" value="30000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="machine_repair_year" class="block text-sm font-medium text-gray-700 mb-1">ค่าซ่อมบำรุงต่อปี (บาท)</label><input type="text" id="machine_repair_year" inputmode="decimal" placeholder="เช่น 25000" value="25000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ค่าเสื่อมราคาต่อปี</p><p id="depreciation_year" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนเครื่องจักรรวม/ปี</p><p id="machine_annual_cost" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const value = parseFloat((document.getElementById('machine_value') as HTMLInputElement).value) || 0;
      const life = parseFloat((document.getElementById('machine_life') as HTMLInputElement).value) || 1;
      const fuel = parseFloat((document.getElementById('machine_fuel_year') as HTMLInputElement).value) || 0;
      const repair = parseFloat((document.getElementById('machine_repair_year') as HTMLInputElement).value) || 0;
      const depreciation = value / life;
      const annualCost = depreciation + fuel + repair;
      (document.getElementById('depreciation_year') as HTMLElement).textContent = Math.round(depreciation).toLocaleString('th-TH') + ' บาท/ปี';
      (document.getElementById('machine_annual_cost') as HTMLElement).textContent = Math.round(annualCost).toLocaleString('th-TH') + ' บาท/ปี';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('farm-machinery-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
