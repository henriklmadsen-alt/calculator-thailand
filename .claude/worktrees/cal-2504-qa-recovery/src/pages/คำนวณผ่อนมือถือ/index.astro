  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function hasInvalidNumber(v: string): boolean {
      const normalized = v.replace(/,/g, '').trim();
      return normalized !== '' && Number.isNaN(Number(normalized));
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('phone-form') as HTMLFormElement;
    const submitBtn = document.getElementById('phone-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('phone-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const nextActionCard = document.getElementById('phone-next-action') as HTMLElement;
    const priceInput = document.getElementById('phone-price') as HTMLInputElement;
    const downInput = document.getElementById('down-payment') as HTMLInputElement;
    const carrierFields = document.getElementById('carrier-fields') as HTMLElement;
    const creditFields = document.getElementById('credit-fields') as HTMLElement;
    const carrierResult = document.getElementById('carrier-result') as HTMLElement;
    let hasTrackedStart = false;

    function getSelectedPlan(): string {
      return (document.querySelector('input[name="plan-type"]:checked') as HTMLInputElement)?.value || 'zero';
    }

    // Toggle plan-specific fields
    document.querySelectorAll('input[name="plan-type"]').forEach((radio) => {
      radio.addEventListener('change', () => {
        const plan = getSelectedPlan();
        carrierFields.classList.toggle('hidden', plan !== 'carrier');
        creditFields.classList.toggle('hidden', plan !== 'credit');
        updateSubmitState();
      });
    });

    function setFieldError(elementId: string, message: string) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearFieldError(elementId: string) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      clearFieldError('phone-price-error');
      clearFieldError('cc-interest-error');
      formError.classList.add('hidden');
    }

    function updateSubmitState() {
      const price = parseNum(priceInput.value);
      const plan = getSelectedPlan();
      let ready = price > 0;
      if (plan === 'credit') {
        const rate = parseFloat((document.getElementById('cc-interest') as HTMLInputElement).value.replace(/,/g, '')) || 0;
        ready = ready && rate > 0;
      }
      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณทันที' : 'กรอกข้อมูลให้ครบ';
      submitBtn.classList.toggle('opacity-70', !ready);
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
    }

    function updateFinancePreview() {
      const price = parseNum(priceInput.value);
      const down = parseNum(downInput.value);
      const preview = document.getElementById('finance-preview') as HTMLElement;
      if (price > 0) {
        const finance = Math.max(0, price - down);
        (document.getElementById('finance-text') as HTMLElement).textContent = fmt(finance);
        preview.classList.remove('hidden');
      } else {
        preview.classList.add('hidden');
      }
    }

    priceInput.addEventListener('input', () => {
      clearFieldError('phone-price-error');
      formError.classList.add('hidden');
      updateSubmitState();
      updateFinancePreview();
    });
    downInput.addEventListener('input', updateFinancePreview);
    document.getElementById('cc-interest')?.addEventListener('input', () => {
      clearFieldError('cc-interest-error');
      formError.classList.add('hidden');
      updateSubmitState();
    });
    updateSubmitState();

    form.addEventListener('input', () => {
      if (!hasTrackedStart) {
        trackCalculatorStart('phone');
        hasTrackedStart = true;
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearValidation();

      const plan = getSelectedPlan();
      const phonePrice = parseNum(priceInput.value);
      const downPayment = Math.min(parseNum(downInput.value), phonePrice);
      const termMonths = parseInt((document.getElementById('term-months') as HTMLSelectElement).value) || 10;

      // Validate price
      if (hasInvalidNumber(priceInput.value)) {
        formError.classList.remove('hidden');
        setFieldError('phone-price-error', 'รูปแบบข้อมูลไม่ถูกต้อง');
        priceInput.focus();
        return;
      }
      if (phonePrice <= 0) {
        formError.classList.remove('hidden');
        setFieldError('phone-price-error', 'กรุณากรอกราคามือถือมากกว่า 0');
        priceInput.focus();
        return;
      }

      // Validate credit interest
      let monthlyRate = 0;
      if (plan === 'credit') {
        const ccInput = document.getElementById('cc-interest') as HTMLInputElement;
        if (hasInvalidNumber(ccInput.value)) {
          formError.classList.remove('hidden');
          setFieldError('cc-interest-error', 'รูปแบบข้อมูลไม่ถูกต้อง');
          ccInput.focus();
          return;
        }
        monthlyRate = parseFloat(ccInput.value.replace(/,/g, '')) || 0;
        if (monthlyRate <= 0) {
          formError.classList.remove('hidden');
          setFieldError('cc-interest-error', 'กรุณากรอกอัตราดอกเบี้ยมากกว่า 0');
          ccInput.focus();
          return;
        }
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      if (!hasTrackedStart) {
        trackCalculatorStart('phone');
        hasTrackedStart = true;
      }

      const financeAmount = phonePrice - downPayment;

      // Calculate based on plan type
      let totalInterest = 0;
      let monthlyPayment = 0;
      let carrierMonthly = 0;

      if (plan === 'zero') {
        // 0% campaign: no interest
        totalInterest = 0;
        monthlyPayment = termMonths > 0 ? financeAmount / termMonths : 0;
      } else if (plan === 'carrier') {
        // Carrier plan: 0% on device + monthly package
        totalInterest = 0;
        monthlyPayment = termMonths > 0 ? financeAmount / termMonths : 0;
        carrierMonthly = parseNum((document.getElementById('carrier-monthly') as HTMLInputElement).value);
      } else {
        // Credit card: flat rate per month
        totalInterest = financeAmount * (monthlyRate / 100) * termMonths;
        const totalPaid = financeAmount + totalInterest;
        monthlyPayment = termMonths > 0 ? totalPaid / termMonths : 0;
      }

      const totalPaid = financeAmount + totalInterest;
      const totalCost = downPayment + totalPaid;

      // Update summary cards
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthlyPayment) + ' บาท';
      (document.getElementById('res-down') as HTMLElement).textContent = fmt(downPayment) + ' บาท';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(totalCost) + ' บาท';

      // Carrier totals
      if (plan === 'carrier') {
        const carrierTotal = carrierMonthly * termMonths;
        const grandTotal = totalCost + carrierTotal;
        (document.getElementById('res-carrier-total') as HTMLElement).textContent = fmt(carrierTotal) + ' บาท';
        (document.getElementById('res-grand-total') as HTMLElement).textContent = fmt(grandTotal) + ' บาท';
        carrierResult.classList.remove('hidden');
      } else {
        carrierResult.classList.add('hidden');
      }

      // Detail rows
      (document.getElementById('res-price') as HTMLElement).textContent = fmt(phonePrice) + ' บาท';
      (document.getElementById('res-down-detail') as HTMLElement).textContent = fmt(downPayment) + ' บาท';
      (document.getElementById('res-finance') as HTMLElement).textContent = fmt(financeAmount) + ' บาท';
      (document.getElementById('res-term') as HTMLElement).textContent = termMonths + ' เดือน';
      (document.getElementById('res-interest-detail') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total-paid') as HTMLElement).textContent = fmt(totalPaid) + ' บาท';

      // Rate display
      const rateRow = document.getElementById('row-rate') as HTMLElement;
      const rateText = document.getElementById('res-rate') as HTMLElement;
      if (plan === 'credit') {
        rateText.textContent = monthlyRate.toFixed(2) + '% ต่อเดือน (' + (monthlyRate * 12).toFixed(2) + '% ต่อปี)';
        rateRow.classList.remove('hidden');
      } else {
        rateText.textContent = '0% (ไม่มีดอกเบี้ย)';
        rateRow.classList.remove('hidden');
      }

      // Payment schedule table
      const tbody = document.getElementById('schedule-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';

      let balance = financeAmount;
      const monthlyPrincipal = termMonths > 0 ? financeAmount / termMonths : 0;
      const monthlyInterestAmt = termMonths > 0 ? totalInterest / termMonths : 0;

      for (let m = 1; m <= termMonths; m++) {
        balance = Math.max(0, balance - monthlyPrincipal);
        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';
        tr.innerHTML = `
          <td class="py-2 pr-2 text-gray-600">${m}</td>
          <td class="py-2 pr-2 text-right">${fmt(monthlyPayment)}</td>
          <td class="py-2 pr-2 text-right">${fmt(monthlyPrincipal)}</td>
          <td class="py-2 pr-2 text-right">${fmt(monthlyInterestAmt)}</td>
          <td class="py-2 text-right">${fmt(balance)}</td>
        `;
        tbody.appendChild(tr);
      }

      resultsDiv.classList.remove('hidden');
      nextActionCard.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('phone');
      trackCalculatorUsed('phone');
    });

    document.querySelectorAll('[data-next-action-link]').forEach((link) => {
      link.addEventListener('click', () => {
        if (typeof window.gtag === 'function') {
          const href = (link as HTMLAnchorElement).getAttribute('href') || '';
          window.gtag('event', 'next_action_click', {
            calculator: 'phone',
            target_href: href,
          });
        }
      });
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('phone');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
