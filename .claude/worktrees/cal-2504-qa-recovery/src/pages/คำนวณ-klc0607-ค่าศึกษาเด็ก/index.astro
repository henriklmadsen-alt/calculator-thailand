---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าศึกษาเด็ก | Kamnuanlek';
const pageDescription = 'คำนวณค่าอุดหนุนการศึกษา ค่าเรียน ทุนการศึกษา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0607-ค่าศึกษาเด็ก/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าศึกษาเด็ก">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าศึกษาเด็ก</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณเงินออมเพื่อศึกษา ค่าเรียน ทุนการศึกษารายปี</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="target_amount" class="block text-sm font-medium text-gray-700 mb-1">เป้าหมายการศึกษา (บาท)</label><input type="text" id="target_amount" inputmode="decimal" placeholder="เช่น 500000" value="500000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="years" class="block text-sm font-medium text-gray-700 mb-1">จำนวนปีที่เก็บ (ปี)</label><input type="number" id="years" min="1" max="18" placeholder="เช่น 12" value="12" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราผลตอบแทน (%/ปี)</label><input type="text" id="rate" inputmode="decimal" placeholder="เช่น 3.5" value="3.5" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3">
            <p class="text-sm text-gray-600">ต้องเก็บต่อเดือน</p>
            <p id="monthly" class="font-bold">-</p>
          </div>
          <div class="bg-green-50 rounded p-3">
            <p class="text-sm text-gray-600">เก็บรวม (ดอก)</p>
            <p id="total_with_interest" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">ต้องเก็บต่อปี</p>
            <p id="yearly" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ควรเก็บทุนการศึกษาเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">ตามแนวปฏิบัติ ควรเตรียมงบประมาณ 500,000-1,000,000 บาท สำหรับการศึกษาครบชั้น</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ผลตอบแทนเฉลี่ยคือเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">ออมทรัพย์: 1.5-2% พันธบัตร: 2-3% กองทุน: 3-6% หุ้น: 6-10% (ตามความเสี่ยง)</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ได้ลดหย่อนภาษีหรือไม่?</h3>
            <p class="text-gray-600 text-sm">ใช่ บางประกาศกำหนดว่าเงินประกันการศึกษา ลดหย่อนได้ หรือหากเป็นกองทุนสำรอง ลดหย่อนได้เต็ม</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const targetAmount = parseFloat((document.getElementById('target_amount') as HTMLInputElement).value) || 0;
      const years = parseInt((document.getElementById('years') as HTMLInputElement).value) || 12;
      const rate = parseFloat((document.getElementById('rate') as HTMLInputElement).value) || 3.5;

      const months = years * 12;
      const monthlyRate = rate / 100 / 12;
      const monthlyPayment = targetAmount / (((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate) * (1 + monthlyRate));
      const yearlyPayment = monthlyPayment * 12;
      const totalWithInterest = monthlyPayment * months;

      (document.getElementById('monthly') as HTMLElement).textContent = monthlyPayment.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('yearly') as HTMLElement).textContent = yearlyPayment.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('total_with_interest') as HTMLElement).textContent = totalWithInterest.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('education-fund');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
