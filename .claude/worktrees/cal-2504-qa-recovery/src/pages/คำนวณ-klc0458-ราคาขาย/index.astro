---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณราคาขายเพื่อกำไร | Kamnuanlek';
const pageDescription = 'คำนวณราคาขายสินค้าเพื่อให้ได้กำไรตามเป้า Cost-Plus Pricing สำหรับธุรกิจไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0458-ราคาขาย/`;
const faqData = [
  { question: 'กำหนดราคาขายอย่างไรให้เหมาะสม?', answer: 'วิธีง่ายคือ Cost-Plus: ราคาขาย = ต้นทุน × (1 + อัตรากำไรที่ต้องการ) แต่ควรพิจารณาราคาตลาด คู่แข่ง และมูลค่าที่ลูกค้ารับรู้ด้วย' },
  { question: 'Markup กับ Margin ต่างกันอย่างไร?', answer: 'Markup คำนวณจากต้นทุน (กำไร/ต้นทุน×100%) Margin คำนวณจากราคาขาย (กำไร/ราคาขาย×100%) Markup 50% = Margin 33.3%' },
  { question: 'ราคาจิตวิทยาคืออะไร?', answer: 'ราคาจิตวิทยา เช่น 99 บาทแทน 100 บาท หรือ 499 บาทแทน 500 บาท ทำให้รู้สึกถูกกว่า เหมาะกับสินค้าอุปโภคบริโภค' },
  { question: 'ควรขึ้นราคาขายเมื่อไหร่?', answer: 'ขึ้นราคาเมื่อ ต้นทุนสูงขึ้น อุปสงค์แข็งแกร่ง คู่แข่งขึ้นราคา เพิ่มมูลค่าสินค้า หรือเมื่อกำไรขั้นต้นต่ำเกินไป' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณราคาขายเพื่อกำไร">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณราคาขายเพื่อกำไร</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณราคาขายที่เหมาะสมเพื่อให้ได้กำไรตามเป้าหมาย</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="cost_per_unit" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนต่อหน่วย (บาท)</label><input type="text" id="cost_per_unit" inputmode="decimal" placeholder="เช่น 200" value="200" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="target_margin" class="block text-sm font-medium text-gray-700 mb-1">อัตรากำไรที่ต้องการ (%)</label><input type="number" id="target_margin" min="0" max="500" placeholder="เช่น 40" value="40" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="vat_included" class="block text-sm font-medium text-gray-700 mb-1">รวม VAT 7%</label><select id="vat_included" class="w-full px-3 py-2 border border-gray-300 rounded-md"><option value="no">ไม่รวม VAT</option><option value="yes">รวม VAT 7%</option></select></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ราคาขายก่อน VAT</p><p id="price_ex_vat" class="font-bold">-</p></div>
          <div class="bg-indigo-50 rounded p-3"><p class="text-sm text-gray-600">ราคาขายรวม VAT</p><p id="price_inc_vat" class="font-bold text-lg">-</p></div>
          <div class="bg-blue-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">กำไรต่อหน่วย</p><p id="profit_per_unit" class="font-bold">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const cost = parseFloat((document.getElementById('cost_per_unit') as HTMLInputElement).value) || 0;
      const margin = parseFloat((document.getElementById('target_margin') as HTMLInputElement).value) || 0;
      const vatIncluded = (document.getElementById('vat_included') as HTMLSelectElement).value;
      const priceExVat = cost / (1 - margin / 100);
      const priceIncVat = priceExVat * 1.07;
      const profitPerUnit = priceExVat - cost;
      (document.getElementById('price_ex_vat') as HTMLElement).textContent = priceExVat.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('price_inc_vat') as HTMLElement).textContent = (vatIncluded === 'yes' ? priceIncVat : priceExVat).toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('profit_per_unit') as HTMLElement).textContent = profitPerUnit.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('selling-price');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
