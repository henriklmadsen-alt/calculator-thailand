---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณรายได้จากการขาย | Kamnuanlek';
const pageDescription = 'คำนวณรายได้จากการขาย Sales Revenue Projection ประมาณการรายได้ตามยอดขายและราคา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0470-รายได้ขาย/`;
const faqData = [
  { question: 'ประมาณการรายได้ขายทำอย่างไร?', answer: 'ประมาณการรายได้ = จำนวนลูกค้า × ความถี่ซื้อ × มูลค่าต่อครั้ง หรือ ยอดขายหน่วย × ราคาขายเฉลี่ย พิจารณา Seasonality และแนวโน้มตลาด' },
  { question: 'Sales Forecast สำคัญอย่างไร?', answer: 'Sales Forecast ช่วยวางแผนสต็อก กำลังผลิต แรงงาน และกระแสเงินสด ธุรกิจที่ Forecast แม่นยำสามารถตัดสินใจได้ดีกว่าและลดต้นทุนได้มาก' },
  { question: 'ยอดขายเฉลี่ยต่อลูกค้า (AOV) สำคัญไหม?', answer: 'AOV (Average Order Value) สำคัญมาก เพิ่ม AOV ด้วย Upsell, Bundle, Free Shipping Threshold เพิ่ม AOV 20% โดยไม่เพิ่มลูกค้าใหม่ คือกำไรเพิ่มทันที' },
  { question: 'ช่องทางขายไหนให้รายได้ดีสุดสำหรับ SME ไทย?', answer: 'SME ไทย ช่องทางออนไลน์ Lazada, Shopee, TikTok Shop ยังเติบโตสูง โซเชียลมีเดีย LINE OA เหมาะตลาด B2C ราคาปลีก การขายตรงให้ Margin ดีสุด' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณรายได้จากการขาย">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณรายได้จากการขาย</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">ประมาณการรายได้ขายตามจำนวนหน่วยและราคา</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="units_sold" class="block text-sm font-medium text-gray-700 mb-1">จำนวนหน่วยขายต่อเดือน</label><input type="number" id="units_sold" min="1" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="avg_price" class="block text-sm font-medium text-gray-700 mb-1">ราคาขายเฉลี่ยต่อหน่วย (บาท)</label><input type="text" id="avg_price" inputmode="decimal" placeholder="เช่น 350" value="350" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="growth_rate_sales" class="block text-sm font-medium text-gray-700 mb-1">อัตราเติบโต MoM (%)</label><input type="number" id="growth_rate_sales" min="-20" max="50" step="0.5" placeholder="เช่น 5" value="5" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">รายได้เดือนนี้</p><p id="curr_revenue_sales" class="font-bold">-</p></div>
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">รายได้เดือนหน้า (คาด)</p><p id="next_revenue_sales" class="font-bold">-</p></div>
          <div class="bg-indigo-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">รายได้ต่อปี (ประมาณการ)</p><p id="annual_revenue_sales" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const units = parseInt((document.getElementById('units_sold') as HTMLInputElement).value) || 0;
      const price = parseFloat((document.getElementById('avg_price') as HTMLInputElement).value) || 0;
      const growth = parseFloat((document.getElementById('growth_rate_sales') as HTMLInputElement).value) || 0;
      const currRevenue = units * price;
      const nextRevenue = currRevenue * (1 + growth / 100);
      const annualRevenue = currRevenue * 12;
      (document.getElementById('curr_revenue_sales') as HTMLElement).textContent = currRevenue.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('next_revenue_sales') as HTMLElement).textContent = Math.round(nextRevenue).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('annual_revenue_sales') as HTMLElement).textContent = annualRevenue.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('sales-revenue-projection');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
