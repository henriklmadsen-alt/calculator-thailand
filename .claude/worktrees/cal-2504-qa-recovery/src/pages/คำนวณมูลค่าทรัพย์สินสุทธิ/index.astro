---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณมูลค่าทรัพย์สินสุทธิ (Net Worth) 2569 | รวมสินทรัพย์หักหนี้สิน | Kamnuanlek';
const pageDescription = 'คำนวณ net worth มูลค่าทรัพย์สินสุทธิจากสินทรัพย์ทุกประเภท หักหนี้สิน พร้อมสรุปสุขภาพทางการเงินและ debt-to-asset ratio อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณมูลค่าทรัพย์สินสุทธิ/`;

const faqData = [
  {
    question: 'Net Worth คืออะไร และคำนวณอย่างไร?',
    answer: 'Net Worth หรือทรัพย์สินสุทธิ คำนวณจาก สินทรัพย์ทั้งหมด (Assets) ลบด้วย หนี้สินทั้งหมด (Liabilities) สินทรัพย์รวมทุกอย่างที่คุณเป็นเจ้าของมีมูลค่า เช่น เงินสด บ้าน รถ ลงทุน ส่วนหนี้สินคือทุกอย่างที่ต้องชำระคืน',
  },
  {
    question: 'Debt-to-Asset Ratio ที่ดีควรอยู่ที่เท่าไร?',
    answer: 'Debt-to-Asset Ratio ต่ำกว่า 36% ถือว่าดี แสดงว่าทรัพย์สินส่วนใหญ่ปลอดหนี้ 37-50% ควรระวัง 51-75% ควรลดหนี้ลงอย่างจริงจัง มากกว่า 75% มีความเสี่ยงสูงมาก ควรปรึกษาที่ปรึกษาการเงิน',
  },
  {
    question: 'ควรติดตาม Net Worth บ่อยแค่ไหน?',
    answer: 'ควรคำนวณ Net Worth อย่างน้อยปีละ 2 ครั้ง หรือทุกไตรมาสหากต้องการติดตามอย่างใกล้ชิด การติดตามสม่ำเสมอช่วยให้รู้ความก้าวหน้าทางการเงิน และตัดสินใจปรับแผนได้ทันเวลา',
  },
  {
    question: 'ทรัพย์สินประเภทไหนควรรวมใน Net Worth?',
    answer: 'รวมทรัพย์สินที่มีมูลค่าทางการเงิน: เงินสดและเงินฝาก กองทุนและพอร์ตหุ้น อสังหาริมทรัพย์ (ราคาตลาด) รถยนต์ ทองคำ กองทุนประกันชีวิต/กบข./กองทุนสำรองเลี้ยงชีพ แต่ไม่ควรรวมทรัพย์สินส่วนตัวที่ไม่มีมูลค่าตลาด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณมูลค่าทรัพย์สินสุทธิ (Net Worth)',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณมูลค่าทรัพย์สินสุทธิ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณมูลค่าทรัพย์สินสุทธิ (Net Worth) 2569 — รวมสินทรัพย์ หักหนี้สิน
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกมูลค่าสินทรัพย์และหนี้สินทุกประเภท ระบบจะคำนวณ Net Worth พร้อม Debt-to-Asset Ratio และสรุปสุขภาพทางการเงินของคุณ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="nw-form" class="space-y-6">
        <p id="nw-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลสินทรัพย์หรือหนี้สินอย่างน้อย 1 รายการ
        </p>

        <!-- Assets Section -->
        <div>
          <h2 class="text-base font-semibold text-gray-900 mb-3 flex items-center gap-2">
            <span class="inline-block w-3 h-3 rounded-full bg-green-500"></span>
            สินทรัพย์ (Assets)
          </h2>
          <div class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
              <label class="block text-sm text-gray-700">เงินสด/เงินฝากธนาคาร (บาท)</label>
              <input type="text" id="a-cash" inputmode="numeric" placeholder="0" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base text-right" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <label class="block text-sm text-gray-700">พอร์ตลงทุน (หุ้น/กองทุน) (บาท)</label>
              <input type="text" id="a-invest" inputmode="numeric" placeholder="0" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base text-right" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <label class="block text-sm text-gray-700">อสังหาริมทรัพย์ (ราคาตลาด) (บาท)</label>
              <input type="text" id="a-property" inputmode="numeric" placeholder="0" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base text-right" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <label class="block text-sm text-gray-700">รถยนต์ (ราคาตลาด) (บาท)</label>
              <input type="text" id="a-car" inputmode="numeric" placeholder="0" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base text-right" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <label class="block text-sm text-gray-700">ทองคำ/สินทรัพย์อื่น (บาท)</label>
              <input type="text" id="a-other" inputmode="numeric" placeholder="0" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base text-right" />
            </div>
            <div class="flex justify-between items-center py-2 border-t border-gray-200">
              <span class="text-sm font-semibold text-gray-700">สินทรัพย์รวม</span>
              <span id="nw-live-assets" class="text-sm font-bold text-green-700">0 บาท</span>
            </div>
          </div>
        </div>

        <!-- Liabilities Section -->
        <div>
          <h2 class="text-base font-semibold text-gray-900 mb-3 flex items-center gap-2">
            <span class="inline-block w-3 h-3 rounded-full bg-red-500"></span>
            หนี้สิน (Liabilities)
          </h2>
          <div class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
              <label class="block text-sm text-gray-700">หนี้บ้าน/สินเชื่อที่อยู่อาศัย (บาท)</label>
              <input type="text" id="l-home" inputmode="numeric" placeholder="0" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base text-right" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <label class="block text-sm text-gray-700">หนี้รถยนต์ (บาท)</label>
              <input type="text" id="l-car" inputmode="numeric" placeholder="0" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base text-right" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <label class="block text-sm text-gray-700">หนี้บัตรเครดิต (บาท)</label>
              <input type="text" id="l-credit" inputmode="numeric" placeholder="0" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base text-right" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <label class="block text-sm text-gray-700">หนี้อื่นๆ (บาท)</label>
              <input type="text" id="l-other" inputmode="numeric" placeholder="0" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base text-right" />
            </div>
            <div class="flex justify-between items-center py-2 border-t border-gray-200">
              <span class="text-sm font-semibold text-gray-700">หนี้สินรวม</span>
              <span id="nw-live-liabilities" class="text-sm font-bold text-red-600">0 บาท</span>
            </div>
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">สรุปสุขภาพทางการเงิน</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ทรัพย์สินรวม</div>
            <div id="nw-res-assets" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">หนี้สินรวม</div>
            <div id="nw-res-liabilities" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div id="nw-res-card" class="rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Net Worth</div>
            <div id="nw-res-networth" class="text-xl font-bold">-</div>
          </div>
          <div id="nw-ratio-card" class="rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Debt-to-Asset Ratio</div>
            <div id="nw-res-ratio" class="text-xl font-bold">-</div>
          </div>
        </div>

        <div id="nw-health-card" class="rounded-lg p-4">
          <div class="font-semibold text-base mb-1" id="nw-health-title">-</div>
          <div class="text-sm" id="nw-health-desc">-</div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณ Net Worth มูลค่าทรัพย์สินสุทธิ</h2>
      <p>
        Net Worth คือตัวชี้วัดสุขภาพทางการเงินที่สำคัญที่สุด บอกให้รู้ว่าคุณมีทรัพย์สินสุทธิเท่าไรหลังหักหนี้สินทั้งหมด
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณ Net Worth</h3>
      <p>
        Net Worth = ทรัพย์สินรวม − หนี้สินรวม<br />
        Debt-to-Asset Ratio = (หนี้สินรวม ÷ ทรัพย์สินรวม) × 100%
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">การประเมินสุขภาพทางการเงิน</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>Debt Ratio &lt; 36%:</strong> สุขภาพการเงินดีเยี่ยม</li>
        <li><strong>Debt Ratio 36-50%:</strong> อยู่ในเกณฑ์ปกติ ควรระวัง</li>
        <li><strong>Debt Ratio 51-75%:</strong> ควรเร่งลดหนี้</li>
        <li><strong>Debt Ratio &gt; 75%:</strong> ความเสี่ยงสูง ต้องปรับแผนการเงินด่วน</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณมูลค่าทรัพย์สินสุทธิ/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางการเงิน มูลค่าสินทรัพย์จริงอาจแตกต่างจากที่กรอก
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const assetIds = ['a-cash', 'a-invest', 'a-property', 'a-car', 'a-other'];
    const liabilityIds = ['l-home', 'l-car', 'l-credit', 'l-other'];

    function sumFields(ids: string[]): number {
      return ids.reduce((sum, id) => {
        const el = document.getElementById(id) as HTMLInputElement;
        return sum + (el ? parseNum(el.value) : 0);
      }, 0);
    }

    const liveAssets = document.getElementById('nw-live-assets') as HTMLElement;
    const liveLiabilities = document.getElementById('nw-live-liabilities') as HTMLElement;

    function updateLive() {
      liveAssets.textContent = fmt(sumFields(assetIds)) + ' บาท';
      liveLiabilities.textContent = fmt(sumFields(liabilityIds)) + ' บาท';
    }

    [...assetIds, ...liabilityIds].forEach((id) => {
      const el = document.getElementById(id);
      if (el) el.addEventListener('input', updateLive);
    });

    const form = document.getElementById('nw-form') as HTMLFormElement;
    const formError = document.getElementById('nw-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const totalAssets = sumFields(assetIds);
      const totalLiabilities = sumFields(liabilityIds);

      if (totalAssets <= 0 && totalLiabilities <= 0) {
        formError.classList.remove('hidden');
        return;
      }

      trackCalculatorStart('net-worth');

      const netWorth = totalAssets - totalLiabilities;
      const debtRatio = totalAssets > 0 ? (totalLiabilities / totalAssets) * 100 : 0;

      (document.getElementById('nw-res-assets') as HTMLElement).textContent = fmt(totalAssets) + ' บาท';
      (document.getElementById('nw-res-liabilities') as HTMLElement).textContent = fmt(totalLiabilities) + ' บาท';
      (document.getElementById('nw-res-networth') as HTMLElement).textContent = fmt(netWorth) + ' บาท';
      (document.getElementById('nw-res-ratio') as HTMLElement).textContent = debtRatio.toFixed(1) + '%';

      // Net Worth card color
      const nwCard = document.getElementById('nw-res-card') as HTMLElement;
      const nwEl = document.getElementById('nw-res-networth') as HTMLElement;
      if (netWorth >= 0) {
        nwCard.className = 'bg-primary-50 rounded-lg p-4 text-center';
        nwEl.className = 'text-xl font-bold text-primary-700';
      } else {
        nwCard.className = 'bg-red-50 rounded-lg p-4 text-center';
        nwEl.className = 'text-xl font-bold text-red-600';
      }

      // Debt ratio card and health
      const ratioCard = document.getElementById('nw-ratio-card') as HTMLElement;
      const ratioEl = document.getElementById('nw-res-ratio') as HTMLElement;
      const healthCard = document.getElementById('nw-health-card') as HTMLElement;
      const healthTitle = document.getElementById('nw-health-title') as HTMLElement;
      const healthDesc = document.getElementById('nw-health-desc') as HTMLElement;

      if (debtRatio <= 36) {
        ratioCard.className = 'bg-green-50 rounded-lg p-4 text-center';
        ratioEl.className = 'text-xl font-bold text-green-700';
        healthCard.className = 'rounded-lg p-4 bg-green-50 border border-green-200';
        healthTitle.className = 'font-semibold text-base mb-1 text-green-700';
        healthTitle.textContent = 'สุขภาพการเงินดีเยี่ยม';
        healthDesc.className = 'text-sm text-green-600';
        healthDesc.textContent = `Debt-to-Asset Ratio ${debtRatio.toFixed(1)}% ต่ำกว่า 36% สินทรัพย์ส่วนใหญ่ปลอดหนี้ คุณมีฐานะทางการเงินที่แข็งแกร่ง`;
      } else if (debtRatio <= 50) {
        ratioCard.className = 'bg-blue-50 rounded-lg p-4 text-center';
        ratioEl.className = 'text-xl font-bold text-blue-700';
        healthCard.className = 'rounded-lg p-4 bg-blue-50 border border-blue-200';
        healthTitle.className = 'font-semibold text-base mb-1 text-blue-700';
        healthTitle.textContent = 'สุขภาพการเงินอยู่ในเกณฑ์ปกติ';
        healthDesc.className = 'text-sm text-blue-600';
        healthDesc.textContent = `Debt-to-Asset Ratio ${debtRatio.toFixed(1)}% อยู่ในระดับที่ยอมรับได้ แต่ควรวางแผนลดหนี้เพื่อเพิ่ม Net Worth`;
      } else if (debtRatio <= 75) {
        ratioCard.className = 'bg-yellow-50 rounded-lg p-4 text-center';
        ratioEl.className = 'text-xl font-bold text-yellow-700';
        healthCard.className = 'rounded-lg p-4 bg-yellow-50 border border-yellow-200';
        healthTitle.className = 'font-semibold text-base mb-1 text-yellow-700';
        healthTitle.textContent = 'ควรเร่งลดหนี้';
        healthDesc.className = 'text-sm text-yellow-700';
        healthDesc.textContent = `Debt-to-Asset Ratio ${debtRatio.toFixed(1)}% ค่อนข้างสูง ควรลดหนี้อย่างจริงจังและหยุดก่อหนี้ใหม่`;
      } else {
        ratioCard.className = 'bg-red-50 rounded-lg p-4 text-center';
        ratioEl.className = 'text-xl font-bold text-red-600';
        healthCard.className = 'rounded-lg p-4 bg-red-50 border border-red-200';
        healthTitle.className = 'font-semibold text-base mb-1 text-red-700';
        healthTitle.textContent = 'ความเสี่ยงสูงมาก — ต้องปรับแผนการเงินด่วน';
        healthDesc.className = 'text-sm text-red-600';
        healthDesc.textContent = `Debt-to-Asset Ratio ${debtRatio.toFixed(1)}% สูงมาก หนี้สินมากกว่า 75% ของสินทรัพย์ ควรปรึกษาที่ปรึกษาการเงินและวางแผนลดหนี้อย่างเร่งด่วน`;
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('net-worth');
      trackCalculatorUsed('net-worth');
    });
  </script>
</BaseLayout>
