---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าธรรมเนียมพร้อมเพย์ 2569 | โอนฟรีไม่เกิน 5,000 บาท | Kamnuanlek';
const pageDescription = 'คำนวณค่าธรรมเนียมโอนเงินผ่านพร้อมเพย์ เปรียบเทียบกับโอนธนาคารปกติ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าธรรมเนียมพร้อมเพย์/`;

const faqData = [
  {
    question: 'พร้อมเพย์คิดค่าธรรมเนียมเท่าไร?',
    answer: 'ตามนโยบายธนาคารแห่งประเทศไทยปัจจุบัน การโอนเงินผ่านพร้อมเพย์ไม่มีค่าธรรมเนียมทุกยอด ทำให้ประหยัดกว่าการโอนธนาคารแบบปกติมาก',
  },
  {
    question: 'พร้อมเพย์ต่างจากการโอนธนาคารปกติอย่างไร?',
    answer: 'พร้อมเพย์ใช้เลขบัตรประชาชนหรือเบอร์โทรศัพท์แทนเลขบัญชีธนาคาร โอนได้ตลอด 24 ชั่วโมง เงินเข้าทันที และไม่มีค่าธรรมเนียม ส่วนการโอนธนาคารปกติมีค่าธรรมเนียม 10-25 บาทต่อครั้ง',
  },
  {
    question: 'ใช้พร้อมเพย์โอนเงินสูงสุดได้เท่าไรต่อวัน?',
    answer: 'วงเงินโอนพร้อมเพย์ขึ้นอยู่กับธนาคารและระดับการยืนยันตัวตน โดยทั่วไปอยู่ที่ 200,000-500,000 บาทต่อวัน บางธนาคารอาจอนุมัติวงเงินสูงกว่าสำหรับลูกค้าที่ยืนยันตัวตนเต็มรูปแบบ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียมพร้อมเพย์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าธรรมเนียมพร้อมเพย์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณค่าธรรมเนียมพร้อมเพย์ 2569</h1>
    <p class="mb-6 text-gray-600">เปรียบเทียบค่าธรรมเนียมโอนเงินผ่านพร้อมเพย์กับการโอนธนาคารปกติ</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc-form" class="space-y-4">
        <div>
          <label for="transfer-amount" class="mb-1 block text-sm font-medium text-gray-700">ยอดโอน (บาท)</label>
          <input id="transfer-amount" type="text" inputmode="numeric" placeholder="เช่น 5000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="freq" class="mb-1 block text-sm font-medium text-gray-700">ความถี่ต่อเดือน (ครั้ง)</label>
          <input id="freq" type="text" inputmode="numeric" placeholder="เช่น 4" value="4"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการเปรียบเทียบ</h2>
        <div class="mb-4 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="py-2 text-left font-semibold text-gray-700">ช่องทาง</th>
                <th class="py-2 text-right font-semibold text-gray-700">ต่อครั้ง</th>
                <th class="py-2 text-right font-semibold text-gray-700">ต่อเดือน</th>
              </tr>
            </thead>
            <tbody id="res-table" class="divide-y divide-gray-100"></tbody>
          </table>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ประหยัดต่อเดือน</div>
            <div id="res-save-monthly" class="text-3xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ประหยัดต่อปี</div>
            <div id="res-save-yearly" class="text-3xl font-bold text-primary-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณค่าธรรมเนียมพร้อมเพย์/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  function normalFee(amount: number): number {
    if (amount <= 5000) return 10;
    if (amount <= 30000) return 15;
    return 25;
  }

  document.getElementById('calc-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const amount = parseNum((document.getElementById('transfer-amount') as HTMLInputElement).value);
    const freq = parseNum((document.getElementById('freq') as HTMLInputElement).value) || 1;
    if (!amount) return;

    const promptpayFee = 0;
    const normalFeeAmt = normalFee(amount);

    const rows = [
      { name: 'พร้อมเพย์', perTx: promptpayFee, monthly: promptpayFee * freq },
      { name: 'โอนธนาคารปกติ', perTx: normalFeeAmt, monthly: normalFeeAmt * freq },
    ];

    const tbody = document.getElementById('res-table')!;
    tbody.innerHTML = rows.map(r =>
      `<tr><td class="py-2 text-gray-800">${r.name}</td><td class="py-2 text-right text-gray-800">${fmt(r.perTx)}</td><td class="py-2 text-right text-gray-800">${fmt(r.monthly)}</td></tr>`
    ).join('');

    const saveMonthly = normalFeeAmt * freq - promptpayFee * freq;
    document.getElementById('res-save-monthly')!.textContent = fmt(saveMonthly);
    document.getElementById('res-save-yearly')!.textContent = fmt(saveMonthly * 12);
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
