---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณลดหย่อน Easy E-Receipt 2569 | 2 เท่า สูงสุด 50,000 บาท | Kamnuanlek';
const pageDescription = 'คำนวณค่าลดหย่อน Easy E-Receipt 2569 ฟรี ซื้อสินค้ามีใบกำกับภาษีอิเล็กทรอนิกส์ ลดหย่อนได้ 2 เท่า สูงสุด 50,000 บาท เช็กภาษีที่ประหยัดได้ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณลดหย่อน-easy-e-receipt/`;

const faqData = [
  {
    question: 'Easy E-Receipt คืออะไร?',
    answer: 'Easy E-Receipt คือโครงการของรัฐบาลที่ให้สิทธิ์ลดหย่อนภาษี 2 เท่าของยอดซื้อสินค้าหรือบริการที่มีใบกำกับภาษีอิเล็กทรอนิกส์ (e-Tax Invoice) หรือใบรับอิเล็กทรอนิกส์ (e-Receipt) ผ่านระบบ e-Tax Invoice & e-Receipt ของกรมสรรพากร',
  },
  {
    question: 'Easy E-Receipt 2569 ลดหย่อนได้สูงสุดเท่าไร?',
    answer: 'ลดหย่อนได้สูงสุด 50,000 บาท ต่อการจ่ายจริง (ยอดซื้อจริงสูงสุด 50,000 บาท ได้สิทธิ์ลดหย่อน 2 เท่า = 50,000 x 2 = 100,000 บาท) ขึ้นอยู่กับเงื่อนไขโครงการ',
  },
  {
    question: 'ซื้อสินค้าอะไรได้บ้าง?',
    answer: 'สินค้าและบริการทั่วไปที่ผู้ประกอบการออกใบกำกับภาษีอิเล็กทรอนิกส์ ได้แก่ สินค้า OTOP บริการท่องเที่ยว ค่าที่พัก อาหาร หนังสือ สินค้าการศึกษา ฯลฯ ยกเว้นสุรา ยาสูบ เชื้อเพลิง รถยนต์ มอเตอร์ไซค์',
  },
  {
    question: 'ช่วงเวลาที่ใช้ได้คือเมื่อไร?',
    answer: 'โครงการ Easy E-Receipt 2569 ครอบคลุมการซื้อสินค้าตั้งแต่วันที่ 16 มกราคม ถึง 28 กุมภาพันธ์ 2569 (ตรวจสอบประกาศทางการอีกครั้งสำหรับการอัปเดต)',
  },
  {
    question: 'ต้องขอใบกำกับภาษีอิเล็กทรอนิกส์อย่างไร?',
    answer: 'แจ้งผู้ขายว่าต้องการใบกำกับภาษีอิเล็กทรอนิกส์ ผู้ขายจะส่งผ่านระบบ e-Tax Invoice & e-Receipt ของกรมสรรพากร หรือส่งไฟล์ XML/PDF ทางอีเมล สามารถตรวจสอบที่เว็บไซต์กรมสรรพากร',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณลดหย่อน Easy E-Receipt 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณลดหย่อน-easy-e-receipt">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณลดหย่อน Easy E-Receipt ปี 2569 (2026)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าลดหย่อน Easy E-Receipt โครงการรัฐบาล ซื้อสินค้าพร้อมใบกำกับภาษีอิเล็กทรอนิกส์
      ลดหย่อนได้ 2 เท่าของยอดซื้อจริง สูงสุดไม่เกินวงเงินโครงการ
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกยอดซื้อสินค้า/บริการ (e-Tax Invoice)</h2>

      <form id="receipt-form" class="space-y-6">
        <div>
          <label for="purchase-amount" class="block text-sm font-medium text-gray-700 mb-1">
            ยอดซื้อรวม (บาท)
          </label>
          <input
            type="text"
            id="purchase-amount"
            inputmode="numeric"
            placeholder="เช่น 30,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p class="mt-1 text-xs text-gray-500">สูงสุดที่นำมาคำนวณ 50,000 บาท (ลดหย่อนได้ 2 เท่า สูงสุด 100,000 บาท)</p>
        </div>

        <div>
          <label for="marginal-rate" class="block text-sm font-medium text-gray-700 mb-1">
            ฐานภาษีของคุณ (%)
          </label>
          <select
            id="marginal-rate"
            class="w-48 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
          >
            <option value="0.05">5%</option>
            <option value="0.10">10%</option>
            <option value="0.15">15%</option>
            <option value="0.20" selected>20%</option>
            <option value="0.25">25%</option>
            <option value="0.30">30%</option>
            <option value="0.35">35%</option>
          </select>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ Easy E-Receipt</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดซื้อจริง</div>
            <div id="result-purchase" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าลดหย่อนรวม (2x)</div>
            <div id="result-deduction" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประหยัดภาษีโดยประมาณ</div>
            <div id="result-tax-saved" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div id="result-note" class="text-sm text-gray-500 mt-2"></div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">โครงการ Easy E-Receipt 2569 คืออะไร?</h2>
      <p>
        Easy E-Receipt เป็นโครงการของรัฐบาลที่กระตุ้นการใช้จ่ายและส่งเสริมระบบภาษีดิจิทัล
        โดยให้สิทธิ์ลดหย่อนภาษีเงินได้บุคคลธรรมดา <strong>2 เท่า</strong> ของยอดซื้อสินค้าและบริการ
        ที่มีใบกำกับภาษีอิเล็กทรอนิกส์
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สินค้าที่เข้าร่วมโครงการ</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>สินค้าและบริการทั่วไปจากผู้ประกอบการที่ออก e-Tax Invoice ได้</li>
        <li>สินค้า OTOP สินค้าชุมชน</li>
        <li>บริการท่องเที่ยว ค่าที่พักโรงแรม</li>
        <li>ค่าอาหาร ร้านอาหารที่เข้าร่วม</li>
        <li>หนังสือ สื่อการเรียนรู้</li>
      </ul>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สินค้าที่ไม่เข้าร่วม</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>สุรา เบียร์ ไวน์</li>
        <li>ยาสูบ</li>
        <li>น้ำมันเชื้อเพลิง</li>
        <li>รถยนต์ มอเตอร์ไซค์ และเรือ</li>
        <li>ค่าสาธารณูปโภค ค่าน้ำ ค่าไฟ</li>
      </ul>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณลดหย่อน-easy-e-receipt/" />
    <RelatedCalculators currentHref="/คำนวณลดหย่อน-easy-e-receipt/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เงื่อนไขโครงการ Easy E-Receipt
      อาจมีการเปลี่ยนแปลง กรุณาตรวจสอบประกาศทางการจากกรมสรรพากรก่อนใช้งาน
    </div>
  </article>

  <script>
    function parseNumber(value: string): number {
      return Math.max(0, parseFloat(value.replace(/,/g, '')) || 0);
    }

    function formatThai(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(num);
    }

    const form = document.getElementById('receipt-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLElement;
    const MAX_PURCHASE = 50_000;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const purchase = parseNumber((document.getElementById('purchase-amount') as HTMLInputElement).value);
      const rate = parseFloat((document.getElementById('marginal-rate') as HTMLSelectElement).value);

      const cappedPurchase = Math.min(purchase, MAX_PURCHASE);
      const deduction = cappedPurchase * 2;
      const taxSaved = deduction * rate;

      (document.getElementById('result-purchase') as HTMLElement).textContent = `${formatThai(cappedPurchase)} บาท`;
      (document.getElementById('result-deduction') as HTMLElement).textContent = `${formatThai(deduction)} บาท`;
      (document.getElementById('result-tax-saved') as HTMLElement).textContent = `~${formatThai(taxSaved)} บาท`;

      let note = `ยอดซื้อ ${formatThai(cappedPurchase)} บาท × 2 = ลดหย่อน ${formatThai(deduction)} บาท`;
      if (purchase > MAX_PURCHASE) {
        note += ` (ยอดซื้อ ${formatThai(purchase)} บาท เกินวงเงิน จึงคำนวณที่ ${formatThai(MAX_PURCHASE)} บาท)`;
      }
      note += ` ประหยัดภาษีที่อัตรา ${(rate * 100).toFixed(0)}% ประมาณ ${formatThai(taxSaved)} บาท`;
      (document.getElementById('result-note') as HTMLElement).textContent = note;

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('easy_e_receipt');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('easy_e_receipt');
    });

    form.addEventListener('input', () => {
      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('easy_e_receipt');
    }, { once: true });
  </script>
</BaseLayout>
