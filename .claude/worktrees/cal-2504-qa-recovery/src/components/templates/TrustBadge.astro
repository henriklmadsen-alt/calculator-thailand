---
interface Props {
  ministry: string;
  url: string;
  updatedDate?: string;
  icon?: string;
}
const { ministry, url, updatedDate = '2569', icon = '🏛️' } = Astro.props;
---
<div class="mt-4 mb-6 p-3 bg-blue-50 border border-blue-200 rounded-lg flex items-center gap-3 text-sm">
  <span class="text-lg flex-shrink-0">{icon}</span>
  <div class="min-w-0">
    <div class="text-blue-800 font-semibold text-xs uppercase tracking-wide mb-0.5">ข้อมูลอ้างอิงจาก</div>
    <a href={url} target="_blank" rel="noopener noreferrer" class="text-blue-700 hover:text-blue-900 font-medium underline break-all leading-tight">
      {ministry}
    </a>
    <div class="text-blue-600 text-xs mt-0.5">อัปเดต {updatedDate}</div>
  </div>
  <div class="flex-shrink-0 ml-auto">
    <span class="bg-blue-700 text-white text-xs px-2 py-0.5 rounded-full font-medium">✓ ทางการ</span>
  </div>
</div>
