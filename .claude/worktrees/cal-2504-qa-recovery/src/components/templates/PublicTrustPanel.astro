---
interface ReferenceLink {
  label: string;
  href: string;
}

interface Props {
  lastUpdated?: string;
  sources: string[];
  assumptions?: string[];
  references?: ReferenceLink[];
  className?: string;
}

const {
  lastUpdated,
  sources = [],
  assumptions = [],
  references = [],
  className = '',
} = Astro.props;
---

<section class:list={['mb-6 rounded-xl border border-slate-200 bg-slate-50/70 p-4 text-sm text-slate-700', className]}>
  <h2 class="text-base font-semibold text-slate-900">ข้อมูลความน่าเชื่อถือ</h2>
  <p class="mt-1 text-sm text-slate-700">
    ใช้ข้อมูลอ้างอิงจากหน่วยงานทางการของไทย และแสดงผลเพื่อช่วยวางแผนก่อนตัดสินใจ
  </p>

  {lastUpdated && (
    <p class="mt-2 text-xs font-medium text-slate-600">อัปเดตล่าสุด: {lastUpdated}</p>
  )}

  {sources.length > 0 && (
    <div class="mt-3">
      <h3 class="text-sm font-semibold text-slate-900">แหล่งที่มา</h3>
      <ul class="mt-1 list-disc space-y-1 pl-5">
        {sources.map((source) => <li>{source}</li>)}
      </ul>
    </div>
  )}

  {assumptions.length > 0 && (
    <div class="mt-3">
      <h3 class="text-sm font-semibold text-slate-900">สมมติฐานและข้อควรทราบ</h3>
      <ul class="mt-1 list-disc space-y-1 pl-5">
        {assumptions.map((assumption) => <li>{assumption}</li>)}
      </ul>
    </div>
  )}

  {references.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {references.map((reference) => (
        <a
          href={reference.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-11 items-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-slate-700 hover:border-primary-400 hover:text-primary-700"
        >
          {reference.label}
        </a>
      ))}
    </div>
  )}
</section>
