---
import type { RelatedLink } from '../../lib/internal-links';
import { getCalculatorLinks } from '../../lib/internal-links';

interface Props {
  /** Current calculator href — used to auto-look up related articles. */
  currentHref: string;
  /** Override the auto-lookup with explicit links. */
  articles?: RelatedLink[];
  /** Section heading override. */
  heading?: string;
  /** Cluster name for "View All" link */
  clusterName?: string;
  /** URL for "View All Articles" link */
  viewAllHref?: string;
}

const {
  currentHref,
  articles: explicitArticles,
  heading = 'ศึกษาเพิ่มเติมจากบทความของเรา',
  clusterName,
  viewAllHref,
} = Astro.props;

const allLinks = explicitArticles ?? getCalculatorLinks(currentHref).articles;
const displayedLinks = allLinks.slice(0, 3);
const hasMoreArticles = allLinks.length > 3;
---

{allLinks.length > 0 && (
  <section class="mb-8">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">{heading}</h2>
    <div class="grid gap-3 sm:grid-cols-1">
      {displayedLinks.map((link) => (
        <a
          href={link.href}
          data-preserve-utm
          class="flex flex-col gap-2 p-4 bg-white rounded-lg shadow-sm border border-gray-200 hover:border-primary-500 transition-colors min-h-[44px]"
        >
          <div class="flex items-start gap-3">
            <span class="text-lg leading-none mt-0.5 flex-shrink-0">📖</span>
            <div class="flex-grow min-w-0">
              <span class="text-primary-600 font-medium block">{link.title}</span>
              <span class="text-gray-400 text-sm block">{link.desc}</span>
            </div>
          </div>
          {(link.date || link.author) && (
            <div class="text-gray-500 text-xs pl-7">
              {link.date && <span>{link.date}</span>}
              {link.date && link.author && <span> • </span>}
              {link.author && <span>{link.author}</span>}
            </div>
          )}
        </a>
      ))}
    </div>
    {hasMoreArticles && (
      <div class="mt-4">
        <a
          href={viewAllHref || '#'}
          class="inline-flex items-center justify-center px-4 py-3 min-h-[44px] text-primary-600 font-medium text-sm border border-primary-300 rounded hover:bg-primary-50 transition-colors focus:outline-2 focus:outline-offset-2 focus:outline-primary-600"
        >
          {clusterName
            ? `ดูบทความทั้งหมดใน ${clusterName}`
            : 'ดูบทความทั้งหมด'}
        </a>
      </div>
    )}
  </section>
)}
