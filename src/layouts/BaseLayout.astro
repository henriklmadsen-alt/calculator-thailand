    <!-- PWA: Service Worker registration + Web Push subscription -->
    <script is:inline>
    (function initPWA() {
      if (!('serviceWorker' in navigator)) return;

      const VAPID_PUBLIC_KEY = 'BOWqVZd05Ge2s0KqqynLV_xGFxtwgq6pT7XhhgjCYCNge4xVni_OZ8HrkFxsNnd9m4Stjipf5K0dCyRZaHkn7cw';
      const PUSH_ASKED_KEY = 'ct.push-asked.v1';
      const PUSH_SUBSCRIBED_KEY = 'ct.push-subscribed.v1';

      function urlBase64ToUint8Array(base64String) {
        const padding = '='.repeat((4 - (base64String.length % 4)) % 4);
        const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
        const rawData = atob(base64);
        return new Uint8Array([...rawData].map(c => c.charCodeAt(0)));
      }

      async function subscribeToPush(reg) {
        try {
          const sub = await reg.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: urlBase64ToUint8Array(VAPID_PUBLIC_KEY),
          });
          await fetch('/api/push/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(sub),
          });
          try { localStorage.setItem(PUSH_SUBSCRIBED_KEY, '1'); } catch {}
        } catch {}
      }

      function showPushPrompt(reg) {
        try {
          if (localStorage.getItem(PUSH_ASKED_KEY) === '1') return;
          if (localStorage.getItem(PUSH_SUBSCRIBED_KEY) === '1') return;
          localStorage.setItem(PUSH_ASKED_KEY, '1');
        } catch {}

        // Show after 30s on the page (non-intrusive delay)
        setTimeout(function() {
          // Only prompt if user has been interacting (not a bounce)
          if (document.hidden) return;

          var banner = document.createElement('div');
          banner.id = 'push-prompt';
          banner.setAttribute('role', 'dialog');
          banner.setAttribute('aria-label', 'รับการแจ้งเตือน');
          banner.style.cssText = [
            'position:fixed', 'bottom:16px', 'left:50%', 'transform:translateX(-50%)',
            'background:#1e40af', 'color:white', 'border-radius:12px',
            'padding:14px 18px', 'display:flex', 'align-items:center', 'gap:12px',
            'box-shadow:0 8px 32px rgba(0,0,0,0.2)', 'z-index:9999',
            'max-width:calc(100vw - 32px)', 'font-family:inherit', 'font-size:14px',
            'animation:slideUp 0.3s ease',
          ].join(';');

          var style = document.createElement('style');
          style.textContent = '@keyframes slideUp{from{transform:translateX(-50%) translateY(80px);opacity:0}to{transform:translateX(-50%) translateY(0);opacity:1}}';
          document.head.appendChild(style);

          banner.innerHTML = [
            '<span style="font-size:20px" aria-hidden="true">🔔</span>',
            '<div>',
            '<div style="font-weight:600;margin-bottom:2px">รับแจ้งเตือนวันคำนวณเงินเดือน</div>',
            '<div style="opacity:0.85;font-size:12px">เตือนทุกวันที่ 25 และช่วงยื่นภาษี ฟรี</div>',
            '</div>',
            '<button id="push-allow" style="background:white;color:#1e40af;border:none;border-radius:8px;padding:8px 14px;font-weight:700;cursor:pointer;font-size:13px;white-space:nowrap">เปิดรับ</button>',
            '<button id="push-deny" style="background:transparent;border:none;color:rgba(255,255,255,0.7);cursor:pointer;font-size:18px;padding:4px;line-height:1" aria-label="ปิด">&times;</button>',
          ].join('');

          document.body.appendChild(banner);

          document.getElementById('push-allow').addEventListener('click', function() {
            banner.remove();
            Notification.requestPermission().then(function(perm) {
              if (perm === 'granted') subscribeToPush(reg);
            });
          });
          document.getElementById('push-deny').addEventListener('click', function() {
            banner.remove();
          });
        }, 30000);
      }

      navigator.serviceWorker.register('/sw.js').then(function(reg) {
        // Check if already subscribed
        reg.pushManager.getSubscription().then(function(sub) {
          if (sub) {
            // Re-register existing subscription with server (handles server restarts)
            fetch('/api/push/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(sub),
            }).catch(function() {});
          } else if (Notification.permission === 'default') {
            showPushPrompt(reg);
          } else if (Notification.permission === 'granted') {
            subscribeToPush(reg);
          }
        });
      }).catch(function() {});
    })();
    </script>

    <!-- PWA: Add to Home Screen install prompt (shows after 3rd calculator use) -->
    <script is:inline>
    (function initA2HS() {
      var INSTALL_PROMPTED_KEY = 'ct.a2hs-prompted.v1';
      var CALC_USE_COUNT_KEY = 'ct.calc-use-count.v1';
      var INSTALL_THRESHOLD = 3;

      // Only on calculator pages
      var path = decodeURIComponent(window.location.pathname);
      var isCalcPage = path.startsWith('/คำนวณ') || path.startsWith('/calc');
      if (!isCalcPage) return;

      // Don't show if already prompted
      try {
        if (localStorage.getItem(INSTALL_PROMPTED_KEY) === '1') return;
      } catch { return; }

      // Increment calculator use counter
      var count = 0;
      try {
        count = parseInt(localStorage.getItem(CALC_USE_COUNT_KEY) || '0', 10) + 1;
        localStorage.setItem(CALC_USE_COUNT_KEY, String(count));
      } catch {}

      // Capture install prompt event
      var deferredPrompt = null;
      window.addEventListener('beforeinstallprompt', function(e) {
        e.preventDefault();
        deferredPrompt = e;
        if (count >= INSTALL_THRESHOLD) showInstallBanner();
      });

      // iOS doesn't fire beforeinstallprompt — use Safari-specific check
      function isIOS() {
        return /iphone|ipad|ipod/i.test(navigator.userAgent) && !window.MSStream;
      }
      function isInStandaloneMode() {
        return ('standalone' in window.navigator) && window.navigator.standalone;
      }

      function showInstallBanner() {
        try { localStorage.setItem(INSTALL_PROMPTED_KEY, '1'); } catch {}

        var banner = document.createElement('div');
        banner.id = 'a2hs-banner';
        banner.setAttribute('role', 'dialog');
        banner.setAttribute('aria-label', 'ติดตั้งแอปพลิเคชัน');
        banner.style.cssText = 'position:fixed;bottom:70px;left:16px;right:16px;background:#1e40af;color:#fff;border-radius:12px;padding:16px;z-index:9998;box-shadow:0 4px 20px rgba(0,0,0,0.3);display:flex;align-items:center;gap:12px;font-family:inherit;';

        var iosText = isIOS()
          ? 'แตะ <strong>⎙</strong> แล้วเลือก <strong>"เพิ่มไปที่หน้าจอหลัก"</strong>'
          : 'ติดตั้งเครื่องคำนวณเลขลงมือถือ ใช้ได้ออฟไลน์';

        banner.innerHTML =
          '<div style="font-size:28px;flex-shrink:0">📲</div>' +
          '<div style="flex:1;font-size:14px;line-height:1.4">' +
            '<strong style="display:block;margin-bottom:2px">เพิ่มไปที่หน้าจอหลัก</strong>' +
            '<span>' + iosText + '</span>' +
          '</div>' +
          (!isIOS() ? '<button id="a2hs-install" style="background:#fff;color:#1e40af;border:none;border-radius:8px;padding:8px 14px;font-weight:700;cursor:pointer;white-space:nowrap;font-size:13px">ติดตั้ง</button>' : '') +
          '<button id="a2hs-close" style="background:transparent;border:none;color:#93c5fd;cursor:pointer;font-size:20px;padding:4px;flex-shrink:0" aria-label="ปิด">✕</button>';

        document.body.appendChild(banner);

        var closeBtn = document.getElementById('a2hs-close');
        if (closeBtn) closeBtn.addEventListener('click', function() { banner.remove(); });

        var installBtn = document.getElementById('a2hs-install');
        if (installBtn && deferredPrompt) {
          installBtn.addEventListener('click', function() {
            banner.remove();
            deferredPrompt.prompt();
            deferredPrompt.userChoice.then(function(choice) {
              if (typeof window.gtag === 'function') {
                window.gtag('event', 'pwa_install_prompt', { outcome: choice.outcome });
              }
            });
          });
        }
      }

      // Check on load: if threshold already met and prompt available
      if (count >= INSTALL_THRESHOLD && deferredPrompt) showInstallBanner();

      // iOS: show informational banner (no prompt event)
      if (count >= INSTALL_THRESHOLD && isIOS() && !isInStandaloneMode()) {
        try { if (localStorage.getItem(INSTALL_PROMPTED_KEY) !== '1') showInstallBanner(); } catch {}
      }
    })();
    </script>

    <script is:inline>
      (function trackRecentCalc() {
        var RECENT_KEY = 'ct.recent-calcs.v1';
        var MAX_RECENT = 5;
        var path = decodeURIComponent(window.location.pathname);
        if (path === '/' || path.startsWith('/บทความ/') || path.startsWith('/หมวดหมู่/') || path.startsWith('/en/')) return;
        // Normalize: ensure trailing slash for consistent matching
        var href = path.endsWith('/') ? path : path + '/';
        try {
          var recent = JSON.parse(localStorage.getItem(RECENT_KEY) || '[]');
          if (!Array.isArray(recent)) recent = [];
          recent = recent.filter(function(h) { return h !== href; });
          recent.unshift(href);
          if (recent.length > MAX_RECENT) recent = recent.slice(0, MAX_RECENT);
          localStorage.setItem(RECENT_KEY, JSON.stringify(recent));
        } catch(e) {}
      })();
    </script>
    <script is:inline>
      (function initThemeToggle() {
        const STORAGE_KEY = 'ct.theme-preference.v1';
        const CYCLE = ['system', 'light', 'dark'];
        const ICONS = { system: '🌗', light: '☀️', dark: '🌙' };
        const LABELS = { system: 'อัตโนมัติ', light: 'โหมดสว่าง', dark: 'โหมดมืด' };

        function resolveTheme(pref) {
          if (pref === 'system') {
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            return prefersDark ? 'dark' : 'light';
          }
          return pref;
        }

        function applyTheme(pref) {
          const effective = resolveTheme(pref);
          const root = document.documentElement;
          root.dataset.themePreference = pref;
          root.dataset.theme = effective;
          root.style.colorScheme = effective;
          try { window.localStorage.setItem(STORAGE_KEY, pref); } catch {}
        }

        function syncButtons(pref) {
          document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
            const label = button.querySelector('[data-theme-label]');
            const icon = button.querySelector('[data-theme-icon]');
            if (label) label.textContent = LABELS[pref] || LABELS.system;
            if (icon) icon.textContent = ICONS[pref] || ICONS.system;
          });
        }

        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          if (button.getAttribute('data-theme-bound') === '1') return;
          button.setAttribute('data-theme-bound', '1');
          button.addEventListener('click', () => {
            const current = document.documentElement.dataset.themePreference || 'system';
            const idx = CYCLE.indexOf(current);
            const next = CYCLE[(idx + 1) % CYCLE.length];
            applyTheme(next);
            syncButtons(next);
          });
        });

        const currentPref = document.documentElement.dataset.themePreference || 'system';
        syncButtons(currentPref);
      })();
    </script>
