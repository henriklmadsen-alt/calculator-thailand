---
import '../styles/theme.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  pageName?: string;
  alternateLocales?: Array<{ hreflang: string; href: string }>;
}

const { title, description, canonical, ogImage, pageName, alternateLocales = [] } = Astro.props;
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageUrl = canonical || siteUrl + Astro.url.pathname;
const imageUrl = ogImage || `${siteUrl}/og-image.svg`;
const adsenseClientId = String(import.meta.env.PUBLIC_ADSENSE_CLIENT_ID || '').trim();
const adsenseEnabledRaw = String(import.meta.env.PUBLIC_ADSENSE_ENABLED || '').trim().toLowerCase();
const adsenseEnabled = ['1', 'true', 'yes', 'on'].includes(adsenseEnabledRaw);
const shouldLoadAdsenseScript = Boolean(adsenseClientId && adsenseEnabled);
const localeAlternates = [
  { hreflang: 'th-TH', href: pageUrl },
  { hreflang: 'x-default', href: pageUrl },
  ...alternateLocales.filter((alt) => alt?.hreflang && alt?.href),
];

const jsonLdWebPage = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  url: pageUrl,
  name: title,
  description,
  inLanguage: 'th-TH',
  isPartOf: {
    '@type': 'WebSite',
    name: 'kamnuanlek — เครื่องคำนวณไทย',
    url: siteUrl,
  },
  sourceOrganization: {
    '@type': 'Organization',
    name: 'kamnuanlek — เครื่องคำนวณไทย',
    url: siteUrl,
  },
});

const breadcrumbJsonLd = pageName ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "หน้าแรก",
      "item": siteUrl + "/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": pageName
    }
  ]
}) : null;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={pageUrl} />
    {localeAlternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <meta name="google-site-verification" content="ZGJ3F-iJz_S9hqfdsjSoj33ZaYLaOfiQ4xjeL3KSgGM" />
    <meta name="google-site-verification" content="zaca9jM01wCKV24fXyQM0o0hYouvbVh8yFjLtAhjc5g" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="เครื่องคำนวณไทย" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="th_TH" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Favicon (SVG inline as data URI - calculator icon) -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%232563eb'/><rect x='20' y='15' width='60' height='25' rx='5' fill='white'/><rect x='20' y='50' width='17' height='17' rx='3' fill='white'/><rect x='41' y='50' width='17' height='17' rx='3' fill='white'/><rect x='62' y='50' width='17' height='17' rx='3' fill='white'/><rect x='20' y='72' width='17' height='17' rx='3' fill='white'/><rect x='41' y='72' width='17' height='17' rx='3' fill='white'/><rect x='62' y='72' width='38' height='17' rx='3' fill='%2360a5fa'/></svg>" />
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%232563eb'/></svg>" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script type="application/ld+json" set:html={jsonLdWebPage} />
    {breadcrumbJsonLd && <script type="application/ld+json" set:html={breadcrumbJsonLd} />}

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EY67HJ8NDD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EY67HJ8NDD');

      function decodePathname(pathname) {
        try {
          return decodeURIComponent(pathname);
        } catch {
          return pathname;
        }
      }

      function getPageType() {
        const decodedPath = decodePathname(window.location.pathname);
        if (decodedPath.startsWith('/บทความ/')) return 'article';
        return decodedPath === '/' ? 'home' : 'calculator';
      }

      function getDefaultCalculatorType() {
        const decodedPath = decodePathname(window.location.pathname);
        const calculatorMap = {
          '/คำนวณค่าไฟฟ้า/': 'electricity_bill',
          '/คำนวณภาษีเงินได้บุคคลธรรมดา/': 'personal_income_tax',
          '/คำนวณผ่อนรถ/': 'vehicle',
          '/คำนวณผ่อนบ้าน/': 'mortgage_refinance',
          '/คำนวณเงินเดือนสุทธิ/': 'net_salary',
          '/คำนวณผ่อนกู้/': 'loan',
          '/คำนวณภาษีมูลค่าเพิ่ม/': 'vat',
          '/คำนวณดอกเบี้ยเงินฝาก/': 'deposit',
          '/คำนวณ-bmi/': 'bmi',
          '/คำนวณอายุ/': 'age',
          '/คำนวณภาษีที่ดิน/': 'land_building_tax',
        };
        return calculatorMap[decodedPath] || '';
      }

      function getLanguageContext() {
        return {
          lang_mode: 'th',
          content_locale: 'th',
          ui_language: 'th',
        };
      }

      function getReferrerHost() {
        if (!document.referrer) return '';
        try {
          return (new URL(document.referrer).hostname || '').toLowerCase();
        } catch {
          return '';
        }
      }

      function classifyAiReferrer(referrerHost) {
        if (!referrerHost || referrerHost === '(direct)') return 'none';

        const aiReferrerRules = [
          ['chat.openai.com', 'chatgpt'],
          ['chatgpt.com', 'chatgpt'],
          ['openai.com', 'chatgpt'],
          ['perplexity.ai', 'perplexity'],
          ['claude.ai', 'claude'],
          ['poe.com', 'poe'],
          ['gemini.google.com', 'gemini'],
          ['copilot.microsoft.com', 'copilot'],
        ];

        for (const [hostFragment, label] of aiReferrerRules) {
          if (referrerHost.includes(hostFragment)) {
            return label;
          }
        }

        return 'none';
      }

      function getTrafficAttribution() {
        const params = new URLSearchParams(window.location.search);
        const utmSource = params.get('utm_source') || '';
        const utmMedium = params.get('utm_medium') || '';
        const utmCampaign = params.get('utm_campaign') || '';
        const referrerHost = getReferrerHost();
        const aiReferrerSource = classifyAiReferrer(referrerHost);
        const trafficChannel = aiReferrerSource !== 'none'
          ? 'ai_referral'
          : (utmSource ? 'campaign' : (referrerHost ? 'referral' : 'direct'));

        return {
          traffic_source: utmSource || referrerHost || '(direct)',
          traffic_medium: utmMedium || (referrerHost ? 'referral' : '(none)'),
          traffic_campaign: utmCampaign || '(not set)',
          referrer_host: referrerHost || '(direct)',
          ai_referrer_source: aiReferrerSource,
          traffic_channel: trafficChannel,
        };
      }

      function withLanguageContext(payload) {
        return {
          ...payload,
          ...getLanguageContext(),
        };
      }

      function emitSessionStartOnce() {
        if (typeof window.gtag !== 'function') return;

        const storageKey = 'ct.session_start.v1';
        try {
          if (window.sessionStorage.getItem(storageKey) === '1') {
            return;
          }
          window.gtag('event', 'session_start', {
            ...getTrafficAttribution(),
            landing_path: window.location.pathname,
            ...getLanguageContext(),
          });
          window.sessionStorage.setItem(storageKey, '1');
        } catch {
          // Session storage can be unavailable in strict privacy modes.
          window.gtag('event', 'session_start', {
            ...getTrafficAttribution(),
            landing_path: window.location.pathname,
            ...getLanguageContext(),
          });
        }
      }

      // Shared GA4 custom event helpers
      function trackCalculatorStart(calculatorType) {
        if (typeof window.gtag !== 'function') return;
        window.__ctCalculatorType = calculatorType;
        window.gtag('event', 'calculator_start', withLanguageContext({
          calculator_type: calculatorType,
          ...getTrafficAttribution(),
        }));
      }
      function trackCalculatorComplete(calculatorType, resultValue) {
        if (typeof window.gtag !== 'function') return;
        window.__ctCalculatorType = calculatorType;
        const payload = {
          calculator_type: calculatorType,
          ...getTrafficAttribution(),
        };
        if (typeof resultValue === 'number' && Number.isFinite(resultValue)) {
          payload.result_value = resultValue;
        }
        window.gtag('event', 'calculator_complete', withLanguageContext(payload));
      }
      function trackCalculatorUsed(calculatorType) {
        if (typeof window.gtag !== 'function') return;
        window.__ctCalculatorType = calculatorType;
        window.gtag('event', 'calculator_used', withLanguageContext({ calculator_type: calculatorType }));
      }
      function trackResultViewed(calculatorType) {
        if (typeof window.gtag !== 'function') return;
        window.__ctCalculatorType = calculatorType;
        window.gtag('event', 'result_viewed', withLanguageContext({ calculator_type: calculatorType }));
      }
      function trackLanguageAwareEvent(eventName, payload = {}) {
        if (typeof window.gtag !== 'function') return;
        window.gtag('event', eventName, withLanguageContext(payload));
      }

      window.trackCalculatorStart = trackCalculatorStart;
      window.trackCalculatorComplete = trackCalculatorComplete;
      window.trackCalculatorUsed = trackCalculatorUsed;
      window.trackResultViewed = trackResultViewed;
      window.trackLanguageAwareEvent = trackLanguageAwareEvent;
      window.getLanguageContext = getLanguageContext;

      function preserveAttributionParamsOnLinks() {
        const source = new URLSearchParams(window.location.search);
        const passthroughKeys = [
          'utm_source',
          'utm_medium',
          'utm_campaign',
          'utm_content',
          'utm_term',
          'utm_id',
          'gclid',
          'fbclid',
          'lang',
        ];

        const passthrough = new URLSearchParams();
        passthroughKeys.forEach((key) => {
          const value = source.get(key);
          if (value) passthrough.set(key, value);
        });

        if ([...passthrough.keys()].length === 0) return;

        document.querySelectorAll('a[data-preserve-utm]').forEach((link) => {
          const href = link.getAttribute('href');
          if (!href) return;

          let targetUrl;
          try {
            targetUrl = new URL(href, window.location.origin);
          } catch {
            return;
          }

          if (targetUrl.origin !== window.location.origin) return;

          passthrough.forEach((value, key) => {
            if (!targetUrl.searchParams.has(key)) {
              targetUrl.searchParams.set(key, value);
            }
          });

          const nextHref = `${targetUrl.pathname}${targetUrl.search}${targetUrl.hash}`;
          link.setAttribute('href', nextHref);
        });
      }

      function bindEntryClickTracking() {
        document.querySelectorAll('[data-entry-event]').forEach((element) => {
          if (element.getAttribute('data-entry-bound') === '1') return;
          element.setAttribute('data-entry-bound', '1');
          element.addEventListener('click', () => {
            const eventName = element.getAttribute('data-entry-event');
            if (!eventName) return;

            const routeTo = element.getAttribute('data-route-to')
              || element.getAttribute('href')
              || '';

            const payload = {
              route_from: window.location.pathname,
              route_to: routeTo,
            };

            const targetCalculator = element.getAttribute('data-target-calculator');
            const entrySurface = element.getAttribute('data-entry-surface');
            const placement = element.getAttribute('data-placement');

            if (targetCalculator) payload.target_calculator = targetCalculator;
            if (entrySurface) payload.entry_surface = entrySurface;
            if (placement) payload.placement = placement;

            trackLanguageAwareEvent(eventName, payload);
          });
        });
      }

      emitSessionStartOnce();

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          preserveAttributionParamsOnLinks();
          bindEntryClickTracking();
        });
      } else {
        preserveAttributionParamsOnLinks();
        bindEntryClickTracking();
      }
    </script>

    {
      shouldLoadAdsenseScript && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`}
          crossorigin="anonymous"
        ></script>
      )
    }

    <script is:inline>
      (function initializeThemeBeforePaint() {
        const STORAGE_KEY = 'ct.theme-preference.v1';
        const allowed = ['light', 'dark', 'system'];
        const root = document.documentElement;

        function getSavedPreference() {
          try {
            const stored = window.localStorage.getItem(STORAGE_KEY);
            return allowed.includes(stored || '') ? stored : 'system';
          } catch {
            return 'system';
          }
        }

        const preference = getSavedPreference();
        const systemPrefersDark = typeof window.matchMedia === 'function'
          && window.matchMedia('(prefers-color-scheme: dark)').matches;
        const effectiveTheme = preference === 'system'
          ? (systemPrefersDark ? 'dark' : 'light')
          : preference;

        root.dataset.themePreference = preference;
        root.dataset.theme = effectiveTheme;
        root.style.colorScheme = effectiveTheme;
      })();
    </script>

    <style>
      .calc-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }
      .calc-card:hover {
        transform: translateY(-2px);
      }

    </style>
  </head>
  <body class="font-thai text-gray-900 flex flex-col">
    <header class="bg-white/80 backdrop-blur-md shadow-sm border-b border-gray-100 sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-9 h-9 bg-gradient-to-br from-primary-500 to-primary-700 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <span class="text-lg font-bold text-gray-900 group-hover:text-primary-600 transition-colors">เครื่องคำนวณไทย</span>
            <span class="hidden sm:block text-xs text-gray-400 -mt-0.5">kamnuanlek.com</span>
          </div>
        </a>
        <div class="flex items-center gap-3 text-sm">
          <a href="/บทความ/" class="text-gray-600 hover:text-primary-600 transition-colors font-medium">บทความ</a>
          <button
            type="button"
            aria-label="สลับโหมดสี"
            data-theme-toggle
            class="min-h-11 rounded-lg border border-slate-200 bg-slate-50 px-2.5 py-1.5 text-xs font-semibold text-slate-600 transition-colors sm:min-h-0"
          >
            <span aria-hidden="true" data-theme-icon>🌗</span>
            <span class="hidden sm:inline" data-theme-label>อัตโนมัติ</span>
          </button>
          <span class="hidden sm:inline px-3 py-1.5 bg-primary-50 text-primary-700 rounded-full font-medium">
            ฟรี 100%
          </span>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-5xl mx-auto px-4 sm:px-6 py-8 w-full">
      <slot />
    </main>

    <footer class="mt-auto border-t border-gray-100 bg-white/60">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 bg-gradient-to-br from-primary-500 to-primary-700 rounded-md flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-gray-700">เครื่องคำนวณไทย</span>
          </div>
          <nav class="flex flex-wrap gap-4 text-sm text-gray-500">
            <a href="/" class="hover:text-primary-600 transition-colors">หน้าแรก</a>
            <a href="/บทความ/" class="hover:text-primary-600 transition-colors">บทความ</a>
            <a href="/คำนวณค่าไฟฟ้า/" class="hover:text-primary-600 transition-colors">ค่าไฟฟ้า</a>
            <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="hover:text-primary-600 transition-colors">คำนวณภาษี</a>
            <a href="/คำนวณภาษีมูลค่าเพิ่ม/" class="hover:text-primary-600 transition-colors">VAT 7%</a>
            <a href="/คำนวณผ่อนกู้/" class="hover:text-primary-600 transition-colors">ผ่อนกู้</a>
            <a href="/คำนวณผ่อนรถ/" class="hover:text-primary-600 transition-colors">ผ่อนรถ</a>
            <a href="/คำนวณดอกเบี้ยเงินฝาก/" class="hover:text-primary-600 transition-colors">ดอกเบี้ยเงินฝาก</a>
            <a href="/คำนวณ-bmi/" class="hover:text-primary-600 transition-colors">BMI</a>
            <a href="/คำนวณอายุ/" class="hover:text-primary-600 transition-colors">คำนวณอายุ</a>
            <a href="/คำนวณเงินเดือนสุทธิ/" class="hover:text-primary-600 transition-colors">เงินเดือนสุทธิ</a>
          </nav>
          <p class="text-xs text-gray-400">© 2026 เครื่องคำนวณไทย — ข้อมูลเพื่อการศึกษาเท่านั้น</p>
        </div>
      </div>
    </footer>
    <script is:inline>
      (function trackRecentCalc() {
        var RECENT_KEY = 'ct.recent-calcs.v1';
        var MAX_RECENT = 5;
        var path = decodeURIComponent(window.location.pathname);
        if (path === '/' || path.startsWith('/บทความ/') || path.startsWith('/หมวดหมู่/') || path.startsWith('/en/')) return;
        // Normalize: ensure trailing slash for consistent matching
        var href = path.endsWith('/') ? path : path + '/';
        try {
          var recent = JSON.parse(localStorage.getItem(RECENT_KEY) || '[]');
          if (!Array.isArray(recent)) recent = [];
          recent = recent.filter(function(h) { return h !== href; });
          recent.unshift(href);
          if (recent.length > MAX_RECENT) recent = recent.slice(0, MAX_RECENT);
          localStorage.setItem(RECENT_KEY, JSON.stringify(recent));
        } catch(e) {}
      })();
    </script>
    <script is:inline>
      (function initThemeToggle() {
        const STORAGE_KEY = 'ct.theme-preference.v1';
        const CYCLE = ['system', 'light', 'dark'];
        const ICONS = { system: '🌗', light: '☀️', dark: '🌙' };
        const LABELS = { system: 'อัตโนมัติ', light: 'โหมดสว่าง', dark: 'โหมดมืด' };

        function resolveTheme(pref) {
          if (pref === 'system') {
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            return prefersDark ? 'dark' : 'light';
          }
          return pref;
        }

        function applyTheme(pref) {
          const effective = resolveTheme(pref);
          const root = document.documentElement;
          root.dataset.themePreference = pref;
          root.dataset.theme = effective;
          root.style.colorScheme = effective;
          try { window.localStorage.setItem(STORAGE_KEY, pref); } catch {}
        }

        function syncButtons(pref) {
          document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
            const label = button.querySelector('[data-theme-label]');
            const icon = button.querySelector('[data-theme-icon]');
            if (label) label.textContent = LABELS[pref] || LABELS.system;
            if (icon) icon.textContent = ICONS[pref] || ICONS.system;
          });
        }

        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          if (button.getAttribute('data-theme-bound') === '1') return;
          button.setAttribute('data-theme-bound', '1');
          button.addEventListener('click', () => {
            const current = document.documentElement.dataset.themePreference || 'system';
            const idx = CYCLE.indexOf(current);
            const next = CYCLE[(idx + 1) % CYCLE.length];
            applyTheme(next);
            syncButtons(next);
          });
        });

        const currentPref = document.documentElement.dataset.themePreference || 'system';
        syncButtons(currentPref);
      })();
    </script>
  </body>
</html>
