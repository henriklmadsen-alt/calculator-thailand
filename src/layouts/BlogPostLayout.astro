---
import '../styles/theme.css';
import AdUnit from '../components/AdUnit.astro';

interface Props {
  title: string;
  description: string;
  publishDate: string;
  modifiedDate?: string;
  canonical?: string;
  ogImage?: string;
  author?: string;
  faqData?: Array<{ question: string; answer: string }>;
  alternateLocales?: Array<{ hreflang: string; href: string }>;
}

const {
  title,
  description,
  publishDate,
  modifiedDate,
  canonical,
  ogImage,
  author = 'คำนวณเลข',
  faqData,
  alternateLocales = [],
} = Astro.props;

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageUrl = canonical || siteUrl + Astro.url.pathname;
const imageUrl = ogImage || `${siteUrl}/og-image.svg`;
const adsenseClientId = String(import.meta.env.PUBLIC_ADSENSE_CLIENT_ID || '').trim();
const adsenseEnabledRaw = String(import.meta.env.PUBLIC_ADSENSE_ENABLED || '').trim().toLowerCase();
const adsenseEnabled = ['1', 'true', 'yes', 'on'].includes(adsenseEnabledRaw);
const shouldLoadAdsenseScript = Boolean(adsenseClientId && adsenseEnabled);
const localeAlternates = [
  { hreflang: 'th-TH', href: pageUrl },
  { hreflang: 'x-default', href: pageUrl },
  ...alternateLocales.filter((alt) => alt?.hreflang && alt?.href),
];

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: imageUrl,
  datePublished: publishDate,
  dateModified: modifiedDate || publishDate,
  author: {
    '@type': 'Organization',
    name: author,
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'คำนวณเลข',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/og-image.svg`,
    },
  },
  sourceOrganization: {
    '@type': 'Organization',
    name: 'Calculator Thailand',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
  inLanguage: 'th',
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'หน้าแรก',
      item: siteUrl + '/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'บทความ',
      item: siteUrl + '/บทความ/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title.replace(/ \|.*$/, ''),
      item: pageUrl,
    },
  ],
};

const jsonLdFaq = faqData
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqData.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={pageUrl} />
    {localeAlternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <meta name="google-site-verification" content="ZGJ3F-iJz_S9hqfdsjSoj33ZaYLaOfiQ4xjeL3KSgGM" />
    <meta name="google-site-verification" content="zaca9jM01wCKV24fXyQM0o0hYouvbVh8yFjLtAhjc5g" />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="คำนวณเลข" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="th_TH" />
    <meta property="article:published_time" content={publishDate} />
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%232563eb'/><rect x='20' y='15' width='60' height='25' rx='5' fill='white'/><rect x='20' y='50' width='17' height='17' rx='3' fill='white'/><rect x='41' y='50' width='17' height='17' rx='3' fill='white'/><rect x='62' y='50' width='17' height='17' rx='3' fill='white'/><rect x='20' y='72' width='17' height='17' rx='3' fill='white'/><rect x='41' y='72' width='17' height='17' rx='3' fill='white'/><rect x='62' y='72' width='38' height='17' rx='3' fill='%2360a5fa'/></svg>" />

    <!-- Fonts (non-blocking load + noscript fallback) -->
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />
    <link rel="dns-prefetch" href="//www.googletagmanager.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700;800&display=swap" />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
    {jsonLdFaq && <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />}

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EY67HJ8NDD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EY67HJ8NDD');

      function getLanguageContext() {
        return {
          lang_mode: 'th',
          content_locale: 'th',
          ui_language: 'th',
        };
      }

      function getReferrerHost() {
        if (!document.referrer) return '';
        try {
          return (new URL(document.referrer).hostname || '').toLowerCase();
        } catch {
          return '';
        }
      }

      function classifyAiReferrer(referrerHost) {
        if (!referrerHost || referrerHost === '(direct)') return 'none';

        const aiReferrerRules = [
          ['chat.openai.com', 'chatgpt'],
          ['chatgpt.com', 'chatgpt'],
          ['openai.com', 'chatgpt'],
          ['perplexity.ai', 'perplexity'],
          ['claude.ai', 'claude'],
          ['poe.com', 'poe'],
          ['gemini.google.com', 'gemini'],
          ['copilot.microsoft.com', 'copilot'],
        ];

        for (const [hostFragment, label] of aiReferrerRules) {
          if (referrerHost.includes(hostFragment)) {
            return label;
          }
        }

        return 'none';
      }

      function getTrafficAttribution() {
        const params = new URLSearchParams(window.location.search);
        const utmSource = params.get('utm_source') || '';
        const utmMedium = params.get('utm_medium') || '';
        const utmCampaign = params.get('utm_campaign') || '';
        const referrerHost = getReferrerHost();
        const aiReferrerSource = classifyAiReferrer(referrerHost);
        const trafficChannel = aiReferrerSource !== 'none'
          ? 'ai_referral'
          : (utmSource ? 'campaign' : (referrerHost ? 'referral' : 'direct'));

        return {
          traffic_source: utmSource || referrerHost || '(direct)',
          traffic_medium: utmMedium || (referrerHost ? 'referral' : '(none)'),
          traffic_campaign: utmCampaign || '(not set)',
          referrer_host: referrerHost || '(direct)',
          ai_referrer_source: aiReferrerSource,
          traffic_channel: trafficChannel,
        };
      }

      function withLanguageContext(payload) {
        return {
          ...payload,
          ...getTrafficAttribution(),
          ...getLanguageContext(),
        };
      }

      function emitSessionStartOnce() {
        if (typeof window.gtag !== 'function') return;

        const storageKey = 'ct.session_start.v1';
        try {
          if (window.sessionStorage.getItem(storageKey) === '1') {
            return;
          }
          window.gtag('event', 'session_start', withLanguageContext({
            landing_path: window.location.pathname,
            page_type: 'article',
          }));
          window.sessionStorage.setItem(storageKey, '1');
        } catch {
          window.gtag('event', 'session_start', withLanguageContext({
            landing_path: window.location.pathname,
            page_type: 'article',
          }));
        }
      }

      function trackLanguageAwareEvent(eventName, payload = {}) {
        if (typeof window.gtag !== 'function') return;
        window.gtag('event', eventName, withLanguageContext(payload));
      }

      function getOrCreateVisitorId() {
        const key = 'ct.visitor_id.v1';
        try {
          const existing = window.localStorage.getItem(key);
          if (existing) return existing;
          const next = (window.crypto && typeof window.crypto.randomUUID === 'function')
            ? window.crypto.randomUUID()
            : `${Date.now()}-${Math.random().toString(36).slice(2)}`;
          window.localStorage.setItem(key, next);
          return next;
        } catch {
          return `${Date.now()}-${Math.random().toString(36).slice(2)}`;
        }
      }

      async function sendVisitorCounterPing() {
        if (window.location.pathname.startsWith('/admin')) return;
        if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') return;

        const perPageKey = `ct.visitor_ping.v1:${window.location.pathname}`;
        try {
          if (window.sessionStorage.getItem(perPageKey) === '1') return;
          window.sessionStorage.setItem(perPageKey, '1');
        } catch {}

        const visitorId = getOrCreateVisitorId();
        const body = JSON.stringify({
          visitorId,
          pagePath: window.location.pathname,
          pageType: 'article',
        });

        try {
          await fetch('/api/visitor-counter', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body,
            keepalive: true,
          });
        } catch {}
      }

      async function renderTodayVisitorCount() {
        const el = document.getElementById('ct-visitor-count-value');
        if (!el) return;

        try {
          const response = await fetch('/api/visitor-counter?days=1', { cache: 'no-store' });
          if (!response.ok) return;
          const payload = await response.json();
          const value = Number(payload?.today?.uniqueVisitors);
          if (!Number.isFinite(value)) return;
          el.textContent = value.toLocaleString('th-TH');
        } catch {}
      }

      function bindEntryClickTracking() {
        document.querySelectorAll('[data-entry-event]').forEach((element) => {
          if (element.getAttribute('data-entry-bound') === '1') return;
          element.setAttribute('data-entry-bound', '1');
          element.addEventListener('click', () => {
            const eventName = element.getAttribute('data-entry-event');
            if (!eventName) return;

            const routeTo = element.getAttribute('data-route-to')
              || element.getAttribute('href')
              || '';

            const payload = {
              route_from: window.location.pathname,
              route_to: routeTo,
            };

            const targetCalculator = element.getAttribute('data-target-calculator');
            const entrySurface = element.getAttribute('data-entry-surface');
            const placement = element.getAttribute('data-placement');

            if (targetCalculator) payload.target_calculator = targetCalculator;
            if (entrySurface) payload.entry_surface = entrySurface;
            if (placement) payload.placement = placement;

            trackLanguageAwareEvent(eventName, payload);
          });
        });
      }

      window.trackLanguageAwareEvent = trackLanguageAwareEvent;
      window.getLanguageContext = getLanguageContext;

      emitSessionStartOnce();

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          sendVisitorCounterPing();
          renderTodayVisitorCount();
          bindEntryClickTracking();
        });
      } else {
        sendVisitorCounterPing();
        renderTodayVisitorCount();
        bindEntryClickTracking();
      }
    </script>

    {
      shouldLoadAdsenseScript && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`}
          crossorigin="anonymous"
        ></script>
      )
    }

    <script is:inline>
      (function initializeThemeBeforePaint() {
        const STORAGE_KEY = 'ct.theme-preference.v1';
        const allowed = ['light', 'dark', 'system'];
        const root = document.documentElement;

        function getSavedPreference() {
          try {
            const stored = window.localStorage.getItem(STORAGE_KEY);
            return allowed.includes(stored || '') ? stored : 'system';
          } catch {
            return 'system';
          }
        }

        const preference = getSavedPreference();
        const systemPrefersDark = typeof window.matchMedia === 'function'
          && window.matchMedia('(prefers-color-scheme: dark)').matches;
        const effectiveTheme = preference === 'system'
          ? (systemPrefersDark ? 'dark' : 'light')
          : preference;

        root.dataset.themePreference = preference;
        root.dataset.theme = effectiveTheme;
        root.style.colorScheme = effectiveTheme;
      })();
    </script>

    <style>
      .prose h2 { margin-top: 2rem; margin-bottom: 0.75rem; font-size: 1.25rem; font-weight: 700; }
      .prose h3 { margin-top: 1.5rem; margin-bottom: 0.5rem; font-size: 1.1rem; font-weight: 600; }
      .prose p { margin-bottom: 1rem; line-height: 1.8; }
      .prose ul, .prose ol { margin-bottom: 1rem; padding-left: 1.5rem; }
      .prose li { margin-bottom: 0.25rem; line-height: 1.7; }
      .prose a { text-decoration: underline; }

    </style>
  </head>
  <body class="font-thai text-gray-900 flex flex-col">
    <header class="bg-white/80 backdrop-blur-md shadow-sm border-b border-gray-100 sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-9 h-9 bg-gradient-to-br from-primary-500 to-primary-700 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <span class="text-lg font-bold text-gray-900 group-hover:text-primary-600 transition-colors">คำนวณเลข</span>
            <span class="hidden sm:block text-xs text-gray-400 -mt-0.5">kamnuanlek.com</span>
          </div>
        </a>
        <div class="flex items-center gap-3 text-sm">
          <a href="/บทความ/" class="text-gray-600 hover:text-primary-600 transition-colors font-medium">บทความ</a>
          <button
            type="button"
            aria-label="สลับโหมดสี"
            data-theme-toggle
            class="min-h-11 rounded-lg border border-slate-200 bg-slate-50 px-2.5 py-1.5 text-xs font-semibold text-slate-600 transition-colors sm:min-h-0"
          >
            <span aria-hidden="true" data-theme-icon>🌗</span>
            <span class="hidden sm:inline" data-theme-label>อัตโนมัติ</span>
          </button>
          <span class="hidden sm:inline px-3 py-1.5 bg-primary-50 text-primary-700 rounded-full font-medium">
            ฟรี 100%
          </span>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-3xl mx-auto px-4 sm:px-6 py-8 w-full">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5 flex-wrap">
          <li><a href="/" class="hover:text-primary-600 transition-colors">หน้าแรก</a></li>
          <li class="text-gray-300">/</li>
          <li><a href="/บทความ/" class="hover:text-primary-600 transition-colors">บทความ</a></li>
          <li class="text-gray-300">/</li>
          <li class="text-gray-700 font-medium truncate max-w-[200px] sm:max-w-none">{title.replace(/ \|.*$/, '')}</li>
        </ol>
      </nav>

      <section class="mb-6 rounded-xl border border-sky-100 bg-sky-50 p-4">
        <p class="text-sm font-semibold text-sky-800">สรุปสั้น: บทความนี้ช่วยอะไร</p>
      </section>

      <article class="prose">
        <slot />
      </article>

      <!-- AdSense: in-content ad unit (lazy-loaded) -->
      <AdUnit slot="in-content" slotId="A1" templateType="article" />

      <!-- Disclaimer -->
      <div class="mt-8 p-4 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-800">
        <strong>ข้อจำกัดความรับผิดชอบ:</strong> บทความนี้จัดทำขึ้นเพื่อให้ความรู้ทั่วไปเท่านั้น ไม่ถือเป็นคำแนะนำทางการเงินหรือภาษี กรุณาปรึกษาผู้เชี่ยวชาญก่อนตัดสินใจทางการเงิน
      </div>

      <!-- Related calculators -->
      <div class="mt-8">
        <h2 class="text-lg font-bold text-gray-900 mb-4">เครื่องคำนวณที่เกี่ยวข้อง</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">คำนวณภาษี</a>
          <a href="/คำนวณเงินเดือนสุทธิ/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">เงินเดือนสุทธิ</a>
          <a href="/คำนวณผ่อนรถ/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">ผ่อนรถ</a>
          <a href="/คำนวณ-bmi/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">คำนวณ BMI</a>
          <a href="/คำนวณดอกเบี้ยเงินฝาก/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">ดอกเบี้ยเงินฝาก</a>
          <a href="/คำนวณภาษีมูลค่าเพิ่ม/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">VAT 7%</a>
        </div>
      </div>
    </main>

    <footer class="mt-auto border-t border-gray-100 bg-white/60">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-6">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 bg-gradient-to-br from-primary-500 to-primary-700 rounded-md flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-gray-700">คำนวณเลข</span>
          </div>
          <nav class="flex flex-wrap gap-4 text-sm text-gray-500">
            <a href="/" class="hover:text-primary-600 transition-colors">หน้าแรก</a>
            <a href="/บทความ/" class="hover:text-primary-600 transition-colors">บทความ</a>
            <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="hover:text-primary-600 transition-colors">คำนวณภาษี</a>
            <a href="/คำนวณภาษีมูลค่าเพิ่ม/" class="hover:text-primary-600 transition-colors">VAT 7%</a>
            <a href="/คำนวณผ่อนกู้/" class="hover:text-primary-600 transition-colors">ผ่อนกู้</a>
            <a href="/คำนวณผ่อนรถ/" class="hover:text-primary-600 transition-colors">ผ่อนรถ</a>
          </nav>
          <div class="text-xs text-gray-400 text-center sm:text-right">
            <p>&copy; 2026 คำนวณเลข — ข้อมูลเพื่อการศึกษาเท่านั้น</p>
            <p class="mt-1">ผู้เยี่ยมชมวันนี้: <span id="ct-visitor-count-value">—</span></p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
