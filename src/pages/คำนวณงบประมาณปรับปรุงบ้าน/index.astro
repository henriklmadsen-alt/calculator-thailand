---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณงบประมาณปรับปรุงบ้าน ปี 2569 — Renovation Budget Calculator | Kamnuanlek';
const pageDescription = 'วางแผนงบประมาณสำหรับโครงการปรับปรุงบ้าน ด้านต่าง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบประมาณปรับปรุงบ้าน/`;

const faqData = [
  {
    question: 'สูตรคำนวณคืออะไร?',
    answer: 'สูตร: รวม = ครัว + ห้องน้ำ + ห้องนอน',
  },
  {
    question: 'ผลลัพธ์แตกต่างจากความเป็นจริงได้หรือ?',
    answer: 'ใช่ ผลลัพธ์นี้เป็นการประมาณการเท่านั้น ค่าจริงอาจแตกต่างขึ้นอยู่กับสภาพการณ์และราคาปัจจุบัน',
  },
  {
    question: 'ควรปรึกษาใครเพื่อเพิ่มเติมข้อมูล?',
    answer: 'ควรปรึกษาสถาปนิก ผู้รับเหมา หรือผู้เชี่ยวชาญการก่อสร้างเพื่อขอคำปรึกษา',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ คำนวณงบประมาณปรับปรุงบ้าน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบประมาณปรับปรุงบ้าน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-orange-100 bg-orange-50 p-4">
      <p class="text-sm font-semibold text-orange-700">คำนวณงบประมาณปรับปรุงบ้าน</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: รวม = ครัว + ห้องน้ำ + ห้องนอน</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณงบประมาณปรับปรุงบ้าน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      วางแผนงบประมาณสำหรับโครงการปรับปรุงบ้าน ด้านต่าง
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc_0325" class="space-y-5">
        <p id="calc_0325-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

                <div>
            <label for="calc_0325-kitchen" class="mb-1 block text-sm font-medium text-gray-700">งบประมาณครัว (บาท)</label>
            <input type="text" id="calc_0325-kitchen" inputmode="numeric" placeholder="เช่น 250000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="calc_0325-kitchen-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        <div>
            <label for="calc_0325-bathroom" class="mb-1 block text-sm font-medium text-gray-700">งบประมาณห้องน้ำ (บาท)</label>
            <input type="text" id="calc_0325-bathroom" inputmode="numeric" placeholder="เช่น 150000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="calc_0325-bathroom-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        <div>
            <label for="calc_0325-bedroom" class="mb-1 block text-sm font-medium text-gray-700">งบประมาณห้องนอน (บาท)</label>
            <input type="text" id="calc_0325-bedroom" inputmode="numeric" placeholder="เช่น 300000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="calc_0325-bedroom-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>


        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="calc_0325-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="rounded-lg bg-green-50 p-4">
          <div class="mb-1 text-sm text-gray-600">ผลลัพธ์</div>
          <div id="res-calc_0325" class="text-2xl font-bold text-green-700">-</div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <p class="text-gray-700">รวม = ครัว + ห้องน้ำ + ห้องนอน</p>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#calc_0325-results" />

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณงบประมาณปรับปรุงบ้าน/" />
    <RelatedCalculators currentHref="/คำนวณงบประมาณปรับปรุงบ้าน/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> คำนวณการประมาณการเท่านั้น ค่าจริงอาจแตกต่างได้
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('calc_0325')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('calc_0325-error').classList.add('hidden');

            const kitchen = parseNum(document.getElementById("calc_0325-kitchen").value);
      const bathroom = parseNum(document.getElementById("calc_0325-bathroom").value);
      const bedroom = parseNum(document.getElementById("calc_0325-bedroom").value);
      let hasError = false;
      if (!Number.isFinite(kitchen) || kitchen <= 0) { setErr('calc_0325-kitchen-error', 'กรอกค่ามากกว่า 0'); hasError = true; }
      if (hasError) { document.getElementById('calc_0325-error').classList.remove('hidden'); document.getElementById('calc_0325-results').classList.add('hidden'); return; }

      const result = kitchen * bathroom;
      setText('res-calc_0325', fmt(result));

      document.getElementById('calc_0325-results').classList.remove('hidden');
      document.getElementById('calc_0325-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
