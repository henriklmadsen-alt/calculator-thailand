---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณรายได้จากสวนยางพารา | Kamnuanlek';
const pageDescription = 'คำนวณรายได้ยางพารา ผลผลิตยางแผ่น ยางถ้วย น้ำยางสด ราคาตลาด กำไรต่อไร่';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0486-รายได้ยาง/`;
const faqData = [
  { question: 'ผลผลิตยางพาราต่อไร่เฉลี่ยเท่าไหร่?', answer: 'ยางพาราไทยผลผลิตเฉลี่ย 200-300 กก./ไร่/ปี (น้ำหนักยางแห้ง) สวนดูแลดีอาจถึง 350-400 กก./ไร่/ปี กรีดได้ตั้งแต่ปีที่ 7 ให้ผลนาน 25-30 ปี' },
  { question: 'ราคายางพาราปัจจุบันเท่าไหร่?', answer: 'ราคายางแผ่นรมควันชั้น 3 (RSS3) ประมาณ 55-75 บาท/กก. น้ำยางสด 35-55 บาท/กก. ราคาผันผวนตามตลาดโลก ติดตามที่ สกย. หรือ RAOT' },
  { question: 'ยางถ้วยหรือยางแผ่นขายได้ราคาดีกว่า?', answer: 'ยางแผ่นรมควันได้ราคาสูงกว่ายางก้อนถ้วย 5-10 บาท/กก. แต่ต้องใช้แรงงานและอุปกรณ์เพิ่ม ยางถ้วยสะดวกกว่าสำหรับสวนขนาดเล็ก' },
  { question: 'ช่วงฤดูแล้งกรีดยางได้ไหม?', answer: 'ยางผลัดใบเดือนกุมภาพันธ์-เมษายน กรีดไม่ได้หรือได้น้อยมาก ช่วงฝนตกหนักกรีดไม่ได้ ทำให้กรีดได้จริงประมาณ 250-280 วัน/ปี' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณรายได้จากสวนยางพารา">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณรายได้จากสวนยางพารา</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณรายได้และกำไรจากสวนยางพาราต่อปี</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="rubber_area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่สวนยาง (ไร่)</label><input type="number" id="rubber_area" min="1" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="rubber_yield_rai" class="block text-sm font-medium text-gray-700 mb-1">ผลผลิตต่อไร่ต่อปี (กก.)</label><input type="number" id="rubber_yield_rai" min="1" placeholder="เช่น 250" value="250" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="rubber_price_kg" class="block text-sm font-medium text-gray-700 mb-1">ราคายาง (บาท/กก.)</label><input type="text" id="rubber_price_kg" inputmode="decimal" placeholder="เช่น 60" value="60" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="rubber_cost_rai" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนดูแลสวนต่อไร่/ปี (บาท)</label><input type="text" id="rubber_cost_rai" inputmode="decimal" placeholder="เช่น 3000" value="3000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้รวมต่อปี</p><p id="rubber_revenue" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">กำไรสุทธิต่อปี</p><p id="rubber_profit" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const area = parseFloat((document.getElementById('rubber_area') as HTMLInputElement).value) || 0;
      const yieldRai = parseFloat((document.getElementById('rubber_yield_rai') as HTMLInputElement).value) || 0;
      const price = parseFloat((document.getElementById('rubber_price_kg') as HTMLInputElement).value) || 0;
      const costRai = parseFloat((document.getElementById('rubber_cost_rai') as HTMLInputElement).value) || 0;
      const revenue = area * yieldRai * price;
      const totalCost = area * costRai;
      const profit = revenue - totalCost;
      (document.getElementById('rubber_revenue') as HTMLElement).textContent = Math.round(revenue).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('rubber_profit') as HTMLElement).textContent = Math.round(profit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('rubber-plantation-income');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
