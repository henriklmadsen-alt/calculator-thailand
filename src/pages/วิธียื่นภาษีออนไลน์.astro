---
import BaseLayout from '../layouts/BaseLayout.astro';

const howtoSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to File Thai Income Tax Online (e-Filing)',
  description: 'Step-by-step guide to filing your Thai personal income tax return online through the Revenue Department e-Filing system.',
  estimatedCost: { '@type': 'PriceSpecification', priceCurrency: 'THB', price: '0' },
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Gather Your Documents', text: 'Collect all income documents: withholding tax certificates (50 tawi), Form ND.1 from employer, and receipts for deductions.' },
    { '@type': 'HowToStep', position: 2, name: 'Go to Revenue Department Website', text: 'Visit efiling.rd.go.th or the Revenue Department website.' },
    { '@type': 'HowToStep', position: 3, name: 'Login or Register', text: 'Log in with your Tax ID (เลขประจำตัวผู้เสียภาษี) or register if first time. You can also use your Thai National ID.' },
    { '@type': 'HowToStep', position: 4, name: 'Select Tax Form', text: 'Choose ภ.ง.ด.91 (employees with only salary income) or ภ.ง.ด.90 (self-employed or multiple income sources).' },
    { '@type': 'HowToStep', position: 5, name: 'Enter Income and Deductions', text: 'Fill in your income, select all applicable deductions and allowances. The system calculates tax automatically.' },
    { '@type': 'HowToStep', position: 6, name: 'Review and Submit', text: 'Review your return, verify calculations, then submit. If tax is owed, pay online via QR code, credit card, or bank transfer.' },
  ]
};
---

<BaseLayout
  title="วิธียื่นภาษีเงินได้ออนไลน์ e-Filing ทีละขั้นตอน ปี 2569 | Kamnuanlek"
  description="วิธียื่นแบบภาษีเงินได้บุคคลธรรมดาออนไลน์ผ่านระบบ e-Filing กรมสรรพากร ทีละขั้นตอน เอกสารที่ต้องใช้ กำหนดยื่น และวิธีชำระภาษี"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "วิธียื่นภาษีเงินได้ออนไลน์ e-Filing ทีละขั้นตอน ปี 2569", "item": "https://www.kamnuanlek.com/วิธียื่นภาษีออนไลน์/"}
    ]
  }</script>
  <script type="application/ld+json" set:html={JSON.stringify(howtoSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">วิธียื่นภาษีเงินได้ออนไลน์ (e-Filing) ทีละขั้นตอน</h1>

    <div class="mb-12 p-6 bg-blue-50 border border-blue-200 rounded-lg">
      <p class="text-lg text-gray-800">
        การยื่นภาษีเงินได้บุคคลธรรมดาออนไลน์ (e-Filing) ทำได้ง่ายและฟรี ทำตามขั้นตอนนี้เพื่อยื่นแบบ ภ.ง.ด.91 หรือ ภ.ง.ด.90 ได้อย่างถูกต้อง
      </p>
      <div class="mt-4 flex gap-3">
        <div class="p-3 bg-white rounded-lg border border-blue-200">
          <p class="font-semibold text-gray-900 text-sm">กำหนดยื่นกระดาษ</p>
          <p class="text-gray-700 text-sm">31 มีนาคม</p>
        </div>
        <div class="p-3 bg-white rounded-lg border border-blue-200">
          <p class="font-semibold text-gray-900 text-sm">กำหนดยื่นออนไลน์</p>
          <p class="text-gray-700 text-sm">8 เมษายน (ขยายเวลา)</p>
        </div>
      </div>
    </div>

    <div class="space-y-6 mb-12">
      <h2 class="text-2xl font-bold text-gray-900">คู่มือทีละขั้นตอน</h2>
      {[
        { num: 1, title: 'เตรียมเอกสาร', content: ['หนังสือรับรองการหักภาษี ณ ที่จ่าย จากนายจ้าง', 'สรุปรายได้จากนายจ้าง (แบบ ND.1)', 'ใบเสร็จค่าลดหย่อน: ประกัน เงินสมทบ RMF/SSF บริจาค', 'หนังสือรับรองประกันสังคม'], icon: '📋' },
        { num: 2, title: 'เข้าระบบ e-Filing กรมสรรพากร', content: ['เว็บไซต์: efiling.rd.go.th', 'เปิดให้บริการมกราคม – เมษายนทุกปี', 'รองรับทั้งคอมพิวเตอร์และมือถือ'], icon: '🌐' },
        { num: 3, title: 'เข้าสู่ระบบหรือลงทะเบียน', content: ['ใช้เลขประจำตัวผู้เสียภาษี 13 หลัก', 'หรือลงทะเบียนด้วยบัตรประชาชน', 'ผู้ใช้ครั้งแรก: ลงทะเบียนล่วงหน้าก่อนถึงกำหนด'], icon: '🔐' },
        { num: 4, title: 'เลือกแบบภาษีที่ถูกต้อง', content: ['ภ.ง.ด.91: เฉพาะผู้มีรายได้จากเงินเดือนจากนายจ้างเดียวเท่านั้น', 'ภ.ง.ด.90: กรณีมีรายได้ฟรีแลนซ์ ค่าเช่า การลงทุน หรือหลายนายจ้าง', 'ไม่แน่ใจ ให้เลือก ภ.ง.ด.90'], icon: '📝' },
        { num: 5, title: 'กรอกรายได้และค่าลดหย่อน', content: ['กรอกเงินเดือนรวมจากหนังสือรับรอง', 'เลือกค่าลดหย่อนที่มีสิทธิ์ (ระบบแสดงตัวเลือก)', 'กรอกค่าลดหย่อนส่วนตัวและผู้อยู่ในความดูแล', 'เพิ่มค่าลดหย่อนเสริม: ประกัน RMF SSF บริจาค'], icon: '✏️' },
        { num: 6, title: 'ตรวจสอบและยื่น', content: ['ตรวจสอบว่ารายได้ที่ต้องเสียภาษีตรงกับที่คำนวณ', 'ยืนยันยอดภาษีที่ต้องชำระ', 'ยื่นแบบ', 'หากมีภาษีค้าง: ชำระออนไลน์ผ่าน QR code ธนาคาร หรือบัตรเครดิต'], icon: '✅' },
      ].map((step) => (
        <div class="flex gap-4 p-6 bg-white border border-gray-200 rounded-lg">
          <div class="flex-shrink-0 text-3xl">{step.icon}</div>
          <div class="flex-grow">
            <div class="flex gap-3 items-center mb-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center font-bold text-sm">{step.num}</span>
              <h3 class="text-lg font-bold text-gray-900">{step.title}</h3>
            </div>
            <ul class="space-y-1">
              {step.content.map((item) => (
                <li class="flex gap-2 text-gray-700 text-sm"><span class="text-primary-600">•</span>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="p-6 bg-green-50 border border-green-200 rounded-lg mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-4">คำนวณก่อนยื่น</h2>
      <p class="text-gray-700 mb-4">ใช้เครื่องคำนวณของเราเพื่อทราบยอดภาษีก่อนเข้า e-Filing:</p>
      <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-medium">
        คำนวณภาษีเงินได้ →
      </a>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">แหล่งข้อมูลที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/อัตราภาษีเงินได้2569/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 อัตราขั้นภาษีปี 2569</span>
          <p class="text-gray-600 text-sm mt-2">อัตราและค่าลดหย่อนทั้งหมด</p>
        </a>
        <a href="/ตรวจสอบหักลดหย่อนภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">✅ เช็กลิสต์ลดหย่อน</span>
          <p class="text-gray-600 text-sm mt-2">ค่าลดหย่อนที่มีสิทธิ์ทั้งหมด</p>
        </a>
        <a href="/ปฏิทินภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📅 ปฏิทินภาษี</span>
          <p class="text-gray-600 text-sm mt-2">กำหนดยื่นภาษีทุกประเภท</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
