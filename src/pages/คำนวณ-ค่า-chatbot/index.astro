---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ ค่าบริการแชทบอต 2569 | Calculator Thailand';
const pageDescription = 'คำนวณค่า Chatbot Platform (Facebook, Line, Website) ประเมิน ROI ลดค่า Support';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่า-chatbot/`;

const faqData = [
  {
    question: 'ค่า Chatbot ทั่วไป?',
    answer: 'ฟรี Platform: ManyChat, Chatfuel 0-500 บาท/เดือน Premium: 2,000-10,000 บาท/เดือน Custom AI Bot: 20,000+ บาท',
  },
  {
    question: 'ROI Chatbot ขึ้นอยู่กับอะไร?',
    answer: 'จำนวน Conversation ต่อวัน, Automation Accuracy, Sales Conversion จาก Bot ลดเวลา Support',
  },
  {
    question: 'ควรเลือก Platform ไหน?',
    answer: 'Facebook: ยิ่งผู้ใช้ มี Free Plan ManyChat ดี Line: ยอดนิยมไทย, Website: Chatfuel, Drift',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าแชทบอต',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าแชทบอต">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🤖 คำนวณค่าบริการแชทบอต
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่า Chatbot Platform ประเมิน ROI ลดค่า Support
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="chatbot-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="monthly-fee" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Chatbot/เดือน (บาท)
            </label>
            <input
              type="text"
              id="monthly-fee"
              inputmode="numeric"
              placeholder="เช่น 5000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="daily-conversations" class="block text-sm font-medium text-gray-700 mb-1">
              Conversation ต่อวัน
            </label>
            <input
              type="text"
              id="daily-conversations"
              inputmode="numeric"
              placeholder="เช่น 100"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="saved-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Support ลด/เดือน (บาท)
            </label>
            <input
              type="text"
              id="saved-cost"
              inputmode="numeric"
              placeholder="เช่น 10000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="conversion-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Conversion Rate (%)
            </label>
            <input
              type="text"
              id="conversion-rate"
              inputmode="numeric"
              placeholder="เช่น 2"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="avg-sale" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าขายเฉลี่ย/Conversion (บาท)
          </label>
          <input
            type="text"
            id="avg-sale"
            inputmode="numeric"
            placeholder="เช่น 1000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณค่า
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่า Chatbot</div>
            <div id="res-chatbot-cost" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าลด Support</div>
            <div id="res-saved" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดขายเพิ่ม</div>
            <div id="res-extra-sales" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ROI %</div>
            <div id="res-roi" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณ-ค่า-chatbot/" />
    <RelatedCalculators currentHref="/คำนวณ-ค่า-chatbot/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('chatbot-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const monthlyFee = parseNum((document.getElementById('monthly-fee') as HTMLInputElement).value);
      const dailyConversations = parseNum((document.getElementById('daily-conversations') as HTMLInputElement).value);
      const savedCost = parseNum((document.getElementById('saved-cost') as HTMLInputElement).value);
      const conversionRate = parseNum((document.getElementById('conversion-rate') as HTMLInputElement).value);
      const avgSale = parseNum((document.getElementById('avg-sale') as HTMLInputElement).value);

      if (monthlyFee <= 0) { (document.getElementById('monthly-fee') as HTMLInputElement).focus(); return; }

      const conversions = (dailyConversations * 30 * conversionRate) / 100;
      const extraSales = conversions * avgSale;
      const totalBenefit = savedCost + extraSales;
      const roi = monthlyFee > 0 ? ((totalBenefit - monthlyFee) / monthlyFee) * 100 : 0;

      (document.getElementById('res-chatbot-cost') as HTMLElement).textContent = fmt(monthlyFee) + ' บาท';
      (document.getElementById('res-saved') as HTMLElement).textContent = fmt(savedCost) + ' บาท';
      (document.getElementById('res-extra-sales') as HTMLElement).textContent = fmt(extraSales) + ' บาท';
      (document.getElementById('res-roi') as HTMLElement).textContent = roi.toFixed(0) + '%';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('chatbot-cost');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('chatbot-cost');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
