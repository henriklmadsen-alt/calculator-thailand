---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเป้าหมายการออม 2569 | วางแผนออมเงินให้ถึงเป้าหมาย | Kamnuanlek';
const pageDescription = 'คำนวณเป้าหมายการออมปี 2569 ว่าต้องออมนานแค่ไหนหรือได้เงินเท่าไร จากเงินต้นเริ่มต้น เงินออมรายเดือน และอัตราดอกเบี้ย เพื่อวางแผนการเงินอย่างมีประสิทธิภาพ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเป้าหมายการออม/`;

const faqData = [
  {
    question: 'สูตรคำนวณเป้าหมายการออมคืออะไร?',
    answer: 'ใช้สูตร Future Value: FV = PV×(1+r)^n + PMT×((1+r)^n − 1)/r โดย r คืออัตราดอกเบี้ยรายเดือน (ต่อปี÷12) และ n คือจำนวนเดือน เช่น ออมเดือนละ 5,000 บาท ดอกเบี้ย 3% ต่อปี เป็นเวลา 10 ปี จะมีเงินรวมประมาณ 697,000 บาท',
  },
  {
    question: 'ควรเริ่มออมเงินเดือนละเท่าไรเพื่อให้ถึงเป้าหมาย?',
    answer: 'ขึ้นอยู่กับเป้าหมายและระยะเวลา กฎทั่วไปคือออมอย่างน้อย 20% ของรายได้ หากมีเงินต้นเริ่มต้นและผลตอบแทนจากการลงทุนที่ดี อาจลดเงินออมรายเดือนลงได้ ใช้เครื่องคำนวณนี้เพื่อหาตัวเลขที่เหมาะกับเป้าหมายของคุณ',
  },
  {
    question: 'ดอกเบี้ยทบต้นช่วยให้ถึงเป้าหมายเร็วขึ้นอย่างไร?',
    answer: 'ดอกเบี้ยทบต้นทำให้เงินเติบโตแบบทวีคูณ เพราะดอกเบี้ยที่ได้รับในแต่ละเดือนจะถูกรวมเป็นเงินต้นสำหรับการคำนวณงวดถัดไป ยิ่งฝากนานยิ่งเห็นผลชัดเจน การเริ่มออมตั้งแต่เนิ่นๆ จึงสำคัญมาก',
  },
  {
    question: 'ควรเลือกออมในบัญชีใดเพื่อผลตอบแทนสูงสุด?',
    answer: 'บัญชีออมทรัพย์พิเศษและเงินฝากประจำให้ดอกเบี้ย 1.5-2.5% ต่อปี กองทุนรวมตลาดเงินประมาณ 1.5-2% ส่วนกองทุน SSF/RMF อาจให้ผลตอบแทนสูงกว่า 5-8% ระยะยาว แต่มีความเสี่ยงสูงกว่า ควรกระจายตามระยะเวลาและความเสี่ยงที่รับได้',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเป้าหมายการออม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเป้าหมายการออม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเป้าหมายการออม 2569 — วางแผนออมเงินให้ถึงเป้าหมาย
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณยอดเงินรวมเมื่อครบกำหนดจากเงินต้น เงินออมรายเดือน และอัตราดอกเบี้ยทบต้น พร้อมตารางยอดเงินรายปี
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="savings-goal-form" class="space-y-5">
        <p id="savings-goal-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="savings-goal-principal" class="block text-sm font-medium text-gray-700 mb-1">
              เงินต้นเริ่มต้น (บาท)
            </label>
            <input
              type="text"
              id="savings-goal-principal"
              inputmode="numeric"
              placeholder="เช่น 50,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="savings-goal-principal-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="savings-goal-monthly" class="block text-sm font-medium text-gray-700 mb-1">
              เงินออมรายเดือน (บาท)
            </label>
            <input
              type="text"
              id="savings-goal-monthly"
              inputmode="numeric"
              placeholder="เช่น 5,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="savings-goal-monthly-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="savings-goal-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราดอกเบี้ย (% ต่อปี)
            </label>
            <input
              type="text"
              id="savings-goal-rate"
              inputmode="decimal"
              placeholder="เช่น 3.0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="savings-goal-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="savings-goal-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลา (ปี)
            </label>
            <input
              type="text"
              id="savings-goal-years"
              inputmode="numeric"
              placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="savings-goal-years-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button
          type="submit"
          id="savings-goal-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดเงินรวมเมื่อถึงเป้า</div>
            <div id="res-total-amount" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยที่ได้รับ</div>
            <div id="res-interest-earned" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินออมรวมทั้งหมด</div>
            <div id="res-total-saved" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">อัตราผลตอบแทนสุทธิ</div>
            <div id="res-return-rate" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินต้นเริ่มต้น</span>
            <span id="res-principal" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินออมรายเดือน</span>
            <span id="res-monthly" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">อัตราดอกเบี้ย</span>
            <span id="res-rate" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ระยะเวลา</span>
            <span id="res-years" class="font-medium">-</span>
          </div>
        </div>

        <details class="mt-4">
          <summary class="cursor-pointer font-semibold text-gray-900 hover:text-primary-600 mb-2">
            ตารางยอดเงินรายปี (คลิกเพื่อดู)
          </summary>
          <div class="overflow-x-auto mt-2">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-gray-500 border-b border-gray-200">
                  <th class="py-2 pr-2">ปีที่</th>
                  <th class="py-2 pr-2 text-right">เงินออมสะสม</th>
                  <th class="py-2 pr-2 text-right">ดอกเบี้ยสะสม</th>
                  <th class="py-2 text-right">ยอดรวม</th>
                </tr>
              </thead>
              <tbody id="yearly-breakdown-body"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณเป้าหมายการออม</h2>

      <p>
        การวางแผนออมเงินให้ถึงเป้าหมายต้องอาศัยการคำนวณที่แม่นยำ โดยพิจารณาทั้งเงินต้น เงินออมรายเดือน
        อัตราดอกเบี้ย และระยะเวลา เครื่องคำนวณนี้ใช้สูตร Future Value ด้วยการทบต้นรายเดือน
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณ</h3>
      <p>
        FV = PV × (1+r)^n + PMT × ((1+r)^n − 1) / r
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>PV = เงินต้นเริ่มต้น</li>
        <li>PMT = เงินออมรายเดือน</li>
        <li>r = อัตราดอกเบี้ยรายเดือน (อัตราต่อปี ÷ 12)</li>
        <li>n = จำนวนเดือนทั้งหมด</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการคำนวณ</h3>
      <p>เงินต้น 100,000 บาท ออมเดือนละ 5,000 บาท ดอกเบี้ย 3% ต่อปี เป็นเวลา 10 ปี:</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>เงินออมรวม: 100,000 + (5,000 × 120) = <strong>700,000 บาท</strong></li>
        <li>ยอดรวมพร้อมดอกเบี้ย: ประมาณ <strong>830,000 บาท</strong></li>
        <li>ดอกเบี้ยที่ได้รับ: ประมาณ <strong>130,000 บาท</strong></li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณเป้าหมายการออม/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      อัตราดอกเบี้ยจริงอาจแตกต่างตามเงื่อนไขของสถาบันการเงิน ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    function hasInvalidNumber(v: string): boolean {
      const normalized = v.replace(/,/g, '').trim();
      return normalized !== '' && Number.isNaN(Number(normalized));
    }

    const form = document.getElementById('savings-goal-form') as HTMLFormElement;
    const submitBtn = document.getElementById('savings-goal-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('savings-goal-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    const principalInput = document.getElementById('savings-goal-principal') as HTMLInputElement;
    const monthlyInput = document.getElementById('savings-goal-monthly') as HTMLInputElement;
    const rateInput = document.getElementById('savings-goal-rate') as HTMLInputElement;
    const yearsInput = document.getElementById('savings-goal-years') as HTMLInputElement;

    function setFieldError(id: string, msg: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.remove('hidden');
    }

    function clearFieldError(id: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      ['savings-goal-principal-error', 'savings-goal-monthly-error', 'savings-goal-rate-error', 'savings-goal-years-error'].forEach(clearFieldError);
    }

    [principalInput, monthlyInput, rateInput, yearsInput].forEach(input => {
      input.addEventListener('input', clearValidation);
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearValidation();

      const principal = parseNum(principalInput.value);
      const monthly = parseNum(monthlyInput.value);
      const annualRate = parseFloat(rateInput.value.replace(/,/g, '')) || 0;
      const years = parseInt(yearsInput.value.replace(/,/g, '')) || 0;

      let hasError = false;
      if (hasInvalidNumber(principalInput.value)) { setFieldError('savings-goal-principal-error', 'รูปแบบข้อมูลไม่ถูกต้อง'); hasError = true; }
      if (hasInvalidNumber(monthlyInput.value)) { setFieldError('savings-goal-monthly-error', 'รูปแบบข้อมูลไม่ถูกต้อง'); hasError = true; }
      if (hasInvalidNumber(rateInput.value) || annualRate <= 0) { setFieldError('savings-goal-rate-error', 'กรุณากรอกอัตราดอกเบี้ยที่ถูกต้อง'); hasError = true; }
      if (years <= 0 || years > 50) { setFieldError('savings-goal-years-error', 'กรุณากรอกระยะเวลา 1-50 ปี'); hasError = true; }

      if (hasError) {
        formError.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('savings-goal');

      const r = annualRate / 100 / 12;
      const n = years * 12;

      let balance = principal;
      let totalDeposited = principal;
      let totalInterest = 0;

      interface YearRow { year: number; deposited: number; interest: number; balance: number; }
      const yearlyRows: YearRow[] = [];

      for (let month = 1; month <= n; month++) {
        const interest = balance * r;
        totalInterest += interest;
        balance += interest;
        if (month > 1 || monthly > 0) {
          balance += monthly;
          totalDeposited += monthly;
        }
        if (month % 12 === 0) {
          yearlyRows.push({ year: month / 12, deposited: totalDeposited, interest: totalInterest, balance });
        }
      }

      const returnRate = totalDeposited > 0 ? (totalInterest / totalDeposited) * 100 : 0;

      (document.getElementById('res-total-amount') as HTMLElement).textContent = fmt(balance) + ' บาท';
      (document.getElementById('res-interest-earned') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total-saved') as HTMLElement).textContent = fmt(totalDeposited) + ' บาท';
      (document.getElementById('res-return-rate') as HTMLElement).textContent = returnRate.toFixed(2) + '%';
      (document.getElementById('res-principal') as HTMLElement).textContent = fmt(principal) + ' บาท';
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthly) + ' บาท/เดือน';
      (document.getElementById('res-rate') as HTMLElement).textContent = annualRate.toFixed(2) + '% ต่อปี';
      (document.getElementById('res-years') as HTMLElement).textContent = years + ' ปี';

      const tbody = document.getElementById('yearly-breakdown-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      yearlyRows.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';
        tr.innerHTML = `
          <td class="py-2 pr-2 text-gray-600">${row.year}</td>
          <td class="py-2 pr-2 text-right">${fmt(row.deposited)}</td>
          <td class="py-2 pr-2 text-right">${fmt(row.interest)}</td>
          <td class="py-2 text-right font-medium">${fmt(row.balance)}</td>
        `;
        tbody.appendChild(tr);
      });

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('savings-goal');
      trackCalculatorUsed('savings-goal');
    });
  </script>
</BaseLayout>
