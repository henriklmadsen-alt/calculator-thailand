---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'เปรียบเทียบ Deductible กับเบี้ยประกัน 2569 | คุ้มไหมเลือก Deductible สูง | Kamnuanlek';
const pageDescription = 'เปรียบเทียบ Deductible กับเบี้ยประกัน 2569 คำนวณว่าการเลือก deductible สูงเพื่อประหยัดเบี้ยคุ้มค่าไหม break-even point จำนวนปีคืนทุน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/เปรียบเทียบdeductibleกับเบี้ย/`;

const faqData = [
  {
    question: 'Deductible คืออะไร?',
    answer: 'Deductible หรือค่าลดหย่อนความรับผิด คือส่วนที่ผู้เอาประกันต้องรับผิดชอบเองในทุกครั้งที่เคลม เช่น deductible 5,000 บาท หมายถึงคุณจ่ายเองก่อน 5,000 บาท แล้วบริษัทประกันจ่ายส่วนที่เหลือ',
  },
  {
    question: 'Deductible สูงขึ้น เบี้ยจะลดลงไหม?',
    answer: 'ใช่ การเลือก deductible สูงขึ้นจะทำให้เบี้ยประกันลดลง เพราะคุณรับความเสี่ยงส่วนแรกเอง ทำให้บริษัทประกันมีภาระน้อยลง ส่วนลดเบี้ยจะมากหรือน้อยขึ้นกับประเภทประกัน',
  },
  {
    question: 'ควรเลือก Deductible สูงหรือต่ำ?',
    answer: 'ถ้าคุณมีเงินสำรองพอและไม่เคลมบ่อย เลือก deductible สูงเพื่อประหยัดเบี้ย แต่ถ้ากังวลว่าไม่มีเงินสดจ่าย deductible ตอนเคลม ให้เลือก deductible ต่ำ แม้เบี้ยจะแพงกว่า',
  },
  {
    question: 'Break-even point ของ Deductible คำนวณอย่างไร?',
    answer: 'Break-even = ส่วนต่าง deductible ÷ ส่วนลดเบี้ยต่อปี คือจำนวนปีที่เงินเบี้ยที่ประหยัดได้จะเท่ากับ deductible ที่เพิ่มขึ้น หากเคลมก่อน break-even จะขาดทุน หากเคลมหลัง break-even จะได้กำไร',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องเปรียบเทียบ Deductible กับเบี้ยประกัน 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="เปรียบเทียบ Deductible กับเบี้ย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">วิเคราะห์ความคุ้มค่าของ Deductible</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณ break-even point และจำนวนปีคืนทุน</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">เปรียบเทียบ Deductible กับเบี้ยประกัน 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">คำนวณว่าการเพิ่ม deductible เพื่อลดเบี้ยประกันคุ้มค่าหรือไม่ และต้องใช้กี่ปีจึงจะคืนทุน</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">เปรียบเทียบสองแผน</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>

        <div class="grid sm:grid-cols-2 gap-6">
          <div class="bg-blue-50 rounded-lg p-4 border border-blue-200">
            <h3 class="font-semibold text-blue-800 mb-3">แผน A — Deductible ต่ำ</h3>
            <div class="space-y-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Deductible (บาท)</label>
                <input type="text" id="ded-a" inputmode="numeric" placeholder="เช่น 5,000"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">เบี้ยประกัน/ปี (บาท)</label>
                <input type="text" id="premium-a" inputmode="numeric" placeholder="เช่น 15,000"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
              </div>
            </div>
          </div>

          <div class="bg-green-50 rounded-lg p-4 border border-green-200">
            <h3 class="font-semibold text-green-800 mb-3">แผน B — Deductible สูง</h3>
            <div class="space-y-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Deductible (บาท)</label>
                <input type="text" id="ded-b" inputmode="numeric" placeholder="เช่น 20,000"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">เบี้ยประกัน/ปี (บาท)</label>
                <input type="text" id="premium-b" inputmode="numeric" placeholder="เช่น 10,000"
                  class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
              </div>
            </div>
          </div>
        </div>

        <button type="button" id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">
          เปรียบเทียบ
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการเปรียบเทียบ</h2>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden mb-4">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b border-gray-200">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
      <div class="rounded-lg p-4 border" id="verdict-box">
        <p class="font-semibold" id="verdict-title">-</p>
        <p class="text-sm mt-1" id="verdict-detail">-</p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">หลักการเลือก Deductible</h2>
      <p>กฎทั่วไปคือ เลือก deductible สูงขึ้นเมื่อ: (1) คุณมีเงินสำรองฉุกเฉินเพียงพอที่จะจ่าย deductible ได้ทันที (2) คุณไม่มีประวัติเคลมบ่อย (3) ส่วนลดเบี้ยที่ได้คืนทุนภายใน 3-5 ปี</p>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/เปรียบเทียบdeductibleกับเบี้ย/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการวิเคราะห์เชิงคณิตศาสตร์ ควรพิจารณาปัจจัยส่วนตัวและสถานการณ์จริงประกอบด้วย
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const dedA = parseNum((document.getElementById('ded-a') as HTMLInputElement).value);
      const premA = parseNum((document.getElementById('premium-a') as HTMLInputElement).value);
      const dedB = parseNum((document.getElementById('ded-b') as HTMLInputElement).value);
      const premB = parseNum((document.getElementById('premium-b') as HTMLInputElement).value);
      const err = document.getElementById('form-error')!;

      if (premA < 1000 || premB < 1000) {
        err.textContent = 'กรุณากรอกเบี้ยประกันทั้งสองแผน';
        err.classList.remove('hidden'); return;
      }
      if (dedB <= dedA) {
        err.textContent = 'Deductible แผน B ต้องสูงกว่าแผน A';
        err.classList.remove('hidden'); return;
      }
      if (premB >= premA) {
        err.textContent = 'เบี้ยแผน B ควรต่ำกว่าแผน A (Deductible สูงกว่าแต่เบี้ยควรถูกกว่า)';
        err.classList.remove('hidden'); return;
      }
      err.classList.add('hidden');

      const dedDiff = dedB - dedA;
      const premSaving = premA - premB;
      const breakeven = dedDiff / premSaving;

      const rows = [
        ['ส่วนต่าง Deductible (B - A)', '', `${fmt(dedDiff)} บาท`],
        ['เบี้ยที่ประหยัดได้ต่อปี (A - B)', '', `${fmt(premSaving)} บาท`],
        ['Break-even Point', 'ส่วนต่าง deductible ÷ เบี้ยที่ประหยัด', `${breakeven.toFixed(1)} ปี`],
        ['5 ปี ประหยัดเบี้ยรวม', '', `${fmt(premSaving * 5)} บาท`],
        ['5 ปี ความเสี่ยง deductible เพิ่ม', '(หากเคลม 1 ครั้ง)', `${fmt(dedDiff)} บาท`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td>
          <td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td>
        </tr>`).join('');

      const verdictBox = document.getElementById('verdict-box')!;
      const verdictTitle = document.getElementById('verdict-title')!;
      const verdictDetail = document.getElementById('verdict-detail')!;

      if (breakeven <= 3) {
        verdictBox.className = 'rounded-lg p-4 border bg-green-50 border-green-200 text-green-800';
        verdictTitle.textContent = `แนะนำเลือกแผน B (Deductible สูง) — คืนทุนใน ${breakeven.toFixed(1)} ปี`;
        verdictDetail.textContent = `ประหยัดเบี้ย ${fmt(premSaving)} บาท/ปี คืนทุน deductible ที่เพิ่มขึ้น ${fmt(dedDiff)} บาท ภายใน ${breakeven.toFixed(1)} ปี ถือว่าคุ้มค่ามาก`;
      } else if (breakeven <= 5) {
        verdictBox.className = 'rounded-lg p-4 border bg-yellow-50 border-yellow-200 text-yellow-800';
        verdictTitle.textContent = `ขึ้นอยู่กับความเสี่ยงส่วนตัว — คืนทุนใน ${breakeven.toFixed(1)} ปี`;
        verdictDetail.textContent = `หากคุณไม่เคยเคลมและมีเงินสำรอง แผน B คุ้มกว่า แต่หากกังวลเรื่องเงินสด ให้ใช้แผน A`;
      } else {
        verdictBox.className = 'rounded-lg p-4 border bg-red-50 border-red-200 text-red-800';
        verdictTitle.textContent = `พิจารณาแผน A — คืนทุนนาน ${breakeven.toFixed(1)} ปี`;
        verdictDetail.textContent = `ส่วนลดเบี้ยน้อยเกินไปเทียบกับ deductible ที่เพิ่มขึ้น แผน A อาจคุ้มกว่าในระยะสั้น`;
      }

      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
