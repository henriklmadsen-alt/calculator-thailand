---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเปรียบเทียบฟรีแลนซ์กับพนักงานประจำ ต้นทุนจริง ปี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณและเปรียบเทียบต้นทุนจริงระหว่างการจ้างพนักงานประจำกับฟรีแลนซ์ รวม SSF PVD โบนัส VAT WHT เพื่อตัดสินใจได้อย่างถูกต้อง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเปรียบเทียบฟรีแลนซ์กับพนักงานประจำ/`;

const faqData = [
  {
    question: 'ต้นทุนจริงของพนักงานประจำสูงกว่าเงินเดือนเท่าไร?',
    answer: 'โดยทั่วไปต้นทุนจริงสูงกว่าเงินเดือนประมาณ 15-30% เมื่อรวม SSF 5% PVD (ถ้ามี) โบนัส และสวัสดิการอื่นๆ เช่น เงินเดือน 30,000 บาท ต้นทุนจริงอาจอยู่ที่ 35,000-40,000 บาท',
  },
  {
    question: 'VAT 7% และ WHT 3% สำหรับฟรีแลนซ์คืออะไร?',
    answer: 'VAT 7% คือภาษีมูลค่าเพิ่มที่ฟรีแลนซ์ที่จดทะเบียนภาษีมูลค่าเพิ่มต้องบวกเพิ่มในใบแจ้งหนี้ WHT 3% คือภาษีหัก ณ ที่จ่ายที่ผู้ว่าจ้างหักออกจากค่าจ้างก่อนจ่าย ทำให้ฟรีแลนซ์ได้รับเงินน้อยลง 3%',
  },
  {
    question: 'จ้างฟรีแลนซ์ถูกกว่าพนักงานประจำเสมอหรือไม่?',
    answer: 'ไม่เสมอไป ขึ้นอยู่กับค่าจ้าง ชั่วโมงทำงาน และสวัสดิการ หากงานต้องการความต่อเนื่องสูงและเต็มเวลา พนักงานประจำอาจคุ้มค่ากว่า ขณะที่งานโปรเจกต์หรือชั่วคราว ฟรีแลนซ์อาจเหมาะกว่า',
  },
  {
    question: 'Break-even คำนวณอย่างไร?',
    answer: 'Break-even ในที่นี้คือจุดที่ต้นทุนพนักงานประจำเท่ากับต้นทุนฟรีแลนซ์ต่อเดือน คำนวณโดยเปรียบเทียบต้นทุนรายปีของทั้งสองแบบ รวมถึงโบนัส SSF PVD กับค่าจ้างฟรีแลนซ์รายเดือน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเปรียบเทียบฟรีแลนซ์กับพนักงานประจำ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเปรียบเทียบฟรีแลนซ์กับพนักงานประจำ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">เปรียบเทียบต้นทุนจริง: พนักงานประจำ vs ฟรีแลนซ์</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณต้นทุนรายเดือนและรายปีแบบครบถ้วน รวม SSF PVD โบนัส VAT และ WHT</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับผู้บริหาร HR และเจ้าของธุรกิจที่ต้องตัดสินใจรูปแบบการจ้างงาน</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณเปรียบเทียบฟรีแลนซ์กับพนักงานประจำ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกข้อมูลพนักงานประจำและฟรีแลนซ์ทั้งสองฝั่ง ระบบจะคำนวณต้นทุนจริงและแสดง Break-even Analysis
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="comp-form" class="space-y-6">
        <p id="comp-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div>
          <h3 class="mb-3 text-base font-semibold text-gray-800 border-b pb-2">👔 พนักงานประจำ (Employee)</h3>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="emp-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือน (บาท/เดือน)</label>
              <input type="text" id="emp-salary" inputmode="numeric" placeholder="เช่น 30,000"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
              <p id="emp-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
            </div>
            <div>
              <label for="emp-pvd" class="mb-1 block text-sm font-medium text-gray-700">PVD นายจ้าง (%) <span class="text-gray-400">(0 ถ้าไม่มี)</span></label>
              <input type="text" id="emp-pvd" inputmode="decimal" placeholder="เช่น 5"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            </div>
            <div>
              <label for="emp-bonus-months" class="mb-1 block text-sm font-medium text-gray-700">โบนัสรายปี (เดือน) <span class="text-gray-400">(0 ถ้าไม่มี)</span></label>
              <input type="text" id="emp-bonus-months" inputmode="decimal" placeholder="เช่น 1.5"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            </div>
            <div>
              <label for="emp-benefits" class="mb-1 block text-sm font-medium text-gray-700">สวัสดิการต่อเดือน (บาท) <span class="text-gray-400">(0 ถ้าไม่มี)</span></label>
              <input type="text" id="emp-benefits" inputmode="numeric" placeholder="เช่น 2,000"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            </div>
          </div>
        </div>

        <div>
          <h3 class="mb-3 text-base font-semibold text-gray-800 border-b pb-2">💼 ฟรีแลนซ์ / ผู้รับจ้าง (Contractor)</h3>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="con-fee" class="mb-1 block text-sm font-medium text-gray-700">ค่าจ้างฟรีแลนซ์ (บาท/เดือน)</label>
              <input type="text" id="con-fee" inputmode="numeric" placeholder="เช่น 35,000"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
              <p id="con-fee-error" class="mt-1 hidden text-sm text-red-600"></p>
            </div>
            <div>
              <label class="mb-1 block text-sm font-medium text-gray-700">ตัวเลือกเพิ่มเติม</label>
              <div class="space-y-2 pt-1">
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                  <input type="checkbox" id="con-vat" class="h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
                  บวก VAT 7% (ฟรีแลนซ์จด VAT)
                </label>
                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                  <input type="checkbox" id="con-wht" checked class="h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
                  หัก WHT 3% (ผู้ว่าจ้างหัก ณ ที่จ่าย)
                </label>
              </div>
            </div>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          เปรียบเทียบต้นทุน
        </button>
      </form>
    </div>

    <div id="comp-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการเปรียบเทียบ</h2>
        <div class="mb-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg bg-blue-50 p-4">
            <div class="mb-2 font-semibold text-blue-800">👔 พนักงานประจำ</div>
            <div class="space-y-1 text-sm">
              <div class="flex justify-between"><span class="text-gray-600">ต้นทุน/เดือน</span><span id="res-emp-monthly" class="font-bold text-blue-700">-</span></div>
              <div class="flex justify-between"><span class="text-gray-600">ต้นทุน/ปี</span><span id="res-emp-annual" class="font-bold text-blue-700">-</span></div>
            </div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4">
            <div class="mb-2 font-semibold text-orange-800">💼 ฟรีแลนซ์</div>
            <div class="space-y-1 text-sm">
              <div class="flex justify-between"><span class="text-gray-600">ต้นทุน/เดือน</span><span id="res-con-monthly" class="font-bold text-orange-700">-</span></div>
              <div class="flex justify-between"><span class="text-gray-600">ต้นทุน/ปี</span><span id="res-con-annual" class="font-bold text-orange-700">-</span></div>
            </div>
          </div>
        </div>
        <div id="comp-verdict" class="mb-4 rounded-lg p-4 text-center font-semibold"></div>
        <div class="space-y-2 text-sm">
          <div class="font-medium text-gray-700 mt-3 mb-1">รายละเอียดพนักงานประจำ</div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">เงินเดือน</span>
            <span id="res-emp-salary" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">SSF นายจ้าง 5%</span>
            <span id="res-emp-ssf" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">PVD นายจ้าง</span>
            <span id="res-emp-pvd" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">สวัสดิการ/เดือน</span>
            <span id="res-emp-benefits" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">โบนัสเฉลี่ย/เดือน</span>
            <span id="res-emp-bonus-monthly" class="font-medium">-</span>
          </div>
          <div class="font-medium text-gray-700 mt-3 mb-1">รายละเอียดฟรีแลนซ์</div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ค่าจ้างฐาน</span>
            <span id="res-con-fee" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">VAT 7% (ถ้ามี)</span>
            <span id="res-con-vat" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">WHT 3% (ถ้ามี — ลดต้นทุน)</span>
            <span id="res-con-wht" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ต้นทุนพนักงาน/เดือน = เงินเดือน + SSF(5%) + PVD + สวัสดิการ + (โบนัส×เงินเดือน÷12)</li>
        <li>ต้นทุนฟรีแลนซ์/เดือน = ค่าจ้าง + VAT(ถ้ามี) − WHT(ถ้ามี)</li>
        <li>WHT ลดภาระนายจ้าง เพราะจ่ายในนามผู้รับ ผู้ว่าจ้างจ่ายน้อยลง 3%</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณต้นทุนพนักงานรายเดือน/">คำนวณต้นทุนพนักงานรายเดือน</a></li>
        <li><a href="/คำนวณภาษีหัก-ณ-ที่จ่ายฟรีแลนซ์/">คำนวณภาษีหัก ณ ที่จ่ายฟรีแลนซ์</a></li>
        <li><a href="/คำนวณรายได้ฟรีแลนซ์รายเดือน/">คำนวณรายได้ฟรีแลนซ์รายเดือน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#comp-results" />
    <RelatedArticles currentHref="/คำนวณเปรียบเทียบฟรีแลนซ์กับพนักงานประจำ/" />
    <RelatedCalculators currentHref="/คำนวณเปรียบเทียบฟรีแลนซ์กับพนักงานประจำ/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการเพื่อใช้ในการตัดสินใจเบื้องต้นเท่านั้น ควรปรึกษาที่ปรึกษาด้านภาษีและกฎหมายแรงงานก่อนตัดสินใจ อัตรา VAT และ WHT อาจมีการเปลี่ยนแปลงตามกฎหมายปัจจุบัน
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }
    function setErr(id, msg) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.toggle('hidden', !msg);
    }

    const form = document.getElementById('comp-form');
    const formError = document.getElementById('comp-form-error');
    const resultBox = document.getElementById('comp-results');
    const verdictBox = document.getElementById('comp-verdict');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['emp-salary-error', 'con-fee-error'].forEach((id) => setErr(id, ''));

      const empSalary = parseNum(document.getElementById('emp-salary').value);
      const empPvd = parseNum(document.getElementById('emp-pvd').value) || 0;
      const empBonusMonths = parseNum(document.getElementById('emp-bonus-months').value) || 0;
      const empBenefits = parseNum(document.getElementById('emp-benefits').value) || 0;
      const conFee = parseNum(document.getElementById('con-fee').value);
      const conVat = document.getElementById('con-vat').checked;
      const conWht = document.getElementById('con-wht').checked;

      let hasError = false;
      if (!Number.isFinite(empSalary) || empSalary <= 0) { setErr('emp-salary-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(conFee) || conFee <= 0) { setErr('con-fee-error', 'กรอกค่าจ้างฟรีแลนซ์มากกว่า 0'); hasError = true; }
      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const ssf = Math.min(empSalary * 0.05, 750);
      const pvd = empSalary * (empPvd / 100);
      const bonusMonthly = (empSalary * empBonusMonths) / 12;
      const empMonthlyCost = empSalary + ssf + pvd + empBenefits + bonusMonthly;
      const empAnnual = empMonthlyCost * 12;

      const vatAmt = conVat ? conFee * 0.07 : 0;
      const whtAmt = conWht ? conFee * 0.03 : 0;
      const conMonthlyCost = conFee + vatAmt - whtAmt;
      const conAnnual = conMonthlyCost * 12;

      const diff = empMonthlyCost - conMonthlyCost;
      if (diff > 0) {
        verdictBox.textContent = `ฟรีแลนซ์ถูกกว่า ${formatMoney(diff)} ต่อเดือน`;
        verdictBox.className = 'mb-4 rounded-lg bg-orange-50 p-4 text-center font-semibold text-orange-700';
      } else if (diff < 0) {
        verdictBox.textContent = `พนักงานประจำถูกกว่า ${formatMoney(Math.abs(diff))} ต่อเดือน`;
        verdictBox.className = 'mb-4 rounded-lg bg-blue-50 p-4 text-center font-semibold text-blue-700';
      } else {
        verdictBox.textContent = 'ต้นทุนทั้งสองแบบเท่ากัน';
        verdictBox.className = 'mb-4 rounded-lg bg-gray-50 p-4 text-center font-semibold text-gray-700';
      }

      setText('res-emp-monthly', formatMoney(empMonthlyCost));
      setText('res-emp-annual', formatMoney(empAnnual));
      setText('res-con-monthly', formatMoney(conMonthlyCost));
      setText('res-con-annual', formatMoney(conAnnual));
      setText('res-emp-salary', formatMoney(empSalary));
      setText('res-emp-ssf', formatMoney(ssf));
      setText('res-emp-pvd', formatMoney(pvd));
      setText('res-emp-benefits', formatMoney(empBenefits));
      setText('res-emp-bonus-monthly', formatMoney(bonusMonthly));
      setText('res-con-fee', formatMoney(conFee));
      setText('res-con-vat', conVat ? formatMoney(vatAmt) : 'ไม่มี');
      setText('res-con-wht', conWht ? formatMoney(whtAmt) : 'ไม่มี');

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
