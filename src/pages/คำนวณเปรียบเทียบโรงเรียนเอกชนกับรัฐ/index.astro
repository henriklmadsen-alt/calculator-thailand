---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเปรียบเทียบโรงเรียนเอกชนกับรัฐ ปี 2569 | ต้นทุน | Kamnuanlek';
const pageDescription = 'เปรียบเทียบค่าเรียน ค่าอื่นๆ และต้นทุนรวมระหว่างโรงเรียนเอกชนกับโรงเรียนรัฐ ในประเทศไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเปรียบเทียบโรงเรียนเอกชนกับรัฐ/`;

const faqData = [
  {
    question: 'โรงเรียนรัฐกับเอกชนต่างกันในด้านค่าเรียนอย่างไร?',
    answer: 'โรงเรียนรัฐมีค่าเรียนต่ำมาก (บางแห่งฟรี ขึ้นอยู่กับระดับชั้น) ส่วนโรงเรียนเอกชนมีค่าเรียน 50,000–200,000+ บาท/ปี โรงเรียนอินเตอร์นาชั่นอาจแพงถึง 500,000+ บาท/ปี',
  },
  {
    question: 'นอกจากค่าเรียน ยังมีค่าอะไรบ้าง?',
    answer: 'มีค่ายูนิฟอร์ม หนังสือเรียน ลองทุนการศึกษา กิจกรรมอื่นๆ โรงเรียนรัฐมีค่าอื่นสักแต่น้อยมาก โรงเรียนเอกชนอาจมีค่าเพิ่มเติม 20,000–50,000 บาท/ปี',
  },
  {
    question: 'คุณภาพการศึกษาต่างกันหรือไม่?',
    answer: 'ไม่ได้เสมอ โรงเรียนรัฐที่ดี (เช่น โรงเรียนส่วนพื้นที่เขตยึดครองเดิม) มีคุณภาพเทียบเท่าโรงเรียนเอกชนมาตรฐาน สิ่งที่ต่างคือ: สิ่งอำนวยความสะดวก ขนาดชั้นเรียน และกิจกรรมเพิ่มเติม',
  },
  {
    question: 'วิธีเลือกที่ดีคืออะไร?',
    answer: 'พิจารณา: บัญชีการคณะแนะนำเข้าใจ (Admissions) คุณภาพครู อัตราส่วนครู-นักเรียน ความพึงพอใจของผู้ปกครอง และสุดท้าย งบประมาณครอบครัว',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเปรียบเทียบโรงเรียนเอกชนกับรัฐ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเปรียบเทียบโรงเรียนเอกชนกับรัฐ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณเปรียบเทียบโรงเรียนเอกชนกับรัฐ ปี 2569</h1>

    <p class="text-gray-600 mb-6">
      เปรียบเทียบต้นทุนทั้งหมด (ค่าเรียน + ค่าใช้จ่ายอื่น) และระยะเวลาระหว่างโรงเรียนเอกชนและโรงเรียนรัฐ
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="school-form" class="space-y-5">
        <h3 class="font-semibold text-gray-900">โรงเรียนรัฐ</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="govt-tuition" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าเรียน/ปี (บาท)
            </label>
            <input
              type="text"
              id="govt-tuition"
              inputmode="numeric"
              placeholder="เช่น 5,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="govt-other" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าอื่นๆ/ปี (บาท)
            </label>
            <input
              type="text"
              id="govt-other"
              inputmode="numeric"
              placeholder="เช่น 3,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <h3 class="font-semibold text-gray-900 mt-6">โรงเรียนเอกชน</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="private-tuition" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าเรียน/ปี (บาท)
            </label>
            <input
              type="text"
              id="private-tuition"
              inputmode="numeric"
              placeholder="เช่น 80,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="private-other" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าอื่นๆ/ปี (บาท)
            </label>
            <input
              type="text"
              id="private-other"
              inputmode="numeric"
              placeholder="เช่น 30,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="years" class="block text-sm font-medium text-gray-700 mb-1">
            ระยะเวลาศึกษา (ปี)
          </label>
          <input
            type="text"
            id="years"
            inputmode="numeric"
            placeholder="เช่น 6"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          />
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-blue-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-700">
          เปรียบเทียบต้นทุน
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการเปรียบเทียบ</h2>

        <div class="grid gap-4 sm:grid-cols-2 mb-6">
          <div class="rounded-lg border-l-4 border-l-blue-500 bg-blue-50 p-4">
            <div class="text-sm text-gray-600 mb-2">โรงเรียนรัฐ</div>
            <div id="res-govt-total" class="text-2xl font-bold text-blue-700">-</div>
            <div id="res-govt-year" class="text-xs text-gray-600 mt-1">-</div>
          </div>
          <div class="rounded-lg border-l-4 border-l-red-500 bg-red-50 p-4">
            <div class="text-sm text-gray-600 mb-2">โรงเรียนเอกชน</div>
            <div id="res-private-total" class="text-2xl font-bold text-red-700">-</div>
            <div id="res-private-year" class="text-xs text-gray-600 mt-1">-</div>
          </div>
        </div>

        <div class="rounded-lg bg-yellow-50 border border-yellow-200 p-4">
          <div class="text-sm text-gray-600 mb-1">ผลต่างของต้นทุน</div>
          <div id="res-difference" class="text-xl font-bold text-yellow-700">-</div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <RelatedCalculators currentHref="/คำนวณเปรียบเทียบโรงเรียนเอกชนกับรัฐ/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-blue-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return 0;
    return Number(String(value).replace(/,/g, '').trim()) || 0;
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#school-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const govtTuition = parseNumber(document.querySelector('#govt-tuition')?.value || '');
    const govtOther = parseNumber(document.querySelector('#govt-other')?.value || '');
    const privateTuition = parseNumber(document.querySelector('#private-tuition')?.value || '');
    const privateOther = parseNumber(document.querySelector('#private-other')?.value || '');
    const years = parseNumber(document.querySelector('#years')?.value || '');

    if (!(years > 0)) {
      results?.classList.add('hidden');
      return;
    }

    const govtYearly = govtTuition + govtOther;
    const privateYearly = privateTuition + privateOther;
    const govtTotal = govtYearly * years;
    const privateTotal = privateYearly * years;
    const difference = privateTotal - govtTotal;

    document.querySelector('#res-govt-total').textContent = formatCurrency(govtTotal);
    document.querySelector('#res-govt-year').textContent = formatCurrency(govtYearly) + '/ปี';
    document.querySelector('#res-private-total').textContent = formatCurrency(privateTotal);
    document.querySelector('#res-private-year').textContent = formatCurrency(privateYearly) + '/ปี';

    if (difference >= 0) {
      document.querySelector('#res-difference').textContent = `เอกชนแพงกว่า ${formatCurrency(difference)}`;
    } else {
      document.querySelector('#res-difference').textContent = `รัฐแพงกว่า ${formatCurrency(Math.abs(difference))}`;
    }

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
