---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ ค่าธรรมเนียม TikTok Shop 2569 | Kamnuanlek';
const pageDescription = 'คำนวณค่าธรรมเนียม TikTok Shop คำนวณกำไรหลังหัก Fee และ Logistics';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าธรรมเนียม-tiktok-shop/`;

const faqData = [
  {
    question: 'ค่าธรรมเนียม TikTok Shop เท่าไร?',
    answer: 'TikTok Shop คิด 5-8% ต่อรายการ (Service Fee) + ค่า Payment Gateway 2-3% รวม 7-11% ทั้งหมด ต่างจาก Shopee (ประมาณ 5%) ส่วนมากแพงกว่า',
  },
  {
    question: 'ต้นทุน TikTok Shop คืออะไร?',
    answer: 'ค่า TikTok Shop Fee (7-11%) ค่า Shipping/Logistics (20-50 บาท) ต้นทุนสินค้า Payment Gateway ยิ่งหลังหัก Fee หลายอย่าง Margin ต่ำมาก',
  },
  {
    question: 'ควรเลือก TikTok Shop หรือ Shopee?',
    answer: 'TikTok: ผู้ใช้ Gen Z สูง, Viral ได้ดี แต่ Fee สูง Shopee: Fee ต่ำ ผู้ใช้เยอะ ความสัมพันธ์ดี Hybrid ดีที่สุด: ขายทั้ง 2 แพลตฟอร์ม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียม TikTok Shop',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าธรรมเนียม TikTok Shop">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🛍️ คำนวณค่าธรรมเนียม TikTok Shop
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าธรรมเนียม TikTok Shop
      คำนวณกำไรหลังหัก Fee และ Logistics
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="tiktok-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="product-price" class="block text-sm font-medium text-gray-700 mb-1">
              ราคาสินค้า (บาท)
            </label>
            <input
              type="text"
              id="product-price"
              inputmode="numeric"
              placeholder="เช่น 500"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="product-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ต้นทุนสินค้า (บาท)
            </label>
            <input
              type="text"
              id="product-cost"
              inputmode="numeric"
              placeholder="เช่น 150"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="tiktok-fee" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า TikTok Shop Fee (%)
            </label>
            <input
              type="text"
              id="tiktok-fee"
              inputmode="numeric"
              placeholder="เช่น 8"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="shipping-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าจัดส่ง (บาท)
            </label>
            <input
              type="text"
              id="shipping-cost"
              inputmode="numeric"
              placeholder="เช่น 30"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="monthly-orders" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนรายการต่อเดือน
            <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
          </label>
          <input
            type="text"
            id="monthly-orders"
            inputmode="numeric"
            placeholder="เช่น 50"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณกำไร
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณกำไร</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">กำไรต่อรายการ</div>
            <div id="res-profit-per-item" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">% Margin</div>
            <div id="res-margin-pct" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">กำไรต่อเดือน</div>
            <div id="res-monthly-profit" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">กำไรต่อปี</div>
            <div id="res-annual-profit" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ราคาขาย</span>
            <span id="res-price" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ต้นทุน + Fee + Shipping</span>
            <span id="res-total-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่า TikTok Fee</span>
            <span id="res-fee-amount" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">จำนวนขาย/เดือน</span>
            <span id="res-orders" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-ค่าธรรมเนียม-tiktok-shop/" />
    <RelatedCalculators currentHref="/คำนวณ-ค่าธรรมเนียม-tiktok-shop/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ ราคา Fee อาจเปลี่ยนแปลง
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('tiktok-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const productPrice = parseNum((document.getElementById('product-price') as HTMLInputElement).value);
      const productCost = parseNum((document.getElementById('product-cost') as HTMLInputElement).value);
      const tiktokFee = parseNum((document.getElementById('tiktok-fee') as HTMLInputElement).value);
      const shippingCost = parseNum((document.getElementById('shipping-cost') as HTMLInputElement).value);
      const monthlyOrders = parseNum((document.getElementById('monthly-orders') as HTMLInputElement).value);

      if (productPrice <= 0) { (document.getElementById('product-price') as HTMLInputElement).focus(); return; }
      if (productCost <= 0) { (document.getElementById('product-cost') as HTMLInputElement).focus(); return; }

      const feeAmount = (productPrice * tiktokFee) / 100;
      const totalCost = productCost + feeAmount + shippingCost;
      const profitPerItem = productPrice - totalCost;
      const marginPct = (profitPerItem / productPrice) * 100;
      const monthlyProfit = profitPerItem * monthlyOrders;
      const annualProfit = monthlyProfit * 12;

      (document.getElementById('res-profit-per-item') as HTMLElement).textContent = fmt(profitPerItem) + ' บาท';
      (document.getElementById('res-margin-pct') as HTMLElement).textContent = marginPct.toFixed(1) + '%';
      (document.getElementById('res-monthly-profit') as HTMLElement).textContent = fmt(monthlyProfit) + ' บาท';
      (document.getElementById('res-annual-profit') as HTMLElement).textContent = fmt(annualProfit) + ' บาท';
      (document.getElementById('res-price') as HTMLElement).textContent = fmt(productPrice) + ' บาท';
      (document.getElementById('res-total-cost') as HTMLElement).textContent = fmt(totalCost) + ' บาท';
      (document.getElementById('res-fee-amount') as HTMLElement).textContent = fmt(feeAmount) + ' บาท';
      (document.getElementById('res-orders') as HTMLElement).textContent = monthlyOrders.toFixed(0);

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('tiktok-shop-fee');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('tiktok-shop-fee');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
