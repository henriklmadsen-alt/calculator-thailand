---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนบำรุงรักษาเครื่องจักร | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนบำรุงรักษา ค่าซ่อม ค่าชำรุด ค่าเสื่อมราคา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-บำรุงรักษาเครื่องจักร/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณบำรุงรักษาเครื่องจักร">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนบำรุงรักษาเครื่องจักร</h1>
    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2"><p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนบำรุงรักษา ค่าซ่อม ค่าเสื่อมราคา</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="price" class="block text-sm font-medium text-gray-700 mb-1">ราคาซื้อ (บาท)</label><input type="text" id="price" inputmode="decimal" placeholder="เช่น 500000" value="500000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="months" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (เดือน)</label><input type="text" id="months" inputmode="numeric" placeholder="เช่น 12" value="12" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-primary-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ค่าบำรุงต่อเดือน</p><p id="monthly" class="font-bold">-</p></div><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวม</p><p id="total" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ค่าเสื่อมต่อปี</p><p id="depreciation" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">มูลค่าคงเหลือ</p><p id="remaining" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const price = parseFloat((document.getElementById('price') as HTMLInputElement).value) || 0;
      const months = parseFloat((document.getElementById('months') as HTMLInputElement).value) || 0;
      if (price <= 0) return;
      const maintenanceRate = 0.05, monthlyMaint = price * maintenanceRate / 12, totalMaint = monthlyMaint * months;
      const annualDepr = price * 0.1, years = months / 12, remainingValue = price - (annualDepr * years);
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('monthly') as HTMLElement).textContent = fmt(monthlyMaint);
      (document.getElementById('total') as HTMLElement).textContent = fmt(totalMaint);
      (document.getElementById('depreciation') as HTMLElement).textContent = fmt(annualDepr);
      (document.getElementById('remaining') as HTMLElement).textContent = fmt(remainingValue);
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('equipment-maintenance');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
