---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าเมล็ดพันธุ์และต้นพันธุ์ | Kamnuanlek';
const pageDescription = 'คำนวณค่าใช้จ่ายเมล็ดพันธุ์ ต้นกล้า ต้นพันธุ์ต่อไร่ต่อฤดูกาล ต้นทุนเมล็ดพันธุ์รวม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0488-ค่าเมล็ดพันธุ์/`;
const faqData = [
  { question: 'เมล็ดพันธุ์ดีกับเมล็ดพันธุ์ทั่วไปต่างกันอย่างไร?', answer: 'เมล็ดพันธุ์ดี (Certified Seed) มีความบริสุทธิ์ อัตราการงอกสูง 85%+ โรคน้อย แต่ราคาสูงกว่า 2-5 เท่า ผลผลิตสูงกว่า 20-40% คุ้มค่าในระยะยาว' },
  { question: 'เมล็ดพันธุ์ข้าวใช้ต่อไร่เท่าไหร่?', answer: 'ข้าวนาหว่าน ใช้เมล็ด 15-20 กก./ไร่ ข้าวนาดำ 2-3 กก./ไร่ เมล็ดพันธุ์ข้าวรับรองราคา 15-25 บาท/กก. จากกรมการข้าว หรือศูนย์เมล็ดพันธุ์ข้าว' },
  { question: 'เก็บเมล็ดพันธุ์เองได้ไหม?', answer: 'เก็บเมล็ดพันธุ์เองได้สำหรับพันธุ์ Open-pollinated แต่พันธุ์ลูกผสม (Hybrid) ต้องซื้อใหม่ทุกรอบ เพราะลูกรุ่นสองผลผลิตลดลงมาก' },
  { question: 'ต้นพันธุ์ไม้ผลซื้อจากไหนดีที่สุด?', answer: 'ซื้อจากสถานีเกษตรหลวง กรมวิชาการเกษตร หรือเกษตรกรที่ได้รับรองคุณภาพ หลีกเลี่ยงซื้อจากแหล่งไม่น่าเชื่อถือ เสี่ยงโรคและพันธุ์ปลอม' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเมล็ดพันธุ์และต้นพันธุ์">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเมล็ดพันธุ์และต้นพันธุ์</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนเมล็ดพันธุ์ต่อฤดูกาล</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="seed_area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่ปลูก (ไร่)</label><input type="number" id="seed_area" min="1" placeholder="เช่น 20" value="20" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="seed_kg_rai" class="block text-sm font-medium text-gray-700 mb-1">เมล็ดพันธุ์ที่ใช้ต่อไร่ (กก.)</label><input type="text" id="seed_kg_rai" inputmode="decimal" placeholder="เช่น 15" value="15" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="seed_price_kg" class="block text-sm font-medium text-gray-700 mb-1">ราคาเมล็ดพันธุ์ (บาท/กก.)</label><input type="text" id="seed_price_kg" inputmode="decimal" placeholder="เช่น 20" value="20" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="extra_seedling" class="block text-sm font-medium text-gray-700 mb-1">ค่าต้นกล้าเสริม (บาท)</label><input type="text" id="extra_seedling" inputmode="decimal" placeholder="เช่น 0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ค่าเมล็ดพันธุ์รวม</p><p id="seed_total" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนพันธุ์ต่อไร่</p><p id="seed_per_rai" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const area = parseFloat((document.getElementById('seed_area') as HTMLInputElement).value) || 0;
      const kgRai = parseFloat((document.getElementById('seed_kg_rai') as HTMLInputElement).value) || 0;
      const priceKg = parseFloat((document.getElementById('seed_price_kg') as HTMLInputElement).value) || 0;
      const extra = parseFloat((document.getElementById('extra_seedling') as HTMLInputElement).value) || 0;
      const seedTotal = (area * kgRai * priceKg) + extra;
      const perRai = area > 0 ? seedTotal / area : 0;
      (document.getElementById('seed_total') as HTMLElement).textContent = Math.round(seedTotal).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('seed_per_rai') as HTMLElement).textContent = Math.round(perRai).toLocaleString('th-TH') + ' บาท/ไร่';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('seed-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
