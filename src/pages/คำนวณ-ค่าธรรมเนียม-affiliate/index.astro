---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ ค่าธรรมเนียม Affiliate 2569 | Calculator Thailand';
const pageDescription = 'คำนวณรายได้ Affiliate Commission ประเมิน ROI Traffic-to-Sales';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าธรรมเนียม-affiliate/`;

const faqData = [
  {
    question: 'อัตรา Commission Affiliate ทั่วไป?',
    answer: 'Digital: 20-50% Physical: 3-10% SaaS: 20-30% Amazon: 1-10% โดยเฉพาะ ขึ้นอยู่กับ Product Category',
  },
  {
    question: 'เบี่ยง Cookie Duration?',
    answer: 'Tracking Cookie เก็บ Browser 7-90 วัน ถ้าลูกค้าซื้อในช่วง Affiliate ได้ Commission ยิ่งนาน Cookie ยิ่งได้เปรียบ',
  },
  {
    question: 'Affiliate ROI คิดอย่างไร?',
    answer: 'ROI = (Commission ได้ - Ads/Content Cost) ÷ Cost × 100 Affiliate ไม่มีค่า Product ต้องจ่ายแต่ Marketing เท่านั้น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียม Affiliate',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าธรรมเนียม Affiliate">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🤝 คำนวณค่าธรรมเนียม Affiliate
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณรายได้ Affiliate Commission
      ประเมิน ROI Traffic-to-Sales
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="affiliate-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="monthly-clicks" class="block text-sm font-medium text-gray-700 mb-1">
              Clicks ต่อเดือน
            </label>
            <input
              type="text"
              id="monthly-clicks"
              inputmode="numeric"
              placeholder="เช่น 1000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="conversion-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Conversion Rate (%)
            </label>
            <input
              type="text"
              id="conversion-rate"
              inputmode="numeric"
              placeholder="เช่น 2"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="avg-sale" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าขายเฉลี่ย (บาท)
            </label>
            <input
              type="text"
              id="avg-sale"
              inputmode="numeric"
              placeholder="เช่น 1000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="commission-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Commission Rate (%)
            </label>
            <input
              type="text"
              id="commission-rate"
              inputmode="numeric"
              placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="marketing-cost" class="block text-sm font-medium text-gray-700 mb-1">
            ค่า Marketing/เดือน (บาท)
            <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
          </label>
          <input
            type="text"
            id="marketing-cost"
            inputmode="numeric"
            placeholder="เช่น 0"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณรายได้
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Commission/เดือน</div>
            <div id="res-commission" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Commission/ปี</div>
            <div id="res-annual" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Net Profit</div>
            <div id="res-profit" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ROI %</div>
            <div id="res-roi" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณ-ค่าธรรมเนียม-affiliate/" />
    <RelatedCalculators currentHref="/คำนวณ-ค่าธรรมเนียม-affiliate/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('affiliate-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const monthlyClicks = parseNum((document.getElementById('monthly-clicks') as HTMLInputElement).value);
      const conversionRate = parseNum((document.getElementById('conversion-rate') as HTMLInputElement).value);
      const avgSale = parseNum((document.getElementById('avg-sale') as HTMLInputElement).value);
      const commissionRate = parseNum((document.getElementById('commission-rate') as HTMLInputElement).value);
      const marketingCost = parseNum((document.getElementById('marketing-cost') as HTMLInputElement).value);

      if (monthlyClicks <= 0) { (document.getElementById('monthly-clicks') as HTMLInputElement).focus(); return; }
      if (conversionRate <= 0) { (document.getElementById('conversion-rate') as HTMLInputElement).focus(); return; }
      if (avgSale <= 0) { (document.getElementById('avg-sale') as HTMLInputElement).focus(); return; }
      if (commissionRate <= 0) { (document.getElementById('commission-rate') as HTMLInputElement).focus(); return; }

      const conversions = (monthlyClicks * conversionRate) / 100;
      const totalSales = conversions * avgSale;
      const commission = (totalSales * commissionRate) / 100;
      const annual = commission * 12;
      const profit = commission - marketingCost;
      const roi = marketingCost > 0 ? (profit / marketingCost) * 100 : 10000;

      (document.getElementById('res-commission') as HTMLElement).textContent = fmt(commission) + ' บาท';
      (document.getElementById('res-annual') as HTMLElement).textContent = fmt(annual) + ' บาท';
      (document.getElementById('res-profit') as HTMLElement).textContent = fmt(profit) + ' บาท';
      (document.getElementById('res-roi') as HTMLElement).textContent = roi > 1000 ? 'N/A' : roi.toFixed(0) + '%';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('affiliate-commission');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('affiliate-commission');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
