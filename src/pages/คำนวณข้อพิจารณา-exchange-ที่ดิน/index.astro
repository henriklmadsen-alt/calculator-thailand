---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณข้อพิจารณา Exchange ที่ดิน 2569 | 1031 Deferral | Kamnuanlek';
const pageDescription = 'คำนวณประเมินค่าสินทรัพย์ในการแลกเปลี่ยนที่ดิน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณข้อพิจารณา-exchange-ที่ดิน/`;

const faqData = [
  { question: 'Cap Rate ที่ดีสำหรับอสังหาริมทรัพย์ไทยคือเท่าไร?', answer: 'Cap Rate ที่ดีในไทยมักอยู่ที่ 5-8% ต่อปี ขึ้นอยู่กับทำเลและประเภทอสังหาฯ ทำเลกรุงเทพฯ ชั้นในมักได้ cap rate ต่ำกว่าต่างจังหวัด' },
  { question: 'ค่าใช้จ่ายแฝงในการซื้ออสังหาฯ มีอะไรบ้าง?', answer: 'ค่าโอน ค่าจดจำนอง ค่าอากรแสตมป์ ภาษีธุรกิจเฉพาะ ค่านายหน้า ค่าซ่อมแซม รวมกันอาจสูงถึง 3-7% ของราคาซื้อ' },
  { question: 'ผลตอบแทนการลงทุนอสังหาฯ ที่ดีต้องเป็นเท่าไร?', answer: 'นักลงทุนส่วนใหญ่ต้องการ IRR อย่างน้อย 8-12% ต่อปี หรือ Yield ค่าเช่า 5-7% ขึ้นอยู่กับทำเลและเป้าหมาย' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกราคาซื้อ ค่าเช่า ค่าใช้จ่ายรายเดือน เครื่องจะคำนวณ Yield, Cash Flow และ Cap Rate ให้อัตโนมัติ' },
  { question: 'ค่าโอนบ้านปี 2569 คิดอัตราเท่าไร?', answer: 'ค่าธรรมเนียมโอน 2% ของราคาประเมิน (ลดเหลือ 1% สำหรับที่อยู่อาศัยราคาไม่เกิน 3 ล้าน จนถึง 31 ธ.ค. 2568), ค่าจดจำนอง 1% ของวงเงิน (ลดเหลือ 0.01% สำหรับกู้ไม่เกิน 3 ล้าน)' },
  { question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ต่างกันอย่างไร?', answer: 'ภาษีธุรกิจเฉพาะ 3.3% (ถือครองน้อยกว่า 5 ปีหรือไม่ได้มีชื่อในทะเบียนบ้าน) | อากรแสตมป์ 0.5% (ถือครอง 5 ปีขึ้นไปและมีชื่อในทะเบียนบ้านครบ 1 ปี) เสียอย่างใดอย่างหนึ่ง' },
  { question: 'ราคาประเมินกรมที่ดินกับราคาตลาดต่างกันอย่างไร?', answer: 'ราคาประเมินคือราคาที่กรมที่ดินกำหนดเพื่อใช้คิดค่าธรรมเนียม อัปเดตทุก 4 ปี มักต่ำกว่าราคาตลาด 20-50% ภาษีและค่าธรรมเนียมใช้ราคาประเมินหรือราคาซื้อขาย แล้วแต่อย่างไหนสูงกว่า' },
  { question: 'ซื้อบ้านมือสองต้องระวังค่าใช้จ่ายอะไร?', answer: 'ค่าธรรมเนียมโอน ค่าภาษีธุรกิจเฉพาะหรืออากรแสตมป์ ค่าจดจำนอง ค่าตรวจสอบภาระผูกพัน ค่าประเมินราคา ค่าซ่อมแซม และค่าประกันภัย รวมกันอาจสูงถึง 5-10% ของราคาซื้อ' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณข้อพิจารณา Exchange ที่ดิน">  <article>
    <h1 class="text-2xl font-bold mb-4">คำนวณข้อพิจารณา Exchange ที่ดิน</h1>
    <div class="bg-white rounded-lg shadow p-6 mb-8">
      <form id="form">
        <div class="grid gap-4">
          <div><label class="block text-sm font-medium mb-1">มูลค่าที่ดินเดิม (บาท)</label>
            <input type="text" id="old" inputmode="numeric" value="2000000" class="w-full px-3 py-2 border rounded"/></div>
          <div><label class="block text-sm font-medium mb-1">มูลค่าที่ดินใหม่ (บาท)</label>
            <input type="text" id="new" inputmode="numeric" value="2300000" class="w-full px-3 py-2 border rounded"/></div>
          <div><label class="block text-sm font-medium mb-1">เงินสดเพิ่มเติมที่ต้องเสียบกรรมสิทธิ์ (บาท)</label>
            <input type="text" id="boot" inputmode="numeric" value="200000" class="w-full px-3 py-2 border rounded"/></div>
        </div>
        <button type="submit" class="mt-6 px-8 py-3 bg-blue-600 text-white rounded">คำนวณ</button>
      </form>
    </div>
    <div id="result" class="hidden bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold mb-4">การวิเคราะห์ Exchange</h2>
      <div class="space-y-2 text-sm"><div class="flex justify-between"><span>ส่วนต่างมูลค่า</span><span id="r-diff">-</span></div>
        <div class="flex justify-between"><span>เงินสดเพิ่มเติม</span><span id="r-boot">-</span></div>
        <div class="flex justify-between font-bold border-t pt-2"><span>กำไรจากการแลกเปลี่ยน</span><span id="r-gain">-</span></div></div>
    </div>
  </article>
  <script>
    document.getElementById('form').addEventListener('submit', (e) => {
      e.preventDefault();
      const old = parseFloat(document.getElementById('old').value.replace(/,/g, '')) || 0;
      const newv = parseFloat(document.getElementById('new').value.replace(/,/g, '')) || 0;
      const boot = parseFloat(document.getElementById('boot').value.replace(/,/g, '')) || 0;
      const diff = newv - old;
      const gain = Math.max(0, diff - boot);
      const fmt = (n) => new Intl.NumberFormat('th-TH').format(Math.round(n));
      document.getElementById('r-diff').textContent = fmt(diff) + ' บาท';
      document.getElementById('r-boot').textContent = fmt(boot) + ' บาท';
      document.getElementById('r-gain').textContent = fmt(gain) + ' บาท';
      document.getElementById('result').classList.remove('hidden');
    });
  </script>

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.dol.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมที่ดิน (dol.go.th)</a> — อัตราค่าธรรมเนียมการโอนและจดทะเบียนสิทธิ์</li>
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยสินเชื่อบ้านอ้างอิง MRR/MLR</li>
      </ul>
    </div>
</BaseLayout>
