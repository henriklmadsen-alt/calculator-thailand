---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าตรวจเลือด | Kamnuanlek';
const pageDescription = 'คำนวณค่าตรวจเลือด ตรวจ CBC ตรวจเคมีเลือด ตรวจไขมัน น้ำตาล ตามอัตราโรงพยาบาลไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0410-ค่าตรวจเลือด/`;

const faqData = [
  { question: 'ค่าตรวจเลือดพื้นฐานเท่าไหร่?', answer: 'ตรวจ CBC (ความสมบูรณ์ของเม็ดเลือด) 200-500 บาท ตรวจน้ำตาล 100-200 บาท ตรวจไขมัน 300-600 บาท ขึ้นอยู่กับโรงพยาบาล' },
  { question: 'ต้องอดอาหารก่อนตรวจเลือดไหม?', answer: 'การตรวจน้ำตาลและไขมันต้องอดอาหาร 8-12 ชั่วโมง การตรวจ CBC และตรวจทั่วไปไม่จำเป็นต้องอด ควรถามแพทย์ก่อนนัด' },
  { question: 'ตรวจเลือดครั้งละกี่รายการดี?', answer: 'ขึ้นอยู่กับวัตถุประสงค์ ตรวจสุขภาพประจำปีทั่วไป 5-10 รายการ ตรวจเจาะจงตามอาการ 1-5 รายการ ตรวจครบชุดสุขภาพ 15-20 รายการ' },
  { question: 'ผลเลือดออกกี่วัน?', answer: 'ผลเลือดส่วนใหญ่ออกภายใน 1-3 ชั่วโมง บางรายการที่ซับซ้อนอาจใช้ 1-3 วัน โรงพยาบาลส่วนใหญ่แจ้งผลทางออนไลน์หรือแอพ' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าตรวจเลือด">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าตรวจเลือด</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">ประมาณการค่าตรวจเลือดตามรายการที่ต้องการ</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="cbc" class="block text-sm font-medium text-gray-700 mb-1">ตรวจ CBC ความสมบูรณ์เม็ดเลือด (บาท)</label><input type="text" id="cbc" inputmode="decimal" placeholder="เช่น 350" value="350" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="glucose" class="block text-sm font-medium text-gray-700 mb-1">ตรวจน้ำตาลในเลือด (บาท)</label><input type="text" id="glucose" inputmode="decimal" placeholder="เช่น 150" value="150" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="lipid" class="block text-sm font-medium text-gray-700 mb-1">ตรวจไขมันในเลือด (บาท)</label><input type="text" id="lipid" inputmode="decimal" placeholder="เช่น 450" value="450" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="liver" class="block text-sm font-medium text-gray-700 mb-1">ตรวจการทำงานของตับ (บาท)</label><input type="text" id="liver" inputmode="decimal" placeholder="เช่น 500" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="kidney" class="block text-sm font-medium text-gray-700 mb-1">ตรวจการทำงานของไต (บาท)</label><input type="text" id="kidney" inputmode="decimal" placeholder="เช่น 400" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">จำนวนรายการตรวจ</p>
            <p id="item_count" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมค่าตรวจเลือด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const cbc = parseFloat((document.getElementById('cbc') as HTMLInputElement).value) || 0;
      const glucose = parseFloat((document.getElementById('glucose') as HTMLInputElement).value) || 0;
      const lipid = parseFloat((document.getElementById('lipid') as HTMLInputElement).value) || 0;
      const liver = parseFloat((document.getElementById('liver') as HTMLInputElement).value) || 0;
      const kidney = parseFloat((document.getElementById('kidney') as HTMLInputElement).value) || 0;

      const items = [cbc, glucose, lipid, liver, kidney].filter(v => v > 0);
      const total = items.reduce((a, b) => a + b, 0);

      (document.getElementById('item_count') as HTMLElement).textContent = items.length + ' รายการ';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('blood-test-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
