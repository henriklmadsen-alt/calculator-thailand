---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเงินกู้แบบ Balloon Payment 2569 | Calculator Thailand';
const pageDescription = 'คำนวณค่างวดสินเชื่อแบบ Balloon Payment ยอดผ่อนรายเดือนต่ำกว่าปกติ แต่มียอดก้อนใหญ่ปลายสัญญา เหมาะสำหรับสินเชื่อรถและอสังหาริมทรัพย์บางประเภทในไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินกู้-balloon/`;

const faqData = [
  {
    question: 'Balloon Payment คืออะไร?',
    answer: 'Balloon Payment คือสินเชื่อที่ค่างวดรายเดือนต่ำกว่าปกติ แต่เมื่อครบสัญญาจะมียอดเงินก้อนใหญ่ (balloon) ที่ต้องชำระในคราวเดียว เหมาะสำหรับผู้ที่คาดว่าจะมีเงินก้อนในอนาคต หรือวางแผนขายทรัพย์สินก่อนครบสัญญา',
  },
  {
    question: 'Balloon Payment ใช้กับสินเชื่อประเภทไหนในไทย?',
    answer: 'ในไทยมักพบในสินเชื่อเช่าซื้อรถยนต์บางรุ่น และสินเชื่ออสังหาริมทรัพย์เชิงพาณิชย์ ธนาคารบางแห่งเสนอรูปแบบนี้เพื่อให้ค่างวดต่อเดือนดึงดูดใจมากขึ้น',
  },
  {
    question: 'Balloon Payment ดีหรือไม่?',
    answer: 'ข้อดีคือค่างวดรายเดือนต่ำ กระแสเงินสดดีขึ้น ข้อเสียคือดอกเบี้ยรวมสูงกว่าผ่อนปกติ และต้องมีแผนชำระยอด balloon ปลายสัญญา หากไม่มีเงินอาจต้องรีไฟแนนซ์ซึ่งมีความเสี่ยง',
  },
  {
    question: 'ยอด Balloon ควรตั้งไว้เท่าไร?',
    answer: 'โดยทั่วไปยอด balloon อยู่ที่ 20-50% ของเงินกู้ต้น ยิ่ง balloon สูงค่างวดรายเดือนยิ่งต่ำ แต่ดอกเบี้ยรวมก็สูงขึ้นด้วย ควรเลือกยอดที่สอดคล้องกับแผนการเงินระยะยาว',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินกู้แบบ Balloon Payment',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินกู้ Balloon">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🎈 คำนวณเงินกู้แบบ Balloon Payment
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่างวดรายเดือนสำหรับสินเชื่อแบบ Balloon Payment ที่มียอดชำระก้อนใหญ่ปลายสัญญา
      เปรียบเทียบกับการผ่อนปกติเพื่อประกอบการตัดสินใจ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="balloon-form" class="space-y-5">
        <div>
          <label for="principal" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนเงินกู้ (บาท)
          </label>
          <input
            type="text"
            id="principal"
            inputmode="numeric"
            placeholder="เช่น 1,000,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="interest-rate" class="block text-sm font-medium text-gray-700 mb-1">
              ดอกเบี้ยต่อปี (%)
            </label>
            <input
              type="text"
              id="interest-rate"
              inputmode="decimal"
              placeholder="เช่น 5.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="term-months" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาผ่อน (เดือน)
            </label>
            <input
              type="text"
              id="term-months"
              inputmode="numeric"
              placeholder="เช่น 60"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="balloon" class="block text-sm font-medium text-gray-700 mb-1">
            ยอด Balloon ปลายสัญญา (บาท)
          </label>
          <input
            type="text"
            id="balloon"
            inputmode="numeric"
            placeholder="เช่น 300,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p class="mt-1 text-xs text-gray-500">ยอดเงินก้อนที่ต้องชำระเมื่อครบสัญญา</p>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่างวดรายเดือน</div>
            <div id="res-monthly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอด Balloon ปลายสัญญา</div>
            <div id="res-balloon" class="text-xl font-bold text-orange-600">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยรวม</div>
            <div id="res-interest" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดชำระรวมทั้งหมด</div>
            <div id="res-total" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center col-span-full sm:col-span-1">
            <div class="text-sm text-gray-600 mb-1">ค่างวดผ่อนปกติ (เทียบ)</div>
            <div id="res-normal-monthly" class="text-xl font-bold text-blue-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินกู้</span>
            <span id="res-principal" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">อัตราดอกเบี้ยต่อปี</span>
            <span id="res-rate" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนงวด</span>
            <span id="res-term" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ประหยัดค่างวดต่อเดือนเทียบปกติ</span>
            <span id="res-saving" class="font-medium text-green-600">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยรวมแบบปกติ (เทียบ)</span>
            <span id="res-normal-interest" class="font-medium text-gray-500">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">ดอกเบี้ยเพิ่มขึ้นเพราะ Balloon</span>
            <span id="res-extra-interest" class="font-medium text-red-500">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">Balloon Payment คืออะไร และคำนวณอย่างไร</h2>

      <p>
        สินเชื่อแบบ Balloon Payment เป็นรูปแบบสินเชื่อที่ค่างวดรายเดือนต่ำกว่าการผ่อนปกติ
        เพราะยังไม่ได้ตัดเงินต้นทั้งหมด โดยจะมียอดเงินก้อนใหญ่ที่เรียกว่า "balloon"
        ค้างอยู่และต้องชำระเมื่อครบสัญญา
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณ Balloon Payment</h3>

      <p>
        ค่างวดรายเดือนคำนวณจากสูตร PMT ที่ปรับให้รองรับมูลค่าปัจจุบันของ balloon:
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>มูลค่าปัจจุบัน Balloon = balloon ÷ (1+r)ⁿ</li>
        <li>เงินต้นที่ต้องผ่อน = เงินกู้ − มูลค่าปัจจุบัน Balloon</li>
        <li>ค่างวด = เงินต้นที่ต้องผ่อน × [r(1+r)ⁿ] ÷ [(1+r)ⁿ − 1]</li>
        <li>ดอกเบี้ยรวม = (ค่างวด × จำนวนงวด + balloon) − เงินกู้</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการคำนวณ</h3>
      <p>
        กู้ 1,000,000 บาท ดอกเบี้ย 5.5% ต่อปี ผ่อน 60 เดือน ยอด balloon 300,000 บาท:
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ค่างวด Balloon: ประมาณ 12,500 บาท/เดือน</li>
        <li>ค่างวดปกติ (ไม่มี balloon): ประมาณ 19,100 บาท/เดือน</li>
        <li>ประหยัดค่างวด: ประมาณ 6,600 บาท/เดือน</li>
        <li>แต่ดอกเบี้ยรวมสูงกว่าแบบปกติ เพราะเงินต้นลดช้ากว่า</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ข้อควรพิจารณาก่อนเลือก Balloon Payment</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ต้องมีแผนชำระยอด balloon — จากเงินออม การขายทรัพย์ หรือการรีไฟแนนซ์</li>
        <li>ดอกเบี้ยรวมสูงกว่าการผ่อนปกติ</li>
        <li>เหมาะสำหรับผู้ที่ต้องการกระแสเงินสดรายเดือนสูงในช่วงแรก</li>
        <li>ตรวจสอบเงื่อนไขธนาคารเรื่องการรีไฟแนนซ์ยอด balloon ล่วงหน้า</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณเงินกู้-balloon/" />
    <RelatedCalculators currentHref="/คำนวณเงินกู้-balloon/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ค่างวดและเงื่อนไขจริงขึ้นอยู่กับสถาบันการเงิน ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('balloon-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const P = parseNum((document.getElementById('principal') as HTMLInputElement).value);
      const annualRate = parseFloat((document.getElementById('interest-rate') as HTMLInputElement).value.replace(/,/g, '')) || 0;
      const n = parseNum((document.getElementById('term-months') as HTMLInputElement).value);
      const balloon = parseNum((document.getElementById('balloon') as HTMLInputElement).value);

      if (P <= 0) { (document.getElementById('principal') as HTMLInputElement).focus(); return; }
      if (n <= 0) { (document.getElementById('term-months') as HTMLInputElement).focus(); return; }
      if (balloon >= P) { alert('ยอด Balloon ต้องน้อยกว่าเงินกู้'); return; }

      const r = annualRate / 100 / 12;

      let monthlyPayment: number;
      let normalMonthly: number;

      if (r === 0) {
        monthlyPayment = (P - balloon) / n;
        normalMonthly = P / n;
      } else {
        const factor = Math.pow(1 + r, n);
        const balloonPV = balloon / factor;
        const effectivePrincipal = P - balloonPV;
        monthlyPayment = effectivePrincipal * (r * factor) / (factor - 1);
        normalMonthly = P * (r * factor) / (factor - 1);
      }

      const totalPaid = monthlyPayment * n + balloon;
      const totalInterest = totalPaid - P;
      const normalTotal = normalMonthly * n;
      const normalInterest = normalTotal - P;
      const extraInterest = totalInterest - normalInterest;
      const saving = normalMonthly - monthlyPayment;

      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthlyPayment) + ' บาท';
      (document.getElementById('res-balloon') as HTMLElement).textContent = fmt(balloon) + ' บาท';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(totalPaid) + ' บาท';
      (document.getElementById('res-normal-monthly') as HTMLElement).textContent = fmt(normalMonthly) + ' บาท';
      (document.getElementById('res-principal') as HTMLElement).textContent = fmt(P) + ' บาท';
      (document.getElementById('res-rate') as HTMLElement).textContent = annualRate.toFixed(2) + '%';
      (document.getElementById('res-term') as HTMLElement).textContent = n + ' งวด';
      (document.getElementById('res-saving') as HTMLElement).textContent = fmt(saving) + ' บาท/เดือน';
      (document.getElementById('res-normal-interest') as HTMLElement).textContent = fmt(normalInterest) + ' บาท';
      (document.getElementById('res-extra-interest') as HTMLElement).textContent = '+' + fmt(extraInterest) + ' บาท';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('balloon-loan');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('balloon-loan');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
