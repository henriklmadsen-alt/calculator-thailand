---
import BaseLayout from '../layouts/BaseLayout.astro';

const deductionCategories = [
  {
    category: 'Personal Allowances',
    items: [
      { name: 'Personal Allowance', amount: '60,000 THB', status: 'Always claim' },
      { name: 'Spouse Allowance', amount: '60,000 THB', status: 'If married' },
      { name: 'Child Allowance (per child)', amount: '20,000 THB', status: 'Up to 5 children' },
      { name: 'Parent/Grandparent Allowance (per person)', amount: '20,000 THB', status: 'If you support them' },
      { name: 'Disability Allowance (self)', amount: '40,000 THB', status: 'If disabled' },
    ]
  },
  {
    category: 'Work-Related Deductions',
    items: [
      { name: 'Professional Fees & Licenses', amount: 'Actual cost', status: 'Keep receipts' },
      { name: 'Education & Training', amount: 'Actual cost', status: 'Job-related only' },
      { name: 'Home Office Depreciation', amount: 'Calculated', status: 'Fixed asset calculation' },
      { name: 'Office Supplies', amount: 'Actual cost', status: 'Consumables' },
      { name: 'Equipment & Tools', amount: 'Depreciated', status: 'Over useful life' },
      { name: 'Professional Membership', amount: 'Actual cost', status: 'Industry associations' },
    ]
  },
  {
    category: 'Health & Life Insurance',
    items: [
      { name: 'Health Insurance Premiums', amount: 'Up to 15,000 THB', status: 'Annual limit' },
      { name: 'Life Insurance Premiums', amount: 'Up to 100,000 THB', status: 'Annual limit' },
      { name: 'Disability Insurance', amount: 'Actual cost', status: 'if approved' },
    ]
  },
  {
    category: 'Investment Savings',
    items: [
      { name: 'Retirement Fund (RMF)', amount: 'Up to 500,000 THB', status: 'Annual contribution' },
      { name: 'Social Security Fund (SSF)', amount: 'Actual contribution', status: 'Self-employed' },
      { name: 'Provident Fund', amount: 'Actual contribution', status: 'Employer-matched' },
      { name: 'Government Savings Bond', amount: 'Actual cost', status: 'Thai bonds only' },
    ]
  },
  {
    category: 'Charitable Donations',
    items: [
      { name: 'Charity Donations', amount: 'Up to 2 years income', status: 'Approved organizations' },
      { name: 'Religious Donations', amount: 'Unlimited', status: 'Temples, mosques, etc.' },
      { name: 'Political/Disaster Donations', amount: 'Unlimited', status: 'If approved' },
    ]
  },
  {
    category: 'Interest Payments',
    items: [
      { name: 'Home Loan Interest', amount: 'Up to 100,000 THB', status: 'First home only' },
      { name: 'Student Loan Interest', amount: 'Actual cost', status: 'Approved loans' },
      { name: 'Mortgage Interest', amount: 'Up to 100,000 THB', status: 'Primary residence' },
    ]
  },
];
---

<BaseLayout
  title="เช็กลิสต์หักลดหย่อนภาษีครบทุกประเภท ปี 2569 อย่าลืมสิทธิ์ | Kamnuanlek"
  description="รายการหักลดหย่อนภาษีเงินได้ครบทุกประเภท ส่วนตัว ประกันชีวิต กองทุน RMF LTF การกุศล และอื่นๆ อัปเดตปี 2569 พร้อมจำนวนเงินสูงสุดแต่ละรายการ"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เช็กลิสต์หักลดหย่อนภาษีครบทุกประเภท ปี 2569</h1>

    <div class="mb-12 p-6 bg-green-50 border border-green-200 rounded-lg">
      <p class="text-lg text-gray-800">
        Don't leave money on the table! This checklist helps you claim every eligible deduction and reduce your tax bill.
      </p>
    </div>

    <div class="space-y-8">
      {deductionCategories.map((section) => (
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <div class="bg-gradient-to-r from-primary-600 to-primary-700 px-6 py-4">
            <h3 class="text-xl font-bold text-white">{section.category}</h3>
          </div>
          <div class="p-6">
            <div class="space-y-4">
              {section.items.map((item) => (
                <div class="flex items-start gap-4 pb-4 border-b border-gray-100 last:border-b-0 last:pb-0">
                  <input
                    type="checkbox"
                    class="mt-1 w-5 h-5 text-primary-600 rounded"
                  />
                  <div class="flex-grow">
                    <div class="flex justify-between items-start">
                      <div>
                        <h4 class="font-semibold text-gray-900">{item.name}</h4>
                        <p class="text-sm text-gray-600 mt-1">{item.status}</p>
                      </div>
                      <div class="text-right">
                        <p class="font-semibold text-primary-600">{item.amount}</p>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 p-6 bg-yellow-50 border border-yellow-200 rounded-lg">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">⚠️ Important Reminders</h2>
      <ul class="space-y-3 text-gray-700">
        <li class="flex gap-3">
          <span class="font-bold text-yellow-700">•</span>
          <span>Keep ALL receipts and documentation for 5 years (Thai law requirement)</span>
        </li>
        <li class="flex gap-3">
          <span class="font-bold text-yellow-700">•</span>
          <span>Deductions must be expenses, not personal purchases</span>
        </li>
        <li class="flex gap-3">
          <span class="font-bold text-yellow-700">•</span>
          <span>Some deductions have annual limits — don't exceed them</span>
        </li>
        <li class="flex gap-3">
          <span class="font-bold text-yellow-700">•</span>
          <span>Not all health/insurance payments qualify — verify with Department of Revenue</span>
        </li>
        <li class="flex gap-3">
          <span class="font-bold text-yellow-700">•</span>
          <span>Charitable donations must be to approved organizations</span>
        </li>
      </ul>
    </div>

    <div class="mt-12 p-8 bg-gradient-to-r from-blue-50 to-cyan-50 rounded-2xl border border-blue-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Calculate Your Tax Savings</h2>
      <p class="text-gray-700 mb-4">
        Now that you've identified all your eligible deductions, calculate your actual tax liability:
      </p>
      <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-semibold">
        Use Tax Calculator →
      </a>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Resources</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/วิธีคำนวณภาษีเงินได้ไทย/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📚 How to Calculate Tax</span>
          <p class="text-gray-600 text-sm mt-2">Step-by-step guide</p>
        </a>
        <a href="/ผิดพลาดภาษีทั่วไป/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">❌ Common Mistakes</span>
          <p class="text-gray-600 text-sm mt-2">Avoid overpaying</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Finance Hub</span>
          <p class="text-gray-600 text-sm mt-2">All financial tools</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
