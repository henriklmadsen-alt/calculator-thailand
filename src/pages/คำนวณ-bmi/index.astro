---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateCard from '../../components/templates/AffiliateCard.astro';

const pageTitle = 'คำนวณ BMI ดัชนีมวลกาย 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่า BMI ตามมาตรฐาน WHO ฟรี — ใส่ส่วนสูงและน้ำหนัก รู้ระดับสุขภาพทันที พร้อมคำแนะนำน้ำหนักที่เหมาะสมสำหรับคนไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-bmi/`;

const faqData = [
  {
    question: 'BMI คืออะไร?',
    answer: 'BMI (Body Mass Index) หรือ ดัชนีมวลกาย คือค่าที่ใช้ประเมินว่าน้ำหนักตัวอยู่ในเกณฑ์ที่เหมาะสมกับส่วนสูงหรือไม่ คำนวณจาก น้ำหนัก (กก.) หาร ส่วนสูง (เมตร) ยกกำลังสอง',
  },
  {
    question: 'ทำไมคนเอเชียใช้เกณฑ์ BMI ต่างจากฝรั่ง?',
    answer: 'องค์การอนามัยโลกภูมิภาคเอเชีย-แปซิฟิก (WHO Asia-Pacific) กำหนดเกณฑ์ BMI สำหรับคนเอเชียต่ำกว่าสากล เนื่องจากคนเอเชียมีแนวโน้มเกิดโรคเรื้อรังที่ BMI ต่ำกว่าคนตะวันตก เช่น เบาหวานและโรคหัวใจ',
  },
  {
    question: 'เกณฑ์ BMI สำหรับคนเอเชียเป็นอย่างไร?',
    answer: 'น้ำหนักน้อย: BMI ต่ำกว่า 18.5, ปกติ: 18.5-22.9, น้ำหนักเกิน: 23.0-24.9, อ้วน: 25.0 ขึ้นไป ซึ่งต่างจากเกณฑ์สากลที่ถือว่าน้ำหนักเกินเริ่มที่ 25 และอ้วนเริ่มที่ 30',
  },
  {
    question: 'BMI มีข้อจำกัดอะไรบ้าง?',
    answer: 'BMI ไม่สามารถแยกแยะระหว่างมวลกล้ามเนื้อกับไขมันได้ นักกีฬาหรือผู้ที่ออกกำลังกายเป็นประจำอาจมี BMI สูงแต่ไม่ได้อ้วน ควรใช้ BMI ร่วมกับตัวชี้วัดอื่นเช่น เส้นรอบเอว และปรึกษาแพทย์',
  },
  {
    question: 'ข้อผิดพลาดทั่วไปในการคำนวณ BMI ที่ต้องหลีกเลี่ยง?',
    answer: 'ข้อผิดพลาดทั่วไป ได้แก่ (1) ใช้ความสูงเป็นเซนติเมตรแทนเมตร (2) ลืมแปลงฟุต/นิ้วเป็นเซนติเมตร (3) ชั่งน้ำหนักพร้อมเสื้อผ้าหนัก (4) ไม่คำนึงถึงต่างอายุ เพศ และประเทศ (5) อาศัย BMI เพียงอย่างเดียวโดยไม่ปรึกษาแพทย์ และ (6) ลืมว่า BMI ไม่แยกแยะมวลกล้ามเนื้อกับไขมัน',
  },
,
  { question: 'BMI คนไทยควรอยู่ในช่วงเท่าไร?', answer: 'ตามเกณฑ์กรมอนามัยสำหรับชาวเอเชีย: ต่ำกว่า 18.5 (น้ำหนักน้อย), 18.5-22.9 (ปกติ), 23.0-24.9 (น้ำหนักเกิน), 25.0+ (อ้วน) เกณฑ์เอเชียต่ำกว่าเกณฑ์สากล เพราะชาวเอเชียมีความเสี่ยงสูงกว่าที่ BMI ต่ำกว่า' },
  { question: 'BMI มีข้อจำกัดอะไรบ้าง?', answer: 'BMI ไม่แยกระหว่างมวลกล้ามเนื้อและไขมัน นักกีฬาหรือคนที่ออกกำลังกายมากอาจมี BMI สูงแต่ไม่อ้วน ไม่คำนึงถึงการกระจายไขมัน (ไขมันพุงอันตรายกว่า) และอาจไม่แม่นยำสำหรับผู้สูงอายุหรือเด็ก' },
  { question: 'ลดน้ำหนักเพื่อให้ BMI อยู่ในเกณฑ์ปกติต้องทำอย่างไร?', answer: 'ลดพลังงานที่บริโภค 500-750 กิโลแคลอรี/วัน เทียบกับพลังงานที่ใช้ จะลดน้ำหนักได้ประมาณ 0.5-0.75 กก./สัปดาห์ ควบคู่กับการออกกำลังกาย 150 นาที/สัปดาห์ตามคำแนะนำกรมอนามัย' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ BMI ดัชนีมวลกาย',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณ BMI (ดัชนีมวลกาย) ตามมาตรฐาน WHO',
  description: 'ขั้นตอนการคำนวณค่า BMI โดยใช้ส่วนสูง (เมตร) และน้ำหนัก (กิโลกรัม) พร้อมการแปลความหมายผลลัพธ์ตามมาตรฐาน WHO',
  step: [
    {
      '@type': 'HowToStep',
      name: 'วัดส่วนสูงให้แม่นยำ',
      text: 'วัดส่วนสูงของคุณ ยืนตรง หลังชิดกำแพง บันทึกเป็นหน่วยเมตร (ม.) ด้วยความแม่นยำทศนิยม 2 ตำแหน่ง เช่น 1.70 เมตร (170 ซม.)',
    },
    {
      '@type': 'HowToStep',
      name: 'ชั่งน้ำหนักด้วยเครื่องชั่งที่แม่นยำ',
      text: 'ใช้เครื่องชั่งน้ำหนักที่ถูกต้อง บันทึกน้ำหนักเป็นกิโลกรัม (กก.) ด้วยความแม่นยำ 0.5 กก. เช่น 65 กก. (ชั่งโดยสวมเสื้อผ้าน้อยที่สุด)',
    },
    {
      '@type': 'HowToStep',
      name: 'คำนวณกำลังสองของส่วนสูง',
      text: 'นำส่วนสูง (เมตร) มายกกำลังสอง เช่น 1.70 × 1.70 = 2.89 ตารางเมตร',
    },
    {
      '@type': 'HowToStep',
      name: 'หารน้ำหนักด้วยกำลังสองของส่วนสูง',
      text: 'BMI = น้ำหนัก (กก.) ÷ ส่วนสูง² (ตร.ม.) = 65 ÷ 2.89 = 22.49',
    },
    {
      '@type': 'HowToStep',
      name: 'แปลความหมาย BMI ตามมาตรฐาน WHO Asia-Pacific',
      text: 'ตารางแปลผล: BMI < 18.5 = น้ำหนักน้อย, BMI 18.5–22.9 = ปกติ, BMI 23–24.9 = น้ำหนักเกิน, BMI ≥ 25 = อ้วน ในตัวอย่าง BMI 22.49 = ปกติ',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ BMI ดัชนีมวลกาย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <style>
    /* Slide-in animation for result card (fade + slide up) */
    @keyframes slideInResult {
      0% {
        opacity: 0;
        transform: translateY(16px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Color pulse animation for BMI value — attention draw */
    @keyframes colorPulse {
      0%, 100% {
        filter: brightness(1);
      }
      50% {
        filter: brightness(1.15);
      }
    }

    /* Subtle glow on gauge pointer */
    @keyframes pointerGlow {
      0%, 100% {
        filter: drop-shadow(0 0 0 rgba(0, 0, 0, 0.2));
      }
      50% {
        filter: drop-shadow(0 0 4px rgba(0, 0, 0, 0.4));
      }
    }

    .result-animate-in {
      animation: slideInResult 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    .bmi-value-pulse {
      animation: colorPulse 1.2s ease-in-out 2;
    }

    #bmi-pointer {
      animation: pointerGlow 1.5s ease-in-out infinite;
    }
  </style>

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณ BMI (ดัชนีมวลกาย)
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2">
      <p class="text-xs font-semibold text-green-800">[อัปเดตตามเกณฑ์ WHO Asia-Pacific 2569] • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่า BMI ออนไลน์ฟรี ใช้เกณฑ์ WHO Asia-Pacific สำหรับคนเอเชีย พร้อมคำแนะนำสุขภาพ
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="weight" class="block text-sm font-medium text-gray-700 mb-1">
            น้ำหนัก (กิโลกรัม)
          </label>
          <input
            type="text"
            id="weight"
            inputmode="decimal"
            placeholder="เช่น 65"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="height" class="block text-sm font-medium text-gray-700 mb-1">
            ส่วนสูง (เซนติเมตร)
          </label>
          <input
            type="text"
            id="height"
            inputmode="decimal"
            placeholder="เช่น 170"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณ BMI
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6 border-2 border-primary-600 bg-primary-50 rounded-lg p-6 shadow-sm">
        <!-- BMI Value -->
        <div class="text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ค่า BMI ของคุณ</div>
          <div id="bmi-value" class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-2">-</div>
          <div id="bmi-category" class="text-lg font-semibold px-4 py-1 rounded-full inline-block">-</div>
        </div>

        <!-- BMI Gauge -->
        <div class="mb-6">
          <div class="relative h-6 rounded-full overflow-hidden flex">
            <div class="bg-blue-400 flex-1" title="น้ำหนักน้อย"></div>
            <div class="bg-green-400 flex-1" title="ปกติ"></div>
            <div class="bg-yellow-400 flex-1" title="น้ำหนักเกิน"></div>
            <div class="bg-red-400 flex-1" title="อ้วน"></div>
          </div>
          <div class="relative h-4">
            <div id="bmi-pointer" class="absolute transition-all duration-500 -translate-x-1/2" style="left: 0%;">
              <div class="w-0 h-0 border-l-[6px] border-r-[6px] border-b-[8px] border-l-transparent border-r-transparent border-b-gray-800"></div>
            </div>
          </div>
          <div class="flex justify-between text-xs text-gray-500 mt-1">
            <span>15</span>
            <span>18.5</span>
            <span>23</span>
            <span>25</span>
            <span>35+</span>
          </div>
          <div class="flex text-xs sm:text-sm text-gray-500 mt-1">
            <div class="flex-1 text-center">น้ำหนักน้อย</div>
            <div class="flex-1 text-center">ปกติ</div>
            <div class="flex-1 text-center">เกิน</div>
            <div class="flex-1 text-center">อ้วน</div>
          </div>
        </div>

        <!-- Health Tips -->
        <div id="health-tips" class="bg-gray-50 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-2">คำแนะนำ</h3>
          <p id="tips-text" class="text-sm text-gray-600"></p>
        </div>

        <!-- Healthy Weight Range -->
        <div class="mt-4 bg-green-50 rounded-lg p-4">
          <h3 class="font-semibold text-gray-900 mb-2">น้ำหนักที่เหมาะสม</h3>
          <p id="healthy-range" class="text-sm text-gray-600"></p>
        </div>

        <!-- Important Disclaimer -->
        <details class="mt-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4">
          <summary class="font-semibold text-yellow-900 cursor-pointer select-none hover:text-yellow-800 transition-colors">
            ⚠️ สำคัญ: ข้อจำกัดของ BMI
          </summary>
          <div class="mt-3 text-sm text-yellow-800 space-y-2">
            <p>• BMI ไม่แยกแยะมวลกล้ามเนื้อกับไขมัน — นักกีฬาอาจมี BMI สูงแต่ไม่อ้วน</p>
            <p>• ไม่เหมาะกับเด็ก ผู้สูงอายุ หญิงตั้งครรภ์ และผู้ป่วยเรื้อรัง</p>
            <p>• ไม่คำนึงถึงการกระจายตัวของไขมัน (ไขมันหน้าท้องอันตรายกว่า)</p>
            <p>• ควรใช้ร่วมกับการวัดเส้นรอบเอว และการตรวจสุขภาพโดยแพทย์</p>
          </div>
        </details>
      </div>
    </div>

    <!-- Divider -->
    <div class="my-8 border-t-2 border-gray-200"></div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ดัชนีมวลกาย (BMI) คืออะไร?</h2>

      <p>
        ดัชนีมวลกาย (Body Mass Index หรือ BMI) เป็นค่าที่ใช้ประเมินภาวะโภชนาการ
        โดยคำนวณจากน้ำหนักตัว (กิโลกรัม) หารด้วยส่วนสูง (เมตร) ยกกำลังสอง
        ค่า BMI ช่วยบอกว่าน้ำหนักตัวอยู่ในเกณฑ์ที่เหมาะสมกับส่วนสูงหรือไม่
        และเป็นตัวชี้วัดเบื้องต้นของความเสี่ยงต่อโรคเรื้อรัง
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณ BMI</h3>

      <div class="bg-gray-50 rounded-lg p-4 text-center my-4">
        <p class="text-lg font-semibold">BMI = น้ำหนัก (กก.) ÷ ส่วนสูง (ม.)<sup>2</sup></p>
        <p class="text-sm text-gray-500 mt-1">ตัวอย่าง: น้ำหนัก 65 กก. ส่วนสูง 170 ซม. → BMI = 65 ÷ 1.70² = 22.49</p>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เกณฑ์ BMI สำหรับคนเอเชีย (WHO Asia-Pacific)</h3>

      <p>
        องค์การอนามัยโลกภูมิภาคเอเชีย-แปซิฟิก กำหนดเกณฑ์ BMI สำหรับคนเอเชียไว้ต่ำกว่าเกณฑ์สากล
        เนื่องจากงานวิจัยพบว่าคนเอเชียมีความเสี่ยงต่อโรคเบาหวาน โรคหัวใจ และความดันโลหิตสูง
        ที่ค่า BMI ต่ำกว่าคนตะวันตก
      </p>

      <div class="overflow-x-auto my-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b-2 border-gray-300">
              <th class="py-2 pr-4">ระดับ</th>
              <th class="py-2 pr-4">ค่า BMI</th>
              <th class="py-2">ความเสี่ยงต่อสุขภาพ</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 text-blue-600 font-medium">น้ำหนักน้อย</td>
              <td class="py-2 pr-4">ต่ำกว่า 18.5</td>
              <td class="py-2">เสี่ยงภาวะขาดสารอาหาร ภูมิคุ้มกันต่ำ</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 text-green-600 font-medium">ปกติ</td>
              <td class="py-2 pr-4">18.5 — 22.9</td>
              <td class="py-2">ต่ำ — น้ำหนักเหมาะสม</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 text-yellow-600 font-medium">น้ำหนักเกิน</td>
              <td class="py-2 pr-4">23.0 — 24.9</td>
              <td class="py-2">ปานกลาง — ควรควบคุมน้ำหนัก</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-red-600 font-medium">อ้วน</td>
              <td class="py-2 pr-4">25.0 ขึ้นไป</td>
              <td class="py-2">สูง — เสี่ยงเบาหวาน โรคหัวใจ ความดัน</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ข้อจำกัดของ BMI</h3>

      <p>
        BMI เป็นเพียงตัวชี้วัดเบื้องต้น มีข้อจำกัดหลายประการ:
      </p>

      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ไม่สามารถแยกแยะระหว่างมวลกล้ามเนื้อกับไขมัน — นักกีฬาอาจมี BMI สูงแต่ไม่อ้วน</li>
        <li>ไม่ได้คำนึงถึงการกระจายตัวของไขมัน — ไขมันหน้าท้องอันตรายกว่าไขมันส่วนอื่น</li>
        <li>ไม่เหมาะกับเด็ก ผู้สูงอายุ และหญิงตั้งครรภ์</li>
        <li>ควรใช้ร่วมกับการวัดเส้นรอบเอวและการตรวจสุขภาพ</li>
      </ul>

      <p class="mt-4">
        เครื่องคำนวณ BMI นี้ใช้เกณฑ์ WHO Asia-Pacific ซึ่งเหมาะกับคนไทยและคนเอเชีย
        ให้ผลลัพธ์แม่นยำกว่าเกณฑ์สากลสำหรับการประเมินความเสี่ยงต่อสุขภาพ
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-8 mb-3">ตัวอย่างการคำนวณ BMI: ส่วนสูง 175 ซม. น้ำหนัก 70 กก.</h3>

      <p class="text-gray-700 mb-3">
        ตัวอย่างนี้แสดงการคำนวณ BMI ของบุคคลที่มีส่วนสูง 175 เซนติเมตร น้ำหนัก 70 กิโลกรัม ซึ่งเป็นสถานการณ์ทั่วไป สะท้อนน้ำหนักที่เหมาะสม:
      </p>

      <div class="bg-blue-50 rounded-lg p-4 mb-4 text-sm">
        <p class="font-semibold text-gray-900 mb-2">ข้อมูลอินพุต:</p>
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>ส่วนสูง: 175 เซนติเมตร = 1.75 เมตร</li>
          <li>น้ำหนัก: 70 กิโลกรัม</li>
        </ul>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-4 text-sm">
        <p class="font-semibold text-gray-900 mb-3">ขั้นตอนการคำนวณ:</p>
        <ol class="list-decimal pl-6 space-y-2 text-gray-700">
          <li><strong>แปลงส่วนสูงเป็นเมตร:</strong> 175 ซม. ÷ 100 = 1.75 ม.</li>
          <li><strong>ยกกำลังสองของส่วนสูง:</strong> 1.75 × 1.75 = 3.0625</li>
          <li><strong>หารน้ำหนักด้วยส่วนสูงกำลังสอง:</strong> 70 ÷ 3.0625 = 22.86</li>
        </ol>
      </div>

      <p class="text-gray-600 text-sm mt-3">
        <strong>ผลลัพธ์:</strong> BMI = 22.86 ซึ่งอยู่ในช่วง 18.5 — 22.9 (ปกติ) ตามเกณฑ์ WHO Asia-Pacific
        หมายความว่าบุคคลนี้มีน้ำหนักเหมาะสมกับส่วนสูง และมีความเสี่ยงต่อโรคเรื้อรังต่ำ ควรรักษาน้ำหนักให้คงที่โดยออกกำลังกายสม่ำเสมอและรับประทานอาหารที่มีประโยชน์
      </p>
    </section>


    <!-- CAL-654 Content Block -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณ BMI และเกณฑ์มาตรฐาน</h2>
      <div class="bg-gray-50 rounded-lg p-4 text-center my-4">
        <p class="text-base font-semibold">BMI = น้ำหนัก (กก.) ÷ [ส่วนสูง (ม.)]²</p>
      </div>
      <p><strong>เกณฑ์มาตรฐาน WHO &amp; กรมอนามัย ประเทศไทย:</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>น้อยเกินไป (Underweight) = BMI &lt; 18.5</li>
        <li>ปกติ (Normal) = BMI 18.5–22.9</li>
        <li>น้ำหนักเกิน (Overweight) = BMI 23.0–24.9</li>
        <li>โรคอ้วน (Obese) = BMI ≥ 25.0</li>
      </ul>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">ตัวอย่างการคำนวณ BMI</h2>

      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่างที่ 1: BMI ปกติ</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>ส่วนสูง = 170 ซม. = 1.70 เมตร</li>
          <li>น้ำหนัก = 65 กก.</li>
          <li>BMI = 65 ÷ (1.70)² = 65 ÷ 2.89 = <strong>22.5 (ปกติ)</strong></li>
        </ul>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่างที่ 2: น้ำหนักเกิน</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>ส่วนสูง = 165 ซม. = 1.65 เมตร</li>
          <li>น้ำหนัก = 70 กก.</li>
          <li>BMI = 70 ÷ (1.65)² = 70 ÷ 2.7225 = <strong>25.7 (น้ำหนักเกิน)</strong></li>
        </ul>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่างที่ 3: น้ำหนักน้อยเกินไป</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>ส่วนสูง = 160 ซม. = 1.60 เมตร</li>
          <li>น้ำหนัก = 48 กก.</li>
          <li>BMI = 48 ÷ (1.60)² = 48 ÷ 2.56 = <strong>18.75 (ปกติ แต่ใกล้ขีดต่ำ)</strong></li>
        </ul>
      </div>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">วิธีคำนวณ BMI ด้วยตนเอง</h2>
      <ol class="list-decimal pl-6 space-y-2 text-gray-700">
        <li>วัดส่วนสูง: ยืนตรง ถอดรองเท้า บันทึกเป็นเมตร (เช่น 170 ซม. = 1.70 ม.)</li>
        <li>ชั่งน้ำหนัก: ตอนเช้าหลังเข้าห้องน้ำ ก่อนรับประทานอาหาร</li>
        <li>ยกกำลังสองของส่วนสูง: เช่น 1.70² = 2.89</li>
        <li>หารน้ำหนักด้วยกำลังสองของส่วนสูง: 65 ÷ 2.89 = 22.5</li>
        <li>เทียบเกณฑ์มาตรฐาน WHO Asia-Pacific สำหรับคนไทย</li>
        <li>ติดตาม BMI ทุก 1 เดือน และปรึกษาแพทย์หากต้องการบริหารน้ำหนัก</li>
      </ol>

      <p class="mt-4 text-sm text-gray-600">
        <strong>แหล่งอ้างอิง:</strong>
