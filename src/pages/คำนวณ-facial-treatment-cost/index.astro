---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าแฟเซียล | Kamnuanlek';
const pageDescription = 'คำนวณค่าแฟเซียล - คำนวณออนไลน์ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-facial-treatment-cost//`;

const faqData = [
  { question: 'ราคาเฉลี่ยของบริการนี้คือเท่าไร?', answer: 'ราคาขึ้นอยู่กับร้าน ทำเล และระดับบริการ ใช้เครื่องคำนวณด้านบนเพื่อประมาณค่าใช้จ่ายตามตัวเลือกที่ต้องการ' },
  { question: 'ควรทำบริการนี้บ่อยแค่ไหน?', answer: 'ขึ้นอยู่กับประเภทบริการและสภาพของแต่ละคน โดยทั่วไปทุก 2-6 สัปดาห์ตามคำแนะนำของช่าง' },
  { question: 'มีวิธีประหยัดค่าใช้จ่ายอย่างไร?', answer: 'เลือกแพ็กเกจ สมัครสมาชิก หรือจองล่วงหน้าในช่วงโปรโมชั่น บางร้านมีส่วนลดสำหรับลูกค้าประจำ' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกรายละเอียดบริการที่ต้องการ เช่น ประเภท จำนวนครั้ง และตัวเลือกเสริม เครื่องจะคำนวณค่าใช้จ่ายรวมให้ทันที' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าแฟเซียล">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าแฟเซียล</h1>
    <div class="mb-4 inline-block rounded-lg border border-fuchsia-200 bg-fuchsia-50 px-3 py-2">
      <p class="text-xs font-semibold text-fuchsia-800">[KLC-0787]</p>
    </div>
    
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ค่าบริการ (บาท)</label>
          <input type="text" id="cost" inputmode="decimal" placeholder="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้ง/เดือน</label>
          <input type="text" id="frequency" inputmode="decimal" placeholder="2" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
      </div>
      
      <button type="button" id="btn-calc" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 text-base">คำนวณ</button>
      
      <div id="result" class="hidden mt-6 grid gap-4 sm:grid-cols-2 text-center">
        <div><div class="text-sm text-gray-600 mb-1">รายเดือน</div><div id="monthly" class="text-3xl font-bold text-primary-600">-</div></div>
        <div><div class="text-sm text-gray-600 mb-1">ต่อปี</div><div id="yearly" class="text-3xl font-bold text-primary-600">-</div></div>
      </div>
    </div>

    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">[โฆษณา]</div>
  </article>

  <script>
    function fmt(n: number) { return new Intl.NumberFormat('th-TH', {style: 'currency', currency: 'THB', minimumFractionDigits: 0, maximumFractionDigits: 0}).format(n); }
    document.getElementById('btn-calc')?.addEventListener('click', () => {
      const cost = parseFloat((document.getElementById('cost') as HTMLInputElement)?.value) || 0;
      const freq = parseFloat((document.getElementById('frequency') as HTMLInputElement)?.value) || 0;
      const monthly = cost * freq;
      document.getElementById('monthly')!.textContent = fmt(monthly);
      document.getElementById('yearly')!.textContent = fmt(monthly * 12);
      document.getElementById('result')!.classList.remove('hidden');
    });
  </script>
</BaseLayout>
