  <script>
    import { calculateVisaFee, destinations, visaTypeLabels, getDestinationById } from '../../lib/visa-fee-calculator';
    import type { VisaDestination, VisaType, ProcessingSpeed } from '../../lib/visa-fee-calculator';

    /* ── helpers ── */
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    /* ── state ── */
    let selectedDest: VisaDestination = 'japan';
    let selectedVisaType: VisaType = 'tourist';
    let selectedSpeed: ProcessingSpeed = 'regular';

    /* ── DOM refs ── */
    const destBtns = document.querySelectorAll<HTMLButtonElement>('.dest-btn');
    const speedBtns = document.querySelectorAll<HTMLButtonElement>('.speed-btn');
    const visaTypeGrid = document.getElementById('visa-type-grid')!;
    const btnCalculate = document.getElementById('btn-calculate')!;
    const resultsDiv = document.getElementById('results')!;
    const exemptNotice = document.getElementById('visa-exempt-notice')!;
    const exemptText = document.getElementById('exempt-text')!;
    const noExpressNote = document.getElementById('no-express-note')!;

    /* ── button toggle helper ── */
    function activateBtn(group: NodeListOf<HTMLButtonElement> | HTMLButtonElement[], activeBtn: HTMLButtonElement) {
      (group as NodeListOf<HTMLButtonElement>).forEach((b: HTMLButtonElement) => {
        b.classList.remove('active-btn', 'border-primary-500', 'bg-primary-50', 'text-primary-700');
        b.classList.add('border-gray-200', 'bg-white', 'text-gray-700');
      });
      activeBtn.classList.add('active-btn', 'border-primary-500', 'bg-primary-50', 'text-primary-700');
      activeBtn.classList.remove('border-gray-200', 'bg-white', 'text-gray-700');
    }

    /* ── render visa type buttons for selected destination ── */
    function renderVisaTypes(destId: VisaDestination) {
      const dest = getDestinationById(destId);
      if (!dest) return;

      visaTypeGrid.innerHTML = dest.availableVisaTypes
        .map((vt, i) => {
          const isActive = i === 0;
          const activeClass = isActive
            ? 'active-btn border-primary-500 bg-primary-50 text-primary-700'
            : 'border-gray-200 bg-white text-gray-700 hover:border-gray-300';
          return `<button type="button" data-visatype="${vt}" class="visatype-btn rounded-lg border-2 px-3 py-3 text-center text-sm font-semibold transition-colors ${activeClass}">${visaTypeLabels[vt]}</button>`;
        })
        .join('');

      // Set default visa type
      selectedVisaType = dest.availableVisaTypes[0];

      // Bind visa type events
      const vtBtns = document.querySelectorAll<HTMLButtonElement>('.visatype-btn');
      vtBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          selectedVisaType = btn.dataset.visatype as VisaType;
          activateBtn(vtBtns, btn);
        });
      });
    }

    /* ── update exempt notice ── */
    function updateExemptNotice(destId: VisaDestination) {
      const dest = getDestinationById(destId);
      if (!dest) return;

      if (dest.visaExemptDays) {
        exemptNotice.classList.remove('hidden');
        exemptText.textContent = `คนไทยเข้า${dest.name}ได้โดยไม่ต้องขอวีซ่า สูงสุด ${dest.visaExemptDays} วัน`;
      } else if (dest.visaOnArrivalDays) {
        exemptNotice.classList.remove('hidden');
        exemptText.textContent = `คนไทยขอ Visa on Arrival เข้า${dest.name}ได้ สูงสุด ${dest.visaOnArrivalDays} วัน`;
      } else {
        exemptNotice.classList.add('hidden');
      }
    }

    /* ── destination click ── */
    destBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedDest = btn.dataset.dest as VisaDestination;
        activateBtn(destBtns, btn);
        renderVisaTypes(selectedDest);
        updateExemptNotice(selectedDest);
      });
    });

    /* ── speed click ── */
    speedBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedSpeed = btn.dataset.speed as ProcessingSpeed;
        activateBtn(speedBtns, btn);
      });
    });

    /* ── calculate ── */
    btnCalculate.addEventListener('click', () => {
      const numApplicants = Math.max(1, Math.min(20, parseInt((document.getElementById('num-applicants') as HTMLInputElement).value) || 1));

      const result = calculateVisaFee({
        destination: selectedDest,
        visaType: selectedVisaType,
        processingSpeed: selectedSpeed,
        numberOfApplicants: numApplicants,
      });

      // Update summary cards
      document.getElementById('res-total')!.textContent = fmt(result.totalAll) + ' บาท';
      document.getElementById('res-per-person')!.textContent = fmt(result.totalPerPerson) + ' บาท';
      document.getElementById('res-processing')!.textContent = result.processingDays;
      document.getElementById('res-applicants')!.textContent = numApplicants + ' คน';

      // Update breakdown table
      document.getElementById('res-visa-fee')!.textContent = fmt(result.visaFee);

      // Original currency
      const rowOriginal = document.getElementById('row-original-fee')!;
      if (result.currency !== 'THB' && result.originalFee > 0) {
        rowOriginal.classList.remove('hidden');
        document.getElementById('res-original-label')!.textContent = `(${result.currency} ${result.originalFee})`;
        document.getElementById('res-original-fee')!.textContent = '';
      } else {
        rowOriginal.classList.add('hidden');
      }

      // Service fee
      const rowService = document.getElementById('row-service')!;
      if (result.serviceFee > 0) {
        rowService.classList.remove('hidden');
        document.getElementById('res-service-fee')!.textContent = fmt(result.serviceFee);
      } else {
        rowService.classList.add('hidden');
      }

      // Express surcharge
      const rowExpress = document.getElementById('row-express')!;
      if (result.expressSurcharge > 0) {
        rowExpress.classList.remove('hidden');
        document.getElementById('res-express')!.textContent = fmt(result.expressSurcharge);
      } else {
        rowExpress.classList.add('hidden');
      }

      document.getElementById('res-per-person-table')!.textContent = fmt(result.totalPerPerson);

      // Multi applicant row
      const rowMulti = document.getElementById('row-multi')!;
      if (numApplicants > 1) {
        rowMulti.classList.remove('hidden');
        document.getElementById('res-multi-label')!.textContent = `x ${numApplicants} คน`;
      } else {
        rowMulti.classList.add('hidden');
      }

      document.getElementById('res-total-table')!.textContent = fmt(result.totalAll);

      // Notes
      const notesList = document.getElementById('notes-list')!;
      notesList.innerHTML = result.notes
        .map(
          (note) =>
            `<li class="flex items-start gap-2">
              <span class="mt-0.5 flex-shrink-0 text-primary-500">•</span>
              <span class="text-sm text-gray-700">${note}</span>
            </li>`
        )
        .join('');

      // Show results
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      // Analytics
      if (typeof trackCalculatorUsed === 'function') {
        trackCalculatorUsed('visa_fee');
      }
    });

    /* ── analytics: track result view ── */
    const resultObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (typeof trackResultViewed === 'function') {
              trackResultViewed('visa_fee');
            }
            resultObserver.disconnect();
          }
        });
      },
      { threshold: 0.5 }
    );
    resultObserver.observe(resultsDiv);

    /* ── initialize ── */
    renderVisaTypes(selectedDest);
    updateExemptNotice(selectedDest);
  </script>
</BaseLayout>
