---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณต้นทุนการเลี้ยงสุกร | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการเลี้ยงหมู สุกร ค่าอาหาร ยา วัคซีน กำไรต่อตัวต่อรุ่น';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0492-เลี้ยงหมู/`;
const faqData = [
  { question: 'ต้นทุนเลี้ยงหมูขุนต่อกิโลกรัมเฉลี่ยเท่าไหร่?', answer: 'ต้นทุนสุกรขุน 55-70 บาท/กก. น้ำหนักมีชีวิต ณ ราคาปัจจุบัน รอบการเลี้ยง 150-170 วัน น้ำหนักเฉลี่ย 100-110 กก./ตัว' },
  { question: 'ราคาสุกรมีชีวิตปัจจุบันเท่าไหร่?', answer: 'ราคาสุกรมีชีวิตหน้าฟาร์ม 60-80 บาท/กก. ราคาผันผวนตามอุปสงค์อุปทาน ติดตามราคาจากสมาคมผู้เลี้ยงสุกรแห่งชาติ หรือกรมปศุสัตว์' },
  { question: 'โรคหลักที่ต้องระวังในการเลี้ยงสุกรมีอะไร?', answer: 'โรค ASF (อหิวาต์แอฟริกาในสุกร) ยังไม่มีวัคซีน ต้องป้องกันด้วยความปลอดภัยทางชีวภาพ FMD (โรคปากเท้าเปื่อย) PRRS CSF ต้องฉีดวัคซีนป้องกัน' },
  { question: 'เลี้ยงหมูขนาดเท่าไหร่จึงจะคุ้มทุน?', answer: 'ฟาร์มหมูขุนที่ต้นทุนต่อหน่วยต่ำต้องเลี้ยงอย่างน้อย 500-1,000 ตัว/รุ่น ฟาร์มเล็ก 100-200 ตัว ต้นทุนสูงกว่าแต่บริหารง่ายกว่า เหมาะเริ่มต้น' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนการเลี้ยงสุกร">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนการเลี้ยงสุกร</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนและกำไรการเลี้ยงหมูต่อรุ่น</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="pig_count" class="block text-sm font-medium text-gray-700 mb-1">จำนวนสุกร (ตัว)</label><input type="number" id="pig_count" min="1" placeholder="เช่น 100" value="100" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="piglet_price" class="block text-sm font-medium text-gray-700 mb-1">ราคาลูกหมู/ตัว (บาท)</label><input type="text" id="piglet_price" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="pig_feed_total" class="block text-sm font-medium text-gray-700 mb-1">ค่าอาหารรวม/ตัว (บาท)</label><input type="text" id="pig_feed_total" inputmode="decimal" placeholder="เช่น 3500" value="3500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="pig_sell_kg" class="block text-sm font-medium text-gray-700 mb-1">น้ำหนักขายต่อตัว (กก.)</label><input type="number" id="pig_sell_kg" min="1" placeholder="เช่น 105" value="105" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="pig_price_kg" class="block text-sm font-medium text-gray-700 mb-1">ราคาขาย (บาท/กก.)</label><input type="text" id="pig_price_kg" inputmode="decimal" placeholder="เช่น 70" value="70" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวมทั้งรุ่น</p><p id="pig_total_cost" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">กำไรสุทธิ/รุ่น</p><p id="pig_profit" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const count = parseFloat((document.getElementById('pig_count') as HTMLInputElement).value) || 0;
      const pigletPrice = parseFloat((document.getElementById('piglet_price') as HTMLInputElement).value) || 0;
      const feedTotal = parseFloat((document.getElementById('pig_feed_total') as HTMLInputElement).value) || 0;
      const sellKg = parseFloat((document.getElementById('pig_sell_kg') as HTMLInputElement).value) || 0;
      const priceKg = parseFloat((document.getElementById('pig_price_kg') as HTMLInputElement).value) || 0;
      const costPerHead = pigletPrice + feedTotal;
      const totalCost = costPerHead * count;
      const totalRevenue = sellKg * priceKg * count;
      const profit = totalRevenue - totalCost;
      (document.getElementById('pig_total_cost') as HTMLElement).textContent = Math.round(totalCost).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('pig_profit') as HTMLElement).textContent = Math.round(profit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('pig-farming-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
