---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเปรียบเทียบทุนการศึกษา ปี 2569 | คะแนนประเมินมูลค่า | เครื่องคำนวณไทย';
const pageDescription = 'เปรียบเทียบมูลค่าและผลประโยชน์จากทุนการศึกษา โครงการดัชนี ทุนที่มีเงื่อนไข ทุนผ่อนชำระ ทั้งภาครัฐและเอกชน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเปรียบเทียบทุนการศึกษา/`;

const faqData = [
  {
    question: 'ทุนการศึกษาประเภทใดบ้าง?',
    answer: 'ทุนการศึกษามีหลายประเภท: ทุนเต็มจำนวน (ครบการศึกษา), ทุนบางส่วน (ลดค่าเรียน), ทุนอุดหนุนเพิ่มเติม (ค่าอพยพ/หนังสือ), ทุนสนับสนุนการขยายโอกาส, และโครงการยืมเงินทั่วไป',
  },
  {
    question: 'ทุนใดดีสำหรับเปรียบเทียบ?',
    answer: 'ควรเปรียบเทียบตามปัจจัย: อัตราทุน (บาท), ระยะเวลา, เงื่อนไขการผ่อนชำระ, การสนับสนุนอื่นเพิ่มเติม, และความเสี่ยง (ต้องคืนเงิน/ต้องสอบด้วย)',
  },
  {
    question: 'วิธีการประเมินมูลค่าทุนอย่างไร?',
    answer: 'ประเมินโดยคำนวณ: (มูลค่าทุนทั้งหมด) ÷ (จำนวนปีศึกษา) = มูลค่าทุนต่อปี เปรียบเทียบกับค่าใช้จ่ายจริง และพิจารณาเงื่อนไขเพิ่มเติม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเปรียบเทียบทุนการศึกษา',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเปรียบเทียบทุนการศึกษา">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณเปรียบเทียบทุนการศึกษา ปี 2569</h1>

    <p class="text-gray-600 mb-6">
      เปรียบเทียบมูลค่า สิทธิประโยชน์ และต้นทุนของทุนการศึกษาต่างๆ เพื่อเลือกทุนที่เหมาะสมที่สุด
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="scholarship-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="scholar1-name" class="block text-sm font-medium text-gray-700 mb-1">
              ชื่อทุนที่ 1 — ไม่บังคับ
            </label>
            <input
              type="text"
              id="scholar1-name"
              placeholder="เช่น ทุน ม.หลัก"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="scholar1-amount" class="block text-sm font-medium text-gray-700 mb-1">
              มูลค่าทุน (บาท)
            </label>
            <input
              type="text"
              id="scholar1-amount"
              inputmode="numeric"
              placeholder="เช่น 100,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="scholar2-name" class="block text-sm font-medium text-gray-700 mb-1">
              ชื่อทุนที่ 2 — ไม่บังคับ
            </label>
            <input
              type="text"
              id="scholar2-name"
              placeholder="เช่น ทุน ม.รัฐ"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="scholar2-amount" class="block text-sm font-medium text-gray-700 mb-1">
              มูลค่าทุน (บาท)
            </label>
            <input
              type="text"
              id="scholar2-amount"
              inputmode="numeric"
              placeholder="เช่น 80,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="years" class="block text-sm font-medium text-gray-700 mb-1">
            ระยะเวลาศึกษา (ปี)
          </label>
          <input
            type="text"
            id="years"
            inputmode="numeric"
            placeholder="เช่น 4"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          />
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-blue-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-700">
          เปรียบเทียบทุน
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการเปรียบเทียบ</h2>

        <div id="comparison-results" class="space-y-4">
          <!-- Dynamically populated -->
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <RelatedCalculators currentHref="/คำนวณเปรียบเทียบทุนการศึกษา/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-blue-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return 0;
    return Number(String(value).replace(/,/g, '').trim()) || 0;
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#scholarship-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const scholar1Name = document.querySelector('#scholar1-name')?.value || 'ทุน 1';
    const scholar1Amount = parseNumber(document.querySelector('#scholar1-amount')?.value || '');
    const scholar2Name = document.querySelector('#scholar2-name')?.value || 'ทุน 2';
    const scholar2Amount = parseNumber(document.querySelector('#scholar2-amount')?.value || '');
    const years = parseNumber(document.querySelector('#years')?.value || '');

    if (!(years > 0 && (scholar1Amount > 0 || scholar2Amount > 0))) {
      results?.classList.add('hidden');
      return;
    }

    const scholarships = [];
    if (scholar1Amount > 0) {
      scholarships.push({
        name: scholar1Name,
        amount: scholar1Amount,
        perYear: scholar1Amount / years,
      });
    }
    if (scholar2Amount > 0) {
      scholarships.push({
        name: scholar2Name,
        amount: scholar2Amount,
        perYear: scholar2Amount / years,
      });
    }

    const html = scholarships.map(s => `
      <div class="rounded-lg border border-gray-200 p-4">
        <h3 class="font-semibold text-gray-900 mb-3">${s.name}</h3>
        <div class="grid grid-cols-2 gap-2 text-sm">
          <div class="text-gray-600">มูลค่าทั้งหมด</div>
          <div class="font-medium text-right">${formatCurrency(s.amount)}</div>
          <div class="text-gray-600">มูลค่า/ปี</div>
          <div class="font-medium text-right">${formatCurrency(s.perYear)}</div>
        </div>
      </div>
    `).join('');

    document.querySelector('#comparison-results').innerHTML = html;
    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
