---
import BaseLayout from '../layouts/BaseLayout.astro';

const businessCalcs = [
  { title: 'Break-Even Calculator', slug: '/คำนวณ-break-even/', desc: 'Find profitability point' },
  { title: 'ROE Calculator', slug: '/คำนวณ-roe/', desc: 'Return on equity' },
  { title: 'ROA Calculator', slug: '/คำนวณ-roa/', desc: 'Return on assets' },
  { title: 'CAGR Calculator', slug: '/คำนวณ-cagr/', desc: 'Growth rate analysis' },
  { title: 'WACC Calculator', slug: '/คำนวณ-wacc/', desc: 'Cost of capital' },
  { title: 'D/E Ratio', slug: '/คำนวณ-debt-to-equity/', desc: 'Leverage analysis' },
];
---

<BaseLayout
  title="เครื่องคำนวณธุรกิจ — ROE กำไร จุดคุ้มทุน VAT | Kamnuanlek"
  description="เครื่องคำนวณธุรกิจฟรีครบชุด คำนวณจุดคุ้มทุน ROE ROA CAGR ภาษีมูลค่าเพิ่ม ต้นทุนขาย อัตรากำไร และตัวชี้วัดทางธุรกิจสำหรับผู้ประกอบการไทย"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณธุรกิจ</h1>
    <p class="text-xl text-gray-600 mb-12">
      Calculate profitability, analyze business performance, and make data-driven decisions. Essential tools for business owners.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {businessCalcs.map((calc) => (
        <a
          href={calc.slug}
          class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all"
        >
          <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-600">{calc.title}</h3>
          <p class="text-gray-600 text-sm mb-4">{calc.desc}</p>
          <span class="text-primary-600 text-sm font-medium">Analyze →</span>
        </a>
      ))}
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">More Tools for Business</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Calculators</span>
          <p class="text-gray-600 text-sm mt-2">Tax, loans, and investment tools</p>
        </a>
        <a href="/เครื่องคำนวณคณิตศาสตร์/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📐 Math & Statistics</span>
          <p class="text-gray-600 text-sm mt-2">Statistical analysis and data tools</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
