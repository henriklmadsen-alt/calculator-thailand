---
import BaseLayout from '../layouts/BaseLayout.astro';

const businessCalcs = [
  { title: 'เครื่องคำนวณจุดคุ้มทุน', slug: '/คำนวณ-break-even/', desc: 'หาจุดที่รายได้เท่ากับต้นทุน' },
  { title: 'เครื่องคำนวณ ROE', slug: '/คำนวณ-roe/', desc: 'ผลตอบแทนต่อส่วนของผู้ถือหุ้น' },
  { title: 'เครื่องคำนวณ ROA', slug: '/คำนวณ-roa/', desc: 'ผลตอบแทนต่อสินทรัพย์รวม' },
  { title: 'เครื่องคำนวณ CAGR', slug: '/คำนวณ-cagr/', desc: 'วิเคราะห์อัตราการเติบโตต่อปี' },
  { title: 'เครื่องคำนวณ WACC', slug: '/คำนวณ-wacc/', desc: 'ต้นทุนถัวเฉลี่ยถ่วงน้ำหนักของเงินทุน' },
  { title: 'อัตราส่วน D/E', slug: '/คำนวณ-debt-to-equity/', desc: 'วิเคราะห์ภาระหนี้สินต่อทุน' },
];
---

<BaseLayout
  title="เครื่องคำนวณธุรกิจ — ROE กำไร จุดคุ้มทุน VAT | Kamnuanlek"
  description="เครื่องคำนวณธุรกิจฟรีครบชุด คำนวณจุดคุ้มทุน ROE ROA CAGR ภาษีมูลค่าเพิ่ม ต้นทุนขาย อัตรากำไร และตัวชี้วัดทางธุรกิจสำหรับผู้ประกอบการไทย"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เครื่องคำนวณธุรกิจ — ROE กำไร จุดคุ้มทุน VAT", "item": "https://www.kamnuanlek.com/เครื่องคำนวณธุรกิจ/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณธุรกิจ</h1>
    <p class="text-xl text-gray-600 mb-12">
      คำนวณความสามารถในการทำกำไร วิเคราะห์ผลการดำเนินงาน และตัดสินใจบนฐานข้อมูลจริง เครื่องมือสำคัญสำหรับผู้ประกอบการ
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {businessCalcs.map((calc) => (
        <a
          href={calc.slug}
          class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all"
        >
          <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-600">{calc.title}</h3>
          <p class="text-gray-600 text-sm mb-4">{calc.desc}</p>
          <span class="text-primary-600 text-sm font-medium">วิเคราะห์ →</span>
        </a>
      ))}
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือสำหรับธุรกิจเพิ่มเติม</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 เครื่องคำนวณการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">ภาษี สินเชื่อ และเครื่องมือการลงทุน</p>
        </a>
        <a href="/เครื่องคำนวณคณิตศาสตร์/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📐 คณิตศาสตร์และสถิติ</span>
          <p class="text-gray-600 text-sm mt-2">วิเคราะห์สถิติและข้อมูลเชิงตัวเลข</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
