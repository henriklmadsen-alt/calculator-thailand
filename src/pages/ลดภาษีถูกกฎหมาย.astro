        {
          strategy: 'ดอกเบี้ยสินเชื่อบ้าน',
          maxDeduction: 'ไม่เกิน 100,000 บาท/ปี',
          taxSavingAt30pct: 'ประหยัดได้ถึง 30,000 บาท',
          requirement: 'สินเชื่อบ้านหลังแรกหรือหลังที่สอง ต้องเป็นดอกเบี้ยที่ชำระจริงในปีภาษี',
          badge: 'อสังหาริมทรัพย์',
          badgeColor: 'bg-rose-100 text-rose-700',
        },
        {
          strategy: 'บริจาคให้องค์กรการกุศลที่ได้รับอนุมัติ',
