---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ลดภาษีถูกกฎหมาย 2569 — RMF SSF ประกัน บริจาค ประหยัดได้เท่าไร | Kamnuanlek"
  description="วิธีลดภาษีเงินได้ถูกกฎหมายสำหรับคนไทย RMF SSF ประกันชีวิต ประกันสุขภาพ บริจาค และกลยุทธ์อื่นๆ คำนวณว่าประหยัดได้เท่าไร อัปเดตปี 2569"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Legal Ways to Reduce Your Thai Income Tax</h1>

    <div class="mb-12 p-6 bg-green-50 border border-green-200 rounded-lg">
      <p class="text-lg text-gray-800">
        Every Thai taxpayer can legally reduce their tax bill through these strategies. The key is planning BEFORE December 31.
      </p>
    </div>

    <div class="space-y-6">
      {[
        {
          strategy: 'Invest in RMF (Retirement Mutual Fund)',
          maxDeduction: 'Up to 500,000 THB/year',
          taxSavingAt30pct: 'Up to 150,000 THB saved',
          requirement: 'Hold until age 55, minimum 5-year hold. Max 30% of annual income.',
          badge: 'Most Impactful',
          badgeColor: 'bg-green-100 text-green-700',
        },
        {
          strategy: 'Invest in SSF (Super Saving Fund)',
          maxDeduction: 'Up to 200,000 THB/year',
          taxSavingAt30pct: 'Up to 60,000 THB saved',
          requirement: 'Hold minimum 10 years from purchase date. Max 30% of annual income.',
          badge: 'Flexible',
          badgeColor: 'bg-blue-100 text-blue-700',
        },
        {
          strategy: 'Life Insurance Premiums',
          maxDeduction: 'Up to 100,000 THB/year',
          taxSavingAt30pct: 'Up to 30,000 THB saved',
          requirement: 'Policy must be 10+ years. Can combine with spouse policy.',
          badge: 'Easy to Claim',
          badgeColor: 'bg-purple-100 text-purple-700',
        },
        {
          strategy: 'Health Insurance Premiums',
          maxDeduction: 'Up to 25,000 THB/year',
          taxSavingAt30pct: 'Up to 7,500 THB saved',
          requirement: 'Any qualifying health insurance policy. Also applies to parent health insurance (max 15,000 THB).',
          badge: 'Health Benefit',
          badgeColor: 'bg-pink-100 text-pink-700',
        },
        {
          strategy: 'Home Loan Interest',
          maxDeduction: 'Up to 100,000 THB/year',
          taxSavingAt30pct: 'Up to 30,000 THB saved',
          requirement: 'First or second home loan. Must be actual interest paid in the tax year.',
          badge: 'Property',
          badgeColor: 'bg-rose-100 text-rose-700',
        },
        {
          strategy: 'Donations to Approved Charities',
          maxDeduction: 'Max 10% of net income (2x actual)',
          taxSavingAt30pct: 'Variable',
          requirement: 'Must be to Revenue-approved organizations. Get an official receipt.',
          badge: 'Social Good',
          badgeColor: 'bg-amber-100 text-amber-700',
        },
        {
          strategy: 'Provident Fund / SSO Contributions',
          maxDeduction: 'Actual amount (up to 500,000 THB)',
          taxSavingAt30pct: 'Up to 150,000 THB saved',
          requirement: 'Employee contribution to provident fund or social security.',
          badge: 'Automatic',
          badgeColor: 'bg-gray-100 text-gray-700',
        },
      ].map((item) => (
        <div class="p-6 bg-white border border-gray-200 rounded-lg hover:shadow-lg transition-shadow">
          <div class="flex justify-between items-start mb-3">
            <h3 class="text-xl font-bold text-gray-900">{item.strategy}</h3>
            <span class={`ml-2 flex-shrink-0 px-3 py-1 rounded-full text-xs font-semibold ${item.badgeColor}`}>{item.badge}</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-3">
            <div class="p-3 bg-green-50 rounded-lg">
              <p class="text-xs text-gray-600">Max Deduction</p>
              <p class="font-bold text-green-700">{item.maxDeduction}</p>
            </div>
            <div class="p-3 bg-blue-50 rounded-lg">
              <p class="text-xs text-gray-600">Tax Saved (30% bracket)</p>
              <p class="font-bold text-blue-700">{item.taxSavingAt30pct}</p>
            </div>
          </div>
          <p class="text-gray-600 text-sm">{item.requirement}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 p-6 bg-primary-50 border border-primary-200 rounded-lg">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Calculate Your Tax Savings</h2>
      <p class="text-gray-700 mb-4">
        Use our income tax calculator to compare your tax before and after deductions. Enter your deductions to see exactly how much you save.
      </p>
      <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-semibold">
        Calculate Your Tax →
      </a>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Resources</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/ตรวจสอบหักลดหย่อนภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">✅ Deductions Checklist</span>
          <p class="text-gray-600 text-sm mt-2">Complete checklist of all write-offs</p>
        </a>
        <a href="/อัตราภาษีเงินได้2569/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 Tax Brackets 2026</span>
          <p class="text-gray-600 text-sm mt-2">Current income tax rates</p>
        </a>
        <a href="/แผนการเกษียณ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🌴 Retirement Planning</span>
          <p class="text-gray-600 text-sm mt-2">RMF and SSF investment strategy</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
