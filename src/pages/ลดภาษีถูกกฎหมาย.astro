>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "ลดภาษีถูกกฎหมาย 2569 — RMF SSF ประกัน บริจาค ประหยัดได้เท่าไร", "item": "https://www.kamnuanlek.com/ลดภาษีถูกกฎหมาย/"}
    ]
  }</script>
