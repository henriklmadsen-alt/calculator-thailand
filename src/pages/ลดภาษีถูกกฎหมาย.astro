          badge: 'ประหยัดมากที่สุด',
          badgeColor: 'bg-green-100 text-green-700',
        },
        {
          strategy: 'ลงทุนใน SSF (กองทุนรวมเพื่อการออม)',
          maxDeduction: 'ไม่เกิน 200,000 บาท/ปี',
          taxSavingAt30pct: 'ประหยัดได้ถึง 60,000 บาท',
          requirement: 'ถือขั้นต่ำ 10 ปีนับจากวันซื้อ สูงสุด 30% ของรายได้ต่อปี',
          badge: 'ยืดหยุ่น',
          badgeColor: 'bg-blue-100 text-blue-700',
