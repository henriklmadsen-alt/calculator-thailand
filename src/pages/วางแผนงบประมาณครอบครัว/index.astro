---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'วางแผนงบประมาณครอบครัว ปี 2569 รวมค่าใช้จ่ายบุตร ต้นทุนต่อคน เงินออมครอบครัว | เครื่องคำนวณไทย';
const pageDescription = 'วางแผนงบประมาณครอบครัวรวมค่าใช้จ่ายบุตร ค่าเรียน กิจกรรม สุขภาพเด็ก คำนวณต้นทุนต่อคน รายจ่ายรวม เงินออมครอบครัวต่อเดือน สำหรับครอบครัวไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/วางแผนงบประมาณครอบครัว/`;

const faqData = [
  {
    question: 'ค่าใช้จ่ายบุตรในไทยเฉลี่ยเดือนละเท่าไร?',
    answer: 'ค่าใช้จ่ายบุตรในไทยขึ้นอยู่กับระดับโรงเรียนและไลฟ์สไตล์ โดยเฉลี่ยอยู่ที่ 3,000-15,000 บาท/เดือน/คน รวมค่าเรียน อาหาร เสื้อผ้า กิจกรรมนอกหลักสูตร และค่าแพทย์',
  },
  {
    question: 'ครอบครัวควรออมเงินสำหรับการศึกษาบุตรเท่าไร?',
    answer: 'แนะนำให้เริ่มออมเงินการศึกษาบุตรตั้งแต่แรกเกิด เป้าหมายทั่วไปคือ 500,000-2,000,000 บาท ขึ้นอยู่กับระดับมหาวิทยาลัย หากเริ่มเมื่อบุตรอายุ 0 ขวบ และออม 18 ปี ต้องออมประมาณ 2,300-9,200 บาท/เดือน',
  },
  {
    question: 'งบบุตรควรเป็นสัดส่วนเท่าไรของรายได้ครอบครัว?',
    answer: 'นักวางแผนการเงินแนะนำว่าค่าใช้จ่ายบุตรทั้งหมด (รวมค่าเรียนด้วย) ไม่ควรเกิน 25-30% ของรายได้ครัวเรือน เพื่อให้ยังมีเงินออมและฉุกเฉินเพียงพอ',
  },
  {
    question: 'ต้นทุนต่อคนในครอบครัวคำนวณอย่างไร?',
    answer: 'ต้นทุนต่อคน = (รายจ่ายรวมครัวเรือน) ÷ จำนวนสมาชิก ตัวเลขนี้บอกว่าต้องใช้เงินเลี้ยงแต่ละคนเดือนละเท่าไร ช่วยในการวางแผนเงินฉุกเฉินและประกันชีวิต',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องวางแผนงบประมาณครอบครัว',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="วางแผนงบประมาณครอบครัว">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-emerald-100 bg-emerald-50 p-4">
      <p class="text-sm font-semibold text-emerald-700">วางแผนงบประมาณครอบครัว รวมค่าใช้จ่ายบุตรทุกรายการ</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: รายได้รวม - (ค่าใช้จ่ายครัวเรือน + ค่าใช้จ่ายบุตร) = เงินออมครอบครัว</p>
      <p class="mt-1 text-xs font-medium text-emerald-800">ต้นทุนต่อคน = รายจ่ายรวม ÷ จำนวนสมาชิก</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      วางแผนงบประมาณครอบครัว ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกข้อมูลรายได้รวม จำนวนสมาชิก และค่าใช้จ่ายทุกหมวดรวมค่าบุตร เพื่อดูภาพรวมการเงินครอบครัว
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="fam-form" class="space-y-5">
        <p id="fam-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fam-members" class="mb-1 block text-sm font-medium text-gray-700">จำนวนสมาชิกในครอบครัว (คน)</label>
            <input type="number" id="fam-members" min="1" max="20" placeholder="เช่น 4"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="fam-members-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="fam-income" class="mb-1 block text-sm font-medium text-gray-700">รายได้รวมครอบครัว (บาท/เดือน)</label>
            <input type="text" id="fam-income" inputmode="numeric" placeholder="เช่น 80,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="fam-income-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <p class="text-sm font-semibold text-gray-700">ค่าใช้จ่ายครัวเรือน (บาท/เดือน)</p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fam-housing" class="mb-1 block text-sm font-medium text-gray-700">ที่อยู่อาศัย (เช่า/ผ่อน)</label>
            <input type="text" id="fam-housing" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="fam-food" class="mb-1 block text-sm font-medium text-gray-700">อาหารทั้งครอบครัว</label>
            <input type="text" id="fam-food" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="fam-transport" class="mb-1 block text-sm font-medium text-gray-700">การเดินทาง / น้ำมัน</label>
            <input type="text" id="fam-transport" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="fam-savings" class="mb-1 block text-sm font-medium text-gray-700">เงินออม / ลงทุน</label>
            <input type="text" id="fam-savings" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <p class="text-sm font-semibold text-gray-700">ค่าใช้จ่ายบุตร (บาท/เดือน รวมทุกคน)</p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fam-school" class="mb-1 block text-sm font-medium text-gray-700">ค่าเรียน / ค่าโรงเรียน</label>
            <input type="text" id="fam-school" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="fam-activities" class="mb-1 block text-sm font-medium text-gray-700">กิจกรรมนอกหลักสูตร</label>
            <input type="text" id="fam-activities" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="fam-childhealth" class="mb-1 block text-sm font-medium text-gray-700">สุขภาพ / วัคซีน / ยาบุตร</label>
            <input type="text" id="fam-childhealth" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="fam-misc" class="mb-1 block text-sm font-medium text-gray-700">เบ็ดเตล็ดอื่นๆ</label>
            <input type="text" id="fam-misc" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          วางแผนงบประมาณครอบครัว
        </button>
      </form>
    </div>

    <div id="fam-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-4">
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายได้รวม</div>
            <div id="res-fam-income" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายจ่ายรวม</div>
            <div id="res-fam-expense" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินออมครอบครัว</div>
            <div id="res-fam-savings" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-purple-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนต่อคน/เดือน</div>
            <div id="res-fam-perhead" class="text-xl font-bold text-purple-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ค่าใช้จ่ายบุตรรวม</span>
            <span id="res-fam-child" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">สัดส่วนค่าบุตร</span>
            <span id="res-fam-childpct" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>รายจ่ายรวม = ค่าใช้จ่ายครัวเรือน + ค่าใช้จ่ายบุตร</li>
        <li>เงินออมครอบครัว = รายได้รวม - รายจ่ายรวม</li>
        <li>ต้นทุนต่อคน = รายจ่ายรวม ÷ จำนวนสมาชิก</li>
        <li>สัดส่วนค่าบุตร = (ค่าใช้จ่ายบุตร ÷ รายได้รวม) × 100%</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณงบประมาณครัวเรือน/">คำนวณงบประมาณครัวเรือน</a></li>
        <li><a href="/คำนวณงบประมาณสองรายได้/">คำนวณงบประมาณสองรายได้</a></li>
        <li><a href="/คำนวณเงินสำรองฉุกเฉิน/">คำนวณเงินสำรองฉุกเฉิน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#fam-results" />
    <RelatedArticles currentHref="/วางแผนงบประมาณครอบครัว/" />
    <RelatedCalculators currentHref="/วางแผนงบประมาณครอบครัว/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการเพื่อการวางแผน ค่าใช้จ่ายจริงอาจแตกต่างตามบริบทครอบครัว
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return 0;
      const n = Number(s);
      return Number.isFinite(n) && n >= 0 ? n : 0;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('fam-form');
    const formError = document.getElementById('fam-error');
    const resultBox = document.getElementById('fam-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['fam-members-error','fam-income-error'].forEach(id => setErr(id, ''));

      const membersRaw = parseInt(document.getElementById('fam-members').value, 10);
      const income = parseNum(document.getElementById('fam-income').value);
      let hasError = false;
      if (!Number.isFinite(membersRaw) || membersRaw < 1) { setErr('fam-members-error', 'กรอกจำนวนสมาชิกอย่างน้อย 1 คน'); hasError = true; }
      if (!income || income <= 0) { setErr('fam-income-error', 'กรอกรายได้รวมมากกว่า 0'); hasError = true; }
      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const housing = parseNum(document.getElementById('fam-housing').value);
      const food = parseNum(document.getElementById('fam-food').value);
      const transport = parseNum(document.getElementById('fam-transport').value);
      const savings = parseNum(document.getElementById('fam-savings').value);
      const school = parseNum(document.getElementById('fam-school').value);
      const activities = parseNum(document.getElementById('fam-activities').value);
      const childhealth = parseNum(document.getElementById('fam-childhealth').value);
      const misc = parseNum(document.getElementById('fam-misc').value);

      const childExpense = school + activities + childhealth;
      const totalExpense = housing + food + transport + savings + childExpense + misc;
      const familySavings = income - totalExpense;
      const perHead = membersRaw > 0 ? totalExpense / membersRaw : 0;

      setText('res-fam-income', formatMoney(income));
      setText('res-fam-expense', formatMoney(totalExpense));
      setText('res-fam-savings', formatMoney(familySavings));
      setText('res-fam-perhead', formatMoney(perHead));
      setText('res-fam-child', formatMoney(childExpense));
      setText('res-fam-childpct', income > 0 ? `${((childExpense / income) * 100).toFixed(1)}%` : '0%');

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
