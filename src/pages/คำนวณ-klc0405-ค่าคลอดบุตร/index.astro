---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าคลอดบุตร | Kamnuanlek';
const pageDescription = 'คำนวณค่าคลอดบุตร ค่าห้อง ค่าฝากครรภ์ ค่าคลอดธรรมชาติ ผ่าคลอด ตามโรงพยาบาลไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0405-ค่าคลอดบุตร/`;

const faqData = [
  { question: 'ค่าคลอดบุตรในโรงพยาบาลเอกชนเท่าไหร่?', answer: 'ค่าคลอดธรรมชาติโรงพยาบาลเอกชน 30,000-80,000 บาท ผ่าคลอด 60,000-150,000 บาท ขึ้นอยู่กับโรงพยาบาลและห้องพัก' },
  { question: 'ประกันสังคมช่วยค่าคลอดบุตรได้เท่าไหร่?', answer: 'ผู้ประกันตนมาตรา 33 ได้รับค่าคลอดบุตรเหมาจ่าย 13,000 บาทต่อครั้ง และเงินสงเคราะห์การหยุดงาน 50% ของเงินเดือนสูงสุด 90 วัน' },
  { question: 'ค่าฝากครรภ์ทั้งหมดประมาณเท่าไหร่?', answer: 'ค่าฝากครรภ์ครบตลอด 9 เดือน ประมาณ 5,000-15,000 บาท รวมอัลตราซาวด์และตรวจเลือด ขึ้นอยู่กับโรงพยาบาล' },
  { question: 'บัตรทองครอบคลุมค่าคลอดบุตรไหม?', answer: 'บัตรทองครอบคลุมค่าคลอดที่โรงพยาบาลในสิทธิ์ รวมการฝากครรภ์ คลอด และดูแลหลังคลอด โดยไม่มีค่าใช้จ่ายเพิ่มเติม' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าคลอดบุตร">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าคลอดบุตร</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">ประมาณการค่าใช้จ่ายการคลอดบุตร ตั้งแต่ฝากครรภ์จนถึงออกจากโรงพยาบาล</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="antenatal" class="block text-sm font-medium text-gray-700 mb-1">ค่าฝากครรภ์ทั้งหมด (บาท)</label><input type="text" id="antenatal" inputmode="decimal" placeholder="เช่น 8000" value="8000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div>
          <label for="delivery_type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทการคลอด</label>
          <select id="delivery_type" class="w-full px-3 py-2 border border-gray-300 rounded-md">
            <option value="30000">คลอดธรรมชาติ รพ.รัฐ (~30,000 บาท)</option>
            <option value="50000" selected>คลอดธรรมชาติ รพ.เอกชน (~50,000 บาท)</option>
            <option value="80000">ผ่าคลอด รพ.เอกชน (~80,000 บาท)</option>
          </select>
        </div>
        <div><label for="room_days" class="block text-sm font-medium text-gray-700 mb-1">จำนวนวันนอน (วัน)</label><input type="number" id="room_days" min="1" max="10" placeholder="เช่น 3" value="3" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="room_rate_birth" class="block text-sm font-medium text-gray-700 mb-1">ค่าห้องต่อวัน (บาท)</label><input type="text" id="room_rate_birth" inputmode="decimal" placeholder="เช่น 2500" value="2500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="baby_care" class="block text-sm font-medium text-gray-700 mb-1">ค่าดูแลทารกและยา (บาท)</label><input type="text" id="baby_care" inputmode="decimal" placeholder="เช่น 5000" value="5000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าฝากครรภ์ + คลอด</p>
            <p id="delivery_total" class="font-bold">-</p>
          </div>
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าห้องและดูแลทารก</p>
            <p id="room_baby_total" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">รวมค่าคลอดบุตรทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const antenatal = parseFloat((document.getElementById('antenatal') as HTMLInputElement).value) || 0;
      const deliveryBase = parseFloat((document.getElementById('delivery_type') as HTMLSelectElement).value) || 0;
      const roomDays = parseInt((document.getElementById('room_days') as HTMLInputElement).value) || 1;
      const roomRate = parseFloat((document.getElementById('room_rate_birth') as HTMLInputElement).value) || 0;
      const babyCare = parseFloat((document.getElementById('baby_care') as HTMLInputElement).value) || 0;

      const deliveryTotal = antenatal + deliveryBase;
      const roomBabyTotal = (roomDays * roomRate) + babyCare;
      const total = deliveryTotal + roomBabyTotal;

      (document.getElementById('delivery_total') as HTMLElement).textContent = deliveryTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('room_baby_total') as HTMLElement).textContent = roomBabyTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('childbirth-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
