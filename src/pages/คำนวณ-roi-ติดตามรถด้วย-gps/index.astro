---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ ROI ติดตามรถด้วย GPS | เครื่องมือวิเคราะห์ผลตอบแทน | Kamnuanlek';
const pageDescription = 'คำนวณผลตอบแทนจากการลงทุนในระบบ GPS ติดตามรถ โดยคำนึงถึงค่าใช้จ่ายการซ่อมซ้อม และประสิทธิภาพการจัดการรถ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-roi-ติดตามรถด้วย-gps/`;

const faqData = [
  {
    question: 'GPS ติดตามรถช่วยประหยัดค่าใช้จ่ายได้อย่างไร?',
    answer: 'GPS ช่วยประหยัดค่าใช้จ่ายผ่าน: (1) เพิ่มประสิทธิภาพเส้นทาง ลดระยะทาง 10-15% (2) ลดการใช้น้ำมันเชื้อเพลิงโดยหลีกเลี่ยงการขับแบบเสียดาย (3) ลดการสูญหายของรถจากการขโมยหรืออุบัติเหตุ (4) ปรับปรุงการให้บริการลูกค้า เพิ่มความพึงพอใจ',
  },
  {
    question: 'ระยะเวลาคืนทุนเป็นเท่าไหร่?',
    answer: 'ระยะเวลาคืนทุน (Payback Period) ขึ้นอยู่กับการลดค่าใช้จ่ายต่อปี โดยปกติ 1-3 ปี สำหรับรถหลายคัน ช่วงนี้สั้นลงเนื่องจากการประหยัดขนาดใหญ่',
  },
  {
    question: 'ค่ำใช้จ่ายประกอบด้วยอะไรบ้าง?',
    answer: 'ค่าใช้จ่าย GPS รวม: (1) ค่ากำลังการติดตั้ง 2,000-5,000 บาท (2) ค่าสมัครรายเดือน 200-500 บาท/รถ (3) ค่าแทนอุปกรณ์เสื่อม (ไม่บ่อย)',
  },
  {
    question: 'ROI คืออะไร?',
    answer: 'ROI (Return On Investment) คือผลตอบแทนจากการลงทุน คำนวณเป็น: (การออม - ต้นทุนการลงทุน) ÷ ต้นทุนการลงทุน × 100% ROI สูงกว่า 20% ถือว่าการลงทุนที่ดี',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ ROI ระบบ GPS ติดตามรถ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ ROI ติดตามรถด้วย GPS">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณ ROI ระบบ GPS ติดตามรถ
    </h1>

    <p class="text-gray-600 mb-6">
      วิเคราะห์ผลตอบแทนจากการลงทุนในระบบ GPS และความคุ้มค่า
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="calculator-form" class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="num-vehicles" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนรถ (คัน)
            </label>
            <input type="text" id="num-vehicles" inputmode="decimal" placeholder="เช่น 10" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="installation-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าติดตั้งต่อรถ (บาท)
            </label>
            <input type="text" id="installation-cost" inputmode="decimal" placeholder="เช่น 3000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="monthly-subscription" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าสมัครต่อเดือน/รถ (บาท)
            </label>
            <input type="text" id="monthly-subscription" inputmode="decimal" placeholder="เช่น 300" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="fuel-reduction" class="block text-sm font-medium text-gray-700 mb-1">
              ลดการใช้น้ำมัน (%)
            </label>
            <input type="text" id="fuel-reduction" inputmode="decimal" placeholder="เช่น 12" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="current-fuel-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าน้ำมันต่อเดือน/รถ (บาท)
            </label>
            <input type="text" id="current-fuel-cost" inputmode="decimal" placeholder="เช่น 5000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="accident-reduction" class="block text-sm font-medium text-gray-700 mb-1">
              ลดต้นทุนอุบัติเหตุต่อปี (บาท)
            </label>
            <input type="text" id="accident-reduction" inputmode="decimal" placeholder="เช่น 10000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="labour-reduction" class="block text-sm font-medium text-gray-700 mb-1">
              ลดค่าแรงดูแลต่อเดือน (บาท)
            </label>
            <input type="text" id="labour-reduction" inputmode="decimal" placeholder="เช่น 2000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="analysis-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาวิเคราะห์ (ปี)
            </label>
            <input type="text" id="analysis-years" inputmode="decimal" placeholder="เช่น 3" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณ ROI
        </button>
      </form>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ROI</div>
          <div id="roi-percent" class="text-4xl font-bold mb-2 text-primary-600">0%</div>
        </div>

        <div class="bg-blue-50 rounded-lg p-4">
          <div class="text-sm text-gray-600">ต้นทุนเริ่มแรก</div>
          <div id="initial-cost" class="text-2xl font-bold text-blue-700">0</div>
        </div>

        <div class="bg-green-50 rounded-lg p-4">
          <div class="text-sm text-gray-600">การออมต่อปี</div>
          <div id="annual-saving" class="text-2xl font-bold text-green-700">0</div>
        </div>

        <div class="bg-orange-50 rounded-lg p-4">
          <div class="text-sm text-gray-600">ระยะเวลาคืนทุน</div>
          <div id="payback-period" class="text-2xl font-bold text-orange-700">0</div>
          <div class="text-sm text-gray-600">ปี</div>
        </div>

        <div class="bg-purple-50 rounded-lg p-4">
          <div class="text-sm text-gray-600">ผลตอบแทนรวม (ตามระยะเวลาวิเคราะห์)</div>
          <div id="total-benefit" class="text-2xl font-bold text-purple-700">0</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">GPS ติดตามรถคืออะไร?</h2>

      <p>
        GPS ติดตามรถ (Vehicle GPS Tracking) เป็นระบบที่ใช้เทคโนโลยี GPS เพื่อติดตามตำแหน่งและเส้นทางของรถในเวลาจริง
        ระบบนี้ช่วยให้บริษัทสามารถจัดการรถและคนขับได้อย่างมีประสิทธิภาพมากขึ้น ลดค่าใช้จ่าย และปรับปรุงการบริการ
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประโยชน์ของระบบ GPS ติดตามรถ</h3>

      <ul class="list-disc list-inside space-y-2 text-gray-700">
        <li><strong>ประสิทธิภาพเส้นทาง:</strong> เลือกเส้นทางที่ดีที่สุด ลดระยะทาง 10-15%</li>
        <li><strong>ประหยัดน้ำมัน:</strong> ปลายเส้นทางที่มีประสิทธิภาพ ลดการใช้น้ำมัน</li>
        <li><strong>ความปลอดภัย:</strong> ลดการขโมยรถ ได้รับเตือนเมื่ออยู่นอกเส้นทาง</li>
        <li><strong>ลดอุบัติเหตุ:</strong> ติดตามอาการขับและให้คำแนะนำการขับที่ปลอดภัย</li>
        <li><strong>ทำหน้าที่ยืนยัน:</strong> บันทึกเส้นทางและเวลาการจัดส่ง</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">การคำนวณ ROI จาก GPS ติดตามรถ</h3>

      <p>
        ROI (Return On Investment) คือผลตอบแทนจากการลงทุนในระบบ GPS ลงทุน โดยคำนวณจาก:
      </p>

      <div class="bg-gray-50 rounded-lg p-4 text-center my-4">
        <p class="text-lg font-semibold">ROI = (ประโยชน์รวม - ต้นทุนรวม) ÷ ต้นทุนเริ่มแรก × 100%</p>
      </div>

      <p>
        โดยทั่วไป ROI จากระบบ GPS ติดตามรถอยู่ที่ 20-50% ต่อปี โดยขึ้นอยู่กับจำนวนรถและประเภทของธุรกิจ
      </p>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณ-roi-ติดตามรถด้วย-gps/" />
    <RelatedCalculators currentHref="/คำนวณ-roi-ติดตามรถด้วย-gps/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น ผลจริงขึ้นอยู่กับสภาพการใช้งานจริง
    </div>
  </article>

  <script>
    function formatNumber(num: number): string {
      return new Intl.NumberFormat('th-TH', {
        minimumFractionDigits: 0,
        maximumFractionDigits: 2,
      }).format(num);
    }

    function calculateROI() {
      const numVehicles = parseFloat(document.getElementById('num-vehicles')?.value || '1') || 1;
      const installationCost = parseFloat(document.getElementById('installation-cost')?.value || '0') || 0;
      const monthlySubscription = parseFloat(document.getElementById('monthly-subscription')?.value || '0') || 0;
      const fuelReduction = parseFloat(document.getElementById('fuel-reduction')?.value || '0') || 0;
      const currentFuelCost = parseFloat(document.getElementById('current-fuel-cost')?.value || '0') || 0;
      const accidentReduction = parseFloat(document.getElementById('accident-reduction')?.value || '0') || 0;
      const labourReduction = parseFloat(document.getElementById('labour-reduction')?.value || '0') || 0;
      const analysisYears = parseFloat(document.getElementById('analysis-years')?.value || '1') || 1;

      // Calculate costs
      const totalInstallationCost = installationCost * numVehicles;
      const monthlySubscriptionCost = monthlySubscription * numVehicles;
      const annualSubscriptionCost = monthlySubscriptionCost * 12;

      // Calculate benefits
      const monthlyFuelSaving = (currentFuelCost * fuelReduction / 100) * numVehicles;
      const annualFuelSaving = monthlyFuelSaving * 12;
      const annualLabourSaving = labourReduction * 12 * numVehicles;
      const annualAccidentSaving = accidentReduction * numVehicles;

      const totalAnnualBenefit = annualFuelSaving + annualLabourSaving + annualAccidentSaving;
      const totalAnnualCost = annualSubscriptionCost;
      const netAnnualBenefit = totalAnnualBenefit - totalAnnualCost;

      const roi = (netAnnualBenefit / totalInstallationCost) * 100;
      const paybackPeriod = totalInstallationCost / (netAnnualBenefit || 1);
      const totalBenefit = (netAnnualBenefit * analysisYears) - totalInstallationCost;

      // Update display
      document.getElementById('roi-percent')!.textContent = formatNumber(Math.max(roi, 0)) + '%';
      document.getElementById('initial-cost')!.textContent = formatNumber(totalInstallationCost) + ' บาท';
      document.getElementById('annual-saving')!.textContent = formatNumber(netAnnualBenefit) + ' บาท';
      document.getElementById('payback-period')!.textContent = formatNumber(Math.max(paybackPeriod, 0));
      document.getElementById('total-benefit')!.textContent = formatNumber(totalBenefit) + ' บาท';

      document.getElementById('result')?.classList.remove('hidden');
    }

    document.getElementById('btn-calculate')?.addEventListener('click', calculateROI);
  </script>
</BaseLayout>
