---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าทำพาสปอร์ต 2569 | ค่าธรรมเนียมหนังสือเดินทาง ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าทำพาสปอร์ต (หนังสือเดินทาง) 2569 ฟรี เล่มปกติ 5 ปี / 10 ปี บริการด่วน ผู้ใหญ่ เด็ก ทำใหม่หรือต่ออายุ พร้อมรายการเอกสารที่ต้องเตรียม ผลลัพธ์ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าทำพาสปอร์ต/`;

const faqData = [
  {
    question: 'ค่าทำพาสปอร์ตปี 2569 เท่าไร?',
    answer: 'หนังสือเดินทางธรรมดา (E-Passport) อายุ 5 ปี ค่าธรรมเนียม 1,000 บาท อายุ 10 ปี ค่าธรรมเนียม 1,500 บาท หากต้องการบริการด่วน (รับเล่มใน 1 วันทำการ) เพิ่ม 1,000 บาท',
  },
  {
    question: 'เด็กอายุต่ำกว่า 20 ปีทำพาสปอร์ตได้กี่ปี?',
    answer: 'ผู้เยาว์ (อายุต่ำกว่า 20 ปี) สามารถทำหนังสือเดินทางได้เฉพาะเล่มอายุ 5 ปี เท่านั้น ค่าธรรมเนียม 1,000 บาท',
  },
  {
    question: 'ทำพาสปอร์ตใช้เอกสารอะไรบ้าง?',
    answer: 'ผู้ใหญ่: บัตรประชาชนตัวจริง และทะเบียนบ้านตัวจริง (กรณีต่ออายุนำเล่มเดิมมาด้วย) ผู้เยาว์: เพิ่มสูติบัตรตัวจริง บัตรประชาชนบิดามารดา และหนังสือยินยอม',
  },
  {
    question: 'ทำพาสปอร์ตด่วนกี่วันได้?',
    answer: 'บริการด่วนพิเศษรับเล่มภายใน 1 วันทำการ (เฉพาะที่กรมการกงสุล แจ้งวัฒนะ และสำนักงานหนังสือเดินทางบางแห่ง) ค่าบริการเพิ่ม 1,000 บาท รวมเป็น 2,000 บาท (เล่ม 5 ปี) หรือ 2,500 บาท (เล่ม 10 ปี)',
  },
  {
    question: 'พาสปอร์ตหมดอายุล่วงหน้าได้กี่เดือน?',
    answer: 'สามารถยื่นทำพาสปอร์ตเล่มใหม่ได้ก่อนเล่มเดิมหมดอายุ โดยไม่จำเป็นต้องรอให้หมดอายุก่อน แนะนำให้ทำล่วงหน้าอย่างน้อย 6 เดือนก่อนเดินทาง',
  },
  {
    question: 'สถานที่ทำพาสปอร์ตมีที่ไหนบ้าง?',
    answer: 'กรมการกงสุล แจ้งวัฒนะ, สำนักงานหนังสือเดินทางชั่วคราว (ศูนย์ราชการแจ้งวัฒนะ, MRT คลองเตย, ปิ่นเกล้า, บางนา, มีนบุรี) และสำนักงานหนังสือเดินทางในต่างจังหวัดอีกหลายแห่ง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าทำพาสปอร์ต (หนังสือเดินทาง) 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าทำพาสปอร์ต">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 10 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อ้างอิงอัตราค่าธรรมเนียม กรมการกงสุล กระทรวงการต่างประเทศ ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณค่าทำพาสปอร์ต 2569 (2026)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าธรรมเนียมทำหนังสือเดินทาง (พาสปอร์ต) ทั้งเล่ม 5 ปี และ 10 ปี
      บริการปกติและด่วน สำหรับผู้ใหญ่และเด็ก พร้อมรายการเอกสารที่ต้องเตรียม ใช้งานฟรี
    </p>

    <PublicTrustPanel
      lastUpdated="20 เม.ย. 2569"
      sources={[
        'กรมการกงสุล กระทรวงการต่างประเทศ: อัตราค่าธรรมเนียมหนังสือเดินทาง',
      ]}
      assumptions={[
        'อัตราค่าธรรมเนียมเป็นค่าธรรมเนียมมาตรฐานสำหรับหนังสือเดินทางธรรมดา (E-Passport)',
        'ไม่รวมค่าถ่ายรูปหรือค่าบริการอื่น ๆ นอกสำนักงาน',
      ]}
      references={[
        {
          label: 'กรมการกงสุล: ค่าธรรมเนียมหนังสือเดินทาง',
          href: 'https://www.consular.go.th/th/page/passport-fee',
        },
      ]}
    />

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูลผู้ยื่นขอพาสปอร์ต</h2>

      <form id="passport-form" class="space-y-5">
        <!-- Applicant Type -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">ประเภทผู้ยื่น</label>
          <div class="grid grid-cols-2 gap-3">
            <button type="button" data-applicant="adult" class="applicant-btn active-btn rounded-lg border-2 border-primary-500 bg-primary-50 px-4 py-3 text-center text-sm font-semibold text-primary-700 transition-colors">
              ผู้ใหญ่ (20 ปีขึ้นไป)
            </button>
            <button type="button" data-applicant="minor" class="applicant-btn rounded-lg border-2 border-gray-200 bg-white px-4 py-3 text-center text-sm font-semibold text-gray-700 transition-colors hover:border-gray-300">
              ผู้เยาว์ (ต่ำกว่า 20 ปี)
            </button>
          </div>
        </div>

        <!-- Application Type -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">ประเภทการยื่น</label>
          <div class="grid grid-cols-2 gap-3">
            <button type="button" data-apptype="first_time" class="apptype-btn active-btn rounded-lg border-2 border-primary-500 bg-primary-50 px-4 py-3 text-center text-sm font-semibold text-primary-700 transition-colors">
              ทำใหม่ (ครั้งแรก)
            </button>
            <button type="button" data-apptype="renewal" class="apptype-btn rounded-lg border-2 border-gray-200 bg-white px-4 py-3 text-center text-sm font-semibold text-gray-700 transition-colors hover:border-gray-300">
              ต่ออายุ / ทำเล่มใหม่
            </button>
          </div>
        </div>

        <!-- Passport Validity -->
        <div id="validity-section">
          <label class="block text-sm font-medium text-gray-700 mb-2">อายุหนังสือเดินทาง</label>
          <div class="grid grid-cols-2 gap-3">
            <button type="button" data-validity="5year" class="validity-btn active-btn rounded-lg border-2 border-primary-500 bg-primary-50 px-4 py-3 text-center text-sm font-semibold text-primary-700 transition-colors">
              <span class="block">5 ปี</span>
              <span class="block text-xs font-normal text-gray-500 mt-1">1,000 บาท</span>
            </button>
            <button type="button" data-validity="10year" class="validity-btn rounded-lg border-2 border-gray-200 bg-white px-4 py-3 text-center text-sm font-semibold text-gray-700 transition-colors hover:border-gray-300">
              <span class="block">10 ปี</span>
              <span class="block text-xs font-normal text-gray-500 mt-1">1,500 บาท</span>
            </button>
          </div>
          <p id="minor-validity-note" class="hidden mt-2 text-xs text-amber-600 font-medium">
            * ผู้เยาว์ (อายุต่ำกว่า 20 ปี) ทำได้เฉพาะเล่ม 5 ปี เท่านั้น
          </p>
        </div>

        <!-- Service Speed -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">ความเร็วบริการ</label>
          <div class="grid grid-cols-2 gap-3">
            <button type="button" data-speed="regular" class="speed-btn active-btn rounded-lg border-2 border-primary-500 bg-primary-50 px-4 py-3 text-center text-sm font-semibold text-primary-700 transition-colors">
              <span class="block">ปกติ</span>
              <span class="block text-xs font-normal text-gray-500 mt-1">2-3 วันทำการ</span>
            </button>
            <button type="button" data-speed="express" class="speed-btn rounded-lg border-2 border-gray-200 bg-white px-4 py-3 text-center text-sm font-semibold text-gray-700 transition-colors hover:border-gray-300">
              <span class="block">ด่วน</span>
              <span class="block text-xs font-normal text-gray-500 mt-1">1 วันทำการ (+1,000 บาท)</span>
            </button>
          </div>
        </div>

        <button
          type="button"
          id="btn-calculate"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          คำนวณค่าธรรมเนียม
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

      <!-- Summary Cards -->
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 mb-6">
        <div class="bg-primary-50 rounded-lg p-4 text-center">
          <div class="text-sm text-gray-600 mb-1">ค่าธรรมเนียมรวม</div>
          <div id="res-total" class="text-2xl font-bold text-primary-700">-</div>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-sm text-gray-600 mb-1">อายุเล่ม</div>
          <div id="res-validity" class="text-xl font-bold text-gray-800">-</div>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 text-center">
          <div class="text-sm text-gray-600 mb-1">ระยะเวลารับเล่ม</div>
          <div id="res-processing" class="text-xl font-bold text-gray-800">-</div>
        </div>
      </div>

      <!-- Fee Breakdown -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden mb-6">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-700">รายการ</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">จำนวนเงิน (บาท)</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 text-gray-700">ค่าธรรมเนียมหนังสือเดินทาง</td>
              <td id="res-base" class="px-4 py-3 text-right font-medium text-gray-900">-</td>
            </tr>
            <tr id="row-express" class="border-b border-gray-100 hidden">
              <td class="px-4 py-3 text-gray-700">ค่าบริการด่วน</td>
              <td id="res-express" class="px-4 py-3 text-right font-medium text-gray-900">-</td>
            </tr>
            <tr class="bg-primary-50">
              <td class="px-4 py-3 font-semibold text-gray-900">รวมทั้งสิ้น</td>
              <td id="res-total-table" class="px-4 py-3 text-right font-bold text-primary-700">-</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Required Documents Checklist -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h3 class="text-base font-semibold text-gray-900 mb-3">เอกสารที่ต้องเตรียม</h3>
        <ul id="doc-checklist" class="space-y-2">
          <!-- Populated by script -->
        </ul>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- Educational Content -->
    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2>หนังสือเดินทาง (พาสปอร์ต) คืออะไร?</h2>
      <p>
        หนังสือเดินทาง (Passport) คือเอกสารราชการที่ใช้แสดงตัวตนและสัญชาติของผู้ถือในการเดินทางระหว่างประเทศ
        ออกโดยกรมการกงสุล กระทรวงการต่างประเทศ ปัจจุบันเป็นแบบ E-Passport (หนังสือเดินทางอิเล็กทรอนิกส์)
        ที่มีชิปบรรจุข้อมูลชีวมิติของผู้ถือ
      </p>

      <h3>อัตราค่าธรรมเนียมหนังสือเดินทาง 2569</h3>
      <table>
        <thead>
          <tr>
            <th>ประเภท</th>
            <th>อายุเล่ม</th>
            <th>ค่าธรรมเนียม</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>หนังสือเดินทางธรรมดา (E-Passport)</td>
            <td>5 ปี</td>
            <td>1,000 บาท</td>
          </tr>
          <tr>
            <td>หนังสือเดินทางธรรมดา (E-Passport)</td>
            <td>10 ปี</td>
            <td>1,500 บาท</td>
          </tr>
          <tr>
            <td>บริการด่วน (เพิ่มจากค่าธรรมเนียมปกติ)</td>
            <td>-</td>
            <td>+1,000 บาท</td>
          </tr>
        </tbody>
      </table>

      <h3>ขั้นตอนการทำพาสปอร์ต</h3>
      <ol>
        <li><strong>จองคิวออนไลน์</strong> — ผ่านเว็บไซต์กรมการกงสุล หรือแอป Queue-Q</li>
        <li><strong>เตรียมเอกสาร</strong> — บัตรประชาชน ทะเบียนบ้าน (และเอกสารเพิ่มเติมตามกรณี)</li>
        <li><strong>ไปที่สำนักงาน</strong> — กรมการกงสุลแจ้งวัฒนะ หรือสำนักงานหนังสือเดินทางที่จองไว้</li>
        <li><strong>ยื่นเอกสารและถ่ายรูป</strong> — เจ้าหน้าที่ตรวจสอบเอกสาร สแกนลายนิ้วมือ ถ่ายรูป</li>
        <li><strong>ชำระค่าธรรมเนียม</strong> — ชำระเงินและรับใบเสร็จ</li>
        <li><strong>รับเล่ม</strong> — บริการปกติ 2-3 วันทำการ / ด่วน 1 วันทำการ (หรือเลือกจัดส่ง EMS)</li>
      </ol>

      <h3>เงื่อนไขสำหรับผู้เยาว์ (อายุต่ำกว่า 20 ปี)</h3>
      <ul>
        <li>ทำหนังสือเดินทางได้เฉพาะเล่ม 5 ปี เท่านั้น</li>
        <li>ต้องมีบิดาหรือมารดามาลงนามยินยอมที่สำนักงาน</li>
        <li>หากบิดาหรือมารดาไม่สามารถมาได้ ต้องมีหนังสือยินยอมที่รับรองจากอำเภอ</li>
        <li>กรณีบิดามารดาหย่า ต้องมีบันทึกการหย่าที่ระบุผู้มีอำนาจปกครอง</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณค่าทำพาสปอร์ต/" />
    <RelatedCalculators currentHref="/คำนวณค่าทำพาสปอร์ต/" />

    <!-- Disclaimer -->
    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลคำนวณเป็นการประมาณตามอัตราค่าธรรมเนียมของกรมการกงสุล
      กระทรวงการต่างประเทศ เพื่อใช้ในการวางแผนเท่านั้น ค่าธรรมเนียมจริงอาจมีการเปลี่ยนแปลง
      กรุณาตรวจสอบกับสำนักงานหนังสือเดินทางอีกครั้งก่อนเดินทาง
    </div>
  </article>

  <script>
    import { calculatePassportFee, getRequiredDocuments } from '../../lib/passport-fee-calculator';
    import type { ApplicantType, ApplicationType, PassportValidity, ServiceSpeed } from '../../lib/passport-fee-calculator';

    /* ── helpers ── */
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 2 }).format(n);
    }

    /* ── state ── */
    let applicantType: ApplicantType = 'adult';
    let applicationType: ApplicationType = 'first_time';
    let validity: PassportValidity = '5year';
    let serviceSpeed: ServiceSpeed = 'regular';

    /* ── DOM refs ── */
    const applicantBtns = document.querySelectorAll<HTMLButtonElement>('.applicant-btn');
    const apptypeBtns = document.querySelectorAll<HTMLButtonElement>('.apptype-btn');
    const validityBtns = document.querySelectorAll<HTMLButtonElement>('.validity-btn');
    const speedBtns = document.querySelectorAll<HTMLButtonElement>('.speed-btn');
    const minorNote = document.getElementById('minor-validity-note')!;
    const btnCalculate = document.getElementById('btn-calculate')!;
    const resultsDiv = document.getElementById('results')!;

    /* ── button toggle helper ── */
    function activateBtn(group: NodeListOf<HTMLButtonElement>, activeBtn: HTMLButtonElement) {
      group.forEach((b) => {
        b.classList.remove('active-btn', 'border-primary-500', 'bg-primary-50', 'text-primary-700');
        b.classList.add('border-gray-200', 'bg-white', 'text-gray-700');
      });
      activeBtn.classList.add('active-btn', 'border-primary-500', 'bg-primary-50', 'text-primary-700');
      activeBtn.classList.remove('border-gray-200', 'bg-white', 'text-gray-700');
    }

    /* ── event listeners ── */
    applicantBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        applicantType = btn.dataset.applicant as ApplicantType;
        activateBtn(applicantBtns, btn);

        // Minors: force 5-year and show note
        if (applicantType === 'minor') {
          validity = '5year';
          const fiveYearBtn = document.querySelector<HTMLButtonElement>('[data-validity="5year"]')!;
          activateBtn(validityBtns, fiveYearBtn);
          // Disable 10-year
          const tenYearBtn = document.querySelector<HTMLButtonElement>('[data-validity="10year"]')!;
          tenYearBtn.classList.add('opacity-50', 'cursor-not-allowed');
          minorNote.classList.remove('hidden');
        } else {
          const tenYearBtn = document.querySelector<HTMLButtonElement>('[data-validity="10year"]')!;
          tenYearBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          minorNote.classList.add('hidden');
        }
      });
    });

    apptypeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        applicationType = btn.dataset.apptype as ApplicationType;
        activateBtn(apptypeBtns, btn);
      });
    });

    validityBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        // Block 10-year for minors
        if (applicantType === 'minor' && btn.dataset.validity === '10year') return;
        validity = btn.dataset.validity as PassportValidity;
        activateBtn(validityBtns, btn);
      });
    });

    speedBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        serviceSpeed = btn.dataset.speed as ServiceSpeed;
        activateBtn(speedBtns, btn);
      });
    });

    /* ── calculate ── */
    btnCalculate.addEventListener('click', () => {
      const result = calculatePassportFee({
        applicantType,
        applicationType,
        validity,
        serviceSpeed,
      });

      // Update summary cards
      document.getElementById('res-total')!.textContent = fmt(result.totalFee) + ' บาท';
      document.getElementById('res-validity')!.textContent = result.validityYears + ' ปี';
      document.getElementById('res-processing')!.textContent = result.processingDays;

      // Update breakdown table
      document.getElementById('res-base')!.textContent = fmt(result.baseFee);
      const rowExpress = document.getElementById('row-express')!;
      if (result.expressSurcharge > 0) {
        rowExpress.classList.remove('hidden');
        document.getElementById('res-express')!.textContent = fmt(result.expressSurcharge);
      } else {
        rowExpress.classList.add('hidden');
      }
      document.getElementById('res-total-table')!.textContent = fmt(result.totalFee);

      // Update document checklist
      const docs = getRequiredDocuments(result.applicantType, result.applicationType);
      const checklist = document.getElementById('doc-checklist')!;
      checklist.innerHTML = docs
        .map(
          (doc) =>
            `<li class="flex items-start gap-2">
              <span class="mt-0.5 flex-shrink-0 ${doc.required ? 'text-red-500' : 'text-gray-400'}">
                ${doc.required ? '●' : '○'}
              </span>
              <span class="text-sm text-gray-700">
                ${doc.label}
                ${doc.required ? '<span class="text-xs text-red-500 font-medium ml-1">(จำเป็น)</span>' : '<span class="text-xs text-gray-400 font-medium ml-1">(ถ้ามี)</span>'}
              </span>
            </li>`
        )
        .join('');

      // Show results
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      // Analytics
      if (typeof trackCalculatorUsed === 'function') {
        trackCalculatorUsed('passport_fee');
      }
    });

    /* ── analytics: track result view ── */
    const resultObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            if (typeof trackResultViewed === 'function') {
              trackResultViewed('passport_fee');
            }
            resultObserver.disconnect();
          }
        });
      },
      { threshold: 0.5 }
    );
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
