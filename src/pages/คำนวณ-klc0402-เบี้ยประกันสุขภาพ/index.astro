---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณเบี้ยประกันสุขภาพ | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันสุขภาพรายปี เบี้ยประกันชีวิต';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0402-เบี้ยประกันสุขภาพ/`;

const faqData = [
  { question: 'ค่ารักษาพยาบาลในไทยแตกต่างกันอย่างไรระหว่างโรงพยาบาลรัฐและเอกชน?', answer: 'โรงพยาบาลรัฐมีค่าใช้จ่ายต่ำกว่ามาก แต่ใช้เวลารอนาน โรงพยาบาลเอกชนสะดวกกว่าแต่ราคาสูงกว่า 3-10 เท่า ขึ้นอยู่กับประเภทการรักษา' },
  { question: 'สิทธิ์ประกันสังคมครอบคลุมค่ารักษาอะไรบ้าง?', answer: 'ผู้ประกันตนมาตรา 33 ได้รับการรักษาฟรีที่โรงพยาบาลตามบัตรรับรองสิทธิ์ ครอบคลุมการรักษาทั่วไป ผ่าตัด คลอดบุตร และยาตามบัญชียา' },
  { question: 'ควรทำประกันสุขภาพหรือสำรองเงินเอง?', answer: 'ประกันสุขภาพช่วยลดความเสี่ยงจากค่าใช้จ่ายสูงที่คาดไม่ถึง เหมาะกับคนที่ไม่มีเงินสำรองมาก ส่วนคนที่มีเงินออมสูงอาจสำรองเองได้' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกค่าห้อง ค่ายา ค่าหัตถการ และค่าตรวจวินิจฉัย กดคำนวณเพื่อดูค่าใช้จ่ายรวมทั้งหมด' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเบี้ยประกันสุขภาพ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณเบี้ยประกันสุขภาพ</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณเบี้ยประกันสุขภาพตามวงเงินเอาประกัน อายุ เพศ</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="coverage" class="block text-sm font-medium text-gray-700 mb-1">วงเงินเอาประกัน (บาท)</label><input type="text" id="coverage" inputmode="decimal" placeholder="เช่น 1000000" value="1000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="age" class="block text-sm font-medium text-gray-700 mb-1">อายุ (ปี)</label><input type="number" id="age" min="20" max="85" placeholder="เช่น 35" value="35" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="premium_rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราเบี้ยต่อ 100 บาท</label><input type="text" id="premium_rate" inputmode="decimal" placeholder="เช่น 0.8" value="0.8" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">เบี้ยต่อเดือน</p>
            <p id="monthly" class="font-bold">-</p>
          </div>
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">เบี้ยต่อปี</p>
            <p id="yearly" class="font-bold">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ประกันสุขภาพควรเอาวงเงินเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">แนะนำ 500,000-3,000,000 บาท ขึ้นอยู่กับรายได้ ช่วงวัย สัติครอบครัว</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">อัตราเบี้ยแตกต่างตามอายุเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">เบี้ยจะสูงขึ้นตามอายุ อายุ 30: 0.5-1% อายุ 50: 1-3% อายุ 65: 3-8% แตกต่างตามสภาพสุขภาพ</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ลดหย่อนประกันสุขภาพได้หรือไม่?</h3>
            <p class="text-gray-600 text-sm">ใช่ ประกันสุขภาพบางประเภทลดหย่อนได้ สูงสุด 2,500 บาท/ปี หรือตามประกาศสรรพากร</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const coverage = parseFloat((document.getElementById('coverage') as HTMLInputElement).value) || 0;
      const premiumRate = parseFloat((document.getElementById('premium_rate') as HTMLInputElement).value) || 0.8;

      const yearlyPremium = (coverage * premiumRate) / 100;
      const monthlyPremium = yearlyPremium / 12;

      (document.getElementById('monthly') as HTMLElement).textContent = monthlyPremium.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('yearly') as HTMLElement).textContent = yearlyPremium.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('health-insurance');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
