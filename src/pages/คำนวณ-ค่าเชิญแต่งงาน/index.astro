---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';

const pageTitle = 'คำนวณค่าเชิญแต่งงาน 2569 | การ์ดสติกเกอร์ | Kamnuanlek';
const pageDescription = 'คำนวณค่าเชิญแต่งงาน การ์ด สติกเกอร์ ซองจดหมาย และค่าส่งไปรษณีย์ ออนไลน์ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าเชิญแต่งงาน/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเชิญแต่งงาน">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเชิญแต่งงาน</h1>
    <div class="mb-4 inline-block rounded-lg border border-pink-200 bg-pink-50 px-3 py-2">
      <p class="text-xs font-semibold text-pink-800">[ค่าเชิญ 2569]</p>
    </div>
    <p class="text-gray-600 mb-6">คำนวณค่าเชิญแต่งงาน รวมการ์ด ซองจดหมาย และส่งไปรษณีย์</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="invitation-cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าเชิญต่อใบ (บาท)</label>
          <input type="text" id="invitation-cost" inputmode="decimal" placeholder="เช่น 50" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="invitation-qty" class="block text-sm font-medium text-gray-700 mb-1">จำนวนเชิญ (ใบ)</label>
          <input type="text" id="invitation-qty" inputmode="decimal" placeholder="เช่น 150" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="envelope" class="block text-sm font-medium text-gray-700 mb-1">ค่าซองจดหมาย (บาท)</label>
          <input type="text" id="envelope" inputmode="decimal" placeholder="เช่น 15000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="postage" class="block text-sm font-medium text-gray-700 mb-1">ค่าส่ง/ไปรษณีย์ (บาท)</label>
          <input type="text" id="postage" inputmode="decimal" placeholder="เช่น 10000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
      </div>
      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-pink-600 text-white font-semibold rounded-md hover:bg-pink-700 transition-colors text-base">คำนวณรวม</button>
      <div id="result" class="hidden mt-8 border-t pt-6">
        <div class="bg-pink-50 rounded-lg p-6 text-center">
          <div class="text-sm text-gray-600 mb-2">ค่าเชิญรวม</div>
          <div class="text-5xl font-bold text-pink-700"><span id="total">-</span></div>
          <div class="text-sm text-gray-600">บาท</div>
        </div>
      </div>
    </div>
    <RelatedCalculators />
    <RelatedArticles />
  </article>
</BaseLayout>

<script>
  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const invCost = parseFloat(document.getElementById('invitation-cost')?.value || 0);
    const invQty = parseFloat(document.getElementById('invitation-qty')?.value || 0);
    const envelope = parseFloat(document.getElementById('envelope')?.value || 0);
    const postage = parseFloat(document.getElementById('postage')?.value || 0);
    const invTotal = invCost * invQty;
    const total = invTotal + envelope + postage;
    if (total === 0) { alert('กรุณาป้อนค่าใช้จ่าย'); return; }
    document.getElementById('total').textContent = total.toLocaleString('th-TH');
    document.getElementById('result').classList.remove('hidden');
  });
</script>
