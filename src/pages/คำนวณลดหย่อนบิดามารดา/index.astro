---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณลดหย่อนบิดามารดา 2569 | ค่าเลี้ยงดูพ่อแม่ 30,000 บาท | Calculator Thailand';
const pageDescription = 'คำนวณค่าลดหย่อนบิดามารดา 2569 ฟรี ลดหย่อนได้คนละ 30,000 บาท สูงสุด 4 คน (พ่อแม่ตัวเองและคู่สมรส) เช็กเงื่อนไขอายุและรายได้ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณลดหย่อนบิดามารดา/`;

const faqData = [
  {
    question: 'ลดหย่อนบิดามารดาได้คนละเท่าไร?',
    answer: 'ลดหย่อนบิดามารดาได้คนละ 30,000 บาท ต่อคน โดยสามารถนำบิดามารดาของตัวเองและของคู่สมรสมาลดหย่อนได้ รวมสูงสุด 4 คน (สูงสุด 120,000 บาท)',
  },
  {
    question: 'บิดามารดาต้องอายุเท่าไรจึงนำมาลดหย่อนได้?',
    answer: 'บิดามารดาต้องมีอายุ 60 ปีบริบูรณ์ขึ้นไป ณ วันที่ 31 ธันวาคมของปีภาษีที่ยื่น',
  },
  {
    question: 'บิดามารดาต้องมีเงื่อนไขรายได้อย่างไร?',
    answer: 'บิดามารดาต้องมีรายได้ไม่เกิน 30,000 บาทต่อปี (รายได้รวมทุกประเภท) จึงจะมีสิทธิ์นำมาลดหย่อน',
  },
  {
    question: 'หากพี่น้องหลายคน ใครสามารถนำพ่อแม่ไปลดหย่อนได้?',
    answer: 'พ่อหรือแม่คนเดียวกันนำไปลดหย่อนได้เพียง 1 คนต่อพ่อแม่ 1 คน หากพี่น้องหลายคนต้องตกลงกันว่าใครจะเป็นผู้ใช้สิทธิ์',
  },
  {
    question: 'ลดหย่อนบิดามารดาคู่สมรสได้ไหม?',
    answer: 'ได้ สามารถนำบิดามารดาของคู่สมรสที่มีอายุ 60 ปีขึ้นไปและรายได้ไม่เกิน 30,000 บาท/ปี มาลดหย่อนได้อีก สูงสุด 2 คน (60,000 บาท)',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณลดหย่อนบิดามารดา 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณลดหย่อนบิดามารดา">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณลดหย่อนบิดามารดา อัปเดตปี 2569 (2026)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าลดหย่อนบิดามารดาตามเกณฑ์กรมสรรพากร ลดหย่อนได้คนละ 30,000 บาท
      สูงสุด 4 คน (พ่อแม่ตัวเองและพ่อแม่คู่สมรส) เงื่อนไข: อายุ 60 ปีขึ้นไป รายได้ไม่เกิน 30,000 บาท/ปี
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกจำนวนบิดามารดาที่มีสิทธิ์ลดหย่อน</h2>

      <form id="parent-form" class="space-y-6">
        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">บิดามารดาของตนเอง</legend>
          <div class="space-y-3">
            <label class="flex items-center gap-3">
              <input type="checkbox" id="own-father" class="w-4 h-4 text-primary-600 rounded" />
              <span class="text-sm text-gray-700">บิดา (พ่อ) — อายุ 60+ ปี รายได้ไม่เกิน 30,000 บาท/ปี</span>
            </label>
            <label class="flex items-center gap-3">
              <input type="checkbox" id="own-mother" class="w-4 h-4 text-primary-600 rounded" />
              <span class="text-sm text-gray-700">มารดา (แม่) — อายุ 60+ ปี รายได้ไม่เกิน 30,000 บาท/ปี</span>
            </label>
          </div>
        </fieldset>

        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">บิดามารดาของคู่สมรส</legend>
          <div class="space-y-3">
            <label class="flex items-center gap-3">
              <input type="checkbox" id="spouse-father" class="w-4 h-4 text-primary-600 rounded" />
              <span class="text-sm text-gray-700">บิดาของคู่สมรส — อายุ 60+ ปี รายได้ไม่เกิน 30,000 บาท/ปี</span>
            </label>
            <label class="flex items-center gap-3">
              <input type="checkbox" id="spouse-mother" class="w-4 h-4 text-primary-600 rounded" />
              <span class="text-sm text-gray-700">มารดาของคู่สมรส — อายุ 60+ ปี รายได้ไม่เกิน 30,000 บาท/ปี</span>
            </label>
          </div>
        </fieldset>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณลดหย่อนบิดามารดา</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">จำนวนที่ลดหย่อนได้</div>
            <div id="result-count" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าลดหย่อนรวม</div>
            <div id="result-total" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประหยัดภาษีโดยประมาณ</div>
            <div id="result-tax-saved" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div id="result-detail" class="space-y-2 text-sm"></div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ลดหย่อนบิดามารดา 2569 มีเงื่อนไขอะไรบ้าง?</h2>
      <p>
        ผู้มีเงินได้สามารถนำค่าอุปการะเลี้ยงดูบิดามารดามาหักเป็นค่าลดหย่อนได้ คนละ 30,000 บาท
        โดยต้องเป็นบิดามารดาของตนเองหรือของคู่สมรส รวมสูงสุด 4 คน (120,000 บาท)
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เงื่อนไขการลดหย่อน</h3>
      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li>บิดามารดาต้องมีอายุ <strong>60 ปีบริบูรณ์ขึ้นไป</strong> ในปีภาษีที่ยื่น</li>
        <li>บิดามารดาต้องมีรายได้ <strong>ไม่เกิน 30,000 บาทต่อปี</strong></li>
        <li>ผู้มีเงินได้ต้องมีชื่ออยู่ในหนังสือรับรองการหักลดหย่อน (ฟอร์ม ล.ย.03)</li>
        <li>บิดามารดาคนเดียวกันนำไปลดหย่อนได้เพียง <strong>1 คน</strong> เท่านั้น</li>
        <li>สามารถลดหย่อนบิดามารดาของคู่สมรสได้ แม้คู่สมรสจะยื่นภาษีแยก</li>
      </ul>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีขอหนังสือรับรอง</h3>
      <p>
        ดาวน์โหลดแบบ ล.ย.03 จากเว็บไซต์กรมสรรพากร ให้บิดาหรือมารดาลงนามรับรอง
        แล้วเก็บไว้เป็นหลักฐานประกอบการยื่นแบบ ภ.ง.ด.90/91
      </p>
    </section>


    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณ</h2>
      <p><strong>ลดหย่อนบิดามารดา = 30,000 บาท × จำนวนคน</strong> (สูงสุด 2 คน = 60,000 บาท)</p>
      <p>เงื่อนไข: บิดา-มารดาต้องมีอายุ 60 ปีขึ้นไป และไม่มีรายได้เกิน 30,000 บาท/ปี</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">ตัวอย่างการคำนวณ</h3>
      <p><strong>ตัวอย่างที่ 1: มีบิดา 1 คน อายุ 65 ปี ไม่มีรายได้</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>สิทธิลดหย่อน</strong> = 30,000 × 1 = <strong>30,000 บาท</strong></li>
      </ul>

      <p class="mt-4"><strong>ตัวอย่างที่ 2: มีบิดาและมารดา ทั้งสอง อายุ 62 ปี ไม่มีรายได้</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>สิทธิลดหย่อน</strong> = 30,000 × 2 = <strong>60,000 บาท</strong> (สูงสุด 2 คน)</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สรุป</h3>
      <p>ลดหย่อนบิดามารดาเป็นสิทธิของผู้มีเงินได้ที่บำรุงพ่อแม่ผู้สูงอายุ ต้องหักจากรายได้สุทธิในแบบ ภ.ง.ด.91 โดยต้องมีหนังสือรับรองคุณสมบัติบิดามารดาจากกรมสรรพากร</p>
      <p class="text-sm text-gray-500 mt-2"><strong>อ้างอิง:</strong> <a href="https://www.rd.go.th" class="text-primary-600 hover:underline" target="_blank" rel="noopener">กรมสรรพากร: ลดหย่อนบิดามารดา</a> [อัปเดต 2569]</p>
    </section>
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณลดหย่อนบิดามารดา/" />
    <RelatedCalculators currentHref="/คำนวณลดหย่อนบิดามารดา/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางภาษีหรือกฎหมาย กรุณาปรึกษาผู้เชี่ยวชาญด้านภาษีสำหรับกรณีเฉพาะ
    </div>
  </article>

  <script>
    function formatThai(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(num);
    }

    const form = document.getElementById('parent-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const ownFather = (document.getElementById('own-father') as HTMLInputElement).checked;
      const ownMother = (document.getElementById('own-mother') as HTMLInputElement).checked;
      const spouseFather = (document.getElementById('spouse-father') as HTMLInputElement).checked;
      const spouseMother = (document.getElementById('spouse-mother') as HTMLInputElement).checked;

      const count = [ownFather, ownMother, spouseFather, spouseMother].filter(Boolean).length;
      const total = count * 30_000;
      // Estimated tax saving at 20% marginal rate (common middle bracket)
      const taxSaved = total * 0.20;

      const items = [];
      if (ownFather) items.push('บิดา (พ่อ) ของตนเอง');
      if (ownMother) items.push('มารดา (แม่) ของตนเอง');
      if (spouseFather) items.push('บิดา (พ่อ) ของคู่สมรส');
      if (spouseMother) items.push('มารดา (แม่) ของคู่สมรส');

      (document.getElementById('result-count') as HTMLElement).textContent = `${count} คน`;
      (document.getElementById('result-total') as HTMLElement).textContent = `${formatThai(total)} บาท`;
      (document.getElementById('result-tax-saved') as HTMLElement).textContent = `~${formatThai(taxSaved)} บาท`;

      const detail = document.getElementById('result-detail') as HTMLElement;
      if (items.length > 0) {
        detail.innerHTML = `
          <p class="font-medium text-gray-700 mb-2">รายการที่ลดหย่อน:</p>
          <ul class="list-disc pl-5 space-y-1 text-gray-600">
            ${items.map(i => `<li>${i} — 30,000 บาท</li>`).join('')}
          </ul>
          <p class="mt-3 text-xs text-gray-500">*ประหยัดภาษีโดยประมาณคำนวณที่อัตรา 20% (อัตราเฉลี่ยมนุษย์เงินเดือน) จริงขึ้นอยู่กับฐานภาษีของแต่ละคน</p>
        `;
      } else {
        detail.innerHTML = '<p class="text-gray-600">ไม่มีบิดามารดาที่มีสิทธิ์ลดหย่อน กรุณาเลือกอย่างน้อย 1 คน</p>';
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('parent_allowance');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('parent_allowance');
    });

    form.addEventListener('input', () => {
      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('parent_allowance');
    }, { once: true });
  </script>
</BaseLayout>
