---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณผลตอบแทน ROI สวนยางพารา 2569 | เครื่องคำนวณเกษตร | Kamnuanlek';
const pageDescription = 'คำนวณผลตอบแทน ROI สวนยางพารา ต้นทุนเริ่มแรม ค่าบำรุงรักษา ผลผลิตยางแห้ง ประมาณการกำไร เปรียบเทียบ 3 สถานการณ์';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ผลตอบแทนสวนยางพารา/`;

const faqData = [
  {
    question: 'ต้องลงทุนเท่าไรในการปลูกยางพารา?',
    answer: 'ต้นทุนเริ่มแรมในการปลูกยางพารา ประมาณ 15,000-20,000 บาทต่อไร่ สำหรับ เตรียมพื้นที่ ซื้อต้นสายพันธุ์ (80-100 ต้น/ไร่) และอุปกรณ์พื้นฐาน ต้นทุนนี้จ่ายครั้งเดียวในปีแรก แล้วต่อจากนั้นมีค่าบำรุงรักษาประจำปี',
  },
  {
    question: 'ยางพารามีผลผลิตเมื่อไร?',
    answer: 'ต้นยางพารามีอายุการผลิตนาน สามารถเก็บเอาน้ำยางได้เมื่ออายุประมาณ 5-7 ปี และสามารถผลิตต่อเนื่องเป็นเวลา 20-30 ปี ในปีแรกของการผลิต ผลผลิตจะเริ่มต่ำ แล้วค่อยๆ เพิ่มขึ้นจนถึงยอดของการผลิต',
  },
  {
    question: 'ยางแห้งมีราคาเท่าไร?',
    answer: 'ราคายางแห้ง (Dry Rubber Content - DRC) ปกติอยู่ที่ 40-60 บาทต่อกิโลกรัม ขึ้นอยู่กับคุณภาพ ระดับของราคาตลาดโลก และสภาวะเศรษฐกิจ ผู้ปลูกควรติดตามราคาตลาดอย่างต่อเนื่อง',
  },
  {
    question: 'สวนยางพาราให้กำไรตลอดปีหรือ?',
    answer: 'ไม่ สวนยางให้ผลผลิตตามฤดูกาล เก็บได้เป็นเวลา 8-9 เดือน โดยปกติจะเริ่มในเดือนพฤษภาคม-มิถุนายนและจบในเดือนกรรมฤการ-พฤศจิกายน ส่วนอื่นๆ ของปีจะมีเพียงค่าบำรุงรักษาเท่านั้น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผลตอบแทน ROI สวนยางพารา',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณผลตอบแทน ROI สวนยางพารา',
  description: 'ขั้นตอนการคำนวณผลตอบแทนจากการลงทุนสวนยางพารา',
  step: [
    {
      '@type': 'HowToStep',
      name: 'กำหนดขนาดสวน',
      text: 'กำหนดขนาดพื้นที่ปลูก (ไร่) เช่น 10 ไร่, 20 ไร่ หรือ 30 ไร่',
    },
    {
      '@type': 'HowToStep',
      name: 'ระบุระยะเวลาจนถึงเก็บเกี่ยว',
      text: 'ปกติต้นยางให้ผลผลิตในปีที่ 5-7 เลือกตามสภาพแบ่งต้นและการดูแล',
    },
    {
      '@type': 'HowToStep',
      name: 'กำหนดจำนวนต้นและผลผลิต',
      text: 'สวนยางปกติมี 80-100 ต้นต่อไร่ ผลผลิตเฉลี่ย 3-4 กิโลกรัมยางแห้งต่อต้นต่อปี',
    },
    {
      '@type': 'HowToStep',
      name: 'ดูผลลัพธ์ ROI และกำไร',
      text: 'เครื่องคำนวณแสดงผล ต้นทุนเริ่มแรม ค่าบำรุงประจำปี รายได้จากยางแห้ง และผลตอบแทนต่อปี',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผลตอบแทนสวนยางพารา">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณผลตอบแทน ROI สวนยางพารา
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2">
      <p class="text-xs font-semibold text-lime-800">[อัปเดตตามราคาตลาด 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณผลตอบแทน ROI จากการลงทุนสวนยางพารา ต้นทุนเริ่มแรม ค่าบำรุงรักษาประจำปี ผลผลิต และกำไรประจำปี
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div>
          <label for="raiSize" class="block text-sm font-medium text-gray-700 mb-1">
            ขนาดสวน (ไร่)
          </label>
          <input
            type="text"
            id="raiSize"
            inputmode="decimal"
            placeholder="เช่น 10"
            value="10"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div>
          <label for="yearsToHarvest" class="block text-sm font-medium text-gray-700 mb-1">
            ระยะเวลาจนถึงเก็บเกี่ยว (ปี)
          </label>
          <input
            type="text"
            id="yearsToHarvest"
            inputmode="decimal"
            placeholder="เช่น 6"
            value="6"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div>
          <label for="treesPerRai" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนต้นต่อไร่
          </label>
          <input
            type="text"
            id="treesPerRai"
            inputmode="decimal"
            placeholder="เช่น 85"
            value="85"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div>
          <label for="yieldPerTree" class="block text-sm font-medium text-gray-700 mb-1">
            ผลผลิตต่อต้นต่อปี (กก. ยางแห้ง)
          </label>
          <input
            type="text"
            id="yieldPerTree"
            inputmode="decimal"
            placeholder="เช่น 3.5"
            value="3.5"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณ ROI
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="bg-blue-50 rounded-lg p-4">
          <p class="text-sm text-gray-600 mb-1">ต้นทุนเริ่มแรม</p>
          <p id="initial-invest" class="text-2xl font-bold text-gray-900">-</p>
        </div>

        <div class="bg-blue-50 rounded-lg p-4">
          <p class="text-sm text-gray-600 mb-1">ต้นทุนบำรุงต่อปี</p>
          <p id="annual-cost" class="text-2xl font-bold text-gray-900">-</p>
        </div>

        <div class="bg-blue-50 rounded-lg p-4">
          <p class="text-sm text-gray-600 mb-1">ต้นทุนรวมถึงเก็บเกี่ยว</p>
          <p id="total-invest" class="text-2xl font-bold text-gray-900">-</p>
        </div>

        <div class="bg-green-50 rounded-lg p-4">
          <p class="text-sm text-gray-600 mb-1">ผลผลิตต่อปี (กก.)</p>
          <p id="yield" class="text-2xl font-bold text-green-600">-</p>
        </div>

        <div class="bg-green-50 rounded-lg p-4">
          <p class="text-sm text-gray-600 mb-1">รายได้ต่อปี</p>
          <p id="annual-income" class="text-2xl font-bold text-green-600">-</p>
        </div>

        <div class="bg-green-50 rounded-lg p-4">
          <p class="text-sm text-gray-600 mb-1">กำไรต่อปี (ปีแรกเก็บเกี่ยว)</p>
          <p id="profit" class="text-2xl font-bold text-green-700">-</p>
        </div>

        <div class="bg-purple-50 rounded-lg p-4">
          <p class="text-sm text-gray-600 mb-1">ROI ต่อปี</p>
          <p id="roi" class="text-2xl font-bold text-purple-600">-</p>
        </div>

        <div class="bg-yellow-50 rounded-lg p-4 border border-yellow-200 text-sm text-yellow-800">
          <p><strong>หมายเหตุ:</strong> ราคายางแห้งปกติ 40-60 บาท/กก. ผลผลิตแท้จริงขึ้นอยู่กับการดูแลและสภาพอากาศ</p>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ยางพารา: การลงทุนระยะยาวของเกษตรกรไทย</h2>

      <p>
        สวนยางพาราเป็นการลงทุนระยะยาวที่มีศักยภาพสูงในการส่งเสริมรายได้ให้แก่เกษตรกรไทย โดยเฉพาะในภาคใต้ เพราะอากาศอบอวลที่เหมาะสม อย่างไรก็ตาม ผู้ปลูกต้องเข้าใจต้นทุน และผลตอบแทนอย่างดี เนื่องจากต้องรอ 5-7 ปีกว่าต้นจะเริ่มให้ผลผลิต
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ต้นทุนการปลูกยางพารา</h3>

      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li><strong>ต้นทุนเริ่มแรม:</strong> ประมาณ 15,000-20,000 บาทต่อไร่ (เตรียมพื้นที่ + ต้น + อุปกรณ์)</li>
        <li><strong>ค่าบำรุงประจำปี:</strong> ประมาณ 4,000-5,000 บาทต่อไร่ (ปุ๋ย ยา การดูแล)</li>
        <li><strong>ระยะเวลากำหนดออกผลิต:</strong> 5-7 ปี จึงจะเริ่มเก็บยางได้</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ผลผลิตและรายได้</h3>

      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li><strong>ต้นต่อไร่:</strong> ปกติ 80-100 ต้น</li>
        <li><strong>ผลผลิตต่อต้น:</strong> เมื่อโตเต็มที่ ให้ยางแห้ง 3-4 กก./ต้น/ปี</li>
        <li><strong>ราคาตลาด:</strong> ยางแห้ง 40-60 บาท/กก. (อ้างอิงตลาดโลก)</li>
        <li><strong>ระยะเวลาเก็บเกี่ยว:</strong> 8-9 เดือนต่อปี (ตามฤดูกาล)</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่าง: สวนยาง 10 ไร่</h3>

      <p>
        สมมติปลูกยาง 10 ไร่ ด้วยต้นสายพันธุ์ที่ดี ระยะเวลา 6 ปี จนถึงเก็บเกี่ยว:
      </p>

      <ul class="list-disc pl-6 space-y-1 text-gray-700 text-sm">
        <li>ต้นทุนเริ่มแรม: 10 × 17,500 = 175,000 บาท</li>
        <li>ค่าบำรุง 6 ปี: 10 × 4,000 × 6 = 240,000 บาท</li>
        <li>ต้นทุนรวม: 415,000 บาท</li>
        <li>รายได้ต่อปี (ปีที่ 7): 10 ไร่ × 85 ต้น × 3.5 กก. × 50 บาท = 148,750 บาท</li>
        <li>ROI ปีแรก: 29.6% ต่อปี</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณ-ผลตอบแทนสวนยางพารา/" />
    <RelatedCalculators currentHref="/คำนวณ-ผลตอบแทนสวนยางพารา/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น ผลผลิตและรายได้จริงขึ้นอยู่กับสภาพอากาศ การดูแล ราคาตลาด และปัจจัยอื่นๆ กรุณาติดต่อหน่วยงานส่งเสริมการเกษตรสำหรับคำแนะนำเฉพาะพื้นที่
    </div>
  </article>

  <script>
    function formatCurrency(num: number): string {
      return new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(num);
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const raiSize = parseFloat((document.getElementById('raiSize') as HTMLInputElement).value) || 0;
      const yearsToHarvest = parseFloat((document.getElementById('yearsToHarvest') as HTMLInputElement).value) || 6;
      const treesPerRai = parseFloat((document.getElementById('treesPerRai') as HTMLInputElement).value) || 85;
      const yieldPerTree = parseFloat((document.getElementById('yieldPerTree') as HTMLInputElement).value) || 3.5;

      if (raiSize <= 0) return;

      const initialInvest = raiSize * 17500;
      const annualMaint = raiSize * 4000;
      const totalInvest = initialInvest + (annualMaint * yearsToHarvest);

      const totalTrees = raiSize * treesPerRai;
      const yield_ = Math.round(totalTrees * yieldPerTree);
      const pricePerKg = 50;
      const annualIncome = yield_ * pricePerKg;

      const profit = annualIncome - annualMaint;
      const roi = (profit / initialInvest) * 100;

      (document.getElementById('initial-invest') as HTMLElement).textContent = formatCurrency(initialInvest);
      (document.getElementById('annual-cost') as HTMLElement).textContent = formatCurrency(annualMaint);
      (document.getElementById('total-invest') as HTMLElement).textContent = formatCurrency(totalInvest);
      (document.getElementById('yield') as HTMLElement).textContent = yield_.toLocaleString('th-TH') + ' กก.';
      (document.getElementById('annual-income') as HTMLElement).textContent = formatCurrency(annualIncome);
      (document.getElementById('profit') as HTMLElement).textContent = formatCurrency(profit);
      (document.getElementById('roi') as HTMLElement).textContent = Math.round(roi * 10) / 10 + '%';

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('rubber-plantation');
    });

    // Auto-calculate on load
    document.getElementById('btn-calculate')!.click();
  </script>
</BaseLayout>
