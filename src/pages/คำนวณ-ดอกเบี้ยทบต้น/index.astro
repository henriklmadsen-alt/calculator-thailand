---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณดอกเบี้ยทบต้น 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณดอกเบี้ยทบต้น (Compound Interest) ฟรี 2569 — ใส่เงินต้น ดอกเบี้ย ระยะเวลา รู้ว่าเงินจะเติบโตเป็นเท่าไรในอนาคต';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ดอกเบี้ยทบต้น/`;

const faqData = [
  {
    question: 'ดอกเบี้ยทบต้นคืออะไร และทำงานอย่างไร?',
    answer: 'ดอกเบี้ยทบต้น (Compound Interest) คือดอกเบี้ยที่คิดจากเงินต้นรวมดอกเบี้ยที่สะสมอยู่ด้วย ทำให้เงินเติบโตเร็วขึ้นแบบทวีคูณเมื่อเวลาผ่านไป ตรงข้ามกับดอกเบี้ยธรรมดา (Simple Interest) ที่คิดจากเงินต้นเดิมตลอด',
  },
  {
    question: 'ความถี่ทบต้น (Compounding Frequency) ส่งผลอย่างไร?',
    answer: 'ยิ่งทบต้นบ่อย ผลตอบแทนยิ่งสูง แต่ความแตกต่างน้อยลงเมื่อความถี่เพิ่มขึ้น เช่น อัตรา 10% ต่อปี: ทบรายปี = 10.00%, ทบรายไตรมาส = 10.38%, ทบรายเดือน = 10.47%, ทบรายวัน = 10.52% ความแตกต่างระหว่างรายเดือนกับรายวันน้อยมาก',
  },
  {
    question: 'กฎ Rule of 72 คืออะไร?',
    answer: 'Rule of 72 เป็นวิธีคิดเร็วว่าเงินจะเพิ่มเป็น 2 เท่าในกี่ปี: จำนวนปี ≈ 72 ÷ อัตราดอกเบี้ย% ตัวอย่าง: อัตรา 6% ต่อปี → เงินเพิ่มเป็น 2 เท่าใน 72÷6 = 12 ปี, อัตรา 12% → 6 ปี',
  },
  {
    question: 'ดอกเบี้ยทบต้นกับเงินเฟ้อ — ควรใช้อย่างไร?',
    answer: 'ต้องคิดถึงผลตอบแทนที่แท้จริง (Real Return) = ผลตอบแทนทบต้น − อัตราเงินเฟ้อ ถ้าเงินเฟ้อ 3% ต่อปีและดอกเบี้ยเงินฝาก 2% ต่อปี ผลตอบแทนแท้จริงติดลบ (-1%) เงินซื้อสินค้าได้น้อยลงแม้จะมีดอกเบี้ยเข้ามา',
  },
  {
    question: 'Effective Annual Rate (EAR) คืออะไร?',
    answer: 'EAR คืออัตราดอกเบี้ยที่แท้จริงต่อปีหลังคำนึงถึงการทบต้น สูตร: EAR = (1 + r/n)^n − 1 เช่น อัตราดอกเบี้ย 12% ทบรายเดือน: EAR = (1+0.01)^12 − 1 = 12.68% ใช้เปรียบเทียบผลิตภัณฑ์การเงินที่มีความถี่ทบต้นต่างกัน',
  },
,
  { question: 'ดอกเบี้ยทบต้น (Compound Interest) คืออะไร?', answer: 'ดอกเบี้ยที่คำนวณจากเงินต้นบวกดอกเบี้ยสะสม ทำให้เงินงอกเร็วกว่าดอกเบี้ยธรรมดา สูตร: A = P(1+r/n)^(nt) โดย P=เงินต้น, r=อัตราดอกเบี้ย, n=ครั้งที่ทบต่อปี, t=จำนวนปี' },
  { question: 'กฎ 72 ใช้คำนวณอะไร?', answer: 'ใช้ประมาณจำนวนปีที่เงินจะเพิ่มเป็น 2 เท่า: จำนวนปี = 72 ÷ อัตราดอกเบี้ย เช่น ดอกเบี้ย 6% ต่อปี เงินจะเป็น 2 เท่าใน 72÷6 = 12 ปี เป็นกฎง่ายสำหรับการวางแผนการเงิน' },
  { question: 'อัตราดอกเบี้ยเงินฝากออมทรัพย์ในไทยปัจจุบันอยู่ที่เท่าไร?', answer: 'ออมทรัพย์ทั่วไปอยู่ที่ 0.5-1.0% ต่อปี ฝากประจำ 12 เดือนอยู่ที่ 1.5-2.5% ต่อปี บัญชีออมทรัพย์พิเศษบางแห่งให้สูงถึง 1.5-3% ตรวจสอบอัตราปัจจุบันจากธนาคารแห่งประเทศไทย bot.or.th' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณดอกเบี้ยทบต้น',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณดอกเบี้ยทบต้น',
  description: 'ขั้นตอนการคำนวณดอกเบี้ยทบต้นด้วยสูตร A = P(1+r/n)^nt',
  step: [
    {
      '@type': 'HowToStep',
      name: 'กรอกเงินต้น (P)',
      text: 'ระบุจำนวนเงินต้นเริ่มต้นที่ต้องการลงทุนหรือฝาก เป็นบาท',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกอัตราดอกเบี้ยต่อปี (r)',
      text: 'ระบุอัตราดอกเบี้ยต่อปีเป็น% เช่น 5 สำหรับ 5% ต่อปี',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกความถี่ทบต้น (n)',
      text: 'เลือกว่าทบต้นกี่ครั้งต่อปี: รายปี (1), รายครึ่งปี (2), รายไตรมาส (4), รายเดือน (12), รายวัน (365)',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกระยะเวลา (t) และดูผล',
      text: 'กรอกจำนวนปี ระบบแสดงมูลค่ารวม ดอกเบี้ยสะสม และ Effective Annual Rate',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-ดอกเบี้ยทบต้น">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณดอกเบี้ยทบต้น — Compound Interest</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: A = P(1 + r/n)^nt รองรับทุกความถี่ทบต้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณดอกเบี้ยทบต้น (Compound Interest) 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณผลของดอกเบี้ยทบต้นในทุกความถี่ ดูมูลค่ารวม ดอกเบี้ยสะสม และ Effective Annual Rate เปรียบเทียบผลิตภัณฑ์การเงิน
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'ธนาคารแห่งประเทศไทย: อัตราดอกเบี้ยนโยบาย 2569',
        'ตลาดหลักทรัพย์แห่งประเทศไทย (SET): ผลตอบแทนการลงทุน',
      ]}
      assumptions={[
        'สูตร: A = P(1 + r/n)^(n×t)',
        'P = เงินต้น, r = อัตราดอกเบี้ยต่อปี (ทศนิยม), n = ความถี่ทบต้น/ปี, t = จำนวนปี',
        'ไม่รวมการฝากเพิ่มระหว่างงวด (ดูมูลค่าอนาคตสำหรับกรณีฝากสม่ำเสมอ)',
      ]}
      references={[
        { label: 'ธนาคารแห่งประเทศไทย', href: 'https://www.bot.or.th' },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="ci-form" class="space-y-5">
        <p id="ci-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ci-principal" class="block text-sm font-medium text-gray-700 mb-1">เงินต้น — Principal (บาท)</label>
            <input type="text" id="ci-principal" inputmode="numeric" placeholder="เช่น 100,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="ci-rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราดอกเบี้ยต่อปี (%)</label>
            <input type="text" id="ci-rate" inputmode="decimal" placeholder="เช่น 5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="ci-freq" class="block text-sm font-medium text-gray-700 mb-1">ความถี่ทบต้น</label>
            <select id="ci-freq"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
              <option value="1">รายปี (1 ครั้ง/ปี)</option>
              <option value="2">รายครึ่งปี (2 ครั้ง/ปี)</option>
              <option value="4">รายไตรมาส (4 ครั้ง/ปี)</option>
              <option value="12" selected>รายเดือน (12 ครั้ง/ปี)</option>
              <option value="365">รายวัน (365 ครั้ง/ปี)</option>
            </select>
          </div>
          <div>
            <label for="ci-years" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (ปี)</label>
            <input type="text" id="ci-years" inputmode="decimal" placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
        </div>

        <button type="submit" id="ci-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณดอกเบี้ยทบต้น
        </button>
      </form>
    </div>

    <div id="ci-results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-4">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">มูลค่ารวม (A)</div>
            <div id="res-ci-total" class="text-2xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยสะสม</div>
            <div id="res-ci-interest" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Effective Annual Rate</div>
            <div id="res-ci-ear" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินต้น</span>
            <span id="res-ci-p" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">อัตราดอกเบี้ย</span>
            <span id="res-ci-r" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ความถี่ทบต้น</span>
            <span id="res-ci-n" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ระยะเวลา</span>
            <span id="res-ci-t" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">สัดส่วนดอกเบี้ย/เงินต้น</span>
            <span id="res-ci-ratio" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#ci-results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรดอกเบี้ยทบต้น</h2>
      <div class="bg-gray-50 rounded-lg p-4 my-4">
        <p class="font-semibold mb-1">สูตร Compound Interest:</p>
        <p class="text-sm">A = P × (1 + r/n)^(n×t)</p>
        <p class="text-xs text-gray-500 mt-1">P = เงินต้น, r = อัตราดอกเบี้ยต่อปี (ทศนิยม), n = ความถี่/ปี, t = ปี</p>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่าง: ฝาก 100,000 บาท ดอกเบี้ย 5% ทบรายเดือน 10 ปี</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>A = 100,000 × (1 + 0.05/12)^(12×10)</li>
          <li>= 100,000 × (1.004167)^120</li>
          <li>= 100,000 × 1.6470</li>
          <li><strong>= 164,700 บาท — ดอกเบี้ยสะสม = 64,700 บาท</strong></li>
        </ul>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        <strong>แหล่งอ้างอิง:</strong>
        <a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">ธนาคารแห่งประเทศไทย</a>
      </p>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-ดอกเบี้ยทบต้น/" />
    <RelatedCalculators currentHref="/คำนวณ-ดอกเบี้ยทบต้น/" slugs={['คำนวณ-มูลค่าอนาคต-future-value', 'คำนวณ-cagr-อัตราเติบโตทบต้นรายปี', 'คำนวณดอกเบี้ยเงินฝาก']} />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ ไม่รวมภาษีดอกเบี้ยและค่าธรรมเนียมจริง
    </div>
  </article>
</BaseLayout>

<script>
  function parseNum(v: string): number {
    return parseFloat(String(v).replace(/,/g, '').trim()) || 0;
  }
  function fmt(n: number): string {
    return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
  }

  const freqLabels: Record<string, string> = {
    '1': 'รายปี',
    '2': 'รายครึ่งปี',
    '4': 'รายไตรมาส',
    '12': 'รายเดือน',
    '365': 'รายวัน',
  };

  const form = document.getElementById('ci-form') as HTMLFormElement;
  const formError = document.getElementById('ci-form-error') as HTMLElement;
  const resultsDiv = document.getElementById('ci-results') as HTMLElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    formError.classList.add('hidden');

    const P = parseNum((document.getElementById('ci-principal') as HTMLInputElement).value);
    const r = parseNum((document.getElementById('ci-rate') as HTMLInputElement).value) / 100;
    const n = parseNum((document.getElementById('ci-freq') as HTMLSelectElement).value);
    const t = parseNum((document.getElementById('ci-years') as HTMLInputElement).value);

    if (P <= 0 || r <= 0 || t <= 0) {
      formError.classList.remove('hidden');
      formError.textContent = 'กรุณากรอกเงินต้น อัตราดอกเบี้ย และระยะเวลาให้ถูกต้อง';
      return;
    }

    const A = P * Math.pow(1 + r / n, n * t);
    const interest = A - P;
    const ear = Math.pow(1 + r / n, n) - 1;
    const ratio = interest / P * 100;
    const freqLabel = freqLabels[String(n)] || `${n} ครั้ง/ปี`;

    (document.getElementById('res-ci-total') as HTMLElement).textContent = fmt(A) + ' บาท';
    (document.getElementById('res-ci-interest') as HTMLElement).textContent = fmt(interest) + ' บาท';
    (document.getElementById('res-ci-ear') as HTMLElement).textContent = (ear * 100).toFixed(4) + '%';
    (document.getElementById('res-ci-p') as HTMLElement).textContent = fmt(P) + ' บาท';
    (document.getElementById('res-ci-r') as HTMLElement).textContent = (r * 100).toFixed(2) + '% ต่อปี';
    (document.getElementById('res-ci-n') as HTMLElement).textContent = freqLabel;
    (document.getElementById('res-ci-t') as HTMLElement).textContent = t.toFixed(1) + ' ปี';
    (document.getElementById('res-ci-ratio') as HTMLElement).textContent = ratio.toFixed(2) + '%';

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
