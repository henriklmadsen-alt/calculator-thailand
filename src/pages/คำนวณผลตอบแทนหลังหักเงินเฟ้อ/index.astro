---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณผลตอบแทนหลังหักเงินเฟ้อ 2569 | Real Return | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณผลตอบแทนจริงหลังหักเงินเฟ้อ เพื่อทราบกำลังซื้อที่แท้จริงของการลงทุน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณผลตอบแทนหลังหักเงินเฟ้อ/`;

const faqData = [
  {
    question: 'ผลตอบแทนจริง (Real Return) คืออะไร?',
    answer: 'ผลตอบแทนจริงคือผลตอบแทนที่ได้หลังหักผลกระทบของเงินเฟ้อออกแล้ว สูตรคือ (1 + ผลตอบแทนนามธรรม) / (1 + อัตราเงินเฟ้อ) - 1 หากผลตอบแทนนามธรรม 7% และเงินเฟ้อ 3.5% ผลตอบแทนจริงจะอยู่ที่ประมาณ 3.4% ไม่ใช่ 3.5%',
  },
  {
    question: 'อัตราเงินเฟ้อในไทยเฉลี่ยเท่าไหร่?',
    answer: 'อัตราเงินเฟ้อในประเทศไทยโดยเฉลี่ยในช่วง 10 ปีที่ผ่านมาอยู่ที่ประมาณ 1-3% ต่อปี แต่บางช่วงปี 2565-2566 สูงถึง 5-7% เนื่องจากราคาพลังงานและอาหารที่ปรับตัวสูงขึ้น การใช้ค่าเฉลี่ย 3-3.5% เป็นการประมาณที่สมเหตุสมผล',
  },
  {
    question: 'ทำไมต้องคำนวณผลตอบแทนจริง?',
    answer: 'เพราะเงินเฟ้อกัดกร่อนกำลังซื้อของเงิน แม้การลงทุนจะได้ผลตอบแทน 5% แต่หากเงินเฟ้อ 3.5% กำลังซื้อเพิ่มขึ้นจริงๆ แค่ 1.4% เท่านั้น การทราบผลตอบแทนจริงช่วยให้เปรียบเทียบทางเลือกลงทุนได้อย่างแม่นยำ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผลตอบแทนหลังหักเงินเฟ้อ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผลตอบแทนหลังหักเงินเฟ้อ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณผลตอบแทนหลังหักเงินเฟ้อ 2569 — Real Return ที่แท้จริง
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณผลตอบแทนจริงหลังหักเงินเฟ้อ เพื่อทราบกำลังซื้อที่แท้จริงของการลงทุน
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="inflation-return-form" class="space-y-5">
        <p id="inflation-return-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ir-nominal" class="block text-sm font-medium text-gray-700 mb-1">ผลตอบแทนนามธรรม (Nominal, %/ปี)</label>
            <input type="text" id="ir-nominal" inputmode="decimal" placeholder="เช่น 7"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="ir-nominal-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ir-inflation" class="block text-sm font-medium text-gray-700 mb-1">อัตราเงินเฟ้อ (%/ปี)</label>
            <input type="text" id="ir-inflation" inputmode="decimal" placeholder="เช่น 3.5" value="3.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="ir-inflation-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ir-principal" class="block text-sm font-medium text-gray-700 mb-1">เงินลงทุน (บาท)</label>
            <input type="text" id="ir-principal" inputmode="numeric" placeholder="เช่น 100,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="ir-principal-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ir-years" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (ปี)</label>
            <select id="ir-years" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              {Array.from({length: 30}, (_, i) => i + 1).map(y => (
                <option value={y} selected={y === 10}>{y} ปี</option>
              ))}
            </select>
          </div>
        </div>

        <button type="submit" id="inflation-return-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ผลตอบแทนจริง (%/ปี)</div>
            <div id="res-real-return" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">มูลค่าอนาคต (ตามนามธรรม)</div>
            <div id="res-nominal-fv" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">กำลังซื้อจริง</div>
            <div id="res-real-fv" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินเฟ้อกัดกร่อน</div>
            <div id="res-erosion" class="text-xl font-bold text-red-600">-</div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรคำนวณผลตอบแทนจริง (Fisher Equation)</h2>
      <p>ผลตอบแทนจริง = ((1 + ผลตอบแทนนามธรรม/100) / (1 + อัตราเงินเฟ้อ/100)) - 1<br />มูลค่าอนาคต = เงินลงทุน × (1 + ผลตอบแทนนามธรรม/100)^n<br />กำลังซื้อจริง = เงินลงทุน × (1 + ผลตอบแทนจริง)^n</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ความสำคัญของผลตอบแทนจริง</h3>
      <p>นักลงทุนมักโฟกัสที่ผลตอบแทนนามธรรม แต่ผลตอบแทนจริงบอกว่ากำลังซื้อเพิ่มขึ้นจริงเท่าไหร่ การลงทุนที่ได้ผลตอบแทนต่ำกว่าอัตราเงินเฟ้อหมายความว่ากำลังซื้อลดลง แม้ยอดเงินจะเพิ่มขึ้น</p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณผลตอบแทนหลังหักเงินเฟ้อ/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น อัตราเงินเฟ้อจริงอาจแตกต่างในอนาคต ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return parseFloat(v.replace(/,/g, '')) || 0; }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }
    const form = document.getElementById('inflation-return-form') as HTMLFormElement;
    const submitBtn = document.getElementById('inflation-return-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('inflation-return-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const nominalInput = document.getElementById('ir-nominal') as HTMLInputElement;
    const inflationInput = document.getElementById('ir-inflation') as HTMLInputElement;
    const principalInput = document.getElementById('ir-principal') as HTMLInputElement;
    function setFieldError(id: string, msg: string) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.remove('hidden'); }
    function clearFieldError(id: string) { const el = document.getElementById(id); if (!el) return; el.textContent = ''; el.classList.add('hidden'); }
    function clearValidation() { formError.classList.add('hidden'); ['ir-nominal-error','ir-inflation-error','ir-principal-error'].forEach(clearFieldError); }
    [nominalInput, inflationInput, principalInput].forEach(input => { input.addEventListener('input', clearValidation); });
    form.addEventListener('submit', (e) => {
      e.preventDefault(); clearValidation();
      const nominal = parseNum(nominalInput.value);
      const inflation = parseNum(inflationInput.value);
      const principal = parseNum(principalInput.value);
      const years = parseInt((document.getElementById('ir-years') as HTMLSelectElement).value) || 10;
      let hasError = false;
      if (isNaN(nominal)) { setFieldError('ir-nominal-error', 'กรุณากรอกผลตอบแทนนามธรรม'); hasError = true; }
      if (isNaN(inflation)) { setFieldError('ir-inflation-error', 'กรุณากรอกอัตราเงินเฟ้อ'); hasError = true; }
      if (principal <= 0) { setFieldError('ir-principal-error', 'กรุณากรอกเงินลงทุน'); hasError = true; }
      if (hasError) { formError.classList.remove('hidden'); return; }
      submitBtn.disabled = true; submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('inflation-adjusted-return');
      const nominalRate = nominal / 100;
      const inflationRate = inflation / 100;
      const realReturn = ((1 + nominalRate) / (1 + inflationRate)) - 1;
      const nominalFV = principal * Math.pow(1 + nominalRate, years);
      const realFV = principal * Math.pow(1 + realReturn, years);
      const erosion = nominalFV - realFV;
      (document.getElementById('res-real-return') as HTMLElement).textContent = (realReturn * 100).toFixed(2) + '%';
      (document.getElementById('res-nominal-fv') as HTMLElement).textContent = fmt(nominalFV) + ' บาท';
      (document.getElementById('res-real-fv') as HTMLElement).textContent = fmt(realFV) + ' บาท';
      (document.getElementById('res-erosion') as HTMLElement).textContent = fmt(erosion) + ' บาท';
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false; submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('inflation-adjusted-return');
      trackCalculatorUsed('inflation-adjusted-return');
    });
  </script>
</BaseLayout>
