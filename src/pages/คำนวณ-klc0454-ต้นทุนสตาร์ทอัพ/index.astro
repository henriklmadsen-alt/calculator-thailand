---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณต้นทุนเริ่มต้นธุรกิจ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนเริ่มต้นธุรกิจ Startup Cost ค่าจดทะเบียน ค่าอุปกรณ์ ค่าเช่า งบดำเนินการ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0454-ต้นทุนสตาร์ทอัพ/`;

const faqData = [
  { question: 'ต้นทุนเริ่มต้นธุรกิจขนาดเล็กเท่าไหร่?', answer: 'ธุรกิจขนาดเล็กใช้งบเริ่มต้น 50,000-500,000 บาท ร้านค้าออนไลน์อาจเริ่มด้วย 20,000-100,000 บาท ร้านอาหาร 200,000-2,000,000 บาท' },
  { question: 'ควรมีเงินสำรองกี่เดือนก่อนเริ่มธุรกิจ?', answer: 'แนะนำมีเงินสำรองค่าใช้จ่ายดำเนินงาน 6-12 เดือน เพราะธุรกิจใหม่มักใช้เวลา 3-6 เดือนกว่าจะมีรายได้เพียงพอ' },
  { question: 'แหล่งเงินทุนสำหรับ Startup ในไทยมีอะไรบ้าง?', answer: 'แหล่งเงินทุน Startup ได้แก่ เงินออมส่วนตัว กู้ธนาคาร สินเชื่อ SME ธ.พ.ด. Angel Investor Venture Capital โปรแกรมรัฐบาล เช่น NIA, DEPA' },
  { question: 'ค่าใช้จ่ายที่มักลืมคำนวณมีอะไรบ้าง?', answer: 'มักลืมคำนวณ ค่าประกันสังคม ภาษีมูลค่าเพิ่ม ค่าซ่อมบำรุง ค่าธรรมเนียมธนาคาร ค่าซอฟต์แวร์ ค่าการตลาด และเงินเดือนตัวเอง' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนเริ่มต้นธุรกิจ">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนเริ่มต้นธุรกิจ</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">ประมาณการต้นทุนทั้งหมดสำหรับเริ่มต้นธุรกิจใหม่</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="reg_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าจดทะเบียนและกฎหมาย (บาท)</label><input type="text" id="reg_cost" inputmode="decimal" placeholder="เช่น 15000" value="15000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="equipment_startup" class="block text-sm font-medium text-gray-700 mb-1">ค่าอุปกรณ์และเครื่องมือ (บาท)</label><input type="text" id="equipment_startup" inputmode="decimal" placeholder="เช่น 100000" value="100000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="rent_deposit" class="block text-sm font-medium text-gray-700 mb-1">มัดจำเช่าและปรับปรุงสถานที่ (บาท)</label><input type="text" id="rent_deposit" inputmode="decimal" placeholder="เช่น 60000" value="60000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="marketing_startup" class="block text-sm font-medium text-gray-700 mb-1">งบการตลาดเริ่มต้น (บาท)</label><input type="text" id="marketing_startup" inputmode="decimal" placeholder="เช่น 30000" value="30000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="working_capital" class="block text-sm font-medium text-gray-700 mb-1">เงินทุนหมุนเวียน 3 เดือน (บาท)</label><input type="text" id="working_capital" inputmode="decimal" placeholder="เช่น 100000" value="100000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">ต้นทุนคงที่เริ่มต้น</p>
            <p id="fixed_startup" class="font-bold">-</p>
          </div>
          <div class="bg-indigo-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมงบเริ่มต้นธุรกิจ</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const regCost = parseFloat((document.getElementById('reg_cost') as HTMLInputElement).value) || 0;
      const equipment = parseFloat((document.getElementById('equipment_startup') as HTMLInputElement).value) || 0;
      const rentDeposit = parseFloat((document.getElementById('rent_deposit') as HTMLInputElement).value) || 0;
      const marketing = parseFloat((document.getElementById('marketing_startup') as HTMLInputElement).value) || 0;
      const workingCapital = parseFloat((document.getElementById('working_capital') as HTMLInputElement).value) || 0;

      const fixedStartup = regCost + equipment + rentDeposit + marketing;
      const total = fixedStartup + workingCapital;

      (document.getElementById('fixed_startup') as HTMLElement).textContent = fixedStartup.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('startup-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
