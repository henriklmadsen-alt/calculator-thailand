---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนและรายได้ปลูกอ้อย | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการปลูกอ้อย ต้นทุนต่อไร่ ราคาอ้อยต่อตัน กำไรต่อฤดูกาล';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0494-ปลูกอ้อย/`;
const faqData = [
  { question: 'ผลผลิตอ้อยต่อไร่เฉลี่ยเท่าไหร่?', answer: 'อ้อยปีแรก (อ้อยปลูก) ผลผลิตเฉลี่ย 8-12 ตัน/ไร่ อ้อยตอ 1-2 ผลผลิต 7-10 ตัน/ไร่ พื้นที่ชลประทานที่ดี อาจได้ 15-20 ตัน/ไร่' },
  { question: 'ราคาอ้อยคิดอย่างไร?', answer: 'ราคาอ้อยอิงจากค่า CCS (Commercial Cane Sugar) ราคาขั้นต้น 800-1,100 บาท/ตัน ปรับตาม CCS และเงินส่วนแบ่งจากน้ำตาล ติดตามจากสำนักงานคณะกรรมการอ้อยและน้ำตาลทราย' },
  { question: 'ต้นทุนปลูกอ้อยต่อไร่เฉลี่ยเท่าไหร่?', answer: 'อ้อยปลูก ต้นทุน 5,000-8,000 บาท/ไร่ อ้อยตอ ต้นทุน 3,000-5,000 บาท/ไร่ รายการหลักคือ ค่าพันธุ์ ปุ๋ย ยา แรงงาน และค่าตัดอ้อย' },
  { question: 'การปลูกอ้อยสดดีกว่าอ้อยไฟไหม้?', answer: 'อ้อยสดได้ราคาสูงกว่าอ้อยไฟ 30 บาท/ตัน เนื่องจาก CCS สูงกว่าและมีสิ่งปนเปื้อนน้อย ลดมลภาวะ แต่ต้นทุนตัดสูงกว่า ต้องใช้เครื่องตัดหรือแรงงานมากขึ้น' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนและรายได้ปลูกอ้อย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนและรายได้ปลูกอ้อย</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนและกำไรการปลูกอ้อยต่อไร่ต่อฤดู</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="sugarcane_area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่ปลูก (ไร่)</label><input type="number" id="sugarcane_area" min="1" placeholder="เช่น 30" value="30" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="sugarcane_cost_rai" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนต่อไร่ (บาท)</label><input type="text" id="sugarcane_cost_rai" inputmode="decimal" placeholder="เช่น 6000" value="6000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="sugarcane_yield_rai" class="block text-sm font-medium text-gray-700 mb-1">ผลผลิตต่อไร่ (ตัน)</label><input type="text" id="sugarcane_yield_rai" inputmode="decimal" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="sugarcane_price_ton" class="block text-sm font-medium text-gray-700 mb-1">ราคาอ้อย (บาท/ตัน)</label><input type="text" id="sugarcane_price_ton" inputmode="decimal" placeholder="เช่น 950" value="950" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้รวม</p><p id="sugarcane_revenue" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">กำไรสุทธิ</p><p id="sugarcane_profit" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const area = parseFloat((document.getElementById('sugarcane_area') as HTMLInputElement).value) || 0;
      const costRai = parseFloat((document.getElementById('sugarcane_cost_rai') as HTMLInputElement).value) || 0;
      const yieldRai = parseFloat((document.getElementById('sugarcane_yield_rai') as HTMLInputElement).value) || 0;
      const priceTon = parseFloat((document.getElementById('sugarcane_price_ton') as HTMLInputElement).value) || 0;
      const totalCost = area * costRai;
      const revenue = area * yieldRai * priceTon;
      const profit = revenue - totalCost;
      (document.getElementById('sugarcane_revenue') as HTMLElement).textContent = Math.round(revenue).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('sugarcane_profit') as HTMLElement).textContent = Math.round(profit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('sugarcane-farming-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
