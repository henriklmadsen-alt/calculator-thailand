---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณชั่วโมงทำงานกะ รวมกะดึก ชั่วโมงต่อสัปดาห์และเดือน ปี 2569 | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณชั่วโมงทำงานกะ รองรับกะข้ามคืน ระบุเวลาเริ่ม-สิ้นสุด พักกี่นาที กี่กะต่อสัปดาห์ คำนวณชั่วโมงรวมต่อสัปดาห์และเดือน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณชั่วโมงทำงานกะ/`;

const faqData = [
  {
    question: 'กะดึก 22:00-06:00 มีกี่ชั่วโมง?',
    answer: 'กะ 22:00-06:00 มีระยะเวลา 8 ชั่วโมง เครื่องคำนวณรองรับกะข้ามคืนโดยอัตโนมัติ หากเวลาสิ้นสุดน้อยกว่าเวลาเริ่มต้น ระบบจะคำนวณว่าเป็นกะข้ามวัน',
  },
  {
    question: 'กฎหมายแรงงานกำหนดชั่วโมงทำงานสูงสุดเท่าไร?',
    answer: 'พ.ร.บ. คุ้มครองแรงงานกำหนดให้ทำงานไม่เกิน 8 ชั่วโมงต่อวัน และไม่เกิน 48 ชั่วโมงต่อสัปดาห์สำหรับงานทั่วไป งานที่อาจเป็นอันตรายกำหนดไม่เกิน 7 ชั่วโมงต่อวัน และ 42 ชั่วโมงต่อสัปดาห์',
  },
  {
    question: 'เวลาพักกลางวันนับรวมในชั่วโมงทำงานหรือไม่?',
    answer: 'กฎหมายกำหนดให้นายจ้างจัดเวลาพักระหว่างทำงานไม่น้อยกว่า 1 ชั่วโมงต่อวัน และเวลาพักนี้ไม่นับเป็นเวลาทำงาน เครื่องคำนวณนี้หักเวลาพักออกจากชั่วโมงทำงานแล้ว',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณชั่วโมงทำงานกะ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณชั่วโมงทำงานกะ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">🕐 คำนวณชั่วโมงทำงานกะ รองรับกะข้ามคืน</p>
      <p class="mt-1 text-sm text-slate-700">ระบุเวลาเริ่ม-สิ้นสุดกะ เวลาพัก จำนวนกะต่อสัปดาห์ คำนวณชั่วโมงต่อกะ สัปดาห์ และเดือน</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับพนักงานกะโรงงาน โรงพยาบาล และงานบริการ 24 ชั่วโมง</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณชั่วโมงทำงานกะ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเวลาเริ่ม-สิ้นสุดกะ เวลาพักพัก จำนวนกะต่อสัปดาห์ และจำนวนสัปดาห์ เพื่อคำนวณชั่วโมงทำงานรวม
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="shift-hours-form" class="space-y-5">
        <p id="shift-hours-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="sh-start" class="mb-1 block text-sm font-medium text-gray-700">เวลาเริ่มกะ (HH:MM)</label>
            <input type="time" id="sh-start" value="22:00"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="sh-start-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="sh-end" class="mb-1 block text-sm font-medium text-gray-700">เวลาสิ้นสุดกะ (HH:MM)</label>
            <input type="time" id="sh-end" value="06:00"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">หากสิ้นสุดหลังเที่ยงคืน ระบบคำนวณกะข้ามคืนให้อัตโนมัติ</p>
            <p id="sh-end-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="sh-break" class="mb-1 block text-sm font-medium text-gray-700">เวลาพัก (นาที)</label>
            <input type="text" id="sh-break" inputmode="numeric" placeholder="เช่น 60"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="sh-break-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="sh-shifts-week" class="mb-1 block text-sm font-medium text-gray-700">กะต่อสัปดาห์ (กะ)</label>
            <input type="text" id="sh-shifts-week" inputmode="numeric" placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="sh-shifts-week-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="sh-weeks" class="mb-1 block text-sm font-medium text-gray-700">จำนวนสัปดาห์</label>
            <input type="text" id="sh-weeks" inputmode="numeric" placeholder="เช่น 4"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="sh-weeks-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณชั่วโมงทำงาน
        </button>
      </form>
    </div>

    <div id="shift-hours-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ชั่วโมงต่อกะ</div>
            <div id="res-sh-per-shift" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ชั่วโมงต่อสัปดาห์</div>
            <div id="res-sh-per-week" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ชั่วโมงต่อเดือน (4 สัปดาห์)</div>
            <div id="res-sh-per-month" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="rounded-lg bg-rose-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ชั่วโมงรวม (ตามระยะที่ระบุ)</div>
            <div id="res-sh-total" class="text-xl font-bold text-rose-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">เวลากะ (รวมพัก)</span>
            <span id="res-sh-gross" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">หักเวลาพัก</span>
            <span id="res-sh-break-text" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">กะทำงานสุทธิต่อกะ</span>
            <span id="res-sh-net" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ชั่วโมงต่อกะ (รวม) = เวลาสิ้นสุด − เวลาเริ่ม (บวก 24 ชม. หากเป็นกะข้ามคืน)</li>
        <li>ชั่วโมงต่อกะ (สุทธิ) = ชั่วโมงต่อกะ − เวลาพัก (นาที ÷ 60)</li>
        <li>ชั่วโมงต่อสัปดาห์ = ชั่วโมงต่อกะ × กะต่อสัปดาห์</li>
        <li>ชั่วโมงต่อเดือน = ชั่วโมงต่อสัปดาห์ × 4</li>
        <li>ชั่วโมงรวม = ชั่วโมงต่อสัปดาห์ × จำนวนสัปดาห์</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณเบี้ยกะดึก/">คำนวณเบี้ยกะดึก</a></li>
        <li><a href="/คำนวณค่าโอที/">คำนวณค่าโอที</a></li>
        <li><a href="/คำนวณค่าจ้างรายชั่วโมง/">คำนวณค่าจ้างรายชั่วโมง</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#shift-hours-results" />
    <RelatedArticles currentHref="/คำนวณชั่วโมงทำงานกะ/" />
    <RelatedCalculators currentHref="/คำนวณชั่วโมงทำงานกะ/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการตามข้อมูลที่กรอก ชั่วโมงทำงานจริงอาจแตกต่างขึ้นอยู่กับวันหยุดและตารางงานจริง กรุณาตรวจสอบกับนายจ้างหรือตารางกะจริงของท่าน
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatHours(h) {
      const hrs = Math.floor(h);
      const mins = Math.round((h - hrs) * 60);
      if (mins === 0) return `${hrs} ชั่วโมง`;
      return `${hrs} ชั่วโมง ${mins} นาที`;
    }
    function setText(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }
    function setErr(id, msg) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.toggle('hidden', !msg);
    }
    function timeToMinutes(timeStr) {
      const [h, m] = timeStr.split(':').map(Number);
      return h * 60 + m;
    }

    const form = document.getElementById('shift-hours-form');
    const formError = document.getElementById('shift-hours-form-error');
    const resultBox = document.getElementById('shift-hours-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['sh-start-error', 'sh-end-error', 'sh-break-error', 'sh-shifts-week-error', 'sh-weeks-error'].forEach((id) => setErr(id, ''));

      const startVal = document.getElementById('sh-start').value;
      const endVal = document.getElementById('sh-end').value;
      const breakMins = parseNum(document.getElementById('sh-break').value);
      const shiftsPerWeek = parseNum(document.getElementById('sh-shifts-week').value);
      const weeks = parseNum(document.getElementById('sh-weeks').value);

      let hasError = false;
      if (!startVal) { setErr('sh-start-error', 'กรอกเวลาเริ่มกะ'); hasError = true; }
      if (!endVal) { setErr('sh-end-error', 'กรอกเวลาสิ้นสุดกะ'); hasError = true; }
      if (!Number.isFinite(breakMins) || breakMins < 0) { setErr('sh-break-error', 'กรอกเวลาพัก >= 0 นาที'); hasError = true; }
      if (!Number.isFinite(shiftsPerWeek) || shiftsPerWeek <= 0 || shiftsPerWeek > 7) { setErr('sh-shifts-week-error', 'กรอกจำนวนกะ 1-7 กะ/สัปดาห์'); hasError = true; }
      if (!Number.isFinite(weeks) || weeks <= 0) { setErr('sh-weeks-error', 'กรอกจำนวนสัปดาห์มากกว่า 0'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const startMins = timeToMinutes(startVal);
      let endMins = timeToMinutes(endVal);
      if (endMins <= startMins) endMins += 24 * 60; // overnight shift

      const grossMinutes = endMins - startMins;
      const netMinutes = grossMinutes - breakMins;
      const netHours = netMinutes / 60;
      const hoursPerWeek = netHours * shiftsPerWeek;
      const hoursPerMonth = hoursPerWeek * 4;
      const totalHours = hoursPerWeek * weeks;

      setText('res-sh-per-shift', formatHours(netHours));
      setText('res-sh-per-week', formatHours(hoursPerWeek));
      setText('res-sh-per-month', formatHours(hoursPerMonth));
      setText('res-sh-total', formatHours(totalHours));
      setText('res-sh-gross', formatHours(grossMinutes / 60));
      setText('res-sh-break-text', `${breakMins} นาที`);
      setText('res-sh-net', formatHours(netHours));

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
