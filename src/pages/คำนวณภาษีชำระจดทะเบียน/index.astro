---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณภาษีทรัพย์สินชำระจดทะเบียน 2569 | ภาษีโอนที่ดิน | Kamnuanlek';
const pageDescription = 'คำนวณภาษีทรัพย์สินที่ต้องเสียเมื่อจดทะเบียนโอนที่ดิน บ้าน คอนโด ตามอัตราของ กรมที่ดิน ปี 2569 ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีชำระจดทะเบียน/`;

const faqData = [
  {
    question: 'ภาษีชำระจดทะเบียนคืออะไร?',
    answer: 'ภาษีที่เสียเมื่อโอนสิทธิในที่ดิน/บ้าน/คอนโด ให้แก่ผู้อื่น คำนวณจากราคาประเมินทุนทรัพย์ของสำนักงานที่ดิน อัตราปกติคือ 2% แต่อาจลดเหลือ 0.01% ถ้าเข้าเงื่อนไขมาตรการของภาครัฐ',
  },
  {
    question: 'ใครจ่ายภาษีชำระจดทะเบียน ผู้ซื้อหรือผู้ขาย?',
    answer: 'โดยปกติผู้ซื้อต้องจ่าย แต่สามารถตกลงกันระหว่างผู้ซื้อและผู้ขายว่าใครจ่าย จำนวนเงินขึ้นอยู่กับราคาประเมินของสำนักงานที่ดิน ไม่ใช่ราคาตลาด',
  },
  {
    question: 'มาตรการ 0.01% ใช้ได้ถึงเมื่อไร?',
    answer: 'มาตรการลดค่าจดทะเบียนโอนเป็น 0.01% ใช้ได้ถึงวันที่ 30 มิถุนายน 2569 สำหรับการโอนและจดจำนองคราวเดียวกัน และต้องเข้าเงื่อนไขที่กำหนด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณภาษีชำระจดทะเบียน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีชำระจดทะเบียน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-rose-100 bg-rose-50 p-4">
      <p class="text-sm font-semibold text-rose-700">ภาษีจดทะเบียนโอนที่ดิน</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณจากราคาประเมินทุนทรัพย์ (ไม่ใช่ราคาตลาด) อัตรา 2% ปกติ หรือ 0.01% หากเข้าเงื่อนไขมาตรการ</p>
      <p class="mt-1 text-xs font-medium text-rose-800">ใช้เป็นค่าประมาณ ยอดจริงขึ้นอยู่กับการประเมินของสำนักงานที่ดิน</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณภาษีทรัพย์สินชำระจดทะเบียน ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกราคาประเมินทุนทรัพย์จากสำนักงานที่ดิน ระบบจะคำนวณภาษีที่ต้องจ่ายเมื่อโอนสิทธิ พร้อมสมัครใจเลือกอัตราปกติ 2% หรือมาตรการ 0.01%
    </p>

    <PublicTrustPanel
      lastUpdated="20 เม.ย. 2569"
      sources={[
        'กรมที่ดิน: อัตราค่าจดทะเบียนโอน 2569',
        'กระทรวงการคลัง: มาตรการลดค่าธรรมเนียม 0.01% (ฉบับที่ 42/2568)',
      ]}
      assumptions={[
        'ราคาประเมินทุนทรัพย์ใช้เป็นฐานคำนวณ ไม่ใช่ราคาตลาด',
        'อัตรา 2% สำหรับการโอนปกติ',
        'อัตรา 0.01% ใช้ได้ถึง 30 มิถุนายน 2569 หากเข้าเงื่อนไข',
      ]}
      references={[
        {
          label: 'กรมที่ดิน: คู่มือค่าธรรมเนียมและภาษี',
          href: 'https://www.dol.go.th/',
        },
        {
          label: 'กระทรวงการคลัง: มาตรการลดค่าจดทะเบียน',
          href: 'https://www.mof.go.th/',
        },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="property-tax-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณากรอกข้อมูลที่จำเป็นให้ครบ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="appraised-value" class="block text-sm font-medium text-gray-700 mb-1">ราคาประเมินทุนทรัพย์ (บาท)</label>
            <input id="appraised-value" type="text" inputmode="numeric" placeholder="เช่น 5,800,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="tax-rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราภาษี</label>
            <select id="tax-rate" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="normal">ปกติ (2%)</option>
              <option value="reduced">มาตรการ (0.01%)</option>
            </select>
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          คำนวณภาษี
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณภาษี</h2>

        <div class="grid gap-3 sm:grid-cols-2 mb-6">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ภาษีที่ต้องจ่าย</div>
            <div id="res-tax-amount" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">อัตราที่ใช้</div>
            <div id="res-tax-rate" class="text-xl font-bold text-sky-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ราคาประเมินทุนทรัพย์</span>
            <span id="res-appraised-value" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-600">อัตราภาษี</span>
            <span id="res-rate-percent" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">ภาษีที่ต้องจ่าย</span>
            <span id="res-calc-tax" class="font-bold text-lg text-primary-700">-</span>
          </div>
        </div>

        <p class="text-xs text-gray-500 mt-4">
          หมายเหตุ: ผลลัพธ์คำนวณจากข้อมูลที่คุณกรอก ยอดจริงขึ้นอยู่กับการประเมินของสำนักงานที่ดิน
        </p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="mb-8 bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 prose prose-slate max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ภาษี (อัตรา 2%) = ราคาประเมิน × 2% (ตามปกติ)</li>
        <li>ภาษี (อัตรา 0.01%) = ราคาประเมิน × 0.01% (มาตรการ ถึง 30 มิถุนายน 2569)</li>
        <li>ฐานคำนวณ: ราคาประเมินทุนทรัพย์จากสำนักงานที่ดิน ไม่ใช่ราคาตลาด</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <RelatedArticles currentHref="/คำนวณภาษีชำระจดทะเบียน/" />
    <RelatedCalculators currentHref="/คำนวณภาษีชำระจดทะเบียน/" />

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(value)} บาท`;
  }

  const form = document.querySelector('#property-tax-form');
  const formError = document.querySelector('#form-error');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const appraisedValue = parseNumber(document.querySelector('#appraised-value')?.value || '');
    const taxRate = document.querySelector('#tax-rate')?.value || 'normal';

    const isValid = Number.isFinite(appraisedValue) && appraisedValue > 0;

    if (!isValid) {
      formError?.classList.remove('hidden');
      results?.classList.add('hidden');
      return;
    }

    formError?.classList.add('hidden');

    const rate = taxRate === 'reduced' ? 0.0001 : 0.02;
    const ratePercent = taxRate === 'reduced' ? '0.01%' : '2%';
    const taxAmount = appraisedValue * rate;

    document.querySelector('#res-tax-amount').textContent = formatCurrency(taxAmount);
    document.querySelector('#res-tax-rate').textContent = ratePercent;
    document.querySelector('#res-appraised-value').textContent = formatCurrency(appraisedValue);
    document.querySelector('#res-rate-percent').textContent = ratePercent;
    document.querySelector('#res-calc-tax').textContent = formatCurrency(taxAmount);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
