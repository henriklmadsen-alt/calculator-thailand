---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ Cash Runway ปี 2569 เงินสดใช้ได้กี่เดือน วันหมดเงิน แจ้งเตือนอันตราย | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณ Cash Runway หรือระยะเวลาที่เงินสดปัจจุบันจะเพียงพอ จากอัตราการใช้จ่ายรายเดือน พร้อมวันประมาณการหมดเงินและสัญญาณเตือนภัย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-cash-runway/`;

const faqData = [
  {
    question: 'Cash Runway คืออะไร?',
    answer: 'Cash Runway คือระยะเวลาที่เงินสดที่มีอยู่จะเพียงพอสำหรับค่าใช้จ่าย ถ้าไม่มีรายได้เพิ่มเลย คำนวณจาก เงินสดปัจจุบัน ÷ ค่าใช้จ่ายรายเดือน เดิมใช้ในธุรกิจ Startup แต่ประยุกต์ใช้กับการเงินส่วนบุคคลได้เช่นกัน',
  },
  {
    question: 'Cash Runway ควรมีอย่างน้อยกี่เดือน?',
    answer: 'สำหรับบุคคล Runway ที่ดีคือ 3-6 เดือน หากน้อยกว่า 3 เดือนถือว่าอยู่ในโซนเสี่ยง ควรหยุดใช้จ่ายฟุ่มเฟือยและเร่งออมทันที',
  },
  {
    question: 'Monthly Burn Rate คืออะไร?',
    answer: 'Burn Rate คืออัตราการใช้จ่ายเงินสดต่อเดือน สำหรับบุคคลคือค่าใช้จ่ายทั้งหมดต่อเดือนก่อนรายได้เข้า ใช้ในการคำนวณว่าเงินออมจะหมดเมื่อไหร่หากหยุดทำงาน',
  },
  {
    question: 'จะเพิ่ม Cash Runway ได้อย่างไร?',
    answer: 'ทำได้สองทาง: (1) ลด Burn Rate โดยตัดค่าใช้จ่ายที่ไม่จำเป็น และ (2) เพิ่มเงินสด โดยออมเงินมากขึ้น ขายสินทรัพย์ที่ไม่จำเป็น หรือหารายได้เสริม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ Cash Runway',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-cash-runway">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-emerald-100 bg-emerald-50 p-4">
      <p class="text-sm font-semibold text-emerald-700">คำนวณ Cash Runway — เงินสดปัจจุบันใช้ได้กี่เดือน</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: Runway = เงินสด ÷ Burn Rate (ค่าใช้จ่าย/เดือน)</p>
      <p class="mt-1 text-xs font-medium text-emerald-800">คำเตือน: น้อยกว่า 3 เดือน = โซนเสี่ยง</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณ Cash Runway ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินสด/เงินออมปัจจุบัน และค่าใช้จ่ายรายเดือน เพื่อดูว่าเงินของคุณจะอยู่ได้นานแค่ไหนหากไม่มีรายได้เข้า
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="cr-form" class="space-y-5">
        <p id="cr-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="cr-cash" class="mb-1 block text-sm font-medium text-gray-700">เงินสด / เงินออมทั้งหมด (บาท)</label>
            <input type="text" id="cr-cash" inputmode="numeric" placeholder="เช่น 150,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="cr-cash-error" class="mt-1 hidden text-sm text-red-600"></p>
            <p class="mt-1 text-xs text-gray-500">รวมบัญชีออมทรัพย์ กองทุนสำรอง เงินสด</p>
          </div>
          <div>
            <label for="cr-burn" class="mb-1 block text-sm font-medium text-gray-700">Burn Rate — ค่าใช้จ่ายต่อเดือน (บาท)</label>
            <input type="text" id="cr-burn" inputmode="numeric" placeholder="เช่น 25,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="cr-burn-error" class="mt-1 hidden text-sm text-red-600"></p>
            <p class="mt-1 text-xs text-gray-500">ค่าใช้จ่ายทั้งหมดต่อเดือน</p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ Cash Runway
        </button>
      </form>
    </div>

    <div id="cr-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div id="cr-runway-box" class="rounded-lg p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">Cash Runway</div>
            <div id="res-cr-runway" class="text-2xl font-bold">-</div>
            <div class="mt-1 text-xs text-gray-500">เดือน</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินสดปัจจุบัน</div>
            <div id="res-cr-cash" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">Burn Rate / เดือน</div>
            <div id="res-cr-burn" class="text-xl font-bold text-red-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">วันประมาณการหมดเงิน</span>
            <span id="res-cr-enddate" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">Burn Rate / วัน</span>
            <span id="res-cr-daily" class="font-medium">-</span>
          </div>
        </div>
        <p id="cr-status" class="mt-4 rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>Cash Runway (เดือน) = เงินสดทั้งหมด ÷ ค่าใช้จ่าย/เดือน</li>
        <li>Burn Rate รายวัน = ค่าใช้จ่าย/เดือน ÷ 30</li>
        <li>วันหมดเงิน = วันนี้ + (Runway × 30 วัน)</li>
        <li>เกณฑ์: น้อยกว่า 3 เดือน = อันตราย | 3-6 = พอดี | มากกว่า 6 = ดี</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณเงินสำรองฉุกเฉิน/">คำนวณเงินสำรองฉุกเฉิน</a></li>
        <li><a href="/คำนวณ-sinking-fund/">คำนวณ Sinking Fund</a></li>
        <li><a href="/คำนวณส่วนต่างรายได้รายจ่าย/">คำนวณส่วนต่างรายได้รายจ่าย</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#cr-results" />
    <RelatedArticles currentHref="/คำนวณ-cash-runway/" />
    <RelatedCalculators currentHref="/คำนวณ-cash-runway/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> การคำนวณสมมติว่าไม่มีรายได้เข้า ในความเป็นจริงหากมีรายได้ระหว่างนั้น Runway จะยาวกว่าที่คำนวณ
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('cr-form');
    const formError = document.getElementById('cr-error');
    const resultBox = document.getElementById('cr-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['cr-cash-error','cr-burn-error'].forEach(id => setErr(id, ''));

      const cash = parseNum(document.getElementById('cr-cash').value);
      const burn = parseNum(document.getElementById('cr-burn').value);
      let hasError = false;
      if (!Number.isFinite(cash) || cash <= 0) { setErr('cr-cash-error', 'กรอกจำนวนเงินสดมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(burn) || burn <= 0) { setErr('cr-burn-error', 'กรอก Burn Rate มากกว่า 0'); hasError = true; }
      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const runway = cash / burn;
      const dailyBurn = burn / 30;

      const endDate = new Date();
      endDate.setDate(endDate.getDate() + Math.round(runway * 30));
      const endDateStr = endDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' });

      setText('res-cr-runway', runway.toFixed(1));
      setText('res-cr-cash', formatMoney(cash));
      setText('res-cr-burn', formatMoney(burn));
      setText('res-cr-enddate', endDateStr);
      setText('res-cr-daily', formatMoney(dailyBurn));

      const runwayBox = document.getElementById('cr-runway-box');
      const runwayEl = document.getElementById('res-cr-runway');
      const statusEl = document.getElementById('cr-status');

      if (runway < 3) {
        runwayBox.className = 'rounded-lg bg-red-50 p-4 text-center';
        runwayEl.className = 'text-2xl font-bold text-red-700';
        statusEl.className = 'mt-4 rounded-lg bg-red-50 p-3 text-sm font-medium text-red-800 border border-red-200';
        statusEl.textContent = `อันตราย! Cash Runway น้อยกว่า 3 เดือน ควรลด Burn Rate และเพิ่มเงินออมทันที`;
      } else if (runway < 6) {
        runwayBox.className = 'rounded-lg bg-amber-50 p-4 text-center';
        runwayEl.className = 'text-2xl font-bold text-amber-700';
        statusEl.className = 'mt-4 rounded-lg bg-amber-50 p-3 text-sm font-medium text-amber-800 border border-amber-200';
        statusEl.textContent = `ระมัดระวัง: Cash Runway อยู่ที่ ${runway.toFixed(1)} เดือน ควรเพิ่มเงินออมให้ถึง 6 เดือน`;
      } else {
        runwayBox.className = 'rounded-lg bg-green-50 p-4 text-center';
        runwayEl.className = 'text-2xl font-bold text-green-700';
        statusEl.className = 'mt-4 rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800 border border-green-200';
        statusEl.textContent = `ดีมาก! Cash Runway ${runway.toFixed(1)} เดือน สุขภาพทางการเงินแข็งแกร่ง`;
      }

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
