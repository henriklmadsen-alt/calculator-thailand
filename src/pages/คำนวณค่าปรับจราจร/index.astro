    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    function calculate() {
      const violationType = (document.getElementById('violation-type') as HTMLSelectElement).value;
      const violationCount = Math.max(1, parseInt((document.getElementById('violation-count') as HTMLInputElement).value) || 1);
      const currentPoints = Math.min(12, Math.max(0, parseInt((document.getElementById('current-points') as HTMLInputElement).value) || 12));

      const v = violations[violationType];
      if (!v) return;

      // Calculate fine
      const totalFineMin = v.fineMin * violationCount;
      const totalFineMax = v.fineMax * violationCount;

      // Calculate points
      const pointsDeducted = v.points * violationCount;
      const pointsRemaining = Math.max(0, currentPoints - pointsDeducted);
      const totalDeducted = 12 - pointsRemaining;

      // Update DOM
      const resultEl = document.getElementById('traffic-result') as HTMLDivElement;
      resultEl.classList.remove('hidden');

      if (v.fineMin === v.fineMax) {
        (document.getElementById('res-fine') as HTMLElement).textContent = `${fmt(totalFineMax)} บาท`;
        (document.getElementById('res-fine-range') as HTMLElement).textContent =
          violationCount > 1 ? `${fmt(v.fineMax)} บาท × ${violationCount} ครั้ง` : '';
      } else {
        (document.getElementById('res-fine') as HTMLElement).textContent = `${fmt(totalFineMin)} - ${fmt(totalFineMax)} บาท`;
        (document.getElementById('res-fine-range') as HTMLElement).textContent =
          violationCount > 1 ? `${fmt(v.fineMin)}-${fmt(v.fineMax)} บาท × ${violationCount} ครั้ง` : `ขึ้นอยู่กับดุลยพินิจเจ้าหน้าที่`;
      }

      (document.getElementById('res-points-deducted') as HTMLElement).textContent =
        v.points > 0 ? `-${v.points * violationCount} คะแนน` : 'ไม่ตัดคะแนน';
      (document.getElementById('res-points-remaining') as HTMLElement).textContent = `${pointsRemaining} / 12 คะแนน`;
      (document.getElementById('res-total-deducted') as HTMLElement).textContent = `${totalDeducted} / 12 คะแนน`;

      // Points remaining color
      const remainingEl = document.getElementById('res-points-remaining') as HTMLElement;
      remainingEl.className = 'text-2xl font-bold';
      if (pointsRemaining === 0) {
        remainingEl.classList.add('text-red-700');
      } else if (pointsRemaining <= 3) {
        remainingEl.classList.add('text-amber-700');
      } else {
        remainingEl.classList.add('text-blue-700');
      }

      // Suspension warning
      const suspensionEl = document.getElementById('suspension-warning') as HTMLDivElement;
      const suspensionDetailEl = document.getElementById('suspension-detail') as HTMLElement;
      if (pointsRemaining === 0) {
        suspensionEl.classList.remove('hidden');
        if (violationType === 'dui') {
          suspensionDetailEl.textContent =
            'เมาแล้วขับ — ถูกตัดคะแนนทั้งหมด 12 คะแนน ส่งผลให้ถูกพักใช้ใบอนุญาตขับขี่ทันที 90 วัน หากขับรถระหว่างถูกพักใช้ใบขับขี่จะมีโทษเพิ่มเติม';
        } else {
          suspensionDetailEl.textContent =
            'คะแนนเหลือ 0 — ถูกพักใช้ใบอนุญาตขับขี่ 90 วัน นับแต่วันที่ได้รับแจ้งคำสั่ง หากขับรถระหว่างถูกพักใช้ใบขับขี่จะมีโทษเพิ่มเติม';
        }
      } else {
        suspensionEl.classList.add('hidden');
      }

      // Criminal notice
      const criminalEl = document.getElementById('criminal-notice') as HTMLDivElement;
      const criminalDetailEl = document.getElementById('criminal-detail') as HTMLElement;
      if (v.criminal) {
        criminalEl.classList.remove('hidden');
        criminalDetailEl.textContent = v.criminal;
      } else {
        criminalEl.classList.add('hidden');
      }

      // Law reference and description
      (document.getElementById('res-law-ref') as HTMLElement).textContent = v.lawRef;
      (document.getElementById('res-description') as HTMLElement).textContent = v.description;

      trackCalculatorUsed('traffic-fine');
    }

    document.getElementById('btn-calculate')!.addEventListener('click', calculate);

    // Track when result section enters viewport
    const trafficResultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('traffic-fine');
          trafficResultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    trafficResultObserver.observe(document.getElementById('traffic-result')!);
  </script>
