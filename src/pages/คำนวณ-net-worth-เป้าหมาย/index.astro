---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ Net Worth เป้าหมายตามอายุ 2569 | ควรมีทรัพย์สินสุทธิเท่าไร | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณ net worth เป้าหมายที่ควรมีตามอายุและรายได้ ตามสูตร wealth accumulation สากล และเปรียบเทียบกับ net worth ปัจจุบันของคุณ อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-net-worth-เป้าหมาย/`;

const faqData = [
  {
    question: 'Net Worth เป้าหมายตามอายุคำนวณอย่างไร?',
    answer: 'สูตรของ Thomas Stanley และ William Danko จากหนังสือ "The Millionaire Next Door": Net Worth เป้าหมาย = อายุ × รายได้ต่อปีก่อนหักภาษี ÷ 10 เช่น อายุ 40 ปี รายได้ 600,000 บาท/ปี เป้าหมาย Net Worth = 40 × 600,000 ÷ 10 = 2,400,000 บาท',
  },
  {
    question: 'PAW และ UAW คืออะไร?',
    answer: 'PAW (Prodigious Accumulator of Wealth) คือผู้สะสมความมั่งคั่งอย่างยอดเยี่ยม มี net worth มากกว่า 2 เท่าของเป้าหมาย ส่วน UAW (Under Accumulator of Wealth) คือผู้สะสมต่ำกว่าเป้า มี net worth น้อยกว่า 0.5 เท่า',
  },
  {
    question: 'Net Worth ที่ดีสำหรับคนไทยในแต่ละช่วงอายุควรเป็นเท่าไร?',
    answer: 'ขึ้นอยู่กับรายได้ของแต่ละคน แต่โดยทั่วไป อายุ 30 ปี รายได้เดือนละ 30,000 บาท: เป้า net worth ~1,080,000 บาท; อายุ 40 ปี รายได้เดือนละ 50,000 บาท: เป้า ~2,400,000 บาท; อายุ 50 ปี รายได้เดือนละ 70,000 บาท: เป้า ~4,200,000 บาท',
  },
  {
    question: 'ถ้า net worth ต่ำกว่าเป้าหมายควรทำอย่างไร?',
    answer: 'ลดรายจ่ายและเพิ่มอัตราการออม เพิ่มรายได้ผ่านการพัฒนาทักษะหรือรายได้เสริม ลงทุนให้มากขึ้นและเร็วขึ้น ลดหนี้ที่มีดอกเบี้ยสูง และตั้งเป้าหมายเพิ่ม net worth ปีละ 10-20% ของรายได้',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ Net Worth เป้าหมาย',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-net-worth-เป้าหมาย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณ Net Worth เป้าหมายตามอายุ 2569 — ควรมีทรัพย์สินสุทธิเท่าไร?
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณ net worth เป้าหมายที่ควรมีตามอายุและรายได้ ตามสูตร Stanley &amp; Danko และเปรียบเทียบสถานะทางการเงินปัจจุบันของคุณ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="nwt-form" class="space-y-5">
        <p id="nwt-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกอายุและรายได้ให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="nwt-age" class="block text-sm font-medium text-gray-700 mb-1">
              อายุปัจจุบัน (ปี)
            </label>
            <input
              type="number"
              id="nwt-age"
              min="18"
              max="70"
              placeholder="เช่น 35"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="nwt-income" class="block text-sm font-medium text-gray-700 mb-1">
              รายได้ต่อปีก่อนหักภาษี (บาท)
            </label>
            <input
              type="text"
              id="nwt-income"
              inputmode="numeric"
              placeholder="เช่น 600,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p class="mt-1 text-xs text-gray-500">รายได้เดือน × 12 หรือรายได้ต่อปีรวมโบนัส</p>
          </div>
          <div class="sm:col-span-2">
            <label for="nwt-current" class="block text-sm font-medium text-gray-700 mb-1">
              Net Worth ปัจจุบัน (บาท) <span class="text-gray-400 font-normal">ไม่บังคับ</span>
            </label>
            <input
              type="text"
              id="nwt-current"
              inputmode="numeric"
              placeholder="เช่น 500,000 (สินทรัพย์รวม หักหนี้สิน)"
              class="w-full sm:w-96 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ Net Worth เป้าหมาย</h2>

        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เป้าหมาย Expected</div>
            <div id="nwt-res-expected" class="text-xl font-bold text-primary-700">-</div>
            <div class="text-xs text-gray-500 mt-1">อายุ × รายได้ ÷ 10</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ระดับ PAW (ยอดเยี่ยม)</div>
            <div id="nwt-res-paw" class="text-xl font-bold text-green-700">-</div>
            <div class="text-xs text-gray-500 mt-1">2× Expected</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ระดับ UAW (ต่ำกว่าเป้า)</div>
            <div id="nwt-res-uaw" class="text-xl font-bold text-red-600">-</div>
            <div class="text-xs text-gray-500 mt-1">0.5× Expected</div>
          </div>
        </div>

        <div id="nwt-status-section" class="hidden">
          <div id="nwt-status-card" class="rounded-lg p-4 mb-4">
            <div class="font-semibold text-lg mb-1" id="nwt-status-title">-</div>
            <div class="text-sm" id="nwt-status-desc">-</div>
            <div class="mt-2 text-sm">
              Net Worth ปัจจุบันของคุณ: <span id="nwt-res-current" class="font-bold">-</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณ Net Worth เป้าหมาย</h2>
      <p>
        สูตรนี้มาจากการวิจัยของ Thomas J. Stanley และ William D. Danko ในหนังสือ "The Millionaire Next Door" ปี 1996 ซึ่งศึกษาพฤติกรรมของเศรษฐีอเมริกัน และพบว่าผู้มีความมั่งคั่งที่แท้จริงมักสะสมทรัพย์สินตามสูตรนี้
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการคำนวณ</h3>
      <p>บุคคลอายุ 40 ปี รายได้ 600,000 บาท/ปี:</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>Expected Net Worth = 40 × 600,000 ÷ 10 = <strong>2,400,000 บาท</strong></li>
        <li>PAW (ยอดเยี่ยม): มากกว่า <strong>4,800,000 บาท</strong></li>
        <li>UAW (ต่ำกว่าเป้า): น้อยกว่า <strong>1,200,000 บาท</strong></li>
      </ul>
      <p class="mt-4 text-sm text-gray-500">
        หมายเหตุ: สูตรนี้เป็นแนวทางสำหรับชาวอเมริกัน การนำมาใช้กับบริบทไทยควรพิจารณาค่าครองชีพและโครงสร้างรายได้ที่แตกต่างกัน
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณ-net-worth-เป้าหมาย/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงแนวทางอ้างอิงเท่านั้น
      ไม่ถือเป็นคำแนะนำทางการเงิน สูตรอาจไม่เหมาะกับทุกบริบทชีวิต
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('nwt-form') as HTMLFormElement;
    const formError = document.getElementById('nwt-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const age = parseInt((document.getElementById('nwt-age') as HTMLInputElement).value) || 0;
      const income = parseNum((document.getElementById('nwt-income') as HTMLInputElement).value);
      const currentNW = parseNum((document.getElementById('nwt-current') as HTMLInputElement).value);

      if (age < 18 || age > 70 || income <= 0) {
        formError.classList.remove('hidden');
        return;
      }

      trackCalculatorStart('net-worth-target');

      const expected = age * income / 10;
      const paw = expected * 2;
      const uaw = expected * 0.5;

      (document.getElementById('nwt-res-expected') as HTMLElement).textContent = fmt(expected) + ' บาท';
      (document.getElementById('nwt-res-paw') as HTMLElement).textContent = fmt(paw) + ' บาท';
      (document.getElementById('nwt-res-uaw') as HTMLElement).textContent = fmt(uaw) + ' บาท';

      const statusSection = document.getElementById('nwt-status-section') as HTMLElement;
      const currentInput = (document.getElementById('nwt-current') as HTMLInputElement).value.replace(/,/g, '').trim();

      if (currentInput !== '' && currentNW >= 0) {
        const statusCard = document.getElementById('nwt-status-card') as HTMLElement;
        const statusTitle = document.getElementById('nwt-status-title') as HTMLElement;
        const statusDesc = document.getElementById('nwt-status-desc') as HTMLElement;
        const currentEl = document.getElementById('nwt-res-current') as HTMLElement;

        currentEl.textContent = fmt(currentNW) + ' บาท';

        if (currentNW >= paw) {
          statusCard.className = 'rounded-lg p-4 mb-4 bg-green-50 border border-green-200';
          statusTitle.textContent = 'ยอดเยี่ยม! ระดับ PAW (Prodigious Accumulator of Wealth)';
          statusTitle.className = 'font-semibold text-lg mb-1 text-green-700';
          statusDesc.textContent = 'Net Worth ของคุณมากกว่า 2 เท่าของเป้าหมาย แสดงว่าคุณสะสมความมั่งคั่งได้ยอดเยี่ยมมาก';
          statusDesc.className = 'text-sm text-green-600';
        } else if (currentNW >= expected) {
          statusCard.className = 'rounded-lg p-4 mb-4 bg-blue-50 border border-blue-200';
          statusTitle.textContent = 'ดีมาก! กำลังไปได้ดี (On Track)';
          statusTitle.className = 'font-semibold text-lg mb-1 text-blue-700';
          statusDesc.textContent = 'Net Worth ของคุณอยู่ในเกณฑ์ Expected หรือสูงกว่า กำลังสะสมความมั่งคั่งได้ตามเป้าหมาย';
          statusDesc.className = 'text-sm text-blue-600';
        } else if (currentNW >= uaw) {
          statusCard.className = 'rounded-lg p-4 mb-4 bg-yellow-50 border border-yellow-200';
          statusTitle.textContent = 'ต้องเร่งสะสม (Below Expected)';
          statusTitle.className = 'font-semibold text-lg mb-1 text-yellow-700';
          statusDesc.textContent = `Net Worth ของคุณต่ำกว่าเป้าหมาย ${fmt(expected - currentNW)} บาท ควรเพิ่มอัตราการออมและลงทุนให้มากขึ้น`;
          statusDesc.className = 'text-sm text-yellow-700';
        } else {
          statusCard.className = 'rounded-lg p-4 mb-4 bg-red-50 border border-red-200';
          statusTitle.textContent = 'ต้องปรับแผนการเงินด่วน (UAW)';
          statusTitle.className = 'font-semibold text-lg mb-1 text-red-700';
          statusDesc.textContent = `Net Worth ของคุณอยู่ในระดับ UAW ต่ำกว่าเป้าหมายมาก ${fmt(expected - currentNW)} บาท ควรวางแผนการออมและลงทุนอย่างจริงจัง`;
          statusDesc.className = 'text-sm text-red-600';
        }
        statusSection.classList.remove('hidden');
      } else {
        statusSection.classList.add('hidden');
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('net-worth-target');
      trackCalculatorUsed('net-worth-target');
    });
  </script>
</BaseLayout>
