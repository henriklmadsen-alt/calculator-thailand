---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณภาษีที่ดินและสิ่งปลูกสร้าง 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณภาษีที่ดินและสิ่งปลูกสร้าง 2569 ฟรี — ที่อยู่อาศัย เกษตร พาณิชย์ รู้ยอดภาษีที่ต้องจ่ายทันที ตามมูลค่าประเมินกรมธนารักษ์';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีที่ดิน/`;

const faqData = [
  {
    question: 'ภาษีที่ดินปี 2569 ใช้อัตราเดียวทุกทรัพย์สินไหม?',
    answer: 'ไม่ใช่ อัตราภาษีขึ้นกับประเภทการใช้ประโยชน์ เช่น เกษตร ที่อยู่อาศัย พาณิชย์ และที่ดินว่างเปล่า รวมถึงคิดแบบขั้นมูลค่าตามกรอบกฎหมาย',
  },
  {
    question: 'บ้านหลังหลักได้ยกเว้นเท่าไร?',
    answer: 'โดยทั่วไปกรณีเข้าเงื่อนไขบ้านหลังหลักจะมีวงเงินยกเว้นสูงกว่าทรัพย์สินประเภทอื่น เครื่องมือนี้ตั้งค่าเริ่มต้นที่ 50 ล้านบาทสำหรับกรณีบ้านหลังหลัก และปรับได้ตามข้อมูลจริงของคุณ',
  },
  {
    question: 'ผลคำนวณในเครื่องมือทำไมอาจไม่ตรงใบแจ้งจริง?',
    answer: 'ยอดจริงขึ้นกับข้อมูลทะเบียน สิทธิยกเว้นรายทรัพย์ ประเภทการใช้ประโยชน์ที่ท้องถิ่นจัดกลุ่ม และมาตรการลดภาษีเฉพาะปี จึงควรใช้ผลลัพธ์นี้เป็นการประมาณการก่อนยื่นจ่ายจริง',
  },
  {
    question: 'ที่ดินเกษตรกรรมเสียภาษีอัตราเท่าไร?',
    answer: 'ที่ดินเกษตรกรรมใช้อัตราขั้นบันไดต่ำสุด เริ่มต้นที่ 0.01% สำหรับมูลค่าประเมินไม่เกิน 75 ล้านบาท และสูงสุด 0.1% สำหรับส่วนที่เกิน 1,000 ล้านบาท โดยบุคคลธรรมดาที่เป็นเจ้าของและทำการเกษตรเองอาจได้รับยกเว้นวงเงินแรกตามประกาศกระทรวงการคลัง',
  },
  {
    question: 'กำหนดชำระภาษีที่ดินและสิ่งปลูกสร้างเมื่อไร?',
    answer: 'โดยปกติกำหนดชำระภายในเดือนเมษายนของทุกปี แต่ท้องถิ่นอาจขยายเวลาออกไปได้ หากไม่ชำระตามกำหนดจะมีเบี้ยปรับ 40% ของภาษีที่ค้าง บวกเงินเพิ่มอีก 1% ต่อเดือน ควรติดตามประกาศจากองค์กรปกครองส่วนท้องถิ่นในพื้นที่',
  },
,
  { question: 'ค่าโอนบ้านปี 2569 คิดอัตราเท่าไร?', answer: 'ค่าธรรมเนียมโอน 2% ของราคาประเมิน (ลดเหลือ 1% สำหรับที่อยู่อาศัยราคาไม่เกิน 3 ล้าน จนถึง 31 ธ.ค. 2568), ค่าจดจำนอง 1% ของวงเงิน (ลดเหลือ 0.01% สำหรับกู้ไม่เกิน 3 ล้าน)' },
  { question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ต่างกันอย่างไร?', answer: 'ภาษีธุรกิจเฉพาะ 3.3% (ถือครองน้อยกว่า 5 ปีหรือไม่ได้มีชื่อในทะเบียนบ้าน) | อากรแสตมป์ 0.5% (ถือครอง 5 ปีขึ้นไปและมีชื่อในทะเบียนบ้านครบ 1 ปี) เสียอย่างใดอย่างหนึ่ง' },
  { question: 'ราคาประเมินกรมที่ดินกับราคาตลาดต่างกันอย่างไร?', answer: 'ราคาประเมินคือราคาที่กรมที่ดินกำหนดเพื่อใช้คิดค่าธรรมเนียม อัปเดตทุก 4 ปี มักต่ำกว่าราคาตลาด 20-50% ภาษีและค่าธรรมเนียมใช้ราคาประเมินหรือราคาซื้อขาย แล้วแต่อย่างไหนสูงกว่า' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณภาษีที่ดินและสิ่งปลูกสร้าง',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "วิธีคำนวณภาษีที่ดิน (Property Tax) ปี 2569",
  "description": "ขั้นตอนการคำนวณภาษีที่ดิน โดยใช้มูลค่าประเมินอากร และอัตราภาษีตามประเภทของที่ดิน ตามพระราชบัญญัติภาษีที่ดินและสิ่งปลูกสร้าง พ.ศ. 2562",
  "step": [
    {"@type": "HowToStep", "name": "ตรวจสอบมูลค่าประเมินอากร (Assessed Value)", "text": "ดูเอกสารใบประเมินอากรจากสำนักที่ดิน บันทึกมูลค่าประเมิน (ไม่ใช่ราคาซื้อขาย) ตัวอย่าง: ที่ดินมูลค่าประเมิน 500,000 บาท"},
    {"@type": "HowToStep", "name": "ตรวจสอบประเภทที่ดิน (Land Classification)", "text": "ระบุประเภท: (1) ที่อยู่อาศัย, (2) เพาะปลูก, (3) พาณิชย์, (4) อุตสาหกรรม อัตราภาษีแตกต่างกันตามประเภท"},
    {"@type": "HowToStep", "name": "ตรวจสอบอัตราภาษีตามจังหวัด", "text": "อัตราภาษีที่ดินแตกต่างไปตามจังหวัดและประเภทที่ดิน ตัวอย่าง: ที่ดินอยู่อาศัยกรุงเทพมหานครอัตรา 0.02% ต่อปี"},
    {"@type": "HowToStep", "name": "คำนวณภาษีที่ดิน", "text": "ภาษีที่ดิน = มูลค่าประเมิน × อัตราภาษี ตัวอย่าง: 500,000 × 0.02% = 100 บาท/ปี"},
    {"@type": "HowToStep", "name": "ตรวจสอบการยกเว้นหรือลดหย่อน", "text": "ตรวจสอบสิทธิยกเว้นภาษี: ที่ดินอยู่อาศัยส่วนตัว (มูลค่าไม่เกิน 50 ล้านบาท), ที่ดินเกษตรกรรม, หรือโครงการของรัฐอาจได้รับยกเว้น"}
  ]
};

---

<BaseLayout noGenericHowTo={true} title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีที่ดิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณภาษีที่ดิน 2569 จากมูลค่าประเมินจริง</p>
      <p class="mt-1 text-sm text-slate-700">รองรับการคำนวณแบบขั้นมูลค่าตามประเภทการใช้ประโยชน์ พร้อมตัวเลือกสิทธิยกเว้นและมาตรการลดภาษี</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับวางงบก่อนรับใบแจ้งภาษีจากท้องถิ่น</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณภาษีที่ดิน 2569 (ที่อยู่อาศัย/พาณิชย์/ที่ดินว่างเปล่า)
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกมูลค่าประเมินทรัพย์สิน เลือกประเภทการใช้ประโยชน์ และกำหนดสิทธิยกเว้นที่ใช้ได้
      ระบบจะคำนวณภาษีแบบขั้นมูลค่าให้ทันที พร้อมแจกแจงช่วงอัตราที่ใช้คิดภาษีเป็นเงินบาท
    </p>

    <PublicTrustPanel
      lastUpdated="19 เม.ย. 2569"
      sources={[
        'พระราชบัญญัติภาษีที่ดินและสิ่งปลูกสร้าง พ.ศ. 2562',
        'พระราชกฤษฎีกากำหนดอัตราภาษีที่ดินและสิ่งปลูกสร้าง พ.ศ. 2564',
        'LTAX e-service: คำถามที่พบบ่อยเรื่องสิทธิยกเว้น',
      ]}
      assumptions={[
        'ผลลัพธ์เป็นการประมาณเพื่อวางแผนเบื้องต้น ไม่ใช่ใบประเมินทางราชการ',
        'ยอดจริงขึ้นกับการจำแนกประเภทการใช้ประโยชน์และประกาศลดภาษีของปีนั้น',
      ]}
      references={[
        {
          label: 'FPO: กฎหมายภาษีที่ดินและสิ่งปลูกสร้าง',
          href: 'https://www.fpo.go.th/main/The-law-in-charge-of-FPO/Law-of-Finance-and-Taxation/17122.aspx',
        },
        {
          label: 'พ.ร.ฎ. อัตราภาษีที่ดินและสิ่งปลูกสร้าง พ.ศ. 2564',
          href: 'https://www.fpo.go.th/main/getattachment/General-information-public-service/%E0%B8%9B%E0%B8%A3%E0%B8%B0%E0%B8%8A%E0%B8%B2%E0%B8%8A%E0%B8%99%E0%B8%84%E0%B8%A7%E0%B8%A3%E0%B8%A3%E0%B8%B9%E0%B9%89/%E0%B8%A0%E0%B8%B2%E0%B8%A9%E0%B8%B5%E0%B8%97%E0%B8%B5%E0%B9%88%E0%B8%94%E0%B8%B4%E0%B8%99%E0%B9%81%E0%B8%A5%E0%B8%B0%E0%B8%AA%E0%B8%B4%E0%B9%88%E0%B8%87%E0%B8%9B%E0%B8%A5%E0%B8%B9%E0%B8%81%E0%B8%AA%E0%B8%A3%E0%B9%89%E0%B8%B2%E0%B8%87/%E0%B9%80%E0%B8%AD%E0%B8%81%E0%B8%AA%E0%B8%B2%E0%B8%A3%E0%B9%81%E0%B8%99%E0%B8%9A-2-%E0%B8%9E-%E0%B8%A3-%E0%B8%8E-2564.PDF.aspx?lang=th-TH',
        },
        {
          label: 'LTAX e-service',
          href: 'https://ltaxsvt.dla.go.th/',
        },
      ]}
    />

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="land-tax-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="appraised-value" class="mb-1 block text-sm font-medium text-gray-700">มูลค่าประเมิน (บาท)</label>
            <input id="appraised-value" type="text" inputmode="decimal" placeholder="เช่น 8000000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>

          <div>
            <label for="usage" class="mb-1 block text-sm font-medium text-gray-700">ประเภทการใช้ประโยชน์</label>
            <select id="usage" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="residential_primary">ที่อยู่อาศัย (บ้านหลังหลัก)</option>
              <option value="residential_secondary">ที่อยู่อาศัย (ไม่ใช่บ้านหลังหลัก)</option>
              <option value="agriculture">เกษตรกรรม</option>
              <option value="commercial">พาณิชยกรรม/อุตสาหกรรม</option>
              <option value="vacant">ที่ดินว่างเปล่า</option>
            </select>
          </div>

          <div>
            <label for="exemption-value" class="mb-1 block text-sm font-medium text-gray-700">สิทธิยกเว้น (บาท)</label>
            <input id="exemption-value" type="text" inputmode="decimal" value="50000000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>

          <div>
            <label for="relief-percent" class="mb-1 block text-sm font-medium text-gray-700">มาตรการลดภาษี (%)</label>
            <input id="relief-percent" type="text" inputmode="decimal" value="0" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button
          type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          คำนวณภาษีที่ดิน
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณภาษีที่ดิน</h2>

        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ภาษีก่อนลดหย่อน</div>
            <div id="res-gross-tax" class="text-xl font-bold text-sky-700">-</div>
          </div>
          <div class="rounded-lg bg-indigo-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">มูลค่าลดภาษี</div>
            <div id="res-relief-amount" class="text-xl font-bold text-indigo-700">-</div>
          </div>
          <div class="rounded-lg bg-emerald-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ภาษีสุทธิที่ต้องชำระ</div>
            <div id="res-net-tax" class="text-xl font-bold text-emerald-700">-</div>
          </div>
        </div>

        <div class="mb-6 space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ประเภทการใช้ประโยชน์</span>
            <span id="res-usage-label" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">มูลค่าประเมิน</span>
            <span id="res-appraised" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">สิทธิยกเว้นที่ใช้</span>
            <span id="res-exemption" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ฐานภาษีหลังหักยกเว้น</span>
            <span id="res-taxable-base" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">อัตราภาษีที่แท้จริง</span>
            <span id="res-effective-rate" class="font-medium">-</span>
          </div>
        </div>

        <h3 class="mb-2 text-base font-semibold text-gray-900">รายละเอียดการคิดภาษีแบบขั้นมูลค่า</h3>
        <ul id="tier-breakdown" class="space-y-2 text-sm text-gray-700"></ul>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">วิธีคิดในหน้านี้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ฐานภาษี = มูลค่าประเมิน - สิทธิยกเว้นที่ใช้ได้</li>
        <li>ภาษีก่อนลดหย่อน = ผลรวมภาษีแต่ละช่วงมูลค่าตามอัตราของประเภททรัพย์สิน</li>
        <li>ภาษีสุทธิ = ภาษีก่อนลดหย่อน - มาตรการลดภาษี (%)</li>
      </ul>
      <p>ต้องการหลักกฎหมายและตัวอย่างละเอียด อ่านต่อที่บทความประกอบด้านล่าง</p>
    </section>

    <RelatedArticles currentHref="/คำนวณภาษีที่ดิน/" />
    <RelatedCalculators currentHref="/คำนวณภาษีที่ดิน/" />


    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณ</h2>
      <p><strong>ภาษีที่ดิน = มูลค่าที่ดิน × อัตราภาษี</strong></p>
      <p>อัตราภาษีขึ้นอยู่กับประเภทที่ดิน: ที่ดินไร่นา (เกษตรกรรม) 0.02% / ที่ดินสวน 0.04% / ที่ดินเปล่า (ไม่ได้ใช้ประโยชน์) 0.1% / ที่ดินบ้านอยู่อาศัย 0.02%</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">ตัวอย่างการคำนวณ</h3>
      <p><strong>ตัวอย่างที่ 1: ที่ดินบ้านอยู่อาศัย มูลค่า 1,000,000 บาท</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>มูลค่าที่ดิน</strong> = 1,000,000 บาท</li>
        <li><strong>อัตราภาษี</strong> = 0.02%</li>
        <li><strong>ภาษีที่ดิน</strong> = 1,000,000 × 0.02% = <strong>200 บาท/ปี</strong></li>
      </ul>

      <p class="mt-4"><strong>ตัวอย่างที่ 2: ที่ดินเปล่า (ไม่ได้ใช้ประโยชน์) มูลค่า 500,000 บาท</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>มูลค่าที่ดิน</strong> = 500,000 บาท</li>
        <li><strong>อัตราภาษี</strong> = 0.1%</li>
        <li><strong>ภาษีที่ดิน</strong> = 500,000 × 0.1% = <strong>500 บาท/ปี</strong></li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สรุป</h3>
      <p>ภาษีที่ดินเป็นภาษีประจำปีที่ต้องชำระให้กับกรมสรรพากร ผู้ที่เป็นเจ้าของที่ดินลงทะเบียนต้องรับผิดชอบ การไม่ชำระ ณ กำหนดอาจมีบทลงโทษเพิ่มเติม</p>
      <p class="text-sm text-gray-500 mt-2"><strong>อ้างอิง:</strong> <a href="https://www.rd.go.th" class="text-primary-600 hover:underline" target="_blank" rel="noopener">กรมสรรพากร: ภาษีที่ดิน</a> [อัปเดต 2569]</p>
    </section>
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> เครื่องมือนี้เป็นการคำนวณเพื่อวางแผนเบื้องต้นตามข้อมูลที่กรอก
      ยอดภาษีที่ต้องชำระจริงให้ยึดใบแจ้งจากหน่วยงานท้องถิ่นและประกาศที่มีผลใช้ในปีภาษีนั้น
    </div>
  </article>

  <script>
    import { calculateLandBuildingTax } from '../../lib/land-building-tax';

    const usageLabels = {
      agriculture: 'เกษตรกรรม',
      residential_primary: 'ที่อยู่อาศัย (บ้านหลังหลัก)',
      residential_secondary: 'ที่อยู่อาศัย (ไม่ใช่บ้านหลังหลัก)',
      commercial: 'พาณิชยกรรม/อุตสาหกรรม',
      vacant: 'ที่ดินว่างเปล่า',
    };

    const form = document.getElementById('land-tax-form');
    const formError = document.getElementById('form-error');
    const results = document.getElementById('results');
    const usageInput = document.getElementById('usage');
    const exemptionInput = document.getElementById('exemption-value');

    const show = (el) => el?.classList.remove('hidden');
    const hide = (el) => el?.classList.add('hidden');

    const parseNumber = (value) => {
      const normalized = String(value ?? '').replace(/,/g, '').trim();
      if (!normalized) return NaN;
      const parsed = Number(normalized);
      return Number.isFinite(parsed) ? parsed : NaN;
    };

    const formatMoney = (value) => `${new Intl.NumberFormat('th-TH', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(value)} บาท`;

    const formatPercent = (value) => `${new Intl.NumberFormat('th-TH', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(value)}%`;

    usageInput?.addEventListener('change', () => {
      if (!exemptionInput) return;
      exemptionInput.value = usageInput.value === 'residential_primary' ? '50000000' : '0';
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      hide(formError);

      const appraisedValue = parseNumber(document.getElementById('appraised-value')?.value);
      const usage = usageInput?.value;
      const exemptionValue = parseNumber(exemptionInput?.value);
      const reliefPercent = parseNumber(document.getElementById('relief-percent')?.value);

      if (!usage || !Number.isFinite(appraisedValue) || appraisedValue < 0 || !Number.isFinite(exemptionValue) || exemptionValue < 0 || !Number.isFinite(reliefPercent) || reliefPercent < 0) {
        show(formError);
        hide(results);
        return;
      }

      const result = calculateLandBuildingTax({
        appraisedValue,
        usage,
        exemptionValue,
        reliefPercent,
      });

      document.getElementById('res-gross-tax').textContent = formatMoney(result.grossTax);
      document.getElementById('res-relief-amount').textContent = formatMoney(result.reliefAmount);
      document.getElementById('res-net-tax').textContent = formatMoney(result.netTax);
      document.getElementById('res-usage-label').textContent = usageLabels[result.usage] || result.usage;
      document.getElementById('res-appraised').textContent = formatMoney(result.appraisedValue);
      document.getElementById('res-exemption').textContent = formatMoney(result.exemptionValue);
      document.getElementById('res-taxable-base').textContent = formatMoney(result.taxableBase);
      document.getElementById('res-effective-rate').textContent = formatPercent(result.effectiveRatePercent);

      const breakdown = document.getElementById('tier-breakdown');
      if (breakdown) {
        breakdown.innerHTML = '';
        if (result.breakdown.length === 0) {
          const li = document.createElement('li');
          li.textContent = 'ไม่มีภาษีที่ต้องชำระในช่วงมูลค่านี้';
          breakdown.appendChild(li);
        } else {
          result.breakdown.forEach((tier) => {
            const li = document.createElement('li');
            const from = new Intl.NumberFormat('th-TH', { maximumFractionDigits: 0 }).format(tier.fromValue);
            const to = tier.toValue === null
              ? 'ขึ้นไป'
              : new Intl.NumberFormat('th-TH', { maximumFractionDigits: 0 }).format(tier.toValue);
            li.textContent = `ช่วง ${from} - ${to} บาท: ${formatMoney(tier.taxableAmount)} x ${formatPercent(tier.ratePercent)} = ${formatMoney(tier.taxAmount)}`;
            breakdown.appendChild(li);
          });
        }
      }

      show(results);

      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('land_building_tax');
      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('land_building_tax', result.netTax);
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('land_building_tax');
    });
  </script>
</BaseLayout>
