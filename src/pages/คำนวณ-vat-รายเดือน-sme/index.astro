---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ VAT รายเดือน SME 2569 | ภาษีมูลค่าเพิ่มสำหรับธุรกิจ | Kamnuanlek';
const pageDescription = 'คำนวณ VAT รายเดือนสำหรับ SME 2569 ฟรี ยอด VAT ขาย (Output VAT) ลบ VAT ซื้อ (Input VAT) = VAT ที่ต้องนำส่ง หรือขอคืน ใช้งานฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-vat-รายเดือน-sme/`;

const faqData = [
  {
    question: 'SME ต้องจดทะเบียน VAT เมื่อไร?',
    answer: 'ธุรกิจที่มีรายได้จากการขายสินค้า/บริการเกิน 1.8 ล้านบาทต่อปี ต้องจดทะเบียน VAT ภายใน 30 วันนับจากวันที่รายได้เกินเกณฑ์',
  },
  {
    question: 'Output VAT และ Input VAT คืออะไร?',
    answer: 'Output VAT คือ VAT ที่เรียกเก็บจากลูกค้า (VAT ขาย) Input VAT คือ VAT ที่จ่ายให้ซัพพลายเออร์เมื่อซื้อสินค้า/บริการ (VAT ซื้อ) VAT ที่นำส่งสรรพากร = Output VAT - Input VAT',
  },
  {
    question: 'ต้องยื่น VAT เมื่อไร?',
    answer: 'ต้องยื่นแบบ ภ.พ.30 ทุกเดือน ภายในวันที่ 15 ของเดือนถัดไป (สำหรับการยื่นออนไลน์ขยายเป็น 23 ของเดือน) แม้ไม่มียอดขายก็ต้องยื่นแบบเปล่า',
  },
  {
    question: 'Input VAT มากกว่า Output VAT ทำไงได้บ้าง?',
    answer: 'หาก Input VAT > Output VAT มีสองทางเลือก: (1) ขอคืนเงิน VAT จากสรรพากร (2) เก็บไว้เป็น Credit VAT นำไปหักในเดือนถัดไปได้ ส่วนใหญ่ธุรกิจเลือกเก็บเป็น Credit เพื่อความสะดวก',
  },
  {
    question: 'ค่าปรับยื่น VAT ล่าช้าเป็นเท่าไร?',
    answer: 'ค่าปรับยื่นช้า 2% ของภาษีที่ต้องชำระต่อเดือน (ขั้นต่ำ 200 บาท) บวกเงินเพิ่ม 1.5% ต่อเดือนของภาษีที่ค้างชำระ',
  },
,
  { question: 'ธุรกิจขนาดไหนต้องจดทะเบียน VAT?', answer: 'ผู้ประกอบการที่มีรายได้จากการขายสินค้าหรือบริการเกิน 1,800,000 บาทต่อปี ต้องจดทะเบียนภาษีมูลค่าเพิ่มภายใน 30 วันนับแต่วันที่รายได้เกิน' },
  { question: 'VAT Input และ Output Tax คืออะไร?', answer: 'Output VAT: ภาษีที่เรียกเก็บจากลูกค้า | Input VAT: ภาษีที่จ่ายให้ซัพพลายเออร์ | ภาษีที่ต้องนำส่งกรมสรรพากร = Output VAT - Input VAT ถ้าติดลบได้รับคืนหรือนำไปเครดิตเดือนถัดไป' },
  { question: 'สินค้าและบริการอะไรได้รับการยกเว้น VAT?', answer: 'อาหารสด พืชผักผลไม้ที่ยังไม่แปรรูป, สัตว์ที่ยังมีชีวิต, ปุ๋ยและยาป้องกันแมลง, หนังสือพิมพ์/นิตยสาร, บริการสุขภาพ/การศึกษา, การขนส่งผู้โดยสารภายในประเทศ' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ VAT รายเดือน SME 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-vat-รายเดือน-sme">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">สำหรับผู้ประกอบการที่จดทะเบียน VAT</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">VAT 7% อัปเดตปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณ VAT รายเดือน สำหรับ SME ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณภาษีมูลค่าเพิ่มที่ต้องนำส่งสรรพากรในแต่ละเดือน
      Output VAT (VAT ขาย) ลบ Input VAT (VAT ซื้อ) = VAT ที่ต้องนำส่ง
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกยอด VAT ขายและ VAT ซื้อ</h2>

      <form id="vat-sme-form" class="space-y-6">
        <p id="vat-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <!-- Output VAT -->
        <div class="rounded-lg border border-blue-100 bg-blue-50 p-4">
          <h3 class="text-sm font-semibold text-blue-800 mb-3">Output VAT — VAT ที่เรียกเก็บจากลูกค้า</h3>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="sales-revenue" class="block text-sm font-medium text-gray-700 mb-1">
                ยอดขาย (ไม่รวม VAT) บาท
              </label>
              <input
                type="text"
                id="sales-revenue"
                inputmode="numeric"
                placeholder="เช่น 500,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
            <div>
              <label for="output-vat-manual" class="block text-sm font-medium text-gray-700 mb-1">
                หรือกรอก Output VAT โดยตรง (บาท)
              </label>
              <input
                type="text"
                id="output-vat-manual"
                inputmode="numeric"
                placeholder="เช่น 35,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
              <p class="mt-1 text-xs text-gray-500">ใส่ยอดขาย หรือ Output VAT อย่างใดอย่างหนึ่ง</p>
            </div>
          </div>
        </div>

        <!-- Input VAT -->
        <div class="rounded-lg border border-green-100 bg-green-50 p-4">
          <h3 class="text-sm font-semibold text-green-800 mb-3">Input VAT — VAT ที่จ่ายเมื่อซื้อสินค้า/บริการ</h3>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="purchase-cost" class="block text-sm font-medium text-gray-700 mb-1">
                ยอดซื้อ (ไม่รวม VAT) บาท
              </label>
              <input
                type="text"
                id="purchase-cost"
                inputmode="numeric"
                placeholder="เช่น 300,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
            <div>
              <label for="input-vat-manual" class="block text-sm font-medium text-gray-700 mb-1">
                หรือกรอก Input VAT โดยตรง (บาท)
              </label>
              <input
                type="text"
                id="input-vat-manual"
                inputmode="numeric"
                placeholder="เช่น 21,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
          </div>
        </div>

        <div>
          <label for="credit-bf" class="block text-sm font-medium text-gray-700 mb-1">
            VAT Credit ยกมาจากเดือนก่อน (บาท) <span class="text-gray-400 font-normal">— ถ้ามี</span>
          </label>
          <input
            type="text"
            id="credit-bf"
            inputmode="numeric"
            placeholder="เช่น 5,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ VAT รายเดือน</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Output VAT (ขาย)</div>
            <div id="result-output" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Input VAT (ซื้อ + Credit)</div>
            <div id="result-input" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div id="result-net-card" class="rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1" id="result-net-label">VAT ที่ต้องนำส่ง</div>
            <div id="result-net" class="text-xl font-bold">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">Output VAT</span>
            <span id="result-output-detail" class="font-medium text-blue-700">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">Input VAT</span>
            <span id="result-input-detail" class="font-medium text-green-700">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">Credit ยกมาจากเดือนก่อน</span>
            <span id="result-credit-detail" class="font-medium text-green-700">-</span>
          </div>
          <div class="flex justify-between py-1 border-t border-gray-300 font-semibold text-base">
            <span id="result-summary-label" class="text-gray-900">VAT ที่ต้องนำส่ง</span>
            <span id="result-summary-amount">-</span>
          </div>
        </div>
        <p id="result-deadline" class="mt-3 text-xs text-gray-500"></p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ภาษีมูลค่าเพิ่ม (VAT) สำหรับ SME</h2>
      <p>
        ผู้ประกอบการที่จดทะเบียน VAT ต้องยื่นแบบ ภ.พ.30 ทุกเดือน ไม่ว่าจะมีรายได้หรือไม่
        สูตรคำนวณ: <strong>VAT ที่ต้องนำส่ง = Output VAT − Input VAT − Credit VAT ยกมา</strong>
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">กำหนดยื่นและชำระ VAT</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ยื่นแบบกระดาษ: ภายในวันที่ <strong>15</strong> ของเดือนถัดไป</li>
        <li>ยื่นออนไลน์ทาง e-Filing: ภายในวันที่ <strong>23</strong> ของเดือนถัดไป</li>
        <li>ค่าปรับยื่นช้า: 2% ของภาษีต่อเดือน (ขั้นต่ำ 200 บาท)</li>
        <li>เงินเพิ่มกรณีชำระช้า: 1.5% ต่อเดือนของภาษีค้างชำระ</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.rd.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมสรรพากร (rd.go.th)</a> — ระบบภาษีมูลค่าเพิ่ม (VAT) 7%</li>
        <li><a href="https://www.rd.go.th/publish/27415.0.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">คู่มือ VAT สำหรับผู้ประกอบการ — กรมสรรพากร</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณ-vat-รายเดือน-sme/" />
    <RelatedCalculators currentHref="/คำนวณ-vat-รายเดือน-sme/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางภาษี กรุณาปรึกษาผู้เชี่ยวชาญหรือนักบัญชีสำหรับการยื่น VAT จริง
    </div>
  </article>

  <script>
    function parseNumber(val: string): number {
      return Math.max(0, parseFloat(val.replace(/,/g, '')) || 0);
    }

    function formatThai(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(num);
    }

    const VAT_RATE = 0.07;
    const form = document.getElementById('vat-sme-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLElement;
    const errorDiv = document.getElementById('vat-error') as HTMLElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');

      const salesRevenue = parseNumber((document.getElementById('sales-revenue') as HTMLInputElement).value);
      const outputVatManual = parseNumber((document.getElementById('output-vat-manual') as HTMLInputElement).value);
      const purchaseCost = parseNumber((document.getElementById('purchase-cost') as HTMLInputElement).value);
      const inputVatManual = parseNumber((document.getElementById('input-vat-manual') as HTMLInputElement).value);
      const creditBf = parseNumber((document.getElementById('credit-bf') as HTMLInputElement).value);

      // Calculate output VAT: prefer manual entry, else compute from revenue
      const outputVat = outputVatManual > 0 ? outputVatManual : salesRevenue * VAT_RATE;
      // Calculate input VAT: prefer manual entry, else compute from cost
      const inputVat = inputVatManual > 0 ? inputVatManual : purchaseCost * VAT_RATE;
      const totalInput = inputVat + creditBf;
      const netVat = outputVat - totalInput;

      (document.getElementById('result-output') as HTMLElement).textContent = `${formatThai(outputVat)} บาท`;
      (document.getElementById('result-input') as HTMLElement).textContent = `${formatThai(totalInput)} บาท`;
      (document.getElementById('result-output-detail') as HTMLElement).textContent = `${formatThai(outputVat)} บาท`;
      (document.getElementById('result-input-detail') as HTMLElement).textContent = `${formatThai(inputVat)} บาท`;
      (document.getElementById('result-credit-detail') as HTMLElement).textContent = `${formatThai(creditBf)} บาท`;

      const netCard = document.getElementById('result-net-card') as HTMLElement;
      const netEl = document.getElementById('result-net') as HTMLElement;
      const netLabel = document.getElementById('result-net-label') as HTMLElement;
      const summaryLabel = document.getElementById('result-summary-label') as HTMLElement;
      const summaryAmount = document.getElementById('result-summary-amount') as HTMLElement;

      if (netVat >= 0) {
        netCard.className = 'bg-red-50 rounded-lg p-4 text-center';
        netEl.className = 'text-xl font-bold text-red-700';
        netLabel.textContent = 'VAT ที่ต้องนำส่ง';
        summaryLabel.textContent = 'VAT ที่ต้องนำส่งสรรพากร';
        netEl.textContent = `${formatThai(netVat)} บาท`;
        summaryAmount.textContent = `${formatThai(netVat)} บาท`;
        summaryAmount.className = 'font-semibold text-red-700';
      } else {
        netCard.className = 'bg-green-50 rounded-lg p-4 text-center';
        netEl.className = 'text-xl font-bold text-green-700';
        netLabel.textContent = 'VAT Credit ยกไปเดือนหน้า';
        summaryLabel.textContent = 'VAT Credit (ยกไปหักเดือนถัดไป)';
        netEl.textContent = `${formatThai(Math.abs(netVat))} บาท`;
        summaryAmount.textContent = `${formatThai(Math.abs(netVat))} บาท`;
        summaryAmount.className = 'font-semibold text-green-700';
      }

      const today = new Date();
      const nextMonth = new Date(today.getFullYear(), today.getMonth() + 1, 23);
      const deadlineStr = nextMonth.toLocaleDateString('th-TH', { day: 'numeric', month: 'long', year: 'numeric' });
      (document.getElementById('result-deadline') as HTMLElement).textContent =
        `กำหนดยื่น ภ.พ.30 ออนไลน์ภายใน ${deadlineStr}`;

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('vat_sme_monthly');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('vat_sme_monthly');
    });

    form.addEventListener('input', () => {
      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('vat_sme_monthly');
    }, { once: true });
  </script>
</BaseLayout>
