---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณทุนประกันชีวิตที่เหมาะสม 2569 | ความต้องการจริง | Kamnuanlek';
const pageDescription = 'คำนวณวงเงินคุ้มครองชีวิตที่เหมาะสม จากรายได้ ภาระหนี้สิน ค่าใช้จ่ายครอบครัว และผู้พึ่งพิง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณทุนประกันชีวิตที่เหมาะสม/`;

const faqData = [
  {
    question: 'ทุนประกันชีวิตที่เหมาะสมควรเป็นเท่าไหร่?',
    answer: 'กฎทั่วไปคือทุนประกัน 10-15 เท่าของรายได้ต่อปี แต่วิธีที่แม่นยำกว่าคือคำนวณจากภาระจริง: หนี้สินทั้งหมด + ค่าใช้จ่ายครอบครัว × ระยะเวลาคุ้มครอง - เงินออมและทรัพย์สินสภาพคล่อง',
  },
  {
    question: 'ทุนประกันชีวิตขั้นต่ำที่ควรมีคือเท่าไหร่?',
    answer: 'ขั้นต่ำที่แนะนำคือคุ้มครองหนี้สินทั้งหมด (บ้าน รถ บัตรเครดิต) บวกรายได้ 1-2 ปีสำหรับให้ครอบครัวปรับตัว หากมีบุตรหรือผู้พึ่งพิง ควรเพิ่มทุนประกันให้ครอบคลุมค่าใช้จ่ายจนบุตรอายุ 22 ปี',
  },
  {
    question: 'ควรทบทวนทุนประกันเมื่อไหร่?',
    answer: 'ควรทบทวนทุนประกันชีวิตทุก 3-5 ปี หรือเมื่อมีเหตุการณ์สำคัญในชีวิต เช่น แต่งงาน มีบุตร ซื้อบ้าน เปลี่ยนงาน หรือรายได้เพิ่มขึ้นมาก เพื่อให้ความคุ้มครองสอดคล้องกับภาระและความต้องการจริง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณทุนประกันชีวิตที่เหมาะสม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณทุนประกันชีวิตที่เหมาะสม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณทุนประกันชีวิตที่เหมาะสม 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณวงเงินคุ้มครองชีวิตที่แท้จริงที่คุณต้องการ จากภาระหนี้สิน ค่าใช้จ่ายครอบครัว และเงินออม
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="li-form" class="space-y-5">
        <p id="li-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="li-income" class="block text-sm font-medium text-gray-700 mb-1">รายได้ต่อปี (บาท)</label>
            <input type="text" id="li-income" inputmode="numeric" placeholder="เช่น 600,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="li-income-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="li-years" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลาคุ้มครองที่ต้องการ (ปี)</label>
            <select id="li-years" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              {[5,10,15,20,25,30].map((y) => (
                <option value={y} selected={y === 20}>{y} ปี</option>
              ))}
            </select>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="li-debt" class="block text-sm font-medium text-gray-700 mb-1">หนี้สินทั้งหมด (บาท)</label>
            <input type="text" id="li-debt" inputmode="numeric" placeholder="เช่น 2,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
          <div>
            <label for="li-expenses" class="block text-sm font-medium text-gray-700 mb-1">ค่าใช้จ่ายครอบครัว/เดือน (บาท)</label>
            <input type="text" id="li-expenses" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="li-savings" class="block text-sm font-medium text-gray-700 mb-1">เงินออมและทรัพย์สิน (บาท)</label>
            <input type="text" id="li-savings" inputmode="numeric" placeholder="เช่น 500,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
          <div>
            <label for="li-current" class="block text-sm font-medium text-gray-700 mb-1">ทุนประกันที่มีอยู่ (บาท)</label>
            <input type="text" id="li-current" inputmode="numeric" placeholder="เช่น 1,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <button type="submit" id="li-submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div class="space-y-2 mb-4">
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-600">ทดแทนรายได้</span>
            <span id="res-income-rep" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-600">ค่าใช้จ่ายครอบครัว</span>
            <span id="res-family-exp" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-600">หนี้สิน</span>
            <span id="res-debt" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-600">หัก: เงินออม</span>
            <span id="res-savings" class="font-medium text-green-600">-</span>
          </div>
          <div class="flex justify-between py-3 bg-blue-50 px-3 rounded-lg">
            <span class="font-bold">ทุนประกันที่แนะนำ</span>
            <span id="res-recommended" class="text-xl font-bold text-blue-700">-</span>
          </div>
          <div id="gap-section" class="flex justify-between py-3 bg-orange-50 px-3 rounded-lg hidden">
            <span class="font-bold text-orange-800">ช่องว่างความคุ้มครอง</span>
            <span id="res-gap" class="text-xl font-bold text-orange-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณทุนประกันที่เหมาะสม</h2>
      <p>ทุนประกันที่แนะนำ = (รายได้ต่อปี × ระยะเวลา) + (ค่าใช้จ่ายต่อเดือน × 12 × ระยะเวลา) + หนี้สิน - เงินออม</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณทุนประกันชีวิตที่เหมาะสม/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงแนวทางประมาณการ ควรปรึกษาที่ปรึกษาประกันภัยสำหรับคำแนะนำที่เหมาะสมกับสถานการณ์ของคุณ
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n) + ' บาท'; }

    const form = document.getElementById('li-form') as HTMLFormElement;
    const formError = document.getElementById('li-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    function setErr(id: string, msg: string) { const el = document.getElementById(id); if (el) { el.textContent = msg; el.classList.remove('hidden'); } }
    function clearErr(id: string) { const el = document.getElementById(id); if (el) { el.textContent = ''; el.classList.add('hidden'); } }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      clearErr('li-income-error');

      const income = parseNum((document.getElementById('li-income') as HTMLInputElement).value);
      const years = parseInt((document.getElementById('li-years') as HTMLSelectElement).value);
      const debt = parseNum((document.getElementById('li-debt') as HTMLInputElement).value);
      const monthlyExp = parseNum((document.getElementById('li-expenses') as HTMLInputElement).value);
      const savings = parseNum((document.getElementById('li-savings') as HTMLInputElement).value);
      const currentCoverage = parseNum((document.getElementById('li-current') as HTMLInputElement).value);

      if (income <= 0) { setErr('li-income-error', 'กรุณากรอกรายได้'); formError.classList.remove('hidden'); return; }

      trackCalculatorStart('term-life-coverage-need');

      const incomeReplacement = income * years;
      const familyExpenses = monthlyExp * 12 * years;
      const recommended = Math.max(debt, incomeReplacement + familyExpenses + debt - savings);
      const gap = Math.max(0, recommended - currentCoverage);

      (document.getElementById('res-income-rep') as HTMLElement).textContent = fmt(incomeReplacement);
      (document.getElementById('res-family-exp') as HTMLElement).textContent = fmt(familyExpenses);
      (document.getElementById('res-debt') as HTMLElement).textContent = fmt(debt);
      (document.getElementById('res-savings') as HTMLElement).textContent = '- ' + fmt(savings);
      (document.getElementById('res-recommended') as HTMLElement).textContent = fmt(recommended);

      const gapSection = document.getElementById('gap-section') as HTMLElement;
      if (currentCoverage > 0 && gap > 0) {
        (document.getElementById('res-gap') as HTMLElement).textContent = fmt(gap);
        gapSection.classList.remove('hidden');
      } else {
        gapSection.classList.add('hidden');
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('term-life-coverage-need');
      trackCalculatorUsed('term-life-coverage-need');
    });
  </script>
</BaseLayout>
