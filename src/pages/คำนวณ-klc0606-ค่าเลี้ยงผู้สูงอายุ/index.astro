---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าเลี้ยงผู้สูงอายุ | Kamnuanlek';
const pageDescription = 'คำนวณค่าดูแลผู้สูงอายุ ค่ารักษา ค่าอาหาร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0606-ค่าเลี้ยงผู้สูงอายุ/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเลี้ยงผู้สูงอายุ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเลี้ยงผู้สูงอายุ</h1>
    <div class="mb-4 inline-block rounded-lg border border-orange-200 bg-orange-50 px-3 py-2"><p class="text-xs font-semibold text-orange-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าดูแลผู้สูงอายุ รวมค่าอาหาร ยา สาธารณูปโภค รายปี</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="num_elderly" class="block text-sm font-medium text-gray-700 mb-1">จำนวนผู้สูงอายุ (คน)</label><input type="number" id="num_elderly" min="1" max="5" placeholder="เช่น 1" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="food_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าอาหารต่อเดือน (บาท/คน)</label><input type="text" id="food_cost" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="medicine_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าเภสัชศาสตร์/ยาต่อเดือน (บาท)</label><input type="text" id="medicine_cost" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="utilities" class="block text-sm font-medium text-gray-700 mb-1">ค่าสาธารณูปโภคต่อเดือน (บาท)</label><input type="text" id="utilities" inputmode="decimal" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="care_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าดูแลระบาย/พยาบาล (บาท/เดือน)</label><input type="text" id="care_cost" inputmode="decimal" placeholder="เช่น 1500" value="1500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-orange-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าต่อเดือน</p>
            <p id="monthly" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าต่อปี</p>
            <p id="yearly" class="font-bold">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่าเลี้ยงผู้สูงอายุต่อเดือนเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">ค่าเลี้ยงผู้สูงอายุโดยทั่วไป 3,000-6,000 บาท/เดือน ขึ้นอยู่กับสภาพสุขภาพและสิ่งอำนวยความสะดวก</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ได้ลดหย่อนภาษีได้หรือไม่?</h3>
            <p class="text-gray-600 text-sm">ใช่ ผู้สูงอายุจดทะเบียนได้รับลดหย่อน 20,000 บาท สามารถนำค่าเลี้ยงหักได้บางส่วน</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">มีเงินช่วยเหลือผู้สูงอายุจากรัฐบาลหรือไม่?</h3>
            <p class="text-gray-600 text-sm">ใช่ เบี้ยความเป็นคนชราของประเทศไทย 500 บาท/เดือนสำหรับผู้สูงอายุ 60 ปีขึ้นไป</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const numElderly = parseInt((document.getElementById('num_elderly') as HTMLInputElement).value) || 1;
      const foodCost = parseFloat((document.getElementById('food_cost') as HTMLInputElement).value) || 0;
      const medicineCost = parseFloat((document.getElementById('medicine_cost') as HTMLInputElement).value) || 0;
      const utilities = parseFloat((document.getElementById('utilities') as HTMLInputElement).value) || 0;
      const careCost = parseFloat((document.getElementById('care_cost') as HTMLInputElement).value) || 0;

      const monthlyPerPerson = (foodCost + medicineCost + utilities + careCost);
      const monthlyTotal = monthlyPerPerson * numElderly;
      const yearlyTotal = monthlyTotal * 12;

      (document.getElementById('monthly') as HTMLElement).textContent = monthlyTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('yearly') as HTMLElement).textContent = yearlyTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('elderly-care');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
