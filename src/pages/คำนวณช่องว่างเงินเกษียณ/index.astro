---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณช่องว่างเงินเกษียณ 2569 | เงินออมพอไหม ขาดอีกเท่าไร | Kamnuanlek';
const pageDescription = 'คำนวณช่องว่างเงินเกษียณ เปรียบเทียบเงินที่จะสะสมได้กับเงินที่ต้องการ ณ วันเกษียณ คำนวณเงินออมรายเดือนเพิ่มเติมเพื่อปิดช่องว่าง อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณช่องว่างเงินเกษียณ/`;

const faqData = [
  {
    question: 'ช่องว่างเงินเกษียณ (Retirement Gap) คืออะไร?',
    answer: 'ช่องว่างเงินเกษียณคือส่วนต่างระหว่างเงินที่คาดว่าจะสะสมได้ ณ วันเกษียณ กับเงินที่ต้องการจริงเพื่อให้ใช้ชีวิตหลังเกษียณได้อย่างสบาย หากเงินที่สะสมได้น้อยกว่าเป้าหมาย ถือว่ามีช่องว่างและต้องออมเพิ่ม',
  },
  {
    question: 'หากมีช่องว่างเงินเกษียณ ต้องทำอย่างไร?',
    answer: 'มีหลายวิธีปิดช่องว่าง ได้แก่ 1) เพิ่มเงินออมรายเดือน 2) เพิ่มผลตอบแทนการลงทุนโดยเปลี่ยนสินทรัพย์ 3) เลื่อนอายุเกษียณออกไป 4) ลดค่าใช้จ่ายหลังเกษียณ เครื่องคำนวณนี้จะบอกว่าต้องออมเพิ่มเดือนละเท่าไรเพื่อปิดช่องว่าง',
  },
  {
    question: 'ผลตอบแทนควรใช้ค่าเท่าไรในการคำนวณ?',
    answer: 'ขึ้นอยู่กับกลยุทธ์การลงทุน หากลงทุนในกองทุนรวมหุ้น ผลตอบแทนเฉลี่ยระยะยาว 6-8% ต่อปี หากลงทุนแบบผสม (หุ้น+ตราสารหนี้) ประมาณ 4-6% ต่อปี สำหรับเงินฝากและตราสารหนี้ล้วน ประมาณ 2-3% ต่อปี',
  },
  {
    question: 'เงินออมปัจจุบันควรนับรวมอะไรบ้าง?',
    answer: 'นับรวมสินทรัพย์การลงทุนทั้งหมดที่ตั้งใจใช้หลังเกษียณ ได้แก่ กองทุน RMF/LTF/SSF เงินใน กบข./กองทุนสำรองเลี้ยงชีพ เงินฝากระยะยาว และพอร์ตหุ้น ไม่นับรวมทรัพย์สินที่อยู่อาศัยหลักและเงินฉุกเฉิน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณช่องว่างเงินเกษียณ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณช่องว่างเงินเกษียณ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณช่องว่างเงินเกษียณ 2569 — เงินออมพอไหม ขาดอีกเท่าไร
    </h1>

    <p class="text-gray-600 mb-6">
      เปรียบเทียบเงินที่คาดว่าจะสะสมได้ ณ วันเกษียณ กับเงินเป้าหมายที่ต้องการ พร้อมคำนวณเงินออมรายเดือนเพิ่มเติมที่จำเป็นเพื่อปิดช่องว่าง
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="retire-gap-form" class="space-y-5">
        <p id="retire-gap-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="gap-current-age" class="block text-sm font-medium text-gray-700 mb-1">
              อายุปัจจุบัน (ปี)
            </label>
            <input
              type="number"
              id="gap-current-age"
              min="18"
              max="79"
              placeholder="เช่น 35"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="gap-current-age-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="gap-retire-age" class="block text-sm font-medium text-gray-700 mb-1">
              อายุเกษียณ (ปี)
            </label>
            <input
              type="number"
              id="gap-retire-age"
              min="41"
              max="80"
              value="60"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="gap-current-savings" class="block text-sm font-medium text-gray-700 mb-1">
              เงินออมปัจจุบัน (บาท)
            </label>
            <input
              type="text"
              id="gap-current-savings"
              inputmode="numeric"
              placeholder="เช่น 500,000"
              value="0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="gap-monthly-savings" class="block text-sm font-medium text-gray-700 mb-1">
              เงินออมรายเดือน (บาท)
            </label>
            <input
              type="text"
              id="gap-monthly-savings"
              inputmode="numeric"
              placeholder="เช่น 10,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="gap-monthly-savings-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="gap-return-rate" class="block text-sm font-medium text-gray-700 mb-1">
              ผลตอบแทนการลงทุน (% ต่อปี)
            </label>
            <input
              type="text"
              id="gap-return-rate"
              inputmode="decimal"
              placeholder="เช่น 7"
              value="7"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="gap-target" class="block text-sm font-medium text-gray-700 mb-1">
              เงินเกษียณที่ต้องการ (บาท)
            </label>
            <input
              type="text"
              id="gap-target"
              inputmode="numeric"
              placeholder="เช่น 10,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="gap-target-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button
          type="submit"
          id="retire-gap-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณช่องว่างเงินเกษียณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินที่จะมีตอนเกษียณ</div>
            <div id="res-gap-projected" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เป้าหมายเงินเกษียณ</div>
            <div id="res-gap-target-display" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div id="res-gap-card" class="rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ช่องว่าง (Surplus/Deficit)</div>
            <div id="res-gap-amount" class="text-xl font-bold">-</div>
          </div>
          <div id="res-extra-savings-card" class="bg-yellow-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ออมเพิ่มรายเดือน</div>
            <div id="res-extra-monthly" class="text-xl font-bold text-yellow-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ระยะเวลาออม</span>
            <span id="res-gap-years" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ผลตอบแทนการลงทุน</span>
            <span id="res-gap-return" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณช่องว่างเงินเกษียณ</h2>
      <p>
        ช่องว่างเงินเกษียณช่วยให้คุณรู้ว่ากำลังอยู่ในเส้นทางที่ถูกต้องหรือไม่ การคำนวณแบ่งเป็น 2 ขั้นตอน
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ขั้นที่ 1: คาดการณ์เงินที่จะมี</h3>
      <p>
        ใช้สูตรมูลค่าอนาคต (Future Value) ของเงินออมรายเดือน บวกกับการเติบโตของเงินออมปัจจุบัน<br/>
        FV = เงินปัจจุบัน × (1+r)^n + เงินออมรายเดือน × [(1+r)^n - 1] / r
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ขั้นที่ 2: คำนวณเงินออมเพิ่มเติม</h3>
      <p>
        หากมีช่องว่าง ใช้สูตร PMT เพื่อหาเงินออมรายเดือนเพิ่มเติมที่ต้องการ<br/>
        เงินออมเพิ่ม = ช่องว่าง × r / [(1+r)^n - 1]
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณช่องว่างเงินเกษียณ/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางการเงิน ควรปรึกษาผู้เชี่ยวชาญก่อนตัดสินใจ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('retire-gap-form') as HTMLFormElement;
    const formError = document.getElementById('retire-gap-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const currentAge = parseInt((document.getElementById('gap-current-age') as HTMLInputElement).value) || 0;
      const retireAge = parseInt((document.getElementById('gap-retire-age') as HTMLInputElement).value) || 60;
      const currentSavings = parseNum((document.getElementById('gap-current-savings') as HTMLInputElement).value);
      const monthlySavings = parseNum((document.getElementById('gap-monthly-savings') as HTMLInputElement).value);
      const returnRate = parseNum((document.getElementById('gap-return-rate') as HTMLInputElement).value) || 7;
      const targetAmount = parseNum((document.getElementById('gap-target') as HTMLInputElement).value);

      if (!currentAge || currentAge <= 0) {
        formError.classList.remove('hidden');
        (document.getElementById('gap-current-age') as HTMLInputElement).focus();
        return;
      }
      if (targetAmount <= 0) {
        formError.classList.remove('hidden');
        (document.getElementById('gap-target') as HTMLInputElement).focus();
        return;
      }

      trackCalculatorStart('retire-gap');

      const yearsToRetire = Math.max(0, retireAge - currentAge);
      const monthsToRetire = yearsToRetire * 12;
      const monthlyRate = returnRate / 100 / 12;

      // FV of current savings + monthly contributions
      let projected: number;
      if (Math.abs(monthlyRate) < 0.0000001) {
        projected = currentSavings + monthlySavings * monthsToRetire;
      } else {
        projected = currentSavings * Math.pow(1 + monthlyRate, monthsToRetire)
          + monthlySavings * (Math.pow(1 + monthlyRate, monthsToRetire) - 1) / monthlyRate;
      }

      const gap = targetAmount - projected;
      const isSurplus = gap <= 0;

      // Additional monthly needed to close gap
      let extraMonthly = 0;
      if (!isSurplus && monthsToRetire > 0) {
        if (Math.abs(monthlyRate) < 0.0000001) {
          extraMonthly = gap / monthsToRetire;
        } else {
          extraMonthly = gap * monthlyRate / (Math.pow(1 + monthlyRate, monthsToRetire) - 1);
        }
      }

      (document.getElementById('res-gap-projected') as HTMLElement).textContent = fmt(projected) + ' บาท';
      (document.getElementById('res-gap-target-display') as HTMLElement).textContent = fmt(targetAmount) + ' บาท';

      const gapCard = document.getElementById('res-gap-card') as HTMLElement;
      const gapAmount = document.getElementById('res-gap-amount') as HTMLElement;
      if (isSurplus) {
        gapCard.className = 'bg-green-50 rounded-lg p-4 text-center';
        gapAmount.className = 'text-xl font-bold text-green-700';
        gapAmount.textContent = '+' + fmt(Math.abs(gap)) + ' บาท (เกิน)';
      } else {
        gapCard.className = 'bg-red-50 rounded-lg p-4 text-center';
        gapAmount.className = 'text-xl font-bold text-red-700';
        gapAmount.textContent = '-' + fmt(gap) + ' บาท (ขาด)';
      }

      const extraCard = document.getElementById('res-extra-savings-card') as HTMLElement;
      const extraMonthlyEl = document.getElementById('res-extra-monthly') as HTMLElement;
      if (isSurplus) {
        extraCard.className = 'bg-green-50 rounded-lg p-4 text-center';
        extraMonthlyEl.className = 'text-xl font-bold text-green-700';
        extraMonthlyEl.textContent = 'ไม่จำเป็น';
      } else {
        extraCard.className = 'bg-red-50 rounded-lg p-4 text-center';
        extraMonthlyEl.className = 'text-xl font-bold text-red-700';
        extraMonthlyEl.textContent = fmt(extraMonthly) + ' บาท';
      }

      (document.getElementById('res-gap-years') as HTMLElement).textContent = yearsToRetire + ' ปี';
      (document.getElementById('res-gap-return') as HTMLElement).textContent = returnRate.toFixed(2) + '% ต่อปี';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('retire-gap');
      trackCalculatorUsed('retire-gap');
    });
  </script>
</BaseLayout>
