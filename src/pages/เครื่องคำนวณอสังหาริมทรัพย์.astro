---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เครื่องคำนวณอสังหาริมทรัพย์ — ค่าโอน จดจำนอง ภาษีที่ดิน ปี 2569 | Kamnuanlek"
  description="เครื่องคำนวณอสังหาริมทรัพย์ฟรีครบชุด คำนวณค่าธรรมเนียมโอนบ้าน ค่าจดจำนอง ภาษีที่ดิน ผลตอบแทนเช่า และค่าคอนโด อัปเดตอัตราปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เครื่องคำนวณอสังหาริมทรัพย์ — ค่าโอน จดจำนอง ภาษีที่ดิน ปี 2569", "item": "https://www.kamnuanlek.com/เครื่องคำนวณอสังหาริมทรัพย์/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณอสังหาริมทรัพย์</h1>
    <p class="text-xl text-gray-600 mb-12">
      Essential tools for property buyers, sellers, landlords, and investors in Thailand. Calculate all costs associated with Thai real estate.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณค่าโอนบ้าน/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🏠</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Property Transfer Fee Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate all fees when buying or selling property: transfer fee (2%), specific business tax (3.3%), stamp duty, and more.</p>
        <span class="text-primary-600 font-medium">Calculate Fees →</span>
      </a>

      <a href="/คำนวณผ่อนบ้าน/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🏦</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Mortgage Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate monthly mortgage payments, total interest, and amortization schedule for your home loan.</p>
        <span class="text-primary-600 font-medium">Calculate Payment →</span>
      </a>

      <a href="/คำนวณภาษีที่ดินและสิ่งปลูกสร้าง/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">📋</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Land & Building Tax Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate annual land and building tax based on property value and type (residential, commercial, agricultural).</p>
        <span class="text-primary-600 font-medium">Calculate Tax →</span>
      </a>

      <a href="/คำนวณค่าเช่า/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🔑</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Rental Yield Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate rental yield percentage to evaluate investment property returns.</p>
        <span class="text-primary-600 font-medium">Calculate Yield →</span>
      </a>

      <a href="/คำนวณค่าส่วนกลาง/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🏢</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Condo Common Area Fee Calculator</h3>
        <p class="text-gray-600 mb-3">Estimate monthly condo maintenance fees based on unit size and building rate (THB/sqm).</p>
        <span class="text-primary-600 font-medium">Calculate Fee →</span>
      </a>

      <a href="/คำนวณผลตอบแทนอสังหา/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">📈</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Property ROI Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate total return on property investment including appreciation and rental income.</p>
        <span class="text-primary-600 font-medium">Calculate ROI →</span>
      </a>
    </div>

    <div class="p-6 bg-rose-50 border border-rose-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Key Property Transfer Costs</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-rose-200">
              <th class="text-left py-2 pr-4 font-semibold text-gray-900">Fee Type</th>
              <th class="text-left py-2 pr-4 font-semibold text-gray-900">Rate</th>
              <th class="text-left py-2 font-semibold text-gray-900">Notes</th>
            </tr>
          </thead>
          <tbody class="space-y-2">
            <tr class="border-b border-rose-100">
              <td class="py-2 pr-4 text-gray-900">Transfer Fee</td>
              <td class="py-2 pr-4 text-gray-700">2% of assessed value</td>
              <td class="py-2 text-gray-600">Split 50/50 buyer-seller</td>
            </tr>
            <tr class="border-b border-rose-100">
              <td class="py-2 pr-4 text-gray-900">Specific Business Tax</td>
              <td class="py-2 pr-4 text-gray-700">3.3% of selling price</td>
              <td class="py-2 text-gray-600">If owned less than 5 years</td>
            </tr>
            <tr class="border-b border-rose-100">
              <td class="py-2 pr-4 text-gray-900">Stamp Duty</td>
              <td class="py-2 pr-4 text-gray-700">0.5% of selling price</td>
              <td class="py-2 text-gray-600">Only if SBT not applicable</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-gray-900">Withholding Tax</td>
              <td class="py-2 pr-4 text-gray-700">Graduated (1-5%)</td>
              <td class="py-2 text-gray-600">Based on assessed value × years</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">More Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/เปรียบเทียบสินเชื่อ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏦 Loan Comparison Guide</span>
          <p class="text-gray-600 text-sm mt-2">Compare home loans and financing options</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Calculators Hub</span>
          <p class="text-gray-600 text-sm mt-2">All financial tools in one place</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
