---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าเช่ามอเตอร์ไซค์ | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าเช่ามอเตอร์ไซค์ตามจำนวนวันและประกัน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าเช่ามอเตอร์ไซค์/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเช่ามอเตอร์ไซค์">
  <article>
    <h1 class="text-2xl font-bold mb-4">คำนวณค่าเช่ามอเตอร์ไซค์</h1>
    <div class="bg-white p-6 rounded-lg border">
      <div class="grid gap-4 mb-4">
        <input type="number" id="rate" placeholder="ค่าเช่ารายวัน" class="p-2 border rounded" />
        <input type="number" id="days" placeholder="จำนวนวัน" value="1" class="p-2 border rounded" />
        <label><input type="checkbox" id="insurance" /> รวมประกัน</label>
      </div>
      <button onclick="calculate()" class="bg-primary-600 text-white px-4 py-2 rounded">คำนวณ</button>
      <div id="result" class="hidden mt-4 p-4 bg-blue-50 rounded">
        <div class="flex justify-between mb-2"><span>รวม</span><span id="total" class="font-bold text-primary-600">-</span></div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  import { calculateMotorcycleRental } from '../../lib/motorcycle-rental-calculator';
  function calculate() {
    const rate = parseInt(document.getElementById('rate').value);
    const days = parseInt(document.getElementById('days').value);
    const insurance = document.getElementById('insurance').checked;
    const result = calculateMotorcycleRental({ dailyRate: rate, days, includingInsurance: insurance });
    document.getElementById('total').textContent = result.total.toLocaleString('th-TH') + ' บาท';
    document.getElementById('result').classList.remove('hidden');
  }
</script>
