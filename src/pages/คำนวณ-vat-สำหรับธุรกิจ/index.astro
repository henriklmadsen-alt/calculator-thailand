---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณ VAT สำหรับธุรกิจ 2569 | Output VAT ลบ Input VAT | Kamnuanlek';
const pageDescription = 'คำนวณภาษี VAT ที่ต้องนำส่ง Output VAT - Input VAT รายเดือน ตามกฎหมายประเทศไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-vat-สำหรับธุรกิจ/`;

const faqData = [
  {
    question: 'VAT ที่ต้องนำส่งคำนวณอย่างไร?',
    answer: 'VAT = (ยอดขาย ÷ 1.07) × 0.07 - VAT ที่เสียไปสำหรับการซื้อ/ค่าใช้จ่าย โดยนำส่งรายเดือนกับสรรพากร',
  },
  {
    question: 'Input VAT คืออะไร?',
    answer: 'VAT ที่ค้างไว้สำหรับการซื้อวัสดุ บริการ ค่าใช้จ่ายการดำเนินงาน ที่มีใบกำกับภาษี สามารถหักออกจาก Output VAT',
  },
  {
    question: 'บริษัททั้งหมดต้องนำส่ง VAT หรือไม่?',
    answer: 'ธุรกิจที่ลงทะเบียน VAT จะต้องนำส่ง บริษัทเล็กไม่ลงทะเบียนตามเกณฑ์ DBD (รายได้น้อยกว่า 1.8 ล้านบาท/ปี)',
  },
  {
    question: 'ถ้า Input VAT มากกว่า Output VAT ทำไง?',
    answer: 'จะได้เครดิต VAT ที่สามารถนำไปหักในเดือนถัดไป หรือขอคืนหากมีการส่งออกสินค้า',
  },
,
  { question: 'ธุรกิจขนาดไหนต้องจดทะเบียน VAT?', answer: 'ผู้ประกอบการที่มีรายได้จากการขายสินค้าหรือบริการเกิน 1,800,000 บาทต่อปี ต้องจดทะเบียนภาษีมูลค่าเพิ่มภายใน 30 วันนับแต่วันที่รายได้เกิน' },
  { question: 'VAT Input และ Output Tax คืออะไร?', answer: 'Output VAT: ภาษีที่เรียกเก็บจากลูกค้า | Input VAT: ภาษีที่จ่ายให้ซัพพลายเออร์ | ภาษีที่ต้องนำส่งกรมสรรพากร = Output VAT - Input VAT ถ้าติดลบได้รับคืนหรือนำไปเครดิตเดือนถัดไป' },
  { question: 'สินค้าและบริการอะไรได้รับการยกเว้น VAT?', answer: 'อาหารสด พืชผักผลไม้ที่ยังไม่แปรรูป, สัตว์ที่ยังมีชีวิต, ปุ๋ยและยาป้องกันแมลง, หนังสือพิมพ์/นิตยสาร, บริการสุขภาพ/การศึกษา, การขนส่งผู้โดยสารภายในประเทศ' },
  { question: 'VAT Zero Rate ต่างจาก VAT Exempt อย่างไร?', answer: 'Zero Rate (0%): เสีย VAT แต่อัตรา 0% เช่น ส่งออกสินค้า — ยังขอคืน Input VAT ได้ | Exempt (ยกเว้น): ไม่ต้องเสีย VAT แต่ขอคืน Input VAT ไม่ได้ สำคัญมากสำหรับการวางแผนภาษี' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ VAT สำหรับธุรกิจ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ VAT สำหรับธุรกิจ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณ VAT สำหรับธุรกิจ
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-purple-200 bg-purple-50 px-3 py-2">
      <p class="text-xs font-semibold text-purple-800">[ตามกฎหมาย VAT ปี 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณภาษี VAT ที่ต้องนำส่งรายเดือน (Output VAT - Input VAT) ตามกฎหมายประเทศไทย
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="revenue" class="block text-sm font-medium text-gray-700 mb-1">
            ยอดขาย (รวม VAT)
          </label>
          <input
            type="text"
            id="revenue"
            inputmode="decimal"
            placeholder="เช่น 500000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
        <div>
          <label for="inputVat" class="block text-sm font-medium text-gray-700 mb-1">
            VAT ที่เสียไปแล้ว
          </label>
          <input
            type="text"
            id="inputVat"
            inputmode="decimal"
            placeholder="เช่น 25000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors"
      >
        คำนวณ VAT
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6 p-4 bg-purple-50 rounded-lg border border-purple-200">
        <h3 class="font-semibold text-gray-900 mb-3">ผลการคำนวณ</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span>ยอดขาย (รวม VAT)</span>
            <span id="result-revenue" class="font-medium">-</span>
          </div>
          <div class="flex justify-between">
            <span>Output VAT (7%)</span>
            <span id="result-output-vat" class="font-medium">-</span>
          </div>
          <div class="flex justify-between">
            <span>Input VAT (ค่าใช้จ่าย)</span>
            <span id="result-input-vat" class="font-medium">-</span>
          </div>
          <div class="border-t border-purple-300 my-2"></div>
          <div class="flex justify-between text-base font-bold">
            <span>VAT ที่ต้องนำส่ง</span>
            <span id="result-liability" class="text-primary-600">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา]
    </div>

    <!-- Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2>VAT ในธุรกิจไทยคืออะไร?</h2>
      <p>VAT (Value Added Tax) หรือภาษีมูลค่าเพิ่มคือภาษีที่เก็บในแต่ละขั้นของการผลิต/จำหน่าย ธุรกิจต้องนำส่ง VAT ที่เก็บจากลูกค้า (Output VAT) ลบด้วย VAT ที่เสียไปในการซื้อสินค้า (Input VAT)</p>

      <h3>ขั้นตอนการคำนวณ</h3>
      <ol>
        <li>หารายได้ทั้งสิ้น ÷ 1.07 เพื่อแยก VAT ออก</li>
        <li>นำรายได้นั้น × 0.07 = Output VAT</li>
        <li>นำ Output VAT - Input VAT (VAT ที่ค่าใช้จ่าย)</li>
        <li>ผลลัพธ์ = VAT ที่ต้องนำส่ง</li>
      </ol>

      <h3>เงื่อนไขการหัก Input VAT</h3>
      <ul>
        <li>ต้องมีใบกำกับภาษี/ใบเสร็จ</li>
        <li>ที่ดำเนินการเรียบร้อย (ให้อากรแสตมป์ครบ)</li>
        <li>ใช้ในการดำเนินกิจการของธุรกิจ</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((item) => (
          <div class="border border-gray-200 rounded-lg p-4 hover:border-gray-300">
            <h3 class="font-semibold text-gray-900 mb-2">{item.question}</h3>
            <p class="text-gray-600 text-sm">{item.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Trust Panel -->
    <section class="bg-gray-50 rounded-lg p-4 sm:p-6 border border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📌 แหล่งอ้างอิง</h2>
      <ul class="text-sm text-gray-700 space-y-1">
        <li>• Excise Department — VAT Regulations B.E. 2560</li>
        <li>• Value Added Tax Act B.E. 2545</li>
        <li>• กรมสรรพากร — แนวทาง VAT 2569</li>
      </ul>
    </section>
  </article>
</BaseLayout>

<script>
  import { calculateBusinessVAT } from '../../lib/business-vat-calculator';

  const btnCalculate = document.getElementById('btn-calculate');
  const revenueInput = document.getElementById('revenue');
  const inputVatInput = document.getElementById('inputVat');
  const resultDiv = document.getElementById('result');

  function formatCurrency(value: number): string {
    return new Intl.NumberFormat('th-TH', {
      style: 'currency',
      currency: 'THB',
      minimumFractionDigits: 0,
    }).format(value);
  }

  function handleCalculate() {
    const revenue = parseFloat(revenueInput.value.replace(/,/g, ''));
    const inputVat = parseFloat(inputVatInput.value.replace(/,/g, ''));

    if (!revenue || revenue <= 0) {
      alert('โปรดระบุยอดขายที่ถูกต้อง');
      return;
    }

    const result = calculateBusinessVAT({
      salaryRevenue: revenue,
      inputVATTotal: inputVat || 0,
      deductibleRate: 100,
    });

    document.getElementById('result-revenue').textContent = formatCurrency(result.salaryRevenue);
    document.getElementById('result-output-vat').textContent = formatCurrency(result.outputVAT);
    document.getElementById('result-input-vat').textContent = formatCurrency(result.inputVAT);
    document.getElementById('result-liability').textContent = formatCurrency(result.vatLiability);

    resultDiv.classList.remove('hidden');
  }

  btnCalculate.addEventListener('click', handleCalculate);
  revenueInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleCalculate();
  });
</script>
