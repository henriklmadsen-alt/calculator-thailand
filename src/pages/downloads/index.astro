---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'ดาวน์โหลด — เครื่องมือฟรี & เทมเพลต';
const pageDescription = 'ดาวน์โหลด PDF, Excel, และเทมเพลตฟรีสำหรับการวางแผนการเงิน ภาษี, ที่อยู่อาศัย, และการเงินส่วนบุคคล';
const canonical = `${siteUrl}/downloads/`;
const authorDate = '2026-05-01';

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDescription,
  image: {
    '@type': 'ImageObject',
    url: `${siteUrl}/og-image.jpg`,
    width: 1200,
    height: 630,
  },
  datePublished: authorDate,
  author: {
    '@type': 'Organization',
    name: 'Kamnuanlek',
  },
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} />

  <article class="prose prose-gray max-w-none">

    <h1>ดาวน์โหลด — เครื่องมือฟรี & เทมเพลต</h1>

    <p>คนไทยท่านหนึ่งต่อคนหนึ่งมีปัญหาเดียวกัน: การวางแผนการเงินต้องใช้เอกสารมากมาย, การตรวจสอบจำนวน, และการติดตามแบบอักษรมากมาย บนเพจนี้ เราจึงรวบรวมเครื่องมือและเทมเพลตฟรีเพื่อทำให้การเงินของคุณง่ายขึ้น</p>

    <h2>ประเภท — ดาวน์โหลด</h2>

    <h3>📋 ดาวน์โหลด Excel — เครื่องมือคำนวณ</h3>

    <p>ใช้ได้ทันที — ไม่ต้องการการเชื่อมต่ออินเทอร์เนต, ไม่มีโฆษณา</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-4">
      <div class="border p-4 rounded-lg">
        <h4>💰 Income Tax Calculator 2569</h4>
        <p>คำนวณภาษีเงินได้ประจำปี รวมลดหย่อน และใช้ได้ทันทีแล้ว</p>
        <p><em>มาเร็ว ๆ</em></p>
      </div>
      <div class="border p-4 rounded-lg">
        <h4>🏠 Mortgage Amortization Schedule</h4>
        <p>ตารางค่างวดเต็ม สำหรับสินเชื่อบ้าน พร้อมการคำนวณเงินลดหย่อน</p>
        <p><em>มาเร็ว ๆ</em></p>
      </div>
      <div class="border p-4 rounded-lg">
        <h4>💳 Debt Payoff Calculator</h4>
        <p>เปรียบเทียบกลยุทธ์การชำระหนี้ และเห็นได้ว่าเมื่อไหร่ปลอดหนี้</p>
        <p><em>มาเร็ว ๆ</em></p>
      </div>
      <div class="border p-4 rounded-lg">
        <h4>📊 Household Budget Planner</h4>
        <p>งบประมาณบ้านรายเดือน เพื่อติดตามค่าใช้จ่ายอย่างละเอียด</p>
        <a href="/downloads/household-budget-template-thailand-2569.txt" download="household-budget-template-2569.txt">ดาวน์โหลด ↓</a>
      </div>
    </div>

    <h3>📄 ดาวน์โหลด PDF — คู่มือและเช็คลิสต์</h3>

    <p>พิมพ์และใช้ได้ — ตรวจเช็คแล้วและรูปแบบใหม่</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-4">
      <div class="border p-4 rounded-lg">
        <h4>✅ Tax Deduction Checklist 2569</h4>
        <p>รายการเช็ครวมของลดหย่อนทั้งหมด และเอกสารที่ต้อง</p>
        <a href="/downloads/tax-deduction-checklist-2569.txt" download="tax-deduction-checklist-2569.txt">ดาวน์โหลด ↓</a>
      </div>
      <div class="border p-4 rounded-lg">
        <h4>🏡 Hidden Home Costs Checklist</h4>
        <p>รายการค่าใช้จ่ายที่มักลืมเมื่อซื้อบ้าน</p>
        <a href="/downloads/property-hidden-costs-checklist-2569.txt" download="property-hidden-costs-checklist-2569.txt">ดาวน์โหลด ↓</a>
      </div>
      <div class="border p-4 rounded-lg">
        <h4>💼 Payslip Verification Guide</h4>
        <p>วิธีตรวจเช็คใบแจ้งเงินเดือนให้ถูกต้อง</p>
        <p><em>มาเร็ว ๆ</em></p>
      </div>
      <div class="border p-4 rounded-lg">
        <h4>🎓 Salary Negotiation Guide</h4>
        <p>วิธีเจรจาเงินเดือนตามบทบาท และอุตสาหกรรม</p>
        <a href="/downloads/salary-negotiation-guide-thailand.txt" download="salary-negotiation-guide-thailand.txt">ดาวน์โหลด ↓</a>
      </div>
    </div>

    <h3>📚 ดาวน์โหลด — คู่มือ & เวิร์กบุ๊ก</h3>

    <p>ศึกษาเพิ่มเติม — แนะนำสำหรับการวางแผนระยะยาว</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-4">
      <div class="border p-4 rounded-lg">
        <h4>🏦 Complete Mortgage Guide</h4>
        <p>คู่มือฉบับสมบูรณ์สำหรับสินเชื่อบ้านและการซื้อที่อยู่อาศัย</p>
        <a href="/guides/mortgage-complete-guide/">อ่านออนไลน์ →</a>
      </div>
      <div class="border p-4 rounded-lg">
        <h4>💰 Tax Deductions Complete Guide</h4>
        <p>คู่มือฉบับสมบูรณ์สำหรับลดหย่อนภาษีเงินได้</p>
        <a href="/guides/tax-deductions-complete-guide/">อ่านออนไลน์ →</a>
      </div>
      <div class="border p-4 rounded-lg">
        <h4>🏠 Buy vs. Rent Complete Comparison</h4>
        <p>เปรียบเทียบเต็มระหว่างการซื้อและเช่าบ้าน</p>
        <a href="/comparisons/buy-vs-rent-complete/">อ่านออนไลน์ →</a>
      </div>
      <div class="border p-4 rounded-lg">
        <h4>📊 Retirement Planning Workbook</h4>
        <p>วางแผนเกษียณอายุเพื่อให้ได้เงินพอ</p>
        <p><em>มาเร็ว ๆ</em></p>
      </div>
    </div>

    <h2>ข้อมูลส่วนเพิ่มเติม</h2>

    <h3>ทำไมต้องดาวน์โหลด?</h3>

    <ul>
      <li>✅ <strong>ฟรี:</strong> ไม่มีค่าใช้จ่าย ไม่มีการแจ้งอีเมล</li>
      <li>✅ <strong>ออฟไลน์:</strong> ไม่ต้องเชื่อมต่ออินเทอร์เนต</li>
      <li>✅ <strong>พิมพ์ได้:</strong> ใช้เป็นเอกสารกระดาษได้ทันที</li>
      <li>✅ <strong>ปรับแต่งได้:</strong> Excel และ PDF สามารถแก้ไขได้</li>
      <li>✅ <strong>อัปเดต:</strong> เราจะปรับปรุงไฟล์เมื่อมีการเปลี่ยนแปลงกฎหมาย</li>
    </ul>

    <h3>วิธีดาวน์โหลด</h3>

    <ol>
      <li>คลิกลิงก์ "ดาวน์โหลด" ในเอกสารหรือที่นี่</li>
      <li>ไฟล์จะบันทึกลงในโฟลเดอร์ "ดาวน์โหลด" ของคุณ</li>
      <li>เปิดไฟล์ใน Excel (สำหรับ .xlsx) หรือ Adobe Reader (สำหรับ PDF)</li>
      <li>แก้ไขและใช้เท่าที่ต้องการ</li>
    </ol>

    <h3>เป็นเจ้าของข้อมูลของคุณ</h3>

    <p>ดาวน์โหลดไฟล์จะถูกบันทึกไว้ที่เครื่องของคุณเท่านั้น เราไม่เก็บข้อมูลใด ๆ และไม่มีการแสดงออกนอกเหนือจากการดาวน์โหลด</p>

    <h2>เสนอแนะ</h2>

    <p>มีเครื่องมือหรือเทมเพลตที่อยากดาวน์โหลด ขออนุมัติให้เราทราบผ่าน <a href="https://www.facebook.com/kamnuanlek">แฟซบุ๊ก</a> หรือ <a href="mailto:support@kamnuanlek.com">อีเมล</a></p>

  </article>
</BaseLayout>