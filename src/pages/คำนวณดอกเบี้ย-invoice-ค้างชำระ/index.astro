---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณดอกเบี้ย Invoice ค้างชำระ ปี 2569 — Late Invoice Interest | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณดอกเบี้ยค้างชำระสำหรับ Invoice ที่เกินกำหนด ป้อนยอด Invoice อัตราดอกเบี้ยและจำนวนวันค้างชำระ ทราบดอกเบี้ยและยอดรวมทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณดอกเบี้ย-invoice-ค้างชำระ/`;

const faqData = [
  {
    question: 'ดอกเบี้ย Invoice ค้างชำระคิดอัตราเท่าไหร่?',
    answer: 'กฎหมายแพ่งและพาณิชย์ไทยกำหนดอัตราดอกเบี้ยผิดนัดที่ 7.5% ต่อปี (เดิม) ปัจจุบันอาจปรับเป็น 5% + อัตราอ้างอิง หรือตามที่ระบุในสัญญา แต่สูงสุดไม่เกินที่กฎหมายกำหนด',
  },
  {
    question: 'สามารถคิดดอกเบี้ยค้างชำระกับลูกค้าได้ไหม?',
    answer: 'สามารถคิดได้หากระบุในสัญญาหรือใบ Invoice ล่วงหน้า ต้องแจ้งให้ชัดเจนว่ามีดอกเบี้ยค้างชำระกี่ % ต่อปีหรือต่อเดือน และเริ่มคิดตั้งแต่เมื่อไหร่',
  },
  {
    question: 'ดอกเบี้ยค้างชำระคิดแบบง่ายหรือทบต้น?',
    answer: 'โดยทั่วไปคิดแบบดอกเบี้ยง่าย (Simple Interest) ไม่ทบต้น ตามหลักกฎหมายแพ่งและพาณิชย์ไทย ยกเว้นตกลงกันไว้เป็นอย่างอื่น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณดอกเบี้ย Invoice ค้างชำระ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณดอกเบี้ย-invoice-ค้างชำระ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-red-100 bg-red-50 p-4">
      <p class="text-sm font-semibold text-red-700">คำนวณดอกเบี้ย Invoice ค้างชำระ</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: ดอกเบี้ย = ยอด × (อัตรา%/ปี) × (วันค้าง ÷ 365)</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณดอกเบี้ย Invoice ค้างชำระ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนยอด Invoice อัตราดอกเบี้ย และจำนวนวันค้างชำระ เพื่อดูดอกเบี้ยและยอดรวมที่ต้องชำระ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="li-form" class="space-y-5">
        <p id="li-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="li-principal" class="mb-1 block text-sm font-medium text-gray-700">ยอด Invoice (บาท)</label>
            <input type="text" id="li-principal" inputmode="numeric" placeholder="เช่น 50,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="li-principal-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="li-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราดอกเบี้ยผิดนัด (%/ปี)</label>
            <input type="text" id="li-rate" inputmode="decimal" placeholder="เช่น 7.5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="li-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
            <p class="mt-1 text-xs text-gray-500">ทั่วไป 7.5% หรือตามสัญญา</p>
          </div>
        </div>

        <div>
          <label for="li-days" class="mb-1 block text-sm font-medium text-gray-700">จำนวนวันค้างชำระ (วัน)</label>
          <input type="text" id="li-days" inputmode="numeric" placeholder="เช่น 45"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          <p id="li-days-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณดอกเบี้ยค้างชำระ
        </button>
      </form>
    </div>

    <div id="li-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ดอกเบี้ยค้างชำระ</div>
            <div id="res-li-interest" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดรวมที่ต้องชำระ</div>
            <div id="res-li-total" class="text-xl font-bold text-orange-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ดอกเบี้ยต่อวัน</div>
            <div id="res-li-daily" class="text-xl font-bold text-blue-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ดอกเบี้ย = ยอด Invoice × (อัตรา% ÷ 100) × (วันค้าง ÷ 365)</li>
        <li>ยอดรวม = ยอด Invoice + ดอกเบี้ย</li>
        <li>ดอกเบี้ยต่อวัน = ยอด × (อัตรา% ÷ 100) ÷ 365</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณวันครบกำหนด-invoice/">คำนวณวันครบกำหนดชำระ Invoice</a></li>
        <li><a href="/คำนวณปฏิทินชำระรายเดือน/">คำนวณปฏิทินชำระรายเดือน</a></li>
        <li><a href="/คำนวณต้นทุน-chargeback/">คำนวณต้นทุน Chargeback</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#li-results" />
    <RelatedArticles currentHref="/คำนวณดอกเบี้ย-invoice-ค้างชำระ/" />
    <RelatedCalculators currentHref="/คำนวณดอกเบี้ย-invoice-ค้างชำระ/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> การคำนวณนี้เป็นการประมาณการ อัตราดอกเบี้ยที่ใช้จริงต้องเป็นไปตามที่ระบุในสัญญาและกฎหมายที่บังคับใช้
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('li-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('li-error').classList.add('hidden');
      ['li-principal-error','li-rate-error','li-days-error'].forEach(id => setErr(id, ''));

      const principal = parseNum(document.getElementById('li-principal').value);
      const rate = parseNum(document.getElementById('li-rate').value);
      const days = parseNum(document.getElementById('li-days').value);

      let hasError = false;
      if (!Number.isFinite(principal) || principal <= 0) { setErr('li-principal-error', 'กรอกยอด Invoice มากกว่า 0'); hasError = true; }
      if (!Number.isFinite(rate) || rate <= 0) { setErr('li-rate-error', 'กรอกอัตราดอกเบี้ยมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(days) || days <= 0) { setErr('li-days-error', 'กรอกจำนวนวันค้างชำระมากกว่า 0'); hasError = true; }
      if (hasError) { document.getElementById('li-error').classList.remove('hidden'); document.getElementById('li-results').classList.add('hidden'); return; }

      const dailyRate = rate / 100 / 365;
      const interest = principal * dailyRate * days;
      const total = principal + interest;

      setText('res-li-interest', fmt(interest));
      setText('res-li-total', fmt(total));
      setText('res-li-daily', fmt(principal * dailyRate));

      document.getElementById('li-results').classList.remove('hidden');
      document.getElementById('li-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
