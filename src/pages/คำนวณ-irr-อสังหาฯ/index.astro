---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ IRR อสังหาฯ 2569 | Internal Rate of Return | อัตราผลตอบแทนภายใน | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณ IRR (Internal Rate of Return) สำหรับการลงทุนอสังหาฯ วิเคราะห์ผลตอบแทนจริงจากเงินลงทุนเบื้องต้น ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-irr-อสังหาฯ/`;

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ IRR อสังหาฯ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ IRR">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณ IRR อสังหาฯ ปี 2569</h1>
    <p class="text-gray-600 mb-6">คำนวณ IRR (อัตราผลตอบแทนภายใน) เพื่อวิเคราะห์ความคุ้มค่าของการลงทุนอสังหาฯระยะยาว</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="irr-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="initial-investment" class="block text-sm font-medium text-gray-700 mb-1">เงินลงทุนเบื้องต้น (บาท)</label>
            <input id="initial-investment" type="text" inputmode="numeric" placeholder="เช่น 2,000,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="annual-cashflow" class="block text-sm font-medium text-gray-700 mb-1">Cash Flow ประจำปี (บาท)</label>
            <input id="annual-cashflow" type="text" inputmode="numeric" placeholder="เช่น 150,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="holding-years" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลาถือครอง (ปี)</label>
            <input id="holding-years" type="text" inputmode="numeric" placeholder="เช่น 10" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" value="10" />
          </div>
          <div>
            <label for="exit-value" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าขายออก (บาท)</label>
            <input id="exit-value" type="text" inputmode="numeric" placeholder="เช่น 3,000,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณ IRR
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="rounded-lg bg-primary-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">IRR (อัตราผลตอบแทนภายใน)</div>
          <div id="res-irr" class="text-2xl font-bold text-primary-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">เงินลงทุนเบื้องต้น</span>
            <span id="res-initial-investment" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">Cash Flow ต่อปี</span>
            <span id="res-annual-cashflow" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ระยะเวลาถือครอง</span>
            <span id="res-holding-years" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">มูลค่าขายออก</span>
            <span id="res-exit-value" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">IRR (ผลตอบแทนรายปี)</span>
            <span id="res-calc-irr" class="font-bold text-lg text-primary-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <RelatedCalculators currentHref="/คำนวณ-irr-อสังหาฯ/" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  function findIRR(initialInvestment, annualCashflow, years, exitValue) {
    // Newton-Raphson method to find IRR
    let rate = 0.1; // Start with 10%
    const maxIterations = 100;
    const tolerance = 0.0001;

    for (let i = 0; i < maxIterations; i++) {
      // NPV calculation
      let npv = -initialInvestment;
      let dnpv = 0;

      for (let year = 1; year <= years; year++) {
        const pv = annualCashflow / Math.pow(1 + rate, year);
        const dpv = -year * annualCashflow / Math.pow(1 + rate, year + 1);
        npv += pv;
        dnpv += dpv;
      }

      const finalValue = exitValue / Math.pow(1 + rate, years);
      const dfinalValue = -years * exitValue / Math.pow(1 + rate, years + 1);
      npv += finalValue;
      dnpv += dfinalValue;

      if (Math.abs(npv) < tolerance) {
        return rate * 100;
      }

      if (Math.abs(dnpv) < 0.0001) {
        rate += 0.001;
      } else {
        rate = rate - npv / dnpv;
      }

      if (rate < -0.99) rate = -0.99;
      if (rate > 5) rate = 5;
    }

    return rate * 100;
  }

  const form = document.querySelector('#irr-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const initialInvestment = parseNumber(document.querySelector('#initial-investment')?.value || '');
    const annualCashflow = parseNumber(document.querySelector('#annual-cashflow')?.value || '');
    const holdingYears = parseNumber(document.querySelector('#holding-years')?.value || '');
    const exitValue = parseNumber(document.querySelector('#exit-value')?.value || '');

    if (!(Number.isFinite(initialInvestment) && initialInvestment > 0 && Number.isFinite(annualCashflow) && annualCashflow > 0 && Number.isFinite(holdingYears) && holdingYears > 0 && Number.isFinite(exitValue) && exitValue > 0)) {
      results?.classList.add('hidden');
      return;
    }

    const irr = findIRR(initialInvestment, annualCashflow, holdingYears, exitValue);

    document.querySelector('#res-irr').textContent = irr.toFixed(2) + '%';
    document.querySelector('#res-initial-investment').textContent = formatCurrency(initialInvestment);
    document.querySelector('#res-annual-cashflow').textContent = formatCurrency(annualCashflow);
    document.querySelector('#res-holding-years').textContent = `${holdingYears.toFixed(0)} ปี`;
    document.querySelector('#res-exit-value').textContent = formatCurrency(exitValue);
    document.querySelector('#res-calc-irr').textContent = irr.toFixed(2) + '%';

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
