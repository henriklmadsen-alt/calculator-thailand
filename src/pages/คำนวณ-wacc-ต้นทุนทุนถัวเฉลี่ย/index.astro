---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ WACC ต้นทุนทุนถัวเฉลี่ย ฟรี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณ WACC (Weighted Average Cost of Capital) ต้นทุนเงินทุนถัวเฉลี่ยของบริษัท สัดส่วนหนี้สิน-ทุน ต้นทุนหนี้-ทุน ภาษีนิติบุคคล ฟรีทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-wacc-ต้นทุนทุนถัวเฉลี่ย/`;

const faqData = [
  {
    question: 'WACC คืออะไร และสำคัญอย่างไร?',
    answer: 'WACC (Weighted Average Cost of Capital) หรือต้นทุนเงินทุนถัวเฉลี่ย คืออัตราผลตอบแทนขั้นต่ำที่บริษัทต้องทำได้เพื่อสร้างมูลค่าให้ผู้ถือหุ้นและเจ้าหนี้ ใช้เป็นอัตราคิดลดใน NPV และเป็น hurdle rate ในการประเมินโครงการลงทุน',
  },
  {
    question: 'ต้นทุนทุน (Cost of Equity) คำนวณอย่างไร?',
    answer: 'ต้นทุนทุนมักคำนวณด้วยสูตร CAPM: Re = Rf + β × (Rm − Rf) โดย Rf = อัตราดอกเบี้ยไร้ความเสี่ยง (เช่น พันธบัตรรัฐบาลไทย ~2.5%), β = ค่าเบต้าหุ้น, (Rm−Rf) = Market Risk Premium (ไทย ~5-7%) หรืออาจใช้อัตราผลตอบแทนที่คาดหวังของผู้ถือหุ้นโดยตรง',
  },
  {
    question: 'WACC ของบริษัทไทยทั่วไปอยู่ที่เท่าไร?',
    answer: 'WACC ของบริษัทจดทะเบียน SET ในไทยโดยทั่วไปอยู่ที่ 8-12% ต่อปี ขึ้นอยู่กับอุตสาหกรรมและโครงสร้างทุน บริษัทพลังงานและสาธารณูปโภคมักมี WACC ต่ำกว่า (~7-9%) ส่วนบริษัทเทคโนโลยีและค้าปลีกมักสูงกว่า (~10-14%)',
  },
  {
    question: 'Tax Shield ใน WACC คืออะไร?',
    answer: 'Tax Shield คือประโยชน์ทางภาษีจากดอกเบี้ยเงินกู้ที่หักออกจากรายได้ก่อนคำนวณภาษีได้ ทำให้ต้นทุนหนี้สิน (Rd) ที่แท้จริงต่ำกว่าอัตราดอกเบี้ยที่จ่าย สูตร: ต้นทุนหนี้สุทธิ = Rd × (1 − อัตราภาษี) ในไทยภาษีนิติบุคคลมาตรฐาน = 20%',
  },
  {
    question: 'ถ้า WACC สูง แปลว่าอะไร?',
    answer: 'WACC สูงหมายความว่าบริษัทมีต้นทุนเงินทุนสูง อาจเกิดจากหนี้สินสูง ความเสี่ยงทางธุรกิจสูง หรือต้นทุนทุนสูง ทำให้ต้องการผลตอบแทนจากโครงการลงทุนสูงขึ้น โครงการที่ NPV > 0 เมื่อใช้ WACC สูงจึงมีคุณภาพดีกว่า',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ WACC ต้นทุนทุนถัวเฉลี่ย',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณ WACC ต้นทุนทุนถัวเฉลี่ย',
  description: 'ขั้นตอนการคำนวณ WACC สำหรับบริษัทในตลาดหลักทรัพย์หรือธุรกิจทั่วไป',
  step: [
    {
      '@type': 'HowToStep',
      name: 'ระบุมูลค่าทุนและหนี้สิน',
      text: 'กรอกมูลค่าตลาดของส่วนทุน (Equity) และมูลค่าหนี้สิน (Debt) ระบบจะคำนวณสัดส่วน E/V และ D/V ให้อัตโนมัติ',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกต้นทุนทุนและต้นทุนหนี้',
      text: 'กรอกต้นทุนทุน (Re%) จาก CAPM หรือ dividend model และต้นทุนหนี้ (Rd%) จากอัตราดอกเบี้ยเงินกู้',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกอัตราภาษีนิติบุคคล',
      text: 'กรอกอัตราภาษีนิติบุคคล (ไทยมาตรฐาน 20%) เพื่อคำนวณ Tax Shield ของดอกเบี้ยเงินกู้',
    },
    {
      '@type': 'HowToStep',
      name: 'อ่านผล WACC',
      text: 'ระบบแสดง WACC % สัดส่วนทุนและหนี้ และต้นทุนหนี้หลังภาษี ใช้ WACC เป็น discount rate ใน NPV',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-wacc-ต้นทุนทุนถัวเฉลี่ย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณ WACC — ต้นทุนเงินทุนถัวเฉลี่ย</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: WACC = (E/V × Re) + (D/V × Rd × (1−T))</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณ WACC ต้นทุนทุนถัวเฉลี่ย (Weighted Average Cost of Capital) 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณ WACC สำหรับบริษัท พร้อมสัดส่วนหนี้สิน-ทุน ต้นทุนหนี้หลังภาษี และการเปรียบเทียบกับค่าเฉลี่ยอุตสาหกรรม
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'Damodaran: WACC and Cost of Capital',
        'ตลาดหลักทรัพย์แห่งประเทศไทย (SET): ข้อมูลต้นทุนทุนรายอุตสาหกรรม',
      ]}
      assumptions={[
        'สูตร: WACC = (E/V × Re) + (D/V × Rd × (1−T))',
        'ใช้มูลค่าตลาด (Market Value) ของส่วนทุนและหนี้สิน',
        'ภาษีนิติบุคคลไทยมาตรฐาน = 20%',
      ]}
      references={[
        { label: 'SET: ข้อมูลอัตราส่วนทางการเงิน', href: 'https://www.set.or.th' },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="wacc-form" class="space-y-5">
        <p id="wacc-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="wacc-equity" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าทุน — Equity (บาท)</label>
            <input type="text" id="wacc-equity" inputmode="numeric" placeholder="เช่น 8,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="wacc-debt" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าหนี้สิน — Debt (บาท)</label>
            <input type="text" id="wacc-debt" inputmode="numeric" placeholder="เช่น 2,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="wacc-re" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนทุน — Cost of Equity (% ต่อปี)</label>
            <input type="text" id="wacc-re" inputmode="decimal" placeholder="เช่น 12"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            <p class="mt-1 text-xs text-gray-500">คำนวณจาก CAPM: Rf + β × (Rm−Rf)</p>
          </div>
          <div>
            <label for="wacc-rd" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนหนี้สิน — Cost of Debt (% ต่อปี)</label>
            <input type="text" id="wacc-rd" inputmode="decimal" placeholder="เช่น 6"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            <p class="mt-1 text-xs text-gray-500">อัตราดอกเบี้ยเงินกู้จากสถาบันการเงิน</p>
          </div>
          <div>
            <label for="wacc-tax" class="block text-sm font-medium text-gray-700 mb-1">อัตราภาษีนิติบุคคล (%)</label>
            <input type="text" id="wacc-tax" inputmode="decimal" placeholder="20" value="20"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            <p class="mt-1 text-xs text-gray-500">ไทยมาตรฐาน 20% (SME อาจ 15%)</p>
          </div>
        </div>

        <button type="submit" id="wacc-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณ WACC
        </button>
      </form>
    </div>

    <div id="wacc-results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ WACC</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">WACC</div>
            <div id="res-wacc" class="text-2xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">สัดส่วนทุน (E/V)</div>
            <div id="res-wacc-ew" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">สัดส่วนหนี้ (D/V)</div>
            <div id="res-wacc-dw" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ต้นทุนหนี้หลังภาษี</div>
            <div id="res-wacc-rd-at" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">องค์ประกอบทุน: E/V × Re</span>
            <span id="res-wacc-equity-component" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">องค์ประกอบหนี้: D/V × Rd × (1−T)</span>
            <span id="res-wacc-debt-component" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#wacc-results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตร WACC และวิธีคำนวณ</h2>
      <div class="bg-gray-50 rounded-lg p-4 my-4">
        <p class="font-semibold mb-1">สูตร WACC:</p>
        <p class="text-sm">WACC = (E/V × Re) + (D/V × Rd × (1−T))</p>
        <p class="text-xs text-gray-500 mt-1">E = มูลค่าทุน, D = มูลค่าหนี้, V = E+D, Re = ต้นทุนทุน, Rd = ต้นทุนหนี้, T = อัตราภาษี</p>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่าง: บริษัท E=8M, D=2M, Re=12%, Rd=6%, T=20%</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>V = 8M + 2M = 10M, E/V = 80%, D/V = 20%</li>
          <li>องค์ประกอบทุน = 80% × 12% = 9.6%</li>
          <li>ต้นทุนหนี้หลังภาษี = 6% × (1−20%) = 4.8%</li>
          <li>องค์ประกอบหนี้ = 20% × 4.8% = 0.96%</li>
          <li><strong>WACC = 9.6% + 0.96% = 10.56%</strong></li>
        </ul>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        <strong>แหล่งอ้างอิง:</strong>
        <a href="https://www.set.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">ตลาดหลักทรัพย์แห่งประเทศไทย (SET)</a>
      </p>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-wacc-ต้นทุนทุนถัวเฉลี่ย/" />
    <RelatedCalculators currentHref="/คำนวณ-wacc-ต้นทุนทุนถัวเฉลี่ย/" slugs={['คำนวณ-npv-มูลค่าปัจจุบันสุทธิ', 'คำนวณ-irr-อัตราผลตอบแทนภายใน', 'คำนวณ-roe-ผลตอบแทนผู้ถือหุ้น']} />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>
</BaseLayout>

<script>
  function parseNum(v: string): number {
    return parseFloat(String(v).replace(/,/g, '').trim()) || 0;
  }

  const form = document.getElementById('wacc-form') as HTMLFormElement;
  const formError = document.getElementById('wacc-form-error') as HTMLElement;
  const resultsDiv = document.getElementById('wacc-results') as HTMLElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    formError.classList.add('hidden');

    const equity = parseNum((document.getElementById('wacc-equity') as HTMLInputElement).value);
    const debt = parseNum((document.getElementById('wacc-debt') as HTMLInputElement).value);
    const re = parseNum((document.getElementById('wacc-re') as HTMLInputElement).value) / 100;
    const rd = parseNum((document.getElementById('wacc-rd') as HTMLInputElement).value) / 100;
    const tax = parseNum((document.getElementById('wacc-tax') as HTMLInputElement).value) / 100;

    if (equity <= 0 || re <= 0 || rd <= 0) {
      formError.classList.remove('hidden');
      formError.textContent = 'กรุณากรอกมูลค่าทุน ต้นทุนทุน และต้นทุนหนี้ให้ถูกต้อง';
      return;
    }

    const V = equity + debt;
    const eWeight = equity / V;
    const dWeight = debt / V;
    const rdAfterTax = rd * (1 - tax);
    const equityComponent = eWeight * re;
    const debtComponent = dWeight * rdAfterTax;
    const wacc = equityComponent + debtComponent;

    (document.getElementById('res-wacc') as HTMLElement).textContent = (wacc * 100).toFixed(2) + '%';
    (document.getElementById('res-wacc-ew') as HTMLElement).textContent = (eWeight * 100).toFixed(2) + '%';
    (document.getElementById('res-wacc-dw') as HTMLElement).textContent = (dWeight * 100).toFixed(2) + '%';
    (document.getElementById('res-wacc-rd-at') as HTMLElement).textContent = (rdAfterTax * 100).toFixed(2) + '%';
    (document.getElementById('res-wacc-equity-component') as HTMLElement).textContent = (equityComponent * 100).toFixed(2) + '%';
    (document.getElementById('res-wacc-debt-component') as HTMLElement).textContent = (debtComponent * 100).toFixed(2) + '%';

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
