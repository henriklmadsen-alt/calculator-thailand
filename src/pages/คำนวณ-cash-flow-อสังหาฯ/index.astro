---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ Cash Flow อสังหาฯ 2569 | รายได้สุทธิ | เงินเหลือจากการลงทุน | Kamnuanlek';
const pageDescription = 'คำนวณ Cash Flow จากการลงทุนอสังหาฯ โดยหักต้นทุนการผ่อนจำนอง ค่าดำเนินการ และข้อมูลอื่น ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-cash-flow-อสังหาฯ/`;

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ Cash Flow อสังหาฯ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const faqData = [
  { question: 'Cap Rate ที่ดีสำหรับอสังหาริมทรัพย์ไทยคือเท่าไร?', answer: 'Cap Rate ที่ดีในไทยมักอยู่ที่ 5-8% ต่อปี ขึ้นอยู่กับทำเลและประเภทอสังหาฯ ทำเลกรุงเทพฯ ชั้นในมักได้ cap rate ต่ำกว่าต่างจังหวัด' },
  { question: 'ค่าใช้จ่ายแฝงในการซื้ออสังหาฯ มีอะไรบ้าง?', answer: 'ค่าโอน ค่าจดจำนอง ค่าอากรแสตมป์ ภาษีธุรกิจเฉพาะ ค่านายหน้า ค่าซ่อมแซม รวมกันอาจสูงถึง 3-7% ของราคาซื้อ' },
  { question: 'ผลตอบแทนการลงทุนอสังหาฯ ที่ดีต้องเป็นเท่าไร?', answer: 'นักลงทุนส่วนใหญ่ต้องการ IRR อย่างน้อย 8-12% ต่อปี หรือ Yield ค่าเช่า 5-7% ขึ้นอยู่กับทำเลและเป้าหมาย' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกราคาซื้อ ค่าเช่า ค่าใช้จ่ายรายเดือน เครื่องจะคำนวณ Yield, Cash Flow และ Cap Rate ให้อัตโนมัติ' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ Cash Flow">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณ Cash Flow อสังหาฯ ปี 2569</h1>
    <p class="text-gray-600 mb-6">วิเคราะห์เงินสดสุทธิที่ได้รับจากการลงทุนอสังหาฯ หลังหักภาระค่าจำนอง ค่าดำเนินการ และค่าใช้จ่ายอื่น</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="cashflow-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="annual-income" class="block text-sm font-medium text-gray-700 mb-1">รายได้เช่า/ปี (บาท)</label>
            <input id="annual-income" type="text" inputmode="numeric" placeholder="เช่น 600,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="mortgage-payment" class="block text-sm font-medium text-gray-700 mb-1">ค่าผ่อนจำนอง/ปี (บาท)</label>
            <input id="mortgage-payment" type="text" inputmode="numeric" placeholder="เช่น 300,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="operating-expense" class="block text-sm font-medium text-gray-700 mb-1">ค่าดำเนินการ/ปี (บาท)</label>
            <input id="operating-expense" type="text" inputmode="numeric" placeholder="เช่น 120,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="other-expense" class="block text-sm font-medium text-gray-700 mb-1">ค่าใช้จ่ายอื่น/ปี (บาท)</label>
            <input id="other-expense" type="text" inputmode="numeric" placeholder="เช่น 50,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" value="0" />
          </div>
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณ Cash Flow
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div id="positive-cash" class="rounded-lg bg-emerald-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">Cash Flow ต่อปี</div>
          <div id="res-cash-flow" class="text-2xl font-bold text-emerald-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">รายได้เช่า/ปี</span>
            <span id="res-annual-income" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-600">ค่าผ่อนจำนอง/ปี</span>
            <span id="res-mortgage-payment" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าดำเนินการ/ปี</span>
            <span id="res-operating-expense" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าใช้จ่ายอื่น/ปี</span>
            <span id="res-other-expense" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">Cash Flow (รายได้ - ค่าใช้จ่ายทั้งหมด)</span>
            <span id="res-calc-flow" class="font-bold text-lg text-primary-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <RelatedCalculators currentHref="/คำนวณ-cash-flow-อสังหาฯ/" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#cashflow-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const annualIncome = parseNumber(document.querySelector('#annual-income')?.value || '');
    const mortgagePayment = parseNumber(document.querySelector('#mortgage-payment')?.value || '');
    const operatingExpense = parseNumber(document.querySelector('#operating-expense')?.value || '');
    const otherExpense = parseNumber(document.querySelector('#other-expense')?.value || '');

    if (!(Number.isFinite(annualIncome) && annualIncome > 0 && Number.isFinite(mortgagePayment) && Number.isFinite(operatingExpense) && Number.isFinite(otherExpense))) {
      results?.classList.add('hidden');
      return;
    }

    const totalExpense = mortgagePayment + operatingExpense + otherExpense;
    const cashFlow = annualIncome - totalExpense;

    document.querySelector('#res-cash-flow').textContent = formatCurrency(cashFlow);
    document.querySelector('#res-annual-income').textContent = formatCurrency(annualIncome);
    document.querySelector('#res-mortgage-payment').textContent = formatCurrency(mortgagePayment);
    document.querySelector('#res-operating-expense').textContent = formatCurrency(operatingExpense);
    document.querySelector('#res-other-expense').textContent = formatCurrency(otherExpense);
    document.querySelector('#res-calc-flow').textContent = formatCurrency(cashFlow);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
