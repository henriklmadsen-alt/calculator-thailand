---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณต้นทุนพนักงานรายเดือน ปี 2569 เงินเดือน SSC นายจ้าง PVD สวัสดิการ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนพนักงานรายเดือนทั้งหมดสำหรับนายจ้าง เงินเดือน ประกันสังคมฝั่งนายจ้าง 5% กองทุนสำรองเลี้ยงชีพ และสวัสดิการอื่นๆ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนพนักงานรายเดือน/`;

const faqData = [
  {
    question: 'ต้นทุนพนักงานจริงสูงกว่าเงินเดือนเท่าไร?',
    answer: 'โดยทั่วไปต้นทุนรวมสูงกว่าเงินเดือน 10-25% ขึ้นอยู่กับสวัสดิการที่บริษัทจัดให้ ประกันสังคมนายจ้างสูงสุด 750 บาท/เดือน กองทุนสำรอง 2-15% ของเงินเดือน',
  },
  {
    question: 'นายจ้างต้องสมทบประกันสังคมเท่าไร?',
    answer: 'นายจ้างสมทบประกันสังคม 5% ของค่าจ้าง ฐานคิดขั้นต่ำ 1,650 บาท สูงสุด 15,000 บาท ดังนั้นสมทบสูงสุด 750 บาท/เดือน/พนักงาน',
  },
  {
    question: 'กองทุนสำรองเลี้ยงชีพ (PVD) นายจ้างต้องสมทบไหม?',
    answer: 'PVD เป็นสวัสดิการสมัครใจ ถ้าบริษัทตั้ง PVD แล้วนายจ้างต้องสมทบไม่น้อยกว่าอัตราที่ลูกจ้างสมทบ โดยทั่วไปกำหนดที่ 3-5% ของเงินเดือน',
  },
  {
    question: 'ต้นทุนพนักงานใช้ในการตัดสินใจจ้างงานอย่างไร?',
    answer: 'ควรคำนวณต้นทุนรวม (Total Cost of Employment) แทนที่จะดูแค่เงินเดือน เพื่อให้เห็นภาพรวมค่าใช้จ่ายบุคลากรที่แท้จริงในงบประมาณบริษัท',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนพนักงานรายเดือน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนพนักงานรายเดือน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ต้นทุนรวมที่นายจ้างต้องจ่ายต่อพนักงาน 1 คน</p>
      <p class="mt-1 text-sm text-slate-700">เงินเดือน + SSC นายจ้าง 5% (สูงสุด 750 บาท) + PVD + สวัสดิการ</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับ HR นายจ้าง และฝ่ายการเงินที่ต้องการคำนวณงบบุคลากร</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณต้นทุนพนักงานรายเดือน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือนและสวัสดิการต่างๆ ระบบจะคำนวณต้นทุนรวมที่นายจ้างต้องจ่ายต่อพนักงาน 1 คนต่อเดือน
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="employer-cost-form" class="space-y-5">
        <p id="employer-cost-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ec-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือน (บาท/เดือน)</label>
            <input type="text" id="ec-salary" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ec-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ec-pvd-pct" class="mb-1 block text-sm font-medium text-gray-700">กองทุนสำรองเลี้ยงชีพ (%) ของนายจ้าง</label>
            <input type="text" id="ec-pvd-pct" inputmode="decimal" placeholder="เช่น 5 หรือ 0 ถ้าไม่มี"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ec-insurance" class="mb-1 block text-sm font-medium text-gray-700">ประกันสุขภาพกลุ่ม (บาท/เดือน)</label>
            <input type="text" id="ec-insurance" inputmode="numeric" placeholder="เช่น 500 หรือ 0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="ec-other" class="mb-1 block text-sm font-medium text-gray-700">สวัสดิการอื่นๆ (บาท/เดือน)</label>
            <input type="text" id="ec-other" inputmode="numeric" placeholder="เช่น 1,000 หรือ 0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณต้นทุนพนักงาน
        </button>
      </form>
    </div>

    <div id="employer-cost-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนรวมต่อเดือน</div>
            <div id="res-ec-total" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนเหนือเงินเดือน</div>
            <div id="res-ec-overhead" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนรวมต่อปี</div>
            <div id="res-ec-annual" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">เงินเดือน</span>
            <span id="res-ec-salary" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">SSC นายจ้าง (5% สูงสุด 750 บาท)</span>
            <span id="res-ec-ssc" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">กองทุนสำรองเลี้ยงชีพ (PVD)</span>
            <span id="res-ec-pvd" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ประกันสุขภาพกลุ่ม</span>
            <span id="res-ec-insurance" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">สวัสดิการอื่นๆ</span>
            <span id="res-ec-other" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>SSC นายจ้าง = min(max(เงินเดือน, 1,650), 15,000) × 5% (สูงสุด 750 บาท)</li>
        <li>PVD นายจ้าง = เงินเดือน × % PVD ÷ 100</li>
        <li>ต้นทุนรวม = เงินเดือน + SSC + PVD + ประกัน + อื่นๆ</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณค่าจ้างพนักงาน/">คำนวณค่าจ้างพนักงาน</a></li>
        <li><a href="/คำนวณประกันสังคม/">คำนวณประกันสังคม</a></li>
        <li><a href="/คำนวณภาษีเงินเดือนและประกันสังคม/">คำนวณภาษีเงินเดือนและประกันสังคม</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#employer-cost-results" />
    <RelatedArticles currentHref="/คำนวณต้นทุนพนักงานรายเดือน/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนพนักงานรายเดือน/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ ต้นทุนจริงอาจรวมค่าใช้จ่ายอื่นๆ เช่น ค่าเดินทาง อุปกรณ์ การฝึกอบรม และพื้นที่ทำงาน
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('employer-cost-form');
    const formError = document.getElementById('employer-cost-form-error');
    const resultBox = document.getElementById('employer-cost-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      setErr('ec-salary-error', '');

      const salary = parseNum(document.getElementById('ec-salary').value);
      const pvdPct = parseNum(document.getElementById('ec-pvd-pct').value) || 0;
      const insurance = parseNum(document.getElementById('ec-insurance').value) || 0;
      const other = parseNum(document.getElementById('ec-other').value) || 0;

      if (!Number.isFinite(salary) || salary <= 0) {
        setErr('ec-salary-error', 'กรอกเงินเดือนมากกว่า 0');
        formError.classList.remove('hidden');
        resultBox.classList.add('hidden');
        return;
      }

      const sscBase = Math.min(Math.max(salary, 1650), 15000);
      const sscEmployer = sscBase * 0.05;
      const pvd = salary * (pvdPct / 100);
      const total = salary + sscEmployer + pvd + insurance + other;
      const overhead = total - salary;

      setText('res-ec-total', formatMoney(total));
      setText('res-ec-overhead', formatMoney(overhead));
      setText('res-ec-annual', formatMoney(total * 12));
      setText('res-ec-salary', formatMoney(salary));
      setText('res-ec-ssc', formatMoney(sscEmployer));
      setText('res-ec-pvd', formatMoney(pvd));
      setText('res-ec-insurance', formatMoney(insurance));
      setText('res-ec-other', formatMoney(other));

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
