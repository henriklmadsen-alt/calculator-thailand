---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่าโทรศัพท์ 2569 | ค่ามือถือรายเดือน AIS TRUE DTAC | เครื่องคำนวณไทย';
const pageDescription = 'เครื่องคำนวณค่าโทรศัพท์มือถือรายเดือน 2569 เปรียบเทียบ AIS TrueMove H DTAC คำนวณค่าแพ็กเกจ ค่าโทรเกิน ค่าเน็ตเกิน SMS และ VAT 7%';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าโทรศัพท์/`;

const faqData = [
  {
    question: 'ค่าโทรศัพท์มือถือคิด VAT ไหม?',
    answer:
      'คิด VAT 7% จากยอดรวมทุกรายการ ทั้งค่าแพ็กเกจรายเดือน ค่าโทรเกินแพ็กเกจ ค่าเน็ตเกิน ค่า SMS และค่าบริการเสริม ตาม พ.ร.บ. ภาษีมูลค่าเพิ่ม',
  },
  {
    question: 'โทรเกินแพ็กเกจคิดเท่าไร?',
    answer:
      'อัตราค่าโทรเกินแพ็กเกจโดยทั่วไปอยู่ที่ 1-2 บาท/นาที ขึ้นอยู่กับค่ายมือถือและแพ็กเกจที่ใช้ เครื่องคำนวณนี้ใช้อัตราเฉลี่ย 1.50 บาท/นาที ควรตรวจสอบอัตราจริงจากใบแจ้งค่าบริการ',
  },
  {
    question: 'เติมเงิน (พรีเพด) กับรายเดือน (โพสต์เพด) ต่างกันอย่างไร?',
    answer:
      'พรีเพดจ่ายล่วงหน้า เลือกซื้อแพ็กเกจเน็ต/โทรตามต้องการ ไม่มีบิลรายเดือน ส่วนโพสต์เพดมีค่าบริการรายเดือนคงที่ ใช้เกินจะคิดค่าบริการเพิ่ม และออกบิลท้ายเดือน',
  },
  {
    question: 'เน็ตเกินแพ็กเกจคิดอย่างไร?',
    answer:
      'เมื่อใช้เน็ตเกินแพ็กเกจ ผู้ให้บริการอาจลดความเร็ว (FUP) หรือคิดค่าบริการเพิ่มประมาณ 1-2 บาท/MB ขึ้นอยู่กับแพ็กเกจและค่าย ผู้ใช้ควรตรวจสอบเงื่อนไขจากค่ายมือถือ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าโทรศัพท์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าโทรศัพท์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">อ้างอิงอัตราปี 2569</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณค่าโทรศัพท์มือถือรายเดือน AIS, TrueMove H, DTAC รวมค่าโทรเกิน ค่าเน็ตเกิน SMS และ VAT 7%</p>
      <p class="mt-1 text-xs font-medium text-sky-800">ผลลัพธ์นี้เป็นการประมาณการเพื่อวางแผนค่าใช้จ่าย</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณค่าโทรศัพท์ 2569 (AIS / TRUE / DTAC)</h1>

    <p class="mb-6 text-gray-600">
      กรอกค่ายมือถือ ประเภทแพ็กเกจ ค่าบริการรายเดือน และการใช้งานเกินแพ็กเกจ เพื่อประมาณค่าโทรศัพท์มือถือรวม VAT ในแต่ละเดือน
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="phone-form" class="space-y-5">
        <p id="phone-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลที่กรอกให้ครบถ้วน
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="provider" class="mb-1 block text-sm font-medium text-gray-700">ค่ายมือถือ</label>
            <select
              id="provider"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">เลือกค่ายมือถือ</option>
              <option value="ais">AIS</option>
              <option value="true">TrueMove H</option>
              <option value="dtac">DTAC</option>
            </select>
            <p id="provider-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="plan-type" class="mb-1 block text-sm font-medium text-gray-700">ประเภทแพ็กเกจ</label>
            <select
              id="plan-type"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">เลือกประเภท</option>
              <option value="postpaid">รายเดือน (โพสต์เพด)</option>
              <option value="prepaid">เติมเงิน (พรีเพด)</option>
            </select>
            <p id="plan-type-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="package-price" class="mb-1 block text-sm font-medium text-gray-700">ค่าแพ็กเกจ/เติมเงิน (บาท/เดือน)</label>
            <input
              type="text"
              id="package-price"
              inputmode="numeric"
              placeholder="เช่น 599"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">แพ็กเกจยอดนิยม: 299, 399, 599, 799, 1099 บาท</p>
            <p id="package-price-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="excess-call" class="mb-1 block text-sm font-medium text-gray-700">โทรเกินแพ็กเกจ (นาที)</label>
            <input
              type="text"
              id="excess-call"
              inputmode="numeric"
              placeholder="เช่น 30"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ไม่มีค่าโทรเกินให้เว้นว่างหรือกรอก 0</p>
            <p id="excess-call-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="excess-data" class="mb-1 block text-sm font-medium text-gray-700">เน็ตเกินแพ็กเกจ (MB)</label>
            <input
              type="text"
              id="excess-data"
              inputmode="numeric"
              placeholder="เช่น 500"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">1 GB = 1,024 MB</p>
            <p id="excess-data-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="sms-count" class="mb-1 block text-sm font-medium text-gray-700">จำนวน SMS</label>
            <input
              type="text"
              id="sms-count"
              inputmode="numeric"
              placeholder="เช่น 10"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p id="sms-count-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="addon-services" class="mb-1 block text-sm font-medium text-gray-700">ค่าบริการเสริม (บาท)</label>
            <input
              type="text"
              id="addon-services"
              inputmode="numeric"
              placeholder="เช่น 50"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">เช่น เสียงรอสาย โทรต่างประเทศ ค่าเบอร์สวย</p>
            <p id="addon-services-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button
          type="submit"
          id="phone-submit-btn"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          กรอกข้อมูลให้ครบ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>

        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าแพ็กเกจ</div>
            <div id="res-package" class="text-lg font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าใช้งานเกิน</div>
            <div id="res-excess" class="text-lg font-bold text-sky-700">-</div>
          </div>
          <div class="rounded-lg bg-purple-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">VAT 7%</div>
            <div id="res-vat" class="text-lg font-bold text-purple-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รวมทั้งหมด</div>
            <div id="res-total" class="text-2xl font-bold text-red-600">-</div>
          </div>
        </div>

        <div class="mb-6 space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ค่ายมือถือ</span>
            <span id="res-provider" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ประเภทแพ็กเกจ</span>
            <span id="res-plan-type" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">รวมก่อน VAT</span>
            <span id="res-subtotal" class="font-medium text-gray-900">-</span>
          </div>
        </div>

        <h3 class="mb-2 text-base font-semibold text-gray-900">รายละเอียดค่าใช้จ่าย</h3>
        <div class="overflow-x-auto rounded-md border border-gray-200">
          <table class="min-w-full text-sm">
            <thead class="bg-gray-50 text-gray-700">
              <tr>
                <th class="px-3 py-2 text-left font-medium">รายการ</th>
                <th class="px-3 py-2 text-right font-medium">จำนวนเงิน (บาท)</th>
              </tr>
            </thead>
            <tbody id="breakdown-body" class="divide-y divide-gray-100 bg-white"></tbody>
          </table>
        </div>

        <div id="rates-info" class="mt-4 rounded-md bg-sky-50 px-3 py-2 text-xs text-sky-800"></div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าโทรเกินแพ็กเกจ = นาทีที่เกิน × อัตราค่าโทร (บาท/นาที)</li>
        <li>ค่าเน็ตเกินแพ็กเกจ = MB ที่เกิน × อัตราค่าเน็ต (บาท/MB)</li>
        <li>ค่า SMS = จำนวนข้อความ × อัตราค่า SMS (บาท/ข้อความ)</li>
        <li>รวมก่อน VAT = ค่าแพ็กเกจ + ค่าโทรเกิน + ค่าเน็ตเกิน + ค่า SMS + ค่าบริการเสริม</li>
        <li>VAT = รวมก่อน VAT × 7%</li>
        <li>รวมทั้งหมด = รวมก่อน VAT + VAT</li>
      </ul>
      <p>
        อัตราค่าบริการเกินแพ็กเกจเป็นค่าเฉลี่ยอ้างอิงจากอัตราที่ประกาศของ AIS, TrueMove H และ DTAC
        อัตราจริงอาจต่างกันตามแพ็กเกจ ควรตรวจสอบจากใบแจ้งค่าบริการจริง
      </p>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <RelatedArticles currentHref="/คำนวณค่าโทรศัพท์/" />
    <RelatedCalculators currentHref="/คำนวณค่าโทรศัพท์/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <section class="mb-8 rounded-lg border border-gray-200 bg-white p-4 text-sm text-gray-700 shadow-sm sm:p-6">
      <h2 class="mb-2 text-base font-semibold text-gray-900">แหล่งอ้างอิงทางการ</h2>
      <ul class="list-disc space-y-1 pl-5">
        <li><a href="https://www.ais.th/postpaid/" target="_blank" rel="noopener noreferrer">AIS แพ็กเกจรายเดือน</a></li>
        <li><a href="https://www.true.th/truemoveh/package/" target="_blank" rel="noopener noreferrer">TrueMove H แพ็กเกจมือถือ</a></li>
        <li><a href="https://www.dtac.co.th/postpaid" target="_blank" rel="noopener noreferrer">DTAC แพ็กเกจรายเดือน</a></li>
        <li><a href="https://www.nbtc.go.th/" target="_blank" rel="noopener noreferrer">สำนักงาน กสทช. อัตราค่าบริการโทรคมนาคม</a></li>
      </ul>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>หมายเหตุสำคัญ:</strong> เครื่องมือนี้เป็นการคำนวณเบื้องต้นเพื่อช่วยประมาณค่าใช้จ่ายมือถือ
      อัตราจริงอาจต่างไปตามแพ็กเกจ โปรโมชัน และเงื่อนไขของผู้ให้บริการ ควรตรวจสอบจากใบแจ้งค่าบริการจริง
    </div>
  </article>

  <script type="module">
    import { calculatePhoneBill, getProviderExcessRates } from '../../lib/phone-bill-calculator';

    function parseNum(value) {
      const normalized = String(value).replace(/,/g, '').trim();
      if (normalized === '') return 0;
      const n = Number(normalized);
      return Number.isFinite(n) ? n : NaN;
    }

    function fmtMoney(amount) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(amount)} บาท`;
    }

    const form = document.getElementById('phone-form');
    const submitBtn = document.getElementById('phone-submit-btn');
    const formError = document.getElementById('phone-form-error');
    const resultsDiv = document.getElementById('results');
    const breakdownBody = document.getElementById('breakdown-body');

    const fields = {
      provider: document.getElementById('provider'),
      planType: document.getElementById('plan-type'),
      packagePrice: document.getElementById('package-price'),
      excessCall: document.getElementById('excess-call'),
      excessData: document.getElementById('excess-data'),
      smsCount: document.getElementById('sms-count'),
      addonServices: document.getElementById('addon-services'),
    };

    const PROVIDER_LABELS = { ais: 'AIS', true: 'TrueMove H', dtac: 'DTAC' };
    const PLAN_TYPE_LABELS = { postpaid: 'รายเดือน (โพสต์เพด)', prepaid: 'เติมเงิน (พรีเพด)' };

    function setFieldError(id, message) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearFieldError(id) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      ['provider-error', 'plan-type-error', 'package-price-error', 'excess-call-error', 'excess-data-error', 'sms-count-error', 'addon-services-error'].forEach(clearFieldError);
    }

    function updateSubmitState() {
      const providerOk = fields.provider.value !== '';
      const planTypeOk = fields.planType.value !== '';
      const priceRaw = String(fields.packagePrice.value).replace(/,/g, '').trim();
      const priceOk = priceRaw !== '' && Number.isFinite(Number(priceRaw)) && Number(priceRaw) >= 0;

      const ready = providerOk && planTypeOk && priceOk;
      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณค่าโทรศัพท์' : 'กรอกข้อมูลให้ครบ';
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
      submitBtn.classList.toggle('opacity-70', !ready);
    }

    Object.values(fields).forEach((field) => {
      field.addEventListener('input', () => { clearValidation(); updateSubmitState(); });
      field.addEventListener('change', () => { clearValidation(); updateSubmitState(); });
    });

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    updateSubmitState();

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      clearValidation();

      const provider = String(fields.provider.value || '');
      const planType = String(fields.planType.value || '');
      const packagePrice = parseNum(fields.packagePrice.value);
      const excessCallMinutes = parseNum(fields.excessCall.value);
      const excessDataMB = parseNum(fields.excessData.value);
      const smsCount = parseNum(fields.smsCount.value);
      const addonServices = parseNum(fields.addonServices.value);

      const validity = {
        provider: provider === 'ais' || provider === 'true' || provider === 'dtac',
        planType: planType === 'postpaid' || planType === 'prepaid',
        packagePrice: Number.isFinite(packagePrice) && packagePrice >= 0,
        excessCall: Number.isFinite(excessCallMinutes) && excessCallMinutes >= 0,
        excessData: Number.isFinite(excessDataMB) && excessDataMB >= 0,
        smsCount: Number.isFinite(smsCount) && smsCount >= 0,
        addonServices: Number.isFinite(addonServices) && addonServices >= 0,
      };

      if (!validity.provider) setFieldError('provider-error', 'กรุณาเลือกค่ายมือถือ');
      if (!validity.planType) setFieldError('plan-type-error', 'กรุณาเลือกประเภทแพ็กเกจ');
      if (!validity.packagePrice) setFieldError('package-price-error', 'กรุณากรอกค่าแพ็กเกจเป็นตัวเลข');
      if (!validity.excessCall) setFieldError('excess-call-error', 'กรุณากรอกจำนวนนาทีเป็นตัวเลข');
      if (!validity.excessData) setFieldError('excess-data-error', 'กรุณากรอกจำนวน MB เป็นตัวเลข');
      if (!validity.smsCount) setFieldError('sms-count-error', 'กรุณากรอกจำนวน SMS เป็นตัวเลข');
      if (!validity.addonServices) setFieldError('addon-services-error', 'กรุณากรอกค่าบริการเสริมเป็นตัวเลข');

      if (!Object.values(validity).every(Boolean)) {
        formError.classList.remove('hidden');
        updateSubmitState();
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('phone_bill');

      const result = calculatePhoneBill({
        provider,
        planType,
        packagePrice,
        excessCallMinutes,
        excessDataMB,
        smsCount,
        addonServices,
      });

      const totalExcess = result.excessCallCharge + result.excessDataCharge + result.smsCharge + result.addonServices;

      setText('res-package', fmtMoney(result.packagePrice));
      setText('res-excess', fmtMoney(totalExcess));
      setText('res-vat', fmtMoney(result.vatAmount));
      setText('res-total', fmtMoney(result.totalBill));

      setText('res-provider', PROVIDER_LABELS[result.provider] || result.provider);
      setText('res-plan-type', PLAN_TYPE_LABELS[result.planType] || result.planType);
      setText('res-subtotal', fmtMoney(result.subtotalBeforeVat));

      breakdownBody.innerHTML = '';
      result.breakdown.forEach((item, idx) => {
        const row = document.createElement('tr');
        const isTotal = idx === result.breakdown.length - 1;
        row.innerHTML = `
          <td class="px-3 py-2 ${isTotal ? 'font-semibold text-gray-900' : 'text-gray-700'}">${item.label}</td>
          <td class="px-3 py-2 text-right ${isTotal ? 'font-bold text-red-600' : 'font-medium text-gray-900'}">${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(item.amount)}</td>
        `;
        breakdownBody.appendChild(row);
      });

      const rates = result.appliedRates;
      setText('rates-info', `อัตราที่ใช้: ค่าโทรเกิน ${rates.callPerMinute} บาท/นาที | ค่าเน็ตเกิน ${rates.dataPerMB} บาท/MB | ค่า SMS ${rates.smsPerMessage} บาท/ข้อความ | ผลลัพธ์นี้เป็นการประเมินเบื้องต้น`);

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณค่าโทรศัพท์';
      trackCalculatorComplete('phone_bill', result.totalBill);
      trackCalculatorUsed('phone_bill');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          trackResultViewed('phone_bill');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
