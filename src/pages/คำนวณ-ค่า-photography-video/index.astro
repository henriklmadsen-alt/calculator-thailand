---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ ค่ากล้องและวิดีโอ 2569 | Kamnuanlek';
const pageDescription = 'คำนวณค่าสินทรัพย์ กล้อง และวิดีโออุปกรณ์ ประเมิน ROI เทียบกับการเช่า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่า-photography-video/`;

const faqData = [
  {
    question: 'ควรซื้อกล้องหรือเช่า?',
    answer: 'ซื้อ: ต้นทุนเริ่มต้นสูง แต่ยาวนาน คุ้ม เช่า: ยืดหยุ่น ต้นทุนต่ำ แต่ยาวนานทำให้แพง Hybrid: ซื้อกล้องเอง เช่า Lens/Light ตามความต้องการ',
  },
  {
    question: 'ค่า Photography ทั่วไป?',
    answer: 'ผลิตภัณฑ์ Shot 500-2,000 บาท/งาน Event Photography 10,000-50,000 บาท/งาน Commercial 30,000-100,000+ บาท',
  },
  {
    question: 'Video Production ราคาเท่าไร?',
    answer: 'Video สั้น 30-60 วินาที 5,000-20,000 บาท Video บริษัท 3-5 นาที 20,000-100,000+ บาท Drone Video 5,000-15,000 บาท/วัน',
  },
  {
    question: 'Equipment Depreciation?',
    answer: 'กล้อง depreciate 15-20%/ปี Lens 10-15%/ปี คำนวณค่าใช้จ่ายในรายจ่ายบัญชี 5 ปี Lifespan มักเพียงพอ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่ากล้องและวิดีโอ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่ากล้องและวิดีโอ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      📸 คำนวณค่ากล้องและวิดีโอ
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าสินทรัพย์ กล้อง และวิดีโออุปกรณ์
      ประเมิน ROI เทียบกับการเช่า
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="photo-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="equipment-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าอุปกรณ์รวม (บาท)
            </label>
            <input
              type="text"
              id="equipment-cost"
              inputmode="numeric"
              placeholder="เช่น 100000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="annual-depreciation" class="block text-sm font-medium text-gray-700 mb-1">
              Depreciation ต่อปี (%)
            </label>
            <input
              type="text"
              id="annual-depreciation"
              inputmode="numeric"
              placeholder="เช่น 15"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="rent-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าเช่าต่อเดือน (บาท)
            </label>
            <input
              type="text"
              id="rent-cost"
              inputmode="numeric"
              placeholder="เช่น 2000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="years" class="block text-sm font-medium text-gray-700 mb-1">
              ใช้ได้กี่ปี
            </label>
            <input
              type="text"
              id="years"
              inputmode="numeric"
              placeholder="เช่น 3"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณค่า
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าซื้อรวม</div>
            <div id="res-purchase-cost" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าเช่ารวม</div>
            <div id="res-rent-total" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าเสื่อมลด</div>
            <div id="res-depreciation" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ออม</div>
            <div id="res-savings" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าเช่า/เดือน</span>
            <span id="res-rent-monthly" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าเสื่อม/ปี</span>
            <span id="res-depreciation-annual" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">Residual Value</span>
            <span id="res-residual" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณ-ค่า-photography-video/" />
    <RelatedCalculators currentHref="/คำนวณ-ค่า-photography-video/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('photo-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const equipmentCost = parseNum((document.getElementById('equipment-cost') as HTMLInputElement).value);
      const annualDepreciation = parseNum((document.getElementById('annual-depreciation') as HTMLInputElement).value);
      const rentCost = parseNum((document.getElementById('rent-cost') as HTMLInputElement).value);
      const years = parseNum((document.getElementById('years') as HTMLInputElement).value);

      if (equipmentCost <= 0) { (document.getElementById('equipment-cost') as HTMLInputElement).focus(); return; }
      if (years <= 0) { (document.getElementById('years') as HTMLInputElement).focus(); return; }

      const monthsTotal = years * 12;
      const rentTotal = rentCost * monthsTotal;
      const depreciationAnnual = (equipmentCost * annualDepreciation) / 100;
      const depreciationTotal = depreciationAnnual * years;
      let residual = equipmentCost;
      for (let i = 0; i < years; i++) {
        residual = residual - (residual * annualDepreciation) / 100;
      }
      const netCostPurchase = depreciationTotal;
      const savings = Math.max(0, rentTotal - netCostPurchase);

      (document.getElementById('res-purchase-cost') as HTMLElement).textContent = fmt(equipmentCost) + ' บาท';
      (document.getElementById('res-rent-total') as HTMLElement).textContent = fmt(rentTotal) + ' บาท';
      (document.getElementById('res-depreciation') as HTMLElement).textContent = fmt(depreciationTotal) + ' บาท';
      (document.getElementById('res-savings') as HTMLElement).textContent = fmt(savings) + ' บาท';
      (document.getElementById('res-rent-monthly') as HTMLElement).textContent = fmt(rentCost) + ' บาท';
      (document.getElementById('res-depreciation-annual') as HTMLElement).textContent = fmt(depreciationAnnual) + ' บาท';
      (document.getElementById('res-residual') as HTMLElement).textContent = fmt(residual) + ' บาท';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('photography-video-cost');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('photography-video-cost');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
