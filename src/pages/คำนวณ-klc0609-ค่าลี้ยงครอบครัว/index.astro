---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าลี้ยงครอบครัว | Calculator Thailand';
const pageDescription = 'คำนวณค่าเลี้ยงดูญาติ ค่าลี้ยงคนติดค้าง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0609-ค่าลี้ยงครอบครัว/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าลี้ยงครอบครัว">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าลี้ยงครอบครัว</h1>
    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2"><p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าดูแลญาติที่ติดค้าง ค่าเลี้ยงผู้พึ่งพา</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="num_dependents" class="block text-sm font-medium text-gray-700 mb-1">จำนวนคนที่พึ่งพา (คน)</label><input type="number" id="num_dependents" min="1" max="10" placeholder="เช่น 2" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="food_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าอาหารต่อคนต่อเดือน (บาท)</label><input type="text" id="food_cost" inputmode="decimal" placeholder="เช่น 3000" value="3000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="health_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่ารักษารักษาต่อเดือน (บาท)</label><input type="text" id="health_cost" inputmode="decimal" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-lime-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-lime-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าต่อเดือน</p>
            <p id="monthly" class="font-bold">-</p>
          </div>
          <div class="bg-lime-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าต่อปี</p>
            <p id="yearly" class="font-bold">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">จำนวนคนที่พึ่งพาเท่าไหร่จึงถือเป็นการลดหย่อน?</h3>
            <p class="text-gray-600 text-sm">ตามกฎหมายภาษีอากร บุคคลผู้พึ่งพา ต้องมีรายได้น้อยกว่า 180,000 บาท/ปี จึงลดหย่อน 15,000 บาทต่อคน</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่าเลี้ยงผู้พึ่งพาเท่าไหร่ต้องจดทะเบียน?</h3>
            <p class="text-gray-600 text-sm">ตามพระราชกฤษณมูลนิติ หากเป็นเด็กหรือผู้สูงอายุ ต้องจดทะเบียน สปส. เพื่อขอสิทธิประกาศ</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">มีเงินช่วยเหลือคนติดค้างหรือไม่?</h3>
            <p class="text-gray-600 text-sm">มี ขึ้นอยู่กับเงื่อนไข เช่น เบี้ยความเป็นคนชรา เบี้ยคนพิการ แต่ประการแรก</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const numDependents = parseInt((document.getElementById('num_dependents') as HTMLInputElement).value) || 1;
      const foodCost = parseFloat((document.getElementById('food_cost') as HTMLInputElement).value) || 0;
      const healthCost = parseFloat((document.getElementById('health_cost') as HTMLInputElement).value) || 0;

      const costPerPerson = foodCost + healthCost;
      const monthlyTotal = costPerPerson * numDependents;
      const yearlyTotal = monthlyTotal * 12;

      (document.getElementById('monthly') as HTMLElement).textContent = monthlyTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('yearly') as HTMLElement).textContent = yearlyTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('dependent-support');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
