---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณรายได้จากผลผลิตเกษตร | Kamnuanlek';
const pageDescription = 'คำนวณรายได้จากผลผลิตทางการเกษตร พืชหลายชนิด ราคาตลาด กำไรสุทธิ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0477-รายได้ผลผลิต/`;
const faqData = [
  { question: 'ราคาผลผลิตเกษตรดูได้จากที่ไหน?', answer: 'ติดตามราคาจาก สำนักงานเศรษฐกิจการเกษตร (สศก.) ที่ oae.go.th หรือ ตลาดกลางสินค้าเกษตร ราคามักอัปเดตรายวัน-รายสัปดาห์' },
  { question: 'ควรขายผลผลิตเองหรือผ่านพ่อค้าคนกลาง?', answer: 'ขายเองผ่านตลาดสด ออนไลน์ หรือโดยตรงให้ผู้บริโภค ได้ราคาสูงกว่า 20-40% แต่ต้องจัดการด้านการตลาดเอง ขนส่งและบรรจุภัณฑ์เพิ่มเติม' },
  { question: 'สัญญาซื้อขายล่วงหน้า (Contract Farming) ดีอย่างไร?', answer: 'Contract Farming ประกันราคาล่วงหน้า ลดความเสี่ยงราคาตก แต่ต้องผลิตตามสเปกที่กำหนด ควรเปรียบเทียบราคาตลาดก่อนตัดสินใจทำสัญญา' },
  { question: 'ผลผลิตเกษตรเสียภาษีไหม?', answer: 'เกษตรกรบุคคลธรรมดาได้รับยกเว้นภาษีเงินได้จากการขายพืชผล ตาม ม.42(17) แห่ง ปพพ. แต่หากเป็นนิติบุคคลต้องเสียภาษีตามปกติ' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณรายได้จากผลผลิตเกษตร">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณรายได้จากผลผลิตเกษตร</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณรายได้รวมและกำไรสุทธิจากการขายผลผลิตทางการเกษตร</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="total_yield_kg" class="block text-sm font-medium text-gray-700 mb-1">ผลผลิตรวม (กก.)</label><input type="number" id="total_yield_kg" min="1" placeholder="เช่น 10000" value="10000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="sell_price_kg" class="block text-sm font-medium text-gray-700 mb-1">ราคาขาย (บาท/กก.)</label><input type="text" id="sell_price_kg" inputmode="decimal" placeholder="เช่น 12" value="12" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="total_farm_cost" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนการผลิตรวม (บาท)</label><input type="text" id="total_farm_cost" inputmode="decimal" placeholder="เช่น 80000" value="80000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="transport_cost_farm" class="block text-sm font-medium text-gray-700 mb-1">ค่าขนส่งและบรรจุภัณฑ์ (บาท)</label><input type="text" id="transport_cost_farm" inputmode="decimal" placeholder="เช่น 5000" value="5000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้จากการขาย</p><p id="farm_revenue" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">กำไรสุทธิ</p><p id="farm_net_profit" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const yieldKg = parseFloat((document.getElementById('total_yield_kg') as HTMLInputElement).value) || 0;
      const priceKg = parseFloat((document.getElementById('sell_price_kg') as HTMLInputElement).value) || 0;
      const cost = parseFloat((document.getElementById('total_farm_cost') as HTMLInputElement).value) || 0;
      const transport = parseFloat((document.getElementById('transport_cost_farm') as HTMLInputElement).value) || 0;
      const revenue = yieldKg * priceKg;
      const netProfit = revenue - cost - transport;
      (document.getElementById('farm_revenue') as HTMLElement).textContent = Math.round(revenue).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('farm_net_profit') as HTMLElement).textContent = Math.round(netProfit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('farm-produce-revenue');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
