---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเช่าซื้อ vs กู้ซื้อ 2569 — เปรียบเทียบต้นทุนรวม | Kamnuanlek';
const pageDescription = 'เปรียบเทียบต้นทุนระหว่างเช่าซื้อและกู้ซื้อ คำนวณค่างวด ดอกเบี้ยรวม และต้นทุนแท้จริง เพื่อตัดสินใจซื้อรถหรือสินค้าที่คุ้มค่าที่สุด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเช่าซื้อ-vs-กู้ซื้อ/`;

const faqData = [
  {
    question: 'เช่าซื้อกับกู้ซื้อต่างกันอย่างไร?',
    answer: 'เช่าซื้อ (Hire Purchase): กรรมสิทธิ์เป็นของผู้ให้เช่าซื้อจนกว่าจะผ่อนครบ ค่างวดรวมดอกเบี้ยแบบ flat rate สัญญาเฉพาะตัว โอนไม่ได้ กู้ซื้อ: กรรมสิทธิ์เป็นของผู้ซื้อทันที ธนาคารอาจให้ดอกเบี้ยต่ำกว่า และมีความยืดหยุ่นกว่าในการโอนกรรมสิทธิ์',
  },
  {
    question: 'เช่าซื้อรถยนต์ดอกเบี้ยเท่าไร?',
    answer: 'เช่าซื้อรถยนต์ในไทยใช้ flat rate ประมาณ 2.49-3.5% ต่อปี เทียบเท่า EIR ประมาณ 4.5-6.5% ต่อปี ส่วนกู้ซื้อผ่านธนาคารอาจได้ดอกเบี้ย 3.5-5% flat rate ขึ้นอยู่กับเงื่อนไขและการเจรจา',
  },
  {
    question: 'ควรเลือกเช่าซื้อหรือกู้ซื้อ?',
    answer: 'เช่าซื้อสะดวกกว่าสำหรับรถยนต์เพราะสัญญาเดียวจบ ไม่ต้องหาธนาคาร ส่วนกู้ซื้ออาจได้ดอกเบี้ยต่ำกว่าถ้าเจรจาดี และมีความยืดหยุ่นกว่าถ้าต้องการขายหรือโอน ควรเปรียบเทียบต้นทุนรวมก่อนตัดสินใจ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเช่าซื้อ vs กู้ซื้อ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเช่าซื้อ vs กู้ซื้อ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      คำนวณเช่าซื้อ vs กู้ซื้อ — เปรียบเทียบต้นทุนรวม
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">เปรียบเทียบค่างวด ดอกเบี้ยรวม และต้นทุนแท้จริงของเช่าซื้อและกู้ซื้อ</p>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6 mb-8">
      <form id="lease-buy-form" class="space-y-6">
        <div>
          <label for="asset-price" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ราคาสินค้า/รถ (บาท)</label>
          <input type="text" id="asset-price" inputmode="numeric" placeholder="เช่น 800,000"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
        </div>
        <div>
          <label for="down-payment" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">เงินดาวน์ (บาท)</label>
          <input type="text" id="down-payment" inputmode="numeric" placeholder="เช่น 160,000"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          <div class="border border-blue-200 dark:border-blue-700 rounded-lg p-4">
            <h3 class="font-semibold text-blue-700 dark:text-blue-300 mb-3">เช่าซื้อ (Hire Purchase)</h3>
            <div class="space-y-3">
              <div>
                <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">Flat Rate (%/ปี)</label>
                <input type="text" id="hire-rate" inputmode="decimal" placeholder="เช่น 2.99"
                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm" />
              </div>
              <div>
                <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">ระยะเวลา (เดือน)</label>
                <input type="text" id="hire-term" inputmode="numeric" placeholder="เช่น 60"
                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm" />
              </div>
            </div>
          </div>

          <div class="border border-green-200 dark:border-green-700 rounded-lg p-4">
            <h3 class="font-semibold text-green-700 dark:text-green-300 mb-3">กู้ซื้อ (Bank Loan)</h3>
            <div class="space-y-3">
              <div>
                <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">ดอกเบี้ย (%/ปี)</label>
                <input type="text" id="loan-rate" inputmode="decimal" placeholder="เช่น 4.5"
                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm" />
                <p class="text-xs text-gray-500 mt-1">ลดต้นลดดอก (reducing balance)</p>
              </div>
              <div>
                <label class="block text-xs text-gray-600 dark:text-gray-400 mb-1">ระยะเวลา (เดือน)</label>
                <input type="text" id="loan-term" inputmode="numeric" placeholder="เช่น 60"
                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm" />
              </div>
            </div>
          </div>
        </div>

        <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          เปรียบเทียบ
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">ผลเปรียบเทียบ</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm mb-4">
            <thead>
              <tr class="border-b border-gray-200 dark:border-gray-700">
                <th class="py-2 pr-4 text-left text-gray-600 dark:text-gray-400">รายการ</th>
                <th class="py-2 pr-4 text-right text-blue-700 dark:text-blue-300">เช่าซื้อ</th>
                <th class="py-2 text-right text-green-700 dark:text-green-300">กู้ซื้อ</th>
              </tr>
            </thead>
            <tbody id="compare-tbody" class="divide-y divide-gray-100 dark:divide-gray-700"></tbody>
          </table>
        </div>
        <div id="winner-box" class="p-3 rounded-lg text-sm font-semibold"></div>
      </div>
    </div>

    <GuardedAdSlot />

    <section class="prose prose-gray dark:prose-invert max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-3">ความแตกต่างสำคัญระหว่างเช่าซื้อและกู้ซื้อ</h2>
      <p>เช่าซื้อใช้ flat rate ทำให้ดูเหมือนดอกเบี้ยต่ำแต่ EIR จริงสูงกว่า ส่วนกู้ซื้อผ่านธนาคารใช้ reducing balance ที่โปร่งใสกว่า ควรเปรียบเทียบ EIR จึงจะตัดสินใจได้อย่างถูกต้อง</p>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณเช่าซื้อ-vs-กู้ซื้อ/" />
    <RelatedCalculators currentHref="/คำนวณเช่าซื้อ-vs-กู้ซื้อ/" />

    <div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg text-sm text-yellow-800 dark:text-yellow-300">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ เงื่อนไขจริงขึ้นอยู่กับสถาบันการเงินและข้อตกลง
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }

    document.getElementById('lease-buy-form')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const price = parseNum((document.getElementById('asset-price') as HTMLInputElement).value);
      const down = parseNum((document.getElementById('down-payment') as HTMLInputElement).value);
      const financed = price - down;
      if (!price || !financed) return;

      const hireRate = parseNum((document.getElementById('hire-rate') as HTMLInputElement).value) || 2.99;
      const hireTerm = parseNum((document.getElementById('hire-term') as HTMLInputElement).value) || 60;
      const loanRate = parseNum((document.getElementById('loan-rate') as HTMLInputElement).value) || 4.5;
      const loanTerm = parseNum((document.getElementById('loan-term') as HTMLInputElement).value) || 60;

      // Hire purchase: flat rate
      const hireInterest = financed * (hireRate / 100) * (hireTerm / 12);
      const hireMonthly = (financed + hireInterest) / hireTerm;
      const hireTotalCost = down + financed + hireInterest;

      // Bank loan: reducing balance
      const r = loanRate / 100 / 12;
      const loanMonthly = r === 0 ? financed / loanTerm : financed * (r * Math.pow(1 + r, loanTerm)) / (Math.pow(1 + r, loanTerm) - 1);
      const loanInterest = loanMonthly * loanTerm - financed;
      const loanTotalCost = down + financed + loanInterest;

      const rows = [
        ['วงเงินที่ต้องการ', fmt(financed) + ' บาท', fmt(financed) + ' บาท'],
        ['ค่างวด/เดือน', fmt(hireMonthly) + ' บาท', fmt(loanMonthly) + ' บาท'],
        ['ดอกเบี้ยรวม', fmt(hireInterest) + ' บาท', fmt(loanInterest) + ' บาท'],
        ['ต้นทุนรวม (รวมดาวน์)', fmt(hireTotalCost) + ' บาท', fmt(loanTotalCost) + ' บาท'],
      ];

      const tbody = document.getElementById('compare-tbody') as HTMLTableSectionElement;
      tbody.innerHTML = rows.map(([l, a, b]) => `<tr><td class="py-2 pr-4 text-gray-600 dark:text-gray-400">${l}</td><td class="py-2 pr-4 text-right font-medium">${a}</td><td class="py-2 text-right font-medium">${b}</td></tr>`).join('');

      const winnerBox = document.getElementById('winner-box') as HTMLElement;
      const diff = Math.abs(hireTotalCost - loanTotalCost);
      if (loanTotalCost < hireTotalCost) {
        winnerBox.className = 'p-3 rounded-lg text-sm font-semibold bg-green-50 dark:bg-green-900/30 text-green-800 dark:text-green-300';
        winnerBox.textContent = `กู้ซื้อประหยัดกว่า ${fmt(diff)} บาท`;
      } else if (hireTotalCost < loanTotalCost) {
        winnerBox.className = 'p-3 rounded-lg text-sm font-semibold bg-blue-50 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300';
        winnerBox.textContent = `เช่าซื้อประหยัดกว่า ${fmt(diff)} บาท`;
      } else {
        winnerBox.className = 'p-3 rounded-lg text-sm font-semibold bg-gray-50 dark:bg-gray-700 text-gray-700 dark:text-gray-300';
        winnerBox.textContent = 'ต้นทุนรวมเท่ากัน';
      }

      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('hire-vs-loan');
    });
  </script>
</BaseLayout>
