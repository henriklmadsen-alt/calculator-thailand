---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าไฟโซลาร์เซลล์ 2569 | ประหยัดค่าไฟ คืนทุนกี่ปี | Kamnuanlek';
const pageDescription = 'เครื่องคำนวณเงินออมโซลาร์เซลล์ คำนวณค่าไฟที่ประหยัดได้ ระยะคืนทุน ROI และ CO₂ ที่ลดได้ สำหรับบ้านอยู่อาศัยในประเทศไทย อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าไฟโซลาร์เซลล์/`;

const faqData = [
  {
    question: 'ติดโซลาร์เซลล์บ้านทั่วไปต้องใช้กี่ kW?',
    answer:
      'บ้านทั่วไปที่ค่าไฟ 2,000-4,000 บาท/เดือน มักติดระบบ 3-5 kW ส่วนค่าไฟ 5,000+ บาท/เดือน แนะนำ 5-10 kW ขึ้นอยู่กับพื้นที่หลังคาและงบประมาณ',
  },
  {
    question: 'โซลาร์เซลล์คืนทุนกี่ปี?',
    answer:
      'ระบบ On-grid บ้านอยู่อาศัยในไทยมักคืนทุนภายใน 6-9 ปี ขึ้นอยู่กับขนาดระบบ ค่าไฟเดิม ทิศหลังคา และภูมิภาค ระบบมีอายุใช้งาน 25 ปีขึ้นไป',
  },
  {
    question: 'ค่าดูแลรักษาโซลาร์เซลล์ต่อปีเท่าไร?',
    answer:
      'ค่าดูแลรักษาปกติประมาณ 2,000-3,000 บาท/ปี สำหรับการล้างแผง ตรวจสอบระบบ และทำความสะอาดทั่วไป อินเวอร์เตอร์อาจต้องเปลี่ยนช่วงปีที่ 10-15',
  },
  {
    question: 'ทิศหลังคาไหนดีที่สุดสำหรับติดโซลาร์เซลล์?',
    answer:
      'หลังคาหันทิศใต้ให้ผลผลิตดีที่สุดในประเทศไทย รองลงมาคือทิศตะวันออก-ตะวันตก (ได้ ~85%) หลังคาทิศเหนือได้น้อยที่สุด (~70%)',
  },
  {
    question: 'Peak Sun Hours ในไทยเท่าไร?',
    answer:
      'เฉลี่ย 4.0-4.8 ชม./วัน ภาคอีสานได้มากสุด (~4.8) ภาคใต้ได้น้อยสุด (~4.0) เนื่องจากมีเมฆมากกว่า กรุงเทพฯ และภาคกลางเฉลี่ย ~4.5 ชม./วัน',
  },
,
  { question: 'ค่าไฟฟ้าในไทยใช้อัตราแบบไหน?', answer: 'ใช้อัตราก้าวหน้า (Progressive Rate) — ยิ่งใช้มากยิ่งแพงต่อหน่วย MEA/PEA มีอัตรา 3 ช่วง ตามประกาศคณะกรรมการกำกับกิจการพลังงาน (กกพ.) บวกค่า FT (Fuel Tariff) ที่เปลี่ยนทุก 4 เดือน' },
  { question: 'ค่า FT คืออะไรและส่งผลต่อค่าไฟอย่างไร?', answer: 'FT (Fuel Adjustment Charge) คือค่าปรับตามต้นทุนเชื้อเพลิง ปรับทุก 4 เดือน ถ้า FT เป็นบวกหมายถึงค่าไฟแพงขึ้น ถ้าเป็นลบถูกลง ส่งผลให้ค่าไฟรายเดือนเปลี่ยนแปลงได้ 5-15%' },
  { question: 'ประหยัดค่าไฟได้อย่างไรบ้าง?', answer: 'ปิดอุปกรณ์ที่ไม่ใช้งาน (standby กิน 5-10% ของค่าไฟ), ใช้หลอด LED แทนหลอดเก่า, ตั้งแอร์ที่ 25-26°C, ซักผ้าครั้งเดียวให้เต็มถัง, ตรวจสอบฉนวนและซีลประตูตู้เย็น' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าไฟโซลาร์เซลล์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าไฟโซลาร์เซลล์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-green-100 bg-green-50 p-4">
      <p class="text-sm font-semibold text-green-700">อ้างอิงอัตราปี 2569</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณตามข้อมูลแสงอาทิตย์เฉลี่ยรายภูมิภาค Performance Ratio 80% และค่าเสื่อมสภาพ 0.5%/ปี</p>
      <p class="mt-1 text-xs font-medium text-green-800">ผลลัพธ์นี้เป็นการประมาณการเพื่อวางแผนการลงทุน</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณค่าไฟโซลาร์เซลล์ — ประหยัดเท่าไร คืนทุนกี่ปี</h1>

    <p class="mb-6 text-gray-600">
      กรอกขนาดระบบโซลาร์เซลล์ ค่าไฟปัจจุบัน และภูมิภาค เพื่อคำนวณผลผลิตไฟฟ้า เงินที่ประหยัดได้ต่อเดือน/ปี
      ระยะเวลาคืนทุน และผลตอบแทนตลอด 25 ปี
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="solar-form" class="space-y-5">
        <p id="solar-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลที่กรอกให้ครบถ้วน
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="system-size" class="mb-1 block text-sm font-medium text-gray-700">ขนาดระบบโซลาร์เซลล์ (kW)</label>
            <input
              type="text"
              id="system-size"
              inputmode="decimal"
              placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">บ้านทั่วไป 3-10 kW | 1 kW ≈ 2-3 แผง</p>
            <p id="system-size-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="monthly-bill" class="mb-1 block text-sm font-medium text-gray-700">ค่าไฟรายเดือนปัจจุบัน (บาท)</label>
            <input
              type="text"
              id="monthly-bill"
              inputmode="numeric"
              placeholder="เช่น 3000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ใช้ตัวเลขจากใบแจ้งค่าไฟ</p>
            <p id="monthly-bill-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="region" class="mb-1 block text-sm font-medium text-gray-700">ภูมิภาค</label>
            <select
              id="region"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">เลือกภูมิภาค</option>
              <option value="central">กรุงเทพฯ และภาคกลาง (4.5 ชม./วัน)</option>
              <option value="northeast">ภาคตะวันออกเฉียงเหนือ (4.8 ชม./วัน)</option>
              <option value="north">ภาคเหนือ (4.3 ชม./วัน)</option>
              <option value="south">ภาคใต้ (4.0 ชม./วัน)</option>
              <option value="east">ภาคตะวันออก (4.5 ชม./วัน)</option>
            </select>
            <p id="region-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="roof-direction" class="mb-1 block text-sm font-medium text-gray-700">ทิศหลังคาหลัก</label>
            <select
              id="roof-direction"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">เลือกทิศหลังคา</option>
              <option value="south">ทิศใต้ (ดีที่สุด — 100%)</option>
              <option value="east_west">ทิศตะวันออก-ตะวันตก (~85%)</option>
              <option value="north">ทิศเหนือ (~70%)</option>
            </select>
            <p id="roof-direction-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="electricity-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราค่าไฟเฉลี่ย (บาท/kWh) — ไม่กรอกใช้ค่าเริ่มต้น</label>
            <input
              type="text"
              id="electricity-rate"
              inputmode="decimal"
              placeholder="เช่น 4.2"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ค่าเริ่มต้น 4.2 บาท/kWh (เฉลี่ยบ้านใช้เกิน 150 หน่วย)</p>
            <p id="electricity-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="system-cost" class="mb-1 block text-sm font-medium text-gray-700">ราคาติดตั้งต่อ kW (บาท) — ไม่กรอกใช้ค่าเริ่มต้น</label>
            <input
              type="text"
              id="system-cost"
              inputmode="numeric"
              placeholder="เช่น 25000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ค่าเริ่มต้น 25,000 บาท/kW (ราคาตลาดปี 2569 ระบบ On-grid)</p>
            <p id="system-cost-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button
          type="submit"
          id="solar-submit-btn"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          กรอกข้อมูลให้ครบ
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>

        <!-- Key metrics grid -->
        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ประหยัดต่อเดือน</div>
            <div id="res-monthly-savings" class="text-lg font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ประหยัดต่อปี</div>
            <div id="res-annual-savings" class="text-lg font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ระยะคืนทุน</div>
            <div id="res-payback" class="text-lg font-bold text-amber-700">-</div>
          </div>
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">กำไรสุทธิ 25 ปี</div>
            <div id="res-net-savings-25yr" class="text-lg font-bold text-sky-700">-</div>
          </div>
        </div>

        <!-- Production & environment -->
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-yellow-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ผลิตไฟต่อวัน</div>
            <div id="res-daily-kwh" class="text-lg font-bold text-yellow-700">-</div>
          </div>
          <div class="rounded-lg bg-purple-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ผลิตไฟต่อปี</div>
            <div id="res-annual-kwh" class="text-lg font-bold text-purple-700">-</div>
          </div>
          <div class="rounded-lg bg-emerald-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ลด CO₂ ต่อปี</div>
            <div id="res-co2" class="text-lg font-bold text-emerald-700">-</div>
          </div>
        </div>

        <!-- Detail summary -->
        <div class="mb-6 space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ขนาดระบบ</span>
            <span id="res-system-size" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ราคาระบบรวม</span>
            <span id="res-total-cost" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ภูมิภาค</span>
            <span id="res-region" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">Peak Sun Hours</span>
            <span id="res-sun-hours" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ทิศหลังคา (ประสิทธิภาพ)</span>
            <span id="res-roof" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">อัตราค่าไฟที่ใช้</span>
            <span id="res-elec-rate" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ROI ตลอด 25 ปี</span>
            <span id="res-roi" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ค่าดูแลรักษารวม 25 ปี</span>
            <span id="res-maintenance" class="font-medium text-gray-900">-</span>
          </div>
        </div>

        <!-- Yearly breakdown table -->
        <h3 class="mb-2 text-base font-semibold text-gray-900">ตารางผลตอบแทนรายปี (25 ปี)</h3>
        <div class="overflow-x-auto rounded-md border border-gray-200">
          <table class="min-w-full text-sm">
            <thead class="bg-gray-50 text-gray-700">
              <tr>
                <th class="px-3 py-2 text-left font-medium">ปีที่</th>
                <th class="px-3 py-2 text-right font-medium">ผลิตไฟ (kWh)</th>
                <th class="px-3 py-2 text-right font-medium">ประหยัด (บาท)</th>
                <th class="px-3 py-2 text-right font-medium">ประหยัดสะสม (บาท)</th>
                <th class="px-3 py-2 text-right font-medium">กำไร/ขาดทุนสุทธิ (บาท)</th>
              </tr>
            </thead>
            <tbody id="yearly-breakdown-body" class="divide-y divide-gray-100 bg-white"></tbody>
          </table>
        </div>

        <p id="result-note" class="mt-4 rounded-md bg-green-50 px-3 py-2 text-xs text-green-800"></p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ผลิตไฟต่อวัน = ขนาดระบบ (kW) × Peak Sun Hours × Performance Ratio (0.80) × ตัวคูณทิศหลังคา</li>
        <li>ผลิตไฟต่อเดือน = ผลิตไฟต่อวัน × 30 วัน</li>
        <li>ประหยัดต่อเดือน = min(ผลิตไฟต่อเดือน × อัตราค่าไฟ, ค่าไฟรายเดือนเดิม)</li>
        <li>ค่าเสื่อมสภาพ = 0.5% ต่อปี (ปีที่ N ผลิตได้ = ปีที่ 1 × (1 − 0.005 × (N−1)))</li>
        <li>ระยะคืนทุน = ปีแรกที่ ผลประหยัดสะสม − ค่าดูแลสะสม − ราคาระบบ ≥ 0</li>
        <li>ROI = (กำไรสุทธิ 25 ปี ÷ ราคาระบบ) × 100%</li>
        <li>ลด CO₂ = ผลิตไฟต่อปี × 0.499 กก. CO₂/kWh (ค่า Emission Factor ของ EGAT 2024)</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <section class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-lg font-semibold text-gray-900">ตัวอย่างการคำนวณ</h2>
      <div class="space-y-3 text-sm text-gray-700">
        <p><strong>ตัวอย่าง:</strong> บ้านในกรุงเทพฯ ค่าไฟ 3,000 บาท/เดือน ติดระบบ 5 kW หลังคาทิศใต้</p>
        <ul class="list-disc space-y-1 pl-6">
          <li>ผลิตไฟต่อวัน = 5 × 4.5 × 0.80 × 1.0 = <strong>18.0 kWh/วัน</strong></li>
          <li>ผลิตไฟต่อเดือน = 18.0 × 30 = <strong>540 kWh/เดือน</strong></li>
          <li>ประหยัดต่อเดือน = min(540 × 4.2, 3,000) = min(2,268, 3,000) = <strong>2,268 บาท</strong></li>
          <li>ราคาระบบ = 5 × 25,000 = <strong>125,000 บาท</strong></li>
          <li>ประหยัดต่อปี = 2,268 × 12 = <strong>27,216 บาท</strong></li>
          <li>คืนทุนประมาณ = <strong>~5 ปี</strong> (หลังหักค่าดูแลรักษา)</li>
        </ul>
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณค่าไฟโซลาร์เซลล์/" />
    <RelatedCalculators currentHref="/คำนวณค่าไฟโซลาร์เซลล์/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <section class="mb-8 rounded-lg border border-gray-200 bg-white p-4 text-sm text-gray-700 shadow-sm sm:p-6">
      <h2 class="mb-2 text-base font-semibold text-gray-900">แหล่งอ้างอิงทางการ</h2>
      <ul class="list-disc space-y-1 pl-5">
        <li><a href="https://www.erc.or.th" target="_blank" rel="noopener noreferrer">กกพ. สำนักงานคณะกรรมการกำกับกิจการพลังงาน</a></li>
        <li><a href="https://www.dede.go.th" target="_blank" rel="noopener noreferrer">กรมพัฒนาพลังงานทดแทนและอนุรักษ์พลังงาน (พพ.)</a></li>
        <li><a href="https://www.egat.co.th" target="_blank" rel="noopener noreferrer">การไฟฟ้าฝ่ายผลิตแห่งประเทศไทย (กฟผ.)</a></li>
      </ul>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>หมายเหตุสำคัญ:</strong> เครื่องมือนี้เป็นการคำนวณเบื้องต้นเพื่อช่วยประเมินความคุ้มค่าของการติดตั้งโซลาร์เซลล์
      ผลลัพธ์จริงขึ้นอยู่กับสภาพอากาศ มุมเอียงหลังคา เงาที่บังแสง ยี่ห้อแผง และราคาตลาดจริง ควรปรึกษาผู้เชี่ยวชาญก่อนตัดสินใจ
    </div>
  </article>

  <script type="module">
    import {
      calculateSolarSavings,
      DEFAULT_ELECTRICITY_RATE,
      DEFAULT_SYSTEM_COST_PER_KW,
    } from '../../lib/solar-panel-calculator';

    function parseNum(value) {
      const normalized = String(value).replace(/,/g, '').trim();
      if (normalized === '') return NaN;
      const n = Number(normalized);
      return Number.isFinite(n) ? n : NaN;
    }

    function fmtMoney(amount) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(amount)} บาท`;
    }

    function fmtMoney2(amount) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(amount)} บาท`;
    }

    function fmtKwh(kwh) {
      return `${new Intl.NumberFormat('th-TH', { maximumFractionDigits: 1 }).format(kwh)} kWh`;
    }

    function fmtPercent(pct) {
      return `${new Intl.NumberFormat('th-TH', { maximumFractionDigits: 1 }).format(pct)}%`;
    }

    const regionLabels = {
      central: 'กรุงเทพฯ และภาคกลาง',
      northeast: 'ภาคตะวันออกเฉียงเหนือ',
      north: 'ภาคเหนือ',
      south: 'ภาคใต้',
      east: 'ภาคตะวันออก',
    };

    const roofLabels = {
      south: 'ทิศใต้ (100%)',
      east_west: 'ทิศตะวันออก-ตะวันตก (85%)',
      north: 'ทิศเหนือ (70%)',
    };

    const form = document.getElementById('solar-form');
    const submitBtn = document.getElementById('solar-submit-btn');
    const formError = document.getElementById('solar-form-error');
    const resultsDiv = document.getElementById('results');
    const breakdownBody = document.getElementById('yearly-breakdown-body');

    const fields = {
      systemSize: document.getElementById('system-size'),
      monthlyBill: document.getElementById('monthly-bill'),
      region: document.getElementById('region'),
      roofDirection: document.getElementById('roof-direction'),
      electricityRate: document.getElementById('electricity-rate'),
      systemCost: document.getElementById('system-cost'),
    };

    function setFieldError(id, message) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearFieldError(id) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      ['system-size-error', 'monthly-bill-error', 'region-error', 'roof-direction-error', 'electricity-rate-error', 'system-cost-error'].forEach(clearFieldError);
    }

    function updateSubmitState() {
      const requiredFilled = [
        fields.systemSize.value,
        fields.monthlyBill.value,
        fields.region.value,
        fields.roofDirection.value,
      ].every((v) => String(v).trim() !== '');

      const sizeVal = parseNum(fields.systemSize.value);
      const billVal = parseNum(fields.monthlyBill.value);
      const rateInput = String(fields.electricityRate.value).trim();
      const rateVal = rateInput === '' ? DEFAULT_ELECTRICITY_RATE : parseNum(rateInput);
      const costInput = String(fields.systemCost.value).trim();
      const costVal = costInput === '' ? DEFAULT_SYSTEM_COST_PER_KW : parseNum(costInput);

      const ready = requiredFilled
        && Number.isFinite(sizeVal) && sizeVal > 0
        && Number.isFinite(billVal) && billVal > 0
        && Number.isFinite(rateVal) && rateVal > 0
        && Number.isFinite(costVal) && costVal > 0;

      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณเงินออมโซลาร์เซลล์' : 'กรอกข้อมูลให้ครบ';
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
      submitBtn.classList.toggle('opacity-70', !ready);
    }

    Object.values(fields).forEach((field) => {
      field.addEventListener('input', () => { clearValidation(); updateSubmitState(); });
      field.addEventListener('change', () => { clearValidation(); updateSubmitState(); });
    });

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    updateSubmitState();

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      clearValidation();

      const systemSize = parseNum(fields.systemSize.value);
      const monthlyBill = parseNum(fields.monthlyBill.value);
      const region = String(fields.region.value || '');
      const roofDirection = String(fields.roofDirection.value || '');
      const rateInput = String(fields.electricityRate.value).trim();
      const electricityRate = rateInput === '' ? DEFAULT_ELECTRICITY_RATE : parseNum(rateInput);
      const costInput = String(fields.systemCost.value).trim();
      const systemCostPerKw = costInput === '' ? DEFAULT_SYSTEM_COST_PER_KW : parseNum(costInput);

      const validity = {
        systemSize: Number.isFinite(systemSize) && systemSize > 0,
        monthlyBill: Number.isFinite(monthlyBill) && monthlyBill > 0,
        region: ['central', 'northeast', 'north', 'south', 'east'].includes(region),
        roofDirection: ['south', 'east_west', 'north'].includes(roofDirection),
        electricityRate: Number.isFinite(electricityRate) && electricityRate > 0,
        systemCostPerKw: Number.isFinite(systemCostPerKw) && systemCostPerKw > 0,
      };

      if (!validity.systemSize) setFieldError('system-size-error', 'กรุณากรอกขนาดระบบเป็นตัวเลขมากกว่า 0');
      if (!validity.monthlyBill) setFieldError('monthly-bill-error', 'กรุณากรอกค่าไฟรายเดือนเป็นตัวเลขมากกว่า 0');
      if (!validity.region) setFieldError('region-error', 'กรุณาเลือกภูมิภาค');
      if (!validity.roofDirection) setFieldError('roof-direction-error', 'กรุณาเลือกทิศหลังคา');
      if (!validity.electricityRate) setFieldError('electricity-rate-error', 'อัตราค่าไฟต้องเป็นตัวเลขมากกว่า 0');
      if (!validity.systemCostPerKw) setFieldError('system-cost-error', 'ราคาติดตั้งต้องเป็นตัวเลขมากกว่า 0');

      if (!Object.values(validity).every(Boolean)) {
        formError.classList.remove('hidden');
        updateSubmitState();
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('solar_panel_savings');

      const result = calculateSolarSavings({
        systemSizeKw: systemSize,
        monthlyBillThb: monthlyBill,
        electricityRate,
        systemCostPerKw,
        region,
        roofDirection,
      });

      // Key metrics
      setText('res-monthly-savings', fmtMoney2(result.monthlySavingsThb));
      setText('res-annual-savings', fmtMoney2(result.annualSavingsThb));
      setText('res-payback', result.paybackYears > 0 ? `${result.paybackYears} ปี` : 'ไม่คืนทุนใน 25 ปี');
      setText('res-net-savings-25yr', fmtMoney(result.netSavings25yr));

      // Production
      setText('res-daily-kwh', fmtKwh(result.dailyProductionKwh));
      setText('res-annual-kwh', fmtKwh(result.annualProductionKwh));
      setText('res-co2', `${new Intl.NumberFormat('th-TH', { maximumFractionDigits: 2 }).format(result.co2ReductionTonsPerYear)} ตัน`);

      // Details
      setText('res-system-size', `${result.systemSizeKw} kW`);
      setText('res-total-cost', fmtMoney(result.totalSystemCost));
      setText('res-region', regionLabels[result.region] || result.region);
      setText('res-sun-hours', `${result.peakSunHours} ชม./วัน`);
      setText('res-roof', roofLabels[roofDirection] || roofDirection);
      setText('res-elec-rate', `${electricityRate} บาท/kWh`);
      setText('res-roi', fmtPercent(result.roiPercent));
      setText('res-maintenance', fmtMoney(result.totalMaintenance25yr));

      // Yearly breakdown table
      breakdownBody.innerHTML = '';
      result.yearlyBreakdown.forEach((row) => {
        const tr = document.createElement('tr');
        const isPayback = row.netCumulativeSavingsThb >= 0;
        const rowClass = isPayback ? 'bg-green-50' : '';
        tr.className = rowClass;
        tr.innerHTML = `
          <td class="px-3 py-2 text-gray-700">${row.year}</td>
          <td class="px-3 py-2 text-right text-gray-700">${new Intl.NumberFormat('th-TH', { maximumFractionDigits: 0 }).format(row.productionKwh)}</td>
          <td class="px-3 py-2 text-right text-gray-700">${new Intl.NumberFormat('th-TH', { maximumFractionDigits: 0 }).format(row.savingsThb)}</td>
          <td class="px-3 py-2 text-right text-gray-700">${new Intl.NumberFormat('th-TH', { maximumFractionDigits: 0 }).format(row.cumulativeSavingsThb)}</td>
          <td class="px-3 py-2 text-right font-medium ${row.netCumulativeSavingsThb >= 0 ? 'text-green-700' : 'text-red-600'}">${new Intl.NumberFormat('th-TH', { maximumFractionDigits: 0 }).format(row.netCumulativeSavingsThb)}</td>
        `;
        breakdownBody.appendChild(tr);
      });

      const noteParts = [
        `ระบบ ${result.systemSizeKw} kW`,
        `Peak Sun Hours ${result.peakSunHours} ชม./วัน`,
        'รวมค่าเสื่อมสภาพ 0.5%/ปี และค่าดูแลรักษา 2,000 บาท/ปี',
      ];
      setText('result-note', noteParts.join(' | '));

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณเงินออมโซลาร์เซลล์';
      trackCalculatorComplete('solar_panel_savings', result.netSavings25yr);
      trackCalculatorUsed('solar_panel_savings');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          trackResultViewed('solar_panel_savings');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
