---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Loan Calculators Comparison — Home vs Car vs Personal Loans | Kamnuanlek"
  description="Compare home loans, car loans, and personal loans. Calculate monthly payments, total interest, and find the best option."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-8">Loan Comparison Guide</h1>

    <div class="mb-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-6 bg-white border border-gray-200 rounded-lg">
        <h3 class="text-xl font-bold text-gray-900 mb-4">🏠 Home Loan</h3>
        <p class="text-gray-600 mb-4">Borrow for property purchase. Longest terms (10-25 years), lowest rates.</p>
        <a href="/คำนวณผ่อนบ้าน/" class="text-primary-600 hover:underline font-medium">Calculate →</a>
      </div>
      <div class="p-6 bg-white border border-gray-200 rounded-lg">
        <h3 class="text-xl font-bold text-gray-900 mb-4">🚗 Car Loan</h3>
        <p class="text-gray-600 mb-4">Borrow for vehicle. Medium terms (3-7 years), moderate rates.</p>
        <a href="/คำนวณผ่อนรถ/" class="text-primary-600 hover:underline font-medium">Calculate →</a>
      </div>
      <div class="p-6 bg-white border border-gray-200 rounded-lg">
        <h3 class="text-xl font-bold text-gray-900 mb-4">💳 Personal Loan</h3>
        <p class="text-gray-600 mb-4">Borrow for any purpose. Short terms (1-5 years), highest rates.</p>
        <a href="/คำนวณผ่อนกู้/" class="text-primary-600 hover:underline font-medium">Calculate →</a>
      </div>
    </div>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">How to Choose</h2>
      <div class="space-y-4">
        <div class="p-4 bg-gray-50 rounded-lg">
          <h3 class="font-semibold text-gray-900 mb-2">1. Compare Interest Rates</h3>
          <p class="text-gray-700">Home loans typically 2-4%, car loans 4-8%, personal loans 8-15%</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-lg">
          <h3 class="font-semibold text-gray-900 mb-2">2. Calculate Total Interest</h3>
          <p class="text-gray-700">Use calculators to see how much you'll pay over the loan term</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-lg">
          <h3 class="font-semibold text-gray-900 mb-2">3. Check Monthly Payment</h3>
          <p class="text-gray-700">Ensure payment fits your budget comfortably</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
