---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เปรียบเทียบสินเชื่อ — บ้าน รถ บุคคล ดอกเบี้ยและค่างวด | Kamnuanlek"
  description="เปรียบเทียบสินเชื่อบ้าน สินเชื่อรถ และสินเชื่อบุคคลแบบ side-by-side คำนวณค่างวดรายเดือน ดอกเบี้ยรวม และเลือกสินเชื่อที่เหมาะกับคุณ"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เปรียบเทียบสินเชื่อ — บ้าน รถ บุคคล ดอกเบี้ยและค่างวด", "item": "https://www.kamnuanlek.com/เปรียบเทียบสินเชื่อ/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-8">คู่มือเปรียบเทียบสินเชื่อ</h1>

    <div class="mb-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="p-6 bg-white border border-gray-200 rounded-lg">
        <h3 class="text-xl font-bold text-gray-900 mb-4">🏠 สินเชื่อบ้าน</h3>
        <p class="text-gray-600 mb-4">กู้เพื่อซื้ออสังหาริมทรัพย์ ระยะเวลานานที่สุด (10-25 ปี) อัตราดอกเบี้ยต่ำที่สุด</p>
        <a href="/คำนวณผ่อนบ้าน/" class="text-primary-600 hover:underline font-medium">คำนวณ →</a>
      </div>
      <div class="p-6 bg-white border border-gray-200 rounded-lg">
        <h3 class="text-xl font-bold text-gray-900 mb-4">🚗 สินเชื่อรถยนต์</h3>
        <p class="text-gray-600 mb-4">กู้เพื่อซื้อรถ ระยะเวลาปานกลาง (3-7 ปี) อัตราดอกเบี้ยปานกลาง</p>
        <a href="/คำนวณผ่อนรถ/" class="text-primary-600 hover:underline font-medium">คำนวณ →</a>
      </div>
      <div class="p-6 bg-white border border-gray-200 rounded-lg">
        <h3 class="text-xl font-bold text-gray-900 mb-4">💳 สินเชื่อบุคคล</h3>
        <p class="text-gray-600 mb-4">กู้เพื่อวัตถุประสงค์ทั่วไป ระยะเวลาสั้น (1-5 ปี) อัตราดอกเบี้ยสูงที่สุด</p>
        <a href="/คำนวณผ่อนกู้/" class="text-primary-600 hover:underline font-medium">คำนวณ →</a>
      </div>
    </div>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">วิธีเลือกสินเชื่อที่เหมาะสม</h2>
      <div class="space-y-4">
        <div class="p-4 bg-gray-50 rounded-lg">
          <h3 class="font-semibold text-gray-900 mb-2">1. เปรียบเทียบอัตราดอกเบี้ย</h3>
          <p class="text-gray-700">สินเชื่อบ้านโดยทั่วไป 2-4% สินเชื่อรถ 4-8% สินเชื่อบุคคล 8-15%</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-lg">
          <h3 class="font-semibold text-gray-900 mb-2">2. คำนวณดอกเบี้ยรวม</h3>
          <p class="text-gray-700">ใช้เครื่องคำนวณเพื่อดูว่าต้องจ่ายดอกเบี้ยรวมเท่าไรตลอดระยะเวลาสัญญา</p>
        </div>
        <div class="p-4 bg-gray-50 rounded-lg">
          <h3 class="font-semibold text-gray-900 mb-2">3. ตรวจสอบค่างวดรายเดือน</h3>
          <p class="text-gray-700">ตรวจสอบว่าค่างวดพอดีกับงบประมาณของคุณอย่างสบายๆ</p>
        </div>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือการเงินเพิ่มเติม</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 เครื่องคำนวณการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">ภาษี ออมเงิน เงินเดือน และเครื่องคำนวณการลงทุน</p>
        </a>
        <a href="/เครื่องคำนวณการเงินชั้นยอด/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 เครื่องมือสำคัญ 10 อันดับ</span>
          <p class="text-gray-600 text-sm mt-2">เครื่องคำนวณการเงินที่มีประโยชน์ที่สุดสำหรับนักลงทุนไทย</p>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
