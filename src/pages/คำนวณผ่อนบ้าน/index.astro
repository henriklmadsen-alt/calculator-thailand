  <script>
    interface LoanSimulation {
      monthlyPayment: number;
      totalInterest: number;
      totalPaid: number;
      payoffMonths: number;
    }

    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function hasInvalidNumber(v: string): boolean {
      const normalized = v.replace(/,/g, '').trim();
      return normalized !== '' && Number.isNaN(Number(normalized));
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    function calcMonthlyPayment(principal: number, annualRate: number, months: number): number {
      if (months <= 0) return 0;
      const monthlyRate = annualRate / 100 / 12;
      if (monthlyRate === 0) return principal / months;
      const factor = Math.pow(1 + monthlyRate, months);
      return principal * (monthlyRate * factor) / (factor - 1);
    }

    function simulateLoan(principal: number, annualRate: number, months: number, extraPayment: number): LoanSimulation {
      if (principal <= 0 || months <= 0) {
        return { monthlyPayment: 0, totalInterest: 0, totalPaid: 0, payoffMonths: 0 };
      }

      const monthlyRate = annualRate / 100 / 12;
      const baseMonthly = calcMonthlyPayment(principal, annualRate, months);

      let balance = principal;
      let totalInterest = 0;
      let totalPaid = 0;
      let payoffMonths = 0;

      // Safety cap keeps loop bounded even when malformed values are entered.
      const maxLoops = months + 600;

      while (balance > 0.01 && payoffMonths < maxLoops) {
        const interestPart = monthlyRate > 0 ? balance * monthlyRate : 0;
        const scheduledPayment = baseMonthly + extraPayment;
        const payment = Math.min(scheduledPayment, balance + interestPart);
        const principalPart = Math.max(0, payment - interestPart);

        totalInterest += interestPart;
        totalPaid += payment;
        balance = Math.max(0, balance - principalPart);
        payoffMonths += 1;
      }

      return {
        monthlyPayment: baseMonthly,
        totalInterest,
        totalPaid,
        payoffMonths,
      };
    }

    function monthLabel(months: number): string {
      const years = Math.floor(months / 12);
      const rem = months % 12;
      if (years <= 0) return `${months} เดือน`;
      if (rem === 0) return `${years} ปี`;
      return `${years} ปี ${rem} เดือน`;
    }

    const form = document.getElementById('mortgage-form') as HTMLFormElement;
    const formError = document.getElementById('mortgage-form-error') as HTMLElement;
    const submitBtn = document.getElementById('mortgage-submit-btn') as HTMLButtonElement;
    const nextActionCard = document.getElementById('mortgage-next-action') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const modeRefinance = document.getElementById('mode-refinance') as HTMLElement;
    const modeNewHome = document.getElementById('mode-new-home') as HTMLElement;
    const outstandingBalanceInput = document.getElementById('outstanding-balance') as HTMLInputElement;
    const homePriceInput = document.getElementById('home-price') as HTMLInputElement;
    const downPaymentPctInput = document.getElementById('down-payment-pct') as HTMLInputElement;
    const currentRateInput = document.getElementById('current-rate') as HTMLInputElement;
    const refinanceRateInput = document.getElementById('refinance-rate') as HTMLInputElement;
    const remainingYearsInput = document.getElementById('remaining-years') as HTMLInputElement;
    const refinanceTermYearsInput = document.getElementById('refinance-term-years') as HTMLInputElement;
    const newHomeRateInput = document.getElementById('new-home-rate') as HTMLInputElement;
    const newHomeYearsInput = document.getElementById('new-home-years') as HTMLInputElement;
    const newHomeLoanAmount = document.getElementById('new-home-loan-amount') as HTMLElement;
    let hasTrackedStart = false;

    function setFieldError(elementId: string, message: string) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearFieldError(elementId: string) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      clearFieldError('outstanding-balance-error');
      clearFieldError('home-price-error');
    }

    function updateSubmitState() {
      const mode = getSelectedMode();
      const ready =
        mode === 'new-home'
          ? parseNum(homePriceInput.value) > 0 && parseNum(newHomeRateInput.value) > 0 && parseNum(newHomeYearsInput.value) > 0
          : parseNum(outstandingBalanceInput.value) > 0 &&
            parseNum(currentRateInput.value) > 0 &&
            parseNum(refinanceRateInput.value) > 0 &&
            parseNum(remainingYearsInput.value) > 0 &&
            parseNum(refinanceTermYearsInput.value) > 0;
      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณทันที' : 'กรอกข้อมูลให้ครบ';
      submitBtn.classList.toggle('opacity-70', !ready);
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
    }

    function getSelectedMode(): 'refinance' | 'new-home' {
      const selected = document.querySelector('input[name="calc-mode"]:checked') as HTMLInputElement;
      return (selected?.value as 'refinance' | 'new-home') || 'refinance';
    }

    function updateModeVisibility() {
      const mode = getSelectedMode();
      if (mode === 'refinance') {
        modeRefinance.classList.remove('hidden');
        modeNewHome.classList.add('hidden');
      } else {
        modeRefinance.classList.add('hidden');
        modeNewHome.classList.remove('hidden');
      }
      clearValidation();
      updateSubmitState();
    }

    function updateNewHomePreview() {
      const homePrice = parseNum(homePriceInput.value);
      const downPct = parseNum(downPaymentPctInput.value);
      const downAmount = homePrice * Math.min(100, downPct) / 100;
      const loanAmount = Math.max(0, homePrice - downAmount);
      newHomeLoanAmount.textContent = fmt(loanAmount) + ' บาท';
    }

    document.querySelectorAll('input[name="calc-mode"]').forEach((radio) => {
      radio.addEventListener('change', () => {
        updateModeVisibility();
      });
    });

    homePriceInput.addEventListener('input', updateNewHomePreview);
    downPaymentPctInput.addEventListener('input', updateNewHomePreview);
    homePriceInput.addEventListener('input', () => {
      clearFieldError('home-price-error');
      formError.classList.add('hidden');
      updateSubmitState();
    });
    outstandingBalanceInput.addEventListener('input', () => {
      clearFieldError('outstanding-balance-error');
      formError.classList.add('hidden');
      updateSubmitState();
    });
    [currentRateInput, refinanceRateInput, remainingYearsInput, refinanceTermYearsInput, newHomeRateInput, newHomeYearsInput].forEach((input) => {
      input.addEventListener('input', () => {
        formError.classList.add('hidden');
        updateSubmitState();
      });
    });
    updateModeVisibility();
    updateNewHomePreview();

    form.addEventListener('input', () => {
      if (!hasTrackedStart) {
        trackCalculatorStart('mortgage_refinance');
        hasTrackedStart = true;
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearValidation();

      const mode = getSelectedMode();

      if (mode === 'new-home') {
        if (hasInvalidNumber(homePriceInput.value)) {
          formError.classList.remove('hidden');
          setFieldError('home-price-error', 'รูปแบบข้อมูลไม่ถูกต้อง');
          homePriceInput.focus();
          updateSubmitState();
          return;
        }

        const homePrice = parseNum(homePriceInput.value);
        const downPct = parseNum((document.getElementById('down-payment-pct') as HTMLInputElement).value);
        const annualRate = parseNum(newHomeRateInput.value);
        const years = parseNum(newHomeYearsInput.value);
        const months = Math.round(years * 12);

        if (homePrice <= 0 || years <= 0) {
          formError.classList.remove('hidden');
          setFieldError('home-price-error', 'กรุณากรอกจำนวนเงินมากกว่า 0');
          homePriceInput.focus();
          updateSubmitState();
          return;
        }

        if (!hasTrackedStart) {
          trackCalculatorStart('mortgage_refinance');
          hasTrackedStart = true;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'กำลังคำนวณ...';

        const downAmount = homePrice * Math.min(100, downPct) / 100;
        const principal = Math.max(0, homePrice - downAmount);
        const scenario = simulateLoan(principal, annualRate, months, 0);

        (document.getElementById('res-current-monthly') as HTMLElement).textContent = fmt(scenario.monthlyPayment) + ' บาท';
        (document.getElementById('res-new-monthly') as HTMLElement).textContent = '-';
        (document.getElementById('res-monthly-delta') as HTMLElement).textContent = '-';
        (document.getElementById('res-total-saving') as HTMLElement).textContent = '-';
        (document.getElementById('res-current-interest') as HTMLElement).textContent = fmt(scenario.totalInterest) + ' บาท';
        (document.getElementById('res-new-interest') as HTMLElement).textContent = '-';
        (document.getElementById('res-refi-fees') as HTMLElement).textContent = '-';
        (document.getElementById('res-payoff-months') as HTMLElement).textContent = monthLabel(scenario.payoffMonths);
        (document.getElementById('res-break-even') as HTMLElement).textContent = 'ไม่เกี่ยวข้องในโหมดนี้';
        (document.getElementById('res-summary-note') as HTMLElement).textContent =
          `ผ่อนบ้านใหม่: ยอดกู้ ${fmt(principal)} บาท ค่างวดประมาณ ${fmt(scenario.monthlyPayment)} บาท/เดือน ดอกเบี้ยรวมประมาณ ${fmt(scenario.totalInterest)} บาท`;
      } else {
        if (hasInvalidNumber(outstandingBalanceInput.value)) {
          formError.classList.remove('hidden');
          setFieldError('outstanding-balance-error', 'รูปแบบข้อมูลไม่ถูกต้อง');
          outstandingBalanceInput.focus();
          updateSubmitState();
          return;
        }

        const principal = parseNum(outstandingBalanceInput.value);
        const remainingYears = parseNum(remainingYearsInput.value);
        const currentRate = parseNum(currentRateInput.value);
        const newRate = parseNum(refinanceRateInput.value);
        const newYears = parseNum(refinanceTermYearsInput.value);
        const fees = parseNum((document.getElementById('refinance-fees') as HTMLInputElement).value);
        const extraPayment = parseNum((document.getElementById('extra-payment') as HTMLInputElement).value);

        if (principal <= 0 || remainingYears <= 0 || newYears <= 0) {
          formError.classList.remove('hidden');
          setFieldError('outstanding-balance-error', 'กรุณากรอกจำนวนเงินมากกว่า 0');
          outstandingBalanceInput.focus();
          updateSubmitState();
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'กำลังคำนวณ...';

        const currentMonths = Math.round(remainingYears * 12);
        const newMonths = Math.round(newYears * 12);
        const currentScenario = simulateLoan(principal, currentRate, currentMonths, extraPayment);
        const newScenario = simulateLoan(principal, newRate, newMonths, extraPayment);

        const monthlyDelta = currentScenario.monthlyPayment - newScenario.monthlyPayment;
        const currentTotalCost = currentScenario.totalPaid;
        const newTotalCost = newScenario.totalPaid + fees;
        const totalSaving = currentTotalCost - newTotalCost;

        const breakEvenMonths = monthlyDelta > 0 ? Math.ceil(fees / monthlyDelta) : 0;

        (document.getElementById('res-current-monthly') as HTMLElement).textContent = fmt(currentScenario.monthlyPayment) + ' บาท';
        (document.getElementById('res-new-monthly') as HTMLElement).textContent = fmt(newScenario.monthlyPayment) + ' บาท';
        (document.getElementById('res-monthly-delta') as HTMLElement).textContent =
          (monthlyDelta >= 0 ? '-' : '+') + fmt(Math.abs(monthlyDelta)) + ' บาท';
        (document.getElementById('res-total-saving') as HTMLElement).textContent =
          (totalSaving >= 0 ? '+' : '-') + fmt(Math.abs(totalSaving)) + ' บาท';
        (document.getElementById('res-current-interest') as HTMLElement).textContent = fmt(currentScenario.totalInterest) + ' บาท';
        (document.getElementById('res-new-interest') as HTMLElement).textContent = fmt(newScenario.totalInterest) + ' บาท';
        (document.getElementById('res-refi-fees') as HTMLElement).textContent = fmt(fees) + ' บาท';
        (document.getElementById('res-payoff-months') as HTMLElement).textContent =
          `${monthLabel(currentScenario.payoffMonths)} / ${monthLabel(newScenario.payoffMonths)}`;
        (document.getElementById('res-break-even') as HTMLElement).textContent =
          breakEvenMonths > 0 ? `${monthLabel(breakEvenMonths)}` : 'ไม่มีจุดคุ้มทุนจากค่างวดรายเดือน';

        const summary = document.getElementById('res-summary-note') as HTMLElement;
        if (totalSaving > 0) {
          summary.className = 'p-3 rounded-lg text-sm bg-green-50 border border-green-200 text-green-900';
          summary.textContent =
            `แผนรีไฟแนนซ์คาดว่าคุ้มกว่า โดยประหยัดสุทธิประมาณ ${fmt(totalSaving)} บาท` +
            (breakEvenMonths > 0 ? ` และถึงจุดคุ้มทุนราว ${monthLabel(breakEvenMonths)}` : '');
        } else if (totalSaving < 0) {
          summary.className = 'p-3 rounded-lg text-sm bg-amber-50 border border-amber-200 text-amber-900';
          summary.textContent =
            `แผนรีไฟแนนซ์ยังไม่คุ้มตามตัวเลขปัจจุบัน (เสียเพิ่มประมาณ ${fmt(Math.abs(totalSaving))} บาท) ` +
            'ลองปรับระยะเวลาใหม่หรือเจรจาดอกเบี้ย/ค่าธรรมเนียมเพิ่มเติม';
        } else {
          summary.className = 'p-3 rounded-lg text-sm bg-primary-50 border border-primary-200 text-primary-900';
          summary.textContent = 'ผลรวมใกล้เคียงกันมาก ควรตัดสินใจจากสภาพคล่องรายเดือนและความเสี่ยงดอกเบี้ยในอนาคต';
        }
      }

      resultsDiv.classList.remove('hidden');
      nextActionCard.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('mortgage_refinance');
      trackCalculatorUsed('mortgage_refinance');
    });

    document.querySelectorAll('[data-next-action-link]').forEach((link) => {
      link.addEventListener('click', () => {
        if (typeof window.gtag === 'function') {
          const href = (link as HTMLAnchorElement).getAttribute('href') || '';
          window.gtag('event', 'next_action_click', {
            calculator: 'mortgage_refinance',
            target_href: href,
          });
        }
      });
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          trackResultViewed('mortgage_refinance');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
