---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณผ่อนบ้าน ดอกเบี้ย 2569 | Calculator Thailand';
const pageDescription = 'คำนวณผ่อนบ้าน ดอกเบี้ย งวด จำนวนเงิน ตารางผ่อน เงินกู้บ้าน พร้อมตารางอื่น 2569 ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณผ่อนบ้าน/`;

const faqData = [
  {
    question: 'รีไฟแนนซ์บ้านคุ้มเมื่อไร?',
    answer: 'มักคุ้มเมื่ออัตราดอกเบี้ยใหม่ต่ำลงชัดเจน และยอดประหยัดรวมมากกว่าค่าธรรมเนียมรีไฟแนนซ์ภายในระยะเวลาที่คุณตั้งใจถือหนี้',
  },
  {
    question: 'จุดคุ้มทุนรีไฟแนนซ์คืออะไร?',
    answer: 'คือจำนวนเดือนที่ส่วนต่างค่างวดสะสมเท่ากับค่าใช้จ่ายรีไฟแนนซ์ เมื่อเกินจุดนี้ไปแล้วผลรวมมักเริ่มคุ้ม',
  },
  {
    question: 'ควรโปะบ้านร่วมกับรีไฟแนนซ์ไหม?',
    answer: 'ถ้ากระแสเงินสดไหว การโปะเงินต้นจะช่วยลดดอกเบี้ยรวมได้เร็วขึ้นทั้งในแผนเดิมและแผนรีไฟแนนซ์',
  },
  {
    question: 'ระยะเวลากู้ใหม่ควรเท่าของเดิมหรือยืดออก?',
    answer: 'ถ้าต้องการลดดอกเบี้ยรวมควรเลือกใกล้เคียงหรือสั้นกว่าเดิม แต่ถ้าต้องการลดภาระรายเดือนอาจยืดระยะเวลาได้โดยยอมรับดอกเบี้ยรวมที่เพิ่มขึ้น',
  },
  {
    question: 'ข้อผิดพลาดทั่วไปในการคำนวณผ่อนบ้านที่ต้องหลีกเลี่ยง?',
    answer: 'ข้อผิดพลาดทั่วไป ได้แก่ (1) ลืมนำยอดหนี้คงเหลือปัจจุบันแทนเงินกู้เดิม (2) ใช้อัตราดอกเบี้ยจากสัญญาเก่าแทนสัญญาใหม่ (3) ไม่รวมค่าธรรมเนียมรีไฟแนนซ์ (4) เปรียบเทียบเปอร์เซ็นต์ดอกเบี้ยไม่เท่า (flat vs effective) (5) ลืมค่าประกันภัชระบบแรงงาน และ (6) คำนวณ break-even ไม่คำนึงถึงโปะเงินต้น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผ่อนบ้านและรีไฟแนนซ์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'THB',
  },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณผ่อนบ้านและเปรียบเทียบรีไฟแนนซ์',
  description: 'ขั้นตอนการใช้เครื่องคำนวณผ่อนบ้าน เปรียบเทียบแผนเดิมกับรีไฟแนนซ์ และหาจุดคุ้มทุน',
  step: [
    {
      '@type': 'HowToStep',
      name: 'เลือกโหมดการคำนวณ',
      text: 'ระบุว่าต้องการคำนวณผ่อนบ้านแบบ "รีไฟแนนซ์เปรียบเทียบ" (เทียบแผนเดิมกับแผนใหม่) หรือ "ซื้อบ้านใหม่" (คำนวณแผนเดี่ยว)',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกข้อมูลสัญญาเดิม',
      text: 'ป้อนข้อมูลจากสัญญาปัจจุบัน: สินเชื่อก่อนอื่น ระยะเวลาทั้งหมด (ปี) ระยะเวลาที่ผ่านไป (ปี) และอัตราดอกเบี้ยต่อปี (%)',
    },
    {
      '@type': 'HowToStep',
      name: 'ป้อนข้อมูลสัญญารีไฟแนนซ์ (หากเป็นโหมดเปรียบเทียบ)',
      text: 'หากเลือกโหมดรีไฟแนนซ์ ให้ป้อนข้อมูลแผนใหม่: สินเชื่อใหม่ ระยะเวลาใหม่ (ปี) อัตราดอกเบี้ยใหม่ (%) และค่าธรรมเนียมรีไฟแนนซ์ (บาท)',
    },
    {
      '@type': 'HowToStep',
      name: 'ป้อนจำนวนเงินที่ต้องการเพิ่มหรือลด',
      text: 'ถ้าต้องการโปะหนี้ (ลดเงินต้น) หรือเพิ่มเงินกู้เพิ่มเติม ให้ป้อนจำนวนนั้น หากไม่มีให้ใส่ 0',
    },
    {
      '@type': 'HowToStep',
      name: 'กดปุ่มคำนวณ',
      text: 'หลังจากกรอกข้อมูลครบแล้ว ให้คลิกปุ่ม "คำนวณผ่อนบ้าน" เพื่อให้ระบบคำนวณผลลัพธ์',
    },
    {
      '@type': 'HowToStep',
      name: 'ตรวจสอบผลการเปรียบเทียบ',
      text: 'ดูผลลัพธ์ที่แสดง ประกอบด้วย ค่างวดรายเดือน ดอกเบี้ยรวมทั้งสัญญา ยอดประหยัดหรือค่าใช้จ่ายเพิ่มเติม และจุดคุ้มทุน (เมื่อรีไฟแนนซ์คุ้ม)',
    },
  ],
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผ่อนบ้านและรีไฟแนนซ์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณผ่อนบ้าน + เปรียบเทียบรีไฟแนนซ์ 2569 (2026)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่างวดบ้านแบบลดต้นลดดอก และเทียบแผนเดิมกับแผนรีไฟแนนซ์แบบเห็นตัวเลขชัดเจน:
      ค่างวดใหม่ ดอกเบี้ยรวม ค่าใช้จ่ายรีไฟแนนซ์ และจุดคุ้มทุน
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="mortgage-form" class="space-y-6">
        <p id="mortgage-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>
        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">โหมดคำนวณ</legend>
          <div class="grid gap-3 sm:grid-cols-2">
            <label class="flex items-start gap-2 p-3 rounded-lg border border-primary-200 bg-primary-50">
              <input type="radio" name="calc-mode" value="refinance" checked class="mt-0.5 w-4 h-4 text-primary-600" />
              <span class="text-sm text-gray-700">
                <span class="block font-semibold text-gray-900">รีไฟแนนซ์เปรียบเทียบ (แนะนำ)</span>
                เทียบสัญญาเดิม vs สัญญาใหม่ พร้อมจุดคุ้มทุน
              </span>
            </label>
            <label class="flex items-start gap-2 p-3 rounded-lg border border-gray-200">
              <input type="radio" name="calc-mode" value="new-home" class="mt-0.5 w-4 h-4 text-primary-600" />
              <span class="text-sm text-gray-700">
                <span class="block font-semibold text-gray-900">ซื้อบ้านใหม่</span>
                คำนวณค่างวดจากราคาบ้านและเงินดาวน์
              </span>
            </label>
          </div>
        </fieldset>

        <div id="mode-refinance" class="space-y-5">
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="outstanding-balance" class="block text-sm font-medium text-gray-700 mb-1">
                เงินต้นคงเหลือ (บาท)
              </label>
              <input
                type="text"
                id="outstanding-balance"
                inputmode="numeric"
                value="2500000"
                placeholder="เช่น 2,500,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
              <p id="outstanding-balance-error" class="mt-1 hidden text-sm text-red-600"></p>
            </div>
            <div>
              <label for="remaining-years" class="block text-sm font-medium text-gray-700 mb-1">
                ระยะเวลาคงเหลือ (ปี)
              </label>
              <input
                type="text"
                id="remaining-years"
                inputmode="numeric"
                value="22"
                placeholder="เช่น 22"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="current-rate" class="block text-sm font-medium text-gray-700 mb-1">
                ดอกเบี้ยแผนเดิม (% ต่อปี)
              </label>
              <input
                type="text"
                id="current-rate"
                inputmode="decimal"
                value="6.2"
                placeholder="เช่น 6.2"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="refinance-rate" class="block text-sm font-medium text-gray-700 mb-1">
                ดอกเบี้ยแผนรีไฟแนนซ์ (% ต่อปี)
              </label>
              <input
                type="text"
                id="refinance-rate"
                inputmode="decimal"
                value="4.2"
                placeholder="เช่น 4.2"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <label for="refinance-term-years" class="block text-sm font-medium text-gray-700 mb-1">
                ระยะเวลาแผนใหม่ (ปี)
              </label>
              <input
                type="text"
                id="refinance-term-years"
                inputmode="numeric"
                value="22"
                placeholder="เช่น 22"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="refinance-fees" class="block text-sm font-medium text-gray-700 mb-1">
                ค่าใช้จ่ายรีไฟแนนซ์รวม (บาท)
              </label>
              <input
                type="text"
                id="refinance-fees"
                inputmode="numeric"
                value="50000"
                placeholder="เช่น 50,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="extra-payment" class="block text-sm font-medium text-gray-700 mb-1">
                โปะเพิ่มต่อเดือน (บาท) <span class="text-gray-400 font-normal">ไม่บังคับ</span>
              </label>
              <input
                type="text"
                id="extra-payment"
                inputmode="numeric"
                value="0"
                placeholder="เช่น 3,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
          </div>
        </div>

        <div id="mode-new-home" class="space-y-5 hidden">
          <div>
            <label for="home-price" class="block text-sm font-medium text-gray-700 mb-1">
              ราคาบ้าน (บาท)
            </label>
            <input
              type="text"
              id="home-price"
              inputmode="numeric"
              value="3500000"
              placeholder="เช่น 3,500,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="home-price-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <label for="down-payment-pct" class="block text-sm font-medium text-gray-700 mb-1">
                เงินดาวน์ (%)
              </label>
              <input
                type="text"
                id="down-payment-pct"
                inputmode="decimal"
                value="20"
                placeholder="เช่น 20"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="new-home-rate" class="block text-sm font-medium text-gray-700 mb-1">
                ดอกเบี้ยต่อปี (%)
              </label>
              <input
                type="text"
                id="new-home-rate"
                inputmode="decimal"
                value="5.5"
                placeholder="เช่น 5.5"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="new-home-years" class="block text-sm font-medium text-gray-700 mb-1">
                ระยะเวลากู้ (ปี)
              </label>
              <input
                type="text"
                id="new-home-years"
                inputmode="numeric"
                value="30"
                placeholder="เช่น 30"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
          </div>
          <div id="new-home-preview" class="text-sm text-gray-600 bg-gray-50 rounded-lg p-3">
            ยอดกู้โดยประมาณ: <span id="new-home-loan-amount" class="font-semibold text-gray-900">-</span>
          </div>
        </div>

        <button
          type="submit"
          id="mortgage-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่างวดแผนเดิม</div>
            <div id="res-current-monthly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่างวดแผนใหม่</div>
            <div id="res-new-monthly" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ส่วนต่างต่อเดือน</div>
            <div id="res-monthly-delta" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประหยัดรวมสุทธิ</div>
            <div id="res-total-saving" class="text-xl font-bold text-gray-800">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยรวมแผนเดิม</span>
            <span id="res-current-interest" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยรวมแผนใหม่</span>
            <span id="res-new-interest" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าใช้จ่ายรีไฟแนนซ์</span>
            <span id="res-refi-fees" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เวลาปิดหนี้ (เดิม/ใหม่)</span>
            <span id="res-payoff-months" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จุดคุ้มทุนรีไฟแนนซ์</span>
            <span id="res-break-even" class="font-medium">-</span>
          </div>
        </div>

        <div id="res-summary-note" class="p-3 rounded-lg text-sm bg-primary-50 border border-primary-200 text-primary-900">
          -
        </div>
      </div>
    </div>
    <div id="mortgage-next-action" class="hidden mb-6 rounded-xl border border-primary-200 bg-primary-50 p-4">
      <p class="text-sm font-semibold text-primary-800">ทำต่อ: คำนวณผ่อนรถ</p>
      <p class="mt-1 text-sm text-primary-700">รวมภาระหนี้บ้านและรถให้เห็นค่างวดรวมต่อเดือนก่อนตัดสินใจ</p>
      <div class="mt-3 flex flex-wrap gap-3">
        <a data-next-action-link href="/คำนวณผ่อนรถ/" class="inline-flex min-h-11 items-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-700">ทำต่อ: คำนวณผ่อนรถ</a>
        <a data-next-action-link href="/บทความ/รีไฟแนนซ์บ้าน-vs-โปะบ้าน-แบบไหนคุ้ม-2569/" class="inline-flex min-h-11 items-center rounded-lg border border-primary-300 bg-white px-4 py-2 text-sm font-semibold text-primary-700 hover:border-primary-400">อ่านต่อ: รีไฟแนนซ์ vs โปะบ้าน</a>
      </div>
    </div>

    <GuardedAdSlot
