---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณสลิปเงินเดือน ยอดสุทธิ หักประกันสังคม ภาษี PVD ปี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณสลิปเงินเดือนครบทุกรายการ เงินเดือน Gross หักประกันสังคม 5% หักภาษี ณ ที่จ่าย หัก PVD และรายการหักอื่นๆ แสดงเงินเดือนสุทธิที่ได้รับ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณสลิปเงินเดือน/`;

const faqData = [
  {
    question: 'สลิปเงินเดือนประกอบด้วยอะไรบ้าง?',
    answer: 'สลิปเงินเดือนประกอบด้วยรายได้ (เงินเดือน เบี้ยเลี้ยง ค่าตำแหน่ง โบนัส) และรายการหัก (ประกันสังคม 5%, ภาษีหัก ณ ที่จ่าย, เงินสมทบ PVD, และรายการหักอื่นๆ) เงินเดือนสุทธิคือรายได้รวมหักรายการหักทั้งหมด',
  },
  {
    question: 'ประกันสังคมหักกี่เปอร์เซ็นต์?',
    answer: 'ประกันสังคมฝั่งพนักงานหัก 5% ของค่าจ้าง แต่ไม่เกิน 750 บาทต่อเดือน (ฐานค่าจ้างสูงสุด 15,000 บาท) ตามอัตราที่กำหนดในปี 2569',
  },
  {
    question: 'ภาษีหัก ณ ที่จ่ายคำนวณอย่างไร?',
    answer: 'ภาษีหัก ณ ที่จ่ายคำนวณจากเงินได้สุทธิต่อปีหลังหักค่าลดหย่อนต่างๆ แล้วคำนวณตามอัตราภาษีแบบขั้นบันได 5-35% แบ่งจ่ายเป็นรายเดือน แนะนำให้กรอกตามที่บริษัทคำนวณหรือใช้เครื่องคำนวณภาษีแยกต่างหาก',
  },
  {
    question: 'เบี้ยเลี้ยงและค่าตำแหน่งต้องเสียภาษีหรือไม่?',
    answer: 'เบี้ยเลี้ยงที่จ่ายตามจริงและสมเหตุสมผลอาจได้รับการยกเว้นภาษีบางส่วน แต่โดยทั่วไปเบี้ยเลี้ยงประจำและค่าตำแหน่งถือเป็นรายได้ต้องเสียภาษี ควรปรึกษาฝ่ายการเงินของบริษัท',
  },
,
  { question: 'ค่าแรงขั้นต่ำปี 2569 อยู่ที่เท่าไร?', answer: 'ค่าแรงขั้นต่ำปี 2568-2569 กรุงเทพและปริมณฑล 370-400 บาท/วัน ต่างจังหวัดอยู่ที่ 330-370 บาท/วัน ขึ้นอยู่กับจังหวัด ตรวจสอบอัตราล่าสุดได้จากกระทรวงแรงงาน mol.go.th' },
  { question: 'เงินเดือนสุทธิคำนวณจากอะไรบ้าง?', answer: 'เงินเดือนสุทธิ = เงินเดือนรวม - ภาษีหัก ณ ที่จ่าย - เงินสมทบประกันสังคม (5% สูงสุด 750 บาท) - กองทุนสำรองเลี้ยงชีพ (ถ้ามี) นายจ้างจ่ายประกันสังคมเพิ่มอีกฝ่าย 5%' },
  { question: 'OT คำนวณอย่างไร?', answer: 'วันธรรมดา: 1.5 เท่าของค่าจ้างปกติต่อชั่วโมง | วันหยุด: 2 เท่า (ชั่วโมงปกติ) และ 3 เท่า (เกินเวลาปกติ) | ตามพระราชบัญญัติคุ้มครองแรงงาน พ.ศ. 2541' },
  { question: 'กองทุนสำรองเลี้ยงชีพมีประโยชน์อย่างไร?', answer: 'เป็นเงินออมระยะยาวที่นายจ้างสมทบ (1-15% ของค่าจ้าง) + ลดหย่อนภาษีได้สูงสุด 15% ของรายได้หรือ 500,000 บาท + ผลตอบแทนจากการลงทุน ดึงออกได้เมื่อออกจากงานหรือเกษียณ' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณสลิปเงินเดือน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณสลิปเงินเดือน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">📋 คำนวณสลิปเงินเดือนครบทุกรายการ</p>
      <p class="mt-1 text-sm text-slate-700">ประกันสังคม 5% (สูงสุด 750 บาท/เดือน) + ภาษีหัก ณ ที่จ่าย + PVD + รายการหักอื่นๆ</p>
      <p class="mt-1 text-xs font-medium text-sky-800">แสดงรายได้รวม รายการหักทั้งหมด และเงินเดือนสุทธิที่ได้รับ</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณสลิปเงินเดือน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกรายได้และรายการหักทั้งหมด ระบบจะแสดงสรุปสลิปเงินเดือนพร้อมเงินเดือนสุทธิ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="payslip-form" class="space-y-5">
        <p id="payslip-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <h3 class="text-base font-semibold text-gray-800 border-b border-gray-200 pb-2">รายได้</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ps-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือน Gross (บาท/เดือน)</label>
            <input type="text" id="ps-salary" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ps-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ps-allowance" class="mb-1 block text-sm font-medium text-gray-700">เบี้ยเลี้ยง / ค่าตำแหน่ง (บาท)</label>
            <input type="text" id="ps-allowance" inputmode="numeric" placeholder="เช่น 2,000 (ถ้าไม่มีใส่ 0)"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ps-allowance-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <h3 class="text-base font-semibold text-gray-800 border-b border-gray-200 pb-2">รายการหัก</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">ประกันสังคมพนักงาน 5% (คำนวณอัตโนมัติ)</label>
            <div id="ps-ssf-display" class="w-full rounded-md border border-gray-200 bg-gray-50 px-3 py-2 text-base text-gray-600">
              กรอกเงินเดือนก่อน
            </div>
            <p class="mt-1 text-xs text-gray-500">สูงสุด 750 บาท/เดือน (ฐาน 15,000 บาท)</p>
          </div>
          <div>
            <label for="ps-tax" class="mb-1 block text-sm font-medium text-gray-700">ภาษีหัก ณ ที่จ่าย (บาท)</label>
            <input type="text" id="ps-tax" inputmode="numeric" placeholder="เช่น 1,500 (ดูจากสลิปจริง)"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ps-tax-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ps-pvd-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราสมทบ PVD (%) — ถ้าไม่มีใส่ 0</label>
            <input type="text" id="ps-pvd-rate" inputmode="decimal" placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ps-pvd-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ps-other-deduct" class="mb-1 block text-sm font-medium text-gray-700">หักอื่นๆ (บาท) — ถ้าไม่มีใส่ 0</label>
            <input type="text" id="ps-other-deduct" inputmode="numeric" placeholder="เช่น 500"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ps-other-deduct-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณสลิปเงินเดือน
        </button>
      </form>
    </div>

    <div id="payslip-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">สรุปสลิปเงินเดือน</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายได้รวม (Gross)</div>
            <div id="res-ps-gross" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">หักรวมทั้งหมด</div>
            <div id="res-ps-total-deduct" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินเดือนสุทธิ (Net)</div>
            <div id="res-ps-net" class="text-2xl font-bold text-green-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">เงินเดือน Gross</span>
            <span id="res-ps-salary-display" class="font-medium text-blue-700">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">เบี้ยเลี้ยง / ค่าตำแหน่ง</span>
            <span id="res-ps-allowance-display" class="font-medium text-blue-700">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">หักประกันสังคม 5%</span>
            <span id="res-ps-ssf-display" class="font-medium text-red-600">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">หักภาษี ณ ที่จ่าย</span>
            <span id="res-ps-tax-display" class="font-medium text-red-600">-</span>
          </div>
          <div id="ps-pvd-row" class="flex justify-between border-b border-gray-100 py-1 hidden">
            <span class="text-gray-600">หักเงินสมทบ PVD</span>
            <span id="res-ps-pvd-display" class="font-medium text-red-600">-</span>
          </div>
          <div id="ps-other-row" class="flex justify-between border-b border-gray-100 py-1 hidden">
            <span class="text-gray-600">หักอื่นๆ</span>
            <span id="res-ps-other-display" class="font-medium text-red-600">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>รายได้รวม = เงินเดือน Gross + เบี้ยเลี้ยง/ค่าตำแหน่ง</li>
        <li>ประกันสังคม = เงินเดือน × 5% แต่ไม่เกิน 750 บาท/เดือน</li>
        <li>PVD พนักงาน = เงินเดือน × อัตราสมทบ ÷ 100</li>
        <li>รวมหัก = ประกันสังคม + ภาษีหัก ณ ที่จ่าย + PVD + หักอื่นๆ</li>
        <li>เงินเดือนสุทธิ = รายได้รวม - รวมหัก</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
        <li><a href="/คำนวณภาษีเงินเดือนและประกันสังคม/">คำนวณภาษีเงินเดือนและประกันสังคม</a></li>
        <li><a href="/คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน/">คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#payslip-results" />
    <RelatedArticles currentHref="/คำนวณสลิปเงินเดือน/" />
    <RelatedCalculators currentHref="/คำนวณสลิปเงินเดือน/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการเบื้องต้น ภาษีหัก ณ ที่จ่ายต้องกรอกตามที่บริษัทคำนวณจริง อัตราประกันสังคมอาจมีการเปลี่ยนแปลง กรุณาตรวจสอบอัตราปัจจุบันกับสำนักงานประกันสังคม
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }
    function setErr(id, msg) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.toggle('hidden', !msg);
    }
    function showEl(id, show) {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('hidden', !show);
    }

    const salaryInput = document.getElementById('ps-salary');
    const ssfDisplay = document.getElementById('ps-ssf-display');

    salaryInput?.addEventListener('input', () => {
      const salary = parseNum(salaryInput.value);
      if (Number.isFinite(salary) && salary > 0) {
        const ssf = Math.min(salary * 0.05, 750);
        ssfDisplay.textContent = `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(ssf)} บาท`;
      } else {
        ssfDisplay.textContent = 'กรอกเงินเดือนก่อน';
      }
    });

    const form = document.getElementById('payslip-form');
    const formError = document.getElementById('payslip-form-error');
    const resultBox = document.getElementById('payslip-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['ps-salary-error', 'ps-allowance-error', 'ps-tax-error', 'ps-pvd-rate-error', 'ps-other-deduct-error'].forEach((id) => setErr(id, ''));

      const salary = parseNum(document.getElementById('ps-salary').value);
      const allowance = parseNum(document.getElementById('ps-allowance').value) || 0;
      const tax = parseNum(document.getElementById('ps-tax').value) || 0;
      const pvdRate = parseNum(document.getElementById('ps-pvd-rate').value) || 0;
      const otherDeduct = parseNum(document.getElementById('ps-other-deduct').value) || 0;

      let hasError = false;
      if (!Number.isFinite(salary) || salary <= 0) { setErr('ps-salary-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(allowance) || allowance < 0) { setErr('ps-allowance-error', 'กรอกเบี้ยเลี้ยงมากกว่าหรือเท่ากับ 0'); hasError = true; }
      if (!Number.isFinite(tax) || tax < 0) { setErr('ps-tax-error', 'กรอกภาษีมากกว่าหรือเท่ากับ 0'); hasError = true; }
      if (!Number.isFinite(pvdRate) || pvdRate < 0 || pvdRate > 15) { setErr('ps-pvd-rate-error', 'กรอกอัตรา PVD 0-15%'); hasError = true; }
      if (!Number.isFinite(otherDeduct) || otherDeduct < 0) { setErr('ps-other-deduct-error', 'กรอกยอดหักอื่นๆ มากกว่าหรือเท่ากับ 0'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const ssf = Math.min(salary * 0.05, 750);
      const pvd = salary * (pvdRate / 100);
      const gross = salary + allowance;
      const totalDeduct = ssf + tax + pvd + otherDeduct;
      const net = gross - totalDeduct;

      setText('res-ps-gross', formatMoney(gross));
      setText('res-ps-total-deduct', formatMoney(totalDeduct));
      setText('res-ps-net', formatMoney(net));
      setText('res-ps-salary-display', formatMoney(salary));
      setText('res-ps-allowance-display', formatMoney(allowance));
      setText('res-ps-ssf-display', formatMoney(ssf));
      setText('res-ps-tax-display', formatMoney(tax));
      setText('res-ps-pvd-display', formatMoney(pvd));
      setText('res-ps-other-display', formatMoney(otherDeduct));

      showEl('ps-pvd-row', pvd > 0);
      showEl('ps-other-row', otherDeduct > 0);

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
