---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณเงินสมทบเกษียณ 2569 | วางแผนออมเงินเกษียณ | Kamnuanlek';
const pageDescription = 'คำนวณเงินสมทบกองทุนเกษียณ กบข. กองทุนสำรองเลี้ยงชีพ และออมทรัพย์ส่วนตัวต่อเดือน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินสมทบเกษียณ/`;

const faqData = [
  {
    question: 'กบข. คืออะไร และใครบ้างที่ต้องสมทบ?',
    answer: 'กบข. (กองทุนบำเหน็จบำนาญข้าราชการ) คือกองทุนสำหรับข้าราชการไทย สมาชิกจะสมทบ 3% ของเงินเดือน และรัฐบาลสมทบเพิ่มอีก 3% พร้อมเงินชดเชย 2% รวมเป็น 8% ต่อเดือน',
  },
  {
    question: 'กองทุนสำรองเลี้ยงชีพ (PVD) แตกต่างจาก กบข. อย่างไร?',
    answer: 'กองทุนสำรองเลี้ยงชีพ (PVD) ใช้สำหรับพนักงานเอกชนที่บริษัทจัดตั้งขึ้น โดยพนักงานและนายจ้างสมทบอย่างน้อย 2-15% ของเงินเดือนฝ่ายละเท่ากัน ส่วน กบข. ใช้เฉพาะข้าราชการ',
  },
  {
    question: 'ควรออมเพิ่มนอกจาก กบข./PVD เท่าไรต่อเดือน?',
    answer: 'ผู้เชี่ยวชาญแนะนำออมเพื่อเกษียณรวมทั้งหมดอย่างน้อย 15% ของรายได้ หากกองทุนหลักครอบคลุมไม่ถึง ควรออมเพิ่มผ่าน RMF, SSF หรือบัญชีออมทรัพย์เพื่อให้ถึงเป้าหมาย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินสมทบเกษียณ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินสมทบเกษียณ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณเงินสมทบเกษียณ 2569</h1>
    <p class="mb-6 text-gray-600">คำนวณเงินสมทบกองทุนเกษียณต่อเดือน รวมถึงส่วนที่นายจ้างสมทบให้ และประมาณการยอดสะสมใน 20 ปี หากต้องการวางแผนค่าใช้จ่ายรายเดือนโดยรวม ดูได้ที่ <a href="/คำนวณอัตราออม/" class="text-primary-600 underline hover:text-primary-800">เครื่องคำนวณอัตราการออม</a> หรือ <a href="/คำนวณงบประมาณครัวเรือน/" class="text-primary-600 underline hover:text-primary-800">คำนวณงบประมาณครัวเรือน</a></p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="retire-form" class="space-y-4">
        <div>
          <label for="income" class="mb-1 block text-sm font-medium text-gray-700">รายได้ต่อเดือน (บาท)</label>
          <input id="income" type="text" inputmode="numeric" placeholder="เช่น 35000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="contrib-pct" class="mb-1 block text-sm font-medium text-gray-700">% สมทบ กบข./กองทุนสำรอง (ของรายได้)</label>
          <input id="contrib-pct" type="text" inputmode="numeric" placeholder="เช่น 3"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="extra-save" class="mb-1 block text-sm font-medium text-gray-700">ออมเพิ่มเอง (บาท/เดือน)</label>
          <input id="extra-save" type="text" inputmode="numeric" placeholder="เช่น 2000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-xs text-gray-600">เงินสมทบของคุณ/เดือน</div>
            <div id="res-own" class="text-2xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-xs text-gray-600">นายจ้างสมทบ/เดือน</div>
            <div id="res-employer" class="text-2xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-xs text-gray-600">รวมทั้งหมด/ปี</div>
            <div id="res-yearly" class="text-2xl font-bold text-orange-700">-</div>
          </div>
          <div class="rounded-lg bg-purple-50 p-4 text-center">
            <div class="mb-1 text-xs text-gray-600">ยอดสะสม 20 ปี (4%/ปี)</div>
            <div id="res-20yr" class="text-2xl font-bold text-purple-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณเงินสมทบเกษียณ/" categoryId="budget" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('retire-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const income = parseNum((document.getElementById('income') as HTMLInputElement).value);
    const pct = parseNum((document.getElementById('contrib-pct') as HTMLInputElement).value);
    const extra = parseNum((document.getElementById('extra-save') as HTMLInputElement).value);

    const ownContrib = income * (pct / 100);
    const employerContrib = ownContrib; // assume equal match
    const totalMonthly = ownContrib + employerContrib + extra;
    const yearly = totalMonthly * 12;

    // Future value with 4% annual return over 20 years, monthly compounding
    const monthlyRate = 0.04 / 12;
    const months = 240;
    const fv = totalMonthly * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate);

    document.getElementById('res-own')!.textContent = fmt(ownContrib + extra);
    document.getElementById('res-employer')!.textContent = fmt(employerContrib);
    document.getElementById('res-yearly')!.textContent = fmt(yearly);
    document.getElementById('res-20yr')!.textContent = fmt(fv);
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
