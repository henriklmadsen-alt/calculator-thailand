---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนปลูกปาล์มน้ำมัน | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการปลูกปาล์มน้ำมัน ผลผลิต รายได้ กำไร ผลตอบแทน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุนปาล์มน้ำมัน/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนปาล์มน้ำมัน">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนปลูกปาล์มน้ำมัน</h1>
    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2"><p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุน ผลผลิต รายได้ และผลตอบแทนจากการปลูกปาล์มน้ำมัน</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="rai" class="block text-sm font-medium text-gray-700 mb-1">ขนาดที่ดิน (ไร่)</label><input type="text" id="rai" inputmode="decimal" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="years" class="block text-sm font-medium text-gray-700 mb-1">ปีที่คิดคำนวณ</label><input type="text" id="years" inputmode="numeric" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-primary-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวม</p><p id="cost" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้รวม</p><p id="income" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">กำไร</p><p id="profit" class="font-bold">-</p></div><div class="bg-purple-50 rounded p-3"><p class="text-sm text-gray-600">ROI</p><p id="roi" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const rai = parseFloat((document.getElementById('rai') as HTMLInputElement).value) || 0;
      const years = parseFloat((document.getElementById('years') as HTMLInputElement).value) || 0;
      if (rai <= 0) return;
      const initCost = rai * 12000, yearlyMaint = rai * 3000;
      const totalCost = initCost + (yearlyMaint * years);
      const yield_ = rai * 2000, price = 10, yearlyIncome = yield_ * price;
      const totalIncome = yearlyIncome * years, profit = totalIncome - totalCost;
      const roi = (profit / totalCost) * 100;
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('cost') as HTMLElement).textContent = fmt(totalCost);
      (document.getElementById('income') as HTMLElement).textContent = fmt(totalIncome);
      (document.getElementById('profit') as HTMLElement).textContent = fmt(profit);
      (document.getElementById('roi') as HTMLElement).textContent = roi.toFixed(1) + '%';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('palm-oil-farming');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
