import RelatedCalculatorsWidget from '../../components/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import AffiliateCard from '../../components/templates/AffiliateCard.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
import TooltipIcon from '../../components/TooltipIcon.astro';
import { getFieldTooltip } from '../../utils/input-field-tooltips';

const pageTitle = 'คำนวณ APR อัตราดอกเบี้ยที่แท้จริง 2569 | Kamnuanlek';
const pageDescription = 'คำนวณ APR อัตราดอกเบี้ยที่แท้จริง 2569 ฟรี — รวมค่าธรรมเนียมทุกอย่าง รู้ต้นทุนสินเชื่อที่แท้จริงก่อนเซ็นสัญญา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-apr/`;

const faqData = [
  {
    question: 'APR คืออะไร?',
    answer: 'APR (Annual Percentage Rate) คืออัตราดอกเบี้ยที่แท้จริงต่อปี ที่รวมค่าธรรมเนียมและค่าใช้จ่ายทั้งหมดเข้าไปในการคำนวณ ทำให้สะท้อนต้นทุนสินเชื่อที่แท้จริงได้ดีกว่าอัตราดอกเบี้ยที่ระบุ',
  },
  {
    question: 'APR ต่างจากอัตราดอกเบี้ยปกติอย่างไร?',
    answer: 'อัตราดอกเบี้ยปกติไม่รวมค่าธรรมเนียมและค่าประกัน APR รวมทุกค่าใช้จ่ายที่เกี่ยวข้อง จึงสูงกว่าอัตราดอกเบี้ยที่ระบุในสัญญาเสมอ ยิ่งมีค่าธรรมเนียมมาก APR ยิ่งสูงกว่าดอกเบี้ยที่ระบุมาก',
  },
  {
    question: 'ควรเปรียบเทียบ APR หรือดอกเบี้ย?',
    answer: 'ควรเปรียบเทียบ APR เสมอ เพราะรวมต้นทุนทั้งหมด หากสินเชื่อ A ดอกเบี้ย 5% แต่มีค่าธรรมเนียมมาก อาจมี APR สูงกว่าสินเชื่อ B ที่ดอกเบี้ย 6% แต่ไม่มีค่าธรรมเนียม',
  },
  {
    question: 'ค่าธรรมเนียมอะไรบ้างที่ควรรวมใน APR?',
    answer: 'ค่าธรรมเนียมการจัดการสินเชื่อ ค่าธรรมเนียมการประเมินหลักประกัน ค่าประกันชีวิต/อัคคีภัยที่บังคับซื้อ ค่าธรรมเนียมเปิดบัญชี ค่านายหน้า ทุกอย่างที่ต้องจ่ายเพื่อให้ได้สินเชื่อควรรวมใน APR',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ APR / Effective Interest Rate',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ APR">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      📈 คำนวณ APR / อัตราดอกเบี้ยที่แท้จริง (EIR)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณ APR (Annual Percentage Rate) ที่รวมค่าธรรมเนียมและค่าประกันทุกรายการ
      เพื่อทราบต้นทุนสินเชื่อที่แท้จริงก่อนตัดสินใจ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
