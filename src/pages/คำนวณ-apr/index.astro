          </div>
          <div>
            <label for="monthly-payment" class="block text-sm font-medium text-gray-700 mb-1">
              ค่างวดต่อเดือน (บาท)
              <TooltipIcon text={getFieldTooltip('apr', 'monthly-payment')} fieldName="monthly-payment" />
            </label>
            <input
              type="text"
              id="monthly-payment"
              inputmode="numeric"
              placeholder="เช่น 11,000"
