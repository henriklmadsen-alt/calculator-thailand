    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">ผลการคำนวณ APR</h2>
          <button
            id="save-calc-btn"
            type="button"
            class="save-calc-btn"
            aria-label="บันทึกการคำนวณนี้"
          >
            💾 บันทึก
          </button>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">APR ต่อปี</div>
            <div id="res-apr-annual" class="text-xl font-bold text-red-600">-</div>
