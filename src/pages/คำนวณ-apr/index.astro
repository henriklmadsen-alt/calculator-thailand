            <div id="res-apr-monthly" class="text-xl font-bold text-orange-600">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยรวม</div>
            <div id="res-interest" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าใช้จ่ายรวมทั้งหมด</div>
            <div id="res-total-cost" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินกู้</span>
            <span id="res-principal" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าธรรมเนียมทั้งหมด</span>
            <span id="res-fees" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าประกัน</span>
            <span id="res-insurance" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่างวดต่อเดือน</span>
            <span id="res-pmt" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนงวด</span>
            <span id="res-term" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">ยอดชำระรวม (ค่างวด)</span>
            <span id="res-total-paid" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Calculators Card (below result, above ad) -->
    <RelatedCalculators currentHref="/คำนวณ-apr/" />

    <!-- Ad (Win #7: Mobile Ad Placement) — moved below result + related calculators -->
    <GuardedAdSlot />

    <!-- Affiliate CTA — hidden until result shown -->
    <AffiliateCard
      category="personal-loan"
      affiliateUrl="/go/ttb-cash2go/?sub_id=คำนวณ-apr"
      partnerName="TTB Cash 2 Go"
      ctaText="สมัครสินเชื่อ TTB Cash 2 Go"
      subtext="วงเงินสูง อนุมัติเร็ว ดอกเบี้ยคงที่"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">APR คืออะไร และทำไมต้องรู้ก่อนกู้</h2>

      <p>
        APR หรือ Annual Percentage Rate คืออัตราดอกเบี้ยที่แท้จริงต่อปี ที่รวมค่าใช้จ่ายทุกอย่าง
        ไม่ใช่แค่ดอกเบี้ย ทำให้เปรียบเทียบข้อเสนอสินเชื่อจากหลายสถาบันได้อย่างยุติธรรม
        ธนาคารแห่งประเทศไทยกำหนดให้สถาบันการเงินเปิดเผย EIR/APR แก่ผู้กู้
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณ APR</h3>
      <p>
        หา monthly rate r ที่ทำให้สมการต่อไปนี้เป็นจริง:
      </p>
      <p class="font-mono text-sm bg-gray-50 p-3 rounded">
        (P − ค่าธรรมเนียมทั้งหมด) = PMT × [1 − (1+r)^(−n)] ÷ r
      </p>
      <p>
        ค่าธรรมเนียมลดเงินต้นที่ผู้กู้ได้รับจริง แต่ยังต้องผ่อนชำระเต็มจำนวน
        จึงเพิ่ม APR ให้สูงขึ้น จากนั้น APR = ((1+r)^12 − 1) × 100
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ค่าใช้จ่ายที่ควรรวมในการคำนวณ APR</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>ค่าธรรมเนียมการจัดการสินเชื่อ (Origination Fee)</strong> — มักเป็น 1-3% ของวงเงิน</li>
        <li><strong>ค่าธรรมเนียมการประเมินหลักประกัน</strong> — สำหรับสินเชื่อบ้านและรถ</li>
        <li><strong>ค่าประกันชีวิต/ประกันสินเชื่อ</strong> — ที่บังคับซื้อพร้อมสินเชื่อ</li>
        <li><strong>ค่าประกันอัคคีภัย</strong> — สำหรับสินเชื่อบ้าน</li>
        <li><strong>ค่าธรรมเนียมเปิดบัญชี</strong> — หากบังคับเปิดบัญชีกับธนาคาร</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่าง: ผลกระทบของค่าธรรมเนียมต่อ APR</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>กู้ 500,000 บาท ดอกเบี้ย 6% ต่อปี ผ่อน 60 เดือน ไม่มีค่าธรรมเนียม → APR ≈ 6%</li>
        <li>เพิ่มค่าธรรมเนียม 15,000 บาท (3%) → APR ≈ 7.1%</li>
        <li>เพิ่มค่าประกัน 10,000 บาท → APR ≈ 7.8%</li>
        <li>ยิ่งระยะเวลากู้สั้น ผลกระทบของค่าธรรมเนียมต่อ APR ยิ่งมาก</li>
      </ul>
    </section>

    <RelatedCalculatorsWidget calculatorSlug="คำนวณ-apr" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณ-apr/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ
      APR ที่แท้จริงของสถาบันการเงินอาจแตกต่างตามนิยามและวิธีคำนวณของแต่ละแห่ง
      ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    // Newton-Raphson to find monthly rate
    function findMonthlyRate(effectivePrincipal: number, PMT: number, n: number): number {
      if (PMT * n <= effectivePrincipal) return 0; // no interest
      let r = 0.01;
      for (let i = 0; i < 200; i++) {
        const factor = Math.pow(1 + r, n);
        const f = PMT * (1 - 1 / factor) / r - effectivePrincipal;
        const df = PMT * (
          (1 - 1 / factor) / (-r * r) +
          n / (r * (1 + r) * factor)
        );
        const rNew = r - f / df;
        if (Math.abs(rNew - r) < 1e-10) return Math.max(0, rNew);
        r = Math.max(1e-8, rNew);
      }
      return Math.max(0, r);
    }

    const form = document.getElementById('apr-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const P = parseNum((document.getElementById('principal') as HTMLInputElement).value);
      const PMT = parseNum((document.getElementById('monthly-payment') as HTMLInputElement).value);
      const n = parseNum((document.getElementById('term-months') as HTMLInputElement).value);
      const fees = parseNum((document.getElementById('fees') as HTMLInputElement).value);
      const insurance = parseNum((document.getElementById('insurance') as HTMLInputElement).value);

      if (P <= 0) { (document.getElementById('principal') as HTMLInputElement).focus(); return; }
      if (PMT <= 0) { (document.getElementById('monthly-payment') as HTMLInputElement).focus(); return; }
      if (n <= 0) { (document.getElementById('term-months') as HTMLInputElement).focus(); return; }

      const totalFees = fees + insurance;
      const effectivePrincipal = P - totalFees;
      const totalPaid = PMT * n;
      const totalInterest = totalPaid - P;
      const totalCost = totalInterest + totalFees;

      let aprAnnual: number;
      let aprMonthly: number;

      if (effectivePrincipal <= 0) {
        alert('ค่าธรรมเนียมรวมสูงกว่าหรือเท่ากับเงินกู้ กรุณาตรวจสอบข้อมูล');
        return;
      }

      aprMonthly = findMonthlyRate(effectivePrincipal, PMT, n);
      aprAnnual = (Math.pow(1 + aprMonthly, 12) - 1) * 100;

      (document.getElementById('res-apr-annual') as HTMLElement).textContent = aprAnnual.toFixed(2) + '%';
      (document.getElementById('res-apr-monthly') as HTMLElement).textContent = (aprMonthly * 100).toFixed(4) + '%';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total-cost') as HTMLElement).textContent = fmt(totalCost) + ' บาท';
      (document.getElementById('res-principal') as HTMLElement).textContent = fmt(P) + ' บาท';
      (document.getElementById('res-fees') as HTMLElement).textContent = fmt(fees) + ' บาท';
      (document.getElementById('res-insurance') as HTMLElement).textContent = fmt(insurance) + ' บาท';
      (document.getElementById('res-pmt') as HTMLElement).textContent = fmt(PMT) + ' บาท';
      (document.getElementById('res-term') as HTMLElement).textContent = n + ' งวด';
      (document.getElementById('res-total-paid') as HTMLElement).textContent = fmt(totalPaid) + ' บาท';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      document.getElementById('affiliate-card')?.classList.remove('hidden');
      trackCalculatorUsed('apr');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('apr');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);

    // ─── Save Calculation (CAL-962) ───────────────────────────────────
    const STORAGE_KEY = 'ct.saved.calcs.v1';
    const MAX_SAVED = 5;
    const calculatorPath = window.location.pathname;
    const calculatorName = 'คำนวณ APR';

    function isLocalStorageAvailable() {
      try {
        const test = '__ct_storage_test__';
        window.localStorage.setItem(test, test);
        window.localStorage.removeItem(test);
        return true;
      } catch {
        return false;
      }
    }

    function getSavedCalculations() {
      if (!isLocalStorageAvailable()) return [];
      try {
        const stored = window.localStorage.getItem(STORAGE_KEY);
        const data = stored ? JSON.parse(stored) : [];
        return Array.isArray(data) ? data : [];
      } catch {
        return [];
      }
    }

    function saveCalculation(inputs, result) {
      if (!isLocalStorageAvailable()) return null;
      try {
        const saved = getSavedCalculations();
        const id = `calc_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
        const newCalc = {
          id,
          calculatorName,
          calculatorPath,
          inputs,
          result,
          timestamp: Date.now(),
        };
        saved.unshift(newCalc);
        if (saved.length > MAX_SAVED) saved.length = MAX_SAVED;
        window.localStorage.setItem(STORAGE_KEY, JSON.stringify(saved));
        return newCalc;
      } catch {
        return null;
      }
    }

    function showSaveSuccess() {
      const feedback = document.createElement('div');
      feedback.className = 'save-calc-feedback';
      feedback.textContent = '✅ บันทึกการคำนวณเรียบร้อย';
      document.body.appendChild(feedback);

      setTimeout(() => {
        feedback.classList.add('fade-out');
        setTimeout(() => feedback.remove(), 300);
      }, 2000);
    }

    const saveBtn = document.getElementById('save-calc-btn');
    if (saveBtn) {
      saveBtn.addEventListener('click', () => {
        const P = parseNum((document.getElementById('principal') as HTMLInputElement).value);
        const PMT = parseNum((document.getElementById('monthly-payment') as HTMLInputElement).value);
        const n = parseNum((document.getElementById('term-months') as HTMLInputElement).value);
        const fees = parseNum((document.getElementById('fees') as HTMLInputElement).value);
        const insurance = parseNum((document.getElementById('insurance') as HTMLInputElement).value);

        if (!P || !PMT || !n) {
          alert('กรุณากรอกข้อมูลให้ครบถ้วน');
          return;
        }

        const aprText = (document.getElementById('res-apr-annual') as HTMLElement).textContent || '-';
        const saved = saveCalculation(
          { principal: P, monthlyPayment: PMT, termMonths: n, fees, insurance },
          aprText
        );

        if (saved) {
          showSaveSuccess();
          trackLanguageAwareEvent('calculation_saved', { calculator_type: 'apr' });
        }
      });
    }
  </script>
</BaseLayout>
