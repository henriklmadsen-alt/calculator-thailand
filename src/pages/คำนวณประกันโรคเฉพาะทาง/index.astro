---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณประกันโรคเฉพาะทาง (Critical Illness) 2569 | โรคมะเร็ง หัวใจ ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันโรคเฉพาะทาง Critical Illness 2569 มะเร็ง โรคหัวใจ โรคหลอดเลือดสมอง ไตวาย ประมาณการเบี้ยตามอายุ เพศ และโรคที่ครอบคลุม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประกันโรคเฉพาะทาง/`;

const faqData = [
  { question: 'ประกันโรคเฉพาะทาง (Critical Illness) คืออะไร?', answer: 'ประกัน Critical Illness จ่ายเงินก้อนทันทีเมื่อได้รับการวินิจฉัยโรคร้ายแรงที่กำหนด เช่น มะเร็ง โรคหัวใจ โรคหลอดเลือดสมอง ไตวาย เงินก้อนนี้ใช้ได้ทุกอย่าง ทั้งค่ารักษา ค่าใช้จ่ายระหว่างพักฟื้น หรือชดเชยรายได้ที่หายไป' },
  { question: 'ประกัน CI ต่างจากประกันสุขภาพอย่างไร?', answer: 'ประกันสุขภาพจ่ายค่ารักษาจริงตามใบเสร็จ ส่วนประกัน CI จ่ายเงินก้อนตามวงเงินที่ทำประกันไว้ทันทีที่ได้รับการวินิจฉัย ไม่ต้องพิสูจน์ค่าใช้จ่าย ทั้งสองควรมีพร้อมกัน' },
  { question: 'ทุน CI ควรทำเท่าไร?', answer: 'แนะนำอย่างน้อย 500,000-1,000,000 บาท เนื่องจากค่ารักษาโรคมะเร็งในไทยเฉลี่ย 500,000-2,000,000 บาทต่อคอร์สการรักษา บวกค่าใช้จ่ายระหว่างพักฟื้นและรายได้ที่หายไป' },
  { question: 'โรคอะไรที่มักอยู่ในความคุ้มครอง CI?', answer: 'โรคหลักที่คุ้มครอง: มะเร็ง โรคหัวใจวาย โรคหลอดเลือดสมอง (Stroke) ไตวายระยะสุดท้าย ตับวาย ปลูกถ่ายอวัยวะ โรคระบบประสาทเสื่อม เช่น อัมพาต ตาบอด หูหนวก บางแผนคุ้มครองมากกว่า 40 โรค' },
];

const jsonLdWebApp = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'เครื่องคำนวณประกันโรคเฉพาะทาง 2569', description: pageDescription, url: canonical, applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' }, inLanguage: 'th' };
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประกันโรคเฉพาะทาง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณการเบี้ยประกันโรคร้ายแรง (Critical Illness)</p>
      <p class="mt-1 text-sm text-slate-700">อ้างอิงอัตราตลาดประกันภัยไทยปี 2569</p>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณประกันโรคเฉพาะทาง 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">ประมาณเบี้ยประกัน Critical Illness สำหรับโรคร้ายแรงต่างๆ ตามอายุ เพศ และวงเงินคุ้มครอง</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูล</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>
        <div>
          <label for="age" class="block text-sm font-medium text-gray-700 mb-1">อายุ (ปี)</label>
          <input type="text" id="age" inputmode="numeric" placeholder="เช่น 35" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="gender" class="block text-sm font-medium text-gray-700 mb-2">เพศ</label>
          <div class="grid grid-cols-2 gap-2 max-w-xs">
            <button type="button" data-gender="male" class="gender-btn py-2 px-4 rounded-md text-sm font-medium transition-colors border border-primary-500 bg-primary-50 text-primary-700">ชาย</button>
            <button type="button" data-gender="female" class="gender-btn py-2 px-4 rounded-md text-sm font-medium transition-colors border border-gray-300 text-gray-600">หญิง</button>
          </div>
        </div>
        <div>
          <label for="sum-assured" class="block text-sm font-medium text-gray-700 mb-1">ทุนประกัน CI (บาท)</label>
          <select id="sum-assured" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="500000">500,000 บาท</option>
            <option value="1000000" selected>1,000,000 บาท</option>
            <option value="2000000">2,000,000 บาท</option>
            <option value="3000000">3,000,000 บาท</option>
          </select>
        </div>
        <div>
          <label for="ci-plan" class="block text-sm font-medium text-gray-700 mb-1">แผนความคุ้มครอง</label>
          <select id="ci-plan" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="0.008">โรคร้ายแรง 5 โรคหลัก (0.8%/ปี)</option>
            <option value="0.012" selected>โรคร้ายแรง 15 โรค (1.2%/ปี)</option>
            <option value="0.018">โรคร้ายแรง 40+ โรค (1.8%/ปี)</option>
          </select>
        </div>
        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">คำนวณเบี้ยประกัน</button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 mb-4 text-center">
        <p class="text-sm text-primary-700 mb-1">เบี้ยประกันประมาณการรายปี</p>
        <p class="text-4xl font-bold text-primary-700" id="total-premium">-</p>
        <p class="text-sm text-primary-600 mt-1" id="monthly-premium">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ทำไมต้องมีประกันโรคร้ายแรง?</h2>
      <p>สถิติจากกระทรวงสาธารณสุขพบว่าคนไทยเสียชีวิตจากโรคมะเร็งและโรคหัวใจเป็นอันดับต้นๆ ค่ารักษาโรคเหล่านี้มักสูงมากจนเป็นภาระทางการเงินที่หนักมาก แม้มีประกันสุขภาพแล้ว CI Insurance ช่วยให้มีเงินก้อนใช้จ่ายได้ตามต้องการ</p>
    </section>
    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />
    <RelatedCalculators currentHref="/คำนวณประกันโรคเฉพาะทาง/" />
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800"><strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงขึ้นกับบริษัทประกันและผลตรวจสุขภาพ</div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    let currentGender = 'male';
    document.querySelectorAll('.gender-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentGender = (btn as HTMLElement).dataset.gender || 'male';
        document.querySelectorAll('.gender-btn').forEach(b => {
          b.classList.remove('border-primary-500', 'bg-primary-50', 'text-primary-700');
          b.classList.add('border-gray-300', 'text-gray-600');
        });
        btn.classList.add('border-primary-500', 'bg-primary-50', 'text-primary-700');
        btn.classList.remove('border-gray-300', 'text-gray-600');
      });
    });

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const age = parseNum((document.getElementById('age') as HTMLInputElement).value);
      const sumAssured = parseFloat((document.getElementById('sum-assured') as HTMLSelectElement).value);
      const ciRate = parseFloat((document.getElementById('ci-plan') as HTMLSelectElement).value);
      const err = document.getElementById('form-error')!;
      if (age < 18 || age > 65) { err.textContent = 'กรุณากรอกอายุ 18-65 ปี'; err.classList.remove('hidden'); return; }
      err.classList.add('hidden');

      const ageFactor = age < 30 ? 0.7 : age < 40 ? 1.0 : age < 50 ? 1.5 : age < 60 ? 2.3 : 3.5;
      const genderFactor = currentGender === 'female' ? 0.85 : 1.0;
      const premium = sumAssured * ciRate * ageFactor * genderFactor;

      const rows = [
        ['ทุนประกัน CI', '', `${fmt(sumAssured)} บาท`],
        ['อัตราเบี้ยฐาน', `แผน ${(ciRate*100).toFixed(1)}%/ปี`, `${fmt(sumAssured * ciRate)} บาท`],
        ['ตัวคูณตามอายุ', `อายุ ${age} ปี × ${ageFactor}`, `${fmt(sumAssured * ciRate * ageFactor)} บาท`],
        ['ตัวคูณตามเพศ', `${currentGender === 'female' ? 'หญิง × 0.85' : 'ชาย × 1.0'}`, `${fmt(premium)} บาท`],
        ['เบี้ยรวมประมาณการ/ปี', '', `<strong>${fmt(premium)} บาท</strong>`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td><td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td></tr>`).join('');

      (document.getElementById('total-premium') as HTMLElement).textContent = fmt(premium) + ' บาท/ปี';
      (document.getElementById('monthly-premium') as HTMLElement).textContent = `≈ ${fmt(premium/12)} บาท/เดือน`;
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
