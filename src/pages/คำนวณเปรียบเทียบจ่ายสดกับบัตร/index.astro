---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเปรียบเทียบจ่ายสดกับบัตร ปี 2569 — Cash vs Card Effective Cost | เครื่องคำนวณไทย';
const pageDescription = 'เปรียบเทียบต้นทุนจริงระหว่างการจ่ายสดกับบัตรเครดิต ป้อนส่วนลดเงินสด Cashback และค่าธรรมเนียม ทราบว่าแบบไหนคุ้มกว่า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเปรียบเทียบจ่ายสดกับบัตร/`;

const faqData = [
  {
    question: 'จ่ายสดหรือบัตรเครดิตคุ้มกว่า?',
    answer: 'ขึ้นอยู่กับเงื่อนไข: ถ้าร้านให้ส่วนลดเงินสดมากกว่า Cashback ที่ได้จากบัตร → จ่ายสดคุ้มกว่า แต่ถ้า Cashback + สิทธิประโยชน์บัตรมากกว่าส่วนลดสด → ใช้บัตรคุ้มกว่า',
  },
  {
    question: 'ส่วนลด 3% เงินสดคุ้มกว่า Cashback 1.5% ไหม?',
    answer: 'ใช่ ถ้าร้านให้ส่วนลดสด 3% แต่บัตรให้ Cashback เพียง 1.5% การจ่ายสดประหยัดกว่า 1.5% ต่อครั้ง',
  },
  {
    question: 'ควรพิจารณาอะไรเพิ่มเติม?',
    answer: 'นอกจากส่วนลดและ Cashback ควรพิจารณา: (1) สิทธิ์ผ่อน 0% (2) ประกันสินค้าจากบัตร (3) คะแนนไมล์สะสม (4) ความปลอดภัยการพกเงินสด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเปรียบเทียบจ่ายสดกับบัตร',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเปรียบเทียบจ่ายสดกับบัตร">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-green-100 bg-green-50 p-4">
      <p class="text-sm font-semibold text-green-700">เปรียบเทียบจ่ายสดกับบัตร — ต้นทุนจริงแบบไหนคุ้มกว่า</p>
      <p class="mt-1 text-sm text-slate-700">ต้นทุนจ่ายสด = ราคา − ส่วนลดเงินสด | ต้นทุนจ่ายบัตร = ราคา − Cashback − แต้ม/ไมล์</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      เปรียบเทียบจ่ายสดกับบัตรเครดิต ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนราคาสินค้า ส่วนลดเงินสด Cashback บัตรและผลประโยชน์อื่น เพื่อดูว่าแบบไหนคุ้มกว่า
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="cvc-form" class="space-y-5">
        <p id="cvc-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div>
          <label for="cvc-price" class="mb-1 block text-sm font-medium text-gray-700">ราคาสินค้า/บริการ (บาท)</label>
          <input type="text" id="cvc-price" inputmode="numeric" placeholder="เช่น 5,000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          <p id="cvc-price-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div class="rounded-lg border border-gray-100 bg-gray-50 p-4">
          <h3 class="mb-3 text-sm font-semibold text-gray-700">จ่ายสด</h3>
          <div>
            <label for="cvc-cash-discount" class="mb-1 block text-sm font-medium text-gray-700">ส่วนลดเงินสด (%)</label>
            <input type="text" id="cvc-cash-discount" inputmode="decimal" placeholder="เช่น 3 (ถ้าไม่มีใส่ 0)"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div class="rounded-lg border border-purple-100 bg-purple-50 p-4">
          <h3 class="mb-3 text-sm font-semibold text-purple-700">จ่ายบัตร</h3>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="cvc-cashback" class="mb-1 block text-sm font-medium text-gray-700">Cashback (%)</label>
              <input type="text" id="cvc-cashback" inputmode="decimal" placeholder="เช่น 1.5"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            </div>
            <div>
              <label for="cvc-points-value" class="mb-1 block text-sm font-medium text-gray-700">มูลค่าแต้ม/ไมล์ (บาท) — ไม่บังคับ</label>
              <input type="text" id="cvc-points-value" inputmode="decimal" placeholder="เช่น 50"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            </div>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          เปรียบเทียบ
        </button>
      </form>
    </div>

    <div id="cvc-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการเปรียบเทียบ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-2">
          <div id="cvc-cash-box" class="rounded-lg p-4">
            <div class="mb-1 text-sm font-semibold text-gray-700">💵 จ่ายสด</div>
            <div id="res-cvc-cash" class="text-2xl font-bold">-</div>
            <div class="mt-1 text-xs text-gray-500">ต้นทุนจริง</div>
          </div>
          <div id="cvc-card-box" class="rounded-lg p-4">
            <div class="mb-1 text-sm font-semibold text-gray-700">💳 จ่ายบัตร</div>
            <div id="res-cvc-card" class="text-2xl font-bold">-</div>
            <div class="mt-1 text-xs text-gray-500">ต้นทุนจริง</div>
          </div>
        </div>
        <p id="cvc-verdict" class="rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ต้นทุนจ่ายสด = ราคา × (1 − ส่วนลดสด%)</li>
        <li>ต้นทุนจ่ายบัตร = ราคา − (ราคา × Cashback%) − มูลค่าแต้ม/ไมล์</li>
        <li>คุ้มกว่าคือแบบที่ต้นทุนน้อยกว่า</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณ-cashback/">คำนวณมูลค่า Cashback</a></li>
        <li><a href="/คำนวณแต้มสะสม/">คำนวณมูลค่าแต้มสะสม</a></li>
        <li><a href="/คำนวณค่าธรรมเนียมผ่อนชำระร้านค้า/">คำนวณค่าธรรมเนียมผ่อนชำระร้านค้า</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#cvc-results" />
    <RelatedArticles currentHref="/คำนวณเปรียบเทียบจ่ายสดกับบัตร/" />
    <RelatedCalculators currentHref="/คำนวณเปรียบเทียบจ่ายสดกับบัตร/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('cvc-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      setErr('cvc-price-error', '');

      const price = parseNum(document.getElementById('cvc-price').value);
      const cashDiscount = parseNum(document.getElementById('cvc-cash-discount').value) || 0;
      const cashback = parseNum(document.getElementById('cvc-cashback').value) || 0;
      const pointsValue = parseNum(document.getElementById('cvc-points-value').value) || 0;

      if (!Number.isFinite(price) || price <= 0) { setErr('cvc-price-error', 'กรอกราคาสินค้ามากกว่า 0'); document.getElementById('cvc-error').classList.remove('hidden'); document.getElementById('cvc-results').classList.add('hidden'); return; }
      document.getElementById('cvc-error').classList.add('hidden');

      const cashCost = price * (1 - cashDiscount / 100);
      const cardCost = price - (price * cashback / 100) - pointsValue;

      setText('res-cvc-cash', fmt(cashCost));
      setText('res-cvc-card', fmt(cardCost));

      const cashBox = document.getElementById('cvc-cash-box');
      const cardBox = document.getElementById('cvc-card-box');
      const verdict = document.getElementById('cvc-verdict');

      if (cashCost < cardCost) {
        cashBox.className = 'rounded-lg bg-green-50 border-2 border-green-300 p-4';
        document.getElementById('res-cvc-cash').className = 'text-2xl font-bold text-green-700';
        cardBox.className = 'rounded-lg bg-gray-50 p-4';
        document.getElementById('res-cvc-card').className = 'text-2xl font-bold text-gray-500';
        verdict.className = 'rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800 border border-green-200';
        verdict.textContent = `✅ จ่ายสดคุ้มกว่า ประหยัดได้ ${fmt(cardCost - cashCost)} ต่อรายการ`;
      } else if (cardCost < cashCost) {
        cardBox.className = 'rounded-lg bg-purple-50 border-2 border-purple-300 p-4';
        document.getElementById('res-cvc-card').className = 'text-2xl font-bold text-purple-700';
        cashBox.className = 'rounded-lg bg-gray-50 p-4';
        document.getElementById('res-cvc-cash').className = 'text-2xl font-bold text-gray-500';
        verdict.className = 'rounded-lg bg-purple-50 p-3 text-sm font-medium text-purple-800 border border-purple-200';
        verdict.textContent = `✅ จ่ายบัตรคุ้มกว่า ประหยัดได้ ${fmt(cashCost - cardCost)} ต่อรายการ`;
      } else {
        cashBox.className = 'rounded-lg bg-gray-50 p-4';
        cardBox.className = 'rounded-lg bg-gray-50 p-4';
        verdict.className = 'rounded-lg bg-gray-50 p-3 text-sm font-medium text-gray-700 border border-gray-200';
        verdict.textContent = 'ต้นทุนเท่ากัน — เลือกได้ตามความสะดวก';
      }

      document.getElementById('cvc-results').classList.remove('hidden');
      document.getElementById('cvc-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
