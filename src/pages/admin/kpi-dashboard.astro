---
import Layout from '../../layouts/Layout.astro';

// Check auth - in production, validate session token
const authToken = Astro.request.headers.get('Authorization');
if (!authToken) {
  return Astro.redirect('/admin/login');
}

// Fetch KPI data server-side
let kpiData = null;
let error = null;

try {
  const apiUrl = new URL('/api/kpi/dashboard', Astro.url.origin);
  apiUrl.searchParams.set('days', '30');

  const response = await fetch(apiUrl.toString(), {
    headers: {
      'Authorization': `Bearer ${process.env.KPI_API_TOKEN}`,
    },
  });

  if (response.ok) {
    kpiData = await response.json();
  } else {
    error = `API error: ${response.status}`;
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to fetch KPI data';
}
---

<Layout title="KPI Dashboard">
  <div class="min-h-screen bg-gray-50 p-8">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-3xl font-bold text-gray-900 mb-8">KPI Dashboard</h1>

      {error && (
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-red-700">Error: {error}</p>
          {error.includes('not configured') && (
            <p class="text-sm text-red-600 mt-2">
              Please configure GSC_SERVICE_ACCOUNT_JSON and GA4_SERVICE_ACCOUNT_JSON environment variables
            </p>
          )}
        </div>
      )}

      {kpiData && (
        <>
          <div class="text-sm text-gray-500 mb-6">
            Last updated: {new Date(kpiData.timestamp).toLocaleString()} (Period: {kpiData.period})
          </div>

          {/* Main KPI Cards */}
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <p class="text-gray-600 text-sm font-medium">Queries at #1</p>
              <p class="text-3xl font-bold text-blue-600">{kpiData.queriesAt1}</p>
              <p class="text-gray-500 text-xs mt-1">{kpiData.keywords.total} total keywords tracked</p>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <p class="text-gray-600 text-sm font-medium">Queries at #1-5</p>
              <p class="text-3xl font-bold text-green-600">{kpiData.queriesAt1To5}</p>
              <p class="text-gray-500 text-xs mt-1">Quick win targets</p>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <p class="text-gray-600 text-sm font-medium">Avg Position</p>
              <p class="text-3xl font-bold text-purple-600">{kpiData.keywords.avgPosition}</p>
              <p class="text-gray-500 text-xs mt-1">Across all keywords</p>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <p class="text-gray-600 text-sm font-medium">Organic Sessions</p>
              <p class="text-3xl font-bold text-orange-600">{kpiData.organic.sessions.toLocaleString()}</p>
              <p class="text-gray-500 text-xs mt-1">Last {kpiData.period}</p>
            </div>
          </div>

          {/* Organic Metrics */}
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <div class="bg-white rounded-lg shadow p-6">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">Organic Traffic</h2>
              <div class="space-y-3">
                <div class="flex justify-between items-center border-b pb-3">
                  <span class="text-gray-600">Sessions</span>
                  <span class="text-2xl font-bold text-gray-900">{kpiData.organic.sessions.toLocaleString()}</span>
                </div>
                <div class="flex justify-between items-center border-b pb-3">
                  <span class="text-gray-600">Users</span>
                  <span class="text-2xl font-bold text-gray-900">{kpiData.organic.users.toLocaleString()}</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-600">AdSense Revenue</span>
                  <span class="text-2xl font-bold text-gray-900">${kpiData.organic.revenue.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>
                </div>
              </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
              <h2 class="text-lg font-semibold text-gray-900 mb-4">Ranking Distribution</h2>
              <div class="space-y-3">
                <div class="flex justify-between items-center border-b pb-3">
                  <span class="text-gray-600">#1 Rankings</span>
                  <span class="text-xl font-bold text-blue-600">{kpiData.queriesAt1}</span>
                </div>
                <div class="flex justify-between items-center border-b pb-3">
                  <span class="text-gray-600">#1-5 Rankings</span>
                  <span class="text-xl font-bold text-green-600">{kpiData.queriesAt1To5}</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-600">#1-10 Rankings</span>
                  <span class="text-xl font-bold text-yellow-600">{kpiData.queriesAt1To10}</span>
                </div>
              </div>
            </div>
          </div>

          {/* Top Keywords */}
          <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Top 20 Keywords</h2>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Keyword</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Position</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Impressions</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Clicks</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">CTR</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  {kpiData.keywords.top100.slice(0, 20).map((keyword: any) => (
                    <tr class="hover:bg-gray-50">
                      <td class="px-6 py-3 text-sm text-gray-900 font-medium">{keyword.query}</td>
                      <td class="px-6 py-3 text-sm">
                        <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                          keyword.position === 1 ? 'bg-blue-100 text-blue-800' :
                          keyword.position <= 5 ? 'bg-green-100 text-green-800' :
                          keyword.position <= 10 ? 'bg-yellow-100 text-yellow-800' :
                          'bg-gray-100 text-gray-800'
                        }`}>
                          #{Math.round(keyword.position)}
                        </span>
                      </td>
                      <td class="px-6 py-3 text-sm text-gray-900">{keyword.impressions.toLocaleString()}</td>
                      <td class="px-6 py-3 text-sm text-gray-900">{keyword.clicks.toLocaleString()}</td>
                      <td class="px-6 py-3 text-sm text-gray-900">{keyword.ctr.toFixed(2)}%</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <div class="text-xs text-gray-500 mt-6 text-center">
            Dashboard auto-refreshes every 5 minutes. Full data export available via API.
          </div>
        </>
      )}
    </div>
  </div>
</Layout>
