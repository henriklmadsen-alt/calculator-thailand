---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Phase 5: Retention Dashboard
// User segmentation, churn prediction, re-engagement campaigns
---

<BaseLayout
  title="Retention Dashboard — Phase 5"
  description="User segmentation and retention optimization"
>
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-gray-900 mb-8">Phase 5: Retention & Re-engagement</h1>

      <!-- User Segments -->
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-8">
        <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-lg shadow p-6 text-white">
          <p class="text-sm font-medium opacity-90">High Value Users</p>
          <p class="text-3xl font-bold mt-2">1,240</p>
          <p class="text-xs opacity-75 mt-1">10%+ value score</p>
        </div>
        <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg shadow p-6 text-white">
          <p class="text-sm font-medium opacity-90">Active Users</p>
          <p class="text-3xl font-bold mt-2">3,850</p>
          <p class="text-xs opacity-75 mt-1">Last 7 days</p>
        </div>
        <div class="bg-gradient-to-br from-yellow-500 to-yellow-600 rounded-lg shadow p-6 text-white">
          <p class="text-sm font-medium opacity-90">At Risk (7-30d)</p>
          <p class="text-3xl font-bold mt-2">1,620</p>
          <p class="text-xs opacity-75 mt-1">Need re-engagement</p>
        </div>
        <div class="bg-gradient-to-br from-red-500 to-red-600 rounded-lg shadow p-6 text-white">
          <p class="text-sm font-medium opacity-90">Churned (30d+)</p>
          <p class="text-3xl font-bold mt-2">890</p>
          <p class="text-xs opacity-75 mt-1">Win-back campaigns</p>
        </div>
        <div class="bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-lg shadow p-6 text-white">
          <p class="text-sm font-medium opacity-90">New Users</p>
          <p class="text-3xl font-bold mt-2">2,340</p>
          <p class="text-xs opacity-75 mt-1">Onboarding phase</p>
        </div>
      </div>

      <!-- Re-engagement Campaigns -->
      <div class="bg-white rounded-lg shadow p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Active Re-engagement Campaigns</h2>
        <div class="space-y-4">
          <div class="border-l-4 border-green-500 pl-4 py-2">
            <p class="font-medium text-gray-900">Email: "We Miss You" (At Risk)</p>
            <p class="text-sm text-gray-600">1,620 emails sent | 12% open rate | $0 cost</p>
            <div class="mt-2 w-full bg-gray-200 rounded-full h-2">
              <div class="bg-green-600 h-2 rounded-full" style="width: 45%"></div>
            </div>
          </div>
          <div class="border-l-4 border-blue-500 pl-4 py-2">
            <p class="font-medium text-gray-900">Push: "Exclusive Calculators" (High Value)</p>
            <p class="text-sm text-gray-600">1,240 notifications | 28% click rate | $0 cost</p>
            <div class="mt-2 w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: 72%"></div>
            </div>
          </div>
          <div class="border-l-4 border-yellow-500 pl-4 py-2">
            <p class="font-medium text-gray-900">Offer: "Return & Get Pro Free" (Churned)</p>
            <p class="text-sm text-gray-600">890 offers sent | 8% redemption | Cost per return: $2.50</p>
            <div class="mt-2 w-full bg-gray-200 rounded-full h-2">
              <div class="bg-yellow-600 h-2 rounded-full" style="width: 35%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Retention Metrics -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Retention Rates by Cohort</h2>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="px-4 py-3 text-left text-sm font-semibold">Cohort</th>
                <th class="px-4 py-3 text-center text-sm font-semibold">D1</th>
                <th class="px-4 py-3 text-center text-sm font-semibold">D7</th>
                <th class="px-4 py-3 text-center text-sm font-semibold">D30</th>
                <th class="px-4 py-3 text-center text-sm font-semibold">D60</th>
                <th class="px-4 py-3 text-center text-sm font-semibold">Trend</th>
              </tr>
            </thead>
            <tbody>
              {['May 2', 'May 1', 'Apr 30', 'Apr 29', 'Apr 28'].map((date, idx) => (
                <tr key={date} class="border-b border-gray-200">
                  <td class="px-4 py-3 text-sm font-medium">{date}</td>
                  <td class="px-4 py-3 text-center text-sm font-bold">
                    {100 - idx * 2}%
                  </td>
                  <td class="px-4 py-3 text-center text-sm">
                    {68 - idx * 4}%
                  </td>
                  <td class="px-4 py-3 text-center text-sm">
                    {42 - idx * 5}%
                  </td>
                  <td class="px-4 py-3 text-center text-sm">
                    {25 - idx * 3}%
                  </td>
                  <td class="px-4 py-3 text-center text-sm">
                    {idx === 0 ? (
                      <span class="text-green-600 font-bold">↑ +8%</span>
                    ) : (
                      <span class="text-gray-500">—</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
