---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Phase 6: Revenue & Monetization Dashboard
// Pricing, subscriptions, upsells, conversion tracking
---

<BaseLayout
  title="Revenue Dashboard — Phase 6"
  description="Monetization metrics and subscription tracking"
>
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-gray-900 mb-8">Phase 6: Revenue & Monetization</h1>

      <!-- Revenue Summary -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white rounded-lg shadow p-6">
          <p class="text-gray-600 text-sm font-medium">Monthly Recurring Revenue</p>
          <p class="text-3xl font-bold text-green-600 mt-2">$8,340</p>
          <p class="text-xs text-gray-500 mt-2">+45% vs last month</p>
        </div>
        <div class="bg-white rounded-lg shadow p-6">
          <p class="text-gray-600 text-sm font-medium">Active Subscriptions</p>
          <p class="text-3xl font-bold text-blue-600 mt-2">834</p>
          <p class="text-xs text-gray-500 mt-2">Pro + Premium plans</p>
        </div>
        <div class="bg-white rounded-lg shadow p-6">
          <p class="text-gray-600 text-sm font-medium">Conversion Rate</p>
          <p class="text-3xl font-bold text-purple-600 mt-2">2.1%</p>
          <p class="text-xs text-gray-500 mt-2">Paid / Free ratio</p>
        </div>
        <div class="bg-white rounded-lg shadow p-6">
          <p class="text-gray-600 text-sm font-medium">Average Revenue Per User</p>
          <p class="text-3xl font-bold text-indigo-600 mt-2">$10.02</p>
          <p class="text-xs text-gray-500 mt-2">ARPU</p>
        </div>
      </div>

      <!-- Pricing Plans -->
      <div class="bg-white rounded-lg shadow p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Pricing Plans & Performance</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Free Plan -->
          <div class="border-2 border-gray-200 rounded-lg p-6">
            <h3 class="text-lg font-bold text-gray-900">Free</h3>
            <p class="text-3xl font-bold text-gray-900 mt-2">$0<span class="text-lg text-gray-600">/mo</span></p>
            <ul class="mt-4 space-y-2 text-sm text-gray-600">
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span> Basic calculators
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span> Ads included
              </li>
              <li class="flex items-center gap-2">
                <span class="text-gray-400">✗</span> No premium tools
              </li>
            </ul>
            <p class="text-2xl font-bold text-gray-900 mt-6">12,400</p>
            <p class="text-xs text-gray-500">active users</p>
          </div>

          <!-- Pro Plan -->
          <div class="border-2 border-blue-600 rounded-lg p-6 bg-blue-50">
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-lg font-bold text-gray-900">Pro</h3>
              <span class="text-xs font-bold text-blue-600 bg-blue-100 px-2 py-1 rounded">POPULAR</span>
            </div>
            <p class="text-3xl font-bold text-gray-900 mt-2">$9.99<span class="text-lg text-gray-600">/mo</span></p>
            <ul class="mt-4 space-y-2 text-sm text-gray-600">
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span> All calculators
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span> Ad-free experience
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span> Email support
              </li>
            </ul>
            <p class="text-2xl font-bold text-blue-600 mt-6">542</p>
            <p class="text-xs text-gray-500">active subscriptions</p>
          </div>

          <!-- Premium Plan -->
          <div class="border-2 border-purple-600 rounded-lg p-6 bg-purple-50">
            <h3 class="text-lg font-bold text-gray-900">Premium</h3>
            <p class="text-3xl font-bold text-gray-900 mt-2">$99.99<span class="text-lg text-gray-600">/yr</span></p>
            <ul class="mt-4 space-y-2 text-sm text-gray-600">
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span> All Pro features
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span> API access
              </li>
              <li class="flex items-center gap-2">
                <span class="text-green-600">✓</span> Priority support
              </li>
            </ul>
            <p class="text-2xl font-bold text-purple-600 mt-6">292</p>
            <p class="text-xs text-gray-500">active subscriptions</p>
          </div>
        </div>
      </div>

      <!-- Revenue Metrics -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Revenue Trends -->
        <div class="bg-white rounded-lg shadow p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4">Monthly Revenue Trend</h3>
          <div class="space-y-3">
            {['Apr', 'May 1st', 'May 2nd'].map((month, idx) => (
              <div key={month} class="flex items-center gap-3">
                <div class="w-16 text-sm font-medium text-gray-600">{month}</div>
                <div class="flex-grow bg-gray-200 rounded-full h-6">
                  <div
                    class="bg-gradient-to-r from-green-500 to-green-600 h-6 rounded-full flex items-center justify-center text-white text-xs font-bold"
                    style={{ width: `${(idx + 1) * 35}%` }}
                  >
                    ${(5760 + idx * 1290).toFixed(0)}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Churn & Expansion -->
        <div class="bg-white rounded-lg shadow p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4">Key Metrics</h3>
          <div class="space-y-4">
            <div class="flex justify-between items-center py-2 border-b border-gray-200">
              <span class="text-gray-600">Monthly Churn Rate</span>
              <span class="text-lg font-bold text-red-600">3.2%</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-gray-200">
              <span class="text-gray-600">Gross Margin</span>
              <span class="text-lg font-bold text-green-600">92%</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-gray-200">
              <span class="text-gray-600">Free → Paid Conversion</span>
              <span class="text-lg font-bold text-blue-600">6.7%</span>
            </div>
            <div class="flex justify-between items-center py-2">
              <span class="text-gray-600">Lifetime Value (LTV)</span>
              <span class="text-lg font-bold text-purple-600">$142.50</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
