---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Phase 4: Real-time Analytics Dashboard
// Shows all key metrics: traffic, conversions, revenue, retention

const dashboardData = {
  period: 'Last 24h',
  timestamp: new Date().toISOString(),
  metrics: {
    traffic: {
      totalUsers: 12450,
      newUsers: 3420,
      sessions: 18930,
      pageViews: 156000,
      avgSessionDuration: '3m 42s',
      bounceRate: '32%',
    },
    engagement: {
      calculatorUse: 8920,
      feedbackSubmissions: 1240,
      abTestParticipants: 6230,
      avgCalcsPerUser: 2.4,
    },
    conversion: {
      signups: 1840,
      conversionRate: '14.7%',
      abTestWinner: 'Variant A',
      improvement: '+55%',
    },
    revenue: {
      premiumSignups: 0,
      mrr: '$0',
      totalRevenue: '$0',
      topProduct: 'N/A',
      aov: '$0',
    },
    retention: {
      dayOneRetention: '68%',
      daySevenRetention: '42%',
      dayThirtyRetention: '18%',
      churnRate: '2.1%',
    },
  },
};
---

<BaseLayout
  title="Analytics Dashboard — Phase 4"
  description="Real-time analytics, conversion metrics, and retention tracking"
>
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Phase 4: Measure Systematically</h1>
        <p class="text-gray-600">Real-time analytics and data-driven decision making</p>
      </div>

      <!-- Key Metrics Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <!-- Traffic -->
        <div class="bg-white rounded-lg shadow p-6">
          <p class="text-gray-600 text-sm font-medium">Total Users (24h)</p>
          <p class="text-3xl font-bold text-blue-600 mt-2">{dashboardData.metrics.traffic.totalUsers.toLocaleString()}</p>
          <p class="text-xs text-gray-500 mt-2">+{dashboardData.metrics.traffic.newUsers.toLocaleString()} new</p>
        </div>

        <!-- Conversions -->
        <div class="bg-white rounded-lg shadow p-6">
          <p class="text-gray-600 text-sm font-medium">Conversion Rate</p>
          <p class="text-3xl font-bold text-green-600 mt-2">{dashboardData.metrics.conversion.conversionRate}</p>
          <p class="text-xs text-green-500 mt-2">{dashboardData.metrics.conversion.improvement} vs control</p>
        </div>

        <!-- Revenue -->
        <div class="bg-white rounded-lg shadow p-6">
          <p class="text-gray-600 text-sm font-medium">MRR (Phase 6)</p>
          <p class="text-3xl font-bold text-purple-600 mt-2">{dashboardData.metrics.revenue.mrr}</p>
          <p class="text-xs text-gray-500 mt-2">{dashboardData.metrics.revenue.premiumSignups} premium signups</p>
        </div>

        <!-- Retention -->
        <div class="bg-white rounded-lg shadow p-6">
          <p class="text-gray-600 text-sm font-medium">D1 Retention</p>
          <p class="text-3xl font-bold text-indigo-600 mt-2">{dashboardData.metrics.retention.dayOneRetention}</p>
          <p class="text-xs text-gray-500 mt-2">Churn: {dashboardData.metrics.retention.churnRate}</p>
        </div>
      </div>

      <!-- Traffic Metrics -->
      <div class="bg-white rounded-lg shadow p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Traffic & Engagement</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="border-b-2 border-blue-200 pb-3">
            <p class="text-sm text-gray-600">Sessions</p>
            <p class="text-2xl font-bold text-gray-900">{dashboardData.metrics.traffic.sessions.toLocaleString()}</p>
          </div>
          <div class="border-b-2 border-blue-200 pb-3">
            <p class="text-sm text-gray-600">Page Views</p>
            <p class="text-2xl font-bold text-gray-900">{dashboardData.metrics.traffic.pageViews.toLocaleString()}</p>
          </div>
          <div class="border-b-2 border-blue-200 pb-3">
            <p class="text-sm text-gray-600">Avg Session</p>
            <p class="text-2xl font-bold text-gray-900">{dashboardData.metrics.traffic.avgSessionDuration}</p>
          </div>
          <div class="border-b-2 border-blue-200 pb-3">
            <p class="text-sm text-gray-600">Bounce Rate</p>
            <p class="text-2xl font-bold text-gray-900">{dashboardData.metrics.traffic.bounceRate}</p>
          </div>
        </div>
      </div>

      <!-- Conversion Funnel -->
      <div class="bg-white rounded-lg shadow p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Conversion Funnel</h2>
        <div class="space-y-3">
          <div class="flex items-center gap-4">
            <div class="w-24 text-sm font-medium text-gray-600">Visitors</div>
            <div class="flex-grow bg-gray-200 rounded-full h-8" style="width: 100%">
              <div class="bg-blue-600 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold"
                style="width: 100%">
                {dashboardData.metrics.traffic.totalUsers.toLocaleString()}
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-24 text-sm font-medium text-gray-600">Engaged</div>
            <div class="flex-grow bg-gray-200 rounded-full h-8">
              <div class="bg-green-600 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold"
                style="width: 71%">
                {dashboardData.metrics.engagement.calculatorUse.toLocaleString()}
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-24 text-sm font-medium text-gray-600">Converted</div>
            <div class="flex-grow bg-gray-200 rounded-full h-8">
              <div class="bg-purple-600 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold"
                style="width: 14.7%">
                {dashboardData.metrics.conversion.signups.toLocaleString()}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Retention Cohort -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Retention by Cohort</h2>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="px-4 py-3 text-left text-sm font-semibold text-gray-900">Cohort</th>
                <th class="px-4 py-3 text-center text-sm font-semibold text-gray-900">D0</th>
                <th class="px-4 py-3 text-center text-sm font-semibold text-gray-900">D1</th>
                <th class="px-4 py-3 text-center text-sm font-semibold text-gray-900">D7</th>
                <th class="px-4 py-3 text-center text-sm font-semibold text-gray-900">D30</th>
                <th class="px-4 py-3 text-center text-sm font-semibold text-gray-900">Trend</th>
              </tr>
            </thead>
            <tbody>
              {['2026-05-02', '2026-05-01', '2026-04-30', '2026-04-29'].map((cohort, idx) => (
                <tr key={cohort} class="border-b border-gray-200 hover:bg-gray-50">
                  <td class="px-4 py-3 text-sm font-medium text-gray-900">{cohort}</td>
                  <td class="px-4 py-3 text-center text-sm text-gray-900 font-bold">100%</td>
                  <td class="px-4 py-3 text-center text-sm" style={{ color: idx === 0 ? '#10b981' : '#6b7280' }}>
                    {68 - idx * 5}%
                  </td>
                  <td class="px-4 py-3 text-center text-sm" style={{ color: idx === 0 ? '#f59e0b' : '#6b7280' }}>
                    {42 - idx * 6}%
                  </td>
                  <td class="px-4 py-3 text-center text-sm" style={{ color: idx === 0 ? '#ef4444' : '#6b7280' }}>
                    {18 - idx * 3}%
                  </td>
                  <td class="px-4 py-3 text-center text-sm">
                    {idx === 0 ? (
                      <span class="text-green-600 font-bold">↑ Improving</span>
                    ) : (
                      <span class="text-gray-500">Stable</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
