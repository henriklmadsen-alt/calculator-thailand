---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณต้นทุนและรายได้ปลูกมันสำปะหลัง | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการปลูกมันสำปะหลัง ต้นทุนต่อไร่ ราคามัน กำไรต่อฤดูกาล';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0495-ปลูกมัน/`;
const faqData = [
  { question: 'ผลผลิตมันสำปะหลังต่อไร่เฉลี่ยเท่าไหร่?', answer: 'มันสำปะหลังผลผลิตเฉลี่ย 3-5 ตัน/ไร่ พันธุ์ดีที่ดูแลดีอาจได้ 5-8 ตัน/ไร่ เก็บเกี่ยวหลังปลูก 8-12 เดือน พันธุ์แนะนำ ระยอง 9, 72, KU50' },
  { question: 'ราคามันสำปะหลังสดเฉลี่ยเท่าไหร่?', answer: 'มันสำปะหลังสดที่เปอร์เซ็นต์แป้ง 25% ราคาประมาณ 1.5-2.5 บาท/กก. ราคาขึ้นอยู่กับ %แป้ง ฤดูกาล และตลาดส่งออก ติดตามราคาจากสำนักงานเศรษฐกิจการเกษตร' },
  { question: 'ต้นทุนปลูกมันสำปะหลังต่อไร่เท่าไหร่?', answer: 'ต้นทุนมันสำปะหลัง 2,500-4,000 บาท/ไร่ รายการหลักคือ ค่าพันธุ์ท่อน ปุ๋ย ยา แรงงาน ค่าเช่าที่ดิน ค่าเก็บเกี่ยวและขนส่ง' },
  { question: 'มันสำปะหลังปลูกซ้ำได้กี่ครั้ง?', answer: 'ปลูกซ้ำในพื้นเดิมได้ แต่ควรหมุนเวียนพืชทุก 2-3 รอบ เพื่อรักษาความอุดมสมบูรณ์ของดิน มันสำปะหลังดูดธาตุอาหารมาก ควรใส่ปุ๋ยอินทรีย์เสริม' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนและรายได้ปลูกมันสำปะหลัง">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนและรายได้ปลูกมันสำปะหลัง</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนและกำไรการปลูกมันสำปะหลัง</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="cassava_area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่ปลูก (ไร่)</label><input type="number" id="cassava_area" min="1" placeholder="เช่น 25" value="25" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="cassava_cost_rai" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนต่อไร่ (บาท)</label><input type="text" id="cassava_cost_rai" inputmode="decimal" placeholder="เช่น 3200" value="3200" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="cassava_yield_rai" class="block text-sm font-medium text-gray-700 mb-1">ผลผลิตต่อไร่ (ตัน)</label><input type="text" id="cassava_yield_rai" inputmode="decimal" placeholder="เช่น 4" value="4" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="cassava_price_kg" class="block text-sm font-medium text-gray-700 mb-1">ราคามัน (บาท/กก.)</label><input type="text" id="cassava_price_kg" inputmode="decimal" placeholder="เช่น 2.2" value="2.2" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้รวม</p><p id="cassava_revenue" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">กำไรสุทธิ</p><p id="cassava_profit" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const area = parseFloat((document.getElementById('cassava_area') as HTMLInputElement).value) || 0;
      const costRai = parseFloat((document.getElementById('cassava_cost_rai') as HTMLInputElement).value) || 0;
      const yieldRai = parseFloat((document.getElementById('cassava_yield_rai') as HTMLInputElement).value) || 0;
      const priceKg = parseFloat((document.getElementById('cassava_price_kg') as HTMLInputElement).value) || 0;
      const totalCost = area * costRai;
      const revenue = area * yieldRai * 1000 * priceKg;
      const profit = revenue - totalCost;
      (document.getElementById('cassava_revenue') as HTMLElement).textContent = Math.round(revenue).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('cassava_profit') as HTMLElement).textContent = Math.round(profit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('cassava-farming-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
