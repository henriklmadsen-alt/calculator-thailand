---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณอัตรากำไรสุทธิ | Kamnuanlek';
const pageDescription = 'คำนวณอัตรากำไรสุทธิ Net Profit Margin กำไรสุทธิหลังหักค่าใช้จ่ายและภาษีทั้งหมด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0472-กำไรสุทธิ/`;
const faqData = [
  { question: 'Net Profit Margin ที่ดีสำหรับธุรกิจไทยเป็นเท่าไหร่?', answer: 'ขึ้นอยู่กับอุตสาหกรรม ร้านอาหาร 3-9% ค้าปลีก 2-5% ซอฟต์แวร์ 15-25% บริการวิชาชีพ 10-20% ธุรกิจที่ Margin ต่ำต้องมียอดขายสูงชดเชย' },
  { question: 'Net Profit ต่างจาก EBITDA อย่างไร?', answer: 'Net Profit คือกำไรหลังหักทุกอย่างรวมภาษี EBITDA คือกำไรก่อนดอกเบี้ย ภาษี ค่าเสื่อม ใช้เปรียบเทียบประสิทธิภาพการดำเนินงาน' },
  { question: 'Net Profit Margin ลดลงเกิดจากอะไร?', answer: 'Margin ลดอาจเกิดจาก ต้นทุนสูงขึ้น ราคาขายไม่ขึ้นตาม OpEx เพิ่ม ยอดขายลด ภาษีเพิ่ม ดอกเบี้ยสูงขึ้น หรือสินค้า Mix ไปสู่สินค้า Margin ต่ำ' },
  { question: 'EBIT Operating Margin คืออะไร?', answer: 'Operating Margin = EBIT ÷ รายได้ × 100% วัดประสิทธิภาพการดำเนินงานก่อนรายการทางการเงินและภาษี เหมาะเปรียบเทียบบริษัทที่มีโครงสร้างทุนต่างกัน' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณอัตรากำไรสุทธิ">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณอัตรากำไรสุทธิ</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณกำไรสุทธิและ Net Profit Margin ของธุรกิจ</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="total_revenue" class="block text-sm font-medium text-gray-700 mb-1">รายได้รวม (บาท)</label><input type="text" id="total_revenue" inputmode="decimal" placeholder="เช่น 5000000" value="5000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="total_cogs" class="block text-sm font-medium text-gray-700 mb-1">COGS ต้นทุนสินค้า (บาท)</label><input type="text" id="total_cogs" inputmode="decimal" placeholder="เช่น 3000000" value="3000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="total_opex_nm" class="block text-sm font-medium text-gray-700 mb-1">OpEx ค่าใช้จ่ายดำเนินงาน (บาท)</label><input type="text" id="total_opex_nm" inputmode="decimal" placeholder="เช่น 1200000" value="1200000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="tax_nm" class="block text-sm font-medium text-gray-700 mb-1">ภาษีที่จ่าย (บาท)</label><input type="text" id="tax_nm" inputmode="decimal" placeholder="เช่น 120000" value="120000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">กำไรสุทธิ</p><p id="net_profit_nm" class="font-bold">-</p></div>
          <div class="bg-indigo-50 rounded p-3"><p class="text-sm text-gray-600">Net Profit Margin</p><p id="net_margin_nm" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const revenue = parseFloat((document.getElementById('total_revenue') as HTMLInputElement).value) || 0;
      const cogs = parseFloat((document.getElementById('total_cogs') as HTMLInputElement).value) || 0;
      const opex = parseFloat((document.getElementById('total_opex_nm') as HTMLInputElement).value) || 0;
      const tax = parseFloat((document.getElementById('tax_nm') as HTMLInputElement).value) || 0;
      const netProfit = revenue - cogs - opex - tax;
      const netMargin = revenue > 0 ? (netProfit / revenue * 100) : 0;
      (document.getElementById('net_profit_nm') as HTMLElement).textContent = netProfit.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('net_margin_nm') as HTMLElement).textContent = netMargin.toFixed(2) + '%';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('net-profit-margin');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
