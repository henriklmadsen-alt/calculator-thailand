---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณความชัน slope จากสองจุด สมการเส้นตรง ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณความชัน (slope) ของเส้นตรง จากพิกัด 2 จุด สมการ y=mx+b และมุมเอียง ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณความชัน/`;

const faqData = [
  {
    question: 'ความชัน (slope) คืออะไร?',
    answer: 'ความชัน (slope, m) คืออัตราการเปลี่ยนแปลงของ y เมื่อ x เพิ่มขึ้น 1 หน่วย คำนวณจากสูตร m = (y₂ - y₁)/(x₂ - x₁) ความชันบวกหมายถึงเส้นขึ้น ความชันลบหมายถึงเส้นลง ความชัน 0 หมายถึงเส้นแนวนอน',
  },
  {
    question: 'ความชันกับมุมเอียงเกี่ยวข้องกันอย่างไร?',
    answer: 'ความชัน m = tan(θ) โดย θ คือมุมที่เส้นตรงทำกับแกน x ดังนั้น θ = arctan(m) ตัวอย่าง: ความชัน 1 ตรงกับมุม 45 องศา ความชัน √3 ตรงกับมุม 60 องศา',
  },
  {
    question: 'เส้นตรงแนวดิ่งมีความชันเท่าไหร่?',
    answer: 'เส้นตรงแนวดิ่ง (vertical line) ไม่มีค่าความชัน (undefined slope) เพราะ x₁ = x₂ ทำให้ส่วนหาร x₂ - x₁ = 0 ซึ่งไม่สามารถหารได้ สมการของเส้นแนวดิ่งคือ x = ค่าคงที่ ไม่ใช่ y = mx + b',
  },
  {
    question: 'สมการเส้นตรง y = mx + b ตีความได้อย่างไร?',
    answer: 'm คือความชัน (slope) แสดงความชันของเส้น ส่วน b คือจุดตัดแกน y (y-intercept) คือค่า y เมื่อ x = 0 ตัวอย่าง: y = 2x + 3 หมายถึงเส้นที่มีความชัน 2 และตัดแกน y ที่จุด (0, 3)',
  },
  {
    question: 'เส้นขนานกันมีความชันเท่ากันไหม?',
    answer: 'ใช่ เส้นขนานกันจะมีความชันเท่ากันเสมอ (m₁ = m₂) ส่วนเส้นตั้งฉากกันจะมีความชันคูณกันได้ -1 นั่นคือ m₁ × m₂ = -1 หรือ m₂ = -1/m₁',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณความชันและสมการเส้นตรง',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'EducationApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณความชันและสมการเส้นตรงจากสองจุด',
  description: 'ขั้นตอนการคำนวณความชัน จุดตัดแกน y สมการเส้นตรง และมุมเอียง',
  step: [
    {
      '@type': 'HowToStep',
      name: 'กรอกพิกัดสองจุด',
      text: 'ใส่ค่า x₁, y₁ และ x₂, y₂ ของสองจุดบนเส้นตรง x₁ และ x₂ ต้องไม่เท่ากัน (ยกเว้นเส้นแนวดิ่ง)',
    },
    {
      '@type': 'HowToStep',
      name: 'กดคำนวณความชัน',
      text: 'กดปุ่ม "คำนวณ" เครื่องจะคำนวณความชัน m = (y₂-y₁)/(x₂-x₁) และจุดตัดแกน y',
    },
    {
      '@type': 'HowToStep',
      name: 'อ่านสมการเส้นตรง',
      text: 'ผลลัพธ์แสดงสมการในรูป y = mx + b พร้อมมุมเอียงเป็นองศา',
    },
    {
      '@type': 'HowToStep',
      name: 'ใช้โหมดความชันและจุด',
      text: 'หากทราบความชันและจุดหนึ่ง ใช้โหมด 2 เพื่อหาสมการเส้นตรงในรูปมาตรฐาน',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณความชัน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณความชัน สมการเส้นตรง และมุมเอียงในหน้าเดียว</p>
      <p class="mt-1 text-sm text-slate-700">รองรับเส้นแนวดิ่ง แสดงสมการ y=mx+b และมุมเป็นองศา</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณความชัน (Slope) และสมการเส้นตรง ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณความชัน (slope) ของเส้นตรงจากพิกัดสองจุด หรือจากความชันและจุดหนึ่ง
      พร้อมแสดงสมการเส้นตรง y = mx + b จุดตัดแกน y และมุมเอียงเป็นองศา
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'สสวท. (SciMath): สมการเส้นตรงและกราฟ',
        'ECMAScript: Math.atan สำหรับคำนวณมุม',
      ]}
      assumptions={[
        'มุมเอียงคำนวณจาก arctan(m) แสดงเป็นองศา',
        'เส้นแนวดิ่ง (x₁ = x₂) แสดงว่าความชันไม่นิยาม',
      ]}
      references={[
        {
          label: 'SciMath: สมการเส้นตรงในระบบพิกัดฉาก',
          href: 'https://www.scimath.org/article-mathematics/item/11474-3',
        },
      ]}
    />

    <!-- Mode 1: Two points -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">1) คำนวณจากสองจุด (x₁,y₁) และ (x₂,y₂)</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: จุด (1, 2) และ (3, 8) → m = 3, b = -1, y = 3x - 1</p>
      <div class="grid gap-3 sm:grid-cols-2">
        <div>
          <label for="slope-x1" class="block text-sm font-medium text-gray-700 mb-1">x₁</label>
          <input id="slope-x1" type="text" inputmode="decimal" placeholder="เช่น 1" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label for="slope-y1" class="block text-sm font-medium text-gray-700 mb-1">y₁</label>
          <input id="slope-y1" type="text" inputmode="decimal" placeholder="เช่น 2" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label for="slope-x2" class="block text-sm font-medium text-gray-700 mb-1">x₂</label>
          <input id="slope-x2" type="text" inputmode="decimal" placeholder="เช่น 3" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label for="slope-y2" class="block text-sm font-medium text-gray-700 mb-1">y₂</label>
          <input id="slope-y2" type="text" inputmode="decimal" placeholder="เช่น 8" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
      </div>
      <button id="btn-slope-two" type="button" class="mt-3 w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700 sm:w-auto sm:px-6">คำนวณ</button>
      <p id="slope-two-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="slope-two-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4 space-y-1">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="slope-two-m" class="text-base font-semibold text-primary-700">-</p>
        <p id="slope-two-b" class="text-base font-semibold text-primary-700">-</p>
        <p id="slope-two-eq" class="text-base font-bold text-primary-800">-</p>
        <p id="slope-two-angle" class="text-sm text-gray-600">-</p>
      </div>
    </div>

    <!-- Mode 2: Slope and one point -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">2) คำนวณจากความชันและจุดหนึ่ง</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: m = 2, จุด (1, 5) → y = 2x + 3</p>
      <div class="grid gap-3 sm:grid-cols-3">
        <div>
          <label for="slope-m" class="block text-sm font-medium text-gray-700 mb-1">ความชัน m</label>
          <input id="slope-m" type="text" inputmode="decimal" placeholder="เช่น 2" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label for="slope-px" class="block text-sm font-medium text-gray-700 mb-1">x₀</label>
          <input id="slope-px" type="text" inputmode="decimal" placeholder="เช่น 1" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label for="slope-py" class="block text-sm font-medium text-gray-700 mb-1">y₀</label>
          <input id="slope-py" type="text" inputmode="decimal" placeholder="เช่น 5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
      </div>
      <button id="btn-slope-pt" type="button" class="mt-3 w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700 sm:w-auto sm:px-6">คำนวณ</button>
      <p id="slope-pt-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="slope-pt-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4 space-y-1">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="slope-pt-eq" class="text-base font-bold text-primary-800">-</p>
        <p id="slope-pt-b" class="text-base text-gray-600">-</p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#slope-pt-result" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรความชันและเส้นตรงที่ควรรู้</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ความชัน: m = (y₂ - y₁) / (x₂ - x₁)</li>
        <li>สมการเส้นตรง: y = mx + b</li>
        <li>จุดตัดแกน y: b = y₁ - m × x₁</li>
        <li>มุมเอียง: θ = arctan(m) (หน่วยองศา)</li>
        <li>เส้นขนาน: m₁ = m₂</li>
        <li>เส้นตั้งฉาก: m₁ × m₂ = -1</li>
      </ul>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณความชัน/" />
    <RelatedCalculators currentHref="/คำนวณความชัน/" />
  </article>
</BaseLayout>

<script>
  const parseNum = (v) => parseFloat(String(v).replace(/,/g, '').trim());

  const setError = (id, msg) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg || '';
    msg ? el.classList.remove('hidden') : el.classList.add('hidden');
  };

  const setText = (id, text) => { const el = document.getElementById(id); if (el) el.textContent = text; };

  const fmtNum = (n) => {
    const s = n.toFixed(6).replace(/\.?0+$/, '');
    return s === '-0' ? '0' : s;
  };

  document.getElementById('btn-slope-two')?.addEventListener('click', () => {
    setError('slope-two-error', '');
    const x1 = parseNum(document.getElementById('slope-x1')?.value);
    const y1 = parseNum(document.getElementById('slope-y1')?.value);
    const x2 = parseNum(document.getElementById('slope-x2')?.value);
    const y2 = parseNum(document.getElementById('slope-y2')?.value);
    if ([x1,y1,x2,y2].some(v => !Number.isFinite(v))) { setError('slope-two-error', 'กรุณากรอกพิกัดให้ครบทั้ง 4 ค่า'); return; }
    if (x1 === x2) {
      setText('slope-two-m', 'ความชัน m = ไม่นิยาม (เส้นแนวดิ่ง)');
      setText('slope-two-b', '');
      setText('slope-two-eq', `สมการ: x = ${x1}`);
      setText('slope-two-angle', 'มุมเอียง = 90°');
      document.getElementById('slope-two-result')?.classList.remove('hidden');
      return;
    }
    const m = (y2 - y1) / (x2 - x1);
    const b = y1 - m * x1;
    const angle = Math.atan(m) * 180 / Math.PI;
    const bSign = b >= 0 ? `+ ${fmtNum(b)}` : `- ${fmtNum(Math.abs(b))}`;
    setText('slope-two-m', `ความชัน m = ${fmtNum(m)}`);
    setText('slope-two-b', `จุดตัดแกน y (b) = ${fmtNum(b)}`);
    setText('slope-two-eq', `สมการ: y = ${fmtNum(m)}x ${bSign}`);
    setText('slope-two-angle', `มุมเอียง = ${fmtNum(angle)}°`);
    document.getElementById('slope-two-result')?.classList.remove('hidden');
  });

  document.getElementById('btn-slope-pt')?.addEventListener('click', () => {
    setError('slope-pt-error', '');
    const m = parseNum(document.getElementById('slope-m')?.value);
    const px = parseNum(document.getElementById('slope-px')?.value);
    const py = parseNum(document.getElementById('slope-py')?.value);
    if ([m,px,py].some(v => !Number.isFinite(v))) { setError('slope-pt-error', 'กรุณากรอกค่าให้ครบ'); return; }
    const b = py - m * px;
    const bSign = b >= 0 ? `+ ${fmtNum(b)}` : `- ${fmtNum(Math.abs(b))}`;
    setText('slope-pt-eq', `สมการ: y = ${fmtNum(m)}x ${bSign}`);
    setText('slope-pt-b', `จุดตัดแกน y (b) = ${fmtNum(b)}`);
    document.getElementById('slope-pt-result')?.classList.remove('hidden');
  });
</script>
