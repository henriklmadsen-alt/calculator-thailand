---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าใช้จ่ายดำเนินงาน | Kamnuanlek';
const pageDescription = 'คำนวณค่าใช้จ่ายดำเนินงาน Operating Expenses ค่าเช่า เงินเดือน สาธารณูปโภค การตลาด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0465-ค่าดำเนินงาน/`;
const faqData = [
  { question: 'ค่าใช้จ่ายดำเนินงาน OpEx คืออะไร?', answer: 'OpEx (Operating Expenses) คือค่าใช้จ่ายในการดำเนินธุรกิจประจำวัน ได้แก่ เงินเดือน ค่าเช่า สาธารณูปโภค การตลาด ซ่อมบำรุง ไม่รวม COGS และ CapEx' },
  { question: 'OpEx ต่างจาก CapEx อย่างไร?', answer: 'OpEx เป็นรายจ่ายประจำวัน CapEx (Capital Expenditures) เป็นการลงทุนในสินทรัพย์ถาวร เช่น เครื่องจักร ซอฟต์แวร์ที่มีอายุใช้งานยาวนาน' },
  { question: 'ค่าใช้จ่ายดำเนินงานควรเป็นกี่เปอร์เซ็นต์ของรายได้?', answer: 'ขึ้นอยู่กับอุตสาหกรรม ธุรกิจบริการ OpEx อาจสูง 60-80% ธุรกิจค้าปลีก 20-35% เป้าหมายคือให้รายได้ - COGS - OpEx = กำไรปฏิบัติการที่เป็นบวก' },
  { question: 'จะลด OpEx ได้อย่างไร?', answer: 'ลด OpEx โดย ทำ Remote Work ลดค่าเช่า ใช้ซอฟต์แวร์ Cloud แทนเซิร์ฟเวอร์ Outsource งานที่ไม่ใช่ Core Business ต่อรองสัญญาซัพพลายเออร์' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าใช้จ่ายดำเนินงาน">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าใช้จ่ายดำเนินงาน</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">สรุปค่าใช้จ่ายดำเนินงานรายเดือนและรายปีของธุรกิจ</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="salary_opex" class="block text-sm font-medium text-gray-700 mb-1">เงินเดือนพนักงานรวม (บาท/เดือน)</label><input type="text" id="salary_opex" inputmode="decimal" placeholder="เช่น 150000" value="150000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="rent_opex" class="block text-sm font-medium text-gray-700 mb-1">ค่าเช่า (บาท/เดือน)</label><input type="text" id="rent_opex" inputmode="decimal" placeholder="เช่น 40000" value="40000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="util_opex" class="block text-sm font-medium text-gray-700 mb-1">สาธารณูปโภค (บาท/เดือน)</label><input type="text" id="util_opex" inputmode="decimal" placeholder="เช่น 10000" value="10000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="mktg_opex" class="block text-sm font-medium text-gray-700 mb-1">การตลาดและโฆษณา (บาท/เดือน)</label><input type="text" id="mktg_opex" inputmode="decimal" placeholder="เช่น 20000" value="20000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="other_opex" class="block text-sm font-medium text-gray-700 mb-1">ค่าใช้จ่ายอื่นๆ (บาท/เดือน)</label><input type="text" id="other_opex" inputmode="decimal" placeholder="เช่น 15000" value="15000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">OpEx ต่อเดือน</p><p id="monthly_opex" class="font-bold">-</p></div>
          <div class="bg-indigo-50 rounded p-3"><p class="text-sm text-gray-600">OpEx ต่อปี</p><p id="yearly_opex" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const salary = parseFloat((document.getElementById('salary_opex') as HTMLInputElement).value) || 0;
      const rent = parseFloat((document.getElementById('rent_opex') as HTMLInputElement).value) || 0;
      const util = parseFloat((document.getElementById('util_opex') as HTMLInputElement).value) || 0;
      const mktg = parseFloat((document.getElementById('mktg_opex') as HTMLInputElement).value) || 0;
      const other = parseFloat((document.getElementById('other_opex') as HTMLInputElement).value) || 0;
      const monthlyOpex = salary + rent + util + mktg + other;
      const yearlyOpex = monthlyOpex * 12;
      (document.getElementById('monthly_opex') as HTMLElement).textContent = monthlyOpex.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('yearly_opex') as HTMLElement).textContent = yearlyOpex.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('operating-expenses');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
