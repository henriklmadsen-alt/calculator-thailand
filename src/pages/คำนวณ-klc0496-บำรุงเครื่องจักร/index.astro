---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าบำรุงรักษาเครื่องจักรการเกษตร | Kamnuanlek';
const pageDescription = 'คำนวณค่าบำรุงรักษาเครื่องจักรเกษตร ค่าน้ำมัน อะไหล่ ซ่อมบำรุงประจำปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0496-บำรุงเครื่องจักร/`;
const faqData = [
  { question: 'ค่าบำรุงรักษาเครื่องจักรเกษตรควรตั้งงบเท่าไหร่?', answer: 'ตั้งงบบำรุงรักษา 5-10% ของมูลค่าเครื่องจักรต่อปี เครื่องเก่า (มากกว่า 5 ปี) อาจสูงถึง 10-15% การบำรุงรักษาเชิงป้องกันช่วยลดค่าซ่อมฉุกเฉินได้มาก' },
  { question: 'เปลี่ยนน้ำมันเครื่องรถไถทุกกี่ชั่วโมง?', answer: 'รถไถนา เปลี่ยนน้ำมันเครื่องทุก 100-200 ชั่วโมง กรองน้ำมัน 200-300 ชั่วโมง กรองอากาศทำความสะอาดทุก 50-100 ชั่วโมง ตรวจน้ำมันเฟืองท้ายทุก 500 ชั่วโมง' },
  { question: 'อะไหล่รถเกี่ยวข้าวที่ต้องเปลี่ยนบ่อยมีอะไร?', answer: 'ใบมีดสแตนเลส สายพานทุกเส้น ตะแกรงคัดข้าว ตีนผีนวดข้าว ควรสต็อกอะไหล่ก่อนเข้าฤดูกาล อะไหล่ไม่มี = หยุดเก็บเกี่ยว = สูญเสียรายได้' },
  { question: 'ซ่อมเองหรือจ้างช่างดีกว่ากัน?', answer: 'ซ่อมเองประหยัดค่าแรง 50-70% แต่ต้องมีความรู้ด้านช่าง อุปกรณ์ครบ และอะไหล่พร้อม งานซับซ้อนหรือการันตีผล ควรจ้างช่างที่ผ่านการรับรองจากผู้ผลิต' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าบำรุงรักษาเครื่องจักรการเกษตร">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าบำรุงรักษาเครื่องจักรเกษตร</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนบำรุงรักษาเครื่องจักรรายปี</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="maint_oil_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าน้ำมันหล่อลื่น/ปี (บาท)</label><input type="text" id="maint_oil_cost" inputmode="decimal" placeholder="เช่น 8000" value="8000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="maint_parts_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าอะไหล่และอุปกรณ์/ปี (บาท)</label><input type="text" id="maint_parts_cost" inputmode="decimal" placeholder="เช่น 15000" value="15000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="maint_labor_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าแรงช่าง/ปี (บาท)</label><input type="text" id="maint_labor_cost" inputmode="decimal" placeholder="เช่น 10000" value="10000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="maint_fuel_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าเชื้อเพลิง/ปี (บาท)</label><input type="text" id="maint_fuel_cost" inputmode="decimal" placeholder="เช่น 25000" value="25000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ค่าบำรุงรักษารวม/ปี</p><p id="maint_total" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">ค่าบำรุงรักษา/เดือน</p><p id="maint_monthly" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const oil = parseFloat((document.getElementById('maint_oil_cost') as HTMLInputElement).value) || 0;
      const parts = parseFloat((document.getElementById('maint_parts_cost') as HTMLInputElement).value) || 0;
      const labor = parseFloat((document.getElementById('maint_labor_cost') as HTMLInputElement).value) || 0;
      const fuel = parseFloat((document.getElementById('maint_fuel_cost') as HTMLInputElement).value) || 0;
      const total = oil + parts + labor + fuel;
      const monthly = total / 12;
      (document.getElementById('maint_total') as HTMLElement).textContent = Math.round(total).toLocaleString('th-TH') + ' บาท/ปี';
      (document.getElementById('maint_monthly') as HTMLElement).textContent = Math.round(monthly).toLocaleString('th-TH') + ' บาท/เดือน';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('farm-machinery-maintenance');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
