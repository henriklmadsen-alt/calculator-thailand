---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณภาษีเงินได้บุคคล 2569 ฟรี | Calculator Thailand';
const pageDescription = 'คำนวณภาษีเงินได้ 2569 ฟรี ตามขั้นบันได พร้อมลดหย่อน SSO ประกันสังคม สรุปรายปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีเงินได้บุคคลธรรมดา/`;

const faqData = [
  {
    question: 'ภาษีเงินได้บุคคลธรรมดาคำนวณอย่างไร?',
    answer: 'ภาษีเงินได้บุคคลธรรมดาคำนวณจากรายได้สุทธิ (รายได้ - ค่าใช้จ่าย - ค่าลดหย่อน) แล้วนำไปคำนวณตามอัตราภาษีแบบขั้นบันได ตั้งแต่ 0% ถึง 35% ตามช่วงรายได้สุทธิ',
  },
  {
    question: 'ค่าลดหย่อนส่วนตัวปี 2569 เป็นเท่าไร?',
    answer: 'ค่าลดหย่อนส่วนตัวปี 2569 คือ 60,000 บาท สำหรับผู้มีเงินได้ทุกคน นอกจากนี้ยังมีค่าลดหย่อนคู่สมรส 60,000 บาท และค่าลดหย่อนบุตร 30,000 บาทต่อคน',
  },
  {
    question: 'รายได้เท่าไรจึงต้องเสียภาษี?',
    answer: 'หลังหักค่าใช้จ่ายและค่าลดหย่อนแล้ว หากรายได้สุทธิไม่เกิน 150,000 บาทต่อปี จะได้รับการยกเว้นภาษี (อัตรา 0%) รายได้สุทธิส่วนที่เกิน 150,000 บาท จึงเริ่มเสียภาษีในอัตรา 5%',
  },
  {
    question: 'ประกันสังคมลดหย่อนภาษีได้สูงสุดเท่าไร?',
    answer: 'เงินสมทบประกันสังคมสามารถนำมาลดหย่อนภาษีได้ตามจริง สูงสุดไม่เกิน 9,000 บาทต่อปี',
  },
  {
    question: 'ค่าใช้จ่ายหักเหมาเป็นเท่าไร?',
    answer: 'ผู้มีเงินได้ประเภทเงินเดือน (40(1)) สามารถหักค่าใช้จ่ายเหมาได้ 50% ของรายได้ แต่ไม่เกิน 100,000 บาท',
  },
  {
    question: 'ข้อผิดพลาดทั่วไปในการคำนวณภาษีที่ต้องหลีกเลี่ยง?',
    answer: 'ข้อผิดพลาดทั่วไปคือ: (1) ลืมหักค่าลดหย่อนคู่สมรส (2) คิดค่าลดหย่อนบุตรมากเกินจำนวน (3) หักประกันสังคมเกิน 9,000 บาท (4) ใช้อัตราภาษีคงที่แทนระบบขั้นบันได (5) ลืมหักค่าใช้จ่ายเหมา 50% ของรายได้ คำนวณในเครื่องคำนวณนี้เพื่อหลีกเลี่ยงข้อผิดพลาด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณภาษีเงินได้บุคคลธรรมดา 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'THB',
  },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณภาษีเงินได้บุคคลธรรมดา ปี 2569',
  description: 'ขั้นตอนการคำนวณภาษีเงินได้ตามอัตราขั้นบันได พร้อมค่าลดหย่อนฐาน ค่าลดหย่อนหลักทั้งหมด',
  step: [
    {
      '@type': 'HowToStep',
      name: 'เลือกประเภทรายได้',
      text: 'ระบุว่าคุณมีรายได้ประเภทใด: (1) เงินเดือน (มาตรา 40(1)) (2) อื่นๆ มาตรา 40 (3) รายได้จากสินทรัพย์ หรือ (4) รายได้อื่น ประเภทต่างๆ จะมีวิธีหักค่าใช้จ่ายที่ต่างกัน',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกรายได้รวมทั้งหมด',
      text: 'ป้อนเงินเดือนรายปี หรือรายได้รวมทั้งหมดในปีที่ต้องการคำนวณภาษี (ข้อมูลจากใบเสร็จเงินเดือน ใบปะหน้าบัญชีบาท หรือเอกสารรับรองรายได้)',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกค่าใช้จ่ายหรือค่าใช้จ่ายเหมา',
      text: 'ป้อนค่าใช้จ่ายจริง (ถ้าทราบจริง) หรือใช้ค่าใช้จ่ายเหมาตามประเภท (เงินเดือน 50% สูงสุด 100,000 บาท หรือประเภทอื่น 30-50% ตามประเภท)',
    },
    {
      '@type': 'HowToStep',
      name: 'ป้อนค่าลดหย่อนส่วนตัว ประกันสังคม และอื่นๆ',
      text: 'กรอกจำนวนเงินลดหย่อน: ส่วนตัว (60,000 บาท) คู่สมรส (60,000 บาท หากแต่งงาน) บุตร (30,000 บาทต่อคน) ประกันสังคม (สูงสุด 9,000 บาท) หรือลดหย่อนอื่นตามเงื่อนไข',
    },
    {
      '@type': 'HowToStep',
      name: 'กดปุ่มคำนวณภาษี',
      text: 'หลังจากกรอกข้อมูลครบแล้ว ให้คลิกปุ่ม "คำนวณภาษีเงินได้" เพื่อให้ระบบคำนวณ',
    },
    {
      '@type': 'HowToStep',
      name: 'ตรวจสอบผลลัพธ์ภาษี',
      text: 'ดูผลลัพธ์ที่แสดง: รายได้สุทธิ อัตราภาษี ภาษีเงินได้เป็นจำนวนบาท พร้อมสรุปภาษีต่อเดือน ตารางคำนวณตามอัตราขั้นบันได และจำนวนเงินที่ควรหักจากเงินเดือนแต่ละเดือน',
    },
  ],
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีเงินได้บุคคลธรรมดา">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณภาษีเงินได้บุคคลธรรมดา อัปเดตลดหย่อน 2569 (2026)
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2">
      <p class="text-xs font-semibold text-green-800">[อัปเดตตามกฎหมายภาษีเงินได้ 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณภาษีเงินได้ตามอัตราขั้นบันไดปี 2569 (2026) พร้อมค่าลดหย่อนครบถ้วน
      ดูผลลัพธ์ทันที ใช้งานฟรี ไม่ต้องสมัครสมาชิก
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูลรายได้และค่าลดหย่อน</h2>

      <form id="tax-form" class="space-y-6">
        <p id="tax-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>
        <!-- Income Section -->
        <div>
          <label for="monthly-salary" class="block text-sm font-medium text-gray-700 mb-1">
            เงินเดือน (บาท/เดือน)
          </label>
          <input
            type="text"
            id="monthly-salary"
            inputmode="numeric"
            placeholder="เช่น 35,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p id="monthly-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div>
          <label for="other-income" class="block text-sm font-medium text-gray-700 mb-1">
            รายได้อื่นๆ ต่อปี (บาท) <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
          </label>
          <input
            type="text"
            id="other-income"
            inputmode="numeric"
            placeholder="เช่น 50,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <!-- Allowances Section -->
        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">ค่าลดหย่อน</legend>
          <div class="space-y-3">
            <label class="flex items-center gap-2">
              <input type="checkbox" id="personal-allowance" checked class="w-4 h-4 text-primary-600 rounded" />
              <span class="text-sm text-gray-700">ค่าลดหย่อนส่วนตัว 60,000 บาท</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" id="spouse-allowance" class="w-4 h-4 text-primary-600 rounded" />
              <span class="text-sm text-gray-700">ค่าลดหย่อนคู่สมรส 60,000 บาท</span>
            </label>
            <div class="flex items-center gap-2">
              <label for="child-count" class="text-sm text-gray-700">จำนวนบุตร (30,000 บาท/คน)</label>
              <input
                type="number"
                id="child-count"
                min="0"
                max="10"
                value="0"
                class="w-16 px-2 py-1 border border-gray-300 rounded-md text-center text-base"
              />
            </div>
          </div>
        </fieldset>

        <!-- Insurance & Funds -->
        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">ประกัน & กองทุน</legend>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="social-security" class="block text-sm text-gray-700 mb-1">
                ประกันสังคม (สูงสุด 9,000)
              </label>
              <input
                type="text"
                id="social-security"
                inputmode="numeric"
                placeholder="เช่น 9,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="life-insurance" class="block text-sm text-gray-700 mb-1">
                ประกันชีวิต (สูงสุด 100,000)
              </label>
              <input
                type="text"
                id="life-insurance"
                inputmode="numeric"
                placeholder="เช่น 50,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="health-insurance" class="block text-sm text-gray-700 mb-1">
                ประกันสุขภาพ (สูงสุด 25,000)
              </label>
              <input
                type="text"
                id="health-insurance"
                inputmode="numeric"
                placeholder="เช่น 15,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="provident-fund" class="block text-sm text-gray-700 mb-1">
                กองทุนสำรองเลี้ยงชีพ (สูงสุด 10,000)
              </label>
              <input
                type="text"
                id="provident-fund"
                inputmode="numeric"
                placeholder="เช่น 10,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
          </div>
        </fieldset>

        <!-- Other Deductions -->
        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">ค่าลดหย่อนอื่นๆ</legend>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="home-loan" class="block text-sm text-gray-700 mb-1">
                ดอกเบี้ยบ้าน (สูงสุด 100,000)
              </label>
              <input
                type="text"
                id="home-loan"
                inputmode="numeric"
                placeholder="เช่น 80,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="donation" class="block text-sm text-gray-700 mb-1">
                เงินบริจาค
              </label>
              <input
                type="text"
                id="donation"
                inputmode="numeric"
                placeholder="เช่น 5,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
          </div>
        </fieldset>

        <button
          type="submit"
          id="tax-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results (hidden until calculation) -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณภาษี</h2>

        <!-- Summary Cards -->
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ภาษีต่อปี</div>
            <div id="result-annual-tax" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ภาษีต่อเดือน</div>
            <div id="result-monthly-tax" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินสุทธิต่อเดือน</div>
            <div id="result-monthly-take-home" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">อัตราภาษีที่แท้จริง</div>
            <div id="result-effective-rate" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>

        <!-- Detail Breakdown -->
        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">รายได้ต่อปี</span>
            <span id="result-annual-income" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">หักค่าใช้จ่าย (50% สูงสุด 100,000)</span>
            <span id="result-expense" class="font-medium text-red-600">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">หักค่าลดหย่อน</span>
            <span id="result-allowances" class="font-medium text-red-600">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-200 font-semibold">
            <span class="text-gray-900">รายได้สุทธิ</span>
            <span id="result-net-income">-</span>
          </div>
        </div>

        <!-- Tax Bracket Table -->
        <h3 class="text-sm font-semibold text-gray-900 mb-2">รายละเอียดขั้นบันไดภาษี</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-gray-500 border-b border-gray-200">
                <th class="py-2 pr-2">ช่วงรายได้สุทธิ</th>
                <th class="py-2 pr-2 text-right">อัตรา</th>
                <th class="py-2 pr-2 text-right">เงินได้ในช่วง</th>
                <th class="py-2 text-right">ภาษี</th>
              </tr>
            </thead>
            <tbody id="bracket-table-body"></tbody>
          </table>
        </div>
      </div>
    </div>
    <div id="tax-next-action" class="hidden mb-6 rounded-xl border border-primary-200 bg-primary-50 p-4">
      <p class="text-sm font-semibold text-primary-800">ทำต่อ: คำนวณเงินเดือนสุทธิ</p>
      <p class="mt-1 text-sm text-primary-700">ดูรายรับสุทธิรายเดือนหลังหักภาษีและประกันสังคมแบบครบภาพ</p>
      <div class="mt-3 flex flex-wrap gap-3">
        <a data-next-action-link href="/คำนวณเงินเดือนสุทธิ/" class="inline-flex min-h-11 items-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-700">ทำต่อ: คำนวณเงินเดือนสุทธิ</a>
        <a data-next-action-link href="/บทความ/ภาษีเงินได้-2569-คำนวณ-วิธีลดหย่อน/" class="inline-flex min-h-11 items-center rounded-lg border border-primary-300 bg-white px-4 py-2 text-sm font-semibold text-primary-700 hover:border-primary-400">อ่านต่อ: วิธีลดหย่อนภาษี 2569</a>
      </div>
    </div>
    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />
<!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
