  <script>
    interface TaxInput {
      annualIncome: number;
      personalAllowance: boolean;
      spouseAllowance: boolean;
      childCount: number;
      socialSecurity: number;
      lifeInsurance: number;
      healthInsurance: number;
      providentFund: number;
      homeLoanInterest: number;
      socialEnterprise: number;
      otherDeductions: number;
    }

    interface BracketBreakdown {
      min: number;
      max: number;
      rate: number;
      taxableInBracket: number;
      taxInBracket: number;
    }

    const TAX_BRACKETS = [
      { min: 0, max: 150_000, rate: 0 },
      { min: 150_000, max: 300_000, rate: 0.05 },
      { min: 300_000, max: 500_000, rate: 0.10 },
      { min: 500_000, max: 750_000, rate: 0.15 },
      { min: 750_000, max: 1_000_000, rate: 0.20 },
      { min: 1_000_000, max: 2_000_000, rate: 0.25 },
      { min: 2_000_000, max: 5_000_000, rate: 0.30 },
      { min: 5_000_000, max: Infinity, rate: 0.35 },
    ];

    function parseNumber(value: string): number {
      return Math.max(0, parseFloat(value.replace(/,/g, '')) || 0);
    }

    function hasInvalidNumber(value: string): boolean {
      const normalized = value.replace(/,/g, '').trim();
      return normalized !== '' && Number.isNaN(Number(normalized));
    }

    function formatThai(num: number, decimals = 2): string {
      return new Intl.NumberFormat('th-TH', {
        minimumFractionDigits: decimals,
        maximumFractionDigits: decimals,
      }).format(num);
    }

    function formatThaiCompact(num: number): string {
      if (num === Infinity) return '∞';
      if (num >= 1_000_000) return formatThai(num / 1_000_000, 0) + ' ล้าน';
      if (num >= 1_000) return formatThai(num / 1_000, 0) + ' พัน';
      return formatThai(num, 0);
    }

    function calculateTax(input: TaxInput) {
      const annualIncome = input.annualIncome;
      const expenseDeduction = Math.min(annualIncome * 0.5, 100_000);

      let allowances = 0;
      if (input.personalAllowance) allowances += 60_000;
      if (input.spouseAllowance) allowances += 60_000;
      allowances += input.childCount * 30_000;
      allowances += Math.min(input.socialSecurity, 9_000);
      allowances += Math.min(input.lifeInsurance, 100_000);
      allowances += Math.min(input.healthInsurance, 25_000);
      allowances += Math.min(input.providentFund, 10_000);
      allowances += Math.min(input.homeLoanInterest, 100_000);
      allowances += input.socialEnterprise;
      allowances += input.otherDeductions;

      const netIncome = Math.max(0, annualIncome - expenseDeduction - allowances);

      let remaining = netIncome;
      let totalTax = 0;
      const breakdown: BracketBreakdown[] = [];

      for (const bracket of TAX_BRACKETS) {
        const width = bracket.max === Infinity ? Infinity : bracket.max - bracket.min;
        const taxable = Math.min(remaining, width);
        const tax = taxable * bracket.rate;
        breakdown.push({ ...bracket, taxableInBracket: taxable, taxInBracket: tax });
        totalTax += tax;
        remaining -= taxable;
        if (remaining <= 0) break;
      }

      return {
        annualIncome,
        expenseDeduction,
        allowances,
        netIncome,
        annualTax: totalTax,
        monthlyTax: totalTax / 12,
        effectiveRate: annualIncome > 0 ? (totalTax / annualIncome) * 100 : 0,
        takeHomePay: annualIncome - totalTax,
        monthlyTakeHome: (annualIncome - totalTax) / 12,
        breakdown,
      };
    }

    const form = document.getElementById('tax-form') as HTMLFormElement;
    const formError = document.getElementById('tax-form-error') as HTMLElement;
    const submitBtn = document.getElementById('tax-submit-btn') as HTMLButtonElement;
    const salaryInput = document.getElementById('monthly-salary') as HTMLInputElement;
    const nextActionCard = document.getElementById('tax-next-action') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    let hasTrackedStart = false;

    function setSalaryError(message: string) {
      const el = document.getElementById('monthly-salary-error') as HTMLElement;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearSalaryError() {
      const el = document.getElementById('monthly-salary-error') as HTMLElement;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function updateSubmitState() {
      const ready = parseNumber(salaryInput.value) > 0;
      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณทันที' : 'กรอกข้อมูลให้ครบ';
      submitBtn.classList.toggle('opacity-70', !ready);
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
    }

    salaryInput.addEventListener('input', () => {
      clearSalaryError();
      formError.classList.add('hidden');
      updateSubmitState();
    });
    updateSubmitState();

    form.addEventListener('input', () => {
      if (!hasTrackedStart) {
        trackCalculatorStart('personal_income_tax');
        hasTrackedStart = true;
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      clearSalaryError();
      formError.classList.add('hidden');

      const monthlySalaryRaw = salaryInput.value;
      const monthlySalary = parseNumber(monthlySalaryRaw);
      const otherIncome = parseNumber((document.getElementById('other-income') as HTMLInputElement).value);

      if (hasInvalidNumber(monthlySalaryRaw)) {
        formError.classList.remove('hidden');
        setSalaryError('รูปแบบข้อมูลไม่ถูกต้อง');
        salaryInput.focus();
        updateSubmitState();
        return;
      }

      if (monthlySalary <= 0) {
        formError.classList.remove('hidden');
        setSalaryError('กรุณากรอกจำนวนเงินมากกว่า 0');
        salaryInput.focus();
        updateSubmitState();
        return;
      }

      if (!hasTrackedStart) {
        trackCalculatorStart('personal_income_tax');
        hasTrackedStart = true;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';

      const input: TaxInput = {
        annualIncome: monthlySalary * 12 + otherIncome,
        personalAllowance: (document.getElementById('personal-allowance') as HTMLInputElement).checked,
        spouseAllowance: (document.getElementById('spouse-allowance') as HTMLInputElement).checked,
        childCount: parseInt((document.getElementById('child-count') as HTMLInputElement).value) || 0,
        socialSecurity: parseNumber((document.getElementById('social-security') as HTMLInputElement).value),
        lifeInsurance: parseNumber((document.getElementById('life-insurance') as HTMLInputElement).value),
        healthInsurance: parseNumber((document.getElementById('health-insurance') as HTMLInputElement).value),
        providentFund: parseNumber((document.getElementById('provident-fund') as HTMLInputElement).value),
        homeLoanInterest: parseNumber((document.getElementById('home-loan') as HTMLInputElement).value),
        socialEnterprise: parseNumber((document.getElementById('donation') as HTMLInputElement).value),
        otherDeductions: 0,
      };

      const result = calculateTax(input);

      // Update summary cards
      (document.getElementById('result-annual-tax') as HTMLElement).textContent = formatThai(result.annualTax) + ' บาท';
      (document.getElementById('result-monthly-tax') as HTMLElement).textContent = formatThai(result.monthlyTax) + ' บาท';
      (document.getElementById('result-monthly-take-home') as HTMLElement).textContent = formatThai(result.monthlyTakeHome) + ' บาท';
      (document.getElementById('result-effective-rate') as HTMLElement).textContent = formatThai(result.effectiveRate) + '%';

      // Update detail breakdown
      (document.getElementById('result-annual-income') as HTMLElement).textContent = formatThai(result.annualIncome) + ' บาท';
      (document.getElementById('result-expense') as HTMLElement).textContent = '-' + formatThai(result.expenseDeduction) + ' บาท';
      (document.getElementById('result-allowances') as HTMLElement).textContent = '-' + formatThai(result.allowances) + ' บาท';
      (document.getElementById('result-net-income') as HTMLElement).textContent = formatThai(result.netIncome) + ' บาท';

      // Update bracket table
      const tbody = document.getElementById('bracket-table-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      for (const b of result.breakdown) {
        const row = document.createElement('tr');
        row.className = 'border-b border-gray-100';
        const maxLabel = b.max === Infinity ? '5,000,001+' : formatThai(b.min, 0) + ' — ' + formatThai(b.max, 0);
        row.innerHTML = `
          <td class="py-2 pr-2 text-gray-700">${b.max === Infinity ? '5,000,001 ขึ้นไป' : formatThai(b.min, 0) + ' — ' + formatThai(b.max, 0)}</td>
          <td class="py-2 pr-2 text-right">${b.rate === 0 ? 'ยกเว้น' : (b.rate * 100) + '%'}</td>
          <td class="py-2 pr-2 text-right">${formatThai(b.taxableInBracket, 0)}</td>
          <td class="py-2 text-right font-medium">${formatThai(b.taxInBracket)}</td>
        `;
        tbody.appendChild(row);
      }

      resultsDiv.classList.remove('hidden');
      nextActionCard.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('personal_income_tax');
      trackCalculatorUsed('personal_income_tax');
    });

    document.querySelectorAll('[data-next-action-link]').forEach((link) => {
      link.addEventListener('click', () => {
        if (typeof window.gtag === 'function') {
          const href = (link as HTMLAnchorElement).getAttribute('href') || '';
          window.gtag('event', 'next_action_click', {
            calculator: 'personal_income_tax',
            target_href: href,
          });
        }
      });
    });

    // Track when result section enters viewport
    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('personal_income_tax');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>

