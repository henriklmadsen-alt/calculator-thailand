---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณรายได้ผู้ประกอบการ | Kamnuanlek';
const pageDescription = 'คำนวณรายได้สุทธิผู้ประกอบการ หักค่าใช้จ่ายธุรกิจ ภาษีเงินได้บุคคลธรรมดา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0469-รายได้ประกอบการ/`;
const faqData = [
  { question: 'เจ้าของธุรกิจเสียภาษีอย่างไร?', answer: 'เจ้าของธุรกิจส่วนตัวเสียภาษีเงินได้บุคคลธรรมดา รายได้จากธุรกิจเป็นเงินได้ประเภท 8 หักค่าใช้จ่าย 60% (ไม่เกิน 600,000 บาท) หรือค่าใช้จ่ายจริง' },
  { question: 'ควรตั้งเป็นบริษัทหรือทำในนามบุคคลดีกว่า?', answer: 'รายได้สูงกว่า 1-2 ล้านบาท/ปี ตั้งบริษัทมักคุ้มกว่า เนื่องจากภาษีนิติบุคคล 20% อาจต่ำกว่าภาษีบุคคลธรรมดาสูงสุด 35% และแยกสินทรัพย์ส่วนตัวออกจากธุรกิจได้' },
  { question: 'รายได้ผู้ประกอบการหักค่าใช้จ่ายได้เท่าไหร่?', answer: 'รายได้ประเภทที่ 8 (ธุรกิจ) หักค่าใช้จ่ายได้ 60% หรือค่าใช้จ่ายจริง บางกิจการอาจหักได้ 70-85% ตามประเภทรายได้' },
  { question: 'ผู้ประกอบการควรประหยัดภาษีอย่างไร?', answer: 'ประหยัดภาษีโดย ลงทุน LTF/RMF ประกันสุขภาพ ประกันชีวิต เงินบริจาค ดอกเบี้ยซื้อบ้าน ค่าใช้จ่ายธุรกิจที่ถูกต้องตามกฎหมาย' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณรายได้ผู้ประกอบการ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณรายได้ผู้ประกอบการ</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณรายได้สุทธิผู้ประกอบการหลังหักค่าใช้จ่ายและภาษี</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="gross_income" class="block text-sm font-medium text-gray-700 mb-1">รายได้รวมต่อปี (บาท)</label><input type="text" id="gross_income" inputmode="decimal" placeholder="เช่น 3000000" value="3000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="biz_expenses" class="block text-sm font-medium text-gray-700 mb-1">ค่าใช้จ่ายธุรกิจจริงต่อปี (บาท)</label><input type="text" id="biz_expenses" inputmode="decimal" placeholder="เช่น 1800000" value="1800000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="personal_deduct" class="block text-sm font-medium text-gray-700 mb-1">ค่าลดหย่อนส่วนตัว (บาท)</label><input type="text" id="personal_deduct" inputmode="decimal" placeholder="เช่น 200000" value="200000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">รายได้สุทธิหลังค่าใช้จ่าย</p><p id="net_income_biz" class="font-bold">-</p></div>
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">รายได้สุทธิหลังลดหย่อน</p><p id="taxable_income" class="font-bold">-</p></div>
          <div class="bg-indigo-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">อัตรากำไรสุทธิ</p><p id="net_margin" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const grossIncome = parseFloat((document.getElementById('gross_income') as HTMLInputElement).value) || 0;
      const bizExpenses = parseFloat((document.getElementById('biz_expenses') as HTMLInputElement).value) || 0;
      const personalDeduct = parseFloat((document.getElementById('personal_deduct') as HTMLInputElement).value) || 0;
      const netIncomeBiz = grossIncome - bizExpenses;
      const taxableIncome = Math.max(0, netIncomeBiz - personalDeduct);
      const netMargin = grossIncome > 0 ? (netIncomeBiz / grossIncome * 100) : 0;
      (document.getElementById('net_income_biz') as HTMLElement).textContent = netIncomeBiz.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('taxable_income') as HTMLElement).textContent = taxableIncome.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('net_margin') as HTMLElement).textContent = netMargin.toFixed(2) + '%';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('entrepreneur-income');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
