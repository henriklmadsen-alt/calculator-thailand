---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';

const pageTitle = 'คำนวณค่าดีเจแต่งงาน 2569 | ค่าเวลา ค่าอุปกรณ์ | Kamnuanlek';
const pageDescription = 'คำนวณค่าดีเจ ลำโพง ไมโครโฟน และความบันเทิงสำหรับงานแต่งงาน ออนไลน์ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าดีเจแต่งงาน/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าดีเจแต่งงาน">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าดีเจและความบันเทิงแต่งงาน</h1>
    <div class="mb-4 inline-block rounded-lg border border-pink-200 bg-pink-50 px-3 py-2">
      <p class="text-xs font-semibold text-pink-800">[ค่าความบันเทิง 2569]</p>
    </div>
    <p class="text-gray-600 mb-6">คำนวณค่าดีเจ ลำโพง และอุปกรณ์ความบันเทิงแต่งงาน</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="dj" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าดีเจ (บาท)
          </label>
          <input type="text" id="dj" inputmode="decimal" placeholder="เช่น 60000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="sound" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าระบบเสียง/ลำโพง (บาท)
          </label>
          <input type="text" id="sound" inputmode="decimal" placeholder="เช่น 20000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="lighting" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าไฟ/แสงสว่าง (บาท)
          </label>
          <input type="text" id="lighting" inputmode="decimal" placeholder="เช่น 15000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="other-entertainment" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าอื่นๆ (บาท)
          </label>
          <input type="text" id="other-entertainment" inputmode="decimal" placeholder="เช่น 10000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
      </div>
      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-pink-600 text-white font-semibold rounded-md hover:bg-pink-700 transition-colors text-base">
        คำนวณรวม
      </button>
      <div id="result" class="hidden mt-8 border-t pt-6">
        <div class="bg-pink-50 rounded-lg p-6 text-center">
          <div class="text-sm text-gray-600 mb-2">ค่าความบันเทิงรวม</div>
          <div class="text-5xl font-bold text-pink-700"><span id="total">-</span></div>
          <div class="text-sm text-gray-600">บาท</div>
        </div>
      </div>
    </div>
    <RelatedCalculators />
    <RelatedArticles />
  </article>
</BaseLayout>

<script>
  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const dj = parseFloat(document.getElementById('dj')?.value || 0);
    const sound = parseFloat(document.getElementById('sound')?.value || 0);
    const lighting = parseFloat(document.getElementById('lighting')?.value || 0);
    const other = parseFloat(document.getElementById('other-entertainment')?.value || 0);
    const total = dj + sound + lighting + other;
    if (total === 0) { alert('กรุณาป้อนค่าใช้จ่าย'); return; }
    document.getElementById('total').textContent = total.toLocaleString('th-TH');
    document.getElementById('result').classList.remove('hidden');
  });
</script>
