---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'แปลงหน่วย 2569 | เมตร กิโลกรัม เซลเซียส ไร่ | เครื่องคำนวณไทย';
const pageDescription = 'แปลงหน่วยวัดออนไลน์ปี 2569 รองรับความยาว มวล อุณหภูมิ และพื้นที่ เช่น m-cm-km-ft-in-mi, kg-g-lb-oz, C-F-K, ตร.ม.-ตร.วา-ไร่-งาน-เอเคอร์ พร้อมใช้ต่อกับเครื่องคำนวณยอดนิยมได้ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/แปลงหน่วย/`;

const faqData = [
  {
    question: 'แปลงเมตรเป็นเซนติเมตรต้องคูณเท่าไร?',
    answer: 'ใช้หลักว่า 1 เมตร = 100 เซนติเมตร ดังนั้นนำค่าที่เป็นเมตรคูณ 100 จะได้ค่าเป็นเซนติเมตร',
  },
  {
    question: 'แปลงกิโลกรัมเป็นกรัมต้องทำอย่างไร?',
    answer: '1 กิโลกรัม = 1,000 กรัม จึงนำค่าน้ำหนักหน่วยกิโลกรัมคูณ 1,000 เพื่อแปลงเป็นกรัม',
  },
  {
    question: 'ทำไมการแปลงอุณหภูมิใช้สูตรต่างจากหน่วยอื่น?',
    answer: 'เพราะอุณหภูมิไม่ได้มีแค่สัดส่วนการคูณ/หาร แต่มีจุดอ้างอิงของแต่ละสเกล (เช่น 0°C ไม่เท่ากับ 0°F) จึงต้องใช้สูตรแปลงเฉพาะ',
  },
  {
    question: 'ควรแปลงหน่วยก่อนใช้เครื่องคำนวณอื่นเมื่อไร?',
    answer: 'ควรแปลงเมื่อข้อมูลต้นทางอยู่คนละหน่วยกับค่าที่จะกรอกในสูตร เช่น เวลาเปรียบเทียบตัวเลขหลายแหล่งก่อนคำนวณเปอร์เซ็นต์หรือวางงบรายเดือน เพื่อให้ผลลัพธ์แม่นยำและเทียบกันได้',
  },
  {
    question: 'ทำไมงานเทียบราคาต่างประเทศต้องแปลงหน่วยก่อนแปลงค่าเงิน?',
    answer: 'เพราะราคาต่อหน่วยอาจใช้คนละมาตรฐาน เช่น ปอนด์กับกิโลกรัมหรือแกลลอนกับลิตร ถ้าแปลงหน่วยให้ตรงก่อน แล้วค่อยแปลงค่าเงิน จะเปรียบเทียบต้นทุนจริงได้ตรงกว่า',
  },
  {
    question: '1 ไร่เท่ากับกี่ตารางเมตร?',
    answer: '1 ไร่ = 1,600 ตารางเมตร โดย 1 ไร่ = 4 งาน = 400 ตารางวา ตามนิยามใน พ.ร.บ.มาตราชั่งตวงวัด พ.ศ. 2542',
  },
  {
    question: 'ตารางวากับตารางเมตรต่างกันอย่างไร?',
    answer: '1 ตารางวา = 4 ตารางเมตร (เพราะ 1 วา = 2 เมตร ดังนั้น 2×2 = 4 ตร.ม.) เป็นหน่วยที่ใช้กันมากในการซื้อขายที่ดินในประเทศไทย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องมือแปลงหน่วย',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="แปลงหน่วย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">แปลงหน่วยวัดในหน้าเดียว</p>
      <p class="mt-1 text-sm text-slate-700">รองรับความยาว มวล อุณหภูมิ และพื้นที่ (รวมหน่วยไทย: วา ไร่ งาน) พร้อมผลลัพธ์แบบทันที</p>
      <p class="mt-1 text-xs font-medium text-sky-800">ใช้ได้ทั้งงานเรียน งานวิศวกรรม ที่ดิน และการคำนวณชีวิตประจำวัน</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      แปลงหน่วย 2569 (เมตร กิโลกรัม เซลเซียส ไร่)
    </h1>

    <p class="mb-6 text-gray-600">
      เลือกหมวดหน่วย ใส่ค่าที่ต้องการแปลง แล้วระบบจะคำนวณผลลัพธ์ให้ทันที
      เครื่องมือนี้ช่วยลดข้อผิดพลาดจากการคำนวณมือ โดยเฉพาะเมื่อคุณต้องสลับหน่วยหลายแบบในงานเดียว
    </p>

    <PublicTrustPanel
      lastUpdated="19 เม.ย. 2569"
      sources={[
        'สำนักชั่งตวงวัด (กรมการค้าภายใน): พ.ร.บ.มาตราชั่งตวงวัด พ.ศ. 2542',
        'สถาบันมาตรวิทยาแห่งชาติ (NIMT)',
        'BIPM SI Brochure',
        'NIST: SI Units - Temperature',
      ]}
      assumptions={[
        'การแปลงหน่วยคำนวณตามนิยามหน่วยมาตรฐาน SI',
        'หน่วยพื้นที่ไทย (ไร่ งาน ตารางวา) ใช้นิยามตาม พ.ร.บ.มาตราชั่งตวงวัด พ.ศ. 2542: 1 ไร่ = 1,600 ตร.ม.',
        'ผลลัพธ์เป็นค่าคณิตศาสตร์ตรงตามสูตร ไม่มีการปัดค่าบังคับ ยกเว้นการแสดงผลบนหน้าจอ',
      ]}
      references={[
        {
          label: 'กรมการค้าภายใน: พระราชบัญญัติมาตราชั่งตวงวัด พ.ศ. 2542',
          href: 'https://www.dit.go.th/th/law/act/weights-measures-2542/',
        },
        {
          label: 'สถาบันมาตรวิทยาแห่งชาติ: มาตรฐานแห่งชาติ',
          href: 'https://www.nimt.or.th/main/?page_id=222',
        },
        {
          label: 'NIST: SI units (Length and Mass)',
          href: 'https://www.nist.gov/pml/owm/metric-si/si-units',
        },
        {
          label: 'NIST: SI Units - Temperature',
          href: 'https://www.nist.gov/pml/owm/si-units-temperature',
        },
        {
          label: 'BIPM SI Brochure',
          href: 'https://www.bipm.org/en/publications/si-brochure',
        },
      ]}
    />

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="unit-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนแปลงหน่วย
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="category" class="mb-1 block text-sm font-medium text-gray-700">หมวดหน่วย</label>
            <select id="category" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="length">ความยาว</option>
              <option value="mass">มวล/น้ำหนัก</option>
              <option value="temperature">อุณหภูมิ</option>
              <option value="area">พื้นที่</option>
            </select>
          </div>

          <div>
            <label for="value-input" class="mb-1 block text-sm font-medium text-gray-700">ค่าที่ต้องการแปลง</label>
            <input id="value-input" type="text" inputmode="decimal" placeholder="เช่น 1.75" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>

          <div>
            <label for="from-unit" class="mb-1 block text-sm font-medium text-gray-700">จากหน่วย</label>
            <select id="from-unit" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"></select>
          </div>

          <div>
            <label for="to-unit" class="mb-1 block text-sm font-medium text-gray-700">เป็นหน่วย</label>
            <select id="to-unit" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"></select>
          </div>
        </div>

        <button
          type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          แปลงหน่วย
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการแปลงหน่วย</h2>

        <div class="mb-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-lg bg-indigo-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าที่ป้อน</div>
            <div id="res-input" class="text-xl font-bold text-indigo-700">-</div>
          </div>
          <div class="rounded-lg bg-emerald-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ผลลัพธ์</div>
            <div id="res-output" class="text-xl font-bold text-emerald-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">หมวดหน่วย</span>
            <span id="res-category" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">สูตร/หลักการ</span>
            <span id="res-formula" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้บ่อย</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ความยาว: 1 km = 1,000 m, 1 m = 100 cm, 1 ft = 0.3048 m, 1 in = 2.54 cm, 1 mi = 1,609.344 m, 1 yd = 0.9144 m</li>
        <li>มวล: 1 t = 1,000 kg, 1 kg = 1,000 g, 1 lb = 0.4536 kg, 1 oz = 28.35 g</li>
        <li>อุณหภูมิ: °F = (°C × 9/5) + 32 และ °C = (°F - 32) × 5/9</li>
        <li>พื้นที่: 1 ไร่ = 4 งาน = 400 ตารางวา = 1,600 ตร.ม., 1 เอเคอร์ = 4,046.86 ตร.ม.</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">อ่านต่อและเครื่องคำนวณที่เกี่ยวข้อง</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        <a href="/บทความ/แปลงหน่วยวัด-เมตร-กิโลกรัม-เซลเซียส/" data-preserve-utm class="block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-colors hover:border-primary-500">
          <span class="font-medium text-primary-600">บทความ: แปลงหน่วยวัด เมตร กิโลกรัม เซลเซียส</span>
          <span class="block text-sm text-gray-400">ดูตัวอย่างแปลงหน่วยทีละขั้นพร้อมจุดพลาดที่พบบ่อย</span>
        </a>
        <a href="/คำนวณ-bmi/" data-preserve-utm class="block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-colors hover:border-primary-500">
          <span class="font-medium text-primary-600">คำนวณ BMI</span>
          <span class="block text-sm text-gray-400">ใช้แปลงหน่วยส่วนสูง/น้ำหนักก่อนคำนวณสุขภาพ</span>
        </a>
        <a href="/คำนวณค่าน้ำ/" data-preserve-utm class="block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-colors hover:border-primary-500">
          <span class="font-medium text-primary-600">คำนวณค่าน้ำ</span>
          <span class="block text-sm text-gray-400">ตรวจสอบหน่วยใช้น้ำและค่าใช้จ่ายรายเดือน</span>
        </a>
        <a href="/คำนวณค่าไฟฟ้า/" data-preserve-utm class="block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-colors hover:border-primary-500">
          <span class="font-medium text-primary-600">คำนวณค่าไฟฟ้า</span>
          <span class="block text-sm text-gray-400">เปรียบเทียบค่าใช้ไฟตามหน่วยใช้งานจริง</span>
        </a>
        <a href="/คำนวณเงินเดือนสุทธิ/" data-preserve-utm class="block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-colors hover:border-primary-500">
          <span class="font-medium text-primary-600">คำนวณเงินเดือนสุทธิ</span>
          <span class="block text-sm text-gray-400">วางงบรายเดือนต่อจากตัวเลขที่แปลงหน่วยแล้ว</span>
        </a>
        <a href="/คำนวณเปอร์เซ็นต์/" data-preserve-utm class="block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-colors hover:border-primary-500">
          <span class="font-medium text-primary-600">คำนวณเปอร์เซ็นต์</span>
          <span class="block text-sm text-gray-400">เทียบเพิ่ม/ลดเป็นเปอร์เซ็นต์หลังจัดหน่วยข้อมูลให้ตรงกัน</span>
        </a>
        <a href="/คำนวณอัตราแลกเปลี่ยน/" data-preserve-utm class="block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-colors hover:border-primary-500">
          <span class="font-medium text-primary-600">คำนวณอัตราแลกเปลี่ยน</span>
          <span class="block text-sm text-gray-400">ต่อยอดจากการแปลงหน่วยเพื่อเทียบต้นทุนสินค้าต่างสกุลเงิน</span>
        </a>
        <a href="/บทความ/คำนวณอัตราแลกเปลี่ยน-บาท-สกุลเงิน-2569/" data-preserve-utm class="block rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition-colors hover:border-primary-500">
          <span class="font-medium text-primary-600">บทความ: คำนวณอัตราแลกเปลี่ยน บาท-สกุลเงิน 2569</span>
          <span class="block text-sm text-gray-400">อ่านวิธีเทียบเรตและค่าสเปรดหลังจัดหน่วยข้อมูลให้ตรงกัน</span>
        </a>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> การแปลงหน่วยในหน้านี้เป็นค่าทางคณิตศาสตร์ตามนิยามหน่วยมาตรฐาน
      โปรดตรวจสอบหน่วยต้นทาง/ปลายทางให้ถูกก่อนนำผลไปใช้งานจริง
    </div>
  </article>

  <script>
    import { convertUnit } from '../../lib/unit-conversion';

    const categoryOptions = {
      length: [
        { value: 'mm', label: 'มิลลิเมตร (mm)' },
        { value: 'cm', label: 'เซนติเมตร (cm)' },
        { value: 'm', label: 'เมตร (m)' },
        { value: 'km', label: 'กิโลเมตร (km)' },
        { value: 'ft', label: 'ฟุต (ft)' },
        { value: 'in', label: 'นิ้ว (in)' },
        { value: 'mi', label: 'ไมล์ (mi)' },
        { value: 'yd', label: 'หลา (yd)' },
      ],
      mass: [
        { value: 'mg', label: 'มิลลิกรัม (mg)' },
        { value: 'g', label: 'กรัม (g)' },
        { value: 'kg', label: 'กิโลกรัม (kg)' },
        { value: 't', label: 'ตัน (t)' },
        { value: 'lb', label: 'ปอนด์ (lb)' },
        { value: 'oz', label: 'ออนซ์ (oz)' },
      ],
      temperature: [
        { value: 'c', label: 'องศาเซลเซียส (°C)' },
        { value: 'f', label: 'องศาฟาเรนไฮต์ (°F)' },
        { value: 'k', label: 'เคลวิน (K)' },
      ],
      area: [
        { value: 'sqm', label: 'ตารางเมตร (ตร.ม.)' },
        { value: 'sqwa', label: 'ตารางวา' },
        { value: 'ngan', label: 'งาน' },
        { value: 'rai', label: 'ไร่' },
        { value: 'acre', label: 'เอเคอร์ (acre)' },
      ],
    };

    const categoryLabels = {
      length: 'ความยาว',
      mass: 'มวล/น้ำหนัก',
      temperature: 'อุณหภูมิ',
      area: 'พื้นที่',
    };

    const form = document.getElementById('unit-form');
    const formError = document.getElementById('form-error');
    const results = document.getElementById('results');
    const categoryInput = document.getElementById('category');
    const fromInput = document.getElementById('from-unit');
    const toInput = document.getElementById('to-unit');

    const show = (el) => el?.classList.remove('hidden');
    const hide = (el) => el?.classList.add('hidden');

    const parseNumber = (value) => {
      const normalized = String(value ?? '').replace(/,/g, '').trim();
      if (!normalized) return NaN;
      const parsed = Number(normalized);
      return Number.isFinite(parsed) ? parsed : NaN;
    };

    const formatNumber = (value) => new Intl.NumberFormat('th-TH', {
      maximumFractionDigits: 10,
    }).format(value);

    const resolveFormula = (category, fromUnit, toUnit) => {
      if (category === 'temperature') {
        if (fromUnit === 'c' && toUnit === 'f') return '°F = (°C × 9/5) + 32';
        if (fromUnit === 'f' && toUnit === 'c') return '°C = (°F - 32) × 5/9';
        if (fromUnit === 'c' && toUnit === 'k') return 'K = °C + 273.15';
        if (fromUnit === 'k' && toUnit === 'c') return '°C = K - 273.15';
        if (fromUnit === 'f' && toUnit === 'k') return 'K = (°F - 32) × 5/9 + 273.15';
        if (fromUnit === 'k' && toUnit === 'f') return '°F = (K - 273.15) × 9/5 + 32';
      }
      return 'แปลงด้วยสัดส่วนหน่วยมาตรฐาน SI';
    };

    const refreshUnitOptions = () => {
      if (!categoryInput || !fromInput || !toInput) return;
      const category = categoryInput.value;
      const options = categoryOptions[category] || [];

      fromInput.innerHTML = '';
      toInput.innerHTML = '';
      options.forEach((opt) => {
        const fromOption = document.createElement('option');
        fromOption.value = opt.value;
        fromOption.textContent = opt.label;
        fromInput.appendChild(fromOption);

        const toOption = document.createElement('option');
        toOption.value = opt.value;
        toOption.textContent = opt.label;
        toInput.appendChild(toOption);
      });

      if (options.length > 1) {
        fromInput.value = options[0].value;
        toInput.value = options[1].value;
      }
    };

    categoryInput?.addEventListener('change', refreshUnitOptions);
    refreshUnitOptions();

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      hide(formError);

      const category = categoryInput?.value;
      const value = parseNumber(document.getElementById('value-input')?.value);
      const fromUnit = fromInput?.value;
      const toUnit = toInput?.value;

      if (!category || !fromUnit || !toUnit || !Number.isFinite(value)) {
        show(formError);
        hide(results);
        return;
      }

      try {
        const convertedValue = convertUnit({
          category,
          value,
          fromUnit,
          toUnit,
        });

        document.getElementById('res-input').textContent = `${formatNumber(value)} ${fromUnit}`;
        document.getElementById('res-output').textContent = `${formatNumber(convertedValue)} ${toUnit}`;
        document.getElementById('res-category').textContent = categoryLabels[category] || category;
        document.getElementById('res-formula').textContent = resolveFormula(category, fromUnit, toUnit);

        show(results);

        if (typeof trackCalculatorStart === 'function') trackCalculatorStart('unit_conversion');
        if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('unit_conversion', convertedValue);
        if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('unit_conversion');
      } catch {
        show(formError);
        hide(results);
      }
    });
  </script>
</BaseLayout>
