---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเงินเดือนหลังเลื่อนตำแหน่ง ปี 2569 ส่วนต่าง ภาษีเปลี่ยนแปลง | Kamnuanlek';
const pageDescription = 'คำนวณเงินเดือนหลังเลื่อนตำแหน่ง เปรียบเทียบเงินเดือนเดิมกับใหม่ เปอร์เซ็นต์ขึ้น ส่วนต่างรายเดือน/ปี และผลกระทบภาษีเงินได้ขั้นบันได';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินเดือนหลังเลื่อนตำแหน่ง/`;

const faqData = [
  {
    question: 'การเลื่อนตำแหน่งมักได้รับขึ้นเงินเดือนเท่าไร?',
    answer: 'การเลื่อนตำแหน่งในไทยมักได้รับขึ้นเงินเดือน 10-30% ขึ้นอยู่กับระดับตำแหน่ง อุตสาหกรรม และนโยบายบริษัท',
  },
  {
    question: 'เงินเดือนที่สูงขึ้นมีผลต่อภาษีอย่างไร?',
    answer: 'รายได้สุทธิที่สูงขึ้นอาจเข้าสู่ขั้นบันไดภาษีที่สูงกว่า ทำให้อัตราภาษีส่วนเพิ่มสูงขึ้น ควรวางแผนลดหย่อนภาษีเพิ่มเติม',
  },
  {
    question: 'ควรต่อรองเงินเดือนอย่างไรเมื่อเลื่อนตำแหน่ง?',
    answer: 'ควรรู้อัตราตลาด (Market Rate) ของตำแหน่งใหม่ในอุตสาหกรรม และต่อรองให้ได้อย่างน้อย 15-20% ขึ้นไปจากเงินเดือนเดิม',
  },
  {
    question: 'ภาษีหัก ณ ที่จ่ายเพิ่มขึ้นเมื่อเงินเดือนสูงขึ้นไหม?',
    answer: 'ใช่ นายจ้างต้องคำนวณและหักภาษี ณ ที่จ่ายใหม่จากเงินเดือนที่สูงขึ้น ซึ่งอาจทำให้เงินสุทธิเพิ่มน้อยกว่าที่คาดหวัง',
  },
,
  { question: 'ค่าแรงขั้นต่ำปี 2569 อยู่ที่เท่าไร?', answer: 'ค่าแรงขั้นต่ำปี 2568-2569 กรุงเทพและปริมณฑล 370-400 บาท/วัน ต่างจังหวัดอยู่ที่ 330-370 บาท/วัน ขึ้นอยู่กับจังหวัด ตรวจสอบอัตราล่าสุดได้จากกระทรวงแรงงาน mol.go.th' },
  { question: 'เงินเดือนสุทธิคำนวณจากอะไรบ้าง?', answer: 'เงินเดือนสุทธิ = เงินเดือนรวม - ภาษีหัก ณ ที่จ่าย - เงินสมทบประกันสังคม (5% สูงสุด 750 บาท) - กองทุนสำรองเลี้ยงชีพ (ถ้ามี) นายจ้างจ่ายประกันสังคมเพิ่มอีกฝ่าย 5%' },
  { question: 'OT คำนวณอย่างไร?', answer: 'วันธรรมดา: 1.5 เท่าของค่าจ้างปกติต่อชั่วโมง | วันหยุด: 2 เท่า (ชั่วโมงปกติ) และ 3 เท่า (เกินเวลาปกติ) | ตามพระราชบัญญัติคุ้มครองแรงงาน พ.ศ. 2541' },
  { question: 'กองทุนสำรองเลี้ยงชีพมีประโยชน์อย่างไร?', answer: 'เป็นเงินออมระยะยาวที่นายจ้างสมทบ (1-15% ของค่าจ้าง) + ลดหย่อนภาษีได้สูงสุด 15% ของรายได้หรือ 500,000 บาท + ผลตอบแทนจากการลงทุน ดึงออกได้เมื่อออกจากงานหรือเกษียณ' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินเดือนหลังเลื่อนตำแหน่ง',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินเดือนหลังเลื่อนตำแหน่ง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">เปรียบเทียบเงินเดือนเดิม vs ใหม่ พร้อมผลกระทบภาษี</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณส่วนต่างและภาษีที่เพิ่มขึ้นตามอัตราขั้นบันได 5-35%</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับพนักงานที่ได้รับการเลื่อนตำแหน่งและต้องการวางแผนการเงิน</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณเงินเดือนหลังเลื่อนตำแหน่ง ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือนเดิมและเงินเดือนใหม่หลังเลื่อนตำแหน่ง ระบบจะแสดงส่วนต่างและผลกระทบต่อภาษีเงินได้
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="promotion-form" class="space-y-5">
        <p id="promotion-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="prom-old-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือนเดิม (บาท/เดือน)</label>
            <input type="text" id="prom-old-salary" inputmode="numeric" placeholder="เช่น 40,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="prom-old-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="prom-new-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือนใหม่ (บาท/เดือน)</label>
            <input type="text" id="prom-new-salary" inputmode="numeric" placeholder="เช่น 55,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="prom-new-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณผลเลื่อนตำแหน่ง
        </button>
      </form>
    </div>

    <div id="promotion-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินเดือนเพิ่มขึ้น %</div>
            <div id="res-prom-pct" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ส่วนต่าง Gross รายเดือน</div>
            <div id="res-prom-gross-diff" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ภาษีเพิ่ม (ประมาณ/เดือน)</div>
            <div id="res-prom-tax-diff" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="rounded-lg bg-teal-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">Net เพิ่มขึ้นจริง/เดือน</div>
            <div id="res-prom-net-diff" class="text-xl font-bold text-teal-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ภาษีเดิม/เดือน (ประมาณ)</span>
            <span id="res-prom-old-tax" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ภาษีใหม่/เดือน (ประมาณ)</span>
            <span id="res-prom-new-tax" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ส่วนต่าง Gross รายปี</span>
            <span id="res-prom-annual-diff" class="font-medium text-green-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">วิธีคำนวณภาษี (ประมาณการ)</h2>
      <p>ใช้สูตรประมาณการอย่างง่าย: หักค่าใช้จ่าย 50% สูงสุด 100,000 บาท/ปี + ลดหย่อนส่วนตัว 60,000 บาท/ปี แล้วคำนวณตามขั้นบันได</p>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณขึ้นเงินเดือน/">คำนวณขึ้นเงินเดือน</a></li>
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
        <li><a href="/คำนวณประกันสังคม/">คำนวณประกันสังคม</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#promotion-results" />
    <RelatedArticles currentHref="/คำนวณเงินเดือนหลังเลื่อนตำแหน่ง/" />
    <RelatedCalculators currentHref="/คำนวณเงินเดือนหลังเลื่อนตำแหน่ง/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์ภาษีเป็นการประมาณการอย่างง่าย ไม่รวมค่าลดหย่อนพิเศษ ควรใช้เครื่องคำนวณภาษีเพื่อตัวเลขที่แม่นยำกว่า
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    function calcMonthlyTax(monthlySalary) {
      const annualGross = monthlySalary * 12;
      const expense = Math.min(annualGross * 0.5, 100000);
      const personal = 60000;
      const ssc = Math.min(monthlySalary * 0.05, 750) * 12;
      const netIncome = Math.max(annualGross - expense - personal - ssc, 0);
      const brackets = [[150000,0],[150000,.05],[200000,.10],[250000,.15],[250000,.20],[1000000,.25],[3000000,.30],[Infinity,.35]];
      let tax = 0, rem = netIncome;
      for (const [size, rate] of brackets) {
        if (rem <= 0) break;
        const chunk = Math.min(rem, size);
        tax += chunk * rate;
        rem -= chunk;
      }
      return tax / 12;
    }

    const form = document.getElementById('promotion-form');
    const formError = document.getElementById('promotion-form-error');
    const resultBox = document.getElementById('promotion-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['prom-old-salary-error','prom-new-salary-error'].forEach((id) => setErr(id, ''));

      const oldSalary = parseNum(document.getElementById('prom-old-salary').value);
      const newSalary = parseNum(document.getElementById('prom-new-salary').value);

      let hasError = false;
      if (!Number.isFinite(oldSalary) || oldSalary <= 0) { setErr('prom-old-salary-error', 'กรอกเงินเดือนเดิมมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(newSalary) || newSalary <= 0) { setErr('prom-new-salary-error', 'กรอกเงินเดือนใหม่มากกว่า 0'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const pctIncrease = ((newSalary - oldSalary) / oldSalary) * 100;
      const grossDiff = newSalary - oldSalary;
      const oldTax = calcMonthlyTax(oldSalary);
      const newTax = calcMonthlyTax(newSalary);
      const taxDiff = newTax - oldTax;
      const netDiff = grossDiff - taxDiff;

      setText('res-prom-pct', `+${pctIncrease.toFixed(2)}%`);
      setText('res-prom-gross-diff', `+${formatMoney(grossDiff)}`);
      setText('res-prom-tax-diff', `+${formatMoney(taxDiff)}`);
      setText('res-prom-net-diff', `+${formatMoney(netDiff)}`);
      setText('res-prom-old-tax', formatMoney(oldTax));
      setText('res-prom-new-tax', formatMoney(newTax));
      setText('res-prom-annual-diff', `+${formatMoney(grossDiff * 12)}`);

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
