---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'ฟรีแลนซ์ต้องเสียภาษีอะไรบ้าง?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ฟรีแลนซ์ต้องเสียภาษีเงินได้บุคคลธรรมดา (PIT) หากรายได้ต่อปีเกิน 120,000 บาท และอาจต้องจดทะเบียน VAT หากรายได้เกิน 1.8 ล้านบาทต่อปี'
      }
    },
    {
      '@type': 'Question',
      name: 'ฟรีแลนซ์หักค่าใช้จ่ายได้เท่าไหร่?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ฟรีแลนซ์สามารถหักค่าใช้จ่ายได้ 60% ของรายได้จากงานอิสระ หรือใช้หักตามจริง (ต้องมีใบเสร็จ)'
      }
    },
    {
      '@type': 'Question',
      name: 'ฟรีแลนซ์ยื่นภาษีเมื่อไหร่?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ยื่นภาษีประจำปีภายในวันที่ 31 มีนาคม ของปีถัดไป หรือยื่นออนไลน์ผ่าน e-Filing ของกรมสรรพากร ภายใน 8 เมษายน'
      }
    },
    {
      '@type': 'Question',
      name: 'ถ้าฟรีแลนซ์รายได้ต่ำกว่า 120,000 บาท ต้องยื่นภาษีไหม?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ยังต้องยื่นแบบแสดงรายการภาษีเงินได้บุคคลธรรมดา (ภ.ง.ด.91/90) แต่จะไม่มีภาษีต้องชำระถ้ารายได้ไม่เกินเกณฑ์'
      }
    }
  ]
};
---

<BaseLayout
  title="Freelancer Tax Guide Thailand — How Much Tax Do You Pay? | Kamnuanlek"
  description="Complete guide to Thai freelancer taxes. How to calculate income tax, deductions, when to file, and VAT registration. Use our free calculator."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Freelancer Tax Guide — Thailand</h1>

    <div class="mb-12 p-6 bg-orange-50 border border-orange-200 rounded-lg">
      <p class="text-lg text-gray-800">
        Freelancing in Thailand? This guide explains exactly what taxes you owe, how much you can deduct, and how to calculate your tax bill correctly.
      </p>
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">1. Types of Tax for Freelancers</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">Personal Income Tax (PIT)</h3>
            <p class="text-gray-700 text-sm">Required when annual income exceeds 120,000 THB. Progressive rates: 0% to 35%.</p>
          </div>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">VAT (7%)</h3>
            <p class="text-gray-700 text-sm">Required when annual revenue exceeds 1.8 million THB. Register with the Revenue Department.</p>
          </div>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">Withholding Tax</h3>
            <p class="text-gray-700 text-sm">Clients deduct 3% when paying freelancers (above 1,000 THB per payment). You receive a certificate.</p>
          </div>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">Social Security (Optional)</h3>
            <p class="text-gray-700 text-sm">Self-employed can voluntarily contribute to Section 39 social security (432 THB/month).</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">2. How to Calculate Your Tax</h2>
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <ol class="space-y-4">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <p class="font-semibold text-gray-900">Total Freelance Income</p>
                <p class="text-gray-600 text-sm">Add all client payments received in the tax year</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <p class="font-semibold text-gray-900">Deduct 60% Expense Allowance</p>
                <p class="text-gray-600 text-sm">Or use actual expenses (requires receipts). Most freelancers use 60%.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center font-bold">3</span>
              <div>
                <p class="font-semibold text-gray-900">Deduct Personal Allowance</p>
                <p class="text-gray-600 text-sm">60,000 THB personal + 20,000 THB per dependent</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center font-bold">4</span>
              <div>
                <p class="font-semibold text-gray-900">Apply Tax Brackets</p>
                <p class="text-gray-600 text-sm">Progressive: 5% on first 150k, 10% on next 150k, etc.</p>
              </div>
            </li>
          </ol>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">3. Example Calculation</h2>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <p class="font-semibold text-gray-900 mb-4">Scenario: Freelance designer earning 600,000 THB/year</p>
          <div class="space-y-2 text-gray-700">
            <div class="flex justify-between border-b border-gray-200 pb-2">
              <span>Total income</span><span class="font-semibold">600,000 THB</span>
            </div>
            <div class="flex justify-between border-b border-gray-200 pb-2">
              <span>Expense deduction (60%)</span><span class="text-red-600">- 360,000 THB</span>
            </div>
            <div class="flex justify-between border-b border-gray-200 pb-2">
              <span>Net income after expenses</span><span>240,000 THB</span>
            </div>
            <div class="flex justify-between border-b border-gray-200 pb-2">
              <span>Personal allowance</span><span class="text-red-600">- 60,000 THB</span>
            </div>
            <div class="flex justify-between border-b border-gray-200 pb-2">
              <span><strong>Taxable income</strong></span><span class="font-semibold">180,000 THB</span>
            </div>
            <div class="flex justify-between pt-2">
              <span><strong>Tax owed</strong></span><span class="font-bold text-primary-600">1,500 THB (5% on 30,000 over 150k)</span>
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">ฟรีแลนซ์ต้องเสียภาษีอะไรบ้าง?</h3>
            <p class="text-gray-700 text-sm">ภาษีเงินได้บุคคลธรรมดา (PIT) ถ้ารายได้เกิน 120,000 บาท/ปี และ VAT ถ้ารายได้เกิน 1.8 ล้านบาท/ปี</p>
          </div>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">ฟรีแลนซ์หักค่าใช้จ่ายได้เท่าไหร่?</h3>
            <p class="text-gray-700 text-sm">หักได้ 60% ของรายได้ หรือหักตามจริง (ต้องมีใบเสร็จ)</p>
          </div>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">ฟรีแลนซ์ยื่นภาษีเมื่อไหร่?</h3>
            <p class="text-gray-700 text-sm">ภายใน 31 มีนาคม (กระดาษ) หรือ 8 เมษายน (e-Filing) ของปีถัดไป</p>
          </div>
        </div>
      </section>
    </div>

    <div class="mt-12 p-6 bg-blue-50 border border-blue-200 rounded-lg">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Calculate Your Freelancer Tax</h2>
      <p class="text-gray-700 mb-4">Use our income tax calculator — include the 60% expense deduction to get the correct freelancer tax amount:</p>
      <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-semibold">
        Calculate My Tax →
      </a>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Resources</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/วิธีคำนวณภาษีเงินได้ไทย/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📚 Tax Calculation Guide</span>
          <p class="text-gray-600 text-sm mt-2">Step-by-step instructions</p>
        </a>
        <a href="/ตรวจสอบหักลดหย่อนภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">✅ Deductions Checklist</span>
          <p class="text-gray-600 text-sm mt-2">All eligible write-offs</p>
        </a>
        <a href="/ผิดพลาดภาษีทั่วไป/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">❌ Common Mistakes</span>
          <p class="text-gray-600 text-sm mt-2">Avoid these 8 errors</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
