---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculateCateringPerPerson } from '../../lib/catering-per-person-cost-calculator';

const pageTitle = 'คำนวณค่าเลี้ยงต่อคน ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าเลี้ยงต่อคนแขก โดยหารงบประมาณเลี้ยงรวมด้วยจำนวนแขก ได้ผลลัพธ์ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าเลี้ยงต่อคน/`;

const faqData = [
  {
    question: 'ค่าเลี้ยงต่อคนปกติเป็นเท่าไร?',
    answer: 'ขึ้นอยู่กับประเภทของงาน เช่น งานแบบจำนวน 200-800 บาทต่อคนสำหรับพิธีเลี้ยงในร่มหรือพื้นที่จำกัด'
  }
];
const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};


const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าเลี้ยงต่อคน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเลี้ยงต่อคน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าเลี้ยงต่อคน
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าเลี้ยงต่อคนแขก โดยหารงบประมาณเลี้ยงรวมด้วยจำนวนแขก
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="totalBudget" class="block text-sm font-medium text-gray-700 mb-1">
            งบประมาณเลี้ยงรวม (บาท)
          </label>
          <input
            type="text"
            id="totalBudget"
            inputmode="decimal"
            placeholder="เช่น 15000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
        <div>
          <label for="guestCount" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนแขก (คน)
          </label>
          <input
            type="text"
            id="guestCount"
            inputmode="decimal"
            placeholder="เช่น 50"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors"
      >
        คำนวณ
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6">
        <div class="bg-green-50 rounded-lg p-4">
          <div class="text-sm text-gray-600 mb-1">ค่าเลี้ยงต่อคน</div>
          <div id="perPersonCost" class="text-3xl font-bold text-green-600">-</div>
        </div>
      </div>
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณค่าเลี้ยงต่อคน</h2>
      <p class="text-gray-600">
        การคำนวณค่าเลี้ยงต่อคนนั้นง่ายดาย โดยหารงบประมาณเลี้ยงรวมด้วยจำนวนแขกที่ประมาณการ เครื่องคำนวณนี้จะช่วยให้คุณรู้ว่าค่าเลี้ยงต่อคนแขกจะเป็นเท่าไร
      </p>
    </section>
  </article>
</BaseLayout>

<script>
  const form = {
    totalBudget: document.getElementById('totalBudget') as HTMLInputElement,
    guestCount: document.getElementById('guestCount') as HTMLInputElement,
  };

  const resultDiv = document.getElementById('result');
  const btn = document.getElementById('btn-calculate');

  btn?.addEventListener('click', () => {
    const totalBudget = parseFloat(form.totalBudget.value) || 0;
    const guestCount = parseFloat(form.guestCount.value) || 0;

    if (guestCount <= 0) {
      alert('กรุณาระบุจำนวนแขก');
      return;
    }

    const perPersonCost = Math.round(totalBudget / guestCount);
    (document.getElementById('perPersonCost') as HTMLElement).textContent =
      perPersonCost.toLocaleString('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + ' บาท';

    resultDiv?.classList.remove('hidden');
    resultDiv?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
