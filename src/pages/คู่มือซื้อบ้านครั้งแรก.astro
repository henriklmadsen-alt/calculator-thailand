---
import BaseLayout from '../layouts/BaseLayout.astro';

const howtoSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Buy Your First Home in Thailand',
  description: 'Step-by-step guide to buying your first home in Thailand, including financing, fees, and taxes.',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Check Your Budget', text: 'Calculate how much home you can afford. Rule of thumb: monthly payment should not exceed 30% of your gross income.' },
    { '@type': 'HowToStep', position: 2, name: 'Save for Down Payment', text: 'Thai banks typically require 10-30% down payment. First-time buyers may qualify for 90% LTV loans.' },
    { '@type': 'HowToStep', position: 3, name: 'Get Pre-Approved', text: 'Apply for a home loan pre-approval from 2-3 banks to compare rates and terms.' },
    { '@type': 'HowToStep', position: 4, name: 'Calculate Total Transfer Costs', text: 'Budget for transfer fees (2%), specific business tax (3.3%), stamp duty, and withholding tax on top of purchase price.' },
    { '@type': 'HowToStep', position: 5, name: 'Sign Sales Agreement', text: 'Review the sale and purchase agreement carefully. Pay 10% deposit.' },
    { '@type': 'HowToStep', position: 6, name: 'Complete Transfer at Land Office', text: 'Both parties meet at Land Department to complete the transfer and pay all fees.' },
  ]
};
---

<BaseLayout
  title="คู่มือซื้อบ้านครั้งแรก 2569 — ค่าใช้จ่าย ค่าธรรมเนียม และสินเชื่อ | Kamnuanlek"
  description="คู่มือซื้อบ้านครั้งแรกฉบับสมบูรณ์ คำนวณค่าใช้จ่ายวันโอน ค่าจดจำนอง อากรแสตมป์ เปรียบเทียบสินเชื่อ และวางแผนงบซื้อบ้าน อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "คู่มือซื้อบ้านครั้งแรก 2569 — ค่าใช้จ่าย ค่าธรรมเนียม และสินเชื่อ", "item": "https://www.kamnuanlek.com/คู่มือซื้อบ้านครั้งแรก/"}
    ]
  }</script>
  <script type="application/ld+json" set:html={JSON.stringify(howtoSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">คู่มือซื้อบ้านครั้งแรก ปี 2569</h1>

    <div class="mb-10 p-6 bg-rose-50 border border-rose-200 rounded-lg">
      <p class="text-lg text-gray-800">
        กำลังซื้อบ้านครั้งแรกในไทย? คู่มือนี้ครอบคลุมทุกขั้นตอน ตั้งแต่งบประมาณ สินเชื่อ ค่าธรรมเนียมกฎหมาย ไปจนถึงกระบวนการโอนกรรมสิทธิ์
      </p>
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-6">คู่มือทีละขั้นตอน</h2>
        <div class="space-y-4">
          {[
            { num: 1, title: 'ตรวจสอบงบประมาณ', desc: 'คำนวณว่าคุณสามารถซื้อบ้านราคาเท่าไรได้ ค่างวดรายเดือนไม่ควรเกิน 30% ของรายได้รวม ใช้เครื่องคำนวณสินเชื่อบ้านของเรา', cta: 'คำนวณสินเชื่อบ้าน', link: '/คำนวณผ่อนบ้าน/' },
            { num: 2, title: 'ออมเงินดาวน์', desc: 'ธนาคารไทยต้องการเงินดาวน์ 10-30% ผู้ซื้อบ้านครั้งแรกอาจสมัครสินเชื่อ LTV 90% ได้ตามเกณฑ์ธนาคารแห่งประเทศไทย' },
            { num: 3, title: 'ขอวงเงินสินเชื่อล่วงหน้า', desc: 'ยื่นขอวงเงินล่วงหน้าจาก 2-3 ธนาคารเพื่อเปรียบเทียบอัตราดอกเบี้ยและเงื่อนไข โดยทั่วไปดอกเบี้ยอยู่ที่ 2-5% ขึ้นอยู่กับประวัติเครดิต' },
            { num: 4, title: 'คำนวณค่าใช้จ่ายโอนทั้งหมด', desc: 'เตรียมงบประมาณเพิ่มอีก 5-8% ของราคาซื้อสำหรับค่าธรรมเนียมราชการ', cta: 'คำนวณค่าธรรมเนียมโอน', link: '/คำนวณค่าโอนบ้าน/' },
            { num: 5, title: 'ลงนามสัญญาจะซื้อจะขาย', desc: 'ตรวจสอบสัญญาจะซื้อจะขายอย่างละเอียด ชำระมัดจำ 10% ตรวจสอบโฉนดที่กรมที่ดิน' },
            { num: 6, title: 'โอนกรรมสิทธิ์', desc: 'พบกันที่กรมที่ดินพร้อมเอกสารครบ ชำระค่าธรรมเนียมและภาษีทั้งหมด รับโฉนดที่ดิน' },
          ].map((step) => (
            <div class="flex gap-4 p-5 bg-white border border-gray-200 rounded-lg">
              <div class="flex-shrink-0 w-10 h-10 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center font-bold text-sm">{step.num}</div>
              <div class="flex-grow">
                <h3 class="font-bold text-gray-900 mb-1">{step.title}</h3>
                <p class="text-gray-700 text-sm mb-2">{step.desc}</p>
                {step.cta && <a href={step.link} class="text-primary-600 text-sm font-medium hover:underline">{step.cta} →</a>}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">ค่าใช้จ่ายทั่วไปในการซื้อบ้าน</h2>
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">รายการค่าใช้จ่าย</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">อัตรา</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">บ้านราคา 2 ล้านบาท</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t">
                <td class="px-4 py-3 text-gray-900">ค่าธรรมเนียมโอน</td>
                <td class="px-4 py-3 text-gray-600">2%</td>
                <td class="px-4 py-3 font-semibold">40,000 บาท</td>
              </tr>
              <tr class="border-t bg-gray-50">
                <td class="px-4 py-3 text-gray-900">ภาษีธุรกิจเฉพาะ</td>
                <td class="px-4 py-3 text-gray-600">3.3%</td>
                <td class="px-4 py-3 font-semibold">66,000 บาท</td>
              </tr>
              <tr class="border-t">
                <td class="px-4 py-3 text-gray-900">ค่าจดจำนอง</td>
                <td class="px-4 py-3 text-gray-600">1% ของวงเงินกู้</td>
                <td class="px-4 py-3 font-semibold">18,000 บาท</td>
              </tr>
              <tr class="border-t bg-gray-50 font-bold">
                <td class="px-4 py-3">ค่าใช้จ่ายรวมทั้งหมด</td>
                <td class="px-4 py-3">~6-8%</td>
                <td class="px-4 py-3 text-primary-600">~124,000 บาท</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องคำนวณที่คุณต้องใช้</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/คำนวณผ่อนบ้าน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏦 เครื่องคำนวณสินเชื่อบ้าน</span>
          <p class="text-gray-600 text-sm mt-2">คำนวณค่างวดรายเดือน</p>
        </a>
        <a href="/เครื่องคำนวณอสังหาริมทรัพย์/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏠 เครื่องคำนวณค่าใช้จ่ายอสังหาฯ</span>
          <p class="text-gray-600 text-sm mt-2">ค่าธรรมเนียมโอนและภาษีที่ดิน</p>
        </a>
        <a href="/เปรียบเทียบสินเชื่อ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🔍 เปรียบเทียบสินเชื่อ</span>
          <p class="text-gray-600 text-sm mt-2">เปรียบเทียบตัวเลือกสินเชื่อบ้าน</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
