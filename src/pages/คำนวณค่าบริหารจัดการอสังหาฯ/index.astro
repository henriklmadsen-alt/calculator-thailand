---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่าบริหารจัดการอสังหาฯ 2569 | ค่าเช่าพื้นที่ | ค่าจ้างอยู่อาศัย | Kamnuanlek';
const pageDescription = 'คำนวณค่าบริหารจัดการทรัพย์สินอสังหาฯ ตามเปอร์เซ็นต์ของรายได้เช่า หรือค่าคงที่ต่อเดือน ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าบริหารจัดการอสังหาฯ/`;

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าบริหารจัดการอสังหาฯ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const faqData = [
  { question: 'Cap Rate ที่ดีสำหรับอสังหาริมทรัพย์ไทยคือเท่าไร?', answer: 'Cap Rate ที่ดีในไทยมักอยู่ที่ 5-8% ต่อปี ขึ้นอยู่กับทำเลและประเภทอสังหาฯ ทำเลกรุงเทพฯ ชั้นในมักได้ cap rate ต่ำกว่าต่างจังหวัด' },
  { question: 'ค่าใช้จ่ายแฝงในการซื้ออสังหาฯ มีอะไรบ้าง?', answer: 'ค่าโอน ค่าจดจำนอง ค่าอากรแสตมป์ ภาษีธุรกิจเฉพาะ ค่านายหน้า ค่าซ่อมแซม รวมกันอาจสูงถึง 3-7% ของราคาซื้อ' },
  { question: 'ผลตอบแทนการลงทุนอสังหาฯ ที่ดีต้องเป็นเท่าไร?', answer: 'นักลงทุนส่วนใหญ่ต้องการ IRR อย่างน้อย 8-12% ต่อปี หรือ Yield ค่าเช่า 5-7% ขึ้นอยู่กับทำเลและเป้าหมาย' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกราคาซื้อ ค่าเช่า ค่าใช้จ่ายรายเดือน เครื่องจะคำนวณ Yield, Cash Flow และ Cap Rate ให้อัตโนมัติ' }
,
  { question: 'ค่าโอนบ้านปี 2569 คิดอัตราเท่าไร?', answer: 'ค่าธรรมเนียมโอน 2% ของราคาประเมิน (ลดเหลือ 1% สำหรับที่อยู่อาศัยราคาไม่เกิน 3 ล้าน จนถึง 31 ธ.ค. 2568), ค่าจดจำนอง 1% ของวงเงิน (ลดเหลือ 0.01% สำหรับกู้ไม่เกิน 3 ล้าน)' },
  { question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ต่างกันอย่างไร?', answer: 'ภาษีธุรกิจเฉพาะ 3.3% (ถือครองน้อยกว่า 5 ปีหรือไม่ได้มีชื่อในทะเบียนบ้าน) | อากรแสตมป์ 0.5% (ถือครอง 5 ปีขึ้นไปและมีชื่อในทะเบียนบ้านครบ 1 ปี) เสียอย่างใดอย่างหนึ่ง' },
  { question: 'ราคาประเมินกรมที่ดินกับราคาตลาดต่างกันอย่างไร?', answer: 'ราคาประเมินคือราคาที่กรมที่ดินกำหนดเพื่อใช้คิดค่าธรรมเนียม อัปเดตทุก 4 ปี มักต่ำกว่าราคาตลาด 20-50% ภาษีและค่าธรรมเนียมใช้ราคาประเมินหรือราคาซื้อขาย แล้วแต่อย่างไหนสูงกว่า' },
  { question: 'ซื้อบ้านมือสองต้องระวังค่าใช้จ่ายอะไร?', answer: 'ค่าธรรมเนียมโอน ค่าภาษีธุรกิจเฉพาะหรืออากรแสตมป์ ค่าจดจำนอง ค่าตรวจสอบภาระผูกพัน ค่าประเมินราคา ค่าซ่อมแซม และค่าประกันภัย รวมกันอาจสูงถึง 5-10% ของราคาซื้อ' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าบริหารจัดการ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณค่าบริหารจัดการอสังหาฯ ปี 2569</h1>
    <p class="text-gray-600 mb-6">คำนวณค่าบริหารจัดการและค่าสาธารณูปโภค สำหรับการเช่าห้องพักอาศัย ห้องออฟฟิศ หรือพื้นที่พาณิชย์</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="management-fee-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="monthly-income" class="block text-sm font-medium text-gray-700 mb-1">รายได้เช่าต่อเดือน (บาท)</label>
            <input id="monthly-income" type="text" inputmode="numeric" placeholder="เช่น 50,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="fee-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทค่าบริหาร</label>
            <select id="fee-type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="percentage">เปอร์เซ็นต์ของรายได้เช่า (%)</option>
              <option value="fixed">ค่าคงที่ต่อเดือน (บาท)</option>
            </select>
          </div>
        </div>

        <div>
          <label for="fee-amount" class="block text-sm font-medium text-gray-700 mb-1" id="fee-label">อัตราค่าบริหาร (%)</label>
          <input id="fee-amount" type="text" inputmode="decimal" placeholder="เช่น 5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" value="5" />
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณค่าบริหาร
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="rounded-lg bg-primary-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ค่าบริหารจัดการ/เดือน</div>
          <div id="res-management-fee" class="text-2xl font-bold text-primary-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">รายได้เช่า/เดือน</span>
            <span id="res-monthly-income" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">อัตราค่าบริหาร</span>
            <span id="res-fee-rate" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-600">ค่าบริหาร/เดือน</span>
            <span id="res-monthly-fee" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าบริหาร/ปี</span>
            <span id="res-annual-fee" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">รายได้สุทธิ/เดือน</span>
            <span id="res-net-income" class="font-bold text-lg text-emerald-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.dol.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมที่ดิน (dol.go.th)</a> — อัตราค่าธรรมเนียมการโอนและจดทะเบียนสิทธิ์</li>
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยสินเชื่อบ้านอ้างอิง MRR/MLR</li>
      </ul>
    </div>
    <RelatedCalculators currentHref="/คำนวณค่าบริหารจัดการอสังหาฯ/" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#management-fee-form');
  const results = document.querySelector('#results');
  const feeTypeSelect = document.querySelector('#fee-type');
  const feeLabel = document.querySelector('#fee-label');
  const feeAmountInput = document.querySelector('#fee-amount');

  feeTypeSelect?.addEventListener('change', (e) => {
    if (e.target.value === 'percentage') {
      feeLabel.textContent = 'อัตราค่าบริหาร (%)';
      feeAmountInput.placeholder = 'เช่น 5';
      feeAmountInput.value = '5';
    } else {
      feeLabel.textContent = 'ค่าบริหาร/เดือน (บาท)';
      feeAmountInput.placeholder = 'เช่น 2500';
      feeAmountInput.value = '';
    }
  });

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const monthlyIncome = parseNumber(document.querySelector('#monthly-income')?.value || '');
    const feeType = document.querySelector('#fee-type')?.value || 'percentage';
    const feeAmount = parseNumber(document.querySelector('#fee-amount')?.value || '');

    if (!(Number.isFinite(monthlyIncome) && monthlyIncome > 0 && Number.isFinite(feeAmount) && feeAmount >= 0)) {
      results?.classList.add('hidden');
      return;
    }

    let monthlyFee = 0;
    let feeRate = '';

    if (feeType === 'percentage') {
      monthlyFee = monthlyIncome * (feeAmount / 100);
      feeRate = `${feeAmount.toFixed(2)}%`;
    } else {
      monthlyFee = feeAmount;
      feeRate = formatCurrency(feeAmount);
    }

    const annualFee = monthlyFee * 12;
    const netIncome = monthlyIncome - monthlyFee;

    document.querySelector('#res-management-fee').textContent = formatCurrency(monthlyFee);
    document.querySelector('#res-monthly-income').textContent = formatCurrency(monthlyIncome);
    document.querySelector('#res-fee-rate').textContent = feeRate;
    document.querySelector('#res-monthly-fee').textContent = formatCurrency(monthlyFee);
    document.querySelector('#res-annual-fee').textContent = formatCurrency(annualFee);
    document.querySelector('#res-net-income').textContent = formatCurrency(netIncome);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
