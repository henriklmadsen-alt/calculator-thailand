---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณขึ้นเงินเดือน 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณขึ้นเงินเดือน 2569 ฟรี — ใส่เงินเดือนปัจจุบันและเปอร์เซ็นต์ที่ขึ้น รู้เงินเดือนใหม่และส่วนต่างรายเดือน-รายปีทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณขึ้นเงินเดือน/`;

const faqData = [
  {
    question: 'ขึ้นเงินเดือน 5% หมายความว่าอะไร?',
    answer: 'ขึ้นเงินเดือน 5% หมายความว่าเงินเดือนใหม่ = เงินเดือนเดิม × 1.05 เช่น เงินเดือนเดิม 30,000 บาท ขึ้น 5% = 31,500 บาท ส่วนต่างรายเดือน 1,500 บาท',
  },
  {
    question: 'อัตราขึ้นเงินเดือนเฉลี่ยในไทยเป็นเท่าไร?',
    answer: 'อัตราขึ้นเงินเดือนเฉลี่ยในไทยมักอยู่ที่ 3-8% ต่อปี ขึ้นอยู่กับอุตสาหกรรม ผลประกอบการบริษัท และผลงานพนักงาน',
  },
  {
    question: 'ขึ้นเงินเดือนมีผลต่อภาษีอย่างไร?',
    answer: 'เงินเดือนที่สูงขึ้นอาจทำให้เสียภาษีเพิ่มขึ้นตามขั้นบันได ควรคำนวณผลกระทบภาษีควบคู่ด้วย',
  },
  {
    question: 'ถ้าขึ้นเงินเดือนกลางปีต้องคำนวณอย่างไร?',
    answer: 'รายได้เพิ่มต่อปีในปีนั้น = ส่วนต่างรายเดือน × จำนวนเดือนที่เหลือในปี เช่น ขึ้นตั้งแต่เดือนกรกฎาคม = ส่วนต่าง × 6 เดือน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณขึ้นเงินเดือน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณขึ้นเงินเดือน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ดูผลของการขึ้นเงินเดือนทันที</p>
      <p class="mt-1 text-sm text-slate-700">เงินเดือนใหม่, ส่วนต่างรายเดือน, ส่วนต่างรายปี</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับพนักงานที่กำลังเจรจาขึ้นเงินเดือนหรือวางแผนการเงิน</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณขึ้นเงินเดือน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือนปัจจุบันและเปอร์เซ็นต์ที่ขึ้น ระบบจะแสดงเงินเดือนใหม่และส่วนต่างทั้งรายเดือนและรายปี
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="raise-form" class="space-y-5">
        <p id="raise-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="raise-current" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือนปัจจุบัน (บาท/เดือน)</label>
            <input type="text" id="raise-current" inputmode="numeric" placeholder="เช่น 35,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="raise-current-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="raise-pct" class="mb-1 block text-sm font-medium text-gray-700">เปอร์เซ็นต์ขึ้นเงินเดือน (%)</label>
            <input type="text" id="raise-pct" inputmode="decimal" placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="raise-pct-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณขึ้นเงินเดือน
        </button>
      </form>
    </div>

    <div id="raise-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินเดือนใหม่</div>
            <div id="res-raise-new" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ส่วนต่างรายเดือน</div>
            <div id="res-raise-monthly-diff" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ส่วนต่างรายปี</div>
            <div id="res-raise-annual-diff" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="rounded-lg bg-rose-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินเดือนเดิม</div>
            <div id="res-raise-old" class="text-xl font-bold text-rose-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>เงินเดือนใหม่ = เงินเดือนปัจจุบัน × (1 + % ÷ 100)</li>
        <li>ส่วนต่างรายเดือน = เงินเดือนใหม่ − เงินเดือนปัจจุบัน</li>
        <li>ส่วนต่างรายปี = ส่วนต่างรายเดือน × 12</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณเงินเดือนหลังเลื่อนตำแหน่ง/">คำนวณเงินเดือนหลังเลื่อนตำแหน่ง</a></li>
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
        <li><a href="/คำนวณโบนัสประจำปี/">คำนวณโบนัสประจำปี</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#raise-results" />
    <RelatedArticles currentHref="/คำนวณขึ้นเงินเดือน/" />
    <RelatedCalculators currentHref="/คำนวณขึ้นเงินเดือน/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการคำนวณตัวเลขเบื้องต้น ยอดจริงอาจต่างกันตามนโยบายและเงื่อนไขของบริษัท
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('raise-form');
    const formError = document.getElementById('raise-form-error');
    const resultBox = document.getElementById('raise-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['raise-current-error','raise-pct-error'].forEach((id) => setErr(id, ''));

      const current = parseNum(document.getElementById('raise-current').value);
      const pct = parseNum(document.getElementById('raise-pct').value);

      let hasError = false;
      if (!Number.isFinite(current) || current <= 0) { setErr('raise-current-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(pct) || pct < 0 || pct > 200) { setErr('raise-pct-error', 'กรอกเปอร์เซ็นต์ 0-200'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const newSalary = current * (1 + pct / 100);
      const monthlyDiff = newSalary - current;
      const annualDiff = monthlyDiff * 12;

      setText('res-raise-new', formatMoney(newSalary));
      setText('res-raise-monthly-diff', `+${formatMoney(monthlyDiff)}`);
      setText('res-raise-annual-diff', `+${formatMoney(annualDiff)}`);
      setText('res-raise-old', formatMoney(current));

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
