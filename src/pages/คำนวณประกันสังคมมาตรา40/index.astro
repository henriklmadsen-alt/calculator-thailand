---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณประกันสังคมมาตรา 40 ปี 2569 3 ทางเลือก 70-300 บาท/เดือน | Kamnuanlek';
const pageDescription = 'คำนวณประกันสังคมมาตรา 40 สำหรับผู้ประกอบอาชีพอิสระ ฟรีแลนซ์ 3 ทางเลือก 70, 100, 300 บาท/เดือน เปรียบเทียบสิทธิ์ที่ได้รับ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประกันสังคมมาตรา40/`;

const faqData = [
  {
    question: 'ประกันสังคมมาตรา 40 คืออะไร?',
    answer: 'มาตรา 40 เป็นการประกันสังคมสมัครใจสำหรับผู้ที่ไม่ได้เป็นลูกจ้างในระบบ เช่น ผู้ประกอบอาชีพอิสระ ฟรีแลนซ์ พ่อค้าแม่ค้า โดยเลือกทางเลือกการจ่ายได้ 3 ระดับ',
  },
  {
    question: 'ทางเลือกไหนคุ้มสุด?',
    answer: 'ทางเลือกที่ 3 (300 บาท/เดือน) ให้สิทธิ์มากสุด รวมกรณีชราภาพ เหมาะถ้าต้องการออมเงินบำนาญ ทางเลือกที่ 1 (70 บาท/เดือน) ถูกสุดแต่ได้สิทธิ์น้อยสุด',
  },
  {
    question: 'มาตรา 40 ทางเลือก 3 ได้เงินชราภาพเท่าไร?',
    answer: 'เงินบำนาญชราภาพคำนวณตามจำนวนเดือนที่สมทบและอัตราที่กำหนด อาจได้รับประมาณ 600-1,000+ บาท/เดือนหลังอายุ 60 ปี ขึ้นอยู่กับระยะเวลาสมทบ',
  },
  {
    question: 'สมัครมาตรา 40 ได้ที่ไหน?',
    answer: 'สมัครได้ที่สำนักงานประกันสังคมทั่วประเทศ, ไปรษณีย์ไทย, ธนาคาร, หรือสมัครออนไลน์ผ่าน www.sso.go.th',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณประกันสังคมมาตรา 40',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประกันสังคมมาตรา 40">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประกันสังคมมาตรา 40 — อาชีพอิสระ ฟรีแลนซ์</p>
      <p class="mt-1 text-sm text-slate-700">ทางเลือก 1: 70 บาท | ทางเลือก 2: 100 บาท | ทางเลือก 3: 300 บาท ต่อเดือน</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เปรียบเทียบสิทธิ์และค่าใช้จ่ายแต่ละทางเลือก</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณประกันสังคมมาตรา 40 ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      เลือกทางเลือกที่ต้องการและระบุจำนวนเดือน ระบบจะคำนวณยอดจ่ายรวมและแสดงสิทธิ์ที่ได้รับ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="m40-form" class="space-y-5">
        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700">เลือกทางเลือก</label>
          <div class="space-y-3">
            <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-gray-200 p-3 hover:border-primary-300 hover:bg-primary-50">
              <input type="radio" name="m40-option" value="1" class="mt-1 accent-primary-600" checked />
              <div>
                <div class="font-semibold text-gray-900">ทางเลือกที่ 1 — 70 บาท/เดือน</div>
                <div class="mt-1 text-sm text-gray-600">คุ้มครอง 3 กรณี: เจ็บป่วย · ทุพพลภาพ · เสียชีวิต</div>
              </div>
            </label>
            <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-gray-200 p-3 hover:border-primary-300 hover:bg-primary-50">
              <input type="radio" name="m40-option" value="2" class="mt-1 accent-primary-600" />
              <div>
                <div class="font-semibold text-gray-900">ทางเลือกที่ 2 — 100 บาท/เดือน</div>
                <div class="mt-1 text-sm text-gray-600">คุ้มครอง 4 กรณี: เจ็บป่วย · ทุพพลภาพ · เสียชีวิต · คลอดบุตร</div>
              </div>
            </label>
            <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-gray-200 p-3 hover:border-primary-300 hover:bg-primary-50">
              <input type="radio" name="m40-option" value="3" class="mt-1 accent-primary-600" />
              <div>
                <div class="font-semibold text-gray-900">ทางเลือกที่ 3 — 300 บาท/เดือน</div>
                <div class="mt-1 text-sm text-gray-600">คุ้มครอง 5 กรณี: เจ็บป่วย · ทุพพลภาพ · เสียชีวิต · คลอดบุตร · <strong>ชราภาพ</strong></div>
              </div>
            </label>
          </div>
        </div>

        <div>
          <label for="m40-months" class="mb-1 block text-sm font-medium text-gray-700">จำนวนเดือนที่ต้องการคำนวณ</label>
          <input type="text" id="m40-months" inputmode="numeric" placeholder="เช่น 12"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
          <p id="m40-months-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="m40-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินสมทบ/เดือน</div>
            <div id="res-m40-monthly" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รวมทั้งหมด</div>
            <div id="res-m40-total" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายปี</div>
            <div id="res-m40-annual" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div id="res-m40-benefits" class="rounded-lg bg-gray-50 p-4 text-sm text-gray-700"></div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">เปรียบเทียบ 3 ทางเลือก</h2>
      <table class="w-full text-sm">
        <thead><tr class="bg-gray-50"><th class="p-2 text-left">ทางเลือก</th><th class="p-2 text-right">บาท/เดือน</th><th class="p-2 text-right">บาท/ปี</th><th class="p-2 text-left">สิทธิ์</th></tr></thead>
        <tbody>
          <tr><td class="p-2">ทางเลือก 1</td><td class="p-2 text-right">70</td><td class="p-2 text-right">840</td><td class="p-2">เจ็บป่วย, ทุพพลภาพ, เสียชีวิต</td></tr>
          <tr class="bg-gray-50"><td class="p-2">ทางเลือก 2</td><td class="p-2 text-right">100</td><td class="p-2 text-right">1,200</td><td class="p-2">+ คลอดบุตร</td></tr>
          <tr><td class="p-2">ทางเลือก 3</td><td class="p-2 text-right">300</td><td class="p-2 text-right">3,600</td><td class="p-2">+ ชราภาพ</td></tr>
        </tbody>
      </table>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">แหล่งอ้างอิง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="https://www.sso.go.th/wpr/content.jsp?lang=th&cat=866" target="_blank" rel="noopener noreferrer">สำนักงานประกันสังคม (SSO): มาตรา 40</a></li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณประกันสังคม/">คำนวณประกันสังคม</a></li>
        <li><a href="/คำนวณประกันสังคมมาตรา39/">คำนวณประกันสังคมมาตรา 39</a></li>
        <li><a href="/คำนวณรายได้ฟรีแลนซ์รายเดือน/">คำนวณรายได้ฟรีแลนซ์รายเดือน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#m40-results" />
    <RelatedArticles currentHref="/คำนวณประกันสังคมมาตรา40/" />
    <RelatedCalculators currentHref="/คำนวณประกันสังคมมาตรา40/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> อัตราและสิทธิ์อาจเปลี่ยนแปลงตามประกาศของสำนักงานประกันสังคม ควรตรวจสอบข้อมูลล่าสุดที่ sso.go.th
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const OPTIONS = {
      '1': { monthly: 70, benefits: ['เจ็บป่วย', 'ทุพพลภาพ', 'เสียชีวิต'] },
      '2': { monthly: 100, benefits: ['เจ็บป่วย', 'ทุพพลภาพ', 'เสียชีวิต', 'คลอดบุตร'] },
      '3': { monthly: 300, benefits: ['เจ็บป่วย', 'ทุพพลภาพ', 'เสียชีวิต', 'คลอดบุตร', 'ชราภาพ'] },
    };

    const form = document.getElementById('m40-form');
    const resultBox = document.getElementById('m40-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      setErr('m40-months-error', '');

      const optionVal = document.querySelector('input[name="m40-option"]:checked').value;
      const months = parseNum(document.getElementById('m40-months').value);

      if (!Number.isFinite(months) || months <= 0 || months > 120) {
        setErr('m40-months-error', 'กรอกจำนวนเดือน 1-120');
        resultBox.classList.add('hidden');
        return;
      }

      const { monthly, benefits } = OPTIONS[optionVal];
      const total = monthly * months;
      const annual = monthly * 12;

      setText('res-m40-monthly', formatMoney(monthly));
      setText('res-m40-total', formatMoney(total));
      setText('res-m40-annual', formatMoney(annual));

      document.getElementById('res-m40-benefits').innerHTML =
        `<p class="mb-2 font-semibold">สิทธิ์ที่ได้รับ (${benefits.length} กรณี):</p>` +
        benefits.map((b) => `<span class="mr-2 inline-block rounded bg-green-100 px-2 py-0.5 text-green-800">✓ ${b}</span>`).join('');

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
