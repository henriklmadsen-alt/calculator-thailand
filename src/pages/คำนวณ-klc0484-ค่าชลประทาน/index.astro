---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าชลประทานและน้ำเพื่อการเกษตร | Kamnuanlek';
const pageDescription = 'คำนวณค่าใช้น้ำชลประทาน ค่าสูบน้ำ ค่าไฟปั๊มน้ำ ต้นทุนน้ำต่อไร่';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0484-ค่าชลประทาน/`;
const faqData = [
  { question: 'ค่าน้ำชลประทานคิดอย่างไร?', answer: 'ชลประทานของรัฐมักไม่คิดค่าน้ำโดยตรง แต่มีค่าบำรุงรักษา 5-20 บาท/ไร่/ปี ส่วนน้ำบาดาลหรือบ่อส่วนตัว คิดจากค่าไฟปั๊มน้ำและค่าบำรุงรักษา' },
  { question: 'ปั๊มน้ำขนาดไหนเหมาะกับพื้นที่เกษตร?', answer: 'พื้นที่ 1-5 ไร่ ใช้ปั๊ม 0.5-1 แรงม้า พื้นที่ 5-20 ไร่ ปั๊ม 1-3 แรงม้า พื้นที่ใหญ่กว่า ใช้ปั๊มหอยโข่งขนาด 3-10 แรงม้า หรือระบบสูบน้ำพลังงานแสงอาทิตย์' },
  { question: 'ระบบน้ำหยดช่วยประหยัดน้ำได้แค่ไหน?', answer: 'ระบบน้ำหยดประหยัดน้ำได้ 30-50% เมื่อเทียบกับการให้น้ำแบบน้ำท่วมขัง เพิ่มผลผลิต ลดวัชพืช เหมาะไม้ผล พืชผัก ลงทุน 3,000-8,000 บาท/ไร่' },
  { question: 'น้ำบาดาลต้องขออนุญาตไหม?', answer: 'เจาะน้ำบาดาลต้องขออนุญาตจากกรมทรัพยากรน้ำบาดาล ค่าธรรมเนียม 500-1,000 บาท ค่าใช้น้ำ 0.5-2 บาท/ลูกบาศก์เมตร ขึ้นกับพื้นที่และปริมาณ' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าชลประทานและน้ำเพื่อการเกษตร">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าชลประทานและน้ำเพื่อการเกษตร</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนน้ำและค่าไฟสูบน้ำต่อฤดูกาล</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="pump_kw" class="block text-sm font-medium text-gray-700 mb-1">กำลังปั๊มน้ำ (กิโลวัตต์)</label><input type="text" id="pump_kw" inputmode="decimal" placeholder="เช่น 2.2" value="2.2" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="pump_hours_day" class="block text-sm font-medium text-gray-700 mb-1">ชั่วโมงสูบน้ำต่อวัน</label><input type="number" id="pump_hours_day" min="1" placeholder="เช่น 4" value="4" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="irrigation_days" class="block text-sm font-medium text-gray-700 mb-1">จำนวนวันให้น้ำ/ฤดูกาล</label><input type="number" id="irrigation_days" min="1" placeholder="เช่น 90" value="90" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="electric_rate" class="block text-sm font-medium text-gray-700 mb-1">ค่าไฟฟ้า (บาท/หน่วย)</label><input type="text" id="electric_rate" inputmode="decimal" placeholder="เช่น 4.2" value="4.2" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ค่าไฟปั๊มน้ำ/วัน</p><p id="daily_pump_cost" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">ค่าน้ำรวม/ฤดูกาล</p><p id="season_water_cost" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const kw = parseFloat((document.getElementById('pump_kw') as HTMLInputElement).value) || 0;
      const hours = parseFloat((document.getElementById('pump_hours_day') as HTMLInputElement).value) || 0;
      const days = parseFloat((document.getElementById('irrigation_days') as HTMLInputElement).value) || 0;
      const rate = parseFloat((document.getElementById('electric_rate') as HTMLInputElement).value) || 0;
      const dailyCost = kw * hours * rate;
      const seasonCost = dailyCost * days;
      (document.getElementById('daily_pump_cost') as HTMLElement).textContent = dailyCost.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('season_water_cost') as HTMLElement).textContent = Math.round(seasonCost).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('irrigation-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
