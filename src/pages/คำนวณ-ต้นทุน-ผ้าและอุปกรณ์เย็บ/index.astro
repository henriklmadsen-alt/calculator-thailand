---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TransparencyPanel from '../../components/templates/TransparencyPanel.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';

const pageTitle = 'คำนวณต้นทุนผ้าและอุปกรณ์เย็บ 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนผ้า ด้าย กระดุม ซิป และอุปกรณ์เย็บเสื้อผ้า รู้ราคาขายที่เหมาะสมฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุน-ผ้าและอุปกรณ์เย็บ/`;

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนผ้าและอุปกรณ์เย็บ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  pageName="คำนวณต้นทุนผ้าและอุปกรณ์เย็บ"
  categoryId="hobby"
  categoryName="งานอดิเรก/ศิลปะ"
  categorySlug="งานอดิเรก"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />

  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-4">คำนวณต้นทุนผ้าและอุปกรณ์เย็บ</h1>

    <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium mb-2">ราคาผ้าต่อเมตร (บาท)</label>
          <input type="number" id="fabricPrice" placeholder="200" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">เมตรทั้งหมด</label>
          <input type="number" id="meters" placeholder="2.5" step="0.5" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนด้าย (บาท)</label>
          <input type="number" id="thread" placeholder="100" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนกระดุม (บาท)</label>
          <input type="number" id="buttons" placeholder="80" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนซิป (บาท)</label>
          <input type="number" id="zippers" placeholder="60" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนรูปแบบและอื่นๆ (บาท)</label>
          <input type="number" id="other" placeholder="150" class="w-full border rounded px-3 py-2" />
        </div>
      </div>
      <button class="mt-6 w-full bg-blue-600 text-white py-2 rounded font-bold hover:bg-blue-700">
        คำนวณ
      </button>
    </div>

    <div id="result" class="hidden bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg shadow-lg p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">ผลลัพธ์</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ต้นทุนรวม</p>
          <p class="text-3xl font-bold text-blue-600" id="totalCost">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ต้นทุนผ้า</p>
          <p class="text-2xl font-bold text-blue-600" id="fabricCost">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ราคาขายแนะนำ</p>
          <p class="text-3xl font-bold text-green-600" id="sellingPrice">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">กำไรโดยประมาณ</p>
          <p class="text-3xl font-bold text-green-600" id="profit">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
      </div>
    </div>

    <TransparencyPanel
      dataOrigin="การคำนวณจากต้นทุนผ้าและอุปกรณ์เย็บที่ผู้ใช้ป้อนเข้า"
      lastUpdated="2026-04-22"
      accuracy="ความแม่นยำขึ้นอยู่กับต้นทุนที่ป้อนเข้า"
    />

    <GuardedAdSlot adUnitId="sewing-calculator" position="bottom" />
    <RelatedCalculators />
  </div>

  <script is:inline>
    function calculate() {
      const fabricCost = (parseFloat(document.getElementById('fabricPrice').value) || 0) * (parseFloat(document.getElementById('meters').value) || 0);
      const otherCosts = (parseFloat(document.getElementById('thread').value) || 0) +
        (parseFloat(document.getElementById('buttons').value) || 0) +
        (parseFloat(document.getElementById('zippers').value) || 0) +
        (parseFloat(document.getElementById('other').value) || 0);
      const totalCost = Math.round(fabricCost + otherCosts);
      const sellingPrice = Math.round(totalCost * 2.5);
      const profit = sellingPrice - totalCost;

      document.getElementById('result').classList.remove('hidden');
      document.getElementById('totalCost').textContent = totalCost.toLocaleString('th-TH');
      document.getElementById('fabricCost').textContent = Math.round(fabricCost).toLocaleString('th-TH');
      document.getElementById('sellingPrice').textContent = sellingPrice.toLocaleString('th-TH');
      document.getElementById('profit').textContent = Math.round(profit).toLocaleString('th-TH');
    }

    document.querySelector('button').addEventListener('click', calculate);
    document.querySelectorAll('input').forEach(input => {
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') calculate();
      });
    });

    window.addEventListener('load', () => {
      document.getElementById('fabricPrice').value = '200';
      document.getElementById('meters').value = '2.5';
      document.getElementById('thread').value = '100';
      document.getElementById('buttons').value = '80';
      document.getElementById('zippers').value = '60';
      document.getElementById('other').value = '150';
      calculate();
    });
  </script>
</BaseLayout>
