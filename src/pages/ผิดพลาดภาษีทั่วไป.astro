---
import BaseLayout from '../layouts/BaseLayout.astro';

const commonMistakes = [
  {
    title: 'Forgetting Deductible Expenses',
    desc: 'Many people don\'t claim all eligible work expenses, causing them to overpay tax.',
    solution: 'Keep records of all professional expenses: office supplies, equipment, education, etc.',
    tip: 'Use our tax calculator to see the impact of including all eligible deductions'
  },
  {
    title: 'Miscalculating Personal Allowance',
    desc: 'Some miss the 60,000 THB personal allowance or don\'t claim dependent allowances.',
    solution: 'Always include: 60,000 THB personal allowance + 20,000 THB per dependent.',
    tip: 'Recalculate with correct allowances — this can save thousands of baht'
  },
  {
    title: 'Applying Wrong Tax Bracket',
    desc: 'Using flat rates instead of progressive tax brackets leads to overpayment.',
    solution: 'Thai tax is progressive: 5% on first 150k, 10% on next 150k, etc.',
    tip: 'Use our calculator to apply the correct progressive rates automatically'
  },
  {
    title: 'Missing Income Sources',
    desc: 'Forgetting to add freelance, investment, or side income to total.',
    solution: 'Report ALL income: salary, freelance, dividends, rental, interest, capital gains.',
    tip: 'List all sources before calculating to ensure completeness'
  },
  {
    title: 'Wrong Calculation Timing',
    desc: 'Calculating tax mid-year instead of after final income is known.',
    solution: 'Calculate tax after tax year ends (Dec 31) when total income is finalized.',
    tip: 'Plan quarterly, but finalize calculations only when year is complete'
  },
  {
    title: 'Not Using Tax-Deferred Accounts',
    desc: 'Missing opportunities to reduce taxable income with retirement/insurance accounts.',
    solution: 'Contribute to retirement accounts (RMF, SSF) for tax deductions.',
    tip: 'Maximize tax-deferred contributions before year-end to lower tax bill'
  },
  {
    title: 'Incorrect Filing Status',
    desc: 'Wrong marital/dependent status leads to missing allowances or exemptions.',
    solution: 'Update status with government: married, children, dependents.',
    tip: 'Verify status changes are reflected in your tax calculation'
  },
  {
    title: 'Paying Too Early Without Calculation',
    desc: 'Voluntarily paying estimated tax without first calculating actual liability.',
    solution: 'Always calculate before paying to know the exact amount owed.',
    tip: 'Use our calculator to confirm amount before making tax payment'
  },
];
---

<BaseLayout
  title="8 ข้อผิดพลาดภาษีที่คนไทยทำบ่อย — หลีกเลี่ยงและประหยัดภาษีได้ | Kamnuanlek"
  description="8 ข้อผิดพลาดภาษีเงินได้ที่คนไทยทำบ่อยที่สุด เรียนรู้วิธีคำนวณที่ถูกต้องและประหยัดเงินจากสิทธิ์ลดหย่อนที่พลาดไป อัปเดตปี 2569"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">8 ข้อผิดพลาดภาษีที่คนไทยทำบ่อยที่สุด</h1>

    <div class="mb-12 p-6 bg-red-50 border border-red-200 rounded-lg">
      <p class="text-lg text-gray-800">
        Thousands of Thai taxpayers overpay each year. Learn the most common mistakes and how to avoid them.
      </p>
    </div>

    <div class="space-y-8">
      {commonMistakes.map((mistake, idx) => (
        <div class="p-6 border border-gray-200 rounded-lg hover:shadow-lg transition-shadow">
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-red-100 text-red-700 rounded-full flex items-center justify-center font-bold">
              {idx + 1}
            </div>
            <div class="flex-grow">
              <h3 class="text-xl font-bold text-gray-900 mb-2">❌ {mistake.title}</h3>
              <p class="text-gray-600 mb-3"><strong>Problem:</strong> {mistake.desc}</p>
              <p class="text-gray-600 mb-3"><strong>Solution:</strong> {mistake.solution}</p>
              <p class="p-3 bg-blue-50 rounded-lg border border-blue-200">
                <strong className="text-blue-900">💡 Tip:</strong> <span className="text-blue-800">{mistake.tip}</span>
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 p-8 bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl border border-green-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">✓ How to Calculate Correctly</h2>
      <ol class="space-y-3 text-gray-700">
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">1.</span>
          <span>List all income sources (salary, freelance, investments, etc.)</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">2.</span>
          <span>Add personal allowance (60,000 THB) + dependent allowances (20,000 THB each)</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">3.</span>
          <span>Subtract all allowances and deductible expenses from total income</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">4.</span>
          <span>Apply progressive tax brackets: 5%, 10%, 15%, 20%, 25%, 30-37%</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">5.</span>
          <span>Use our calculator to verify and avoid manual calculation errors</span>
        </li>
      </ol>
    </div>

    <div class="mt-12 p-6 bg-blue-50 border border-blue-200 rounded-lg">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Ready to Calculate Correctly?</h2>
      <p class="text-gray-700 mb-4">
        Stop guessing and start calculating with confidence. Our calculator helps you avoid these common mistakes:
      </p>
      <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-semibold">
        Use Income Tax Calculator →
      </a>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Resources</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/วิธีคำนวณภาษีเงินได้ไทย/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📚 How to Calculate Tax Guide</span>
          <p class="text-gray-600 text-sm mt-2">Step-by-step instructions for calculating your tax</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Calculators Hub</span>
          <p class="text-gray-600 text-sm mt-2">Complete collection of financial tools</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
