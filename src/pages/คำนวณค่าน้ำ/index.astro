---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณค่าน้ำประปา 2569 | Calculator Thailand';
const pageDescription = 'ค่าน้ำประปา MWA PWA ท้องถิ่น อัตราค่าน้ำ หน่วยใช้ ตารางสรุป 2569 ฟรี ตรวจสอบ ตอนนี้';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าน้ำ/`;

const faqData = [
  {
    question: 'ค่าน้ำบ้านอยู่อาศัยคิดแบบขั้นบันไดอย่างไร?',
    answer: 'ให้แยกปริมาณใช้น้ำตามช่วงหน่วยของแต่ละการประปา แล้วคูณอัตราต่อหน่วยในแต่ละช่วง จากนั้นรวมยอดทุกช่วง และบวกค่าอื่นที่เกี่ยวข้อง เช่น ค่าบริการรายเดือนหรือ VAT ตามเงื่อนไขของหน่วยงาน',
  },
  {
    question: 'ทำไมค่าน้ำ กปภ. บางเดือนใช้น้ำเกิน 50 หน่วยแล้วแพงขึ้น?',
    answer: 'ตามประกาศการจัดประเภทผู้ใช้น้ำของ กปภ. ผู้ใช้น้ำประเภทที่อยู่อาศัยประเภท 1 หากใช้เกิน 50 ลบ.ม./เดือน จะคิดอัตราเท่ากับผู้ใช้น้ำประเภท 2 ตั้งแต่หน่วยที่ 51 เป็นต้นไป',
  },
  {
    question: 'ค่าน้ำที่คำนวณได้ไม่เท่าบิลจริงเกิดจากอะไร?',
    answer: 'ความต่างมักเกิดจากการปัดเศษในระบบออกบิล รอบวันจดมาตรวัดน้ำจริงในเดือนนั้น และค่าใช้จ่ายเฉพาะพื้นที่หรือรายการอื่นที่หน่วยงานแสดงในใบแจ้งค่าน้ำ',
  },
  {
    question: 'ต้องใส่ VAT ทุกครั้งไหม?',
    answer: 'แนะนำให้เปิด VAT เพื่อดูยอดชำระรวมปลายบิล โดยค่าตั้งต้นในเครื่องมือคือ 7% และผู้ใช้สามารถปรับได้หากมีประกาศเปลี่ยนแปลงในอนาคต',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าน้ำประปา',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณค่าน้ำประปาฝายครัวเรือน ปี 2569',
  description: 'ขั้นตอนการคำนวณค่าน้ำประปาฝายครัวเรือน โดยใช้ปริมาณน้ำใช้ (ลูกบาศก์เมตร) และอัตราค่าน้ำแบบขั้นบันได',
  step: [
    {
      '@type': 'HowToStep',
      name: 'ตรวจสอบมิเตอร์น้ำ (Water Meter)',
      text: 'ดูหมายเลขมิเตอร์น้ำของคุณที่หน้าบ้าน บันทึกเลขมิเตอร์ปัจจุบัน (หน่วย: ลูกบาศก์เมตร) หรือดูจากใบแจ้งค่าน้ำงวดล่าสุด',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกการประปาและประเภทผู้ใช้น้ำ',
      text: 'ระบุว่าใช้น้ำจาก กปน. (การประปานครหลวง) หรือ กปภ. (การประปาส่วนภูมิภาค) และเลือกประเภทผู้ใช้น้ำ: ครัวเรือน หรือ พาณิชย์',
    },
    {
      '@type': 'HowToStep',
      name: 'คำนวณปริมาณน้ำใช้',
      text: 'ปริมาณน้ำใช้ = มิเตอร์ปัจจุบัน - มิเตอร์งวดที่แล้ว (หน่วย: ลูกบาศก์เมตร) ตัวอย่าง: 150 - 130 = 20 ลบ.ม.',
    },
    {
      '@type': 'HowToStep',
      name: 'ใช้อัตราค่าน้ำแบบขั้นบันได',
      text: 'ค่าน้ำฝายครัวเรือน กปน.: 0-10 ลบ.ม. = 6 บาท, 11-20 = 8 บาท, 21-30 = 10 บาท, 31+ = 12 บาท ตัวอย่าง 15 ลบ.ม.: (10 × 6) + (5 × 8) = 100 บาท',
    },
    {
      '@type': 'HowToStep',
      name: 'เพิ่มค่าบริการและภาษี VAT 7%',
      text: 'รวมค่าบำรุงท่อระบายน้ำ (5-15 บาท/เดือน) และ VAT 7% ตัวอย่าง: (100 + 10) × 1.07 = 117.70 บาท/เดือน',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าน้ำ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณค่าน้ำ 2569 จากหน่วยใช้งานจริงของบ้านคุณ</p>
      <p class="mt-1 text-sm text-slate-700">รองรับทั้ง กปน. และ กปภ. พร้อมขั้นต่ำค่าน้ำตามตารางอัตรา และ VAT</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับวางงบรายเดือนและเทียบผลก่อน-หลังประหยัดน้ำ</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าน้ำ 2569 (กปน. / กปภ. ตาราง 1-3)
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกจำนวนหน่วยน้ำที่ใช้ต่อเดือน แล้วเลือกการประปาให้ตรงกับพื้นที่ใช้งาน ระบบจะสรุปค่าใช้น้ำตามขั้นบันได
      ตรวจขั้นต่ำค่าน้ำ (สำหรับ กปภ.) และคำนวณยอดรวมก่อน/หลัง VAT เป็นเงินบาทแบบเห็นรายละเอียดทีละช่วง
    </p>

    <PublicTrustPanel
      lastUpdated="19 เม.ย. 2569"
      sources={[
        'การประปานครหลวง (กปน.): อัตราค่าน้ำและค่าบริการรายเดือน',
        'การประปาส่วนภูมิภาค (กปภ.): ตารางอัตราค่าน้ำประปา',
        'การประปาส่วนภูมิภาค (กปภ.): การจัดประเภทผู้ใช้น้ำ',
      ]}
      assumptions={[
        'ผลคำนวณเป็นการประมาณจากข้อมูลที่ผู้ใช้กรอกและตารางอัตราทางการล่าสุดที่ใช้อ้างอิง',
        'ยอดบิลจริงอาจต่างเล็กน้อยจากการปัดเศษและรอบวันจดมาตรวัดน้ำ',
      ]}
      references={[
        {
          label: 'กปน.: อัตราค่าน้ำและบริการ',
          href: 'https://www.mwa.co.th/services/users-should-know/users-service-rate/service-rate/',
        },
        {
          label: 'กปภ.: ตารางอัตราค่าน้ำประปา',
          href: 'https://www.pwa.co.th/contents/service/table-price',
        },
        {
          label: 'กปภ.: การจัดประเภทผู้ใช้น้ำ',
          href: 'https://www.pwa.co.th/contents/service/customer-type',
        },
      ]}
    />

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="water-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="provider" class="mb-1 block text-sm font-medium text-gray-700">ผู้ให้บริการน้ำประปา</label>
            <select id="provider" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="mwa_residential">กปน. (กรุงเทพฯ/นนทบุรี/สมุทรปราการ)</option>
              <option value="pwa_table_1">กปภ. ตาราง 1 (พื้นที่ร่วมลงทุนเอกชน)</option>
              <option value="pwa_table_2">กปภ. ตาราง 2 (ภูเก็ต/สมุย/พงัน)</option>
              <option value="pwa_table_3">กปภ. ตาราง 3 (พื้นที่อื่นทั่วประเทศ)</option>
            </select>
          </div>

          <div>
            <label for="units-used" class="mb-1 block text-sm font-medium text-gray-700">ปริมาณใช้น้ำ (ลบ.ม./เดือน)</label>
            <input id="units-used" type="text" inputmode="decimal" placeholder="เช่น 28" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>

          <div id="meter-size-wrap">
            <label for="meter-size" class="mb-1 block text-sm font-medium text-gray-700">ขนาดมาตรวัดน้ำ (สำหรับ กปน.)</label>
            <select id="meter-size" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="1/2">1/2 นิ้ว</option>
              <option value="3/4">3/4 นิ้ว</option>
              <option value="1">1 นิ้ว</option>
              <option value="1 1/2">1 1/2 นิ้ว</option>
              <option value="2">2 นิ้ว</option>
              <option value="3">3 นิ้ว</option>
              <option value="4">4 นิ้ว</option>
              <option value="6">6 นิ้ว</option>
              <option value="8">8 นิ้ว</option>
              <option value="12">12 นิ้ว</option>
              <option value="16">16 นิ้ว</option>
            </select>
          </div>

          <div>
            <label for="vat-rate" class="mb-1 block text-sm font-medium text-gray-700">VAT (%)</label>
            <input id="vat-rate" type="text" inputmode="decimal" value="7" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <label class="inline-flex items-center gap-2 text-sm text-gray-700">
          <input id="include-vat" type="checkbox" checked class="h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
          รวม VAT ในผลลัพธ์
        </label>

        <button
          type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          คำนวณค่าน้ำ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณค่าน้ำประปา</h2>

        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าน้ำตามขั้นบันได</div>
            <div id="res-base" class="text-xl font-bold text-sky-700">-</div>
          </div>
          <div class="rounded-lg bg-indigo-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดก่อน VAT</div>
            <div id="res-subtotal" class="text-xl font-bold text-indigo-700">-</div>
          </div>
          <div class="rounded-lg bg-emerald-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดรวมสุทธิ</div>
            <div id="res-total" class="text-xl font-bold text-emerald-700">-</div>
          </div>
        </div>

        <div class="mb-6 space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ผู้ให้บริการที่ใช้คำนวณ</span>
            <span id="res-provider" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ค่าบริการรายเดือน (กปน.)</span>
            <span id="res-service-fee" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ค่าน้ำดิบ (กปน.)</span>
            <span id="res-raw-surcharge" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ขั้นต่ำค่าน้ำ (กปภ.)</span>
            <span id="res-min-floor" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ส่วนเพิ่มจากขั้นต่ำ (กปภ.)</span>
            <span id="res-min-adjustment" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">VAT</span>
            <span id="res-vat" class="font-medium">-</span>
          </div>
        </div>

        <h3 class="mb-2 text-base font-semibold text-gray-900">แจกแจงค่าน้ำรายช่วงหน่วย</h3>
        <ul id="tier-breakdown" class="space-y-2 text-sm text-gray-700"></ul>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าน้ำตามขั้นบันได = ผลรวม(จำนวนหน่วยในแต่ละช่วง × อัตราค่าน้ำของช่วงนั้น)</li>
        <li>กรณี กปภ. ระบบตรวจขั้นต่ำ 150 บาท/เดือนตามตารางพื้นที่ และบวกส่วนต่างอัตโนมัติเมื่อค่าน้ำตามขั้นบันไดต่ำกว่าเกณฑ์</li>
        <li>กรณี กปน. บวกค่าบริการรายเดือนตามขนาดมาตรวัดน้ำ และค่าน้ำดิบ 0.15 บาท/ลบ.ม.</li>
        <li>ยอดก่อน VAT = ค่าน้ำขั้นบันได + ส่วนเพิ่มขั้นต่ำ + ค่าบริการ + ค่าน้ำดิบ</li>
        <li>ยอดรวมสุทธิ = ยอดก่อน VAT + VAT</li>
      </ul>
      <p>อ่านคำอธิบายละเอียดพร้อมตัวอย่างเป็นเงินบาทได้ที่บทความประกอบด้านล่าง</p>
    </section>

    <RelatedArticles currentHref="/คำนวณค่าน้ำ/" />
    <RelatedCalculators currentHref="/คำนวณค่าน้ำ/" />


    <!-- CAL-654 Content Block -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณค่าน้ำ</h2>
      <p><strong>ค่าน้ำรวม = ค่าน้ำบริโภค + ค่าบำรุงท่อระบายน้ำ + VAT 7%</strong></p>
      <p class="mt-2"><strong>อัตราค่าน้ำบริโภค (ระดับบ้านเรือน กปน.):</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>0–10 ลบ.ม. = 6 บาท/ลบ.ม.</li>
        <li>11–20 ลบ.ม. = 8 บาท/ลบ.ม.</li>
        <li>21–30 ลบ.ม. = 10 บาท/ลบ.ม.</li>
        <li>31+ ลบ.ม. = 12 บาท/ลบ.ม.</li>
      </ul>
      <p class="mt-2">ค่าบำรุงท่อระบาย: บ้านเรือน 5–15 บาท/เดือน | ธุรกิจขนาดเล็ก 20–40 บาท/เดือน</p>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">ตัวอย่างการคำนวณค่าน้ำ</h2>

      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่างที่ 1: ใช้น้ำ 15 ลบ.ม./เดือน (บ้านเรือน)</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>ค่าน้ำ = (10 × 6) + (5 × 8) = 60 + 40 = 100 บาท</li>
          <li>ค่าบำรุงท่อ = 10 บาท</li>
          <li>รวมก่อน VAT = 110 บาท + VAT 7% (7.70) = <strong>117.70 บาท</strong></li>
        </ul>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่างที่ 2: ใช้น้ำ 35 ลบ.ม./เดือน (บ้านเรือน)</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>ค่าน้ำ = (10×6) + (10×8) + (10×10) + (5×12) = 60+80+100+60 = 300 บาท</li>
          <li>รวมก่อน VAT = 310 บาท + VAT 7% (21.70) = <strong>331.70 บาท</strong></li>
        </ul>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่างที่ 3: ใช้น้ำ 50 ลบ.ม./เดือน (ธุรกิจขนาดเล็ก)</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>ค่าน้ำ = (10×6) + (10×8) + (10×10) + (20×12) = 60+80+100+240 = 480 บาท</li>
          <li>ค่าบำรุงท่อ (ธุรกิจ) = 35 บาท</li>
          <li>รวมก่อน VAT = 515 บาท + VAT 7% (36.05) = <strong>551.05 บาท</strong></li>
        </ul>
      </div>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">วิธีคำนวณค่าน้ำ</h2>
      <ol class="list-decimal pl-6 space-y-2 text-gray-700">
        <li>อ่านมิเตอร์น้ำ: ตรวจสอบใบแจ้งค่าน้ำหรืออ่านมิเตอร์โดยตรง</li>
        <li>คำนวณน้ำที่ใช้ = มิเตอร์ปัจจุบัน − มิเตอร์งวดที่แล้ว (หน่วย ลบ.ม.)</li>
        <li>เลือกประเภท: บ้านเรือน (กปน./กปภ.) หรือ ธุรกิจขนาดเล็ก</li>
        <li>คำนวณค่าน้ำตามขั้นบันไดของหน่วยงาน</li>
        <li>เพิ่มค่าบำรุงท่อระบายน้ำตามประเภทผู้ใช้</li>
        <li>คูณ 1.07 (VAT 7%) เพื่อได้ยอดชำระรวม</li>
        <li>เทียบกับใบแจ้งค่าน้ำจริง และบันทึกการใช้เพื่อตรวจสอบการรั่ว</li>
      </ol>

      <p class="mt-4 text-sm text-gray-600">
        <strong>แหล่งอ้างอิง:</strong>
        <a href="https://www.mwa.co.th/" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">การประปานครหลวง (กปน.): อัตราค่าน้ำปี 2569</a> [อัปเดต 2569] ·
        <a href="https://www.wpc.or.th/" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">สำนักงานคณะกรรมการน้ำ: ตารางอัตราค่าน้ำ</a> [อัปเดต 2569]
      </p>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> เครื่องมือนี้ใช้เพื่อช่วยประมาณการค่าน้ำเบื้องต้นสำหรับการวางแผนงบประมาณ
      ยอดเรียกเก็บจริงให้ยึดใบแจ้งค่าน้ำประปาจากหน่วยงานผู้ให้บริการในรอบบิลนั้นเป็นหลัก
    </div>
  </article>

  <script>
    import { calculateWaterBill, WATER_PROVIDER_LABELS } from '../../lib/water-bill-calculator';

    const form = document.getElementById('water-form');
    const formError = document.getElementById('form-error');
    const results = document.getElementById('results');

    const providerInput = document.getElementById('provider');
    const unitsInput = document.getElementById('units-used');
    const meterSizeWrap = document.getElementById('meter-size-wrap');
    const meterSizeInput = document.getElementById('meter-size');
    const vatRateInput = document.getElementById('vat-rate');
    const includeVatInput = document.getElementById('include-vat');

    const show = (el) => el?.classList.remove('hidden');
    const hide = (el) => el?.classList.add('hidden');

    const parseNumber = (value) => {
      const normalized = String(value ?? '').replace(/,/g, '').trim();
      if (!normalized) return NaN;
      const parsed = Number(normalized);
      return Number.isFinite(parsed) ? parsed : NaN;
    };

    const formatMoney = (value) => `${new Intl.NumberFormat('th-TH', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(value)} บาท`;

    const toggleMeterSize = () => {
      if (!providerInput || !meterSizeWrap) return;
      const isMwa = providerInput.value === 'mwa_residential';
      meterSizeWrap.classList.toggle('hidden', !isMwa);
    };

    providerInput?.addEventListener('change', toggleMeterSize);
    toggleMeterSize();

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      hide(formError);

      const provider = providerInput?.value;
      const unitsUsed = parseNumber(unitsInput?.value);
      const vatRate = parseNumber(vatRateInput?.value);
      const includeVat = Boolean(includeVatInput?.checked);
      const meterSize = meterSizeInput?.value;

      if (!provider || !Number.isFinite(unitsUsed) || unitsUsed < 0 || !Number.isFinite(vatRate) || vatRate < 0) {
        show(formError);
        hide(results);
        return;
      }

      const result = calculateWaterBill({
        provider,
        unitsUsed,
        meterSize,
        vatRatePercent: vatRate,
        includeVat,
      });

      document.getElementById('res-base').textContent = formatMoney(result.baseCharge);
      document.getElementById('res-subtotal').textContent = formatMoney(result.totalBeforeVat);
      document.getElementById('res-total').textContent = formatMoney(result.totalAmount);
      document.getElementById('res-provider').textContent = WATER_PROVIDER_LABELS[result.provider] || result.provider;
      document.getElementById('res-service-fee').textContent = formatMoney(result.serviceFee);
      document.getElementById('res-raw-surcharge').textContent = formatMoney(result.rawWaterSurcharge);
      document.getElementById('res-min-floor').textContent = result.minimumChargeFloor > 0 ? formatMoney(result.minimumChargeFloor) : '-';
      document.getElementById('res-min-adjustment').textContent = result.minimumChargeAdjustment > 0 ? formatMoney(result.minimumChargeAdjustment) : '-';
      document.getElementById('res-vat').textContent = includeVat
        ? `${formatMoney(result.vatAmount)} (${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(vatRate)}%)`
        : 'ไม่รวม VAT';

      const tierBreakdown = document.getElementById('tier-breakdown');
      if (tierBreakdown) {
        tierBreakdown.innerHTML = '';
        result.tierBreakdown.forEach((tier) => {
          const li = document.createElement('li');
          li.className = 'rounded-md border border-gray-100 bg-gray-50 px-3 py-2';
          li.textContent = `${tier.label}: ${new Intl.NumberFormat('th-TH', { maximumFractionDigits: 2 }).format(tier.units)} หน่วย × ${formatMoney(tier.rate)} = ${formatMoney(tier.amount)}`;
          tierBreakdown.appendChild(li);
        });
      }

      show(results);
      results.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('water_bill');
      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('water_bill', result.totalAmount);
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('water_bill');
      if (typeof trackResultViewed === 'function') trackResultViewed('water_bill');
    });
  </script>
</BaseLayout>
