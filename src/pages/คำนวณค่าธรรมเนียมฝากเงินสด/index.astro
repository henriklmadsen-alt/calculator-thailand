---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณค่าธรรมเนียมฝากเงินสด 2569 | ฝากเงินสดต่างสาขา | Kamnuanlek';
const pageDescription = 'คำนวณค่าธรรมเนียมฝากเงินสดผ่านเคาน์เตอร์ธนาคาร ต่างสาขา ต่างธนาคาร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าธรรมเนียมฝากเงินสด/`;

const faqData = [
  {
    question: 'ฝากเงินสดต่างสาขาธนาคารเดียวกันมีค่าธรรมเนียมไหม?',
    answer: 'ขึ้นอยู่กับธนาคาร บางธนาคารไม่เก็บค่าธรรมเนียมสำหรับการฝากต่างสาขาธนาคารเดียวกัน แต่บางธนาคารเก็บประมาณ 20-25 บาทต่อครั้ง ควรตรวจสอบกับธนาคารของคุณโดยตรง',
  },
  {
    question: 'ฝากเงินต่างธนาคารทำได้ไหม และมีค่าธรรมเนียมเท่าไร?',
    answer: 'การฝากเงินสดเข้าบัญชีต่างธนาคารสามารถทำได้ที่เคาน์เตอร์ธนาคาร โดยมีค่าธรรมเนียมประมาณ 30-50 บาทต่อครั้ง หรืออาจสูงกว่าขึ้นอยู่กับธนาคาร แต่ทางเลือกที่ถูกกว่าคือโอนผ่านพร้อมเพย์แทน',
  },
  {
    question: 'วิธีประหยัดค่าธรรมเนียมฝากเงินสดทำอย่างไร?',
    answer: 'ฝากที่สาขาหรือตู้ฝากเงิน (Cash Deposit Machine) ของธนาคารเดียวกันเพื่อฟรีค่าธรรมเนียม หรือใช้ตู้ CDM (Cash Deposit Machine) ซึ่งบางธนาคารไม่มีค่าธรรมเนียม หากต้องโอนให้คนอื่นอีกธนาคาร ให้ฝากในธนาคารเดียวกันก่อนแล้วค่อยโอนผ่านพร้อมเพย์',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียมฝากเงินสด',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าธรรมเนียมฝากเงินสด">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณค่าธรรมเนียมฝากเงินสด 2569</h1>
    <p class="mb-6 text-gray-600">คำนวณค่าธรรมเนียมฝากเงินสดผ่านเคาน์เตอร์ธนาคาร ทุกประเภทสาขา</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc-form" class="space-y-4">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label for="same-branch-count" class="mb-1 block text-sm font-medium text-gray-700">ฝากสาขาเดียวกัน (ครั้ง/เดือน)</label>
            <input id="same-branch-count" type="text" inputmode="numeric" placeholder="0" value="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">ฟรี</p>
          </div>
          <div>
            <label for="diff-branch-count" class="mb-1 block text-sm font-medium text-gray-700">ต่างสาขาธนาคารเดียวกัน (ครั้ง/เดือน)</label>
            <input id="diff-branch-count" type="text" inputmode="numeric" placeholder="0" value="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="diff-branch-fee" class="mb-1 block text-sm font-medium text-gray-700">ค่าธรรมเนียมต่างสาขา (บาท/ครั้ง)</label>
            <input id="diff-branch-fee" type="text" inputmode="numeric" value="20"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="diff-bank-count" class="mb-1 block text-sm font-medium text-gray-700">ต่างธนาคาร (ครั้ง/เดือน)</label>
            <input id="diff-bank-count" type="text" inputmode="numeric" placeholder="0" value="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="diff-bank-fee" class="mb-1 block text-sm font-medium text-gray-700">ค่าธรรมเนียมต่างธนาคาร (บาท/ครั้ง)</label>
            <input id="diff-bank-fee" type="text" inputmode="numeric" value="40"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ค่าธรรมเนียมฝากเงินสดรวม</h2>
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รวม/เดือน</div>
            <div id="res-monthly" class="text-3xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รวม/ปี</div>
            <div id="res-yearly" class="text-3xl font-bold text-orange-700">-</div>
          </div>
        </div>
        <div id="res-breakdown" class="mt-4 space-y-1 text-sm text-gray-700"></div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณค่าธรรมเนียมฝากเงินสด/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('calc-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const diffBranchCount = parseNum((document.getElementById('diff-branch-count') as HTMLInputElement).value);
    const diffBranchFee = parseNum((document.getElementById('diff-branch-fee') as HTMLInputElement).value);
    const diffBankCount = parseNum((document.getElementById('diff-bank-count') as HTMLInputElement).value);
    const diffBankFee = parseNum((document.getElementById('diff-bank-fee') as HTMLInputElement).value);

    const diffBranchTotal = diffBranchCount * diffBranchFee;
    const diffBankTotal = diffBankCount * diffBankFee;
    const monthly = diffBranchTotal + diffBankTotal;

    const lines = [];
    if (diffBranchCount > 0) lines.push(`• ต่างสาขาธนาคารเดียวกัน ${diffBranchCount} ครั้ง × ${fmt(diffBranchFee)}: ${fmt(diffBranchTotal)}`);
    if (diffBankCount > 0) lines.push(`• ต่างธนาคาร ${diffBankCount} ครั้ง × ${fmt(diffBankFee)}: ${fmt(diffBankTotal)}`);

    document.getElementById('res-monthly')!.textContent = fmt(monthly);
    document.getElementById('res-yearly')!.textContent = fmt(monthly * 12);
    document.getElementById('res-breakdown')!.innerHTML = lines.join('<br/>') || 'ไม่มีค่าธรรมเนียม';
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
