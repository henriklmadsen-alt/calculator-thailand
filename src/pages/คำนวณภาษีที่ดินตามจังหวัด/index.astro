---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณภาษีที่ดินตามจังหวัด 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณภาษีที่ดินตามจังหวัด 2569 ฟรี — ระบุจังหวัด ประเภทที่ดิน มูลค่า รู้ว่าต้องจ่ายภาษีรายปีเท่าไร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีที่ดินตามจังหวัด/`;

const provinces = [
  'โปรดเลือกจังหวัด',
  'กรุงเทพมหานคร',
  'สมุทรปราการ',
  'สมุทรสาคร',
  'สมุทรสงคราม',
  'นครศรีธรรมราช',
  'กระบี่',
  'ภูเก็ต',
  'สุราษฎร์ธานี',
  'นครปฐม',
  'ราชบุรี',
  'เพชรบุรี',
  'หัวหินประจวบคีรีขันธ์',
  'ชลบุรี',
  'ระยอง',
  'จันทบุรี',
  'ตราด',
  'อยุธยา',
  'ลพบุรี',
  'สิงห์บุรี',
  'สระบุรี',
  'นครสวรรค์',
  'พิษณุโลก',
  'พิจิตร',
  'เพชรบูรณ์',
  'ตาก',
  'กำแพงเพชร',
  'ลำปาง',
  'ลำพูน',
  'แม่ฮ่องสอน',
  'เชียงใหม่',
  'เชียงราย',
  'ปะการัง',
  'ประสิทธิ์',
  'ร้อยเอ็ด',
  'มหาสารคาม',
  'ศรีสะเกษ',
  'อุบลราชธานี',
  'ยโสธร',
  'ชัยภูมิ',
  'นครราชสีมา',
  'บึงกาฬ',
  'อำนาจเจริญ',
  'สกลนคร',
  'นครพนม',
  'มุกดาหาร',
  'เลย',
  'หนองคาย',
  'ขอนแก่น',
  'สุรินทร์',
  'ศรีอำนัย',
  'นครแนวนคร',
  'อุตรดิตถ์',
  'อุทัยธานี',
  'สพรรณบุรี',
  'กาฬสินธุ์',
  'นราธิวาส',
  'ปัตตานี',
  'ยะลา',
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณภาษีที่ดินตามจังหวัด',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีที่ดินตามจังหวัด">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณภาษีที่ดินตามจังหวัด ปี 2569</h1>
    <p class="text-gray-600 mb-6">คำนวณภาษีประจำปีสำหรับที่ดิน โดยพิจารณาจากจังหวัด พื้นที่ใช้สอย และประเภทการใช้ประโยชน์</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="property-tax-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="province" class="block text-sm font-medium text-gray-700 mb-1">จังหวัด</label>
            <select id="province" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              {provinces.map((prov) => (
                <option value={prov}>{prov}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="land-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทที่ดิน</label>
            <select id="land-type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="residential">ที่อยู่อาศัย</option>
              <option value="agricultural">เกษตร</option>
              <option value="commercial">พาณิชย์</option>
              <option value="industrial">อุตสาหกรรม</option>
              <option value="vacant">ว่าง</option>
            </select>
          </div>
        </div>

        <div>
          <label for="land-area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่ (ตร.ว.)</label>
          <input id="land-area" type="text" inputmode="numeric" placeholder="เช่น 100" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณภาษี
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="rounded-lg bg-primary-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ภาษีประจำปี</div>
          <div id="res-tax-amount" class="text-2xl font-bold text-primary-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">จังหวัด</span>
            <span id="res-province" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ประเภทที่ดิน</span>
            <span id="res-land-type" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">พื้นที่ที่ดิน</span>
            <span id="res-area" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">อัตราภาษี/ตร.ว.</span>
            <span id="res-rate" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">ภาษีประจำปี</span>
            <span id="res-calc-tax" class="font-bold text-lg text-primary-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <RelatedCalculators currentHref="/คำนวณภาษีที่ดินตามจังหวัด/" />
  </article>
</BaseLayout>

<script>
  // Sample tax rates by province and land type (บาท/ตร.ว. ต่อปี)
  // ข้อมูลตัวอย่าง ควรตรวจสอบกับกรมธรรมชาติที่เป็นปัจจุบัน
  const taxRates = {
    'กรุงเทพมหานคร': { residential: 25, agricultural: 5, commercial: 50, industrial: 30, vacant: 10 },
    'สมุทรปราการ': { residential: 20, agricultural: 4, commercial: 40, industrial: 25, vacant: 8 },
    'ชลบุรี': { residential: 18, agricultural: 3.5, commercial: 35, industrial: 22, vacant: 7 },
  };

  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  function getDefaultRate(landType) {
    const rates = { residential: 15, agricultural: 2.5, commercial: 25, industrial: 15, vacant: 5 };
    return rates[landType] || 15;
  }

  const form = document.querySelector('#property-tax-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const province = document.querySelector('#province')?.value || '';
    const landType = document.querySelector('#land-type')?.value || 'residential';
    const landArea = parseNumber(document.querySelector('#land-area')?.value || '');

    if (!province || province === 'โปรดเลือกจังหวัด' || !(Number.isFinite(landArea) && landArea > 0)) {
      results?.classList.add('hidden');
      return;
    }

    const provinceData = taxRates[province];
    let taxRate = getDefaultRate(landType);
    if (provinceData) {
      taxRate = provinceData[landType] || getDefaultRate(landType);
    }

    const taxAmount = landArea * taxRate;

    document.querySelector('#res-tax-amount').textContent = formatCurrency(taxAmount);
    document.querySelector('#res-province').textContent = province;
    document.querySelector('#res-land-type').textContent = document.querySelector('#land-type').options[document.querySelector('#land-type').selectedIndex].text;
    document.querySelector('#res-area').textContent = `${landArea.toFixed(2)} ตร.ว.`;
    document.querySelector('#res-rate').textContent = `${taxRate.toFixed(2)} บาท`;
    document.querySelector('#res-calc-tax').textContent = formatCurrency(taxAmount);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
