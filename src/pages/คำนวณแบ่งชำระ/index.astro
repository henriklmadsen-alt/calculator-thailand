---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณแบ่งชำระ ปี 2569 — Split Payment Calculator | Kamnuanlek';
const pageDescription = 'คำนวณยอดแบ่งชำระเท่าๆ กัน หรือแบ่งตามสัดส่วน เหมาะสำหรับการแบ่งชำระค่าสินค้าระหว่างหลายคน หรือแบ่งจ่ายหลายงวด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณแบ่งชำระ/`;

const faqData = [
  {
    question: 'แบ่งชำระแบบเท่ากันคำนวณอย่างไร?',
    answer: 'ยอดต่อคน/งวด = ยอดรวม ÷ จำนวนคน/งวด หากมีเศษให้บวกไปงวดสุดท้ายหรือคนสุดท้าย',
  },
  {
    question: 'แบ่งชำระตามสัดส่วนคำนวณอย่างไร?',
    answer: 'ยอดของแต่ละคน = ยอดรวม × (สัดส่วนของคนนั้น ÷ ผลรวมสัดส่วนทั้งหมด) ใช้เมื่อแต่ละคนรับผิดชอบไม่เท่ากัน',
  },
  {
    question: 'ถ้ามีเศษสตางค์ทำอย่างไร?',
    answer: 'เศษสตางค์มักบวกให้คนสุดท้ายหรืองวดสุดท้าย หรือปัดขึ้น/ลงตามข้อตกลง บางครั้งใช้วิธีปัดงวดแรกขึ้น แล้วงวดที่เหลือปัดลง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณแบ่งชำระ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณแบ่งชำระ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-teal-100 bg-teal-50 p-4">
      <p class="text-sm font-semibold text-teal-700">คำนวณแบ่งชำระ — Split Payment</p>
      <p class="mt-1 text-sm text-slate-700">แบ่งเท่าๆ กัน หรือตามสัดส่วน สำหรับหลายคนหรือหลายงวด</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณแบ่งชำระ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนยอดรวมและจำนวนคน/งวด เพื่อคำนวณยอดแบ่งชำระ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="sp-form" class="space-y-5">
        <p id="sp-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="sp-total" class="mb-1 block text-sm font-medium text-gray-700">ยอดรวม (บาท)</label>
            <input type="text" id="sp-total" inputmode="numeric" placeholder="เช่น 10,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="sp-total-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="sp-parts" class="mb-1 block text-sm font-medium text-gray-700">จำนวนคน / งวด</label>
            <input type="number" id="sp-parts" min="2" max="100" placeholder="เช่น 3"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="sp-parts-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div>
          <label for="sp-fee" class="mb-1 block text-sm font-medium text-gray-700">ค่าธรรมเนียมรวม (บาท) — ไม่บังคับ</label>
          <input type="text" id="sp-fee" inputmode="numeric" placeholder="เช่น 150 (ค่าบริการร้านอาหาร)"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณแบ่งชำระ
        </button>
      </form>
    </div>

    <div id="sp-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการแบ่งชำระ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-teal-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดต่อคน/งวด</div>
            <div id="res-sp-each" class="text-2xl font-bold text-teal-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดรวม+ค่าธรรมเนียม</div>
            <div id="res-sp-grand" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">คนสุดท้าย (มีเศษ)</div>
            <div id="res-sp-last" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ยอดรวม = ยอดสินค้า + ค่าธรรมเนียม</li>
        <li>ยอดต่อคน (ปัดลง) = floor(ยอดรวม ÷ จำนวนคน × 100) ÷ 100</li>
        <li>คนสุดท้าย = ยอดรวม − (ยอดต่อคน × (จำนวนคน − 1))</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณค่าใช้จ่ายร่วม/">คำนวณค่าใช้จ่ายร่วม</a></li>
        <li><a href="/คำนวณปฏิทินชำระรายเดือน/">คำนวณปฏิทินชำระรายเดือน</a></li>
        <li><a href="/คำนวณวันครบกำหนด-invoice/">คำนวณวันครบกำหนด Invoice</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#sp-results" />
    <RelatedArticles currentHref="/คำนวณแบ่งชำระ/" />
    <RelatedCalculators currentHref="/คำนวณแบ่งชำระ/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('sp-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      ['sp-total-error','sp-parts-error'].forEach(id => setErr(id, ''));

      const total = parseNum(document.getElementById('sp-total').value);
      const parts = parseInt(document.getElementById('sp-parts').value);
      const fee = parseNum(document.getElementById('sp-fee').value) || 0;

      let hasError = false;
      if (!Number.isFinite(total) || total <= 0) { setErr('sp-total-error', 'กรอกยอดรวมมากกว่า 0'); hasError = true; }
      if (!parts || parts < 2) { setErr('sp-parts-error', 'กรอกจำนวนคน/งวดอย่างน้อย 2'); hasError = true; }
      if (hasError) { document.getElementById('sp-error').classList.remove('hidden'); document.getElementById('sp-results').classList.add('hidden'); return; }
      document.getElementById('sp-error').classList.add('hidden');

      const grand = total + fee;
      const eachRaw = grand / parts;
      const eachFloor = Math.floor(eachRaw * 100) / 100;
      const lastPerson = grand - eachFloor * (parts - 1);

      setText('res-sp-each', fmt(eachFloor));
      setText('res-sp-grand', fmt(grand));
      setText('res-sp-last', fmt(lastPerson));

      document.getElementById('sp-results').classList.remove('hidden');
      document.getElementById('sp-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
