---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import AffiliateCard from '../../components/templates/AffiliateCard.astro';
import ResultCardHub from '../../components/templates/ResultCardHub.astro';
import TransparencyPanel from '../../components/templates/TransparencyPanel.astro';

const pageTitle = 'คำนวณต้นทุนสีและอุปกรณ์จิตรกรรม 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนสีและอุปกรณ์จิตรกรรม แจงรายการต้นทุนแต่ละชิ้น รู้ราคาขายที่เหมาะสมสำหรับผลงานศิลปะของคุณฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุน-สีและอุปกรณ์จิตรกรรม/`;

const faqData = [
  {
    question: 'ต้นทุนอุปกรณ์จิตรกรรมประกอบด้วยอะไรบ้าง?',
    answer: 'ต้นทุนอุปกรณ์จิตรกรรมประกอบด้วย: (1) ผ้าใบหรือกระดาษขนาดต่างๆ (2) สีน้ำมัน สีอะคริลิก หรือสีอื่น (3) แปรงหลายขนาด (4) จานผสมสี (5) น้ำมันเอก หรือทำลายสี (6) วาร์นิช เพื่อปกป้องผลงาน (7) อื่นๆ เช่น ลวดเสริมผ้าใบ กรรม เกาะ และผ้าใบพิเศษ',
  },
  {
    question: 'จะลดต้นทุนอุปกรณ์จิตรกรรมไปได้อย่างไร?',
    answer: 'วิธีลดต้นทุน: (1) ซื้อชุดสีเต็มแบบเป็นชุด แทนซื้อเป็นตัว (2) เลือกสีแบรนด์ไทย หรือแบรนด์เบาะบางแทนสีนำเข้า (3) ใช้ผ้าใบคุณภาพประหยัด สำหรับฝึกหัด (4) ต่อลวดเสริมผ้าใบเอง (5) ขอแสดงความคิดเห็นจากศิลปินอื่นหรือเมนเทอร์',
  },
  {
    question: 'ควรตั้งราคาขายผลงานศิลปะอย่างไร?',
    answer: 'การตั้งราคาสำหรับศิลปะใจควรพิจารณา: (1) ต้นทุนวัสดุทั้งหมด (2) ค่าแรง/เวลาในการวาด (3) ค่าใช้จ่ายอื่น เช่น ค่าแสดงงาน (4) ความยากของผลงาน (5) ชื่อเสียงของศิลปิน (6) ตลาดที่เป้าหมาย (7) ผลงานเปรียบเทียบของศิลปินอื่น หนึ่งในวิธีทั่วไป คือตั้งราคาเป็น 3-5 เท่าของต้นทุนวัสดุ',
  },
  {
    question: 'อุปกรณ์จิตรกรรมใช้นานเท่าไร?',
    answer: 'อายุการใช้อุปกรณ์จิตรกรรมแตกต่างกันไป: (1) สีน้ำมันและอะคริลิก: ใช้ได้เพียงครั้งละเล็กน้อย เอา 1-2 ปี (2) แปรง: ขึ้นอยู่กับการเก็บรักษา 1-3 ปี (3) ผ้าใบ: เก็บรักษาได้นาน หากจัดเก็บปลอดภัยหลายปี (4) วาร์นิช: ใช้นาน 3-5 ปีหากเก็บรักษาเป็น (5) น้ำมันเอก: 5 ปี หรือนานกว่า',
  },
  {
    question: 'ความแตกต่างระหว่างสีน้ำมัน สีอะคริลิก และสีน้ำคืออะไร?',
    answer: 'สีทั้งสามมีความแตกต่าง: (1) สีน้ำมัน: เงาว สีต่อสี ช้า แต่ผลงานเก่าวัน ใช้เกาะที่เจาะหรือสารละลาย (2) สีอะคริลิก: แห้งเร็ว ล้างน้ำได้ คงสีน้อยลง (3) สีน้ำ: แห้งเร็ว เบา แต่ยากต่อการแก้ไข ลดพื้นที่ใช้ได้เฉพาะบางชนิด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนสีและอุปกรณ์จิตรกรรม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณต้นทุนสีและอุปกรณ์จิตรกรรม',
  description: 'ขั้นตอนการคำนวณต้นทุนอุปกรณ์จิตรกรรมทั้งหมด และการตั้งราคาขายผลงานศิลปะ',
  step: [
    {
      '@type': 'HowToStep',
      name: 'รวบรวมรายการอุปกรณ์จิตรกรรมของคุณ',
      text: 'สร้างรายการอุปกรณ์ทั้งหมดที่คุณใช้ ได้แก่ ผ้าใบ สี แปรง จานผสม น้ำมันเอก วาร์นิช และอื่นๆ',
    },
    {
      '@type': 'HowToStep',
      name: 'บันทึกราคาต้นทุนของแต่ละรายการ',
      text: 'ค้นหาราคาต้นทุนของแต่ละสิ่งของจากใบเสร็จ หรือจากที่ซื้อ บันทึกราคาเป็นบาท',
    },
    {
      '@type': 'HowToStep',
      name: 'ป้อนข้อมูลลงในเครื่องคำนวณ',
      text: 'กรอกต้นทุนของอุปกรณ์แต่ละชนิดลงในช่องที่เกี่ยวข้อง และระบุพื้นที่ตารางเมตร (ถ้าจำเป็น)',
    },
    {
      '@type': 'HowToStep',
      name: 'ดูผลลัพธ์ต้นทุนรวม',
      text: 'เครื่องคำนวณจะแสดงต้นทุนรวม ต้นทุนต่อตารางเมตร และมูลค่าขายแนะนำ',
    },
    {
      '@type': 'HowToStep',
      name: 'ตั้งราคาขายผลงาน',
      text: 'ใช้ราคาขายแนะนำเป็นฐาน ปรับเพิ่มตามชื่อเสียง ความยากขององค์ประกอบ และตลาดเป้าหมาย',
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  pageName="คำนวณต้นทุนสีและอุปกรณ์จิตรกรรม"
  categoryId="hobby"
  categoryName="งานอดิเรก"
  categorySlug="งานอดิเรก"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <style>
    @keyframes slideInResult {
      0% {
        opacity: 0;
        transform: translateY(16px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .result-animate-in {
      animation: slideInResult 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
  </style>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-4">คำนวณต้นทุนสีและอุปกรณ์จิตรกรรม</h1>

    <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนผ้าใบ (บาท)</label>
          <input type="number" id="canvas" placeholder="500" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนชุดสี (บาท)</label>
          <input type="number" id="paint" placeholder="800" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนแปรง (บาท)</label>
          <input type="number" id="brushes" placeholder="400" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนจานผสมและอื่นๆ (บาท)</label>
          <input type="number" id="palette" placeholder="200" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนตัวทำละลาย (บาท)</label>
          <input type="number" id="solvents" placeholder="300" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนวาร์นิช/ตัวเคลือบ (บาท)</label>
          <input type="number" id="varnish" placeholder="250" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">ต้นทุนอื่นๆ (บาท)</label>
          <input type="number" id="other" placeholder="150" class="w-full border rounded px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">พื้นที่ภาพ (ตร.ม.)</label>
          <input type="number" id="area" placeholder="0.5" step="0.1" class="w-full border rounded px-3 py-2" />
        </div>
      </div>
      <button class="mt-6 w-full bg-blue-600 text-white py-2 rounded font-bold hover:bg-blue-700">
        คำนวณ
      </button>
    </div>

    <div id="result" class="hidden result-animate-in bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg shadow-lg p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">ผลลัพธ์</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ต้นทุนรวม</p>
          <p class="text-3xl font-bold text-blue-600" id="totalCost">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ต้นทุนต่อตร.ม.</p>
          <p class="text-3xl font-bold text-blue-600" id="costPerSqm">0</p>
          <p class="text-xs text-gray-500">บาท/ตร.ม.</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">ราคาขายแนะนำ</p>
          <p class="text-3xl font-bold text-green-600" id="suggestedPrice">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
        <div class="bg-white rounded p-4">
          <p class="text-sm text-gray-600">กำไรโดยประมาณ</p>
          <p class="text-3xl font-bold text-green-600" id="profit">0</p>
          <p class="text-xs text-gray-500">บาท</p>
        </div>
      </div>
      <div class="mt-4 bg-white rounded p-4">
        <h3 class="font-bold mb-2">รายละเอียดต้นทุน</h3>
        <div id="breakdown" class="space-y-1 text-sm"></div>
      </div>
    </div>

    <TransparencyPanel
      dataOrigin="การคำนวณจากข้อมูลต้นทุนของอุปกรณ์จิตรกรรมที่ผู้ใช้ป้อนเข้า"
      lastUpdated="2026-04-22"
      accuracy="ความแม่นยำขึ้นอยู่กับข้อมูลต้นทุนที่ป้อนเข้า"
    />

    <div class="my-12">
      <h2 class="text-2xl font-bold mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="border rounded p-4 cursor-pointer hover:bg-gray-50">
            <summary class="font-bold text-lg">{faq.question}</summary>
            <p class="mt-2 text-gray-700">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <GuardedAdSlot adUnitId="painting-supplies-calculator" position="bottom" />

    <RelatedCalculators />
    <RelatedArticles />
  </div>

  <script is:inline>
    // Import the calculator logic
    import { calculatePaintingSupplies } from '../../lib/painting-art-supplies-cost-calculator';

    function calculate() {
      const inputs = {
        canvasCost: parseFloat(document.getElementById('canvas').value) || 0,
        paintSetCost: parseFloat(document.getElementById('paint').value) || 0,
        brushesSetCost: parseFloat(document.getElementById('brushes').value) || 0,
        paletteAndMixingCost: parseFloat(document.getElementById('palette').value) || 0,
        solventsCost: parseFloat(document.getElementById('solvents').value) || 0,
        varnishFixativeCost: parseFloat(document.getElementById('varnish').value) || 0,
        otherSuppliesCost: parseFloat(document.getElementById('other').value) || 0,
        paintingAreaSqMeter: parseFloat(document.getElementById('area').value) || 1,
      };

      const result = calculatePaintingSupplies(inputs);

      document.getElementById('result').classList.remove('hidden');
      document.getElementById('totalCost').textContent = result.totalCost.toLocaleString('th-TH');
      document.getElementById('costPerSqm').textContent = result.costPerSqMeter.toLocaleString('th-TH');
      document.getElementById('suggestedPrice').textContent = result.suggestedSellingPrice.toLocaleString('th-TH');
      document.getElementById('profit').textContent = result.profitPerPainting.toLocaleString('th-TH');

      const breakdown = document.getElementById('breakdown');
      breakdown.innerHTML = `
        <div class="flex justify-between"><span>ผ้าใบ:</span><strong>${result.costBreakdown.canvas.toLocaleString('th-TH')}</strong></div>
        <div class="flex justify-between"><span>สี:</span><strong>${result.costBreakdown.paint.toLocaleString('th-TH')}</strong></div>
        <div class="flex justify-between"><span>แปรง:</span><strong>${result.costBreakdown.brushes.toLocaleString('th-TH')}</strong></div>
        <div class="flex justify-between"><span>จานผสม:</span><strong>${result.costBreakdown.palette.toLocaleString('th-TH')}</strong></div>
        <div class="flex justify-between"><span>ตัวทำละลาย:</span><strong>${result.costBreakdown.solvents.toLocaleString('th-TH')}</strong></div>
        <div class="flex justify-between"><span>วาร์นิช:</span><strong>${result.costBreakdown.varnish.toLocaleString('th-TH')}</strong></div>
        <div class="flex justify-between"><span>อื่นๆ:</span><strong>${result.costBreakdown.other.toLocaleString('th-TH')}</strong></div>
      `;
    }

    // Calculate on button click
    document.querySelector('button').addEventListener('click', calculate);

    // Calculate on Enter key
    document.querySelectorAll('input').forEach(input => {
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') calculate();
      });
    });

    // Auto-calculate with example data
    window.addEventListener('load', () => {
      document.getElementById('canvas').value = '500';
      document.getElementById('paint').value = '800';
      document.getElementById('brushes').value = '400';
      document.getElementById('palette').value = '200';
      document.getElementById('solvents').value = '300';
      document.getElementById('varnish').value = '250';
      document.getElementById('other').value = '150';
      document.getElementById('area').value = '0.5';
      calculate();
    });
  </script>
</BaseLayout>
