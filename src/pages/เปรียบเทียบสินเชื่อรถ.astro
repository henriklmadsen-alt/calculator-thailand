---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout noGenericHowTo={true} title="เปรียบเทียบสินเชื่อรถยนต์ 2569 — อัตราดอกเบี้ยทุกธนาคาร | Kamnuanlek"
  description="เปรียบเทียบอัตราดอกเบี้ยสินเชื่อรถยนต์ 2569 กรุงศรี กสิกร SCB TTB พร้อมตัวอย่างจริง Honda City 400,000 บาท และเทคนิคขอสินเชื่อให้ได้อัตราดีสุด"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เปรียบเทียบสินเชื่อรถยนต์ 2569", "item": "https://www.kamnuanlek.com/เปรียบเทียบสินเชื่อรถ/"}
    ]
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "วิธีเปรียบเทียบสินเชื่อรถยนต์ให้ได้อัตราดีสุด",
    "description": "4 ขั้นตอนเปรียบเทียบสินเชื่อรถยนต์และขอสินเชื่อให้ได้อัตราดอกเบี้ยต่ำสุด",
    "step": [
      {"@type": "HowToStep", "position": 1, "name": "ขอใบเสนอราคาจาก 2–3 ธนาคาร", "text": "อัตราดอกเบี้ยสินเชื่อรถต่างกัน 0.5–1.5% ต่อปีระหว่างธนาคาร ขอใบเสนอราคาหลายแห่งใช้เวลา 5 นาที แต่ประหยัดได้หลายหมื่นบาท"},
      {"@type": "HowToStep", "position": 2, "name": "ตรวจสอบเครดิตสกอร์ก่อนสมัคร", "text": "เครดิตสกอร์ 700+ จะได้อัตราดอกเบี้ยต่ำกว่า ตรวจสอบเครดิตบูโรก่อนสมัคร และแก้ไขข้อผิดพลาดหากมี"},
      {"@type": "HowToStep", "position": 3, "name": "วางดาวน์ให้สูงขึ้น", "text": "ดาวน์ 25–30% ขึ้นไปช่วยลดอัตราดอกเบี้ยได้ 0.5–1% เพราะธนาคารมีความเสี่ยงน้อยลง"},
      {"@type": "HowToStep", "position": 4, "name": "เลือกระยะเวลาที่เหมาะสม", "text": "ผ่อน 60 เดือน (5 ปี) มักสมดุลดีสุด ผ่อน 84 เดือนจ่ายดอกเบี้ยเพิ่มขึ้น 30–40% แต่ค่างวดลงเพียง 25–30%"}
    ]
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "อัตราดอกเบี้ยสินเชื่อรถยนต์ธนาคารไทย 2569 เท่าไร?",
        "acceptedAnswer": {"@type": "Answer", "text": "อัตรา Flat Rate ปี 2569: TTB 2.00–3.25%, กสิกรไทย/SCB 2.25–3.50%, กรุงศรี 2.99–3.99% อัตราจริงขึ้นอยู่กับเครดิตสกอร์และดาวน์เพมเม้นต์"}
      },
      {
        "@type": "Question",
        "name": "ดอกเบี้ย 1% ต่างกัน ประหยัดได้เท่าไร?",
        "acceptedAnswer": {"@type": "Answer", "text": "สินเชื่อ 400,000 บาท 60 เดือน ดอกเบี้ยต่างกัน 1% ประหยัดได้ประมาณ 20,000–24,000 บาทตลอดสัญญา หรือประมาณ 400 บาทต่อเดือน"}
      },
      {
        "@type": "Question",
        "name": "ผ่อน 60 เดือน กับ 84 เดือน อันไหนดีกว่า?",
        "acceptedAnswer": {"@type": "Answer", "text": "60 เดือนดีกว่าในแง่ดอกเบี้ยรวม 84 เดือนจ่ายดอกเบี้ยเพิ่มขึ้น 30–40% แต่ค่างวดลงเพียง 25–30% เลือก 84 เดือนเฉพาะเมื่อค่างวด 60 เดือนเกินกว่า 30% ของรายได้"}
      }
    ]
  }</script>

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เปรียบเทียบสินเชื่อรถยนต์ 2569</h1>
    <p class="text-lg text-gray-600 mb-2">อัตราดอกเบี้ยทุกธนาคาร พร้อมตัวอย่างจริงและเทคนิคขอสินเชื่อให้ได้ดีล</p>
    <p class="text-sm text-gray-400 mb-8">อัปเดตล่าสุด: 2569 · อัตราอ้างอิงจากธนาคารแห่งประเทศไทย</p>

    <div class="mb-10 p-6 bg-blue-50 border border-blue-200 rounded-lg">
      <p class="text-gray-800">
        ซื้อรถด้วยการผ่อนชำระเป็นเรื่องปกติสำหรับคนไทย แต่อัตราดอกเบี้ยต่างกันหลายอย่างระหว่างธนาคาร เลือกอัตราที่ดีขึ้นแค่ 0.5% แต่ประหยัดค่างวดได้หลายพันบาทตลอดสัญญา
      </p>
    </div>

    <div class="space-y-12">

      <!-- Bank Rate Table -->
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">อัตราดอกเบี้ยสินเชื่อรถยนต์ธนาคารไทย 2569</h2>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ธนาคาร</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">อัตราดอกเบี้ย (Flat Rate)</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ระยะเวลาสูงสุด</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900 hidden sm:table-cell">หมายเหตุ</th>
              </tr>
            </thead>
            <tbody>
              {[
                { bank: 'TTB (ทีทีบี)', rate: '2.00–3.25%', term: '84 เดือน', note: 'อัตราต่ำสุดในตลาด', best: true },
                { bank: 'กสิกรไทย (KBank)', rate: '2.25–3.50%', term: '84 เดือน', note: 'สาขาครอบคลุมทั่วประเทศ', best: false },
                { bank: 'ไทยพาณิชย์ (SCB)', rate: '2.25–3.50%', term: '84 เดือน', note: 'แอปดีสุด จัดการออนไลน์ง่าย', best: false },
                { bank: 'กรุงศรี (Krungsri)', rate: '2.99–3.99%', term: '84 เดือน', note: 'อนุมัติเร็ว เงื่อนไขยืดหยุ่น', best: false },
              ].map((row, i) => (
                <tr class={`border-t ${i % 2 === 1 ? 'bg-gray-50' : ''} ${row.best ? 'bg-green-50' : ''}`}>
                  <td class="px-4 py-3 font-semibold text-gray-900">
                    {row.bank}
                    {row.best && <span class="ml-2 text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded-full">อัตราต่ำสุด</span>}
                  </td>
                  <td class="px-4 py-3 font-mono text-gray-900">{row.rate}</td>
                  <td class="px-4 py-3 text-gray-700">{row.term}</td>
                  <td class="px-4 py-3 text-gray-600 hidden sm:table-cell">{row.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-500 mt-2">* อัตราขึ้นอยู่กับเครดิตสกอร์ ดาวน์เพมเม้นต์ และประเภทรถ อัตราจริงจะทราบเมื่อสมัครกับธนาคาร</p>
      </section>

      <!-- Worked Example -->
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">ตัวอย่างจริง: Honda City 500,000 บาท</h2>
        <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg mb-4 text-sm text-gray-700">
          <strong>เงื่อนไข:</strong> ราคารถ 500,000 บาท · ดาวน์ 20% (100,000 บาท) · กู้ 400,000 บาท · ระยะเวลา 60 เดือน
        </div>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">อัตราดอกเบี้ย</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ค่างวด/เดือน</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ดอกเบี้ยรวม</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900 hidden sm:table-cell">ประหยัดจากอัตราสูงสุด</th>
              </tr>
            </thead>
            <tbody>
              {[
                { rate: '2.00% (TTB)', monthly: '7,333 บาท', interest: '40,000 บาท', save: 'ประหยัดสูงสุด', best: true },
                { rate: '2.25% (KBank/SCB)', monthly: '7,500 บาท', interest: '50,000 บาท', save: '~10,000 บาท', best: false },
                { rate: '3.00%', monthly: '8,000 บาท', interest: '80,000 บาท', save: '—', best: false },
                { rate: '3.50% (Krungsri สูงสุด)', monthly: '8,333 บาท', interest: '100,000 บาท', save: '—', best: false },
              ].map((row, i) => (
                <tr class={`border-t ${i % 2 === 1 ? 'bg-gray-50' : ''} ${row.best ? 'bg-green-50' : ''}`}>
                  <td class="px-4 py-3 font-medium text-gray-900">{row.rate}</td>
                  <td class="px-4 py-3 font-semibold text-gray-900">{row.monthly}</td>
                  <td class="px-4 py-3 text-gray-700">{row.interest}</td>
                  <td class="px-4 py-3 text-green-700 font-medium hidden sm:table-cell">{row.save}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="mt-4 p-4 bg-amber-50 border border-amber-200 rounded-lg">
          <p class="text-sm text-amber-900"><strong>ผลสรุป:</strong> เลือก TTB (2.00%) แทน Krungsri (3.50%) ประหยัดได้ประมาณ <strong>60,000 บาทตลอดสัญญา</strong> หรือ 1,000 บาทต่อเดือน — แค่ขอใบเสนอราคาเพิ่มอีก 2 แห่ง</p>
        </div>
      </section>

      <!-- 4 Tips -->
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-6">4 เทคนิคขอสินเชื่อรถให้ได้อัตราดี</h2>
        <div class="space-y-4">
          {[
            {
              num: 1,
              title: 'ขอใบเสนอราคาจาก 2–3 ธนาคาร',
              desc: 'อัตราสูตรปกติต่างกัน 0.5–1.5% ต่อปีระหว่างธนาคาร ใช้เวลา 5 นาทีต่อแห่ง แต่ประหยัดได้หลายหมื่นบาท อย่าพอใจกับใบเสนอราคาแรกที่ได้',
            },
            {
              num: 2,
              title: 'บอกธนาคารว่าคุณมีเครดิตดี',
              desc: 'เครดิตสกอร์ 700+ ช่วยให้ได้อัตราต่ำกว่า ตรวจสอบเครดิตบูโรก่อนสมัคร ถ้ามีหนี้ค้างชำระ ชำระให้จบก่อนสมัครสินเชื่อรถ',
            },
            {
              num: 3,
              title: 'วางดาวน์เพมเม้นต์สูงขึ้น',
              desc: 'ดาวน์ 25–30% ขึ้นไปช่วยลดอัตราดอกเบี้ยได้ 0.5–1% เพราะธนาคารมีความเสี่ยงน้อยลง ตัวอย่างดาวน์จาก 20% เป็น 30% อาจประหยัดดอกเบี้ยเพิ่มอีก 15,000–20,000 บาท',
            },
            {
              num: 4,
              title: 'เลือกระยะเวลาให้เหมาะสม',
              desc: 'ผ่อน 60 เดือน (5 ปี) มักสมดุลดีสุด ผ่อน 84 เดือนจ่ายดอกเบี้ยเพิ่มขึ้น 30–40% แต่ค่างวดลงเพียง 25–30% เลือก 84 เดือนเฉพาะเมื่อค่างวด 60 เดือนเกิน 30% ของรายได้',
            },
          ].map((tip) => (
            <div class="flex gap-4 p-5 bg-white border border-gray-200 rounded-lg">
              <div class="flex-shrink-0 w-10 h-10 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center font-bold">{tip.num}</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">{tip.title}</h3>
                <p class="text-sm text-gray-700">{tip.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Term Comparison -->
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">เปรียบเทียบระยะเวลาผ่อน (กู้ 400,000 บาท อัตรา 2.50%)</h2>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ระยะเวลา</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ค่างวด/เดือน</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ดอกเบี้ยรวม</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900 hidden sm:table-cell">ความเหมาะสม</th>
              </tr>
            </thead>
            <tbody>
              {[
                { term: '36 เดือน (3 ปี)', monthly: '12,222 บาท', interest: '40,000 บาท', fit: 'มีรายได้สูง อยากจบเร็ว', bg: '' },
                { term: '48 เดือน (4 ปี)', monthly: '9,583 บาท', interest: '60,000 บาท', fit: 'สมดุลดีสุดสำหรับรายได้ปานกลาง', bg: 'bg-gray-50' },
                { term: '60 เดือน (5 ปี)', monthly: '8,000 บาท', interest: '80,000 บาท', fit: 'แนะนำสำหรับส่วนใหญ่', bg: 'bg-green-50', best: true },
                { term: '72 เดือน (6 ปี)', monthly: '7,083 บาท', interest: '110,000 บาท', fit: 'ค่างวดต่ำแต่ดอกเบี้ยสูง', bg: 'bg-gray-50' },
                { term: '84 เดือน (7 ปี)', monthly: '6,429 บาท', interest: '140,000 บาท', fit: 'เฉพาะรายได้น้อยมาก', bg: '' },
              ].map((row) => (
                <tr class={`border-t ${row.bg}`}>
                  <td class="px-4 py-3 font-medium text-gray-900">
                    {row.term}
                    {row.best && <span class="ml-2 text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded-full">แนะนำ</span>}
                  </td>
                  <td class="px-4 py-3 font-semibold text-gray-900">{row.monthly}</td>
                  <td class="px-4 py-3 text-gray-700">{row.interest}</td>
                  <td class="px-4 py-3 text-gray-600 hidden sm:table-cell">{row.fit}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-6">คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {[
            {
              q: 'ดอกเบี้ยสินเชื่อรถ Flat Rate กับ Effective Rate ต่างกันอย่างไร?',
              a: 'Flat Rate คิดดอกเบี้ยจากยอดกู้เดิมตลอดสัญญา เช่น 2.5% Flat Rate = 4.5–5% Effective Rate (อัตราที่แท้จริง) ธนาคารไทยส่วนใหญ่ใช้ Flat Rate ในการโฆษณา แต่ดอกเบี้ยที่แท้จริงสูงกว่าประมาณ 2 เท่า'
            },
            {
              q: 'เครดิตบูโรไม่ดี ยังกู้สินเชื่อรถได้ไหม?',
              a: 'ยังได้แต่อัตราดอกเบี้ยจะสูงกว่า บางธนาคารอาจปฏิเสธ ทางออกคือ (1) ชำระหนี้ค้างทั้งหมดก่อน (2) ขอผู้ค้ำประกันที่มีเครดิตดี (3) วางดาวน์สูงขึ้น 30–40% เพื่อลดความเสี่ยงให้ธนาคาร'
            },
            {
              q: 'ไฟแนนซ์รถมือสองอัตราดอกเบี้ยสูงกว่ารถใหม่ไหม?',
              a: 'ใช่ สินเชื่อรถมือสองมักสูงกว่า 0.5–2% เพราะมูลค่ารถลดลงเร็วกว่า ความเสี่ยงสูงกว่า บางธนาคารรับไฟแนนซ์รถมือสองสูงสุด 60–72 เดือนเท่านั้น'
            },
            {
              q: 'ผ่อนรถแล้ว ขอรีไฟแนนซ์ได้ไหม?',
              a: 'ได้ ถ้าผ่อนมาแล้ว 12 เดือนขึ้นไปและไม่เคยผิดนัด สามารถขอรีไฟแนนซ์กับธนาคารอื่นที่มีอัตราต่ำกว่า ประหยัดได้ 10,000–30,000 บาทขึ้นกับยอดเหลือและอัตราใหม่'
            },
          ].map((faq) => (
            <div class="p-5 bg-white border border-gray-200 rounded-lg">
              <h3 class="font-bold text-gray-900 mb-2">{faq.q}</h3>
              <p class="text-gray-700 text-sm">{faq.a}</p>
            </div>
          ))}
        </div>
      </section>

    </div>

    <!-- Calculator Links -->
    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องคำนวณสินเชื่อรถที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {[
          { href: '/คำนวณผ่อนรถ/', icon: '🚗', title: 'คำนวณผ่อนรถ', desc: 'ค่างวดรายเดือนตามราคารถและดาวน์' },
