---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณกำไรขั้นต้น | Kamnuanlek';
const pageDescription = 'คำนวณกำไรขั้นต้น Gross Profit อัตรากำไรขั้นต้น Gross Margin สำหรับธุรกิจไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0456-กำไรขั้นต้น/`;

const faqData = [
  { question: 'กำไรขั้นต้นคืออะไร?', answer: 'กำไรขั้นต้น (Gross Profit) = รายได้จากการขาย - ต้นทุนสินค้า (COGS) เป็นกำไรก่อนหักค่าใช้จ่ายดำเนินงานและภาษี' },
  { question: 'อัตรากำไรขั้นต้นที่ดีควรเป็นเท่าไหร่?', answer: 'ขึ้นอยู่กับประเภทธุรกิจ ร้านค้าปลีก 20-40% ร้านอาหาร 60-70% ซอฟต์แวร์ 70-90% บริการ 50-80% ธุรกิจผลิต 20-50%' },
  { question: 'ต้นทุนสินค้า COGS คืออะไร?', answer: 'COGS (Cost of Goods Sold) คือต้นทุนโดยตรงในการผลิตหรือซื้อสินค้า รวมวัตถุดิบ แรงงานผลิต ค่าโรงงาน ไม่รวมค่าขาย ค่าบริหาร' },
  { question: 'จะเพิ่มกำไรขั้นต้นได้อย่างไร?', answer: 'เพิ่มกำไรขั้นต้นโดย ขึ้นราคาขาย ลดต้นทุนสินค้า (ต่อรองซัพพลายเออร์) ปรับ Mix สินค้าไปสินค้ากำไรสูง ลดของเสียและสต็อก' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณกำไรขั้นต้น">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณกำไรขั้นต้น</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณกำไรขั้นต้นและอัตรากำไรขั้นต้น Gross Profit Margin</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="revenue_gp" class="block text-sm font-medium text-gray-700 mb-1">รายได้จากการขาย (บาท)</label><input type="text" id="revenue_gp" inputmode="decimal" placeholder="เช่น 1000000" value="1000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="cogs_gp" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนสินค้าขาย COGS (บาท)</label><input type="text" id="cogs_gp" inputmode="decimal" placeholder="เช่น 600000" value="600000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">กำไรขั้นต้น</p>
            <p id="gross_profit" class="font-bold">-</p>
          </div>
          <div class="bg-indigo-50 rounded p-3">
            <p class="text-sm text-gray-600">อัตรากำไรขั้นต้น</p>
            <p id="gross_margin" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const revenue = parseFloat((document.getElementById('revenue_gp') as HTMLInputElement).value) || 0;
      const cogs = parseFloat((document.getElementById('cogs_gp') as HTMLInputElement).value) || 0;

      const grossProfit = revenue - cogs;
      const grossMargin = revenue > 0 ? (grossProfit / revenue * 100) : 0;

      (document.getElementById('gross_profit') as HTMLElement).textContent = grossProfit.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('gross_margin') as HTMLElement).textContent = grossMargin.toFixed(2) + '%';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('gross-profit-margin');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
