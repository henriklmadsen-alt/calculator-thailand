---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณผลกระทบต้นทุนจากใบสั่งจราจร ปี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณผลกระทบต้นทุนรวมจากค่าปรับใบสั่งจราจร รวมค่าปรับ ค่าขึ้นเบี้ยประกัน และเวลาที่เสียไป';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณผลกระทบต้นทุนจากใบสั่ง/`;

const faqData = [
  {
    question: 'ค่าปรับใบสั่งจราจรในไทยเฉลี่ยเท่าไร?',
    answer: 'ค่าปรับใบสั่งจราจรในไทยแตกต่างกันตามประเภทความผิด เช่น ไม่คาดเข็มขัดนิรภัย 500 บาท ฝ่าไฟแดง 1,000 บาท ขับรถเร็วเกินกำหนด 500–2,000 บาท ใช้โทรศัพท์ขณะขับรถ 400–1,000 บาท ตามพระราชบัญญัติจราจรทางบก พ.ศ. 2522 และที่แก้ไขเพิ่มเติม',
  },
  {
    question: 'ใบสั่งจราจรส่งผลต่อเบี้ยประกันรถอย่างไร?',
    answer: 'การมีประวัติใบสั่งจราจรหรืออุบัติเหตุส่งผลให้บริษัทประกันพิจารณาว่าผู้ขับขี่มีความเสี่ยงสูงขึ้น ทำให้เบี้ยประกันภัยชั้น 1 อาจเพิ่มขึ้น 5–20% ต่อปี ขึ้นอยู่กับบริษัทประกันและประเภทของความผิด',
  },
  {
    question: 'ต้นทุนเวลาที่เสียไปจากใบสั่งควรคิดอย่างไร?',
    answer: 'ต้นทุนเวลารวมถึงเวลาที่ต้องรอชำระค่าปรับที่สถานีตำรวจหรือออนไลน์ เวลาเดินทาง และเวลาที่หยุดรถระหว่างถูกจับ โดยเฉลี่ยใช้เวลา 1–3 ชั่วโมงต่อครั้ง ควรคำนวณโดยใช้อัตราค่าจ้างต่อชั่วโมงของตัวเองเป็นเกณฑ์',
  },
  {
    question: 'วิธีลดโอกาสถูกใบสั่งจราจรมีอะไรบ้าง?',
    answer: 'วิธีลดโอกาสถูกใบสั่ง ได้แก่ ปฏิบัติตามกฎจราจรอย่างเคร่งครัด ไม่ใช้โทรศัพท์ขณะขับ คาดเข็มขัดนิรภัยทุกครั้ง ตรวจสอบเอกสารรถให้ครบถ้วน และวางแผนเส้นทางเพื่อหลีกเลี่ยงพื้นที่จราจรติดขัด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผลกระทบต้นทุนจากใบสั่งจราจร',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผลกระทบต้นทุนจากใบสั่งจราจร">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณผลกระทบต้นทุนจากใบสั่งจราจร
    </h1>
    <p class="text-gray-600 mb-6">
      คำนวณต้นทุนรวมที่แท้จริงจากใบสั่งจราจร รวมค่าปรับ ค่าเบี้ยประกันที่เพิ่มขึ้น และค่าเสียเวลา เพื่อให้เห็นภาพรวมผลกระทบทางการเงิน
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="calculator-form" class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fine-amount" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าปรับต่อใบสั่ง (บาท)
            </label>
            <input
              type="text"
              id="fine-amount"
              inputmode="decimal"
              placeholder="เช่น 1000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="violations-per-year" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนใบสั่งต่อปี (ครั้ง)
            </label>
            <input
              type="text"
              id="violations-per-year"
              inputmode="decimal"
              placeholder="เช่น 3"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="insurance-premium" class="block text-sm font-medium text-gray-700 mb-1">
              เบี้ยประกันรถปัจจุบัน (บาท/ปี)
            </label>
            <input
              type="text"
              id="insurance-premium"
              inputmode="decimal"
              placeholder="เช่น 15000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="insurance-increase" class="block text-sm font-medium text-gray-700 mb-1">
              เบี้ยประกันเพิ่มขึ้น (%)
            </label>
            <input
              type="text"
              id="insurance-increase"
              inputmode="decimal"
              placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="time-lost" class="block text-sm font-medium text-gray-700 mb-1">
              เวลาที่เสียต่อใบสั่ง (ชั่วโมง)
            </label>
            <input
              type="text"
              id="time-lost"
              inputmode="decimal"
              placeholder="เช่น 2"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="hourly-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราค่าจ้างต่อชั่วโมง (บาท)
            </label>
            <input
              type="text"
              id="hourly-rate"
              inputmode="decimal"
              placeholder="เช่น 200"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>
        <button
          type="button"
          id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ
        </button>
      </form>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="bg-blue-50 rounded-lg p-4">
          <div class="text-sm text-blue-700 font-medium mb-1">ค่าปรับรวมต่อปี</div>
          <div id="total-fines" class="text-2xl font-bold text-blue-800">-</div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-orange-50 rounded-lg p-4">
            <div class="text-sm text-orange-700 font-medium mb-1">ค่าเบี้ยประกันที่เพิ่มขึ้น</div>
            <div id="insurance-cost" class="text-xl font-bold text-orange-800">-</div>
            <div class="text-xs text-orange-600 mt-1">ต่อปี</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4">
            <div class="text-sm text-orange-700 font-medium mb-1">ต้นทุนเสียเวลา</div>
            <div id="productivity-cost" class="text-xl font-bold text-orange-800">-</div>
            <div class="text-xs text-orange-600 mt-1">ต่อปี</div>
          </div>
        </div>
        <div class="bg-red-50 rounded-lg p-4 border border-red-200">
          <div class="text-sm text-red-700 font-medium mb-1">ผลกระทบต้นทุนรวมต่อปี</div>
          <div id="total-impact" class="text-3xl font-bold text-red-800">-</div>
          <div id="per-violation" class="text-sm text-red-600 mt-1">-</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ต้นทุนที่แท้จริงของใบสั่งจราจร</h2>
      <p>
        หลายคนมองว่าใบสั่งจราจรมีต้นทุนเพียงค่าปรับที่ต้องจ่าย แต่ในความเป็นจริงผลกระทบทางการเงินมีหลายมิติ
        ทั้งค่าเบี้ยประกันรถที่ปรับสูงขึ้น เวลาและผลผลิตที่เสียไประหว่างติดต่อชำระค่าปรับ
        และความเสี่ยงที่เพิ่มขึ้นจากพฤติกรรมการขับขี่
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณผลกระทบต้นทุนรวม</h3>
      <div class="bg-gray-50 rounded-lg p-4 my-4 space-y-2">
        <p class="font-medium">ค่าปรับรวม = ค่าปรับต่อใบสั่ง × จำนวนใบสั่งต่อปี</p>
        <p class="font-medium">ค่าเบี้ยประกันเพิ่ม = เบี้ยปัจจุบัน × (% เพิ่ม / 100)</p>
        <p class="font-medium">ต้นทุนเวลา = เวลาต่อใบสั่ง × จำนวนใบสั่ง × อัตราค่าจ้าง/ชั่วโมง</p>
        <p class="font-semibold text-primary-700">ผลกระทบรวม = ค่าปรับรวม + ค่าเบี้ยเพิ่ม + ต้นทุนเวลา</p>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">อัตราค่าปรับตามกฎหมายจราจรไทย 2569</h3>
      <p>
        กฎหมายจราจรทางบกของไทยกำหนดค่าปรับหลายระดับ เช่น ขับรถโดยไม่มีใบอนุญาต 1,000–2,000 บาท
        ฝ่าไฟแดง 500–1,000 บาท ไม่คาดเข็มขัดนิรภัย 500 บาท ใช้โทรศัพท์ขณะขับรถ 400–1,000 บาท
        และขับรถเร็วเกินกำหนด 200–500 บาท ซึ่งหากสะสมหลายใบสั่งต่อปีจะส่งผลกระทบต่อต้นทุนรวมอย่างมีนัยสำคัญ
      </p>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณผลกระทบต้นทุนจากใบสั่ง/" />
    <RelatedCalculators currentHref="/คำนวณผลกระทบต้นทุนจากใบสั่ง/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเบื้องต้นเท่านั้น
      อัตราค่าปรับและเบี้ยประกันอาจแตกต่างกันขึ้นอยู่กับบริษัทประกันและสภาพการณ์จริง
      กรุณาตรวจสอบข้อมูลล่าสุดจากหน่วยงานที่เกี่ยวข้อง
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const fineAmount = parseNum((document.getElementById('fine-amount') as HTMLInputElement).value);
      const violations = parseNum((document.getElementById('violations-per-year') as HTMLInputElement).value);
      const premium = parseNum((document.getElementById('insurance-premium') as HTMLInputElement).value);
      const insuranceIncreasePct = parseNum((document.getElementById('insurance-increase') as HTMLInputElement).value);
      const timeLost = parseNum((document.getElementById('time-lost') as HTMLInputElement).value);
      const hourlyRate = parseNum((document.getElementById('hourly-rate') as HTMLInputElement).value);

      if (fineAmount <= 0 || violations <= 0) {
        (document.getElementById('fine-amount') as HTMLInputElement).focus();
        return;
      }

      const totalFines = fineAmount * violations;
      const insuranceCost = premium * (insuranceIncreasePct / 100);
      const productivityCost = timeLost * violations * hourlyRate;
      const totalImpact = totalFines + insuranceCost + productivityCost;
      const perViolation = violations > 0 ? totalImpact / violations : 0;

      (document.getElementById('total-fines') as HTMLElement).textContent = `฿${fmt(totalFines)}`;
      (document.getElementById('insurance-cost') as HTMLElement).textContent = `฿${fmt(insuranceCost)}`;
      (document.getElementById('productivity-cost') as HTMLElement).textContent = `฿${fmt(productivityCost)}`;
      (document.getElementById('total-impact') as HTMLElement).textContent = `฿${fmt(totalImpact)}`;
      (document.getElementById('per-violation') as HTMLElement).textContent = `เฉลี่ย ฿${fmt(perViolation)} ต่อครั้ง (รวมทุกต้นทุน)`;

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
    });

    document.querySelectorAll('#calculator-form input').forEach(input => {
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
