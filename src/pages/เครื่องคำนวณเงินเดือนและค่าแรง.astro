---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เครื่องคำนวณเงินเดือนและค่าแรง — เงินสุทธิ โอที ประกันสังคม | Kamnuanlek"
  description="เครื่องคำนวณเงินเดือนและค่าแรงฟรี คำนวณเงินเดือนสุทธิหลังหักภาษีและประกันสังคม ค่าโอที ค่าแรงขั้นต่ำ และเงินชดเชย อัปเดตกฎหมายแรงงานปี 2569"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Salary & Wage Calculators</h1>
    <p class="text-xl text-gray-600 mb-12">
      Calculate your take-home pay, overtime, social security contributions, and more. All calculators follow Thailand's 2026 labor laws.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณเงินเดือนสุทธิ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">💰</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Net Salary Calculator</h3>
        <p class="text-gray-600 mb-3">See exactly how much you take home after income tax and social security deductions.</p>
        <span class="text-primary-600 font-medium">Calculate Net Pay →</span>
      </a>

      <a href="/คำนวณโอที/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">⏰</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Overtime Pay Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate overtime pay based on hourly rate. Thai law requires 1.5x pay for overtime hours.</p>
        <span class="text-primary-600 font-medium">Calculate OT →</span>
      </a>

      <a href="/คำนวณประกันสังคม/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🏥</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Social Security Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate your monthly social security contribution (5% of salary, max 750 THB/month).</p>
        <span class="text-primary-600 font-medium">Calculate →</span>
      </a>

      <a href="/คำนวณค่าแรงขั้นต่ำ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">👷</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Minimum Wage Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate wages based on Thailand's minimum wage (varies by province). Current rate: 363-400 THB/day.</p>
        <span class="text-primary-600 font-medium">Calculate →</span>
      </a>

      <a href="/คำนวณค่าชดเชย/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">📋</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Severance Pay Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate legal severance pay based on years of service when employment is terminated.</p>
        <span class="text-primary-600 font-medium">Calculate →</span>
      </a>

      <a href="/คำนวณโบนัส/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🎁</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Bonus Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate your expected year-end bonus based on salary and performance multiplier.</p>
        <span class="text-primary-600 font-medium">Calculate →</span>
      </a>
    </div>

    <div class="p-6 bg-green-50 border border-green-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Key Salary Facts for 2026</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 bg-white rounded-lg border border-green-100">
          <h3 class="font-semibold text-gray-900 mb-2">Personal Income Tax</h3>
          <p class="text-gray-700">Progressive: 0% up to 150,000 THB / year, then 5%–37% on higher income</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-green-100">
          <h3 class="font-semibold text-gray-900 mb-2">Social Security</h3>
          <p class="text-gray-700">Employee: 5% of salary (max 750 THB/month). Employer matches.</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-green-100">
          <h3 class="font-semibold text-gray-900 mb-2">Overtime Rate</h3>
          <p class="text-gray-700">1.5x hourly rate for hours beyond 8/day or 48/week. 3x on public holidays.</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-green-100">
          <h3 class="font-semibold text-gray-900 mb-2">Minimum Wage</h3>
          <p class="text-gray-700">363–400 THB per day depending on province (Bangkok: 400 THB/day)</p>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Calculators</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Calculators</span>
          <p class="text-gray-600 text-sm mt-2">Tax, loans, savings, and investment tools</p>
        </a>
        <a href="/วิธีคำนวณภาษีเงินได้ไทย/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📚 Income Tax Guide</span>
          <p class="text-gray-600 text-sm mt-2">Step-by-step guide to calculating tax</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
