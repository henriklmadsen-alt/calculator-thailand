---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณแผนหมุนเพาะปลูก | Calculator Thailand';
const pageDescription = 'คำนวณการหมุนเพาะปลูก แบ่งพื้นที่ รายได้ต่อพืช วิเคราะห์ผลตอบแทน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-วางแผนหมุนเพาะปลูก/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณวางแผนหมุนเพาะปลูก">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณแผนหมุนเพาะปลูก</h1>
    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2"><p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณการหมุนเพาะปลูก 3 พืชสลับกัน แบ่งพื้นที่ วิเคราะห์รายได้</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="rai" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่ทั้งหมด (ไร่)</label><input type="text" id="rai" inputmode="decimal" placeholder="เช่น 30" value="30" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="years" class="block text-sm font-medium text-gray-700 mb-1">รอบการหมุนเพาะ (ปี)</label><input type="text" id="years" inputmode="numeric" placeholder="เช่น 1" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-primary-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ไร่ต่อพืช</p><p id="perCrop" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้พืช 1</p><p id="crop1" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้พืช 2</p><p id="crop2" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้รวม</p><p id="total" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const rai = parseFloat((document.getElementById('rai') as HTMLInputElement).value) || 0;
      const years = parseFloat((document.getElementById('years') as HTMLInputElement).value) || 0;
      if (rai <= 0) return;
      const raiPerCrop = rai / 3;
      const rotation1Income = raiPerCrop * 450 * 6, rotation2Income = raiPerCrop * 4000 * 3.5;
      const totalIncome = (rotation1Income + rotation2Income) * years;
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('perCrop') as HTMLElement).textContent = raiPerCrop.toFixed(1) + ' ไร่';
      (document.getElementById('crop1') as HTMLElement).textContent = fmt(rotation1Income);
      (document.getElementById('crop2') as HTMLElement).textContent = fmt(rotation2Income);
      (document.getElementById('total') as HTMLElement).textContent = fmt(totalIncome);
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('crop-rotation-planning');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
