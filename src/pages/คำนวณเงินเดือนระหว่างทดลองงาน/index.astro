---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเงินเดือนระหว่างทดลองงาน ปี 2569 เริ่มงานกลางเดือน คิดแบบ Pro-rata | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณเงินเดือนระหว่างทดลองงาน รองรับเริ่มงานกลางเดือน คิดสัดส่วนตามวันทำงานจริง เปรียบเทียบกับเงินเดือนเต็มเดือน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินเดือนระหว่างทดลองงาน/`;

const faqData = [
  {
    question: 'เงินเดือนเดือนแรกคำนวณอย่างไรถ้าเริ่มงานกลางเดือน?',
    answer: 'เงินเดือนเดือนแรก = เงินเดือนเต็ม × (วันทำงานจริง ÷ วันทำงานในเดือนนั้น) ซึ่งเรียกว่าการคิดแบบ Pro-rata',
  },
  {
    question: 'ช่วงทดลองงานกี่เดือน?',
    answer: 'กฎหมายแรงงานไม่ได้กำหนดช่วงทดลองงานตายตัว แต่ทั่วไปอยู่ที่ 90 วัน (3 เดือน) หรือ 120 วัน บางบริษัทอาจกำหนด 6 เดือน',
  },
  {
    question: 'ในช่วงทดลองงานได้รับสิทธิ์ประกันสังคมไหม?',
    answer: 'ได้รับ ลูกจ้างทุกคนที่มีรายได้ต้องสมทบประกันสังคมตั้งแต่วันแรกที่เริ่มงาน โดยนายจ้างต้องขึ้นทะเบียนภายใน 30 วัน',
  },
  {
    question: 'ถ้าเงินเดือนทดลองงานต่ำกว่าปกติต้องบอกพนักงานไหม?',
    answer: 'ต้องระบุไว้ในสัญญาจ้างงาน และต้องไม่ต่ำกว่าอัตราค่าแรงขั้นต่ำตามกฎหมาย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินเดือนระหว่างทดลองงาน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินเดือนระหว่างทดลองงาน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คิดเงินเดือนแบบ Pro-rata สำหรับเดือนแรกที่เริ่มงาน</p>
      <p class="mt-1 text-sm text-slate-700">เงินเดือนเต็ม × (วันทำงานจริง ÷ วันทำงานในเดือน)</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับพนักงานใหม่ที่ต้องการทราบยอดรับเดือนแรก</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณเงินเดือนระหว่างทดลองงาน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือน วันที่เริ่มงาน และวันทำงานในเดือน ระบบจะคำนวณเงินเดือนสำหรับเดือนแรกแบบ Pro-rata
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="probation-form" class="space-y-5">
        <p id="probation-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="prob-full-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือนเต็ม (บาท/เดือน)</label>
            <input type="text" id="prob-full-salary" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="prob-full-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="prob-trial-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือนช่วงทดลองงาน (บาท/เดือน, ถ้าต่างจากเต็ม)</label>
            <input type="text" id="prob-trial-salary" inputmode="numeric" placeholder="เช่น 27,000 หรือเว้นว่างถ้าเท่ากัน"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="prob-start-day" class="mb-1 block text-sm font-medium text-gray-700">วันที่เริ่มงาน (วันที่ในเดือน)</label>
            <input type="text" id="prob-start-day" inputmode="numeric" placeholder="เช่น 15"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="prob-start-day-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="prob-total-days" class="mb-1 block text-sm font-medium text-gray-700">วันทำงานทั้งเดือน (วัน)</label>
            <input type="text" id="prob-total-days" inputmode="numeric" placeholder="เช่น 26"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="prob-total-days-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="prob-days-worked" class="mb-1 block text-sm font-medium text-gray-700">วันที่ทำงานจริงในเดือนนั้น</label>
            <input type="text" id="prob-days-worked" inputmode="numeric" placeholder="เช่น 12"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="prob-days-worked-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="probation-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินเดือนเดือนแรก (Pro-rata)</div>
            <div id="res-prob-first" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินเดือนเต็มเดือน</div>
            <div id="res-prob-full" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ส่วนต่าง</div>
            <div id="res-prob-diff" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">วันทำงานจริง ÷ วันทำงานทั้งเดือน</span>
            <span id="res-prob-ratio" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>เงินเดือน Pro-rata = เงินเดือนช่วงทดลองงาน × (วันทำงานจริง ÷ วันทำงานทั้งเดือน)</li>
        <li>ถ้าไม่มีเงินเดือนพิเศษช่วงทดลองงาน ใช้เงินเดือนเต็มคำนวณ</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
        <li><a href="/คำนวณประกันสังคม/">คำนวณประกันสังคม</a></li>
        <li><a href="/คำนวณขึ้นเงินเดือน/">คำนวณขึ้นเงินเดือน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#probation-results" />
    <RelatedArticles currentHref="/คำนวณเงินเดือนระหว่างทดลองงาน/" />
    <RelatedCalculators currentHref="/คำนวณเงินเดือนระหว่างทดลองงาน/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ การคิดเงินเดือนจริงขึ้นอยู่กับนโยบายบริษัทและสัญญาจ้าง
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('probation-form');
    const formError = document.getElementById('probation-form-error');
    const resultBox = document.getElementById('probation-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['prob-full-salary-error','prob-total-days-error','prob-days-worked-error'].forEach((id) => setErr(id, ''));

      const fullSalary = parseNum(document.getElementById('prob-full-salary').value);
      const trialSalaryInput = parseNum(document.getElementById('prob-trial-salary').value);
      const trialSalary = Number.isFinite(trialSalaryInput) && trialSalaryInput > 0 ? trialSalaryInput : fullSalary;
      const totalDays = parseNum(document.getElementById('prob-total-days').value);
      const daysWorked = parseNum(document.getElementById('prob-days-worked').value);

      let hasError = false;
      if (!Number.isFinite(fullSalary) || fullSalary <= 0) { setErr('prob-full-salary-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(totalDays) || totalDays <= 0 || totalDays > 31) { setErr('prob-total-days-error', 'กรอกวันทำงานทั้งเดือน 1-31 วัน'); hasError = true; }
      if (!Number.isFinite(daysWorked) || daysWorked <= 0 || daysWorked > 31) { setErr('prob-days-worked-error', 'กรอกวันทำงานจริง 1-31 วัน'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const proRata = trialSalary * (daysWorked / totalDays);
      const diff = fullSalary - proRata;

      setText('res-prob-first', formatMoney(proRata));
      setText('res-prob-full', formatMoney(trialSalary));
      setText('res-prob-diff', `−${formatMoney(diff)}`);
      setText('res-prob-ratio', `${daysWorked} ÷ ${totalDays} = ${(daysWorked/totalDays*100).toFixed(1)}%`);

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
