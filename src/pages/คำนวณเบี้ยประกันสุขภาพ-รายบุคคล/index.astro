---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import AffiliateCard from '../../components/templates/AffiliateCard.astro';

const pageTitle = 'คำนวณเบี้ยประกันสุขภาพรายบุคคล 2569 | OPD+IPD | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณเบี้ยประกันสุขภาพรายบุคคล รวม OPD ผู้ป่วยนอก และ IPD ผู้ป่วยใน ตามอายุ เพศ และแผนประกัน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเบี้ยประกันสุขภาพ-รายบุคคล/`;

const faqData = [
  {
    question: 'ประกันสุขภาพ OPD และ IPD ต่างกันอย่างไร?',
    answer: 'OPD (ผู้ป่วยนอก) ครอบคลุมค่ารักษาพยาบาลที่ไม่ต้องนอนโรงพยาบาล เช่น ค่าพบแพทย์ ค่ายา ค่าตรวจ IPD (ผู้ป่วยใน) ครอบคลุมค่ารักษาเมื่อต้องนอนโรงพยาบาลอย่างน้อย 1 คืน เช่น การผ่าตัด ค่าห้องพัก ค่าหมอ',
  },
  {
    question: 'ควรซื้อประกันสุขภาพแผนไหน?',
    answer: 'สำหรับคนทั่วไปที่สุขภาพดี แผนพื้นฐาน IPD เพียงอย่างเดียวก็เพียงพอ หากมีโรคประจำตัวหรือใช้บริการ OPD บ่อย ควรเพิ่มแผน OPD ด้วย แผนพรีเมียมเหมาะสำหรับผู้ต้องการความคุ้มครองสูงสุดและเข้าถึงโรงพยาบาลชั้นนำ',
  },
  {
    question: 'เบี้ยประกันสุขภาพลดหย่อนภาษีได้เท่าไหร่?',
    answer: 'เบี้ยประกันสุขภาพสามารถนำไปลดหย่อนภาษีได้สูงสุด 25,000 บาทต่อปี (ตามประกาศกรมสรรพากร) และเมื่อรวมกับเบี้ยประกันชีวิตไม่เกิน 100,000 บาทต่อปีรวมกัน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเบี้ยประกันสุขภาพรายบุคคล',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเบี้ยประกันสุขภาพรายบุคคล">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณเบี้ยประกันสุขภาพรายบุคคล 2569</p>
      <p class="mt-1 text-sm text-slate-700">ตัวเลขเป็นการประมาณการ เพื่อใช้วางแผนเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเบี้ยประกันสุขภาพรายบุคคล 2569 — OPD + IPD
    </h1>

    <p class="text-gray-600 mb-6">
      ประมาณเบี้ยประกันสุขภาพรายบุคคลตามอายุ เพศ แผนความคุ้มครอง และวงเงิน IPD
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="hi-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="hi-age" class="block text-sm font-medium text-gray-700 mb-1">อายุ (ปี)</label>
            <input type="text" id="hi-age" inputmode="numeric" placeholder="เช่น 30"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="hi-age-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="hi-gender" class="block text-sm font-medium text-gray-700 mb-1">เพศ</label>
            <select id="hi-gender" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="male">ชาย</option>
              <option value="female">หญิง</option>
            </select>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="hi-plan" class="block text-sm font-medium text-gray-700 mb-1">แผนประกันสุขภาพ</label>
            <select id="hi-plan" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="basic">พื้นฐาน (IPD เท่านั้น)</option>
              <option value="standard" selected>มาตรฐาน (OPD + IPD)</option>
              <option value="premium">พรีเมียม (OPD + IPD สูงสุด)</option>
            </select>
          </div>
          <div>
            <label for="hi-ipd" class="block text-sm font-medium text-gray-700 mb-1">วงเงิน IPD ต่อปี</label>
            <select id="hi-ipd" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="100000">100,000 บาท</option>
              <option value="200000" selected>200,000 บาท</option>
              <option value="500000">500,000 บาท</option>
              <option value="1000000">1,000,000 บาท</option>
            </select>
          </div>
        </div>

        <div>
          <label for="hi-preexist" class="block text-sm font-medium text-gray-700 mb-1">โรคประจำตัว</label>
          <select id="hi-preexist" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white sm:w-64">
            <option value="no">ไม่มี</option>
            <option value="yes">มีโรคประจำตัว (loading +30%)</option>
          </select>
        </div>

        <button type="submit" id="hi-submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ (ประมาณการ)</h2>
        <div class="space-y-2 mb-4">
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-600">เบี้ย IPD (ผู้ป่วยใน)</span>
            <span id="res-ipd" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-600">เบี้ย OPD (ผู้ป่วยนอก)</span>
            <span id="res-opd" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-3 bg-primary-50 px-3 rounded-lg">
            <span class="font-bold">เบี้ยรวมรายปี</span>
            <span id="res-annual" class="text-xl font-bold text-primary-700">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">เบี้ยรายเดือน</span>
            <span id="res-monthly" class="font-semibold text-gray-900">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">สิทธิลดหย่อนภาษี (สูงสุด)</span>
            <span id="res-tax" class="font-semibold text-green-600">-</span>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-2">* เบี้ยจริงอาจแตกต่างตามบริษัทประกัน ควรติดต่อตัวแทนเพื่อใบเสนอราคาที่ถูกต้อง</p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณเบี้ยประกันสุขภาพ</h2>
      <p>เบี้ยประกันสุขภาพขึ้นอยู่กับอายุ เพศ และวงเงินคุ้มครอง อายุมากขึ้นเบี้ยสูงขึ้นเพราะความเสี่ยงด้านสุขภาพเพิ่มขึ้น</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <AffiliateCard
      category="insurance"
      affiliateUrl="https://retail.easysunday.com/?sRefCode=SAF5401723"
      partnerName="EasySunday"
      ctaText="เปรียบเทียบประกันสุขภาพ"
      subtext="เปรียบเทียบแผนประกันสุขภาพจากหลายบริษัท AXA, MSIG, Cigna และอื่น ๆ"
    />
    <RelatedCalculators currentHref="/คำนวณเบี้ยประกันสุขภาพ-รายบุคคล/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงต้องสอบถามบริษัทประกันสุขภาพโดยตรง
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n) + ' บาท'; }

    const form = document.getElementById('hi-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    function setErr(id: string, msg: string) { const el = document.getElementById(id); if (el) { el.textContent = msg; el.classList.remove('hidden'); } }
    function clearErr(id: string) { const el = document.getElementById(id); if (el) { el.textContent = ''; el.classList.add('hidden'); } }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearErr('hi-age-error');

      const age = parseNum((document.getElementById('hi-age') as HTMLInputElement).value);
      const gender = (document.getElementById('hi-gender') as HTMLSelectElement).value;
      const plan = (document.getElementById('hi-plan') as HTMLSelectElement).value;
      const ipd = parseNum((document.getElementById('hi-ipd') as HTMLSelectElement).value);
      const preexist = (document.getElementById('hi-preexist') as HTMLSelectElement).value;

      if (age < 1 || age > 65) { setErr('hi-age-error', 'กรุณากรอกอายุระหว่าง 1-65 ปี'); return; }

      trackCalculatorStart('health-insurance-individual');

      let baseIPDRatePer1000 = 0;
      if (age < 30) baseIPDRatePer1000 = 2.5;
      else if (age < 40) baseIPDRatePer1000 = 4;
      else if (age < 50) baseIPDRatePer1000 = 7;
      else if (age < 60) baseIPDRatePer1000 = 12;
      else baseIPDRatePer1000 = 20;

      if (gender === 'female' && age >= 20 && age <= 45) baseIPDRatePer1000 *= 1.1;

      let ipdPremium = (ipd / 1000) * baseIPDRatePer1000;
      const opdPremium = plan === 'basic' ? 0 : plan === 'standard' ? 3000 : 6000;
      let total = ipdPremium + opdPremium;

      if (preexist === 'yes') total *= 1.3;

      const taxBenefit = Math.min(total, 25000);

      (document.getElementById('res-ipd') as HTMLElement).textContent = fmt(ipdPremium * (preexist === 'yes' ? 1.3 : 1));
      (document.getElementById('res-opd') as HTMLElement).textContent = plan === 'basic' ? 'ไม่รวม' : fmt(opdPremium * (preexist === 'yes' ? 1.3 : 1));
      (document.getElementById('res-annual') as HTMLElement).textContent = fmt(total);
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(total / 12);
      (document.getElementById('res-tax') as HTMLElement).textContent = fmt(taxBenefit);

      resultsDiv.classList.remove('hidden');
      document.getElementById('affiliate-card')?.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('health-insurance-individual');
      trackCalculatorUsed('health-insurance-individual');
    });
  </script>
</BaseLayout>
