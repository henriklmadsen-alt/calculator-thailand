---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเงินดาวน์ 2569 — บ้าน รถ คอนโด | Calculator Thailand';
const pageDescription = 'คำนวณเงินดาวน์ขั้นต่ำสำหรับบ้าน รถ และคอนโด ตามเปอร์เซ็นต์ที่กำหนด พร้อมค่าใช้จ่ายแรกเข้าทั้งหมด ช่วยวางแผนเงินออมก่อนกู้';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินดาวน์/`;

const faqData = [
  {
    question: 'เงินดาวน์บ้านต้องกี่เปอร์เซ็นต์?',
    answer: 'ตามเกณฑ์ธนาคารแห่งประเทศไทย (LTV) บ้านหลังแรกราคาไม่เกิน 10 ล้านบาทดาวน์ขั้นต่ำ 5% ราคาเกิน 10 ล้านบาทดาวน์ 10% บ้านหลังที่สองขึ้นไปดาวน์ 10-20% ขึ้นอยู่กับประเภทสัญญา',
  },
  {
    question: 'เงินดาวน์รถยนต์ต้องเท่าไร?',
    answer: 'รถยนต์ดาวน์ขั้นต่ำ 15-25% ของราคารถ แต่ถ้าดาวน์มากขึ้น เช่น 30-40% จะได้ค่างวดต่ำลง และดอกเบี้ยรวมน้อยลง บางโปรโมชั่นอาจมีดาวน์ 0% แต่ดอกเบี้ยสูงกว่า',
  },
  {
    question: 'ค่าใช้จ่ายแรกเข้าบ้านมีอะไรบ้าง?',
    answer: 'นอกจากเงินดาวน์แล้ว ยังมีค่าธรรมเนียมโอน 2% ค่าจดจำนอง 1% ค่าประกันอัคคีภัย ค่าประกันสินเชื่อ (MRF/MRTA) และค่าตีราคาประเมิน รวมกันอาจถึง 3-5% ของราคาบ้าน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินดาวน์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินดาวน์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      คำนวณเงินดาวน์ — บ้าน รถ คอนโด พร้อมค่าใช้จ่ายแรกเข้า
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">คำนวณเงินดาวน์ตามเปอร์เซ็นต์ที่กำหนด และค่าใช้จ่ายที่ต้องเตรียมก่อนวันโอน</p>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6 mb-8">
      <form id="down-form" class="space-y-5">
        <div>
          <label for="asset-price" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ราคาซื้อขาย (บาท)</label>
          <input type="text" id="asset-price" inputmode="numeric" placeholder="เช่น 3,500,000"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="down-pct" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">เงินดาวน์ (%)</label>
            <input type="text" id="down-pct" inputmode="decimal" placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
          <div>
            <label for="asset-type" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ประเภท</label>
            <select id="asset-type" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base">
              <option value="house">บ้าน/คอนโด</option>
              <option value="car">รถยนต์</option>
              <option value="other">อื่น ๆ</option>
            </select>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="transfer-fee" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ค่าโอน % (บ้าน: 2%)</label>
            <input type="text" id="transfer-fee" inputmode="decimal" placeholder="2"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
          <div>
            <label for="mortgage-fee" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ค่าจดจำนอง % (1%)</label>
            <input type="text" id="mortgage-fee" inputmode="decimal" placeholder="1"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
        </div>
        <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 mb-4">
          <div class="bg-primary-50 dark:bg-primary-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">เงินดาวน์</div>
            <div id="res-down" class="text-xl font-bold text-primary-700 dark:text-primary-300">-</div>
          </div>
          <div class="bg-blue-50 dark:bg-blue-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">วงเงินกู้</div>
            <div id="res-loan" class="text-xl font-bold text-blue-700 dark:text-blue-300">-</div>
          </div>
          <div class="bg-orange-50 dark:bg-orange-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ต้องเตรียมทั้งหมด</div>
            <div id="res-total" class="text-xl font-bold text-orange-700 dark:text-orange-300">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100 dark:border-gray-700">
            <span class="text-gray-600 dark:text-gray-400">ค่าธรรมเนียมโอน</span>
            <span id="res-transfer" class="font-medium text-gray-900 dark:text-gray-100">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100 dark:border-gray-700">
            <span class="text-gray-600 dark:text-gray-400">ค่าจดจำนอง</span>
            <span id="res-mortgage" class="font-medium text-gray-900 dark:text-gray-100">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100 dark:border-gray-700">
            <span class="text-gray-600 dark:text-gray-400">ค่าธรรมเนียมอื่น (ประมาณ)</span>
            <span id="res-other" class="font-medium text-gray-900 dark:text-gray-100">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot />

    <section class="prose prose-gray dark:prose-invert max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-3">เกณฑ์ LTV (Loan-to-Value) สำหรับบ้านในไทย</h2>
      <p>ธนาคารแห่งประเทศไทยกำหนดเกณฑ์ LTV เพื่อควบคุมการปล่อยกู้อสังหาริมทรัพย์ หลังปี 2562 บ้านหลังแรกราคาไม่เกิน 10 ล้านบาทกู้ได้ 95-100% (ดาวน์ 0-5%) แต่บ้านหลังที่สองขึ้นไปกู้ได้สูงสุด 80-90% ขึ้นอยู่กับมูลค่า</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 dark:text-gray-100 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600 dark:text-gray-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณเงินดาวน์/" />
    <RelatedCalculators currentHref="/คำนวณเงินดาวน์/" />

    <div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg text-sm text-yellow-800 dark:text-yellow-300">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ เกณฑ์จริงขึ้นอยู่กับนโยบายของสถาบันการเงินและ ธปท.
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }

    document.getElementById('asset-type')!.addEventListener('change', (e) => {
      const type = (e.target as HTMLSelectElement).value;
      const tfInput = document.getElementById('transfer-fee') as HTMLInputElement;
      const mfInput = document.getElementById('mortgage-fee') as HTMLInputElement;
      if (type === 'car') { tfInput.value = '0'; mfInput.value = '0'; }
      else if (type === 'house') { tfInput.value = '2'; mfInput.value = '1'; }
    });

    document.getElementById('down-form')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const price = parseNum((document.getElementById('asset-price') as HTMLInputElement).value);
      if (!price) return;
      const pct = parseNum((document.getElementById('down-pct') as HTMLInputElement).value) || 10;
      const tfPct = parseNum((document.getElementById('transfer-fee') as HTMLInputElement).value);
      const mfPct = parseNum((document.getElementById('mortgage-fee') as HTMLInputElement).value);

      const down = price * pct / 100;
      const loan = price - down;
      const transferFee = price * tfPct / 100;
      const mortgageFee = loan * mfPct / 100;
      const otherFee = loan * 0.005; // ~0.5% for insurance etc
      const total = down + transferFee + mortgageFee + otherFee;

      (document.getElementById('res-down') as HTMLElement).textContent = fmt(down) + ' บาท';
      (document.getElementById('res-loan') as HTMLElement).textContent = fmt(loan) + ' บาท';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(total) + ' บาท';
      (document.getElementById('res-transfer') as HTMLElement).textContent = fmt(transferFee) + ' บาท';
      (document.getElementById('res-mortgage') as HTMLElement).textContent = fmt(mortgageFee) + ' บาท';
      (document.getElementById('res-other') as HTMLElement).textContent = fmt(otherFee) + ' บาท';

      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('down-payment');
    });
  </script>
</BaseLayout>
