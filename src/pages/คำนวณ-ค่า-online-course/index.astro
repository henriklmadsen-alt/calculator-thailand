---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ ค่าสร้างคอร์สออนไลน์ 2569 | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนและรายได้ คอร์สออนไลน์ ประเมิน Break-even Point';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่า-online-course/`;

const faqData = [
  {
    question: 'ต้นทุนสร้างคอร์สออนไลน์?',
    answer: 'สอนเอง: 20,000-50,000 บาท (เวลา Video Recording) จ้างคนอื่น: 100,000-500,000+ บาท Platform: 500-5,000 บาท/เดือน Marketing: 5,000-50,000 บาท',
  },
  {
    question: 'ราคาคอร์สควรเป็นเท่าไร?',
    answer: 'Beginner: 500-2,000 บาท Intermediate: 2,000-10,000 บาท Advanced: 10,000-50,000+ บาท ขึ้นอยู่กับ Skill Level และ Market',
  },
  {
    question: 'Break-even Point?',
    answer: 'ถ้าสร้างคอร์สใช้ 50,000 บาท ราคา 5,000 บาท = ต้องขาย 10 คน พอถึง Break-even',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าคอร์สออนไลน์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าคอร์สออนไลน์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🎓 คำนวณค่าสร้างคอร์สออนไลน์
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณต้นทุนและรายได้ คอร์สออนไลน์
      ประเมิน Break-even Point
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="course-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="dev-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ต้นทุนพัฒนาคอร์ส (บาท)
            </label>
            <input
              type="text"
              id="dev-cost"
              inputmode="numeric"
              placeholder="เช่น 50000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="course-price" class="block text-sm font-medium text-gray-700 mb-1">
              ราคาคอร์ส (บาท)
            </label>
            <input
              type="text"
              id="course-price"
              inputmode="numeric"
              placeholder="เช่น 5000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="platform-fee" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Platform (%)
            </label>
            <input
              type="text"
              id="platform-fee"
              inputmode="numeric"
              placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="sales" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนขาย (คน)
            </label>
            <input
              type="text"
              id="sales"
              inputmode="numeric"
              placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณค่า
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดขายรวม</div>
            <div id="res-revenue" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">กำไร</div>
            <div id="res-profit" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Break-even Point</div>
            <div id="res-breakeven" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ROI %</div>
            <div id="res-roi" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณ-ค่า-online-course/" />
    <RelatedCalculators currentHref="/คำนวณ-ค่า-online-course/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('course-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const devCost = parseNum((document.getElementById('dev-cost') as HTMLInputElement).value);
      const coursePrice = parseNum((document.getElementById('course-price') as HTMLInputElement).value);
      const platformFee = parseNum((document.getElementById('platform-fee') as HTMLInputElement).value);
      const sales = parseNum((document.getElementById('sales') as HTMLInputElement).value);

      if (devCost <= 0) { (document.getElementById('dev-cost') as HTMLInputElement).focus(); return; }
      if (coursePrice <= 0) { (document.getElementById('course-price') as HTMLInputElement).focus(); return; }

      const feeAmount = (coursePrice * platformFee) / 100;
      const netPrice = coursePrice - feeAmount;
      const revenue = coursePrice * sales;
      const netRevenue = revenue - (feeAmount * sales);
      const profit = netRevenue - devCost;
      const breakeven = coursePrice > 0 ? Math.ceil(devCost / netPrice) : 0;
      const roi = devCost > 0 ? (profit / devCost) * 100 : 0;

      (document.getElementById('res-revenue') as HTMLElement).textContent = fmt(revenue) + ' บาท';
      (document.getElementById('res-profit') as HTMLElement).textContent = fmt(profit) + ' บาท';
      (document.getElementById('res-breakeven') as HTMLElement).textContent = breakeven + ' คน';
      (document.getElementById('res-roi') as HTMLElement).textContent = roi.toFixed(0) + '%';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('online-course-cost');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('online-course-cost');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
