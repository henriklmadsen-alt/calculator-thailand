---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณแบ่งบิลรูมเมท 2569 | หารค่าใช้จ่ายรูมเมท | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณแบ่งบิลค่าเช่า ค่าไฟ ค่าน้ำ ค่าอินเทอร์เน็ตสำหรับรูมเมทหลายคน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณแบ่งบิลรูมเมท/`;

const faqData = [
  {
    question: 'ค่าไฟควรหารเท่ากันหรือตามการใช้งานจริง?',
    answer: 'หากใช้งานเท่ากันโดยประมาณ การหารเท่ากันง่ายและสะดวก แต่หากมีคนอยู่บ้านนานกว่าหรือใช้อุปกรณ์ไฟฟ้ามากกว่า อาจตกลงหักค่าพื้นฐานร่วมกันก่อน แล้วค่าส่วนเกินคิดตามสัดส่วนการใช้',
  },
  {
    question: 'วิธีจัดการเมื่อรูมเมทคนหนึ่งไม่ยอมจ่าย?',
    answer: 'ควรตกลงเงื่อนไขให้ชัดเจนตั้งแต่ต้น กำหนดวันจ่าย และบันทึกเป็นลายลักษณ์อักษรหรือใช้แอปติดตาม หากมีปัญหาซ้ำซาก ควรคุยตรงๆ หรือปรึกษาเจ้าของห้องเพื่อปรับข้อตกลง',
  },
  {
    question: 'แอปอะไรที่ช่วยจัดการค่าใช้จ่ายรูมเมทได้ดี?',
    answer: 'แอปยอดนิยมได้แก่ Splitwise, Tricount และ Bill Splitting ซึ่งช่วยบันทึกค่าใช้จ่าย คำนวณยอดค้างชำระ และส่งการแจ้งเตือนให้รูมเมทแต่ละคนได้อย่างสะดวก',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณแบ่งบิลรูมเมท',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณแบ่งบิลรูมเมท">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณแบ่งบิลรูมเมท 2569</h1>
    <p class="mb-6 text-gray-600">กรอกจำนวนรูมเมทและค่าใช้จ่ายแต่ละรายการ เพื่อดูว่าแต่ละคนต้องจ่ายเท่าไร หากอยู่กับครอบครัวหรือกลุ่มใหญ่ดูได้ที่ <a href="/คำนวณแบ่งค่าใช้จ่ายครัวเรือน/" class="text-primary-600 underline hover:text-primary-800">คำนวณแบ่งค่าใช้จ่ายครัวเรือน</a> หรือ <a href="/คำนวณแบ่งค่าใช้จ่ายคู่รัก/" class="text-primary-600 underline hover:text-primary-800">คำนวณแบ่งค่าใช้จ่ายคู่รัก</a></p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="roommate-form" class="space-y-4">
        <div>
          <label for="num-roommates" class="mb-1 block text-sm font-medium text-gray-700">จำนวนรูมเมท</label>
          <select id="num-roommates"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48">
            {[2,3,4,5,6,7,8].map(n => <option value={n}>{n} คน</option>)}
          </select>
        </div>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {[
            { id: 'rm-rent', label: 'ค่าเช่า (บาท/เดือน)' },
            { id: 'rm-electric', label: 'ค่าไฟฟ้า (บาท/เดือน)' },
            { id: 'rm-water', label: 'ค่าน้ำประปา (บาท/เดือน)' },
            { id: 'rm-internet', label: 'ค่าอินเทอร์เน็ต (บาท/เดือน)' },
            { id: 'rm-other', label: 'ค่าใช้จ่ายอื่นๆ (บาท/เดือน)' },
          ].map(f => (
            <div>
              <label for={f.id} class="mb-1 block text-sm font-medium text-gray-700">{f.label}</label>
              <input id={f.id} type="text" inputmode="numeric" placeholder="0"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            </div>
          ))}
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รวมทั้งหมด/เดือน</div>
            <div id="rm-res-total" class="text-3xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">แต่ละคนจ่าย/เดือน</div>
            <div id="rm-res-per" class="text-3xl font-bold text-green-700">-</div>
          </div>
        </div>
        <div id="rm-breakdown" class="space-y-1 text-sm text-gray-700"></div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณแบ่งบิลรูมเมท/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('roommate-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const people = parseInt((document.getElementById('num-roommates') as HTMLSelectElement).value);
    const items = [
      { id: 'rm-rent', label: 'ค่าเช่า' },
      { id: 'rm-electric', label: 'ค่าไฟฟ้า' },
      { id: 'rm-water', label: 'ค่าน้ำ' },
      { id: 'rm-internet', label: 'ค่าอินเทอร์เน็ต' },
      { id: 'rm-other', label: 'ค่าใช้จ่ายอื่นๆ' },
    ];

    let total = 0;
    const lines: string[] = [];

    items.forEach(item => {
      const val = parseNum((document.getElementById(item.id) as HTMLInputElement).value);
      if (val > 0) {
        total += val;
        lines.push(`• ${item.label}: ${fmt(val)} (แต่ละคน ${fmt(val / people)})`);
      }
    });

    document.getElementById('rm-res-total')!.textContent = fmt(total);
    document.getElementById('rm-res-per')!.textContent = fmt(total / people);
    document.getElementById('rm-breakdown')!.innerHTML = lines.length > 0 ? lines.join('<br/>') : 'ยังไม่ได้กรอกค่าใช้จ่าย';
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
