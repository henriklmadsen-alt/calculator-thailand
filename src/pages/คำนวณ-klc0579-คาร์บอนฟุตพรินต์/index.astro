---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณคาร์บอนฟุตพรินต์ | Calculator Thailand';
const pageDescription = 'คำนวณการปล่อยคาร์บอนรายปี ไฟฟ้า น้ำ ขนส่ง การบริโภค';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0579-คาร์บอนฟุตพรินต์/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณคาร์บอนฟุตพรินต์">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณคาร์บอนฟุตพรินต์</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณการปล่อยคาร์บอนไดออกไซด์รายปี จากกิจกรรมประจำวัน</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="electric" class="block text-sm font-medium text-gray-700 mb-1">ค่าไฟฟ้า (บาท/เดือน)</label><input type="text" id="electric" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="km" class="block text-sm font-medium text-gray-700 mb-1">ขับรถ (กม./สัปดาห์)</label><input type="text" id="km" inputmode="decimal" placeholder="เช่น 100" value="100" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">คาร์บอนจากไฟฟ้า</p><p id="e_carbon" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">คาร์บอนจากขนส่ง</p><p id="t_carbon" class="font-bold">-</p></div><div class="bg-orange-50 rounded p-3"><p class="text-sm text-gray-600">รวมคาร์บอนต่อปี</p><p id="total" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const electric = parseFloat((document.getElementById('electric') as HTMLInputElement).value) || 0;
      const km = parseFloat((document.getElementById('km') as HTMLInputElement).value) || 0;
      const eCarbon = electric * 12 * 0.546, tCarbon = km * 52 * 0.21, total = eCarbon + tCarbon;
      (document.getElementById('e_carbon') as HTMLElement).textContent = eCarbon.toFixed(1) + ' กก. CO₂';
      (document.getElementById('t_carbon') as HTMLElement).textContent = tCarbon.toFixed(1) + ' กก. CO₂';
      (document.getElementById('total') as HTMLElement).textContent = total.toFixed(1) + ' กก. CO₂';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('carbon-footprint');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
