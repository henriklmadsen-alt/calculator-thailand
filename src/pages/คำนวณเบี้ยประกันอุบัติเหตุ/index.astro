---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import AffiliateCard from '../../components/templates/AffiliateCard.astro';

const pageTitle = 'คำนวณเบี้ยประกันอุบัติเหตุ (PA) 2569 | ตามอาชีพและวงเงิน | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณเบี้ยประกันอุบัติเหตุส่วนบุคคล (PA) ตามวงเงินคุ้มครอง กลุ่มอาชีพ และค่ารักษาพยาบาล';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเบี้ยประกันอุบัติเหตุ/`;

const faqData = [
  {
    question: 'ประกันอุบัติเหตุ PA ครอบคลุมอะไรบ้าง?',
    answer: 'ประกันอุบัติเหตุส่วนบุคคล (PA) ครอบคลุมการเสียชีวิต ทุพพลภาพถาวร (ทั้งสิ้นหรือบางส่วน) จากอุบัติเหตุ บางแบบยังครอบคลุมค่ารักษาพยาบาลจากอุบัติเหตุด้วย ทำให้เป็นประกันที่คุ้มค่าราคาสำหรับทุกคน',
  },
  {
    question: 'กลุ่มอาชีพในประกัน PA แบ่งอย่างไร?',
    answer: 'กลุ่มที่ 1: พนักงานออฟฟิศ นักบัญชี นักเรียน ครู — เสี่ยงต่ำสุด กลุ่มที่ 2: ช่างก่อสร้าง พนักงานขาย คนขับรถ — เสี่ยงปานกลาง กลุ่มที่ 3: ช่างเชื่อม คนงานเหมือง คนทำงานบนที่สูง — เสี่ยงสูง บางบริษัทแบ่งเป็น 4-5 กลุ่ม',
  },
  {
    question: 'ประกัน PA ต่างจากประกันสุขภาพอย่างไร?',
    answer: 'ประกัน PA คุ้มครองเฉพาะกรณีอุบัติเหตุเท่านั้น ส่วนประกันสุขภาพคุ้มครองทั้งการเจ็บป่วยและอุบัติเหตุ ดังนั้น PA เบี้ยถูกกว่าแต่ครอบคลุมน้อยกว่า ควรมีทั้งสองประเภทเพื่อความคุ้มครองครบถ้วน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเบี้ยประกันอุบัติเหตุ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเบี้ยประกันอุบัติเหตุ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณเบี้ยประกันอุบัติเหตุ PA 2569</p>
      <p class="mt-1 text-sm text-slate-700">ตัวเลขเป็นการประมาณการ เพื่อใช้วางแผนเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเบี้ยประกันอุบัติเหตุส่วนบุคคล (PA) 2569
    </h1>

    <p class="text-gray-600 mb-6">
      ประมาณเบี้ยประกันอุบัติเหตุตามวงเงินคุ้มครอง กลุ่มอาชีพ และค่ารักษาพยาบาล
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="pa-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="pa-sum" class="block text-sm font-medium text-gray-700 mb-1">วงเงินคุ้มครองเสียชีวิต/ทุพพลภาพ (บาท)</label>
            <input type="text" id="pa-sum" inputmode="numeric" placeholder="เช่น 500,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="pa-sum-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="pa-group" class="block text-sm font-medium text-gray-700 mb-1">กลุ่มอาชีพ</label>
            <select id="pa-group" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="1">กลุ่ม 1 — ออฟฟิศ/นักเรียน/ครู</option>
              <option value="2">กลุ่ม 2 — ภาคสนาม/คนขับรถ</option>
              <option value="3">กลุ่ม 3 — งานเสี่ยงสูง/ก่อสร้าง</option>
            </select>
          </div>
        </div>

        <div>
          <label for="pa-medical" class="block text-sm font-medium text-gray-700 mb-1">วงเงินค่ารักษาพยาบาลจากอุบัติเหตุ (บาท, ไม่บังคับ)</label>
          <input type="text" id="pa-medical" inputmode="numeric" placeholder="เช่น 30,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base sm:w-64" />
        </div>

        <button type="submit" id="pa-submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ (ประมาณการ)</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เบี้ยรายปี</div>
            <div id="res-annual" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เบี้ยรายเดือน</div>
            <div id="res-monthly" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">วงเงินคุ้มครองรวม</div>
            <div id="res-coverage" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">อัตราเบี้ยประกันอุบัติเหตุ</h2>
      <p>กลุ่ม 1: 0.25% ของวงเงิน | กลุ่ม 2: 0.40% | กลุ่ม 3: 0.80% ค่ารักษาพยาบาลเพิ่มประมาณ 0.1-0.2%</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <AffiliateCard
      category="insurance"
      affiliateUrl="https://retail.easysunday.com/?sRefCode=SAF5401723"
      partnerName="EasySunday"
      ctaText="เปรียบเทียบประกันอุบัติเหตุ"
      subtext="เปรียบเทียบแผนประกันอุบัติเหตุจากหลายบริษัท"
    />
    <RelatedCalculators currentHref="/คำนวณเบี้ยประกันอุบัติเหตุ/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงต้องสอบถามบริษัทประกันภัยโดยตรง
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n) + ' บาท'; }

    const form = document.getElementById('pa-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    function setErr(id: string, msg: string) { const el = document.getElementById(id); if (el) { el.textContent = msg; el.classList.remove('hidden'); } }
    function clearErr(id: string) { const el = document.getElementById(id); if (el) { el.textContent = ''; el.classList.add('hidden'); } }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearErr('pa-sum-error');

      const sumInsured = parseNum((document.getElementById('pa-sum') as HTMLInputElement).value);
      const group = parseInt((document.getElementById('pa-group') as HTMLSelectElement).value);
      const medical = parseNum((document.getElementById('pa-medical') as HTMLInputElement).value);

      if (sumInsured <= 0) { setErr('pa-sum-error', 'กรุณากรอกวงเงินคุ้มครอง'); return; }

      trackCalculatorStart('accident-insurance-premium');

      const rates: Record<number, number> = { 1: 0.0025, 2: 0.004, 3: 0.008 };
      const medRates: Record<number, number> = { 1: 0.001, 2: 0.0015, 3: 0.002 };

      const basePremium = sumInsured * (rates[group] || 0.0025);
      const medPremium = medical > 0 ? medical * (medRates[group] || 0.001) : 0;
      const annual = basePremium + medPremium;
      const coverage = sumInsured + medical;

      (document.getElementById('res-annual') as HTMLElement).textContent = fmt(annual);
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(annual / 12);
      (document.getElementById('res-coverage') as HTMLElement).textContent = fmt(coverage);

      resultsDiv.classList.remove('hidden');
      document.getElementById('affiliate-card')?.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('accident-insurance-premium');
      trackCalculatorUsed('accident-insurance-premium');
    });
  </script>
</BaseLayout>
