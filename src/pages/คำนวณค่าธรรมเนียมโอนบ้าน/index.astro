---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณค่าธรรมเนียมโอนบ้าน 2569 | ค่าโอน จดจำนอง ภาษี | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณค่าธรรมเนียมโอนบ้าน 2569 เช็กค่าโอน ค่าจดจำนอง ภาษีธุรกิจเฉพาะ อากรแสตมป์ และภาษีหัก ณ ที่จ่าย พร้อมสรุปแยกผู้ซื้อ-ผู้ขาย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าธรรมเนียมโอนบ้าน/`;

const faqData = [
  {
    question: 'ค่าโอนบ้านปี 2569 คิดจากอะไร?',
    answer: 'ค่าจดทะเบียนโอนคิดจากราคาประเมินทุนทรัพย์เป็นหลัก โดยอัตราปกติที่ใช้ทั่วไปคือ 2% และอาจลดเหลือ 0.01% หากเข้าเงื่อนไขมาตรการภาครัฐ',
  },
  {
    question: 'มาตรการ 0.01% ใช้ได้ถึงเมื่อไร?',
    answer: 'ตามเอกสารกระทรวงการคลังที่ใช้อ้างอิง มาตรการลดค่าจดทะเบียนโอนและจดจำนองเหลือ 0.01% ใช้ถึงวันที่ 30 มิถุนายน 2569 สำหรับเคสที่เข้าเงื่อนไข',
  },
  {
    question: 'ถ้าเสียภาษีธุรกิจเฉพาะแล้ว ต้องเสียอากรแสตมป์อีกไหม?',
    answer: 'ไม่ต้องเสียซ้ำ โดยคู่มือกรมที่ดินระบุว่าเมื่อกรณีต้องเสียภาษีธุรกิจเฉพาะแล้ว ให้ยกเว้นอากรแสตมป์',
  },
  {
    question: 'ภาษีหัก ณ ที่จ่ายผู้ขายบุคคลธรรมดาทำไมไม่คำนวณอัตโนมัติ?',
    answer: 'ผู้ขายบุคคลธรรมดาต้องคำนวณตามหลักเกณฑ์หักค่าใช้จ่าย/ปีถือครองและอัตราก้าวหน้า จึงให้กรอกยอดที่สำนักงานที่ดินประเมินเพื่อหลีกเลี่ยงการประมาณที่คลาดเคลื่อน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียมโอนบ้าน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณค่าธรรมเนียมโอนบ้านและที่ดิน',
  description: 'ขั้นตอนการคำนวณค่าธรรมเนียมโอนกรรมสิทธิ์ ค่าจดจำนอง และภาษีที่เกี่ยวข้อง ตามกรมที่ดิน',
  step: [
    { '@type': 'HowToStep', name: 'ระบุราคาซื้อขายหรือราคาประเมิน', text: 'กรอกราคาซื้อขายจริง และราคาประเมินจากกรมที่ดิน (ตรวจสอบได้ที่เว็บไซต์ treasury.go.th) ค่าธรรมเนียมคำนวณจากราคาที่สูงกว่าระหว่างสองราคานี้' },
    { '@type': 'HowToStep', name: 'คำนวณค่าธรรมเนียมโอน 2%', text: 'ค่าธรรมเนียมโอนกรรมสิทธิ์ = ราคาอ้างอิง × 2% ตัวอย่าง: บ้านราคา 3,000,000 บาท = ค่าธรรมเนียมโอน 60,000 บาท (ปกติแบ่งกันจ่ายคนละครึ่งระหว่างผู้ซื้อและผู้ขาย)' },
    { '@type': 'HowToStep', name: 'คำนวณค่าจดจำนอง 1%', text: 'หากกู้ธนาคาร ต้องชำระค่าจดจำนอง = วงเงินกู้ × 1% สูงสุด 200,000 บาท ตัวอย่าง: กู้ 2,400,000 บาท = ค่าจดจำนอง 24,000 บาท' },
    { '@type': 'HowToStep', name: 'คำนวณภาษีธุรกิจเฉพาะหรืออากรแสตมป์', text: 'ถือครองน้อยกว่า 5 ปี หรือย้ายทะเบียนน้อยกว่า 1 ปี = ภาษีธุรกิจเฉพาะ 3.3% ถ้าถือครองนานกว่า = อากรแสตมป์ 0.5% (จ่ายอย่างใดอย่างหนึ่ง ไม่ใช่ทั้งคู่)' },
    { '@type': 'HowToStep', name: 'รวมค่าใช้จ่ายทั้งหมด', text: 'รวมค่าธรรมเนียมโอน + ค่าจดจำนอง + ภาษีธุรกิจเฉพาะ/อากรแสตมป์ + ภาษีเงินได้หัก ณ ที่จ่าย (ผู้ขาย) นำไปเตรียมเงินก่อนวันโอนที่กรมที่ดิน' },
  ],
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าธรรมเนียมโอนบ้าน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">อัปเดตเกณฑ์ค่าโอนปี 2569</p>
      <p class="mt-1 text-sm text-slate-700">รองรับทั้งอัตราปกติและกรณีมาตรการ 0.01% ที่มีเงื่อนไขเฉพาะ</p>
      <p class="mt-1 text-xs font-medium text-sky-800">แสดงผลแยกเป็นค่าใช้จ่ายผู้ซื้อและผู้ขายเพื่อวางเงินวันโอน</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณค่าธรรมเนียมโอนบ้าน ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกราคาซื้อขาย ราคาประเมิน วงเงินจำนอง และสถานะภาษี เพื่อคำนวณค่าโอน ค่าจดจำนอง ภาษีธุรกิจเฉพาะ อากรแสตมป์ และภาษีหัก ณ ที่จ่ายในหน้าเดียว
    </p>

    <PublicTrustPanel
      lastUpdated="16 เม.ย. 2569"
      sources={[
        'กรมที่ดิน: คู่มือประชาชนค่าธรรมเนียม ภาษี และอากร',
        'กระทรวงการคลัง: มาตรการลดค่าธรรมเนียม 0.01% (ฉบับที่ 42/2568)',
        'กรมที่ดิน: ข่าวประชาสัมพันธ์เงื่อนไขมาตรการ 0.01%',
      ]}
      assumptions={[
        'เครื่องมือนี้คำนวณตามข้อมูลที่ผู้ใช้กรอกและเงื่อนไขที่ผู้ใช้เลือก',
        'ภาษีหัก ณ ที่จ่ายผู้ขายบุคคลธรรมดาให้กรอกยอดประเมินจากสำนักงานที่ดินเพื่อความแม่นยำ',
      ]}
      references={[
        {
          label: 'กรมที่ดิน: ค่าธรรมเนียม ภาษี และอากร',
          href: 'https://www.dol.go.th/dol-services/public-service-manual/land-registration/fees-taxes-duties/',
        },
        {
          label: 'กระทรวงการคลัง (8 เม.ย. 2568): มาตรการลดค่าธรรมเนียม 0.01%',
          href: 'https://media.thaigov.go.th/uploads/document/275/2025/04/pdf/Doc_20250408141606000000.pdf',
        },
        {
          label: 'กรมที่ดิน: ข่าวมาตรการลดค่าธรรมเนียมโอน/จำนอง 0.01%',
          href: 'https://www.dol.go.th/nakhonsithammarat/news-nst/press-release/news-1775105715/',
        },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="home-transfer-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณากรอกข้อมูลที่จำเป็นให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="sale-price" class="block text-sm font-medium text-gray-700 mb-1">ราคาซื้อขาย (บาท)</label>
            <input id="sale-price" type="text" inputmode="numeric" placeholder="เช่น 6,000,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="appraised-price" class="block text-sm font-medium text-gray-700 mb-1">ราคาประเมินทุนทรัพย์ (บาท)</label>
            <input id="appraised-price" type="text" inputmode="numeric" placeholder="เช่น 5,800,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="mortgage-amount" class="block text-sm font-medium text-gray-700 mb-1">วงเงินจำนอง (บาท)</label>
            <input id="mortgage-amount" type="text" inputmode="numeric" placeholder="เช่น 4,500,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="seller-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทผู้ขาย</label>
            <select id="seller-type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="corporate">นิติบุคคล (หัก ณ ที่จ่าย 1% อัตโนมัติ)</option>
              <option value="individual">บุคคลธรรมดา (กรอกภาษีหัก ณ ที่จ่ายเอง)</option>
            </select>
          </div>
        </div>

        <div id="individual-wht-wrap" class="hidden">
          <label for="individual-wht" class="block text-sm font-medium text-gray-700 mb-1">ภาษีหัก ณ ที่จ่ายผู้ขายบุคคลธรรมดา (บาท)</label>
          <input id="individual-wht" type="text" inputmode="numeric" placeholder="เช่น 95,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:max-w-md" />
          <p class="mt-1 text-xs text-gray-500">กรอกยอดตามที่สำนักงานที่ดินคำนวณให้ เพื่อหลีกเลี่ยงการประมาณคลาดเคลื่อน</p>
        </div>

        <div class="space-y-3 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
          <label class="flex items-start gap-3 text-sm text-gray-700">
            <input id="has-specific-business-tax" type="checkbox" class="mt-0.5 h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
            <span>กรณีนี้เข้าเกณฑ์เสียภาษีธุรกิจเฉพาะ 3.3% (ถ้าเลือกข้อนี้ ระบบจะยกเว้นอากรแสตมป์อัตโนมัติ)</span>
          </label>
          <label class="flex items-start gap-3 text-sm text-gray-700">
            <input id="reduced-fee-eligible" type="checkbox" class="mt-0.5 h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
            <span>เข้าเงื่อนไขมาตรการค่าธรรมเนียม 0.01% (ใช้ได้ถึง 30 มิถุนายน 2569 และต้องจดโอน+จดจำนองในคราวเดียวกัน)</span>
          </label>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          คำนวณค่าใช้จ่ายวันโอน
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณค่าธรรมเนียมโอนบ้าน</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าจดทะเบียนโอน</div>
            <div id="res-transfer-fee" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าจดทะเบียนจำนอง</div>
            <div id="res-mortgage-fee" class="text-xl font-bold text-sky-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รวมฝั่งผู้ซื้อ</div>
            <div id="res-buyer-costs" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="rounded-lg bg-emerald-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รวมค่าใช้จ่ายทั้งหมด</div>
            <div id="res-total-costs" class="text-xl font-bold text-emerald-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm mb-4">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ฐานภาษีที่ใช้ (ราคาที่สูงกว่า)</span>
            <span id="res-tax-base" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ภาษีธุรกิจเฉพาะ (3.3%)</span>
            <span id="res-sbt" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">อากรแสตมป์</span>
            <span id="res-stamp-duty" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ภาษีหัก ณ ที่จ่าย</span>
            <span id="res-withholding-tax" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">รวมฝั่งผู้ขาย</span>
            <span id="res-seller-costs" class="font-semibold">-</span>
          </div>
        </div>

        <div id="reduced-fee-note" class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800"></div>
        <p class="mt-3 text-xs text-gray-500">
          หมายเหตุ: ผลลัพธ์ใช้เพื่อวางแผนงบประมาณก่อนวันโอน ยอดจริงขึ้นกับเอกสารสิทธิ เงื่อนไขผู้ซื้อ-ผู้ขาย และการประเมินของสำนักงานที่ดินในวันทำรายการ
        </p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="mb-8 bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 prose prose-slate max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ค่าจดทะเบียนโอน (ปกติ) = ราคาประเมิน x 2%</li>
        <li>ค่าจดทะเบียนจำนอง (ปกติ) = วงเงินจำนอง x 1% (ไม่เกิน 200,000 บาท)</li>
        <li>ค่าธรรมเนียมมาตรการ (กรณีเข้าเงื่อนไข) = 0.01% สำหรับค่าโอนและค่าจำนอง</li>
        <li>ภาษีธุรกิจเฉพาะ = 3.3% x ฐานราคาที่สูงกว่า (ราคาซื้อขาย/ราคาประเมิน)</li>
        <li>อากรแสตมป์ = 1 บาทต่อทุก 200 บาท และยกเว้นเมื่อเสียภาษีธุรกิจเฉพาะ</li>
        <li>ภาษีหัก ณ ที่จ่ายผู้ขายนิติบุคคล = 1% x ฐานราคาที่สูงกว่า</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <RelatedArticles currentHref="/คำนวณค่าธรรมเนียมโอนบ้าน/" />
    <RelatedCalculators currentHref="/คำนวณค่าธรรมเนียมโอนบ้าน/" />

    <section class="mb-8 bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 prose prose-slate max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ค่าธรรมเนียมโอนบ้านประกอบด้วยอะไรบ้าง?</h2>
      <p class="text-gray-700">เมื่อซื้อบ้านหรือที่ดิน เราต้องเสียค่าธรรมเนียมหลายประเภท และค่าเหล่านี้สามารถรวมกันเป็นจำนวนเงินที่สำคัญได้ <strong>ตัวอย่าง:</strong> ซื้อบ้านราคา 3,500,000 บาท กรณีเจ้าของเดิมถือครองไม่ถึง 5 ปี ค่าธรรมเนียมที่ต้องจ่ายคือ:</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>ค่าโอนสิทธิ:</strong> 2% ของราคาประเมิน = 3,500,000 × 2% = 70,000 บาท</li>
        <li><strong>ค่าจดจำนอง:</strong> 1% ของราคาประเมิน = 3,500,000 × 1% = 35,000 บาท</li>
        <li><strong>ภาษีธุรกิจเฉพาะ:</strong> 3.3% ของราคาประเมิน = 3,500,000 × 3.3% = 115,500 บาท</li>
      </ul>
      <p class="text-gray-700"><strong>รวมทั้งหมด:</strong> 70,000 + 35,000 + 115,500 = <strong>220,500 บาท</strong></p>
      <p class="text-gray-700">ถ้าเจ้าของปัจจุบันถือครองนานกว่า 5 ปี ภาษีธุรกิจเฉพาะจะถูกแทนด้วยอากรแสตมป์ 0.5%:</p>
      <p class="text-gray-700"><strong>ตัวอย่างที่ 2:</strong> ซื้อบ้านราคา 2,000,000 บาท จากเจ้าของที่ถือครองนานกว่า 5 ปี</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ค่าโอน: 2,000,000 × 2% = 40,000 บาท</li>
        <li>ค่าจดจำนอง: 2,000,000 × 1% = 20,000 บาท</li>
        <li>อากรแสตมป์: 2,000,000 × 0.5% = 10,000 บาท</li>
      </ul>
      <p class="text-gray-700"><strong>รวมทั้งหมด:</strong> 40,000 + 20,000 + 10,000 = <strong>70,000 บาท</strong></p>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">การคำนวณค่าธรรมเนียมทีละขั้น</h2>
      <ol class="list-decimal pl-6 space-y-2 text-gray-700">
        <li><strong>หาราคาประเมิน:</strong> ติดต่อ<a href="https://www.dol.go.th/" target="_blank" rel="noopener" class="text-primary-600 hover:underline">สำนักงานที่ดิน (dol.go.th)</a> เพื่อขอประเมินราคาทรัพย์สิน — นี่คือราคาที่ใช้คำนวณค่าธรรมเนียม ไม่ใช่ราคาซื้อขายจริง</li>
        <li><strong>ตรวจสอบอายุการถือครอง:</strong> ดูจากเอกสารโอนปัจจุบัน วันที่โอนเข้า วันที่ขึ้นทะเบียน เพื่อดูว่าเจ้าของปัจจุบันถือครองนานกว่า 5 ปีหรือไม่</li>
        <li><strong>คำนวณตามอัตรา:</strong> ใช้ราคาประเมิน × อัตราค่าธรรมเนียม (2%, 1%, และ 3.3% หรือ 0.5%) ตามสถานะของเจ้าของเดิม</li>
        <li><strong>รวมค่าธรรมเนียม:</strong> บวกค่าโอน + ค่าจดจำนอง + ภาษีธุรกิจเฉพาะหรืออากรแสตมป์</li>
      </ol>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">สิ่งสำคัญที่ต้องรู้</h2>
      <p class="text-gray-700">ราคาประเมินมักต่ำกว่าราคาซื้อขายจริง — ค่าธรรมเนียมคำนวณจากราคาประเมินตามกฎหมาย อ้างอิง: <a href="https://www.rd.go.th/" target="_blank" rel="noopener" class="text-primary-600 hover:underline">พระราชกฤษฎีกาภาษีธุรกิจเฉพาะ (rd.go.th)</a> [อัปเดต 2569] และเอกสารของ<a href="https://www.dol.go.th/" target="_blank" rel="noopener" class="text-primary-600 hover:underline">สำนักงานที่ดิน (dol.go.th)</a> [อัปเดต 2569]</p>
      <p class="text-sm text-gray-500 mt-2">ต้องการดูค่างวดผ่อนบ้านด้วยหรือไม่? → <a href="/คำนวณผ่อนบ้าน/" class="text-primary-600 hover:underline">คำนวณผ่อนบ้านและรีไฟแนนซ์</a></p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  import { calculateHomeTransferFees } from '../../lib/home-transfer-fee';

  const form = document.querySelector('#home-transfer-form');
  const formError = document.querySelector('#form-error');
  const results = document.querySelector('#results');

  const salePriceInput = document.querySelector('#sale-price');
  const appraisedPriceInput = document.querySelector('#appraised-price');
  const mortgageAmountInput = document.querySelector('#mortgage-amount');
  const sellerTypeInput = document.querySelector('#seller-type');
  const individualWhtWrap = document.querySelector('#individual-wht-wrap');
  const individualWhtInput = document.querySelector('#individual-wht');
  const hasSpecificBusinessTaxInput = document.querySelector('#has-specific-business-tax');
  const reducedFeeEligibleInput = document.querySelector('#reduced-fee-eligible');
  const reducedFeeNote = document.querySelector('#reduced-fee-note');

  const elTransferFee = document.querySelector('#res-transfer-fee');
  const elMortgageFee = document.querySelector('#res-mortgage-fee');
  const elBuyerCosts = document.querySelector('#res-buyer-costs');
  const elTotalCosts = document.querySelector('#res-total-costs');
  const elTaxBase = document.querySelector('#res-tax-base');
  const elSbt = document.querySelector('#res-sbt');
  const elStampDuty = document.querySelector('#res-stamp-duty');
  const elWithholdingTax = document.querySelector('#res-withholding-tax');
  const elSellerCosts = document.querySelector('#res-seller-costs');

  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(value)} บาท`;
  }

  function toggleIndividualWhtInput() {
    const isIndividual = sellerTypeInput.value === 'individual';
    individualWhtWrap.classList.toggle('hidden', !isIndividual);
  }

  sellerTypeInput?.addEventListener('change', toggleIndividualWhtInput);
  toggleIndividualWhtInput();

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const salePrice = parseNumber(salePriceInput?.value || '');
    const appraisedPrice = parseNumber(appraisedPriceInput?.value || '');
    const mortgageAmount = parseNumber(mortgageAmountInput?.value || '');
    const individualWht = parseNumber(individualWhtInput?.value || '');
    const hasSpecificBusinessTax = Boolean(hasSpecificBusinessTaxInput?.checked);
    const isReducedFeeEligible = Boolean(reducedFeeEligibleInput?.checked);
    const sellerType = sellerTypeInput?.value === 'individual' ? 'individual' : 'corporate';

    const isValid =
      Number.isFinite(salePrice) && salePrice > 0 &&
      Number.isFinite(appraisedPrice) && appraisedPrice > 0 &&
      Number.isFinite(mortgageAmount) && mortgageAmount >= 0 &&
      (
        sellerType === 'corporate' ||
        !individualWhtInput?.value ||
        (Number.isFinite(individualWht) && individualWht >= 0)
      );

    if (!isValid) {
      formError?.classList.remove('hidden');
      results?.classList.add('hidden');
      return;
    }

    formError?.classList.add('hidden');

    const result = calculateHomeTransferFees({
      salePrice,
      appraisedPrice,
      mortgageAmount,
      isReducedFeeEligible,
      hasSpecificBusinessTax,
      sellerType,
      customIndividualWithholdingTax: Number.isFinite(individualWht) ? individualWht : 0,
    });

    elTransferFee.textContent = formatCurrency(result.transferFee);
    elMortgageFee.textContent = formatCurrency(result.mortgageFee);
    elBuyerCosts.textContent = formatCurrency(result.buyerCosts);
    elTotalCosts.textContent = formatCurrency(result.totalCosts);
    elTaxBase.textContent = formatCurrency(result.taxableBase);
    elSbt.textContent = formatCurrency(result.specificBusinessTax);
    elStampDuty.textContent = formatCurrency(result.stampDuty);
    elWithholdingTax.textContent = formatCurrency(result.withholdingTax);
    elSellerCosts.textContent = formatCurrency(result.sellerCosts);

    if (result.isReducedFeeApplied) {
      reducedFeeNote.className = 'rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800';
      reducedFeeNote.textContent = 'ระบบใช้อัตรามาตรการ 0.01% สำหรับค่าโอนและค่าจดจำนอง (อ้างอิงประกาศที่มีผลถึง 30 มิถุนายน 2569)';
    } else if (isReducedFeeEligible && result.reducedFeeValidationMessage) {
      reducedFeeNote.className = 'rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800';
      reducedFeeNote.textContent = `${result.reducedFeeValidationMessage} ระบบจึงคำนวณด้วยอัตราปกติ 2% และ 1%`;
    } else {
      reducedFeeNote.className = 'rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700';
      reducedFeeNote.textContent = 'ระบบใช้อัตราปกติ: ค่าโอน 2% และค่าจดจำนอง 1% (ค่าจำนองสูงสุด 200,000 บาท)';
    }

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
