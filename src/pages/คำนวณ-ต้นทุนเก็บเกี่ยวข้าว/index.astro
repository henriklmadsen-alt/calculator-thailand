---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนเก็บเกี่ยวข้าว | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการเก็บเกี่ยวข้าว ค่าแรง ค่าเช่าเครื่องจักร ค่าขนส่ง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุนเก็บเกี่ยวข้าว/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนเก็บเกี่ยวข้าว">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนเก็บเกี่ยวข้าว</h1>
    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2"><p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนการเก็บเกี่ยวข้าว ค่าแรง ค่าเช่าเครื่องจักร</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="rai" class="block text-sm font-medium text-gray-700 mb-1">ไร่</label><input type="text" id="rai" inputmode="decimal" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="labor" class="block text-sm font-medium text-gray-700 mb-1">จำนวนแรงงาน</label><input type="text" id="labor" inputmode="numeric" placeholder="เช่น 5" value="5" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="days" class="block text-sm font-medium text-gray-700 mb-1">วัน</label><input type="text" id="days" inputmode="numeric" placeholder="เช่น 3" value="3" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="wage" class="block text-sm font-medium text-gray-700 mb-1">ค่าแรงต่อวัน (บาท)</label><input type="text" id="wage" inputmode="decimal" placeholder="เช่น 300" value="300" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-primary-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6"><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวม</p><p id="total" class="text-2xl font-bold">-</p></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const rai = parseFloat((document.getElementById('rai') as HTMLInputElement).value) || 0;
      const labor = parseFloat((document.getElementById('labor') as HTMLInputElement).value) || 0;
      const days = parseFloat((document.getElementById('days') as HTMLInputElement).value) || 0;
      const wage = parseFloat((document.getElementById('wage') as HTMLInputElement).value) || 0;
      if (rai <= 0) return;
      const total = labor * days * wage;
      (document.getElementById('total') as HTMLElement).textContent = new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(total);
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('harvest-labor');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
