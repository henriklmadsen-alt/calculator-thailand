---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณแบ่งค่าใช้จ่ายคู่รัก 2569 | แฟร์แชร์ค่าใช้จ่าย | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณแบ่งค่าใช้จ่ายคู่รักตามสัดส่วนรายได้หรือเท่ากัน ค่าเช่า อาหาร เที่ยว';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณแบ่งค่าใช้จ่ายคู่รัก/`;

const faqData = [
  {
    question: 'คู่รักควรแบ่งค่าใช้จ่ายเท่ากันหรือตามสัดส่วนรายได้?',
    answer: 'ไม่มีคำตอบตายตัว หากรายได้ใกล้เคียงกัน การแบ่งเท่ากันง่ายและโปร่งใส แต่หากรายได้ต่างกันมากกว่า 30% ขึ้นไป การแบ่งตามสัดส่วนรายได้จะยุติธรรมกว่า ลดความเครียดทางการเงินให้ฝ่ายที่รายได้น้อยกว่า',
  },
  {
    question: 'ค่าใช้จ่ายอะไรบ้างที่คู่รักควรแชร์ร่วมกัน?',
    answer: 'ค่าใช้จ่ายร่วมที่ควรแชร์ได้แก่ ค่าเช่า/ผ่อนบ้าน ค่าสาธารณูปโภค ค่าอาหารที่กินร่วมกัน ค่าท่องเที่ยวร่วม และค่าประกันสุขภาพครอบครัว ส่วนค่าใช้จ่ายส่วนตัวควรแยกกัน',
  },
  {
    question: 'ควรพูดคุยเรื่องเงินกับคู่รักเมื่อไหร่?',
    answer: 'ควรคุยเรื่องเงินตั้งแต่เริ่มอยู่ร่วมกันหรือวางแผนแต่งงาน หัวข้อสำคัญได้แก่ รายได้ หนี้สิน เป้าหมายการออม และปรัชญาการใช้เงิน การพูดคุยอย่างเปิดใจจะลดความขัดแย้งในอนาคต',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณแบ่งค่าใช้จ่ายคู่รัก',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณแบ่งค่าใช้จ่ายคู่รัก">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณแบ่งค่าใช้จ่ายคู่รัก 2569</h1>
    <p class="mb-6 text-gray-600">คำนวณว่าแต่ละฝ่ายควรจ่ายเท่าไรจากค่าใช้จ่ายร่วม ทั้งแบบเท่ากันและตามสัดส่วนรายได้ หากอยู่หลายคนดูได้ที่ <a href="/คำนวณแบ่งค่าใช้จ่ายครัวเรือน/" class="text-primary-600 underline hover:text-primary-800">คำนวณแบ่งค่าใช้จ่ายครัวเรือน</a> หรือ <a href="/คำนวณแบ่งบิลรูมเมท/" class="text-primary-600 underline hover:text-primary-800">คำนวณแบ่งบิลรูมเมท</a></p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="couple-form" class="space-y-4">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label for="income1" class="mb-1 block text-sm font-medium text-gray-700">รายได้คนที่ 1 (บาท/เดือน)</label>
            <input id="income1" type="text" inputmode="numeric" placeholder="เช่น 40000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="income2" class="mb-1 block text-sm font-medium text-gray-700">รายได้คนที่ 2 (บาท/เดือน)</label>
            <input id="income2" type="text" inputmode="numeric" placeholder="เช่น 30000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>
        <div>
          <label for="shared-exp" class="mb-1 block text-sm font-medium text-gray-700">ค่าใช้จ่ายร่วมรายเดือน (บาท)</label>
          <input id="shared-exp" type="text" inputmode="numeric" placeholder="เช่น 25000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label class="mb-2 block text-sm font-medium text-gray-700">วิธีแบ่ง</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="split-method" id="split-equal" value="equal" checked class="text-primary-600" />
              <span class="text-sm text-gray-700">แบ่งเท่ากัน</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="split-method" id="split-prop" value="proportional" class="text-primary-600" />
              <span class="text-sm text-gray-700">ตามสัดส่วนรายได้</span>
            </label>
          </div>
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid grid-cols-2 gap-4">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">คนที่ 1 จ่าย/เดือน</div>
            <div id="res-p1" class="text-3xl font-bold text-primary-700">-</div>
            <div id="res-p1-pct" class="mt-1 text-xs text-gray-500"></div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">คนที่ 2 จ่าย/เดือน</div>
            <div id="res-p2" class="text-3xl font-bold text-green-700">-</div>
            <div id="res-p2-pct" class="mt-1 text-xs text-gray-500"></div>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณแบ่งค่าใช้จ่ายคู่รัก/" categoryId="budget" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('couple-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const income1 = parseNum((document.getElementById('income1') as HTMLInputElement).value);
    const income2 = parseNum((document.getElementById('income2') as HTMLInputElement).value);
    const shared = parseNum((document.getElementById('shared-exp') as HTMLInputElement).value);
    const method = (document.querySelector('input[name="split-method"]:checked') as HTMLInputElement).value;

    let pay1: number, pay2: number, pct1: number, pct2: number;

    if (method === 'equal') {
      pay1 = shared / 2;
      pay2 = shared / 2;
      pct1 = 50;
      pct2 = 50;
    } else {
      const totalIncome = income1 + income2;
      if (totalIncome <= 0) return;
      pct1 = (income1 / totalIncome) * 100;
      pct2 = (income2 / totalIncome) * 100;
      pay1 = shared * (income1 / totalIncome);
      pay2 = shared * (income2 / totalIncome);
    }

    document.getElementById('res-p1')!.textContent = fmt(pay1);
    document.getElementById('res-p2')!.textContent = fmt(pay2);
    document.getElementById('res-p1-pct')!.textContent = pct1.toFixed(1) + '% ของค่าใช้จ่ายร่วม';
    document.getElementById('res-p2-pct')!.textContent = pct2.toFixed(1) + '% ของค่าใช้จ่ายร่วม';
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
