---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณค่าทางด่วน 2569 | ทางด่วนพิเศษ มอเตอร์เวย์ เปรียบเทียบเส้นทาง กทม. | เครื่องคำนวณไทย';
const pageDescription = 'เครื่องคำนวณค่าทางด่วนฟรี เลือกเส้นทาง ศรีรัช ดอนเมืองโทลล์เวย์ บูรพาวิถี กาญจนาภิเษก มอเตอร์เวย์ เปรียบเทียบค่าผ่านทางและเส้นทางถูกสุด อัปเดต 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าทางด่วน/`;

const faqData = [
  {
    question: 'ค่าทางด่วนปี 2569 ปรับขึ้นหรือไม่?',
    answer: 'อัตราค่าผ่านทางพิเศษ (EXAT) ปี 2569 ยังคงใช้อัตราเดิมตามประกาศล่าสุดของการทางพิเศษแห่งประเทศไทย สำหรับมอเตอร์เวย์ (DOH) อัตราค่าผ่านทางเป็นไปตามประกาศกรมทางหลวง ควรตรวจสอบก่อนเดินทางเพราะอาจมีการปรับปรุงระหว่างปี',
  },
  {
    question: 'Easy Pass ลดค่าทางด่วนได้เท่าไร?',
    answer: 'บัตร Easy Pass ไม่ได้ลดค่าผ่านทาง แต่ช่วยให้ผ่านด่านได้เร็วขึ้นโดยไม่ต้องจ่ายเงินสด ปัจจุบันบัตร Easy Pass ใช้ได้กับทางพิเศษของ EXAT และดอนเมืองโทลล์เวย์ สำหรับมอเตอร์เวย์ใช้ระบบ M-Pass ของกรมทางหลวง',
  },
  {
    question: 'ทางด่วนกับมอเตอร์เวย์ต่างกันอย่างไร?',
    answer: 'ทางด่วนพิเศษ (Expressway) ดูแลโดยการทางพิเศษแห่งประเทศไทย (EXAT) ส่วนใหญ่อยู่ในเขตกรุงเทพฯ ใช้บัตร Easy Pass มอเตอร์เวย์ (Motorway) ดูแลโดยกรมทางหลวง (DOH) เป็นทางหลวงพิเศษระหว่างเมือง ใช้ระบบ M-Pass ทั้งสองมีอัตราค่าผ่านทางและระบบเก็บเงินแยกกัน',
  },
  {
    question: 'รถจักรยานยนต์ขึ้นทางด่วนได้ไหม?',
    answer: 'รถจักรยานยนต์ไม่สามารถขึ้นทางพิเศษ (ทางด่วน) และมอเตอร์เวย์ได้ ห้ามตามกฎหมาย เนื่องจากเหตุผลด้านความปลอดภัย มีเฉพาะรถยนต์ 4 ล้อขึ้นไปเท่านั้นที่สามารถใช้ทางด่วนได้',
  },
  {
    question: 'วิธีเลือกเส้นทางด่วนที่ประหยัดที่สุด?',
    answer: 'เปรียบเทียบค่าผ่านทางระหว่างเส้นทางต่างๆ ด้วยเครื่องคำนวณนี้ บางเส้นทางอาจต้องผ่านหลายด่าน ทำให้ค่าใช้จ่ายรวมสูงกว่า แนะนำให้พิจารณาทั้งค่าทางด่วน ระยะทาง และเวลาประกอบกัน ในชั่วโมงเร่งด่วนทางด่วนอาจประหยัดเวลาได้มากแม้เสียค่าผ่านทาง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าทางด่วน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าทางด่วน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <!-- Info banner -->
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ข้อมูลสำคัญ</p>
      <p class="mt-1 text-sm text-slate-700">
        อัตราค่าผ่านทางตามประกาศการทางพิเศษแห่งประเทศไทย (EXAT) และกรมทางหลวง (DOH) — ครอบคลุม 8 ทางด่วนและมอเตอร์เวย์ในเขตกรุงเทพฯ และปริมณฑล
      </p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณค่าทางด่วน เปรียบเทียบเส้นทาง กทม.
    </h1>

    <p class="text-gray-600 mb-6">
      เลือกเส้นทางทางด่วนหรือมอเตอร์เวย์ ประเภทรถ และจุดขึ้น-ลง เพื่อคำนวณค่าผ่านทาง พร้อมเปรียบเทียบหลายเส้นทาง
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <!-- Expressway selection -->
      <div class="mb-5">
        <label for="expressway" class="block text-sm font-medium text-gray-700 mb-1">
          เลือกทางด่วน / มอเตอร์เวย์
        </label>
        <select
          id="expressway"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
        >
          <optgroup label="ทางพิเศษ (EXAT)">
            <option value="chalerm">ทางด่วนเฉลิมมหานคร (ดินแดง–บางนา)</option>
            <option value="sirat">ทางด่วนศรีรัช (แจ้งวัฒนะ–พระราม 9)</option>
            <option value="sirat-outer">ศรีรัช–วงแหวนรอบนอก (บางพลี–สุขสวัสดิ์)</option>
            <option value="chalong">ทางด่วนฉลองรัช (รามอินทรา–อาจณรงค์)</option>
            <option value="burapha">ทางด่วนบูรพาวิถี (บางนา–ชลบุรี)</option>
            <option value="kanchanaphisek">ทางด่วนกาญจนาภิเษก (บางพลี–บางขุนเทียน)</option>
          </optgroup>
          <optgroup label="ดอนเมืองโทลล์เวย์">
            <option value="donmuang">ดอนเมืองโทลล์เวย์ (ดินแดง–ดอนเมือง)</option>
          </optgroup>
          <optgroup label="มอเตอร์เวย์ (DOH)">
            <option value="motorway7">มอเตอร์เวย์ 7 (กรุงเทพ–ชลบุรี–พัทยา)</option>
          </optgroup>
        </select>
      </div>

      <!-- Vehicle type -->
      <div class="mb-5">
        <label for="vehicle-type" class="block text-sm font-medium text-gray-700 mb-1">
          ประเภทรถ
        </label>
        <select
          id="vehicle-type"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
        >
          <option value="0">รถ 4 ล้อ (รถเก๋ง, กระบะ, SUV)</option>
          <option value="1">รถ 6–10 ล้อ (รถบรรทุก, รถบัส)</option>
          <option value="2">รถมากกว่า 10 ล้อ (รถพ่วง, รถบรรทุกหนัก)</option>
        </select>
      </div>

      <!-- Entry point -->
      <div class="mb-5">
        <label for="entry-point" class="block text-sm font-medium text-gray-700 mb-1">
          ด่านขาเข้า (จุดขึ้น)
        </label>
        <select
          id="entry-point"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
        >
          <option value="">-- เลือกด่านขาเข้า --</option>
        </select>
      </div>

      <!-- Exit point -->
      <div class="mb-5">
        <label for="exit-point" class="block text-sm font-medium text-gray-700 mb-1">
          ด่านขาออก (จุดลง)
        </label>
        <select
          id="exit-point"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
        >
          <option value="">-- เลือกด่านขาออก --</option>
        </select>
      </div>

      <!-- Calculate Button -->
      <button
        type="button"
        id="btn-calculate"
        class="w-full px-6 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณค่าทางด่วน
      </button>

      <!-- Results -->
      <div id="toll-result" class="hidden mt-6">
        <!-- Toll amount -->
        <div class="text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ค่าผ่านทาง</div>
          <div id="res-toll" class="text-4xl sm:text-5xl font-bold text-primary-700 mb-1">-</div>
          <div id="res-route-name" class="text-sm text-gray-500"></div>
        </div>

        <!-- Route details -->
        <div class="grid gap-3 sm:grid-cols-2 mb-4">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-gray-600 mb-1">ทางด่วน</div>
            <div id="res-expressway" class="text-base font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4">
            <div class="text-sm text-gray-600 mb-1">ผู้ดำเนินการ</div>
            <div id="res-operator" class="text-base font-bold text-green-700">-</div>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-3 mb-4">
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-sm text-gray-600 mb-1">ประเภทรถ</div>
            <div id="res-vehicle" class="text-sm font-bold text-gray-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-sm text-gray-600 mb-1">จุดขึ้น</div>
            <div id="res-entry" class="text-sm font-bold text-gray-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-sm text-gray-600 mb-1">จุดลง</div>
            <div id="res-exit" class="text-sm font-bold text-gray-700">-</div>
          </div>
        </div>

        <!-- Rate table for all vehicle types on this route -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
          <h3 class="text-sm font-semibold text-gray-700 mb-2">อัตราค่าผ่านทางเส้นทางนี้ (ทุกประเภทรถ)</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-gray-500 border-b border-gray-200">
                  <th class="py-2 pr-4">ประเภทรถ</th>
                  <th class="py-2 text-right">ค่าผ่านทาง (บาท)</th>
                </tr>
              </thead>
              <tbody id="res-rate-table" class="text-gray-700"></tbody>
            </table>
          </div>
        </div>

        <!-- Payment info -->
        <div class="bg-amber-50 rounded-lg p-4 mb-4">
          <h3 class="text-sm font-semibold text-amber-700 mb-2">ระบบชำระเงิน</h3>
          <div id="res-payment" class="text-sm text-amber-600"></div>
        </div>
      </div>

      <!-- Route comparison section -->
      <div class="mt-6 border-t border-gray-200 pt-6">
        <h3 class="text-base font-semibold text-gray-900 mb-3">เปรียบเทียบเส้นทาง</h3>
        <p class="text-sm text-gray-500 mb-3">กดปุ่ม "เพิ่มเส้นทาง" เพื่อบันทึกผลลัพธ์แล้วเปรียบเทียบหลายเส้นทาง</p>
        <button
          type="button"
          id="btn-add-compare"
          class="px-4 py-2 border border-primary-600 text-primary-600 font-medium rounded-md hover:bg-primary-50 transition-colors text-sm mb-3"
        >
          + เพิ่มเส้นทางเปรียบเทียบ
        </button>
        <button
          type="button"
          id="btn-clear-compare"
          class="hidden px-4 py-2 border border-red-400 text-red-500 font-medium rounded-md hover:bg-red-50 transition-colors text-sm mb-3 ml-2"
        >
          ล้างทั้งหมด
        </button>
        <div id="compare-list" class="space-y-2"></div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">อัตราค่าทางด่วนปี 2569</h2>

      <p>
        ทางด่วนในประเทศไทยแบ่งเป็น 2 ระบบหลัก คือทางพิเศษของการทางพิเศษแห่งประเทศไทย (EXAT) และมอเตอร์เวย์ของกรมทางหลวง (DOH)
        อัตราค่าผ่านทางขึ้นอยู่กับเส้นทาง ระยะทาง และประเภทรถ
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ทางพิเศษ EXAT ในกรุงเทพฯ</h3>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b border-gray-200">
              <th class="py-2 pr-4">ทางด่วน</th>
              <th class="py-2 pr-4">เส้นทาง</th>
              <th class="py-2">ค่าผ่านทาง 4 ล้อ (บาท)</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">เฉลิมมหานคร</td>
              <td class="py-2 pr-4">ดินแดง–บางนา</td>
              <td class="py-2">25–50</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ศรีรัช</td>
              <td class="py-2 pr-4">แจ้งวัฒนะ–พระราม 9</td>
              <td class="py-2">25–80</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ฉลองรัช</td>
              <td class="py-2 pr-4">รามอินทรา–อาจณรงค์</td>
              <td class="py-2">25–55</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ดอนเมืองโทลล์เวย์</td>
              <td class="py-2 pr-4">ดินแดง–อนุสรณ์สถาน</td>
              <td class="py-2">35–90</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">บูรพาวิถี</td>
              <td class="py-2 pr-4">บางนา–ชลบุรี</td>
              <td class="py-2">15–50</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">กาญจนาภิเษก</td>
              <td class="py-2 pr-4">บางพลี–บางขุนเทียน</td>
              <td class="py-2">25–55</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">ศรีรัช–วงแหวนฯ</td>
              <td class="py-2 pr-4">บางพลี–สุขสวัสดิ์</td>
              <td class="py-2">25–50</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">มอเตอร์เวย์ (กรมทางหลวง)</h3>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b border-gray-200">
              <th class="py-2 pr-4">มอเตอร์เวย์</th>
              <th class="py-2 pr-4">เส้นทาง</th>
              <th class="py-2">ค่าผ่านทาง 4 ล้อ (บาท)</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr>
              <td class="py-2 pr-4">มอเตอร์เวย์ 7</td>
              <td class="py-2 pr-4">กรุงเทพ–ชลบุรี–พัทยา</td>
              <td class="py-2">30–135</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ระบบชำระเงินค่าทางด่วน</h3>

      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>เงินสด</strong> — ชำระที่ด่านเก็บเงิน (ทุกทางด่วน)</li>
        <li><strong>Easy Pass</strong> — บัตรอิเล็กทรอนิกส์ของ EXAT ใช้กับทางพิเศษและดอนเมืองโทลล์เวย์</li>
        <li><strong>M-Pass</strong> — ระบบเก็บค่าผ่านทางอัตโนมัติของกรมทางหลวง ใช้กับมอเตอร์เวย์</li>
        <li><strong>M-Flow</strong> — ระบบเก็บเงินแบบไร้ไม้กั้น ใช้กับมอเตอร์เวย์บางช่วง</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการคำนวณ</h3>

      <p>ตัวอย่าง: ขับรถเก๋ง (4 ล้อ) จากดินแดงไปบางนา ผ่านทางด่วนเฉลิมมหานคร:</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ด่านขาเข้า: ดินแดง</li>
        <li>ด่านขาออก: บางนา</li>
        <li>ค่าผ่านทาง: 50 บาท (รถ 4 ล้อ)</li>
        <li>ชำระได้ด้วยเงินสดหรือ Easy Pass</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณค่าทางด่วน/" />
    <RelatedCalculators currentHref="/คำนวณค่าทางด่วน/" />

    <!-- Disclaimer -->
