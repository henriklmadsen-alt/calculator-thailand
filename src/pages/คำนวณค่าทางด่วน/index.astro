---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณค่าทางด่วน | ค่าผ่านด่านทางหลวง | ฟรี | Calculator Thailand';
const pageDescription = 'คำนวณค่าทางด่วน ค่าผ่านด่านทางหลวง ตามปลายทางแต่ละสาย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าทางด่วน/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าทางด่วน">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าทางด่วน</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2">
      <p class="text-xs font-semibold text-blue-800">[ปี 2569]</p>
    </div>
    <p class="text-gray-600 mb-6">คำนวณค่าผ่านด่านทางหลวง ตามเส้นทางและประเภทรถ</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-3 mb-6">
        <div>
          <label for="route" class="block text-sm font-medium text-gray-700 mb-1">เส้นทาง</label>
          <select id="route" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500">
            <option value="bangkok-pattaya">กทม-พัทยา</option>
            <option value="bangkok-prachuab">กทม-ประจวบฯ</option>
            <option value="bangkok-lopburi">กทม-ลพบุรี</option>
          </select>
        </div>
        <div>
          <label for="vehicleType" class="block text-sm font-medium text-gray-700 mb-1">ประเภทรถ</label>
          <select id="vehicleType" class="w-full px-3 py-2 border border-gray-300 rounded-md">
            <option value="car">รถเก๋ง</option>
            <option value="motorcycle">มอเตอร์ไซค์</option>
            <option value="truck">รถบรรทุก</option>
          </select>
        </div>
        <div>
          <label for="trips" class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้ง</label>
          <input type="number" id="trips" min="1" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" />
        </div>
      </div>
      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white rounded-md">คำนวณ</button>
      <div id="result" class="hidden mt-6 p-4 bg-blue-50 rounded-lg">
        <div class="flex justify-between"><span>ค่าต่อครั้ง</span><span id="perTrip">-</span></div>
        <div class="flex justify-between"><span>รวม</span><span id="total" class="text-lg font-bold text-primary-600">-</span></div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  import { calculateTollFee } from '../../lib/toll-fee-calculator';
  document.getElementById('btn-calculate').addEventListener('click', () => {
    const result = calculateTollFee({
      route: document.getElementById('route').value as any,
      vehicleType: document.getElementById('vehicleType').value as any,
      trips: parseInt(document.getElementById('trips').value)
    });
    document.getElementById('perTrip').textContent = result.feePerTrip.toLocaleString('th-TH') + ' บาท';
    document.getElementById('total').textContent = result.totalFee.toLocaleString('th-TH') + ' บาท';
    document.getElementById('result').classList.remove('hidden');
  });
</script>
