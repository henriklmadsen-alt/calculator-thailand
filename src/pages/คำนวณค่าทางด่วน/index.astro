    const vehicleLabels = ['รถ 4 ล้อ', 'รถ 6–10 ล้อ', 'รถมากกว่า 10 ล้อ'];

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    // Populate entry/exit dropdowns when expressway changes
    function populateGates() {
      const ewKey = (document.getElementById('expressway') as HTMLSelectElement).value;
      const ew = expressways[ewKey];
      if (!ew) return;

      const entrySelect = document.getElementById('entry-point') as HTMLSelectElement;
      const exitSelect = document.getElementById('exit-point') as HTMLSelectElement;

      entrySelect.innerHTML = '<option value="">-- เลือกด่านขาเข้า --</option>';
      exitSelect.innerHTML = '<option value="">-- เลือกด่านขาออก --</option>';

      for (const gate of ew.gates) {
        entrySelect.add(new Option(gate, gate));
        exitSelect.add(new Option(gate, gate));
      }
    }

    function findRoute(ewKey: string, entry: string, exit: string): TollRoute | null {
      const ew = expressways[ewKey];
      if (!ew) return null;
      // Try both directions
      return (
        ew.routes.find((r) => r.entry === entry && r.exit === exit) ||
        ew.routes.find((r) => r.entry === exit && r.exit === entry) ||
        null
      );
    }

    let lastResult: { ewKey: string; entry: string; exit: string; vehicleIdx: number; toll: number } | null = null;

    function calculate() {
      const ewKey = (document.getElementById('expressway') as HTMLSelectElement).value;
      const vehicleIdx = parseInt((document.getElementById('vehicle-type') as HTMLSelectElement).value);
      const entry = (document.getElementById('entry-point') as HTMLSelectElement).value;
      const exit = (document.getElementById('exit-point') as HTMLSelectElement).value;

      if (!entry || !exit) {
        alert('กรุณาเลือกด่านขาเข้าและด่านขาออก');
        return;
      }
      if (entry === exit) {
        alert('ด่านขาเข้าและด่านขาออกต้องไม่เหมือนกัน');
        return;
      }

      const ew = expressways[ewKey];
      const route = findRoute(ewKey, entry, exit);

      if (!route) {
        alert('ไม่พบข้อมูลค่าผ่านทางสำหรับเส้นทางนี้ กรุณาเลือกด่านอื่น');
        return;
      }

      const toll = route.rates[vehicleIdx];
      lastResult = { ewKey, entry, exit, vehicleIdx, toll };

      // Update DOM
      const resultEl = document.getElementById('toll-result') as HTMLDivElement;
      resultEl.classList.remove('hidden');

      (document.getElementById('res-toll') as HTMLElement).textContent = `${fmt(toll)} บาท`;
      (document.getElementById('res-route-name') as HTMLElement).textContent = `${entry} → ${exit}`;
      (document.getElementById('res-expressway') as HTMLElement).textContent = ew.name;
      (document.getElementById('res-operator') as HTMLElement).textContent = ew.operator;
      (document.getElementById('res-vehicle') as HTMLElement).textContent = vehicleLabels[vehicleIdx];
      (document.getElementById('res-entry') as HTMLElement).textContent = entry;
      (document.getElementById('res-exit') as HTMLElement).textContent = exit;

      // Rate table for all vehicle types
      const tbody = document.getElementById('res-rate-table') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      for (let i = 0; i < 3; i++) {
        const tr = document.createElement('tr');
        tr.className = i < 2 ? 'border-b border-gray-100' : '';
        const isSelected = i === vehicleIdx;
        tr.innerHTML = `
          <td class="py-2 pr-4 ${isSelected ? 'font-bold text-primary-700' : ''}">${vehicleLabels[i]}${isSelected ? ' ✓' : ''}</td>
          <td class="py-2 text-right ${isSelected ? 'font-bold text-primary-700' : ''}">${fmt(route.rates[i])}</td>
        `;
        tbody.appendChild(tr);
      }

      // Payment info
      (document.getElementById('res-payment') as HTMLElement).textContent = ew.payment;

      trackCalculatorUsed('toll');
    }

    // ── Route comparison ──
    interface CompareItem {
      expressway: string;
      entry: string;
      exit: string;
      vehicle: string;
      toll: number;
    }

    const compareItems: CompareItem[] = [];

    function renderCompare() {
      const list = document.getElementById('compare-list') as HTMLDivElement;
      const clearBtn = document.getElementById('btn-clear-compare') as HTMLButtonElement;

      if (compareItems.length === 0) {
        list.innerHTML = '';
        clearBtn.classList.add('hidden');
        return;
      }

      clearBtn.classList.remove('hidden');
      const cheapest = Math.min(...compareItems.map((c) => c.toll));

      list.innerHTML = compareItems
        .map(
          (item, idx) => `
        <div class="flex items-center justify-between p-3 rounded-lg border ${item.toll === cheapest ? 'border-green-300 bg-green-50' : 'border-gray-200 bg-gray-50'}">
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium text-gray-900 truncate">${item.expressway}</div>
            <div class="text-xs text-gray-500">${item.entry} → ${item.exit} · ${item.vehicle}</div>
          </div>
          <div class="flex items-center gap-2 ml-3">
            <span class="text-lg font-bold ${item.toll === cheapest ? 'text-green-700' : 'text-gray-700'}">${fmt(item.toll)} ฿</span>
            ${item.toll === cheapest ? '<span class="text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded">ถูกสุด</span>' : ''}
            <button type="button" data-remove="${idx}" class="text-gray-400 hover:text-red-500 text-lg leading-none" aria-label="ลบ">&times;</button>
          </div>
        </div>
      `,
        )
        .join('');

      // Attach remove listeners
      list.querySelectorAll('[data-remove]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const i = parseInt((btn as HTMLElement).dataset.remove!);
          compareItems.splice(i, 1);
          renderCompare();
        });
      });
    }

    document.getElementById('btn-add-compare')!.addEventListener('click', () => {
      if (!lastResult) {
        alert('กรุณาคำนวณค่าทางด่วนก่อน แล้วค่อยเพิ่มเส้นทางเปรียบเทียบ');
        return;
      }
      const ew = expressways[lastResult.ewKey];
      compareItems.push({
        expressway: ew.name,
        entry: lastResult.entry,
        exit: lastResult.exit,
        vehicle: vehicleLabels[lastResult.vehicleIdx],
        toll: lastResult.toll,
      });
      renderCompare();
    });

    document.getElementById('btn-clear-compare')!.addEventListener('click', () => {
      compareItems.length = 0;
      renderCompare();
    });

    // ── Event listeners ──
    document.getElementById('expressway')!.addEventListener('change', populateGates);
    document.getElementById('btn-calculate')!.addEventListener('click', calculate);

    // Initialize gates on page load
    populateGates();

    // Track when result section enters viewport
    const tollResultObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            trackResultViewed('toll');
            tollResultObserver.disconnect();
          }
        });
      },
      { threshold: 0.5 },
    );
    tollResultObserver.observe(document.getElementById('toll-result')!);
  </script>
</BaseLayout>
