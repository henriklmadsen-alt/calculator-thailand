---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพนายจ้าง อัตรา 2-15% รวม PVD ปี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพ (PVD) ฝั่งนายจ้าง อัตราสมทบ 2-15% คำนวณเงินสมทบพนักงาน นายจ้าง และรวม PVD ต่อเดือนและต่อปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพนายจ้าง/`;

const faqData = [
  {
    question: 'นายจ้างต้องสมทบกองทุน PVD เท่าไร?',
    answer: 'นายจ้างต้องสมทบอย่างน้อยเท่ากับพนักงาน (ไม่ต่ำกว่า 2%) และสูงสุดไม่เกิน 15% ของค่าจ้าง นายจ้างสามารถกำหนดอัตราที่สูงกว่าพนักงานเพื่อจูงใจพนักงานได้',
  },
  {
    question: 'เงินสมทบนายจ้างนำมาหักภาษีได้หรือไม่?',
    answer: 'เงินสมทบของนายจ้างเข้ากองทุน PVD สามารถนำมาหักเป็นค่าใช้จ่ายได้ ไม่เกิน 15% ของค่าจ้างลูกจ้างและไม่เกิน 500,000 บาทต่อลูกจ้างหนึ่งคนต่อปี',
  },
  {
    question: 'อัตราสมทบนายจ้างต้องเท่ากับพนักงานเสมอหรือไม่?',
    answer: 'ไม่จำเป็น นายจ้างสมทบได้ตั้งแต่ขั้นต่ำเท่ากับพนักงาน และสูงสุดถึง 15% โดยนายจ้างบางรายเลือกสมทบสูงกว่าพนักงานเพื่อเป็นสวัสดิการและดึงดูดพนักงาน',
  },
  {
    question: 'ถ้าลาออกก่อนกำหนด พนักงานได้รับเงินสมทบนายจ้างเท่าไร?',
    answer: 'ขึ้นอยู่กับอายุงานและข้อบังคับกองทุน โดยทั่วไปหากอายุงานน้อยกว่า 5 ปีอาจได้รับเงินสมทบนายจ้างบางส่วน และครบ 5 ปีขึ้นไปมักได้รับเต็มจำนวน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพนายจ้าง',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพนายจ้าง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">🏢 กองทุนสำรองเลี้ยงชีพนายจ้าง (PVD) อัตรา 2-15%</p>
      <p class="mt-1 text-sm text-slate-700">นายจ้างสมทบอย่างน้อยเท่ากับพนักงาน สูงสุดไม่เกิน 15% ของค่าจ้าง</p>
      <p class="mt-1 text-xs font-medium text-sky-800">คำนวณต้นทุน PVD รวมทั้งฝั่งพนักงานและนายจ้างต่อเดือนและต่อปี</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพนายจ้าง ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือน อัตราสมทบพนักงาน และอัตราสมทบนายจ้าง ระบบจะคำนวณเงินสมทบแต่ละฝ่ายและยอดรวม PVD ทั้งหมด
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="pvd-er-form" class="space-y-5">
        <p id="pvd-er-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="pvder-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือน (บาท/เดือน)</label>
            <input type="text" id="pvder-salary" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="pvder-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="pvder-emp-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราสมทบพนักงาน (%)</label>
            <input type="text" id="pvder-emp-rate" inputmode="decimal" placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">2-15%</p>
            <p id="pvder-emp-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="pvder-er-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราสมทบนายจ้าง (%)</label>
            <input type="text" id="pvder-er-rate" inputmode="decimal" placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">ขั้นต่ำเท่ากับพนักงาน สูงสุด 15%</p>
            <p id="pvder-er-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณเงินสมทบ PVD
        </button>
      </form>
    </div>

    <div id="pvd-er-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">พนักงานสมทบ/เดือน</div>
            <div id="res-pvder-emp-monthly" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">นายจ้างสมทบ/เดือน</div>
            <div id="res-pvder-er-monthly" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รวม PVD/เดือน</div>
            <div id="res-pvder-total-monthly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รวม PVD/ปี</div>
            <div id="res-pvder-total-annual" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">พนักงานสมทบรายปี</span>
            <span id="res-pvder-emp-annual" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">นายจ้างสมทบรายปี</span>
            <span id="res-pvder-er-annual" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>เงินสมทบพนักงาน/เดือน = เงินเดือน × อัตราสมทบพนักงาน ÷ 100</li>
        <li>เงินสมทบนายจ้าง/เดือน = เงินเดือน × อัตราสมทบนายจ้าง ÷ 100</li>
        <li>รวม PVD/เดือน = เงินสมทบพนักงาน + เงินสมทบนายจ้าง</li>
        <li>รวม PVD/ปี = รวม PVD/เดือน × 12</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน/">คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน</a></li>
        <li><a href="/คำนวณต้นทุนพนักงานรายเดือน/">คำนวณต้นทุนพนักงานรายเดือน</a></li>
        <li><a href="/คำนวณลดหย่อนกองทุนสำรองเลี้ยงชีพ/">คำนวณลดหย่อนกองทุนสำรองเลี้ยงชีพ</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#pvd-er-results" />
    <RelatedArticles currentHref="/คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพนายจ้าง/" />
    <RelatedCalculators currentHref="/คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพนายจ้าง/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการเบื้องต้น อัตราสมทบจริงขึ้นอยู่กับข้อบังคับกองทุนและนโยบายบริษัท กรุณาตรวจสอบกับฝ่ายทรัพยากรบุคคลและที่ปรึกษากองทุนของบริษัท
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }
    function setErr(id, msg) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.toggle('hidden', !msg);
    }

    const form = document.getElementById('pvd-er-form');
    const formError = document.getElementById('pvd-er-form-error');
    const resultBox = document.getElementById('pvd-er-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['pvder-salary-error', 'pvder-emp-rate-error', 'pvder-er-rate-error'].forEach((id) => setErr(id, ''));

      const salary = parseNum(document.getElementById('pvder-salary').value);
      const empRate = parseNum(document.getElementById('pvder-emp-rate').value);
      const erRate = parseNum(document.getElementById('pvder-er-rate').value);

      let hasError = false;
      if (!Number.isFinite(salary) || salary <= 0) { setErr('pvder-salary-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(empRate) || empRate < 2 || empRate > 15) { setErr('pvder-emp-rate-error', 'กรอกอัตราพนักงาน 2-15%'); hasError = true; }
      if (!Number.isFinite(erRate) || erRate < 2 || erRate > 15) { setErr('pvder-er-rate-error', 'กรอกอัตรานายจ้าง 2-15%'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const empMonthly = salary * (empRate / 100);
      const erMonthly = salary * (erRate / 100);
      const totalMonthly = empMonthly + erMonthly;
      const totalAnnual = totalMonthly * 12;

      setText('res-pvder-emp-monthly', formatMoney(empMonthly));
      setText('res-pvder-er-monthly', formatMoney(erMonthly));
      setText('res-pvder-total-monthly', formatMoney(totalMonthly));
      setText('res-pvder-total-annual', formatMoney(totalAnnual));
      setText('res-pvder-emp-annual', formatMoney(empMonthly * 12));
      setText('res-pvder-er-annual', formatMoney(erMonthly * 12));

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
