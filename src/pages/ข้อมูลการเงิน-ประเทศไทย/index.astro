---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'ข้อมูลการเงินประเทศไทย 2569 — อัตรา ฐาน และสถิติทางการ | Kamnuanlek';
const pageDescription = 'รวมข้อมูลการเงินไทยที่สำคัญ: อัตราภาษี ค่าแรงขั้นต่ำ ประกันสังคม ดอกเบี้ย อัพเดตปี 2569 จากแหล่งข้อมูลทางการ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/ข้อมูลการเงิน-ประเทศไทย/`;

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าหลัก', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'ข้อมูลการเงินประเทศไทย 2569', item: canonical },
  ],
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'อัตราภาษีเงินได้บุคคลธรรมดาปี 2569 มีกี่ขั้น?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ปี 2569 มี 8 ขั้น: 0% (ไม่เกิน 150,000 บาท), 5% (150,001–300,000), 10% (300,001–500,000), 15% (500,001–750,000), 20% (750,001–1,000,000), 25% (1,000,001–2,000,000), 30% (2,000,001–5,000,000), 35% (เกิน 5,000,000 บาท) ตามประมวลรัษฎากรที่กรมสรรพากรกำหนด',
      },
    },
    {
      '@type': 'Question',
      name: 'ค่าแรงขั้นต่ำกรุงเทพ 2569 เท่าไร?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ค่าแรงขั้นต่ำในกรุงเทพมหานครและปริมณฑลปี 2569 อยู่ที่ 400 บาทต่อวัน ตามประกาศกระทรวงแรงงาน ส่วนภาคกลางและจังหวัดอื่นอยู่ที่ 370–395 บาทต่อวัน',
      },
    },
    {
      '@type': 'Question',
      name: 'เงินสมทบประกันสังคมมาตรา 33 ปี 2569 จ่ายเท่าไร?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ลูกจ้างมาตรา 33 จ่ายเงินสมทบ 5% ของเงินเดือน สูงสุด 750 บาทต่อเดือน นายจ้างจ่ายเพิ่มอีก 5% และรัฐบาลสมทบ 2.75% ฐานค่าจ้างอยู่ระหว่าง 1,650–15,000 บาทต่อเดือน',
      },
    },
    {
      '@type': 'Question',
      name: 'อัตราดอกเบี้ยนโยบาย ธปท. ปัจจุบันเท่าไร?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'อัตราดอกเบี้ยนโยบายของธนาคารแห่งประเทศไทย (ธปท.) ในปี 2569 อยู่ที่ 2.50% ต่อปี ส่วนอัตรา MRR (Minimum Retail Rate) ของธนาคารพาณิชย์ทั่วไปอยู่ในช่วง 7–8% และ MLR (Minimum Lending Rate) อยู่ที่ 5–6%',
      },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />  <div class="max-w-4xl mx-auto">

    <nav class="text-xs text-gray-500 mb-4">
      <a href="/" class="hover:text-primary-600">หน้าหลัก</a>
      <span class="mx-1">›</span>
      <span class="text-gray-700">ข้อมูลการเงินประเทศไทย 2569</span>
    </nav>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">
      ข้อมูลการเงินประเทศไทย 2569
    </h1>
    <p class="text-gray-600 mb-2 text-sm">
      รวมอัตรา ฐาน และสถิติทางการที่นักบัญชี HR นักการเงิน และประชาชนทั่วไปค้นหาบ่อยที่สุด
      อัปเดตตามประกาศทางการล่าสุดปี 2569
    </p>
    <p class="text-xs text-gray-400 mb-8">
      แหล่งอ้างอิง:
      <a href="https://www.rd.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">กรมสรรพากร</a>,
      <a href="https://www.sso.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สำนักงานประกันสังคม</a>,
      <a href="https://www.mol.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">กระทรวงแรงงาน</a>,
      <a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ธนาคารแห่งประเทศไทย</a>
      — อัปเดต เม.ย. 2569
    </p>

    <div class="space-y-10">

      <!-- Section 1: Personal Income Tax Brackets -->
      <section id="อัตราภาษีเงินได้">
        <h2 class="text-xl font-bold text-gray-900 mb-1">1. ภาษีเงินได้บุคคลธรรมดา ปี 2569</h2>
        <p class="text-sm text-gray-600 mb-3">
          ระบบภาษีแบบขั้นบันได (Progressive Tax) ตาม
          <a href="https://www.rd.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ประมวลรัษฎากร กรมสรรพากร</a>
        </p>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-amber-50 text-amber-900">
              <tr>
                <th class="px-4 py-2.5 text-left font-semibold">รายได้สุทธิ (บาท/ปี)</th>
                <th class="px-4 py-2.5 text-right font-semibold">อัตราภาษี</th>
                <th class="px-4 py-2.5 text-right font-semibold">ภาษีสูงสุดในขั้น (บาท)</th>
                <th class="px-4 py-2.5 text-right font-semibold">ภาษีสะสม (บาท)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="bg-white"><td class="px-4 py-2 text-gray-700">0 – 150,000</td><td class="px-4 py-2 text-right font-bold text-green-600">0% (ยกเว้น)</td><td class="px-4 py-2 text-right text-gray-500">0</td><td class="px-4 py-2 text-right text-gray-500">0</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">150,001 – 300,000</td><td class="px-4 py-2 text-right font-bold text-primary-600">5%</td><td class="px-4 py-2 text-right text-gray-600">7,500</td><td class="px-4 py-2 text-right text-gray-600">7,500</td></tr>
              <tr class="bg-white"><td class="px-4 py-2 text-gray-700">300,001 – 500,000</td><td class="px-4 py-2 text-right font-bold text-primary-600">10%</td><td class="px-4 py-2 text-right text-gray-600">20,000</td><td class="px-4 py-2 text-right text-gray-600">27,500</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">500,001 – 750,000</td><td class="px-4 py-2 text-right font-bold text-primary-600">15%</td><td class="px-4 py-2 text-right text-gray-600">37,500</td><td class="px-4 py-2 text-right text-gray-600">65,000</td></tr>
              <tr class="bg-white"><td class="px-4 py-2 text-gray-700">750,001 – 1,000,000</td><td class="px-4 py-2 text-right font-bold text-orange-600">20%</td><td class="px-4 py-2 text-right text-gray-600">50,000</td><td class="px-4 py-2 text-right text-gray-600">115,000</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">1,000,001 – 2,000,000</td><td class="px-4 py-2 text-right font-bold text-orange-600">25%</td><td class="px-4 py-2 text-right text-gray-600">250,000</td><td class="px-4 py-2 text-right text-gray-600">365,000</td></tr>
              <tr class="bg-white"><td class="px-4 py-2 text-gray-700">2,000,001 – 5,000,000</td><td class="px-4 py-2 text-right font-bold text-red-600">30%</td><td class="px-4 py-2 text-right text-gray-600">900,000</td><td class="px-4 py-2 text-right text-gray-600">1,265,000</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">5,000,001 ขึ้นไป</td><td class="px-4 py-2 text-right font-bold text-red-700">35%</td><td class="px-4 py-2 text-right text-gray-600">—</td><td class="px-4 py-2 text-right text-gray-600">—</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-500 mt-2">* คำนวณจากรายได้สุทธิหลังหักค่าใช้จ่ายและค่าลดหย่อนทั้งหมด</p>
        <div class="mt-3">
          <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700">
            คำนวณภาษีเงินได้บุคคลธรรมดา →
          </a>
        </div>
      </section>

      <!-- Section 2: Minimum Wage -->
      <section id="ค่าแรงขั้นต่ำ">
        <h2 class="text-xl font-bold text-gray-900 mb-1">2. ค่าแรงขั้นต่ำ ปี 2569</h2>
        <p class="text-sm text-gray-600 mb-3">
          ตามประกาศ
          <a href="https://www.mol.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">กระทรวงแรงงาน (mol.go.th)</a>
          อัปเดตล่าสุด
        </p>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-blue-50 text-blue-900">
              <tr>
                <th class="px-4 py-2.5 text-left font-semibold">ภูมิภาค / จังหวัด</th>
                <th class="px-4 py-2.5 text-right font-semibold">ค่าแรงขั้นต่ำ (บาท/วัน)</th>
                <th class="px-4 py-2.5 text-right font-semibold">โดยประมาณ (บาท/เดือน)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="bg-white"><td class="px-4 py-2 font-medium text-gray-800">กรุงเทพมหานคร และปริมณฑล</td><td class="px-4 py-2 text-right font-bold text-blue-700">400</td><td class="px-4 py-2 text-right text-gray-600">~10,400</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">ภาคกลาง (นนทบุรี ปทุมธานี อยุธยา ฯลฯ)</td><td class="px-4 py-2 text-right font-semibold text-gray-800">395</td><td class="px-4 py-2 text-right text-gray-600">~10,270</td></tr>
              <tr class="bg-white"><td class="px-4 py-2 text-gray-700">ภาคตะวันออก (ชลบุรี ระยอง ฯลฯ)</td><td class="px-4 py-2 text-right font-semibold text-gray-800">390</td><td class="px-4 py-2 text-right text-gray-600">~10,140</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">ภาคใต้ (ภูเก็ต สุราษฎร์ธานี ฯลฯ)</td><td class="px-4 py-2 text-right font-semibold text-gray-800">380</td><td class="px-4 py-2 text-right text-gray-600">~9,880</td></tr>
              <tr class="bg-white"><td class="px-4 py-2 text-gray-700">ภาคเหนือ (เชียงใหม่ เชียงราย ฯลฯ)</td><td class="px-4 py-2 text-right font-semibold text-gray-800">375</td><td class="px-4 py-2 text-right text-gray-600">~9,750</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">ภาคตะวันออกเฉียงเหนือ (ขอนแก่น อุดร ฯลฯ)</td><td class="px-4 py-2 text-right font-semibold text-gray-800">370</td><td class="px-4 py-2 text-right text-gray-600">~9,620</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-500 mt-2">* คำนวณโดยประมาณ 26 วันทำงาน/เดือน — ตรวจสอบอัตราล่าสุดจากกระทรวงแรงงานโดยตรง</p>
        <div class="mt-3">
          <a href="/คำนวณเงินเดือนสุทธิ/" class="inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700">
            คำนวณเงินเดือนสุทธิ →
          </a>
        </div>
      </section>

      <!-- Section 3: Social Security -->
      <section id="ประกันสังคม">
        <h2 class="text-xl font-bold text-gray-900 mb-1">3. อัตราประกันสังคม ปี 2569</h2>
        <p class="text-sm text-gray-600 mb-3">
          ตาม
          <a href="https://www.sso.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">พระราชบัญญัติประกันสังคม สำนักงานประกันสังคม (sso.go.th)</a>
        </p>
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-lg border border-green-200 bg-green-50 p-4">
            <h3 class="font-bold text-green-900 mb-2 text-sm">มาตรา 33 (ลูกจ้าง)</h3>
            <ul class="text-xs text-green-800 space-y-1">
              <li>ลูกจ้าง: <strong>5%</strong> สูงสุด 750 บ./เดือน</li>
              <li>นายจ้าง: <strong>5%</strong> สูงสุด 750 บ./เดือน</li>
              <li>รัฐบาล: <strong>2.75%</strong></li>
              <li>ฐาน: 1,650 – 15,000 บ./เดือน</li>
              <li class="pt-1 font-medium">คุ้มครอง 7 กรณี</li>
            </ul>
          </div>
          <div class="rounded-lg border border-blue-200 bg-blue-50 p-4">
            <h3 class="font-bold text-blue-900 mb-2 text-sm">มาตรา 39 (อิสระ เคยเป็น ม.33)</h3>
            <ul class="text-xs text-blue-800 space-y-1">
              <li>จ่ายเอง: <strong>432 บ./เดือน</strong></li>
              <li>รัฐบาลสมทบ: 120 บ./เดือน</li>
              <li>ฐาน: 4,800 บาท</li>
              <li>สมัครภายใน 6 เดือนหลังออกจาก ม.33</li>
              <li class="pt-1 font-medium">คุ้มครอง 6 กรณี</li>
            </ul>
          </div>
          <div class="rounded-lg border border-purple-200 bg-purple-50 p-4">
            <h3 class="font-bold text-purple-900 mb-2 text-sm">มาตรา 40 (อาชีพอิสระ)</h3>
            <ul class="text-xs text-purple-800 space-y-1">
              <li>ทางเลือก 1: <strong>70 บ./เดือน</strong> (3 กรณี)</li>
              <li>ทางเลือก 2: <strong>100 บ./เดือน</strong> (4 กรณี)</li>
              <li>ทางเลือก 3: <strong>300 บ./เดือน</strong> (5 กรณี)</li>
              <li class="pt-1 text-gray-500">เหมาะสำหรับฟรีแลนซ์ / เจ้าของกิจการ</li>
            </ul>
          </div>
        </div>
        <div class="mt-3">
          <a href="/คำนวณประกันสังคม/" class="inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700">
            คำนวณประกันสังคม →
          </a>
        </div>
      </section>

      <!-- Section 4: Interest Rates -->
      <section id="อัตราดอกเบี้ย">
        <h2 class="text-xl font-bold text-gray-900 mb-1">4. อัตราดอกเบี้ย ปี 2569</h2>
        <p class="text-sm text-gray-600 mb-3">
          ข้อมูลจาก
          <a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ธนาคารแห่งประเทศไทย (bot.or.th)</a>
        </p>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-orange-50 text-orange-900">
              <tr>
                <th class="px-4 py-2.5 text-left font-semibold">ประเภทอัตราดอกเบี้ย</th>
                <th class="px-4 py-2.5 text-right font-semibold">อัตรา (% ต่อปี)</th>
                <th class="px-4 py-2.5 text-left font-semibold">หมายเหตุ</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="bg-white"><td class="px-4 py-2 font-medium text-gray-800">อัตรานโยบาย ธปท.</td><td class="px-4 py-2 text-right font-bold text-orange-700">2.50%</td><td class="px-4 py-2 text-gray-600 text-xs">กำหนดโดย กนง.</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">MRR (Minimum Retail Rate)</td><td class="px-4 py-2 text-right font-semibold text-gray-800">7–8%</td><td class="px-4 py-2 text-gray-600 text-xs">ธนาคารพาณิชย์ทั่วไป</td></tr>
              <tr class="bg-white"><td class="px-4 py-2 text-gray-700">MLR (Minimum Lending Rate)</td><td class="px-4 py-2 text-right font-semibold text-gray-800">5–6%</td><td class="px-4 py-2 text-gray-600 text-xs">สินเชื่อรายใหญ่</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">MOR (Minimum Overdraft Rate)</td><td class="px-4 py-2 text-right font-semibold text-gray-800">7–9%</td><td class="px-4 py-2 text-gray-600 text-xs">วงเงินเบิกเกินบัญชี</td></tr>
              <tr class="bg-white"><td class="px-4 py-2 text-gray-700">ดอกเบี้ยเงินฝากออมทรัพย์</td><td class="px-4 py-2 text-right font-semibold text-gray-800">0.5–1.5%</td><td class="px-4 py-2 text-gray-600 text-xs">ธนาคารพาณิชย์ทั่วไป</td></tr>
              <tr class="bg-gray-50"><td class="px-4 py-2 text-gray-700">ดอกเบี้ยเงินฝากประจำ 12 เดือน</td><td class="px-4 py-2 text-right font-semibold text-gray-800">1.5–2.5%</td><td class="px-4 py-2 text-gray-600 text-xs">ธนาคารพาณิชย์ทั่วไป</td></tr>
              <tr class="bg-white"><td class="px-4 py-2 text-gray-700">ดอกเบี้ยบัตรเครดิต (สูงสุด)</td><td class="px-4 py-2 text-right font-semibold text-red-600">18%</td><td class="px-4 py-2 text-gray-600 text-xs">เพดานตามกฎหมาย</td></tr>
            </tbody>
          </table>
        </div>
        <div class="mt-3 flex flex-wrap gap-3">
          <a href="/คำนวณดอกเบี้ย/" class="inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700">
            คำนวณดอกเบี้ยเงินกู้ →
          </a>
          <a href="/คำนวณสินเชื่อบ้าน/" class="inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700">
            คำนวณสินเชื่อบ้าน →
          </a>
        </div>
      </section>

      <!-- Section 5: Key Tax Deductions -->
      <section id="ค่าลดหย่อนภาษี">
        <h2 class="text-xl font-bold text-gray-900 mb-1">5. ค่าลดหย่อนภาษีที่สำคัญ ปี 2569</h2>
        <p class="text-sm text-gray-600 mb-3">
          ตามประกาศ
          <a href="https://www.rd.go.th/th/8359.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">กรมสรรพากร — ค่าลดหย่อนภาษีเงินได้บุคคลธรรมดา</a>
        </p>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
