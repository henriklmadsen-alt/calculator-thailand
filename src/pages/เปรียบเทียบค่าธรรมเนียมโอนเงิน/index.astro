---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'เปรียบเทียบค่าธรรมเนียมโอนเงิน 2569 | พร้อมเพย์ vs โอนธนาคาร | Kamnuanlek';
const pageDescription = 'เปรียบเทียบค่าธรรมเนียมโอนเงินช่องทางต่างๆ พร้อมเพย์ โอนธนาคาร โอนต่างธนาคาร เพื่อเลือกที่คุ้มสุด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/เปรียบเทียบค่าธรรมเนียมโอนเงิน/`;

const faqData = [
  {
    question: 'ช่องทางโอนเงินไหนถูกที่สุดในประเทศไทย?',
    answer: 'พร้อมเพย์ถูกที่สุดเพราะไม่มีค่าธรรมเนียมทุกยอด รองลงมาคือการโอนธนาคารเดียวกัน (บางธนาคารฟรี) ส่วนการโอนต่างธนาคารและโอนต่างประเทศมีค่าธรรมเนียมสูงกว่า',
  },
  {
    question: 'ทำไมการโอนต่างประเทศถึงแพงกว่ามาก?',
    answer: 'การโอนต่างประเทศผ่าน SWIFT ต้องผ่านธนาคารตัวแทน (correspondent bank) หลายแห่ง ทำให้มีค่าธรรมเนียมสะสมในแต่ละขั้น รวมทั้งยังมีต้นทุนการแลกเปลี่ยนเงินตราและความเสี่ยงที่ธนาคารต้องรับด้วย',
  },
  {
    question: 'การโอนธนาคารเดียวกันกับต่างธนาคารต่างกันอย่างไร?',
    answer: 'การโอนธนาคารเดียวกันมักฟรีหรือถูกกว่า เพราะระบบอยู่ในธนาคารเดียวกัน ส่วนโอนต่างธนาคารต้องผ่านระบบ interbank (เช่น ITMX) จึงมีค่าธรรมเนียมเพิ่มเติม 10-25 บาทต่อครั้ง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องเปรียบเทียบค่าธรรมเนียมโอนเงิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="เปรียบเทียบค่าธรรมเนียมโอนเงิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">เปรียบเทียบค่าธรรมเนียมโอนเงิน 2569</h1>
    <p class="mb-6 text-gray-600">เปรียบเทียบค่าธรรมเนียมโอนเงิน 4 ช่องทาง เลือกช่องทางที่คุ้มค่าที่สุดสำหรับคุณ</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc-form" class="space-y-4">
        <div>
          <label for="amount" class="mb-1 block text-sm font-medium text-gray-700">ยอดโอน (บาท)</label>
          <input id="amount" type="text" inputmode="numeric" placeholder="เช่น 10000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="freq" class="mb-1 block text-sm font-medium text-gray-700">ความถี่/เดือน (ครั้ง)</label>
          <input id="freq" type="text" inputmode="numeric" placeholder="4" value="4"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          เปรียบเทียบ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ตารางเปรียบเทียบ 4 ช่องทาง</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 bg-gray-50">
                <th class="px-3 py-2 text-left font-semibold text-gray-700">ช่องทาง</th>
                <th class="px-3 py-2 text-right font-semibold text-gray-700">ต่อครั้ง</th>
                <th class="px-3 py-2 text-right font-semibold text-gray-700">ต่อเดือน</th>
                <th class="px-3 py-2 text-right font-semibold text-gray-700">ต่อปี</th>
              </tr>
            </thead>
            <tbody id="res-table" class="divide-y divide-gray-100"></tbody>
          </table>
        </div>
        <div class="mt-4 rounded-lg bg-green-50 p-3">
          <p class="text-sm font-medium text-green-800">ช่องทางถูกที่สุด: <span id="res-best" class="font-bold">-</span></p>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/เปรียบเทียบค่าธรรมเนียมโอนเงิน/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  function sameBankFee(amount: number): number {
    if (amount <= 5000) return 0;
    if (amount <= 30000) return 10;
    return 15;
  }

  function diffBankFee(amount: number): number {
    if (amount <= 5000) return 10;
    if (amount <= 30000) return 20;
    return 25;
  }

  document.getElementById('calc-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const amount = parseNum((document.getElementById('amount') as HTMLInputElement).value);
    const freq = parseNum((document.getElementById('freq') as HTMLInputElement).value) || 1;
    if (!amount) return;

    const channels = [
      { name: 'พร้อมเพย์', perTx: 0 },
      { name: 'โอนธนาคารเดียวกัน', perTx: sameBankFee(amount) },
      { name: 'โอนต่างธนาคาร', perTx: diffBankFee(amount) },
      { name: 'โอนต่างประเทศ (SWIFT)', perTx: 500 },
    ];

    const tbody = document.getElementById('res-table')!;
    tbody.innerHTML = channels.map(c => {
      const monthly = c.perTx * freq;
      const yearly = monthly * 12;
      return `<tr class="hover:bg-gray-50"><td class="px-3 py-2 text-gray-800">${c.name}</td><td class="px-3 py-2 text-right text-gray-800">${fmt(c.perTx)}</td><td class="px-3 py-2 text-right text-gray-800">${fmt(monthly)}</td><td class="px-3 py-2 text-right text-gray-800">${fmt(yearly)}</td></tr>`;
    }).join('');

    const best = channels.reduce((a, b) => a.perTx <= b.perTx ? a : b);
    document.getElementById('res-best')!.textContent = best.name;
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
