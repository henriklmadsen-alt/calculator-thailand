    <p style="margin-top:1.5rem; font-size:0.78rem; color:#94a3b8; line-height:1.5;">
      การเข้าสู่ระบบถือว่าคุณยอมรับ<br>
      <a href="/ข้อกำหนดการใช้งาน/" style="color:#2563eb;">ข้อกำหนดการใช้งาน</a> ของเรา
    </p>
  </div>
</div>

<!-- ── Chat panel (shown when authenticated) ── -->
<div id="chat-panel">
  <div class="chat-header">
    <div>
      <span class="chat-header-title">🤖 AI Advisor</span>
      <span id="tier-badge" class="tier-badge">Free</span>
    </div>
