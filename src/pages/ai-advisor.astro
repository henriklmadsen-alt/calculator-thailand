  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Sarabun', 'Noto Sans Thai', sans-serif; background: #f8fafc; color: #1e293b; min-height: 100vh; }

    /* ── Login panel ── */
    #login-panel {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      min-height: 100vh; padding: 2rem;
    }
    .login-card {
      background: #fff; border-radius: 1.5rem; padding: 2.5rem 2rem;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08); width: 100%; max-width: 400px; text-align: center;
    }
    .login-logo { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .login-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.25rem; color: #0f172a; }
    .login-sub { font-size: 0.95rem; color: #64748b; margin-bottom: 2rem; line-height: 1.5; }
    .login-btn {
      display: flex; align-items: center; justify-content: center; gap: 0.75rem;
      width: 100%; padding: 0.875rem 1.25rem; border-radius: 0.75rem; font-size: 1rem;
      font-weight: 600; cursor: pointer; border: none; text-decoration: none;
      transition: opacity 0.15s, transform 0.1s; margin-bottom: 0.75rem;
    }
    .login-btn:hover { opacity: 0.9; transform: translateY(-1px); }
    .login-btn:active { transform: translateY(0); }
    .btn-google { background: #fff; color: #374151; border: 2px solid #e5e7eb; }
    .btn-facebook { background: #1877f2; color: #fff; }
    .btn-apple { background: #000; color: #fff; }
    .login-divider { font-size: 0.8rem; color: #94a3b8; margin: 0.5rem 0 1rem; }
    .login-free-badge {
      display: inline-block; background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0;
      border-radius: 9999px; padding: 0.25rem 0.75rem; font-size: 0.8rem; font-weight: 600;
      margin-bottom: 1.5rem;
    }
    .error-msg { color: #dc2626; font-size: 0.875rem; margin-bottom: 1rem; }

    /* ── Chat interface ── */
    #chat-panel {
      display: none; flex-direction: column; height: 100vh;
    }
    .chat-header {
      background: #fff; border-bottom: 1px solid #e2e8f0;
      padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between;
    }
    .chat-header-title { font-size: 1.1rem; font-weight: 700; color: #0f172a; }
    .chat-header-meta { font-size: 0.8rem; color: #64748b; }
    .tier-badge {
      background: #eff6ff; color: #2563eb; border-radius: 9999px;
      padding: 0.2rem 0.6rem; font-size: 0.75rem; font-weight: 600; margin-left: 0.5rem;
    }
    .logout-btn {
      background: none; border: none; color: #94a3b8; font-size: 0.875rem;
      cursor: pointer; padding: 0.25rem 0.5rem; border-radius: 0.375rem;
    }
    .logout-btn:hover { color: #ef4444; background: #fef2f2; }
    .messages-area {
      flex: 1; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;
    }
    .message { max-width: 80%; border-radius: 1rem; padding: 0.875rem 1rem; line-height: 1.6; font-size: 0.95rem; }
    .message.user { background: #2563eb; color: #fff; align-self: flex-end; border-bottom-right-radius: 0.25rem; }
    .message.ai { background: #fff; color: #1e293b; align-self: flex-start; border: 1px solid #e2e8f0; border-bottom-left-radius: 0.25rem; }
    .message.ai .typing { display: flex; gap: 4px; padding: 0.25rem 0; }
    .message.ai .typing span { width: 8px; height: 8px; border-radius: 50%; background: #94a3b8; animation: bounce 1.2s infinite; }
    .message.ai .typing span:nth-child(2) { animation-delay: 0.2s; }
    .message.ai .typing span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes bounce { 0%,80%,100% { transform: scale(0.7); opacity: 0.5; } 40% { transform: scale(1); opacity: 1; } }

    .suggestions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
    .suggestion-chip {
      background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 9999px;
      padding: 0.375rem 0.875rem; font-size: 0.8rem; color: #475569; cursor: pointer;
      transition: background 0.15s;
    }
    .suggestion-chip:hover { background: #e2e8f0; }

    .input-area { background: #fff; border-top: 1px solid #e2e8f0; padding: 1rem 1.5rem; }
    .quota-bar { font-size: 0.8rem; color: #64748b; margin-bottom: 0.5rem; }
    .quota-bar span { color: #2563eb; font-weight: 600; }
    .input-row { display: flex; gap: 0.75rem; }
    #message-input {
      flex: 1; border: 2px solid #e2e8f0; border-radius: 0.75rem; padding: 0.75rem 1rem;
      font-size: 0.95rem; font-family: inherit; resize: none; outline: none;
      transition: border-color 0.15s;
    }
    #message-input:focus { border-color: #2563eb; }
    #send-btn {
      background: #2563eb; color: #fff; border: none; border-radius: 0.75rem;
      padding: 0.75rem 1.25rem; font-size: 1rem; cursor: pointer; transition: background 0.15s;
    }
    #send-btn:hover { background: #1d4ed8; }
    #send-btn:disabled { background: #94a3b8; cursor: not-allowed; }

    .paywall-banner {
      background: linear-gradient(135deg, #eff6ff, #f0fdf4);
      border: 1px solid #bfdbfe; border-radius: 0.75rem;
      padding: 1rem; text-align: center; margin: 1rem;
    }
    .paywall-banner h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem; }
    .paywall-banner p { font-size: 0.875rem; color: #64748b; margin-bottom: 0.75rem; }
    .upgrade-btn {
      display: inline-block; background: #2563eb; color: #fff; border-radius: 0.5rem;
      padding: 0.5rem 1.25rem; font-size: 0.9rem; font-weight: 600; text-decoration: none;
      cursor: pointer; border: none; transition: background 0.15s;
    }
    .upgrade-btn:hover { background: #1d4ed8; }

    @media (max-width: 640px) {
      .message { max-width: 92%; }
      .chat-header { padding: 0.875rem 1rem; }
    }
  </style>
</head>
<body>

<!-- ── Login panel (shown when not authenticated) ── -->
<div id="login-panel">
