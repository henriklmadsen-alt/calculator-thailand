---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณบำนาญรายเดือน 2569 | รายได้หลังเกษียณจากพอร์ตลงทุน | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณรายได้บำนาญรายเดือนที่จะได้รับจากเงินก้อนพอร์ตเกษียณ โดยใช้ safe withdrawal rate และผลตอบแทนหลังเกษียณ แสดงรายได้ที่ยั่งยืนตลอดชีวิต อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณบำนาญรายเดือน/`;

const faqData = [
  {
    question: 'บำนาญรายเดือนจากพอร์ตเกษียณคำนวณอย่างไร?',
    answer: 'มีสองวิธีหลัก คือ 1) Safe Withdrawal Rate: คูณพอร์ตด้วยอัตราถอนที่ปลอดภัย (เช่น 4%) หารด้วย 12 เดือน เงินต้นยังคงอยู่ตลอด 2) Annuity: คำนวณยอดถอนรายเดือนที่ทำให้พอร์ตหมดพอดีตามอายุขัยที่กำหนด ซึ่งให้รายได้สูงกว่าแต่เงินต้นหมดตามระยะเวลา',
  },
  {
    question: 'วิธี Safe Rate กับ Annuity ต่างกันอย่างไร?',
    answer: 'Safe Rate เหมาะหากต้องการเหลือมรดก เงินไม่หมดและยังเติบโตต่อ แต่รายได้รายเดือนจะต่ำกว่า Annuity เหมาะหากต้องการรายได้สูงสุดและไม่กังวลเรื่องมรดก เงินจะหมดพอดีตามช่วงเวลาที่ตั้งไว้',
  },
  {
    question: 'พอร์ตเกษียณ 5 ล้านบาทได้บำนาญเดือนละเท่าไร?',
    answer: 'ด้วยอัตรา Safe Rate 4%: 5,000,000 × 4% ÷ 12 = 16,667 บาท/เดือน แบบ Annuity 25 ปีที่ผลตอบแทน 5%: ประมาณ 29,000 บาท/เดือน ซึ่งสูงกว่า Safe Rate แต่เงินต้นจะหมดหลัง 25 ปี',
  },
  {
    question: 'ควรใช้อายุขัยกี่ปีในการคำนวณ Annuity?',
    answer: 'แนะนำใช้ 25-30 ปีหลังเกษียณ (เกษียณ 60 → คำนวณถึง 85-90 ปี) เพื่อป้องกันความเสี่ยงอายุยืนกว่าที่คาด บางคนใช้ 35 ปีเพื่อความระมัดระวังสูงสุด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณบำนาญรายเดือน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณบำนาญรายเดือน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณบำนาญรายเดือน 2569 — รายได้หลังเกษียณจากพอร์ตลงทุน
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณรายได้บำนาญรายเดือนจากพอร์ตเกษียณ เปรียบเทียบทั้งแบบ Safe Withdrawal Rate (เงินต้นคงอยู่) และแบบ Annuity (ถอนหมดพอดีตามอายุขัย)
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="pension-monthly-form" class="space-y-5">
        <p id="pension-monthly-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div>
          <label for="pension-portfolio" class="block text-sm font-medium text-gray-700 mb-1">
            เงินก้อนพอร์ตเกษียณ (บาท)
          </label>
          <input
            type="text"
            id="pension-portfolio"
            inputmode="numeric"
            placeholder="เช่น 5,000,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p id="pension-portfolio-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="pension-safe-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Safe Withdrawal Rate (% ต่อปี)
            </label>
            <input
              type="text"
              id="pension-safe-rate"
              inputmode="decimal"
              placeholder="เช่น 4"
              value="4"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="pension-return" class="block text-sm font-medium text-gray-700 mb-1">
              ผลตอบแทนพอร์ต (% ต่อปี)
            </label>
            <input
              type="text"
              id="pension-return"
              inputmode="decimal"
              placeholder="เช่น 5"
              value="5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="pension-life-years" class="block text-sm font-medium text-gray-700 mb-1">
              อายุขัยคาดหวัง (ปีนับจากเกษียณ)
            </label>
            <input
              type="number"
              id="pension-life-years"
              min="5"
              max="60"
              value="25"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          id="pension-monthly-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณบำนาญรายเดือน</h2>

        <div class="grid gap-3 sm:grid-cols-2 mb-6">
          <div class="bg-green-50 rounded-lg p-4">
            <div class="text-sm font-semibold text-green-800 mb-2">แบบ Safe Withdrawal Rate</div>
            <div class="text-sm text-gray-600 mb-1">รายได้รายเดือน</div>
            <div id="res-pension-safe-monthly" class="text-2xl font-bold text-green-700 mb-2">-</div>
            <div class="text-xs text-gray-500">เงินต้นคงอยู่ตลอดชีวิต สามารถส่งต่อเป็นมรดกได้</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm font-semibold text-blue-800 mb-2">แบบ Annuity (ถอนหมดพอดี)</div>
            <div class="text-sm text-gray-600 mb-1">รายได้รายเดือน</div>
            <div id="res-pension-annuity-monthly" class="text-2xl font-bold text-blue-700 mb-2">-</div>
            <div class="text-xs text-gray-500">เงินต้นหมดพอดีตาม <span id="res-pension-life-years-display">-</span> ปี</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">พอร์ตเกษียณ</span>
            <span id="res-pension-portfolio" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">รายได้รายปี (Safe Rate)</span>
            <span id="res-pension-safe-annual" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">รายได้รายปี (Annuity)</span>
            <span id="res-pension-annuity-annual" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">รายได้สูงกว่าเมื่อใช้ Annuity</span>
            <span id="res-pension-diff" class="font-medium text-blue-600">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณบำนาญรายเดือนจากพอร์ตเกษียณ</h2>
      <p>
        บำนาญรายเดือนจากพอร์ตเกษียณสามารถคำนวณได้สองวิธีหลัก แต่ละวิธีมีข้อดีข้อเสียแตกต่างกัน
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">Safe Withdrawal Rate</h3>
      <p>
        รายได้รายเดือน = พอร์ต × (อัตราถอน ÷ 100) ÷ 12<br/>
        ตัวอย่าง: พอร์ต 5,000,000 บาท × 4% ÷ 12 = 16,667 บาท/เดือน<br/>
        ข้อดี: เงินต้นไม่หมด ยังเติบโตต่อได้ เหมาะสำหรับผู้ต้องการความมั่นคงสูง
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">Annuity (ถอนหมดตามระยะเวลา)</h3>
      <p>
        รายได้รายเดือน = พอร์ต × r ÷ [1 - (1+r)^(-n)]<br/>
        โดย r = อัตราผลตอบแทนรายเดือน, n = จำนวนเดือนทั้งหมด<br/>
        ข้อดี: รายได้สูงกว่า Safe Rate แต่เงินต้นจะหมดตามกำหนด
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณบำนาญรายเดือน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางการเงิน ควรปรึกษาผู้เชี่ยวชาญก่อนวางแผนเกษียณ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('pension-monthly-form') as HTMLFormElement;
    const formError = document.getElementById('pension-monthly-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const portfolio = parseNum((document.getElementById('pension-portfolio') as HTMLInputElement).value);
      const safeRate = parseNum((document.getElementById('pension-safe-rate') as HTMLInputElement).value) || 4;
      const returnRate = parseNum((document.getElementById('pension-return') as HTMLInputElement).value) || 5;
      const lifeYears = parseInt((document.getElementById('pension-life-years') as HTMLInputElement).value) || 25;

      if (portfolio <= 0) {
        formError.classList.remove('hidden');
        (document.getElementById('pension-portfolio') as HTMLInputElement).focus();
        return;
      }

      trackCalculatorStart('pension-monthly');

      // Safe Rate method
      const safeMonthlIncome = portfolio * (safeRate / 100) / 12;
      const safeAnnualIncome = safeMonthlIncome * 12;

      // Annuity method
      const monthlyRate = returnRate / 100 / 12;
      const n = lifeYears * 12;
      let annuityMonthly: number;
      if (Math.abs(monthlyRate) < 0.0000001) {
        annuityMonthly = portfolio / n;
      } else {
        annuityMonthly = portfolio * monthlyRate / (1 - Math.pow(1 + monthlyRate, -n));
      }
      const annuityAnnual = annuityMonthly * 12;

      const diff = annuityMonthly - safeMonthlIncome;

      (document.getElementById('res-pension-safe-monthly') as HTMLElement).textContent = fmt(safeMonthlIncome) + ' บาท/เดือน';
      (document.getElementById('res-pension-annuity-monthly') as HTMLElement).textContent = fmt(annuityMonthly) + ' บาท/เดือน';
      (document.getElementById('res-pension-life-years-display') as HTMLElement).textContent = lifeYears.toString();
      (document.getElementById('res-pension-portfolio') as HTMLElement).textContent = fmt(portfolio) + ' บาท';
      (document.getElementById('res-pension-safe-annual') as HTMLElement).textContent = fmt(safeAnnualIncome) + ' บาท';
      (document.getElementById('res-pension-annuity-annual') as HTMLElement).textContent = fmt(annuityAnnual) + ' บาท';
      (document.getElementById('res-pension-diff') as HTMLElement).textContent = '+' + fmt(Math.max(0, diff)) + ' บาท/เดือน';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('pension-monthly');
      trackCalculatorUsed('pension-monthly');
    });
  </script>
</BaseLayout>
