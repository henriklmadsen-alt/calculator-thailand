---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณภาษีธุรกิจเฉพาะ 3.3% 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณภาษีธุรกิจเฉพาะ 2569 ฟรี — ขายอสังหาฯ ภายใน 5 ปี ต้องเสียเท่าไร ใส่ราคาขาย รู้ยอดภาษีทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีธุรกิจเฉพาะ/`;

const faqData = [
  {
    question: 'ภาษีธุรกิจเฉพาะ 3.3% คืออะไร?',
    answer: 'ภาษีธุรกิจเฉพาะเป็นภาษีที่เรียกเก็บจากรายรับของกิจการบางประเภท เช่น การขายอสังหาริมทรัพย์ที่ถือครองไม่ถึง 5 ปี ในอัตรา 3% บวกภาษีท้องถิ่น 0.3% รวมเป็น 3.3% คำนวณจากราคาขายหรือราคาประเมินที่สูงกว่า',
  },
  {
    question: 'การขายบ้านแบบไหนต้องเสียภาษีธุรกิจเฉพาะ?',
    answer: 'การขายอสังหาริมทรัพย์ที่ถือครองไม่เกิน 5 ปีนับจากวันที่ได้มา ต้องเสียภาษีธุรกิจเฉพาะ หากถือครองเกิน 5 ปีจะเสียแค่อากรแสตมป์ 0.5% แทน',
  },
  {
    question: 'ภาษีธุรกิจเฉพาะคำนวณจากฐานอะไร?',
    answer: 'คำนวณจากราคาขายหรือราคาประเมินของกรมธนารักษ์ แล้วแต่ราคาใดสูงกว่า โดยใช้อัตรา 3.3% (ภาษี 3% + ภาษีท้องถิ่น 0.3%)',
  },
  {
    question: 'ถ้าขายบ้านที่อยู่อาศัยหลักเกิน 1 ปี ต้องเสียภาษีธุรกิจเฉพาะไหม?',
    answer: 'หากมีชื่ออยู่ในทะเบียนบ้านเกิน 1 ปีก่อนขาย และถือครองเกิน 5 ปี จะได้รับยกเว้นภาษีธุรกิจเฉพาะ แต่ถ้าถือครองไม่ถึง 5 ปีแม้มีชื่อในทะเบียนบ้านก็ยังต้องเสีย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณภาษีธุรกิจเฉพาะ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "วิธีคำนวณภาษีธุรกิจเฉพาะ ปี 2569",
  "description": "ขั้นตอนการคำนวณภาษีธุรกิจเฉพาะสำหรับผู้ประกอบการ เช่น อสังหาริมทรัพย์ ธนาคาร ประกันชีวิต ตามพระราชกฤษฎีกาของกรมสรรพากร",
  "step": [
    {"@type": "HowToStep", "name": "ตรวจสอบว่าธุรกิจต้องเสียภาษีธุรกิจเฉพาะ", "text": "ธุรกิจที่เสียภาษีธุรกิจเฉพาะ: (1) ธนาคาร/สถาบันการเงิน, (2) ประกันชีวิต, (3) อสังหาริมทรัพย์ (ขายที่ดิน/บ้าน), (4) ธุรกิจจำนำ, (5) การขายหลักทรัพย์"},
    {"@type": "HowToStep", "name": "ระบุฐานภาษี (Tax Base)", "text": "ฐานภาษีธุรกิจเฉพาะ = รายรับรวม (Gross Revenue) ก่อนหักค่าใช้จ่าย ตัวอย่าง: ขายที่ดิน 5,000,000 บาท → ฐานภาษี = 5,000,000 บาท"},
    {"@type": "HowToStep", "name": "ตรวจสอบอัตราภาษี", "text": "อัตราภาษีธุรกิจเฉพาะ: อสังหาริมทรัพย์ 3.3% (รวมภาษีท้องถิ่น), ธนาคาร 3.3%, ประกันชีวิต 2.75%, การจำนำ 2.75%, การขายหลักทรัพย์ 0.1%"},
    {"@type": "HowToStep", "name": "คำนวณภาษีธุรกิจเฉพาะ", "text": "ภาษีธุรกิจเฉพาะ = ฐานภาษี × อัตราภาษี ตัวอย่าง: ขายที่ดิน 5,000,000 × 3.3% = 165,000 บาท"},
    {"@type": "HowToStep", "name": "ยื่นแบบและชำระภาษี", "text": "ยื่นแบบ ภ.ธ.40 ภายใน 15 วันของเดือนถัดไป หรือสำหรับอสังหาริมทรัพย์ ชำระพร้อมการโอนที่สำนักงานที่ดิน"}
  ]
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีธุรกิจเฉพาะ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณภาษีธุรกิจเฉพาะ (3.3%)
    </h1>
    <p class="text-gray-600 mb-6">
      คำนวณภาษีธุรกิจเฉพาะสำหรับการขายอสังหาริมทรัพย์ภายใน 5 ปี ในอัตรา 3.3% จากราคาขายหรือราคาประเมิน
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ข้อมูลการขายอสังหาริมทรัพย์</h2>

      <div class="space-y-4">
        <div>
          <label for="sale-price" class="block text-sm font-medium text-gray-700 mb-1">
            ราคาขาย (บาท)
          </label>
          <input type="text" id="sale-price" inputmode="numeric" placeholder="เช่น 3,500,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
        </div>

        <div>
          <label for="appraisal-price" class="block text-sm font-medium text-gray-700 mb-1">
            ราคาประเมิน (บาท) <span class="text-gray-400 font-normal">— ใส่ 0 ถ้าไม่ทราบ</span>
          </label>
          <input type="text" id="appraisal-price" inputmode="numeric" placeholder="เช่น 2,800,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
        </div>
      </div>

      <button type="button" id="btn-calculate"
        class="mt-5 w-full sm:w-auto px-8 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
        คำนวณภาษี
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6 p-4 bg-primary-50 rounded-lg border border-primary-200">
        <h3 class="font-semibold text-primary-900 mb-3">ผลการคำนวณ</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-700">ฐานภาษี (ราคาที่สูงกว่า)</span>
            <span id="res-base" class="font-semibold text-gray-900">-</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-700">ภาษีธุรกิจเฉพาะ 3%</span>
            <span id="res-3pct" class="font-semibold text-gray-900">-</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-700">ภาษีท้องถิ่น 0.3%</span>
            <span id="res-local" class="font-semibold text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-t border-primary-300 pt-2 mt-2">
            <span class="font-bold text-primary-900">รวมภาษีธุรกิจเฉพาะ (3.3%)</span>
            <span id="res-total" class="font-bold text-primary-700 text-lg">-</span>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-3">* ฐานภาษีใช้ราคาขายหรือราคาประเมิน แล้วแต่ราคาใดสูงกว่า</p>
      </div>
    </div>

    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">[โฆษณา — AdSense]</div>

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ภาษีธุรกิจเฉพาะ (SBT) คืออะไร?</h2>
      <p>
        ภาษีธุรกิจเฉพาะ (Special Business Tax: SBT) เป็นภาษีตามประมวลรัษฎากร หมวด 4 มาตรา 91/1 ถึง 91/21
        เรียกเก็บจากกิจการบางประเภทที่ได้รับยกเว้น VAT แต่รัฐยังต้องการจัดเก็บภาษีเป็นการเฉพาะ
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">การคำนวณภาษีธุรกิจเฉพาะสำหรับขายอสังหาฯ</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ฐานภาษี = ราคาขาย หรือ ราคาประเมิน แล้วแต่ราคาใดสูงกว่า</li>
        <li>ภาษีธุรกิจเฉพาะ = ฐานภาษี × 3%</li>
        <li>ภาษีท้องถิ่น = ภาษีธุรกิจเฉพาะ × 10% (= ฐานภาษี × 0.3%)</li>
        <li>รวมทั้งสิ้น = ฐานภาษี × 3.3%</li>
      </ul>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการคำนวณ</h3>
      <p>ขายบ้านราคา 3,500,000 บาท ราคาประเมิน 2,800,000 บาท (ถือครองน้อยกว่า 5 ปี)</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ฐานภาษี = 3,500,000 บาท (ราคาขายสูงกว่า)</li>
        <li>ภาษีธุรกิจเฉพาะ = 3,500,000 × 3% = 105,000 บาท</li>
        <li>ภาษีท้องถิ่น = 3,500,000 × 0.3% = 10,500 บาท</li>
        <li>รวม = 115,500 บาท</li>
      </ul>
    </section>


    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณ</h2>
      <p><strong>ภาษีธุรกิจเฉพาะ = มูลค่าการขาย × อัตราภาษี</strong> (อัตรา 0.1%−5% ขึ้นอยู่กับประเภทธุรกิจ)</p>
      <p>ประเภทธุรกิจที่ต้องเสีย เช่น อัญมณี น้ำมัน ยาสูบ เหล้า บุหรี่ และธุรกิจอื่นตามที่กฎหมายกำหนด</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">ตัวอย่างการคำนวณ</h3>
      <p><strong>ตัวอย่างที่ 1: ธุรกิจยาสูบ มูลค่าการขาย 1,000,000 บาท (อัตรา 2%)</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>มูลค่าการขาย</strong> = 1,000,000 บาท</li>
        <li><strong>อัตราภาษี</strong> = 2%</li>
        <li><strong>ภาษีธุรกิจเฉพาะ</strong> = 1,000,000 × 2% = <strong>20,000 บาท</strong></li>
      </ul>

      <p class="mt-4"><strong>ตัวอย่างที่ 2: ธุรกิจน้ำมัน มูลค่าการขาย 5,000,000 บาท (อัตรา 1%)</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>มูลค่าการขาย</strong> = 5,000,000 บาท</li>
        <li><strong>อัตราภาษี</strong> = 1%</li>
        <li><strong>ภาษีธุรกิจเฉพาะ</strong> = 5,000,000 × 1% = <strong>50,000 บาท</strong></li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สรุป</h3>
      <p>ธุรกิจบางประเภทต้องเสียภาษีพิเศษเพิ่มเติมจากภาษีเงินได้ ตามพระราชกฤษฎีกา อัตราต่างกันตามประเภทสินค้า</p>
      <p class="text-sm text-gray-500 mt-2"><strong>อ้างอิง:</strong> <a href="https://www.rd.go.th" class="text-primary-600 hover:underline" target="_blank" rel="noopener">กรมสรรพากร: ภาษีธุรกิจเฉพาะ</a> [อัปเดต 2569]</p>
    </section>
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณภาษีธุรกิจเฉพาะ/" />
    <RelatedCalculators currentHref="/คำนวณภาษีธุรกิจเฉพาะ/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางภาษีหรือกฎหมาย กรุณาปรึกษาผู้เชี่ยวชาญด้านภาษีสำหรับกรณีเฉพาะ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' บาท';
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const salePrice = parseNum((document.getElementById('sale-price') as HTMLInputElement).value);
      const appraisalPrice = parseNum((document.getElementById('appraisal-price') as HTMLInputElement).value);
      if (salePrice <= 0) { (document.getElementById('sale-price') as HTMLInputElement).focus(); return; }

      const base = Math.max(salePrice, appraisalPrice);
      const tax3 = base * 0.03;
      const taxLocal = base * 0.003;
      const total = base * 0.033;

      (document.getElementById('res-base') as HTMLElement).textContent = fmt(base);
      (document.getElementById('res-3pct') as HTMLElement).textContent = fmt(tax3);
      (document.getElementById('res-local') as HTMLElement).textContent = fmt(taxLocal);
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(total);
      document.getElementById('result')!.classList.remove('hidden');
      trackCalculatorUsed('specific-business-tax');
    });
  </script>
</BaseLayout>
