---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนระบบอ่อนน้ำ | Water Softening | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนติดตั้งระบบอ่อนน้ำ ค่าบำรุงรักษา และค่าเกลือแบบ softening ประจำปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนระบบอ่อนน้ำ/`;
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนระบบอ่อนน้ำ">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนระบบอ่อนน้ำ</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2">
      <p class="text-xs font-semibold text-blue-800">[อัปเดต 2569]</p>
    </div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนการติดตั้งและดูแลรักษาระบบอ่อนน้ำประจำปี</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="capacity" class="block text-sm font-medium text-gray-700 mb-1">ความจุระบบ (ลิตร/วินาที)</label>
          <input type="number" id="capacity" placeholder="5" value="5" min="1" max="50" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 text-base" />
        </div>
        <div>
          <label for="familySize" class="block text-sm font-medium text-gray-700 mb-1">จำนวนคน</label>
          <input type="number" id="familySize" placeholder="4" value="4" min="1" max="20" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 text-base" />
        </div>
      </div>
      <button id="calculateBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-md">คำนวณต้นทุน</button>
    </div>
    <div id="results" class="bg-blue-50 rounded-lg border border-blue-200 p-6 hidden">
      <p class="text-sm text-gray-600 mb-1">ต้นทุนรวมติดตั้ง</p>
      <p id="totalCost" class="text-2xl font-bold text-blue-600">0 บาท</p>
      <p class="text-xs text-gray-500 mt-4">ต้นทุนบำรุงรักษารายปี <strong id="maintainance">0</strong> บาท</p>
    </div>
  </article>
  <script>
    document.getElementById('calculateBtn').addEventListener('click', () => {
      const capacity = parseFloat(document.getElementById('capacity').value) || 5;
      const familySize = parseInt(document.getElementById('familySize').value) || 4;
      const baseCost = 25000 + capacity * 3000;
      const maintenance = capacity * 5000;
      document.getElementById('totalCost').textContent = new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(baseCost);
      document.getElementById('maintainance').textContent = new Intl.NumberFormat('th-TH').format(maintenance);
      document.getElementById('results').classList.remove('hidden');
    });
  </script>
</BaseLayout>
