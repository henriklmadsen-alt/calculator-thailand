---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณภาษีเงินได้นิติบุคคล 2569 | ขั้นบันได 15-37% | Calculator Thailand';
const pageDescription = 'คำนวณภาษีนิติบุคคล ตามขั้นบันได 15% 20% 30% 37% ตามกฎหมายภาษีไทย ปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีเงินได้นิติบุคคล/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีเงินได้นิติบุคคล">
  <article>
    <h1 class="text-3xl font-bold text-gray-900 mb-3">คำนวณภาษีเงินได้นิติบุคคล</h1>

    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2">
      <p class="text-xs font-semibold text-green-800">[ปี 2569 — ขั้นบันได 15-37%]</p>
    </div>

    <p class="text-gray-600 mb-6">คำนวณภาษีเงินได้นิติบุคคล ตามขั้นบันไดแบบก้าวหน้า (15%, 20%, 30%, 37%)</p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="grossIncome" class="block text-sm font-medium text-gray-700 mb-1">รายได้รวม (บาท)</label>
          <input type="text" id="grossIncome" inputmode="decimal" placeholder="เช่น 10000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" />
        </div>
        <div>
          <label for="expenses" class="block text-sm font-medium text-gray-700 mb-1">ค่าใช้จ่ายหักได้ (บาท)</label>
          <input type="text" id="expenses" inputmode="decimal" placeholder="เช่น 6000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" />
        </div>
      </div>

      <div class="mb-6">
        <label class="flex items-center">
          <input type="checkbox" id="isResident" checked class="w-4 h-4 border-gray-300 rounded" />
          <span class="ml-2 text-sm text-gray-700">บริษัทต่างประเทศ (ต้องเสีย Surtax)</span>
        </label>
      </div>

      <button id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700">คำนวณภาษี</button>

      <!-- Result -->
      <div id="result" class="hidden mt-6 p-4 bg-green-50 rounded-lg border border-green-200">
        <h3 class="font-semibold text-gray-900 mb-3">ผลการคำนวณ</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between"><span>รายได้รวม</span><span id="r-income" class="font-medium">-</span></div>
          <div class="flex justify-between"><span>ค่าใช้จ่ายหักได้</span><span id="r-expenses" class="font-medium">-</span></div>
          <div class="flex justify-between"><span>รายได้สุทธิ</span><span id="r-taxable" class="font-medium">-</span></div>
          <div class="border-t border-green-300 my-2"></div>
          <div class="flex justify-between"><span>ภาษีเงินได้</span><span id="r-tax" class="font-medium text-primary-600">-</span></div>
          <div class="border-t-2 border-green-400 my-2"></div>
          <div class="flex justify-between text-base font-bold"><span>รายได้สุทธิหลังภาษี</span><span id="r-net" class="text-primary-600">-</span></div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2>อัตราภาษีนิติบุคคล ปี 2569</h2>
      <table>
        <tbody>
          <tr>
            <td>รายได้สุทธิ 0-500,000 บาท</td>
            <td><strong>15%</strong></td>
          </tr>
          <tr>
            <td>รายได้สุทธิ 500,001-1,000,000 บาท</td>
            <td><strong>20%</strong></td>
          </tr>
          <tr>
            <td>รายได้สุทธิ 1,000,001-4,000,000 บาท</td>
            <td><strong>30%</strong></td>
          </tr>
          <tr>
            <td>รายได้สุทธิ 4,000,000 บาทขึ้นไป</td>
            <td><strong>37%</strong></td>
          </tr>
        </tbody>
      </table>

      <h3>คำนวณอย่างไร?</h3>
      <ol>
        <li>รายได้สุทธิ = รายได้รวม - ค่าใช้จ่ายหักได้</li>
        <li>นำรายได้สุทธิไปตามขั้นบันได (แต่ละส่วนของรายได้ใช้อัตราต่างกัน)</li>
        <li>รวมภาษีทั้งหมด = ผลรวมจากแต่ละขั้น</li>
      </ol>

      <h3>ค่าใช้จ่ายหักได้คืออะไร?</h3>
      <ul>
        <li>เงินเดือน ค่าแรง ค่าตอบแทน</li>
        <li>ค่าจ้างเหมา ค่าสัญญา</li>
        <li>ค่า VAT ที่สามารถหักได้</li>
        <li>ค่าเสื่อมราคาอุปกรณ์/สินทรัพย์</li>
        <li>ดอกเบี้ยเงินกู้ทำงาน</li>
        <li>เบี้ยประกันกลุ่ม บำเหน็จบำนาญ</li>
      </ul>
    </section>
  </article>
</BaseLayout>

<script>
  import { calculateCorporateIncomeTax } from '../../lib/corporate-income-tax-calculator';

  function fmt(n: number) {
    return new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', minimumFractionDigits: 0 }).format(n);
  }

  document.getElementById('btn-calculate').addEventListener('click', () => {
    const income = parseFloat((document.getElementById('grossIncome') as HTMLInputElement).value.replace(/,/g, '')) || 0;
    const expenses = parseFloat((document.getElementById('expenses') as HTMLInputElement).value.replace(/,/g, '')) || 0;
    const isResident = (document.getElementById('isResident') as HTMLInputElement).checked;

    if (income <= 0) {
      alert('โปรดระบุรายได้');
      return;
    }

    const result = calculateCorporateIncomeTax({
      grossIncome: income,
      deductibleExpenses: expenses,
      capitalGains: 0,
      isResident,
    });

    (document.getElementById('r-income') as HTMLElement).textContent = fmt(result.grossIncome);
    (document.getElementById('r-expenses') as HTMLElement).textContent = fmt(result.deductibleExpenses);
    (document.getElementById('r-taxable') as HTMLElement).textContent = fmt(result.taxableIncome);
    (document.getElementById('r-tax') as HTMLElement).textContent = fmt(result.totalTax);
    (document.getElementById('r-net') as HTMLElement).textContent = fmt(result.netIncome);

    (document.getElementById('result') as HTMLElement).classList.remove('hidden');
  });
</script>
