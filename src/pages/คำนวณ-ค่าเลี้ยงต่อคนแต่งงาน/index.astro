---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าเลี้ยงต่อคนแต่งงาน 2569 | ราคาเมนูอาหาร | Kamnuanlek';
const pageDescription = 'คำนวณค่าเลี้ยงต่อหัวสำหรับแต่งงาน โดยการป้อนจำนวนแขกและงบประมาณทั้งหมด ออนไลน์ฟรี พร้อมราคาอ้างอิงอาหารไทยและจีน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าเลี้ยงต่อคนแต่งงาน/`;

const faqData = [
  {
    question: 'ค่าเลี้ยงต่อคนแต่งงานเฉลี่ยเท่าไหร่ในไทย?',
    answer: 'ค่าเลี้ยงต่อหัวเฉลี่ยในประเทศไทยอยู่ที่ 1,000-2,500 บาท/คน ขึ้นอยู่กับคุณภาพของอาหารและสถานที่ รีสอร์ตห้องแขกหรูหรามักมีค่าเลี้ยง 1,500-2,500 บาท/คน ขณะที่โรงแรมระดับกลางอยู่ที่ 800-1,500 บาท/คน',
  },
  {
    question: 'ค่าเลี้ยงรวมเครื่องดื่มแอลกอฮอล์กี่บาท?',
    answer: 'ถ้าต้องการรวมค่าเครื่องดื่มแอลกอฮอล์ (เบียร์, ลำไม้, ไวน์) โดยปกติเพิ่มขึ้น 200-500 บาท/คน ถ้าต้องการอาหารสูงมากขึ้น 300-800 บาท/คน และดื่มเต็มที่ บ่อยครั้งเพิ่มอีก 200-400 บาท/คน',
  },
  {
    question: 'จะประหยัดค่าเลี้ยงแต่งงานได้ไหม?',
    answer: 'วิธีลดค่าเลี้ยง: (1) เลือกเมนูอาหารแบบง่ายๆ แต่เสิร์ฟอย่างสวยงาม (2) จำกัดจำนวนเมนูอาหารเพียง 2-3 หลัก (3) ใช้ข้าวและซุปแทนอาหารหวาน (4) เลือกวันเวลาที่ห่างจากเทศกาล',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าเลี้ยงต่อคนแต่งงาน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเลี้ยงต่อคนแต่งงาน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าเลี้ยงต่อคนแต่งงาน
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-pink-200 bg-pink-50 px-3 py-2">
      <p class="text-xs font-semibold text-pink-800">[ราคาค่าเลี้ยง 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าเลี้ยงต่อหัวสำหรับแต่งงาน โดยหารค่าอาหารทั้งหมดด้วยจำนวนแขก
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="budget" class="block text-sm font-medium text-gray-700 mb-1">
            งบประมาณอาหารทั้งหมด (บาท)
          </label>
          <input
            type="text"
            id="budget"
            inputmode="decimal"
            placeholder="เช่น 300000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 text-base"
          />
        </div>

        <div>
          <label for="guests" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนแขก (คน)
          </label>
          <input
            type="text"
            id="guests"
            inputmode="decimal"
            placeholder="เช่น 150"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 text-base"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-pink-600 text-white font-semibold rounded-md hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณ
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-8 border-t pt-6">
        <div class="bg-pink-50 rounded-lg p-6 text-center">
          <div class="text-sm text-gray-600 mb-2">ค่าเลี้ยงต่อคน</div>
          <div class="text-5xl font-bold text-pink-700 mb-2">
            <span id="cost-per-guest">-</span>
          </div>
          <div class="text-sm text-gray-600">บาท/คน</div>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 mt-6">
          <div class="border rounded-lg p-4">
            <div class="text-sm text-gray-600 mb-1">งบประมาณรวม</div>
            <div class="text-2xl font-bold text-gray-900"><span id="show-budget">-</span> บาท</div>
          </div>
          <div class="border rounded-lg p-4">
            <div class="text-sm text-gray-600 mb-1">จำนวนแขก</div>
            <div class="text-2xl font-bold text-gray-900"><span id="show-guests">-</span> คน</div>
          </div>
        </div>

        <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
          <p class="text-sm text-blue-900">
            <strong>คำแนะนำ:</strong> ราคาต่อคน <span id="comparison">-</span> เป็นราคาที่สมเหมาะสำหรับแต่งงาน คุณสามารถปรับเมนูให้เหมาะสม
          </p>
        </div>
      </div>
    </div>

    <!-- Reference Prices -->
    <section class="mb-10">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-4">ราคาอ้างอิงค่าเลี้ยงแต่งงาน</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="border p-3 text-left">ประเภท</th>
              <th class="border p-3 text-left">ราคา/คน</th>
              <th class="border p-3 text-left">หมายเหตุ</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border p-3">อาหารไทยแบบง่ายๆ</td>
              <td class="border p-3">800-1,200 บาท</td>
              <td class="border p-3">อาหารจานหลัก + ข้าว + ซุป</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-3">อาหารไทยทั่วไป</td>
              <td class="border p-3">1,000-1,500 บาท</td>
              <td class="border p-3">2-3 จานอาหาร + ดessert</td>
            </tr>
            <tr>
              <td class="border p-3">อาหารไทยพรีเมียม</td>
              <td class="border p-3">1,500-2,000 บาท</td>
              <td class="border p-3">อาหารคัดสรรพิเศษ</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-3">อาหารสมัพันธ์/จีน</td>
              <td class="border p-3">1,200-2,000 บาท</td>
              <td class="border p-3">ปีศาจอบสวน + ลูกชิ้น</td>
            </tr>
            <tr>
              <td class="border p-3">เพิ่มเครื่องดื่มแอลกอฮอล์</td>
              <td class="border p-3">+200-500 บาท</td>
              <td class="border p-3">เบียร์, ลำไม้, ไวน์</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ Section -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators />
    <RelatedArticles />
  </article>
</BaseLayout>

<script>
  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const budget = parseFloat(document.getElementById('budget')?.value || 0);
    const guests = parseFloat(document.getElementById('guests')?.value || 0);

    if (budget <= 0 || guests <= 0) {
      alert('กรุณาป้อนจำนวนแขกและงบประมาณ');
      return;
    }

    const costPerGuest = budget / guests;

    document.getElementById('cost-per-guest').textContent = Math.round(costPerGuest).toLocaleString('th-TH');
    document.getElementById('show-budget').textContent = budget.toLocaleString('th-TH');
    document.getElementById('show-guests').textContent = guests.toLocaleString('th-TH');

    let comparison = '';
    if (costPerGuest < 800) {
      comparison = 'ต่ำกว่า — ควรพิจารณาเพิ่มเมนูหรือคุณภาพ';
    } else if (costPerGuest < 1200) {
      comparison = 'เหมาะสม — อาหารไทยแบบธรรมชาติ';
    } else if (costPerGuest < 1800) {
      comparison = 'ดี — อาหารมีคุณภาพพอสมควร';
    } else {
      comparison = 'พรีเมียม — อาหารคัดสรรพิเศษ';
    }

    document.getElementById('comparison').textContent = comparison;
    document.getElementById('result').classList.remove('hidden');
  });
</script>
