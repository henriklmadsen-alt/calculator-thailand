---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculatePassportFee, EXAMPLE_1, EXAMPLE_2, EXAMPLE_3 } from '../../lib/passport-fee-calculator';

const pageTitle = 'คำนวณค่าพาสปอร์ต 2569 | ค่าธรรมเนียมพาสปอร์ตไทย | Kamnuanlek';
const pageDescription = 'คำนวณค่าพาสปอร์ต (หนังสือเดินทาง) ออนไลน์ฟรี สำหรับผู้ใหญ่และเด็ก โดยระบบจะคำนวณค่าธรรมเนียมตามประเภท ระยะเวลา บริการด่วน ตามอัตรา 2569 ที่ทำการต่างประเทศ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าพาสปอร์ต/`;

const faqData = [
  {
    question: 'พาสปอร์ตไทยมีกี่ประเภท?',
    answer: 'หนังสือเดินทางธรรมดามี 2 ประเภท: หนังสือเดินทาง 5 ปี (ค่า 1,000 บาท) และหนังสือเดินทาง 10 ปี (ค่า 1,500 บาท) โดยผู้เยาว์ (อายุต่ำกว่า 20 ปี) สามารถขอได้เฉพาะเล่ม 5 ปี',
  },
  {
    question: 'บริการด่วน (Express) ค่าเพิ่มเท่าไหร่?',
    answer: 'ค่าบริการด่วนคือ 1,000 บาทต่อเล่ม สำหรับผู้ที่ต้องการรับเล่มภายใน 1 วันทำการ โดยเพิ่มเติมจากค่าธรรมเนียมพื้นฐาน',
  },
  {
    question: 'พาสปอร์ตออนไลน์ (E-Passport) แตกต่างจากธรรมดาอย่างไร?',
    answer: 'E-Passport (หนังสือเดินทางอิเล็กทรอนิกส์) มีชิปประมวลผลและให้ข้อมูลชีวมิติ มีความปลอดภัยสูงกว่า และได้รับยอมรับจากประเทศส่วนใหญ่ แต่ค่าธรรมเนียมจะเท่ากับหนังสือเดินทางธรรมดา',
  },
  {
    question: 'ต้องเตรียมเอกสารอะไรบ้างเมื่อขอพาสปอร์ต?',
    answer: 'เอกสารหลัก: บัตรประชาชน ทะเบียนบ้าน สำหรับขอครั้งแรก: สูติบัตร สำหรับต่อ: พาสปอร์ตเล่มเดิม สำหรับเด็ก: หนังสือยินยอมจากบิดามารดา และสูติบัตร',
  },
  {
    question: 'สามารถขอพาสปอร์ตได้ที่ไหนบ้าง?',
    answer: 'สามารถขอได้ที่สำนักทำหนังสือเดินทาง สำนักงานการต่างประเทศในจังหวัด หรือสถานทูต/สถาน领事ไทยต่างประเทศ (หากอยู่นอกประเทศ)',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าพาสปอร์ต',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณค่าพาสปอร์ต',
  description: 'ขั้นตอนการคำนวณค่าธรรมเนียมขออบรมหนังสือเดินทางไทยตามประเภทและระยะเวลาที่ขอ',
  step: [
    {
      '@type': 'HowToStep',
      name: 'เลือกประเภทพาสปอร์ต',
      text: 'ระบุประเภท: ผู้ใหญ่ 5 ปี (1,000 บาท) ผู้ใหญ่ 10 ปี (1,500 บาท) เด็ก 5 ปี (1,000 บาท) หรือต่อพาสปอร์ต (1,000 บาท)',
    },
    {
      '@type': 'HowToStep',
      name: 'ระบุจำนวนเล่มที่ต้องการ',
      text: 'ปกติจะขอเล่มละหนึ่งเล่ม แต่สามารถขออย่างน้อย 1 เล่ม',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกบริการด่วน (หากต้องการ)',
      text: 'หากต้องการรับเล่มภายใน 1 วันทำการ ให้เพิ่มบริการด่วน (ค่าเพิ่ม 1,000 บาท)',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกวิธีรับบริการ',
      text: 'เลือกระหว่าง ขอที่สำนักทำหนังสือเดินทาง หรือขอผ่านไปรษณีย์ (ค่าเพิ่ม 100 บาท)',
    },
    {
      '@type': 'HowToStep',
      name: 'ดูผลการคำนวณ',
      text: 'ระบบจะแสดงค่าธรรมเนียมรวมทั้งสิ้นตามการเลือกของท่าน',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าพาสปอร์ต">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าพาสปอร์ต (หนังสือเดินทาง)
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-indigo-200 bg-indigo-50 px-3 py-2">
      <p class="text-xs font-semibold text-indigo-800">[อัปเดตอัตราการต่างประเทศ 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าธรรมเนียมพาสปอร์ต (หนังสือเดินทาง) ออนไลน์ฟรี สำหรับผู้ใหญ่และเด็ก ตามอัตราปัจจุบันของกระทรวงการต่างประเทศ
    </p>

    <!-- Calculator Section -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <!-- Passport Type Selection -->
      <div class="mb-6">
        <label for="passport-type" class="block text-sm font-medium text-gray-700 mb-2">
          ประเภทพาสปอร์ต
        </label>
        <select
          id="passport-type"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-base"
        >
          <option value="adult10">ผู้ใหญ่ 10 ปี (1,500 บาท)</option>
          <option value="adult5">ผู้ใหญ่ 5 ปี (1,000 บาท)</option>
          <option value="child">เด็ก 5 ปี (1,000 บาท)</option>
          <option value="renewal">ต่อพาสปอร์ต (1,000 บาท)</option>
        </select>
      </div>

      <!-- Number of Copies -->
      <div class="mb-6">
        <label for="num-copies" class="block text-sm font-medium text-gray-700 mb-2">
          จำนวนเล่ม
        </label>
        <input
          type="number"
          id="num-copies"
          min="1"
          max="10"
          value="1"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-base"
        />
      </div>

      <!-- Service Options -->
      <div class="mb-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex items-center">
          <input
            type="checkbox"
            id="rush-service"
            class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
          />
          <label for="rush-service" class="ml-2 block text-sm text-gray-700">
            บริการด่วน (+1,000 บาท/เล่ม)
          </label>
        </div>

        <div>
          <label for="service-type" class="block text-sm font-medium text-gray-700 mb-2">
            วิธีรับบริการ
          </label>
          <select
            id="service-type"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-base"
          >
            <option value="in-person">ขอที่ที่ทำการ (ฟรี)</option>
            <option value="postal">ส่งทางไปรษณีย์ (+100 บาท)</option>
          </select>
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-indigo-600 text-white font-semibold rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณค่าพาสปอร์ต
      </button>

      <!-- Results -->
      <div id="result" class="hidden mt-6 pt-6 border-t border-gray-200">
        <!-- Cost Breakdown -->
        <div class="grid gap-4 sm:grid-cols-2 mb-6">
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-sm text-gray-600">ค่าพาสปอร์ตพื้นฐาน</div>
            <div id="base-fee" class="text-2xl font-bold text-gray-900">0 บาท</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-sm text-gray-600">ค่าบริการเพิ่มเติม</div>
            <div id="extra-fees" class="text-2xl font-bold text-gray-900">0 บาท</div>
          </div>
        </div>

        <!-- Total -->
        <div class="bg-indigo-50 rounded-lg p-4 border border-indigo-200 mb-6">
          <div class="text-sm text-indigo-600 font-semibold mb-1">ค่าธรรมเนียมรวมทั้งสิ้น</div>
          <div id="total-fee" class="text-4xl font-bold text-indigo-900">0 บาท</div>
        </div>

        <!-- Details -->
        <div id="details-table" class="bg-gray-50 rounded-lg p-4 text-sm"></div>
      </div>
    </div>

    <!-- Content Section -->
    <div class="grid gap-6 sm:grid-cols-2 mb-8">
      <!-- Key Information -->
      <div class="bg-blue-50 rounded-lg border border-blue-200 p-6">
        <h2 class="text-lg font-semibold text-blue-900 mb-4">✔ ประเภทพาสปอร์ต</h2>
        <ul class="space-y-2 text-sm text-gray-700">
          <li><strong>ผู้ใหญ่ 10 ปี:</strong> 1,500 บาท (ปกติ)</li>
          <li><strong>ผู้ใหญ่ 5 ปี:</strong> 1,000 บาท (บางครั้ง)</li>
          <li><strong>เด็ก 5 ปี:</strong> 1,000 บาท (อายุต่ำกว่า 20)</li>
          <li><strong>ต่อพาสปอร์ต:</strong> 1,000 บาท (เล่มเดิมจะมอบให้)</li>
        </ul>
      </div>

      <!-- Services -->
      <div class="bg-green-50 rounded-lg border border-green-200 p-6">
        <h2 class="text-lg font-semibold text-green-900 mb-4">🚀 บริการ</h2>
        <ul class="space-y-2 text-sm text-gray-700">
          <li><strong>ปกติ:</strong> 2-3 วันทำการ</li>
          <li><strong>บริการด่วน:</strong> +1,000 บาท (1 วันทำการ)</li>
          <li><strong>ส่งไปรษณีย์:</strong> +100 บาท</li>
          <li><strong>หมายเหตุ:</strong> เวลาอาจล่าช้าตามจำนวนผู้ขอ</li>
        </ul>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="bg-gray-50 rounded-lg p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-6">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg border border-gray-200 p-4">
            <summary class="font-semibold text-gray-900 cursor-pointer">
              {faq.question}
            </summary>
            <p class="text-gray-600 mt-3 text-sm">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <!-- Trust Section -->
    <div class="bg-yellow-50 rounded-lg border border-yellow-200 p-6 mb-8">
      <h2 class="text-lg font-semibold text-yellow-900 mb-3">⚖️ ความน่าเชื่อถือ</h2>
      <p class="text-sm text-gray-700 mb-3">
        เครื่องคำนวณนี้อ้างอิงจากอัตราการต่างประเทศไทยปัจจุบัน:
      </p>
      <ul class="text-sm text-gray-700 space-y-1">
        <li>• <strong>แหล่งที่มา:</strong> กระทรวงการต่างประเทศ สำนักทำหนังสือเดินทาง</li>
        <li>• <strong>อัปเดต:</strong> ปี 2569 (2026)</li>
        <li>• <strong>หมายเหตุ:</strong> ค่าอาจเปลี่ยนแปลงตามนโยบายรัฐบาล โปรดยืนยันกับที่ทำการก่อนไปสมัคร</li>
      </ul>
    </div>

    <!-- Related Calculators -->
    <RelatedCalculators categoryId="government" />
  </article>
</BaseLayout>

<script>
  import { calculatePassportFee } from '../../lib/passport-fee-calculator';

  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const passportType = (document.getElementById('passport-type') as HTMLSelectElement)
      .value as 'adult10' | 'adult5' | 'child' | 'renewal';
    const numberOfCopies = parseInt(
      (document.getElementById('num-copies') as HTMLInputElement).value || '1'
    );
    const rushService = (document.getElementById('rush-service') as HTMLInputElement)
      .checked;
    const serviceType = (document.getElementById('service-type') as HTMLSelectElement)
      .value as 'in-person' | 'postal';

    const result = calculatePassportFee({
      passportType,
      numberOfCopies,
      rushService,
      serviceType,
    });

    // Display results
    const resultDiv = document.getElementById('result');
    if (resultDiv) {
      resultDiv.classList.remove('hidden');

      document.getElementById('base-fee')!.textContent =
        result.basePassportFee.toLocaleString('th-TH') + ' บาท';
      document.getElementById('extra-fees')!.textContent =
        (result.rushServiceFee + result.postalServiceFee).toLocaleString('th-TH') + ' บาท';
      document.getElementById('total-fee')!.textContent =
        result.total.toLocaleString('th-TH') + ' บาท';

      const detailsTable = document.getElementById('details-table')!;
      detailsTable.innerHTML = `
        <div class="space-y-2">
          <div class="flex justify-between"><span>ประเภท:</span><strong>${result.passportTypeName}</strong></div>
          <div class="flex justify-between"><span>จำนวนเล่ม:</span><strong>${result.numberOfCopies} เล่ม</strong></div>
          <div class="flex justify-between"><span>วิธีรับบริการ:</span><strong>${result.serviceType}</strong></div>
          <div class="flex justify-between"><span>บริการด่วน:</span><strong>${result.rushService ? 'ใช่' : 'ไม่'}</strong></div>
        </div>
      `;
    }
  });
</script>
