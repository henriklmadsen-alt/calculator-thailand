---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณระยะเวลาถึงเป้าหมายการออม 2569 | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณจำนวนเดือน/ปีที่ต้องใช้ถึงเป้าหมายออม จากเงินต้น ออมรายเดือน และอัตราดอกเบี้ย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณระยะเวลาถึงเป้าหมาย/`;

const faqData = [
  {
    question: 'ปัจจัยอะไรส่งผลต่อระยะเวลาถึงเป้าหมาย?',
    answer: 'ปัจจัยหลักคือเงินออมปัจจุบัน เงินออมรายเดือน และอัตราดอกเบี้ย เงินออมปัจจุบันมากขึ้นและออมรายเดือนสูงขึ้นจะลดระยะเวลาได้อย่างชัดเจน ดอกเบี้ยทบต้นช่วยเร่งการเติบโตได้มากในระยะยาว โดยเฉพาะเมื่อระยะเวลาเกิน 5 ปี',
  },
  {
    question: 'เงินออมรายเดือนเท่าไหร่ถึงจะถึงล้านบาทใน 10 ปี?',
    answer: 'หากเริ่มจากศูนย์ ดอกเบี้ย 2% ต่อปี ต้องออมประมาณ 7,500 บาทต่อเดือน หากดอกเบี้ย 5% ต้องออมประมาณ 6,440 บาทต่อเดือน ลองใช้เครื่องคำนวณนี้ปรับตัวเลขตามสถานการณ์จริงของคุณ',
  },
  {
    question: 'ควรเพิ่มเงินออมรายเดือนหรือหาอัตราดอกเบี้ยสูงขึ้น?',
    answer: 'ทั้งสองวิธีช่วยลดระยะเวลาถึงเป้าหมาย แต่การเพิ่มเงินออมรายเดือนให้ผลเร็วกว่าในระยะสั้น ขณะที่การหาผลตอบแทนที่ดีกว่าให้ผลชัดเจนกว่าในระยะยาว อุดมคติคือทำทั้งสอง เพิ่มอัตราการออมและลงทุนให้ผลตอบแทนสูงขึ้นพร้อมกัน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณระยะเวลาถึงเป้าหมายการออม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณระยะเวลาถึงเป้าหมาย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณระยะเวลาถึงเป้าหมายการออม 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณจำนวนเดือน/ปีที่ต้องใช้ถึงเป้าหมายออม จากเงินต้น ออมรายเดือน และอัตราดอกเบี้ย
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="savings-timeline-form" class="space-y-5">
        <p id="savings-timeline-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="st-target" class="block text-sm font-medium text-gray-700 mb-1">เป้าหมาย (บาท)</label>
            <input type="text" id="st-target" inputmode="numeric" placeholder="เช่น 1,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="st-target-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="st-current" class="block text-sm font-medium text-gray-700 mb-1">เงินออมปัจจุบัน (บาท)</label>
            <input type="text" id="st-current" inputmode="numeric" placeholder="เช่น 100,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="st-monthly" class="block text-sm font-medium text-gray-700 mb-1">ออมเพิ่มรายเดือน (บาท)</label>
            <input type="text" id="st-monthly" inputmode="numeric" placeholder="เช่น 5,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="st-monthly-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="st-rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราดอกเบี้ย (%/ปี)</label>
            <input type="text" id="st-rate" inputmode="decimal" placeholder="เช่น 5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <button type="submit" id="savings-timeline-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ระยะเวลา</div>
            <div id="res-timeline" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">วันที่คาดถึงเป้า</div>
            <div id="res-date" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยสะสม</div>
            <div id="res-interest" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินออมสะสม</div>
            <div id="res-saved" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณระยะเวลาถึงเป้าหมายออม</h2>
      <p>เครื่องคำนวณนี้ใช้วิธี iterative simulation รายเดือน โดยคำนวณการเติบโตของยอดออมจากดอกเบี้ยทบต้นและเงินออมรายเดือน จนกว่าจะถึงเป้าหมาย</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรการเติบโตรายเดือน</h3>
      <p>ยอดใหม่ = ยอดเดิม × (1 + r/12) + เงินออมรายเดือน<br />นับจำนวนเดือนจนกว่า ยอดใหม่ &gt;= เป้าหมาย<br />หาก r = 0: จำนวนเดือน = (เป้าหมาย - เงินออมปัจจุบัน) / เงินออมรายเดือน</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">พลังของการออมสม่ำเสมอ</h3>
      <p>การออมเงินสม่ำเสมอทุกเดือนร่วมกับดอกเบี้ยทบต้นทำให้ยอดออมเติบโตแบบเอกซ์โปเนนเชียล ยิ่งเริ่มเร็ว ระยะเวลาถึงเป้าหมายยิ่งสั้นลง</p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณระยะเวลาถึงเป้าหมาย/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น อัตราดอกเบี้ยจริงอาจเปลี่ยนแปลง ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }
    const form = document.getElementById('savings-timeline-form') as HTMLFormElement;
    const submitBtn = document.getElementById('savings-timeline-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('savings-timeline-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const targetInput = document.getElementById('st-target') as HTMLInputElement;
    const currentInput = document.getElementById('st-current') as HTMLInputElement;
    const monthlyInput = document.getElementById('st-monthly') as HTMLInputElement;
    const rateInput = document.getElementById('st-rate') as HTMLInputElement;
    function setFieldError(id: string, msg: string) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.remove('hidden'); }
    function clearFieldError(id: string) { const el = document.getElementById(id); if (!el) return; el.textContent = ''; el.classList.add('hidden'); }
    function clearValidation() { formError.classList.add('hidden'); ['st-target-error','st-monthly-error'].forEach(clearFieldError); }
    [targetInput, currentInput, monthlyInput, rateInput].forEach(input => { input.addEventListener('input', clearValidation); });
    form.addEventListener('submit', (e) => {
      e.preventDefault(); clearValidation();
      const target = parseNum(targetInput.value);
      const current = parseNum(currentInput.value);
      const monthly = parseNum(monthlyInput.value);
      const annualRate = parseFloat(rateInput.value.replace(/,/g, '')) || 0;
      let hasError = false;
      if (target <= 0) { setFieldError('st-target-error', 'กรุณากรอกเป้าหมาย'); hasError = true; }
      if (monthly <= 0) { setFieldError('st-monthly-error', 'กรุณากรอกเงินออมรายเดือน'); hasError = true; }
      if (hasError) { formError.classList.remove('hidden'); return; }
      if (current >= target) {
        setFieldError('st-target-error', 'ยอดออมปัจจุบันถึงเป้าหมายแล้ว');
        formError.classList.remove('hidden'); return;
      }
      submitBtn.disabled = true; submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('savings-goal-timeline');
      const r = annualRate / 100;
      let months = 0;
      let balance = current;
      let totalInterest = 0;
      const maxMonths = 1200;
      if (r === 0) {
        months = Math.ceil((target - current) / monthly);
        balance = current + monthly * months;
        totalInterest = 0;
      } else {
        const rm = r / 12;
        while (balance < target && months < maxMonths) {
          const interest = balance * rm;
          totalInterest += interest;
          balance += interest + monthly;
          months++;
        }
      }
      const totalSaved = current + monthly * months;
      const yrs = Math.floor(months / 12);
      const mos = months % 12;
      const timelineText = (yrs > 0 ? yrs + ' ปี ' : '') + (mos > 0 ? mos + ' เดือน' : (yrs > 0 ? '' : '0 เดือน'));
      const targetDate = new Date();
      targetDate.setMonth(targetDate.getMonth() + months);
      const dateText = targetDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'long' });
      (document.getElementById('res-timeline') as HTMLElement).textContent = months < maxMonths ? timelineText : 'มากกว่า 100 ปี';
      (document.getElementById('res-date') as HTMLElement).textContent = months < maxMonths ? dateText : '-';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-saved') as HTMLElement).textContent = fmt(totalSaved) + ' บาท';
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false; submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('savings-goal-timeline');
      trackCalculatorUsed('savings-goal-timeline');
    });
  </script>
</BaseLayout>
