---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณค่าย้อมผม 2569 | Hair Dye Cost | Calculator Thailand';
const pageDescription = 'คำนวณค่าย้อมผมต่อครั้ง สี พิเศษ รูตแตน และค่าบำรุงผมย้อมต่อเดือนและปีออนไลน์ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-hair-color-cost/`;

const faqData = [
  {
    question: 'ค่าย้อมผมเฉลี่ยเท่าไหร่?',
    answer: 'สีปกติ 200-500 บาท สีพิเศษ 400-800 บาท รูตแตน 300-600 บาท แบลีช 500-1,000 บาท ขึ้นอยู่กับร้านและความยาว',
  },
  {
    question: 'ตัดสินใจว่าควรย้อมที่ร้านหรือที่บ้าน?',
    answer: 'ที่ร้านแพงกว่า แต่ผลออกมาสวยและปลอดภัยกว่า ที่บ้านประหยัดแต่มีความเสี่ยงเสียผมและสีไม่เสมอ',
  },
  {
    question: 'ย้อมผมบ่อยเท่าไหร่เป็นเท่าพอ?',
    answer: 'สี1 เดือนครึ่งต่อครั้ง สีพิเศษ 2-3 เดือนต่อครั้ง รูตแตนทุก 4-8 สัปดาห์ขึ้นอยู่ความเร็วการโตของเส้นผม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าย้อมผม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าย้อมผม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าย้อมผมต่อเดือนและต่อปี
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-fuchsia-200 bg-fuchsia-50 px-3 py-2">
      <p class="text-xs font-semibold text-fuchsia-800">[KLC-0777: อัปเดต 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าย้อมผม รูตแตน บำรุงเพิ่มเติม ต่อเดือนและต่อปี
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="regular-dye-cost" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าย้อมปกติ (บาท)
          </label>
          <input
            type="text"
            id="regular-dye-cost"
            inputmode="decimal"
            placeholder="เช่น 300"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="regular-frequency" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนครั้งต่อเดือน
          </label>
          <input
            type="text"
            id="regular-frequency"
            inputmode="decimal"
            placeholder="เช่น 0.5"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="root-touch-cost" class="block text-sm font-medium text-gray-700 mb-1">
            ค่ารูตแตน (บาท)
          </label>
          <input
            type="text"
            id="root-touch-cost"
            inputmode="decimal"
            placeholder="เช่น 400"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="root-frequency" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนครั้งต่อเดือน
          </label>
          <input
            type="text"
            id="root-frequency"
            inputmode="decimal"
            placeholder="เช่น 0.25"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="treatment-cost" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าบำรุงผม (บาท/เดือน)
          </label>
          <input
            type="text"
            id="treatment-cost"
            inputmode="decimal"
            placeholder="เช่น 200"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณ
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6">
        <div class="grid gap-4 sm:grid-cols-3 mb-6">
          <div class="text-center">
            <div class="text-sm text-gray-600 mb-1">รายเดือน</div>
            <div id="monthly-cost" class="text-3xl font-bold text-primary-600">-</div>
            <div class="text-xs text-gray-500">บาท</div>
          </div>
          <div class="text-center">
            <div class="text-sm text-gray-600 mb-1">ประมาณการต่อปี</div>
            <div id="yearly-cost" class="text-3xl font-bold text-primary-600">-</div>
            <div class="text-xs text-gray-500">บาท</div>
          </div>
          <div class="text-center">
            <div class="text-sm text-gray-600 mb-1">รายสัปดาห์โดยเฉลี่ย</div>
            <div id="weekly-cost" class="text-3xl font-bold text-primary-600">-</div>
            <div class="text-xs text-gray-500">บาท</div>
          </div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ราคาย้อมผมเฉลี่ยในไทย</h2>

      <p>
        ค่าย้อมผมในประเทศไทยแตกต่างกันตามประเภทสีและร้าน
        ย้อมปกติ 200-500 บาท
        ย้อมสีพิเศษ 400-800 บาท
        รูตแตน 300-600 บาท
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประเภทสีและราคา</h3>

      <div class="overflow-x-auto my-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b-2 border-gray-300">
              <th class="py-2 pr-4">ประเภท</th>
              <th class="py-2 pr-4">ราคา</th>
              <th class="py-2">หมายเหตุ</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ย้อมปกติ</td>
              <td class="py-2 pr-4">200-500 บาท</td>
              <td class="py-2">สีธรรมชาติหรือสีเข้มหมวก</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ย้อมสีพิเศษ</td>
              <td class="py-2 pr-4">400-800 บาท</td>
              <td class="py-2">สีสวาง ชมพู ม่วง ฯลฯ</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">รูตแตน</td>
              <td class="py-2 pr-4">300-600 บาท</td>
              <td class="py-2">ย้อมเฉพาะรากผมที่โผล่</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">บำรุงเพิ่มเติม</td>
              <td class="py-2 pr-4">100-300 บาท</td>
              <td class="py-2">แมส เซรั่ม หรือทรีทเมนต์</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีประหยัดค่าย้อมผม</h3>

      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ลดความถี่ของการย้อมผมโดยเลือกสีที่มีความเสี่ยงจางน้อย เช่น สีน้ำตาล</li>
        <li>ใช้บริการรูตแตนแทนการย้อมใหม่ทั้งหมด ประหยัดได้ 30-40%</li>
        <li>เลือกร้านที่เหมาะสมกับงบประมาณ ไม่จำเป็นต้องไปร้านแบรนด์ดัง</li>
        <li>ย้อมที่บ้านด้วยสินค้าราคาถูก แต่ต้องศึกษาวิธีใช้ให้ถูกต้อง</li>
        <li>ใช้ผมจริง Ombre หรือ Balayage เพื่อลดการดูแล</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการเท่านั้น
      ราคาจริงอาจแตกต่างตามร้านและสภาพผมของคุณ
    </div>
  </article>

  <script>
    function calculateDyeCost(
      regularCost: number,
      regularFreq: number,
      rootCost: number,
      rootFreq: number,
      treatmentCost: number
    ): { monthly: number; yearly: number; weekly: number } {
      const monthly = regularCost * regularFreq + rootCost * rootFreq + treatmentCost;
      const yearly = monthly * 12;
      const weekly = monthly / 4.33;

      return { monthly, yearly, weekly };
    }

    function formatCurrency(value: number): string {
      return new Intl.NumberFormat('th-TH', {
        style: 'currency',
        currency: 'THB',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(value);
    }

    const btncalculate = document.getElementById('btn-calculate');
    const resultDiv = document.getElementById('result');
    const monthlyCostEl = document.getElementById('monthly-cost');
    const yearlyCostEl = document.getElementById('yearly-cost');
    const weeklyCostEl = document.getElementById('weekly-cost');

    btncalculate?.addEventListener('click', () => {
      const regularCost = parseFloat((document.getElementById('regular-dye-cost') as HTMLInputElement)?.value) || 0;
      const regularFreq = parseFloat((document.getElementById('regular-frequency') as HTMLInputElement)?.value) || 0;
      const rootCost = parseFloat((document.getElementById('root-touch-cost') as HTMLInputElement)?.value) || 0;
      const rootFreq = parseFloat((document.getElementById('root-frequency') as HTMLInputElement)?.value) || 0;
      const treatmentCost = parseFloat((document.getElementById('treatment-cost') as HTMLInputElement)?.value) || 0;

      const result = calculateDyeCost(regularCost, regularFreq, rootCost, rootFreq, treatmentCost);

      monthlyCostEl!.textContent = formatCurrency(result.monthly);
      yearlyCostEl!.textContent = formatCurrency(result.yearly);
      weeklyCostEl!.textContent = formatCurrency(result.weekly);

      resultDiv!.classList.remove('hidden');
    });
  </script>
</BaseLayout>
