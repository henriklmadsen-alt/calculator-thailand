---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---
<BaseLayout pageName="คำนวณค่าแท็กซี่">  <h1 class="text-2xl font-bold mb-4">คำนวณค่าแท็กซี่</h1>
  <div class="bg-white p-6 rounded-lg border">
    <input type="number" id="distance" placeholder="ระยะทาง (กม.)" class="w-full p-2 border rounded mb-4" />
    <button onclick="calculate()" class="bg-primary-600 text-white px-4 py-2 rounded">คำนวณ</button>
    <div id="result" class="hidden mt-4 p-4 bg-blue-50 rounded">
      <div class="flex justify-between"><span>ค่าแท็กซี่</span><span id="total" class="font-bold">-</span></div>
    </div>
  </div>
  <script>
    import { calculateTaxiCost } from '../../lib/taxi-cost-calculator';
    function calculate() {
      const result = calculateTaxiCost({ distanceKm: parseInt(document.getElementById('distance').value) });
      document.getElementById('total').textContent = result.totalCost.toLocaleString('th-TH') + ' บาท';
      document.getElementById('result').classList.remove('hidden');
    }
  </script>
</BaseLayout>
