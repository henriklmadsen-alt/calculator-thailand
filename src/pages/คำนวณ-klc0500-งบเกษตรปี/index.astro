---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณงบประมาณการเกษตรรายปี | Kamnuanlek';
const pageDescription = 'คำนวณงบประมาณเกษตรกรรมประจำปี รายได้คาด ต้นทุนรวม กำไรเป้าหมาย วางแผนการเงินเกษตร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0500-งบเกษตรปี/`;
const faqData = [
  { question: 'เกษตรกรควรวางแผนงบประมาณล่วงหน้าแค่ไหน?', answer: 'วางแผนงบประมาณล่วงหน้า 1 ปีก่อนเริ่มฤดูกาล ครอบคลุมรายได้คาด ต้นทุนผันแปร ต้นทุนคงที่ เงินสำรองฉุกเฉิน 10-15% และการชำระหนี้ ทบทวนทุกฤดูกาล' },
  { question: 'เงินสำรองฉุกเฉินสำหรับเกษตรกรควรมีเท่าไหร่?', answer: 'เกษตรกรควรมีเงินสำรอง 3-6 เดือนของค่าใช้จ่ายประจำ หรือ 10-20% ของต้นทุนการผลิต เพื่อรองรับภัยพิบัติ ราคาตก หรือผลผลิตเสียหาย' },
  { question: 'จะเพิ่มรายได้เกษตรนอกฤดูกาลได้อย่างไร?', answer: 'ปลูกพืชผักระยะสั้น รับจ้างเก็บเกี่ยว แปรรูปสินค้าเกษตร ท่องเที่ยวเชิงเกษตร เลี้ยงสัตว์เสริม หรือรับจ้างตามฤดูกาล เพื่อสร้างกระแสเงินสดตลอดปี' },
  { question: 'ซอฟต์แวร์บัญชีเกษตรมีให้ใช้ฟรีไหม?', answer: 'กรมส่งเสริมการเกษตรมี Smart Farmer App และ BizFarm App ให้ใช้ฟรี บันทึกต้นทุน รายรับ รายจ่าย คำนวณกำไร และวิเคราะห์แนวโน้มฤดูกาล' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบประมาณการเกษตรรายปี">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณงบประมาณการเกษตรรายปี</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">วางแผนงบประมาณเกษตรกรรมประจำปีอย่างครบถ้วน</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="farm_target_revenue" class="block text-sm font-medium text-gray-700 mb-1">รายได้เกษตรคาดต่อปี (บาท)</label><input type="text" id="farm_target_revenue" inputmode="decimal" placeholder="เช่น 300000" value="300000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="farm_input_budget" class="block text-sm font-medium text-gray-700 mb-1">งบปัจจัยการผลิต (ปุ๋ย ยา เมล็ด) (บาท)</label><input type="text" id="farm_input_budget" inputmode="decimal" placeholder="เช่น 80000" value="80000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="farm_labor_budget" class="block text-sm font-medium text-gray-700 mb-1">งบแรงงาน (บาท)</label><input type="text" id="farm_labor_budget" inputmode="decimal" placeholder="เช่น 50000" value="50000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="farm_overhead_budget" class="block text-sm font-medium text-gray-700 mb-1">งบค่าใช้จ่ายคงที่ (เช่า เครื่องจักร ฯลฯ) (บาท)</label><input type="text" id="farm_overhead_budget" inputmode="decimal" placeholder="เช่น 40000" value="40000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="farm_emergency_budget" class="block text-sm font-medium text-gray-700 mb-1">งบสำรองฉุกเฉิน (บาท)</label><input type="text" id="farm_emergency_budget" inputmode="decimal" placeholder="เช่น 20000" value="20000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">งบรวมทั้งหมด</p><p id="farm_total_budget" class="font-bold">-</p></div>
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">กำไรเป้าหมาย</p><p id="farm_target_profit" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">อัตรากำไรเป้าหมาย</p><p id="farm_target_margin" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const revenue = parseFloat((document.getElementById('farm_target_revenue') as HTMLInputElement).value) || 0;
      const inputs = parseFloat((document.getElementById('farm_input_budget') as HTMLInputElement).value) || 0;
      const labor = parseFloat((document.getElementById('farm_labor_budget') as HTMLInputElement).value) || 0;
      const overhead = parseFloat((document.getElementById('farm_overhead_budget') as HTMLInputElement).value) || 0;
      const emergency = parseFloat((document.getElementById('farm_emergency_budget') as HTMLInputElement).value) || 0;
      const totalBudget = inputs + labor + overhead + emergency;
      const targetProfit = revenue - totalBudget;
      const targetMargin = revenue > 0 ? (targetProfit / revenue * 100) : 0;
      (document.getElementById('farm_total_budget') as HTMLElement).textContent = Math.round(totalBudget).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('farm_target_profit') as HTMLElement).textContent = Math.round(targetProfit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('farm_target_margin') as HTMLElement).textContent = targetMargin.toFixed(1) + '%';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('annual-farm-budget');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
