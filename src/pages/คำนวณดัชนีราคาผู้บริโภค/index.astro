---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import { THAI_CPI_DATA, getAvailableYears } from '../../lib/cpi-calculator.ts';

const pageTitle = 'คำนวณดัชนีราคาผู้บริโภค CPI เงินเฟ้อไทย 2569 | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณดัชนีราคาผู้บริโภค เทียบมูลค่าเงินบาทในอดีตกับปัจจุบัน ดูว่าเงิน X บาทจากปี Y มีค่าเท่าไรวันนี้ อัปเดตข้อมูล CPI ล่าสุดปี 2569 ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณดัชนีราคาผู้บริโภค/`;

const availableYears = getAvailableYears();

const faqData = [
  {
    question: 'ดัชนีราคาผู้บริโภค (CPI) คืออะไร?',
    answer: 'ดัชนีราคาผู้บริโภค (Consumer Price Index - CPI) เป็นตัวชี้วัดการเปลี่ยนแปลงของระดับราคาสินค้าและบริการที่ผู้บริโภคซื้อ จัดทำโดยสำนักดัชนีเศรษฐกิจการค้า กระทรวงพาณิชย์ ใช้เป็นเครื่องมือวัดอัตราเงินเฟ้อของไทย',
  },
  {
    question: 'เงิน 100 บาท ปี 2540 เท่ากับเท่าไรในปี 2568?',
    answer: 'เงิน 100 บาทในปี พ.ศ. 2540 มีมูลค่าเทียบเท่าประมาณ 149 บาทในปี 2568 หมายความว่าของที่เคยซื้อได้ 100 บาท ตอนนี้ต้องจ่ายเกือบ 149 บาท เพราะราคาสินค้าเพิ่มขึ้นตามเงินเฟ้อสะสม',
  },
  {
    question: 'อัตราเงินเฟ้อไทยเฉลี่ยเท่าไรต่อปี?',
    answer: 'อัตราเงินเฟ้อไทยเฉลี่ยประมาณ 2-3% ต่อปีในช่วง 10 ปีที่ผ่านมา แต่ปี 2565 เงินเฟ้อพุ่งถึง 6% จากราคาพลังงานและอาหารที่สูงขึ้น ปี 2567-2568 เงินเฟ้อกลับมาอยู่ในระดับต่ำประมาณ 0.4-1%',
  },
  {
    question: 'CPI ปีฐาน 2562 หมายความว่าอย่างไร?',
    answer: 'ปีฐาน 2562 หมายถึงกระทรวงพาณิชย์กำหนดให้ปี 2562 (ค.ศ. 2019) เป็นค่า 100 จากนั้นเทียบราคาสินค้าปีอื่นๆ กับปีนี้ เช่น CPI ปี 2565 = 106.36 แปลว่าราคาสินค้าเพิ่มขึ้น 6.36% จากปี 2562',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณดัชนีราคาผู้บริโภค CPI',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

// Serialize CPI data for client-side use
const cpiDataJson = JSON.stringify(THAI_CPI_DATA);

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณดัชนีราคาผู้บริโภค">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">เทียบค่าเงินบาทข้ามปี ด้วยข้อมูล CPI จริง</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตข้อมูล CPI ถึงปี 2568 — ปีฐาน 2562 = 100</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณดัชนีราคาผู้บริโภค CPI เทียบมูลค่าเงินบาท 2569
    </h1>

    <p class="text-gray-600 mb-6">
      เทียบมูลค่าเงินบาทในอดีตกับปัจจุบันด้วยดัชนี CPI จากกระทรวงพาณิชย์ ดูว่าเงิน X บาทจากปี Y มีค่าเท่าไรวันนี้
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="cpi-form" class="space-y-5">
        <p id="cpi-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div>
          <label for="amount" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนเงิน (บาท)
          </label>
          <input
            type="text"
            id="amount"
            inputmode="numeric"
            placeholder="เช่น 1,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p id="amount-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="from-year" class="block text-sm font-medium text-gray-700 mb-1">
              ปี พ.ศ. ต้นทาง (เงินจากปีไหน)
            </label>
            <select
              id="from-year"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              {availableYears.map((y) => (
                <option value={y} selected={y === 2550}>{y} ({y - 543})</option>
              ))}
            </select>
          </div>
          <div>
            <label for="to-year" class="block text-sm font-medium text-gray-700 mb-1">
              ปี พ.ศ. ปลายทาง (เทียบกับปีไหน)
            </label>
            <select
              id="to-year"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              {availableYears.map((y) => (
                <option value={y} selected={y === 2568}>{y} ({y - 543})</option>
              ))}
            </select>
          </div>
        </div>

        <button
          type="submit"
          id="cpi-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <!-- Main Result -->
        <div class="bg-primary-50 rounded-lg p-5 mb-6 text-center">
          <p class="text-sm text-gray-600 mb-1">
            เงิน <span id="res-orig-amount" class="font-semibold">-</span> บาท ในปี พ.ศ. <span id="res-from-year-label">-</span>
          </p>
          <p class="text-sm text-gray-600 mb-2">มีมูลค่าเทียบเท่า</p>
          <div id="res-adjusted" class="text-3xl font-bold text-primary-700">- บาท</div>
          <p class="text-sm text-gray-600 mt-1">ในปี พ.ศ. <span id="res-to-year-label">-</span></p>
        </div>

        <!-- Summary Cards -->
        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินเฟ้อสะสม</div>
            <div id="res-inflation" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินเฟ้อเฉลี่ย/ปี</div>
            <div id="res-annual-rate" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">อำนาจซื้อเปลี่ยน</div>
            <div id="res-purchasing-power" class="text-xl font-bold text-purple-700">-</div>
          </div>
        </div>

        <!-- Detail Rows -->
        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนเงินต้นทาง</span>
            <span id="res-amount-detail" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">CPI ปี <span id="res-from-cpi-year">-</span></span>
            <span id="res-from-cpi" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">CPI ปี <span id="res-to-cpi-year">-</span></span>
            <span id="res-to-cpi" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ช่วงเวลา</span>
            <span id="res-year-span" class="font-medium">-</span>
          </div>
        </div>

        <!-- Explanation -->
        <div class="bg-gray-50 rounded-lg p-4 text-sm text-gray-700">
          <p id="res-explanation">-</p>
        </div>
      </div>
    </div>

    <div id="cpi-next-action" class="hidden mb-6 rounded-xl border border-primary-200 bg-primary-50 p-4">
      <p class="text-sm font-semibold text-primary-800">ทำต่อ: คำนวณดอกเบี้ยเงินฝาก</p>
      <p class="mt-1 text-sm text-primary-700">ดูว่าดอกเบี้ยเงินฝากชนะเงินเฟ้อหรือไม่ ด้วยเครื่องคำนวณดอกเบี้ยเงินฝาก</p>
      <div class="mt-3 flex flex-wrap gap-3">
        <a data-next-action-link href="/คำนวณดอกเบี้ยเงินฝาก/" class="inline-flex min-h-11 items-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-700">ทำต่อ: คำนวณดอกเบี้ยเงินฝาก</a>
        <a data-next-action-link href="/คำนวณเงินเกษียณ/" class="inline-flex min-h-11 items-center rounded-lg border border-primary-300 bg-white px-4 py-2 text-sm font-semibold text-primary-700 hover:border-primary-400">อ่านต่อ: คำนวณเงินเกษียณ</a>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ดัชนีราคาผู้บริโภคคืออะไร</h2>

      <p>
        ดัชนีราคาผู้บริโภค (Consumer Price Index หรือ CPI) เป็นเครื่องมือที่กระทรวงพาณิชย์ใช้วัดการเปลี่ยนแปลงของระดับราคาสินค้าและบริการในตะกร้าสินค้าที่ผู้บริโภคซื้อเป็นประจำ
        CPI เป็นตัวชี้วัดหลักในการวัดอัตราเงินเฟ้อของประเทศไทย
      </p>

      <p>
        สำนักดัชนีเศรษฐกิจการค้า กระทรวงพาณิชย์ จัดทำดัชนีราคาผู้บริโภคทุกเดือน โดยสำรวจราคาสินค้าและบริการกว่า 430 รายการ
        จาก 7 หมวดหลัก ได้แก่ อาหารและเครื่องดื่มไม่มีแอลกอฮอล์ เครื่องนุ่งห่มและรองเท้า เคหสถาน การตรวจรักษาและบริการส่วนบุคคล
        พาหนะ การขนส่งและการสื่อสาร การบันเทิง การอ่าน การศึกษาฯ และยาสูบและเครื่องดื่มมีแอลกอฮอล์
      </p>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">สูตรคำนวณมูลค่าเงินตาม CPI</h2>

      <p>การคำนวณมูลค่าเงินเทียบเท่าข้ามปีใช้สูตร:</p>

      <div class="bg-gray-50 p-4 rounded-lg my-4 font-mono text-sm">
        มูลค่าเทียบเท่า = จำนวนเงิน × (CPI ปีปลายทาง ÷ CPI ปีต้นทาง)
      </div>

      <p>อัตราเงินเฟ้อสะสมคำนวณจาก:</p>

      <div class="bg-gray-50 p-4 rounded-lg my-4 font-mono text-sm">
        เงินเฟ้อสะสม (%) = ((CPI ปีปลาย − CPI ปีต้น) ÷ CPI ปีต้น) × 100
      </div>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">ตัวอย่างการคำนวณ</h2>

      <p>เงิน 1,000 บาท ในปี พ.ศ. 2550 เทียบกับปี 2568:</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>CPI ปี 2550 = 95.42</li>
        <li>CPI ปี 2568 = 108.83</li>
        <li>มูลค่าเทียบเท่า = 1,000 × (108.83 ÷ 95.42) = <strong>1,140.54 บาท</strong></li>
        <li>เงินเฟ้อสะสม = ((108.83 − 95.42) ÷ 95.42) × 100 = <strong>14.05%</strong></li>
        <li>เงินเฟ้อเฉลี่ย = ประมาณ <strong>0.73%</strong> ต่อปี (ช่วง 18 ปี)</li>
      </ul>

      <p class="mt-4">
        หมายความว่าของที่เคยซื้อได้ 1,000 บาทในปี 2550 ตอนนี้ต้องจ่าย 1,140.54 บาท
        อำนาจซื้อของเงิน 1,000 บาทลดลงไปจากเดิม
      </p>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">ตาราง CPI ไทยย้อนหลัง สรุป</h2>

      <p>
        ข้อมูลด้านล่างเป็นดัชนีราคาผู้บริโภคทั่วไปเฉลี่ยรายปี ปีฐาน 2562 = 100
        เผยแพร่โดยสำนักดัชนีเศรษฐกิจการค้า กระทรวงพาณิชย์ ข้อมูลก่อนปี 2562 คำนวณเทียบกลับ (rebased) จากชุดปีฐานเดิม
      </p>

      <div class="overflow-x-auto my-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b border-gray-200">
              <th class="py-2 pr-4">ปี พ.ศ.</th>
              <th class="py-2 pr-4">ปี ค.ศ.</th>
              <th class="py-2 text-right">CPI (ฐาน 2562=100)</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr class="border-b border-gray-100"><td class="py-1">2536</td><td class="py-1">1993</td><td class="py-1 text-right">58.93</td></tr>
            <tr class="border-b border-gray-100"><td class="py-1">2540</td><td class="py-1">1997</td><td class="py-1 text-right">73.10</td></tr>
            <tr class="border-b border-gray-100"><td class="py-1">2545</td><td class="py-1">2002</td><td class="py-1 text-right">82.16</td></tr>
            <tr class="border-b border-gray-100"><td class="py-1">2550</td><td class="py-1">2007</td><td class="py-1 text-right">95.42</td></tr>
            <tr class="border-b border-gray-100"><td class="py-1">2555</td><td class="py-1">2012</td><td class="py-1 text-right">110.00</td></tr>
            <tr class="border-b border-gray-100"><td class="py-1">2560</td><td class="py-1">2017</td><td class="py-1 text-right">114.37</td></tr>
            <tr class="border-b border-gray-100 font-semibold"><td class="py-1">2562</td><td class="py-1">2019</td><td class="py-1 text-right">100.00</td></tr>
            <tr class="border-b border-gray-100"><td class="py-1">2565</td><td class="py-1">2022</td><td class="py-1 text-right">106.36</td></tr>
            <tr class="border-b border-gray-100"><td class="py-1">2567</td><td class="py-1">2024</td><td class="py-1 text-right">108.06</td></tr>
            <tr class="border-b border-gray-100"><td class="py-1">2568</td><td class="py-1">2025</td><td class="py-1 text-right">108.83</td></tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">ข้อควรระวัง</h2>

      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>CPI เป็นค่าเฉลี่ยทั้งประเทศ ราคาสินค้าบางอย่างอาจเพิ่มมากกว่าหรือน้อยกว่า CPI</li>
        <li>ข้อมูลก่อนปี 2562 เป็นการคำนวณเทียบกลับ (rebased) อาจมีความคลาดเคลื่อนเล็กน้อย</li>
        <li>CPI ไม่รวมราคาสินทรัพย์ เช่น อสังหาริมทรัพย์ หุ้น ทองคำ ซึ่งอาจเพิ่มขึ้นมากกว่า CPI</li>
        <li>เงินเฟ้อเฉลี่ยต่อปีเป็นค่าเฉลี่ยเรขาคณิต ไม่ใช่เลขคณิต จึงแม่นยำกว่าการหาร</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณดัชนีราคาผู้บริโภค/" />
    <RelatedCalculators currentHref="/คำนวณดัชนีราคาผู้บริโภค/" />

    <!-- Source -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">แหล่งข้อมูล</h2>
      <ul class="list-disc pl-6 space-y-1 text-sm text-gray-600">
        <li>สำนักดัชนีเศรษฐกิจการค้า กระทรวงพาณิชย์ — ดัชนีราคาผู้บริโภคทั่วไป ปีฐาน 2562</li>
        <li>ธนาคารแห่งประเทศไทย — รายงานอัตราเงินเฟ้อ</li>
      </ul>
    </section>

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการจากดัชนี CPI เฉลี่ยรายปี
      ราคาสินค้าบางรายการอาจเปลี่ยนแปลงมากหรือน้อยกว่าดัชนีเฉลี่ย ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script define:vars={{ cpiDataJson }}>
    const CPI_DATA = JSON.parse(cpiDataJson);

    function parseNum(v) {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function hasInvalidNumber(v) {
      const normalized = v.replace(/,/g, '').trim();
      return normalized !== '' && Number.isNaN(Number(normalized));
    }

    function fmt(n, decimals = 2) {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: decimals, maximumFractionDigits: decimals }).format(n);
    }

    const form = document.getElementById('cpi-form');
    const submitBtn = document.getElementById('cpi-submit-btn');
    const formError = document.getElementById('cpi-form-error');
    const amountInput = document.getElementById('amount');
    const fromYearSelect = document.getElementById('from-year');
    const toYearSelect = document.getElementById('to-year');
    const resultsDiv = document.getElementById('results');
    const nextActionCard = document.getElementById('cpi-next-action');

    function setFieldError(elementId, message) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearFieldError(elementId) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      clearFieldError('amount-error');
    }

    function updateSubmitState() {
      const ready = parseNum(amountInput.value) > 0;
      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณทันที' : 'กรอกจำนวนเงิน';
      submitBtn.classList.toggle('opacity-70', !ready);
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
    }

    amountInput.addEventListener('input', () => {
      clearValidation();
      updateSubmitState();
    });
    updateSubmitState();

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearValidation();

      const amount = parseNum(amountInput.value);
      const fromYear = parseInt(fromYearSelect.value);
      const toYear = parseInt(toYearSelect.value);

      if (hasInvalidNumber(amountInput.value)) {
        formError.classList.remove('hidden');
        setFieldError('amount-error', 'รูปแบบข้อมูลไม่ถูกต้อง');
        amountInput.focus();
        updateSubmitState();
        return;
      }

      if (amount <= 0) {
        formError.classList.remove('hidden');
        setFieldError('amount-error', 'กรุณากรอกจำนวนเงินมากกว่า 0');
        amountInput.focus();
        updateSubmitState();
        return;
      }

      if (fromYear === toYear) {
        formError.textContent = 'กรุณาเลือกปีต้นทางและปลายทางต่างกัน';
        formError.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('cpi');

      const fromCpi = CPI_DATA[fromYear];
      const toCpi = CPI_DATA[toYear];
      const adjustedAmount = amount * (toCpi / fromCpi);
      const yearSpan = Math.abs(toYear - fromYear);
      const inflationRate = ((toCpi - fromCpi) / fromCpi) * 100;
      const annualizedRate = yearSpan > 0 ? (Math.pow(toCpi / fromCpi, 1 / yearSpan) - 1) * 100 : 0;
      const purchasingPowerChange = ((fromCpi - toCpi) / toCpi) * 100;

      // Update main result
      document.getElementById('res-orig-amount').textContent = fmt(amount, 0);
      document.getElementById('res-from-year-label').textContent = fromYear;
      document.getElementById('res-adjusted').textContent = fmt(adjustedAmount) + ' บาท';
      document.getElementById('res-to-year-label').textContent = toYear;

      // Summary cards
      const inflSign = inflationRate >= 0 ? '+' : '';
      document.getElementById('res-inflation').textContent = inflSign + fmt(inflationRate) + '%';
      document.getElementById('res-annual-rate').textContent = (annualizedRate >= 0 ? '+' : '') + fmt(annualizedRate) + '%';
      document.getElementById('res-purchasing-power').textContent = (purchasingPowerChange >= 0 ? '+' : '') + fmt(purchasingPowerChange) + '%';

      // Color-code purchasing power
      const ppEl = document.getElementById('res-purchasing-power');
      ppEl.classList.remove('text-red-700', 'text-green-700', 'text-purple-700');
      ppEl.classList.add(purchasingPowerChange > 0 ? 'text-green-700' : purchasingPowerChange < 0 ? 'text-red-700' : 'text-purple-700');

      // Detail rows
      document.getElementById('res-amount-detail').textContent = fmt(amount) + ' บาท';
      document.getElementById('res-from-cpi-year').textContent = fromYear;
      document.getElementById('res-from-cpi').textContent = fmt(fromCpi);
      document.getElementById('res-to-cpi-year').textContent = toYear;
      document.getElementById('res-to-cpi').textContent = fmt(toCpi);
      document.getElementById('res-year-span').textContent = yearSpan + ' ปี';

      // Explanation
      const direction = toCpi > fromCpi ? 'เพิ่มขึ้น' : 'ลดลง';
      const explanation = `ระดับราคาสินค้า${direction}จากปี ${fromYear} ถึง ${toYear} ` +
        `ดังนั้นเงิน ${fmt(amount, 0)} บาท ในปี ${fromYear} ` +
        `ต้องใช้เงิน ${fmt(adjustedAmount)} บาท ในปี ${toYear} เพื่อซื้อสินค้าเดียวกัน ` +
        `(เงินเฟ้อสะสม ${inflSign}${fmt(inflationRate)}% หรือเฉลี่ย ${(annualizedRate >= 0 ? '+' : '')}${fmt(annualizedRate)}% ต่อปี)`;
      document.getElementById('res-explanation').textContent = explanation;

      resultsDiv.classList.remove('hidden');
      nextActionCard.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณทันที';
      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('cpi');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('cpi');
    });

    document.querySelectorAll('[data-next-action-link]').forEach((link) => {
      link.addEventListener('click', () => {
        if (typeof window.gtag === 'function') {
          const href = link.getAttribute('href') || '';
          window.gtag('event', 'next_action_click', {
            calculator: 'cpi',
            target_href: href,
          });
        }
      });
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (typeof trackResultViewed === 'function') trackResultViewed('cpi');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
