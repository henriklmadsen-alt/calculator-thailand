---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณความสิ้นเปลืองไฟฟ้า ปี 2569 — Electricity Consumption Forecast | Kamnuanlek';
const pageDescription = 'ประมาณการความสิ้นเปลืองไฟฟ้าเดือนถัดไป';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณความสิ้นเปลืองไฟฟ้า/`;

const faqData = [
  {
    question: 'สูตรคำนวณคืออะไร?',
    answer: 'สูตร: kWh/เดือน = (กำลัง × ชั่วโมง × 30) ÷ 1000',
  },
  {
    question: 'ผลลัพธ์แตกต่างจากความเป็นจริงได้หรือ?',
    answer: 'ใช่ ผลลัพธ์นี้เป็นการประมาณการเท่านั้น ค่าจริงอาจแตกต่างขึ้นอยู่กับสภาพการณ์และราคาปัจจุบัน',
  },
  {
    question: 'ควรปรึกษาใครเพื่อเพิ่มเติมข้อมูล?',
    answer: 'ควรปรึกษาสถาปนิก ผู้รับเหมา หรือผู้เชี่ยวชาญการก่อสร้างเพื่อขอคำปรึกษา',
  },
,
  { question: 'ค่าไฟฟ้าในไทยใช้อัตราแบบไหน?', answer: 'ใช้อัตราก้าวหน้า (Progressive Rate) — ยิ่งใช้มากยิ่งแพงต่อหน่วย MEA/PEA มีอัตรา 3 ช่วง ตามประกาศคณะกรรมการกำกับกิจการพลังงาน (กกพ.) บวกค่า FT (Fuel Tariff) ที่เปลี่ยนทุก 4 เดือน' },
  { question: 'ค่า FT คืออะไรและส่งผลต่อค่าไฟอย่างไร?', answer: 'FT (Fuel Adjustment Charge) คือค่าปรับตามต้นทุนเชื้อเพลิง ปรับทุก 4 เดือน ถ้า FT เป็นบวกหมายถึงค่าไฟแพงขึ้น ถ้าเป็นลบถูกลง ส่งผลให้ค่าไฟรายเดือนเปลี่ยนแปลงได้ 5-15%' },
  { question: 'ประหยัดค่าไฟได้อย่างไรบ้าง?', answer: 'ปิดอุปกรณ์ที่ไม่ใช้งาน (standby กิน 5-10% ของค่าไฟ), ใช้หลอด LED แทนหลอดเก่า, ตั้งแอร์ที่ 25-26°C, ซักผ้าครั้งเดียวให้เต็มถัง, ตรวจสอบฉนวนและซีลประตูตู้เย็น' },
  { question: 'มิเตอร์ไฟฟ้าขนาด 5(15) A กับ 15(45) A ต่างกันอย่างไร?', answer: 'ขนาดมิเตอร์กำหนดกระแสสูงสุด ครัวเรือนทั่วไปใช้ 5(15) A เพียงพอ บ้านใหญ่หรือใช้เครื่องใช้ไฟฟ้ากำลังสูงมากควรใช้ 15(45) A ค่าไฟคิดในอัตราเดียวกัน แต่ค่าบริการรายเดือนต่างกัน' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ คำนวณความสิ้นเปลืองไฟฟ้า',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณความสิ้นเปลืองไฟฟ้า">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-orange-100 bg-orange-50 p-4">
      <p class="text-sm font-semibold text-orange-700">คำนวณความสิ้นเปลืองไฟฟ้า</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: kWh/เดือน = (กำลัง × ชั่วโมง × 30) ÷ 1000</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณความสิ้นเปลืองไฟฟ้า ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ประมาณการความสิ้นเปลืองไฟฟ้าเดือนถัดไป
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc_0340" class="space-y-5">
        <p id="calc_0340-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

                <div>
            <label for="calc_0340-wattage" class="mb-1 block text-sm font-medium text-gray-700">กำลัง (W)</label>
            <input type="text" id="calc_0340-wattage" inputmode="numeric" placeholder="เช่น 1000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="calc_0340-wattage-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        <div>
            <label for="calc_0340-hours_per_day" class="mb-1 block text-sm font-medium text-gray-700">ชั่วโมงใช้ต่อวัน (h)</label>
            <input type="text" id="calc_0340-hours_per_day" inputmode="numeric" placeholder="เช่น 8"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="calc_0340-hours_per_day-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>


        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="calc_0340-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="rounded-lg bg-green-50 p-4">
          <div class="mb-1 text-sm text-gray-600">ผลลัพธ์</div>
          <div id="res-calc_0340" class="text-2xl font-bold text-green-700">-</div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <p class="text-gray-700">kWh/เดือน = (กำลัง × ชั่วโมง × 30) ÷ 1000</p>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#calc_0340-results" />

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.mea.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">การไฟฟ้านครหลวง MEA (mea.or.th)</a> — อัตราค่าไฟฟ้าและโครงสร้างราคา</li>
        <li><a href="https://www.pea.co.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">การไฟฟ้าส่วนภูมิภาค PEA (pea.co.th)</a> — อัตราค่าไฟฟ้าต่างจังหวัด</li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณความสิ้นเปลืองไฟฟ้า/" />
    <RelatedCalculators currentHref="/คำนวณความสิ้นเปลืองไฟฟ้า/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> คำนวณการประมาณการเท่านั้น ค่าจริงอาจแตกต่างได้
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('calc_0340')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('calc_0340-error').classList.add('hidden');

            const wattage = parseNum(document.getElementById("calc_0340-wattage").value);
      const hours_per_day = parseNum(document.getElementById("calc_0340-hours_per_day").value);
      let hasError = false;
      if (!Number.isFinite(wattage) || wattage <= 0) { setErr('calc_0340-wattage-error', 'กรอกค่ามากกว่า 0'); hasError = true; }
      if (hasError) { document.getElementById('calc_0340-error').classList.remove('hidden'); document.getElementById('calc_0340-results').classList.add('hidden'); return; }

      const result = wattage * hours_per_day;
      setText('res-calc_0340', fmt(result));

      document.getElementById('calc_0340-results').classList.remove('hidden');
      document.getElementById('calc_0340-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
