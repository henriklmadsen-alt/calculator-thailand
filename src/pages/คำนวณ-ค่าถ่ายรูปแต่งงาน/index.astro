---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';

const pageTitle = 'คำนวณค่าถ่ายรูปแต่งงาน 2569 | ฟรีวิดีโอ | Calculator Thailand';
const pageDescription = 'คำนวณค่าถ่ายรูป วิดีโอ อัลบั้ม พิมพ์ และแฟรม สำหรับงานแต่งงาน ออนไลน์ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าถ่ายรูปแต่งงาน/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าถ่ายรูปแต่งงาน">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าถ่ายรูปแต่งงาน</h1>
    <div class="mb-4 inline-block rounded-lg border border-pink-200 bg-pink-50 px-3 py-2">
      <p class="text-xs font-semibold text-pink-800">[ค่าบริการ 2569]</p>
    </div>
    <p class="text-gray-600 mb-6">คำนวณค่าถ่ายรูปและวิดีโอแต่งงาน พร้อมค่าเพิ่มเติม</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="photographer" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าภาพยนตร์/ช่างภาพ (บาท)
          </label>
          <input type="text" id="photographer" inputmode="decimal" placeholder="เช่น 100000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="videographer" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าถ่ายวิดีโอ (บาท)
          </label>
          <input type="text" id="videographer" inputmode="decimal" placeholder="เช่น 50000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="album" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าอัลบั้มรูป (บาท)
          </label>
          <input type="text" id="album" inputmode="decimal" placeholder="เช่น 20000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="prints" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าพิมพ์รูป (บาท)
          </label>
          <input type="text" id="prints" inputmode="decimal" placeholder="เช่น 15000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
      </div>
      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-pink-600 text-white font-semibold rounded-md hover:bg-pink-700 transition-colors text-base">
        คำนวณรวม
      </button>
      <div id="result" class="hidden mt-8 border-t pt-6">
        <div class="bg-pink-50 rounded-lg p-6 text-center">
          <div class="text-sm text-gray-600 mb-2">ค่าถ่ายรูปรวม</div>
          <div class="text-5xl font-bold text-pink-700"><span id="total">-</span></div>
          <div class="text-sm text-gray-600">บาท</div>
        </div>
      </div>
    </div>
    <RelatedCalculators />
    <RelatedArticles />
  </article>
</BaseLayout>

<script>
  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const photographer = parseFloat(document.getElementById('photographer')?.value || 0);
    const videographer = parseFloat(document.getElementById('videographer')?.value || 0);
    const album = parseFloat(document.getElementById('album')?.value || 0);
    const prints = parseFloat(document.getElementById('prints')?.value || 0);
    const total = photographer + videographer + album + prints;
    if (total === 0) { alert('กรุณาป้อนค่าใช้จ่าย'); return; }
    document.getElementById('total').textContent = total.toLocaleString('th-TH');
    document.getElementById('result').classList.remove('hidden');
  });
</script>
