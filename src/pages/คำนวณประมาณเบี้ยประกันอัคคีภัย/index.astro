---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณประมาณเบี้ยประกันอัคคีภัย 2569 | บ้านและอาคาร | เครื่องคำนวณไทย';
const pageDescription = 'ประมาณการเบี้ยประกันอัคคีภัยสำหรับบ้าน อาคาร และทรัพย์สิน ตามมูลค่า ประเภทอาคาร และการใช้งาน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประมาณเบี้ยประกันอัคคีภัย/`;

const faqData = [
  {
    question: 'ประกันอัคคีภัยครอบคลุมอะไรบ้าง?',
    answer: 'ประกันอัคคีภัยพื้นฐานครอบคลุม 3 ภัย ได้แก่ ไฟไหม้ ฟ้าผ่า และการระเบิดของแก๊ส โดยคุ้มครองทั้งตัวอาคาร ทรัพย์สินภายใน และค่าซ่อมแซม บางกรมธรรม์มีความคุ้มครองเพิ่มเติม เช่น ลมพายุ น้ำท่วม โจรกรรม',
  },
  {
    question: 'อาคารไม้มีเบี้ยสูงกว่าอาคารคอนกรีตเพราะอะไร?',
    answer: 'อาคารไม้ติดไฟได้ง่ายกว่าและลุกลามเร็วกว่าอาคารคอนกรีต ทำให้ความเสี่ยงต่อไฟไหม้สูงกว่ามาก บริษัทประกันจึงคิดเบี้ยสำหรับอาคารไม้สูงกว่าอาคารคอนกรีต 2-3 เท่า เพื่อสะท้อนความเสี่ยงที่แตกต่างกัน',
  },
  {
    question: 'ต้องทำประกันอัคคีภัยบ้านในมูลค่าเท่าไหร่?',
    answer: 'ควรทำประกันในมูลค่าที่ต้องใช้สร้างบ้านใหม่ทั้งหลัง (Replacement Cost) ไม่ใช่ราคาตลาด เพราะราคาก่อสร้างใหม่อาจต่างจากราคาขาย หากทำประกันต่ำกว่ามูลค่าจริงอาจเจอ Average Clause ที่บริษัทจ่ายค่าเสียหายตามสัดส่วน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณประมาณเบี้ยประกันอัคคีภัย',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประมาณเบี้ยประกันอัคคีภัย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณเบี้ยประกันอัคคีภัย 2569</p>
      <p class="mt-1 text-sm text-slate-700">ตัวเลขเป็นการประมาณการ เพื่อใช้วางแผนเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณประมาณเบี้ยประกันอัคคีภัย 2569 — บ้านและอาคาร
    </h1>

    <p class="text-gray-600 mb-6">
      ประมาณการเบี้ยประกันอัคคีภัยตามประเภทอาคาร การใช้งาน และมูลค่าทรัพย์สิน
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="fire-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fire-building" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าอาคาร (บาท)</label>
            <input type="text" id="fire-building" inputmode="numeric" placeholder="เช่น 3,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="fire-building-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="fire-contents" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าทรัพย์สิน (บาท)</label>
            <input type="text" id="fire-contents" inputmode="numeric" placeholder="เช่น 500,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fire-construction" class="block text-sm font-medium text-gray-700 mb-1">ประเภทอาคาร</label>
            <select id="fire-construction" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="wood">ไม้ทั้งหลัง</option>
              <option value="half">ครึ่งตึกครึ่งไม้</option>
              <option value="concrete" selected>ตึก/คอนกรีต</option>
            </select>
          </div>
          <div>
            <label for="fire-usage" class="block text-sm font-medium text-gray-700 mb-1">ประเภทการใช้งาน</label>
            <select id="fire-usage" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="residential" selected>ที่อยู่อาศัย</option>
              <option value="commercial">พาณิชย์/ร้านค้า</option>
              <option value="warehouse">คลังสินค้า/โกดัง</option>
            </select>
          </div>
        </div>

        <button type="submit" id="fire-submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ (ประมาณการ)</h2>
        <div class="space-y-2 mb-4">
          <div class="flex justify-between py-2 border-b border-gray-100"><span class="text-gray-600">เบี้ยอาคาร</span><span id="res-building" class="font-medium">-</span></div>
          <div class="flex justify-between py-2 border-b border-gray-100"><span class="text-gray-600">เบี้ยทรัพย์สิน</span><span id="res-contents" class="font-medium">-</span></div>
          <div class="flex justify-between py-3 bg-primary-50 px-3 rounded-lg">
            <span class="font-bold">รวมเบี้ยรายปี</span>
            <span id="res-total" class="text-xl font-bold text-primary-700">-</span>
          </div>
        </div>
        <p id="res-note" class="text-sm text-gray-600 mt-2">-</p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">อัตราเบี้ยประกันอัคคีภัย (ประมาณการ)</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200">
          <thead><tr class="bg-gray-50"><th class="px-4 py-2 text-left border-b">ประเภทอาคาร</th><th class="px-4 py-2 text-right border-b">ที่อยู่อาศัย</th><th class="px-4 py-2 text-right border-b">พาณิชย์</th><th class="px-4 py-2 text-right border-b">คลังสินค้า</th></tr></thead>
          <tbody>
            <tr class="border-b"><td class="px-4 py-2">ตึก/คอนกรีต</td><td class="px-4 py-2 text-right">0.12%</td><td class="px-4 py-2 text-right">0.18%</td><td class="px-4 py-2 text-right">0.24%</td></tr>
            <tr class="border-b"><td class="px-4 py-2">ครึ่งตึกครึ่งไม้</td><td class="px-4 py-2 text-right">0.25%</td><td class="px-4 py-2 text-right">0.375%</td><td class="px-4 py-2 text-right">0.50%</td></tr>
            <tr><td class="px-4 py-2">ไม้ทั้งหลัง</td><td class="px-4 py-2 text-right">0.40%</td><td class="px-4 py-2 text-right">0.60%</td><td class="px-4 py-2 text-right">0.80%</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณประมาณเบี้ยประกันอัคคีภัย/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงต้องสอบถามบริษัทประกันภัยโดยตรง อัตราอาจแตกต่างตามบริษัทและเงื่อนไขกรมธรรม์
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n) + ' บาท'; }

    const form = document.getElementById('fire-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    function setErr(id: string, msg: string) { const el = document.getElementById(id); if (el) { el.textContent = msg; el.classList.remove('hidden'); } }
    function clearErr(id: string) { const el = document.getElementById(id); if (el) { el.textContent = ''; el.classList.add('hidden'); } }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearErr('fire-building-error');

      const building = parseNum((document.getElementById('fire-building') as HTMLInputElement).value);
      const contents = parseNum((document.getElementById('fire-contents') as HTMLInputElement).value);
      const construction = (document.getElementById('fire-construction') as HTMLSelectElement).value;
      const usage = (document.getElementById('fire-usage') as HTMLSelectElement).value;

      if (building <= 0) { setErr('fire-building-error', 'กรุณากรอกมูลค่าอาคาร'); return; }

      trackCalculatorStart('fire-insurance-estimate');

      const baseRates: Record<string, number> = { wood: 0.004, half: 0.0025, concrete: 0.0012 };
      const usageMultipliers: Record<string, number> = { residential: 1.0, commercial: 1.5, warehouse: 2.0 };

      const rate = (baseRates[construction] || 0.0012) * (usageMultipliers[usage] || 1.0);
      const buildingPremium = building * rate;
      const contentsPremium = contents * rate * 1.1;
      const total = buildingPremium + contentsPremium;

      const usageNames: Record<string, string> = { residential: 'ที่อยู่อาศัย', commercial: 'พาณิชย์', warehouse: 'คลังสินค้า' };
      const constructionNames: Record<string, string> = { wood: 'ไม้', half: 'ครึ่งตึกครึ่งไม้', concrete: 'ตึก/คอนกรีต' };

      (document.getElementById('res-building') as HTMLElement).textContent = fmt(buildingPremium);
      (document.getElementById('res-contents') as HTMLElement).textContent = contents > 0 ? fmt(contentsPremium) : 'ไม่รวม';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(total);
      (document.getElementById('res-note') as HTMLElement).textContent = `อาคาร${constructionNames[construction]} | ใช้เป็น${usageNames[usage]} | อัตราเบี้ย ${(rate * 100).toFixed(3)}%`;

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('fire-insurance-estimate');
      trackCalculatorUsed('fire-insurance-estimate');
    });
  </script>
</BaseLayout>
