---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่าใช้จ่ายร่วม ปี 2569 — Shared Expense Settlement | Kamnuanlek';
const pageDescription = 'คำนวณการชำระค่าใช้จ่ายร่วมกลุ่ม ป้อนค่าใช้จ่ายแต่ละคนและจำนวนสมาชิก ระบบจะคำนวณว่าใครต้องโอนให้ใครเท่าไหร่';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าใช้จ่ายร่วม/`;

const faqData = [
  {
    question: 'Shared Expense Settlement คืออะไร?',
    answer: 'การชำระค่าใช้จ่ายร่วมกันในกลุ่ม เช่น ทริปท่องเที่ยว หรืออยู่ร่วมกัน โดยคำนวณว่าใครจ่ายเกินควรได้รับคืน ใครจ่ายน้อยต้องโอนจ่าย',
  },
  {
    question: 'วิธีคำนวณค่าใช้จ่ายร่วม?',
    answer: 'ยอดเฉลี่ยต่อคน = ยอดรวม ÷ จำนวนสมาชิก ถ้าจ่ายไปมากกว่าค่าเฉลี่ย = ได้รับคืน, ถ้าจ่ายน้อยกว่า = ต้องโอนจ่าย',
  },
  {
    question: 'แอปไหนที่ช่วยจัดการค่าใช้จ่ายร่วม?',
    answer: 'มีหลายแอปเช่น Splitwise, Tricount หรือ LINE Pay ที่ช่วยติดตามและชำระค่าใช้จ่ายร่วมในกลุ่ม เครื่องคำนวณนี้ใช้สำหรับคำนวณรอบเดียว',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าใช้จ่ายร่วม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าใช้จ่ายร่วม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-teal-100 bg-teal-50 p-4">
      <p class="text-sm font-semibold text-teal-700">คำนวณค่าใช้จ่ายร่วม — Shared Expense Settlement</p>
      <p class="mt-1 text-sm text-slate-700">ป้อนยอดที่แต่ละคนจ่ายไป ระบบคำนวณว่าใครได้คืน/ต้องโอน</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าใช้จ่ายร่วม ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนชื่อและจำนวนเงินที่แต่ละคนจ่ายไป เพื่อดูว่าใครต้องโอนให้ใครเท่าไหร่
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-800">รายการสมาชิก</h2>
        <button type="button" id="se-add" class="rounded-md bg-teal-100 px-3 py-1 text-sm font-medium text-teal-700 hover:bg-teal-200">
          + เพิ่มสมาชิก
        </button>
      </div>

      <div id="se-members" class="space-y-3 mb-4">
        <!-- rows injected by JS -->
      </div>

      <button type="button" id="se-calc" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 sm:w-auto">
        คำนวณค่าใช้จ่ายร่วม
      </button>
    </div>

    <div id="se-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-teal-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดรวมทั้งหมด</div>
            <div id="res-se-total" class="text-xl font-bold text-teal-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าเฉลี่ยต่อคน</div>
            <div id="res-se-avg" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-gray-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">จำนวนสมาชิก</div>
            <div id="res-se-count" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>
        <div id="se-settlement" class="space-y-2"></div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าเฉลี่ย = ยอดรวม ÷ จำนวนสมาชิก</li>
        <li>ยอดของแต่ละคน − ค่าเฉลี่ย = บวก (ได้รับ), ลบ (ต้องจ่าย)</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณแบ่งชำระ/">คำนวณแบ่งชำระ</a></li>
        <li><a href="/วางแผนงบประมาณครอบครัว/">วางแผนงบประมาณครอบครัว</a></li>
        <li><a href="/คำนวณงบเดินทางท่องเที่ยว/">คำนวณงบเดินทางท่องเที่ยว</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#se-results" />
    <RelatedArticles currentHref="/คำนวณค่าใช้จ่ายร่วม/" />
    <RelatedCalculators currentHref="/คำนวณค่าใช้จ่ายร่วม/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }

    const membersDiv = document.getElementById('se-members');
    let memberCount = 0;

    function addMember(name = '', amount = '') {
      memberCount++;
      const id = memberCount;
      const row = document.createElement('div');
      row.id = `se-row-${id}`;
      row.className = 'flex gap-2 items-start';
      row.innerHTML = `
        <div class="flex-1">
          <input type="text" placeholder="ชื่อ (เช่น ก)" value="${name}"
            class="se-name w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none" />
        </div>
        <div class="flex-1">
          <input type="text" inputmode="numeric" placeholder="จำนวนเงินที่จ่าย" value="${amount}"
            class="se-amount w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none" />
        </div>
        <button type="button" onclick="document.getElementById('se-row-${id}').remove()" class="mt-1 text-red-400 hover:text-red-600 text-xl leading-none">×</button>
      `;
      membersDiv.appendChild(row);
    }

    // Add 3 default rows
    addMember('ก', '');
    addMember('ข', '');
    addMember('ค', '');

    document.getElementById('se-add')?.addEventListener('click', () => addMember());

    document.getElementById('se-calc')?.addEventListener('click', () => {
      const rows = membersDiv.querySelectorAll('[id^="se-row-"]');
      const members = [];
      rows.forEach(row => {
        const name = row.querySelector('.se-name').value.trim() || `คนที่ ${members.length + 1}`;
        const amount = parseNum(row.querySelector('.se-amount').value);
        if (Number.isFinite(amount)) members.push({ name, amount });
      });

      if (members.length < 2) { alert('กรุณาป้อนข้อมูลอย่างน้อย 2 คน'); return; }

      const total = members.reduce((s, m) => s + m.amount, 0);
      const avg = total / members.length;

      document.getElementById('res-se-total').textContent = fmt(total);
      document.getElementById('res-se-avg').textContent = fmt(avg);
      document.getElementById('res-se-count').textContent = `${members.length} คน`;

      const settlement = document.getElementById('se-settlement');
      settlement.innerHTML = '<h3 class="font-medium text-gray-800 mb-2">สรุปการโอน</h3>';

      members.forEach(m => {
        const diff = m.amount - avg;
        const div = document.createElement('div');
        div.className = `flex justify-between border-b border-gray-100 py-2 text-sm`;
        div.innerHTML = `
          <span class="text-gray-700">${m.name} (จ่ายไป ${fmt(m.amount)})</span>
          <span class="font-medium ${diff >= 0 ? 'text-green-600' : 'text-red-600'}">
            ${diff >= 0 ? `ได้รับคืน ${fmt(diff)}` : `ต้องโอน ${fmt(Math.abs(diff))}`}
          </span>
        `;
        settlement.appendChild(div);
      });

      document.getElementById('se-results').classList.remove('hidden');
      document.getElementById('se-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
