---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="คำนวณค่าส่งพัสดุ 2569 — เปรียบเทียบไปรษณีย์ไทย Kerry Flash J&T | Kamnuanlek"
  description="คำนวณและเปรียบเทียบค่าส่งพัสดุในไทย อัตราค่าส่งไปรษณีย์ไทย Kerry Express Flash Express J&T ตามน้ำหนักและปลายทาง อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "คำนวณค่าส่งพัสดุ 2569 — เปรียบเทียบไปรษณีย์ไทย Kerry Flash J&T", "item": "https://www.kamnuanlek.com/คำนวณค่าส่งพัสดุ/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">คู่มือค่าส่งพัสดุ ปี 2569</h1>
    <p class="text-xl text-gray-600 mb-10">
      Compare shipping rates from major Thai courier services. Find the cheapest option for your parcel.
    </p>

    <a href="/คำนวณค่าส่งพัสดุ/" class="block p-6 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors mb-12">
      <h2 class="text-2xl font-bold mb-2">Use Shipping Cost Calculator →</h2>
      <p class="opacity-90">Calculate exact shipping cost for your parcel weight and destination</p>
    </a>

    <div class="p-6 bg-yellow-50 border border-yellow-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Approximate Rates (Bangkok to Bangkok)</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-yellow-200">
              <th class="text-left py-2 pr-4 font-semibold text-gray-900">Provider</th>
              <th class="text-left py-2 pr-4 font-semibold text-gray-900">Up to 1 kg</th>
              <th class="text-left py-2 pr-4 font-semibold text-gray-900">1-2 kg</th>
              <th class="text-left py-2 font-semibold text-gray-900">Notes</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-yellow-100">
              <td class="py-2 pr-4 font-semibold text-gray-900">Thailand Post (EMS)</td>
              <td class="py-2 pr-4 text-gray-700">35-50 THB</td>
              <td class="py-2 pr-4 text-gray-700">60-80 THB</td>
              <td class="py-2 text-gray-600">Government service</td>
            </tr>
            <tr class="border-b border-yellow-100">
              <td class="py-2 pr-4 font-semibold text-gray-900">Kerry Express</td>
              <td class="py-2 pr-4 text-gray-700">38-55 THB</td>
              <td class="py-2 pr-4 text-gray-700">65-90 THB</td>
              <td class="py-2 text-gray-600">Good coverage</td>
            </tr>
            <tr class="border-b border-yellow-100">
              <td class="py-2 pr-4 font-semibold text-gray-900">Flash Express</td>
              <td class="py-2 pr-4 text-gray-700">25-45 THB</td>
              <td class="py-2 pr-4 text-gray-700">50-70 THB</td>
              <td class="py-2 text-gray-600">Often cheapest</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 font-semibold text-gray-900">J&T Express</td>
              <td class="py-2 pr-4 text-gray-700">28-48 THB</td>
              <td class="py-2 pr-4 text-gray-700">55-75 THB</td>
              <td class="py-2 text-gray-600">Fast same-day options</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-gray-600 text-xs mt-2">* Rates vary by route, size, and current promotions. Use calculator for exact quotes.</p>
    </div>

    <div class="p-6 bg-blue-50 border border-blue-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Tips for Cheaper Shipping</h2>
      <ul class="space-y-2 text-gray-700">
        <li class="flex gap-3">
          <span class="text-primary-600 font-bold">✓</span>
          <span>Use lightweight packaging — weight is the main cost driver</span>
        </li>
        <li class="flex gap-3">
          <span class="text-primary-600 font-bold">✓</span>
          <span>Drop-off at service points is cheaper than home pickup</span>
        </li>
        <li class="flex gap-3">
          <span class="text-primary-600 font-bold">✓</span>
          <span>Flash and J&T often have discount promotions via their apps</span>
        </li>
        <li class="flex gap-3">
          <span class="text-primary-600 font-bold">✓</span>
          <span>For heavy items, check if rail/bus freight is more cost-effective</span>
        </li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">More Household Cost Calculators</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/เครื่องคำนวณค่าใช้จ่ายบ้าน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏠 Household Bills Hub</span>
          <p class="text-gray-600 text-sm mt-2">Electricity, water, internet calculators</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Tools Hub</span>
          <p class="text-gray-600 text-sm mt-2">All financial calculators</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
