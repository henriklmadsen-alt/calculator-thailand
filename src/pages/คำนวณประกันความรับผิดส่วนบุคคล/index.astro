---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณประกันความรับผิดส่วนบุคคล (Personal Liability) 2569 | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันความรับผิดส่วนบุคคล 2569 คุ้มครองเมื่อทำให้บุคคลอื่นหรือทรัพย์สินเสียหายโดยไม่ตั้งใจ เช่น สุนัขกัด น้ำท่วมห้องข้างล่าง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประกันความรับผิดส่วนบุคคล/`;

const faqData = [
  { question: 'ประกันความรับผิดส่วนบุคคลครอบคลุมอะไร?', answer: 'ครอบคลุมค่าเสียหายที่คุณต้องรับผิดชอบต่อบุคคลอื่น เช่น สุนัขของคุณกัดคนอื่น ลูกของคุณทำของเสียหายที่บ้านเพื่อน น้ำรั่วจากห้องคุณทำให้ห้องข้างล่างเสียหาย ลื่นในบ้านของคุณ' },
  { question: 'ประกัน Personal Liability ต่างจากประกันบ้านอย่างไร?', answer: 'ประกันบ้านคุ้มครองทรัพย์สินของคุณเอง ส่วนประกัน Personal Liability คุ้มครองความเสียหายที่คุณทำให้ผู้อื่น บางกรมธรรม์ประกันบ้านรวม personal liability ไว้ด้วย ควรตรวจสอบกรมธรรม์ที่มีอยู่ก่อน' },
  { question: 'เบี้ยประกัน Personal Liability ในไทยเท่าไร?', answer: 'เบี้ยส่วนใหญ่อยู่ที่ 1,500-5,000 บาท/ปี สำหรับวงเงินคุ้มครอง 1-5 ล้านบาท ขึ้นกับวงเงิน ประเภทที่อยู่อาศัย และความเสี่ยงส่วนบุคคล ถือว่าถูกมากเมื่อเทียบกับความเสี่ยงที่คุ้มครอง' },
  { question: 'ใครควรซื้อประกัน Personal Liability?', answer: 'เหมาะสำหรับ: เจ้าของสัตว์เลี้ยง (โดยเฉพาะสุนัขพันธุ์ใหญ่) ผู้เช่าหรือเจ้าของอพาร์ตเมนต์ชั้นบน ผู้ที่จัดงานสังสรรค์ที่บ้านบ่อยๆ และผู้มีทรัพย์สินมากที่ต้องการปกป้องจากการถูกฟ้อง' },
];

const jsonLdWebApp = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'เครื่องคำนวณประกันความรับผิดส่วนบุคคล 2569', description: pageDescription, url: canonical, applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' }, inLanguage: 'th' };
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประกันความรับผิดส่วนบุคคล">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณการเบี้ย Personal Liability Insurance</p>
      <p class="mt-1 text-sm text-slate-700">คุ้มครองเมื่อเผลอทำให้คนอื่นหรือทรัพย์สินเขาเสียหาย</p>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณประกันความรับผิดส่วนบุคคล 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">ประมาณเบี้ยประกัน Personal Liability ตามวงเงินและปัจจัยความเสี่ยงส่วนบุคคล</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูล</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>
        <div>
          <label for="liability-limit" class="block text-sm font-medium text-gray-700 mb-1">วงเงินคุ้มครองสูงสุด (บาท)</label>
          <select id="liability-limit" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="1000000">1,000,000 บาท</option>
            <option value="2000000">2,000,000 บาท</option>
            <option value="5000000" selected>5,000,000 บาท</option>
            <option value="10000000">10,000,000 บาท</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">ปัจจัยความเสี่ยงเพิ่มเติม</label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-sm text-gray-700"><input type="checkbox" id="chk-pet" class="rounded" /> มีสัตว์เลี้ยง (สุนัขหรือแมว)</label>
            <label class="flex items-center gap-2 text-sm text-gray-700"><input type="checkbox" id="chk-highrise" class="rounded" /> อาศัยในอพาร์ตเมนต์/คอนโดชั้นบน</label>
            <label class="flex items-center gap-2 text-sm text-gray-700"><input type="checkbox" id="chk-pool" class="rounded" /> มีสระว่ายน้ำหรือพื้นที่เสี่ยง</label>
          </div>
        </div>
        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">คำนวณเบี้ยประกัน</button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 mb-4 text-center">
        <p class="text-sm text-primary-700 mb-1">เบี้ยประกันประมาณการรายปี</p>
        <p class="text-4xl font-bold text-primary-700" id="total-premium">-</p>
        <p class="text-sm text-primary-600 mt-1" id="monthly-premium">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ทำไมต้องมีประกันความรับผิดส่วนบุคคล?</h2>
      <p>ในชีวิตประจำวัน อุบัติเหตุที่ทำให้คนอื่นเสียหายอาจเกิดขึ้นได้โดยไม่ตั้งใจ และค่าชดเชยอาจสูงมาก ประกัน Personal Liability ช่วยปกป้องทรัพย์สินส่วนตัวจากการถูกฟ้องร้อง</p>
    </section>
    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />
    <RelatedCalculators currentHref="/คำนวณประกันความรับผิดส่วนบุคคล/" />
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800"><strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงขึ้นกับบริษัทประกัน</div>
  </article>

  <script>
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const limit = parseFloat((document.getElementById('liability-limit') as HTMLSelectElement).value);
      const hasPet = (document.getElementById('chk-pet') as HTMLInputElement).checked;
      const hasHighrise = (document.getElementById('chk-highrise') as HTMLInputElement).checked;
      const hasPool = (document.getElementById('chk-pool') as HTMLInputElement).checked;

      const baseRate = 0.001; // 0.1% of limit
      let basePremium = limit * baseRate;
      const minPremium = 1500;
      basePremium = Math.max(basePremium, minPremium);

      const petAdd = hasPet ? 500 : 0;
      const highriseAdd = hasHighrise ? 400 : 0;
      const poolAdd = hasPool ? 600 : 0;
      const total = basePremium + petAdd + highriseAdd + poolAdd;

      const rows = [
        ['วงเงินคุ้มครอง', '', `${fmt(limit)} บาท`],
        ['เบี้ยฐาน', `0.1% หรือขั้นต่ำ 1,500 บาท`, `${fmt(basePremium)} บาท`],
        ['เพิ่มเติม: สัตว์เลี้ยง', hasPet ? 'มี' : 'ไม่มี', hasPet ? '+500 บาท' : '-'],
        ['เพิ่มเติม: อยู่ชั้นบน', hasHighrise ? 'มี' : 'ไม่มี', hasHighrise ? '+400 บาท' : '-'],
        ['เพิ่มเติม: สระว่ายน้ำ', hasPool ? 'มี' : 'ไม่มี', hasPool ? '+600 บาท' : '-'],
        ['เบี้ยรวมประมาณการ/ปี', '', `<strong>${fmt(total)} บาท</strong>`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td><td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td></tr>`).join('');

      (document.getElementById('total-premium') as HTMLElement).textContent = fmt(total) + ' บาท/ปี';
      (document.getElementById('monthly-premium') as HTMLElement).textContent = `≈ ${fmt(total/12)} บาท/เดือน`;
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
