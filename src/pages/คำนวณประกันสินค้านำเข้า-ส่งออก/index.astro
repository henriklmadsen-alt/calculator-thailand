---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณประกันสินค้านำเข้า-ส่งออก (Marine Cargo) 2569 | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันสินค้านำเข้า-ส่งออก Marine Cargo Insurance 2569 ตามมูลค่า CIF เส้นทางขนส่ง ประเภทสินค้า และเงื่อนไขคุ้มครอง ICC A B C';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประกันสินค้านำเข้า-ส่งออก/`;

const faqData = [
  {
    question: 'ประกัน Marine Cargo คืออะไร?',
    answer: 'Marine Cargo Insurance หรือประกันภัยสินค้าขนส่งทางทะเล คือประกันที่คุ้มครองสินค้าระหว่างการขนส่งจากต้นทางถึงปลายทาง ครอบคลุมทั้งทางทะเล อากาศ และทางบก ป้องกันความเสียหายจากอุบัติเหตุ ไฟไหม้ การจม หรือการสูญหาย',
  },
  {
    question: 'เงื่อนไข ICC A B C ต่างกันอย่างไร?',
    answer: 'ICC A (All Risks) คุ้มครองความเสี่ยงทุกประเภทยกเว้นที่ระบุไว้ เบี้ยแพงที่สุด | ICC B คุ้มครองความเสี่ยงปานกลาง รวมไฟ จม พลิกคว่ำ | ICC C คุ้มครองเฉพาะความเสี่ยงหลัก เบี้ยถูกที่สุด เหมาะสินค้าไม่บอบบาง',
  },
  {
    question: 'ฐานคำนวณเบี้ยประกัน Marine Cargo คือเท่าไร?',
    answer: 'โดยทั่วไปคำนวณจากมูลค่า CIF (Cost + Insurance + Freight) บวก 10% เพื่อครอบคลุมกำไรที่คาดหวัง ดังนั้นฐานประกัน = CIF × 110% อัตราเบี้ยอยู่ที่ 0.1-0.5% ของฐานประกัน ขึ้นกับประเภทสินค้าและเส้นทาง',
  },
  {
    question: 'ใครรับผิดชอบค่าประกัน Marine Cargo?',
    answer: 'ขึ้นกับเทอมการค้า (Incoterms): CIF ผู้ขายรับผิดชอบ | FOB ผู้ซื้อรับผิดชอบตั้งแต่สินค้าขึ้นเรือ | EXW ผู้ซื้อรับผิดชอบทั้งหมด | DDP ผู้ขายรับผิดชอบจนถึงปลายทาง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณประกันสินค้านำเข้า-ส่งออก 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประกันสินค้านำเข้า-ส่งออก">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณเบี้ยประกัน Marine Cargo Insurance</p>
      <p class="mt-1 text-sm text-slate-700">อัตราอ้างอิงตลาดประกันภัยไทย ผลลัพธ์เป็นการประมาณการ</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณประกันสินค้านำเข้า-ส่งออก 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">คำนวณเบี้ยประกัน Marine Cargo ตามมูลค่าสินค้า เส้นทาง และเงื่อนไขความคุ้มครอง</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูลสินค้า</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>

        <div>
          <label for="cif-value" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าสินค้า CIF (บาท)</label>
          <input type="text" id="cif-value" inputmode="numeric" placeholder="เช่น 500,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">CIF = ราคาสินค้า + ค่าขนส่ง + ค่าประกัน (ประมาณ)</p>
        </div>

        <div>
          <label for="cargo-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทสินค้า</label>
          <select id="cargo-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="0.001">สินค้าทั่วไป (0.10%)</option>
            <option value="0.0015">เครื่องจักร/อิเล็กทรอนิกส์ (0.15%)</option>
            <option value="0.002">สินค้าเกษตร/อาหาร (0.20%)</option>
            <option value="0.003">สินค้าอันตราย/เคมี (0.30%)</option>
            <option value="0.0008">วัตถุดิบ/bulk (0.08%)</option>
          </select>
        </div>

        <div>
          <label for="coverage-clause" class="block text-sm font-medium text-gray-700 mb-1">เงื่อนไขความคุ้มครอง</label>
          <select id="coverage-clause" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="1.3">ICC A - All Risks (ครอบคลุมทุกความเสี่ยง)</option>
            <option value="1.0" selected>ICC B - ความเสี่ยงปานกลาง</option>
            <option value="0.7">ICC C - ความเสี่ยงหลักเท่านั้น</option>
          </select>
        </div>

        <button type="button" id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">
          คำนวณเบี้ยประกัน
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 mb-4 text-center">
        <p class="text-sm text-primary-700 mb-1">เบี้ยประกันประมาณการ</p>
        <p class="text-4xl font-bold text-primary-700" id="total-premium">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b border-gray-200">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ทำไมต้องทำประกัน Marine Cargo?</h2>
      <p>การส่งออก-นำเข้าสินค้ามีความเสี่ยงระหว่างทางหลายประการ ไม่ว่าจะเป็นพายุ เรือล่ม อัคคีภัย การโจรกรรม หรืออุบัติเหตุในการขนถ่าย ประกัน Marine Cargo ช่วยให้ผู้นำเข้า-ส่งออกไม่ต้องรับความเสี่ยงทางการเงินเองทั้งหมด</p>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณประกันสินค้านำเข้า-ส่งออก/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ อัตราจริงขึ้นกับบริษัทประกันและลักษณะสินค้า
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const cif = parseNum((document.getElementById('cif-value') as HTMLInputElement).value);
      const rate = parseFloat((document.getElementById('cargo-type') as HTMLSelectElement).value);
      const clauseFactor = parseFloat((document.getElementById('coverage-clause') as HTMLSelectElement).value);
      const err = document.getElementById('form-error')!;

      if (cif < 10000) {
        err.textContent = 'กรุณากรอกมูลค่าสินค้าอย่างน้อย 10,000 บาท';
        err.classList.remove('hidden'); return;
      }
      err.classList.add('hidden');

      const insuredValue = cif * 1.10; // CIF + 10%
      const basePremium = insuredValue * rate;
      const total = basePremium * clauseFactor;
      const clauseNames: Record<string, string> = { '1.3': 'ICC A', '1.0': 'ICC B', '0.7': 'ICC C' };
      const clauseName = clauseNames[clauseFactor.toString()] || 'ICC B';

      const rows = [
        ['มูลค่า CIF', '', `${fmt(cif)} บาท`],
        ['มูลค่าเอาประกัน (CIF × 110%)', '', `${fmt(insuredValue)} บาท`],
        ['อัตราเบี้ยฐาน', `${(rate*100).toFixed(2)}%`, `${fmt(basePremium)} บาท`],
        [`ปรับตามเงื่อนไข ${clauseName}`, `× ${clauseFactor}`, `${fmt(total)} บาท`],
        ['เบี้ยประกันประมาณการ', '', `<strong>${fmt(total)} บาท</strong>`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td>
          <td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td>
        </tr>`).join('');

      (document.getElementById('total-premium') as HTMLElement).textContent = fmt(total) + ' บาท/เที่ยว';
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
