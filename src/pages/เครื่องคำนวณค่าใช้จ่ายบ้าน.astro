---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เครื่องคำนวณค่าใช้จ่ายบ้าน — ค่าไฟ ค่าน้ำ อินเทอร์เน็ต ปี 2569 | Kamnuanlek"
  description="เครื่องคำนวณค่าใช้จ่ายบ้านฟรี คำนวณค่าไฟฟ้า PEA MEA ค่าน้ำประปา ค่าอินเทอร์เน็ต และค่าใช้จ่ายรายเดือนรวม อัปเดตอัตราปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เครื่องคำนวณค่าใช้จ่ายบ้าน — ค่าไฟ ค่าน้ำ อินเทอร์เน็ต ปี 2569", "item": "https://www.kamnuanlek.com/เครื่องคำนวณค่าใช้จ่ายบ้าน/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณค่าใช้จ่ายบ้าน</h1>
    <p class="text-xl text-gray-600 mb-12">
      คำนวณค่าใช้จ่ายบ้านรายเดือน ไม่ว่าจะเป็นค่าไฟ ค่าน้ำ ค่าอินเทอร์เน็ต และอื่นๆ เครื่องคำนวณทุกตัวใช้อัตราค่าสาธารณูปโภคของไทยที่อัปเดตล่าสุด
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณค่าไฟฟ้า/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณค่าไฟฟ้า</h3>
        <p class="text-gray-600 mb-3">คำนวณค่าไฟฟ้ารายเดือนตามจำนวนหน่วยที่ใช้และโครงสร้างอัตราค่าไฟของ กฟน./กฟภ.</p>
        <span class="text-primary-600 font-medium">คำนวณค่าไฟ →</span>
      </a>

      <a href="/คำนวณค่าน้ำประปา/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">💧</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณค่าน้ำประปา</h3>
        <p class="text-gray-600 mb-3">คำนวณค่าน้ำประปารายเดือนตามปริมาณการใช้น้ำ (ลูกบาศก์เมตร) และอัตราของ กปน./กปภ.</p>
        <span class="text-primary-600 font-medium">คำนวณค่าน้ำ →</span>
      </a>

      <a href="/คำนวณค่าอินเทอร์เน็ต/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🌐</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณค่าอินเทอร์เน็ตและโทรศัพท์</h3>
        <p class="text-gray-600 mb-3">เปรียบเทียบค่าอินเทอร์เน็ตและแพ็กเกจโทรศัพท์ เพื่อเลือกแผนที่คุ้มค่าที่สุดตามการใช้งานของคุณ</p>
        <span class="text-primary-600 font-medium">เปรียบเทียบแพ็กเกจ →</span>
      </a>

      <a href="/คำนวณค่าเช่าบ้าน/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🏘️</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณเช่าบ้านเทียบซื้อบ้าน</h3>
        <p class="text-gray-600 mb-3">เปรียบเทียบต้นทุนการเช่าบ้านกับการซื้อบ้าน เพื่อดูว่าตัวเลือกใดเหมาะกับสถานการณ์ของคุณมากกว่า</p>
        <span class="text-primary-600 font-medium">เปรียบเทียบตัวเลือก →</span>
      </a>
    </div>

    <div class="p-6 bg-yellow-50 border border-yellow-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">ค่าสาธารณูปโภคเฉลี่ยรายเดือนในกรุงเทพฯ</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="p-4 bg-white rounded-lg border border-yellow-100 text-center">
          <p class="text-3xl mb-2">⚡</p>
          <p class="text-2xl font-bold text-gray-900">600–1,200</p>
          <p class="text-gray-700 font-medium">บาท/เดือน ค่าไฟ</p>
          <p class="text-gray-500 text-sm mt-1">คอนโด 1-2 ห้องนอน</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-yellow-100 text-center">
          <p class="text-3xl mb-2">💧</p>
          <p class="text-2xl font-bold text-gray-900">150–350</p>
          <p class="text-gray-700 font-medium">บาท/เดือน ค่าน้ำ</p>
          <p class="text-gray-500 text-sm mt-1">ครัวเรือน 1-2 คน</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-yellow-100 text-center">
          <p class="text-3xl mb-2">🌐</p>
          <p class="text-2xl font-bold text-gray-900">500–1,000</p>
          <p class="text-gray-700 font-medium">บาท/เดือน อินเทอร์เน็ต</p>
          <p class="text-gray-500 text-sm mt-1">ไฟเบอร์ 500Mbps–1Gbps</p>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือการเงินเพิ่มเติม</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 ศูนย์รวมเครื่องคำนวณการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">ภาษี สินเชื่อ ออมเงิน และการลงทุน</p>
        </a>
        <a href="/เครื่องคำนวณการเงินชั้นยอด/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 เครื่องมือสำคัญ 10 อันดับ</span>
          <p class="text-gray-600 text-sm mt-2">เครื่องคำนวณที่ทุกคนควรรู้จัก</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
