---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เครื่องคำนวณค่าใช้จ่ายบ้าน — ค่าไฟ ค่าน้ำ อินเทอร์เน็ต ปี 2569 | Kamnuanlek"
  description="เครื่องคำนวณค่าใช้จ่ายบ้านฟรี คำนวณค่าไฟฟ้า PEA MEA ค่าน้ำประปา ค่าอินเทอร์เน็ต และค่าใช้จ่ายรายเดือนรวม อัปเดตอัตราปี 2569"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Household Bill Calculators</h1>
    <p class="text-xl text-gray-600 mb-12">
      Calculate your monthly home expenses: electricity, water, internet, and more. All calculators use the latest Thai utility rates.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณค่าไฟฟ้า/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Electricity Bill Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate your monthly electricity bill based on units used and MEA/PEA rate structure.</p>
        <span class="text-primary-600 font-medium">Calculate Electricity Bill →</span>
      </a>

      <a href="/คำนวณค่าน้ำประปา/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">💧</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Water Bill Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate your monthly water bill based on usage (cubic meters) and MWA/PWA rates.</p>
        <span class="text-primary-600 font-medium">Calculate Water Bill →</span>
      </a>

      <a href="/คำนวณค่าอินเทอร์เน็ต/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🌐</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Internet & Telecom Cost Calculator</h3>
        <p class="text-gray-600 mb-3">Compare internet and phone plan costs to find the best value for your usage.</p>
        <span class="text-primary-600 font-medium">Compare Plans →</span>
      </a>

      <a href="/คำนวณค่าเช่าบ้าน/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🏘️</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Rent vs Buy Calculator</h3>
        <p class="text-gray-600 mb-3">Compare the cost of renting vs buying a home. See which option is better for your situation.</p>
        <span class="text-primary-600 font-medium">Compare Options →</span>
      </a>
    </div>

    <div class="p-6 bg-yellow-50 border border-yellow-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Average Monthly Utility Costs in Bangkok</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="p-4 bg-white rounded-lg border border-yellow-100 text-center">
          <p class="text-3xl mb-2">⚡</p>
          <p class="text-2xl font-bold text-gray-900">600–1,200</p>
          <p class="text-gray-700 font-medium">THB/month electricity</p>
          <p class="text-gray-500 text-sm mt-1">1-2 bedroom condo</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-yellow-100 text-center">
          <p class="text-3xl mb-2">💧</p>
          <p class="text-2xl font-bold text-gray-900">150–350</p>
          <p class="text-gray-700 font-medium">THB/month water</p>
          <p class="text-gray-500 text-sm mt-1">1-2 person household</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-yellow-100 text-center">
          <p class="text-3xl mb-2">🌐</p>
          <p class="text-2xl font-bold text-gray-900">500–1,000</p>
          <p class="text-gray-700 font-medium">THB/month internet</p>
          <p class="text-gray-500 text-sm mt-1">Fiber 500Mbps–1Gbps</p>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">More Financial Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Calculators Hub</span>
          <p class="text-gray-600 text-sm mt-2">Tax, loans, savings, and investments</p>
        </a>
        <a href="/เครื่องคำนวณการเงินชั้นยอด/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 Top 10 Essential Tools</span>
          <p class="text-gray-600 text-sm mt-2">Most important calculators to know</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
