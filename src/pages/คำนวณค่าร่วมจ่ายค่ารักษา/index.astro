---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่าร่วมจ่ายค่ารักษาพยาบาล (Medical Co-pay) 2569 | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าร่วมจ่ายค่ารักษาพยาบาล (Co-pay) 2569 จากประกันสุขภาพหรือสวัสดิการ คำนวณส่วนที่ประกันจ่ายและส่วนที่คุณต้องจ่ายเอง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าร่วมจ่ายค่ารักษา/`;

const faqData = [
  { question: 'ค่าร่วมจ่าย (Co-pay) คืออะไร?', answer: 'Co-pay คือสัดส่วนหรือจำนวนเงินที่ผู้เอาประกันต้องจ่ายร่วมกับบริษัทประกันเมื่อรับการรักษา เช่น co-pay 20% หมายถึงคุณจ่าย 20% ประกันจ่าย 80%' },
  { question: 'ทำไมประกันถึงมีค่า co-pay?', answer: 'Co-pay ช่วยป้องกัน "Moral Hazard" คือการที่ผู้เอาประกันใช้บริการมากเกินจำเป็นเพราะรู้ว่าประกันจ่ายให้หมด การมี co-pay ทำให้ผู้เอาประกันรู้สึกว่าต้องรับผิดชอบค่าใช้จ่ายส่วนหนึ่ง' },
  { question: 'Co-pay กับ Deductible ต่างกันอย่างไร?', answer: 'Deductible คือจำนวนคงที่ที่จ่ายก่อนประกันเริ่มจ่าย ส่วน Co-pay คือเปอร์เซ็นต์ที่ต้องจ่ายร่วมตลอด บางกรมธรรม์มีทั้งสอง: จ่าย deductible ก่อน แล้วยังมี co-pay ของส่วนที่เหลือ' },
  { question: 'มีวิธีลดค่า co-pay ไหม?', answer: 'วิธีลดภาระค่า co-pay: (1) เลือกแผนประกันที่ไม่มี co-pay แต่เบี้ยสูงขึ้น (2) ซื้อประกัน top-up เพื่อครอบคลุม co-pay (3) ใช้โรงพยาบาลในเครือข่าย (In-network) ที่มี co-pay ต่ำกว่า' },
];

const jsonLdWebApp = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'เครื่องคำนวณค่าร่วมจ่ายค่ารักษา 2569', description: pageDescription, url: canonical, applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' }, inLanguage: 'th' };
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าร่วมจ่ายค่ารักษา">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณค่าร่วมจ่ายและส่วนที่ประกันจ่าย</p>
      <p class="mt-1 text-sm text-slate-700">รู้ก่อนว่าต้องจ่ายเองเท่าไรก่อนไปโรงพยาบาล</p>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณค่าร่วมจ่ายค่ารักษาพยาบาล 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">คำนวณว่าต้องจ่ายค่ารักษาเองเท่าไร หลังหัก deductible และค่า co-pay ตามเงื่อนไขประกันของคุณ</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูล</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>
        <div>
          <label for="medical-bill" class="block text-sm font-medium text-gray-700 mb-1">ค่ารักษาพยาบาลทั้งหมด (บาท)</label>
          <input type="text" id="medical-bill" inputmode="numeric" placeholder="เช่น 45,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="deductible" class="block text-sm font-medium text-gray-700 mb-1">Deductible (บาท)</label>
          <input type="text" id="deductible" inputmode="numeric" placeholder="เช่น 0" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="copay-pct" class="block text-sm font-medium text-gray-700 mb-1">อัตราค่าร่วมจ่าย Co-pay (%)</label>
          <select id="copay-pct" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="0">0% (ประกันจ่ายทั้งหมด)</option>
            <option value="10">10%</option>
            <option value="20" selected>20%</option>
            <option value="30">30%</option>
            <option value="40">40%</option>
          </select>
        </div>
        <div>
          <label for="max-out-of-pocket" class="block text-sm font-medium text-gray-700 mb-1">วงเงินสูงสุดที่จ่ายเองต่อปี (บาท, ใส่ 0 ถ้าไม่จำกัด)</label>
          <input type="text" id="max-out-of-pocket" inputmode="numeric" placeholder="เช่น 30,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">คำนวณ</button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="grid gap-4 sm:grid-cols-2 mb-4">
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-center"><p class="text-xs text-red-700 mb-1">คุณจ่ายเอง</p><p class="text-3xl font-bold text-red-700" id="you-pay">-</p></div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center"><p class="text-xs text-green-700 mb-1">ประกันจ่าย</p><p class="text-3xl font-bold text-green-700" id="insurance-pays">-</p></div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">เกี่ยวกับค่าร่วมจ่ายในระบบประกันสุขภาพไทย</h2>
      <p>ในไทย ค่าร่วมจ่ายพบได้ทั้งในประกันสุขภาพภาคเอกชนและในระบบประกันสังคม โดยประกันสุขภาพเอกชนบางแผนกำหนด co-pay 10-30% เพื่อแลกกับเบี้ยที่ถูกลง</p>
    </section>
    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (<details class="bg-white rounded-lg shadow-sm border border-gray-200"><summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary><div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div></details>))}
      </div>
    </section>
    <RelatedCalculators currentHref="/คำนวณค่าร่วมจ่ายค่ารักษา/" />
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800"><strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ ขึ้นกับเงื่อนไขกรมธรรม์จริง</div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const bill = parseNum((document.getElementById('medical-bill') as HTMLInputElement).value);
      const ded = parseNum((document.getElementById('deductible') as HTMLInputElement).value);
      const copay = parseFloat((document.getElementById('copay-pct') as HTMLSelectElement).value) / 100;
      const maxOOP = parseNum((document.getElementById('max-out-of-pocket') as HTMLInputElement).value);
      const err = document.getElementById('form-error')!;
      if (bill < 100) { err.textContent = 'กรุณากรอกค่ารักษาพยาบาล'; err.classList.remove('hidden'); return; }
      err.classList.add('hidden');

      const afterDed = Math.max(0, bill - ded);
      const copayAmt = afterDed * copay;
      const insurancePortion = afterDed - copayAmt;
      let youPay = ded + copayAmt;
      if (maxOOP > 0 && youPay > maxOOP) youPay = maxOOP;
      const insurancePays = bill - youPay;

      const rows = [
        ['ค่ารักษาพยาบาลทั้งหมด', '', `${fmt(bill)} บาท`],
        ['Deductible ที่จ่ายเอง', '', `${fmt(ded)} บาท`],
        ['ยอดหลังหัก Deductible', '', `${fmt(afterDed)} บาท`],
        ['Co-pay', `${(copay*100).toFixed(0)}%`, `${fmt(copayAmt)} บาท`],
        ['ประกันจ่าย', '', `${fmt(insurancePortion)} บาท`],
        maxOOP > 0 ? ['วงเงินสูงสุดจ่ายเอง', `จำกัดที่ ${fmt(maxOOP)} บาท`, ''] : null,
        ['คุณจ่ายเองรวม', '', `<strong>${fmt(youPay)} บาท</strong>`],
        ['ประกันจ่ายรวม', '', `<strong>${fmt(insurancePays)} บาท</strong>`],
      ].filter(Boolean) as string[][];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td><td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td></tr>`).join('');

      (document.getElementById('you-pay') as HTMLElement).textContent = fmt(youPay) + ' บาท';
      (document.getElementById('insurance-pays') as HTMLElement).textContent = fmt(insurancePays) + ' บาท';
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
