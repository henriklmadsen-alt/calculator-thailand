---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ ROE ผลตอบแทนผู้ถือหุ้น ฟรี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณ ROE (Return on Equity) ผลตอบแทนต่อส่วนผู้ถือหุ้น เปรียบเทียบกับค่าเฉลี่ย SET และอุตสาหกรรม วิเคราะห์ประสิทธิภาพบริษัท ฟรีทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-roe-ผลตอบแทนผู้ถือหุ้น/`;

const faqData = [
  {
    question: 'ROE คืออะไร และสำคัญอย่างไรในการลงทุน?',
    answer: 'ROE (Return on Equity) คืออัตราผลตอบแทนต่อส่วนผู้ถือหุ้น แสดงว่าบริษัทสร้างกำไรได้กี่% จากเงินทุนของผู้ถือหุ้น นักลงทุน Value เช่น Warren Buffett ใช้ ROE เป็นตัวชี้วัดสำคัญ ROE สูงและสม่ำเสมอมักแสดงว่าบริษัทมีความได้เปรียบในการแข่งขัน (Competitive Moat)',
  },
  {
    question: 'ROE ที่ดีสำหรับบริษัทไทย SET ควรเป็นเท่าไร?',
    answer: 'ค่าเฉลี่ย ROE ของบริษัทใน SET ไทยอยู่ที่ประมาณ 10-15% ต่อปี บริษัทคุณภาพดีมักมี ROE > 15% อย่างสม่ำเสมอ บริษัทธนาคารพาณิชย์ขนาดใหญ่ในไทยมักมี ROE 8-12% ส่วนบริษัทเทคโนโลยีและค้าปลีกชั้นนำอาจมี ROE 20-30%',
  },
  {
    question: 'ROE สูงเสมอดีหรือเปล่า?',
    answer: 'ไม่เสมอ ROE สูงมากอาจเกิดจากหนี้สินสูง (Leverage สูง) ไม่ใช่ประสิทธิภาพการดำเนินงานจริง ควรดู ROE ร่วมกับ Debt-to-Equity Ratio และ ROA เพื่อเข้าใจว่า ROE สูงเพราะบริษัทดีจริง หรือเพราะกู้หนี้มาลงทุน',
  },
  {
    question: 'DuPont Analysis คืออะไร?',
    answer: 'DuPont Analysis แยก ROE เป็น 3 ส่วน: ROE = Net Profit Margin × Asset Turnover × Equity Multiplier ช่วยวิเคราะห์ว่า ROE สูงเพราะ (1) กำไรต่อยอดขายดี (2) ใช้สินทรัพย์หมุนเวียนเร็ว หรือ (3) ใช้ leverage สูง',
  },
  {
    question: 'ROE ต่างจาก ROCE อย่างไร?',
    answer: 'ROCE (Return on Capital Employed) = EBIT ÷ Capital Employed โดย Capital Employed = สินทรัพย์รวม − หนี้สินหมุนเวียน ROCE รวมทั้งทุนและหนี้ระยะยาว จึงเหมาะกับเปรียบเทียบบริษัทที่มีโครงสร้างทุนต่างกัน ส่วน ROE ดูเฉพาะส่วนผู้ถือหุ้น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ ROE ผลตอบแทนผู้ถือหุ้น',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณ ROE ผลตอบแทนผู้ถือหุ้น',
  description: 'ขั้นตอนการคำนวณ ROE และแปลผลสำหรับการลงทุนในหุ้น',
  step: [
    {
      '@type': 'HowToStep',
      name: 'หากำไรสุทธิจากงบกำไรขาดทุน',
      text: 'ดูกำไรสุทธิ (Net Income) จากงบกำไรขาดทุนประจำปี หรืองบล่าสุด 12 เดือน',
    },
    {
      '@type': 'HowToStep',
      name: 'หาส่วนผู้ถือหุ้นจากงบดุล',
      text: 'ดูส่วนผู้ถือหุ้นรวม (Shareholders\' Equity) จากงบดุล อาจใช้ค่าเฉลี่ยต้นปีและปลายปีเพื่อความแม่นยำ',
    },
    {
      '@type': 'HowToStep',
      name: 'คำนวณ ROE',
      text: 'ROE = กำไรสุทธิ ÷ ส่วนผู้ถือหุ้น × 100 เช่น กำไร 10M ÷ ส่วนทุน 80M × 100 = 12.5%',
    },
    {
      '@type': 'HowToStep',
      name: 'เปรียบเทียบกับเกณฑ์อ้างอิง',
      text: 'เปรียบเทียบกับค่าเฉลี่ย SET (~12%) และอุตสาหกรรมเดียวกัน ROE > 15% ถือว่าดี ROE > 20% ดีมาก',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-roe-ผลตอบแทนผู้ถือหุ้น">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณ ROE — ผลตอบแทนต่อส่วนผู้ถือหุ้น</p>
      <p class="mt-1 text-sm text-slate-700">เปรียบเทียบกับค่าเฉลี่ย SET ไทย ~12%</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณ ROE ผลตอบแทนผู้ถือหุ้น (Return on Equity) 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณ ROE สำหรับบริษัทหรือหุ้นที่สนใจลงทุน พร้อมการเปรียบเทียบกับค่าเฉลี่ย SET ไทยและคำแนะนำการแปลผล
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'ตลาดหลักทรัพย์แห่งประเทศไทย (SET): ข้อมูลอัตราส่วนทางการเงินรายอุตสาหกรรม',
        'กรมพัฒนาธุรกิจการค้า: ฐานข้อมูลงบการเงิน',
      ]}
      assumptions={[
        'สูตร: ROE = กำไรสุทธิ ÷ ส่วนผู้ถือหุ้น × 100',
        'ค่าเฉลี่ย ROE ของ SET ไทยอ้างอิง: ~12% ต่อปี',
      ]}
      references={[
        { label: 'SET: อัตราส่วนทางการเงิน', href: 'https://www.set.or.th' },
        { label: 'กรมพัฒนาธุรกิจการค้า', href: 'https://www.dbd.go.th' },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="roe-form" class="space-y-5">
        <p id="roe-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="roe-income" class="block text-sm font-medium text-gray-700 mb-1">กำไรสุทธิ — Net Income (บาท)</label>
            <input type="text" id="roe-income" inputmode="numeric" placeholder="เช่น 10,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            <p class="mt-1 text-xs text-gray-500">จากงบกำไรขาดทุน</p>
          </div>
          <div>
            <label for="roe-equity" class="block text-sm font-medium text-gray-700 mb-1">ส่วนผู้ถือหุ้น — Shareholders' Equity (บาท)</label>
            <input type="text" id="roe-equity" inputmode="numeric" placeholder="เช่น 80,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            <p class="mt-1 text-xs text-gray-500">จากงบดุล (ส่วนของผู้ถือหุ้นรวม)</p>
          </div>
        </div>

        <button type="submit" id="roe-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณ ROE
        </button>
      </form>
    </div>

    <div id="roe-results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ ROE</h2>
        <div class="grid gap-3 sm:grid-cols-2 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ROE</div>
            <div id="res-roe" class="text-3xl font-bold text-primary-700">-</div>
          </div>
          <div id="roe-bench-card" class="rounded-lg p-4 text-center bg-gray-50">
            <div class="text-sm text-gray-600 mb-1">เทียบค่าเฉลี่ย SET (~12%)</div>
            <div id="res-roe-bench" class="text-xl font-bold">-</div>
          </div>
        </div>
        <div class="mt-4 rounded-lg bg-blue-50 p-3">
          <p id="res-roe-interpretation" class="text-sm text-blue-800"></p>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#roe-results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตร ROE และการแปลผล</h2>
      <div class="bg-gray-50 rounded-lg p-4 my-4">
        <p class="font-semibold mb-1">สูตร ROE:</p>
        <p class="text-sm">ROE = กำไรสุทธิ ÷ ส่วนผู้ถือหุ้น × 100</p>
      </div>
      <div class="overflow-x-auto mt-4">
        <table class="min-w-full text-sm border border-gray-200 rounded-lg">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-2 text-left font-semibold text-gray-700">ระดับ ROE</th>
              <th class="px-4 py-2 text-left font-semibold text-gray-700">การแปลผล</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr><td class="px-4 py-2">&lt; 8%</td><td class="px-4 py-2">ต่ำกว่าค่าเฉลี่ย SET อาจต้องปรับปรุง</td></tr>
            <tr><td class="px-4 py-2">8–12%</td><td class="px-4 py-2">ใกล้เคียงค่าเฉลี่ย SET ผลตอบแทนพอใช้</td></tr>
            <tr><td class="px-4 py-2">12–20%</td><td class="px-4 py-2">ดีกว่าค่าเฉลี่ย สัญญาณบริษัทมีคุณภาพ</td></tr>
            <tr><td class="px-4 py-2">&gt; 20%</td><td class="px-4 py-2">ดีเยี่ยม บริษัทมี Competitive Moat สูง</td></tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        <strong>แหล่งอ้างอิง:</strong>
        <a href="https://www.set.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">ตลาดหลักทรัพย์แห่งประเทศไทย (SET)</a>
      </p>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-roe-ผลตอบแทนผู้ถือหุ้น/" />
    <RelatedCalculators currentHref="/คำนวณ-roe-ผลตอบแทนผู้ถือหุ้น/" slugs={['คำนวณ-roa-ผลตอบแทนสินทรัพย์', 'คำนวณ-wacc-ต้นทุนทุนถัวเฉลี่ย', 'คำนวณ-npv-มูลค่าปัจจุบันสุทธิ']} />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ ไม่ถือเป็นคำแนะนำการลงทุน ควรวิเคราะห์ประกอบกับปัจจัยอื่นก่อนตัดสินใจ
    </div>
  </article>
</BaseLayout>

<script>
  function parseNum(v: string): number {
    return parseFloat(String(v).replace(/,/g, '').trim()) || 0;
  }

  const form = document.getElementById('roe-form') as HTMLFormElement;
  const formError = document.getElementById('roe-form-error') as HTMLElement;
  const resultsDiv = document.getElementById('roe-results') as HTMLElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    formError.classList.add('hidden');

    const income = parseNum((document.getElementById('roe-income') as HTMLInputElement).value);
    const equity = parseNum((document.getElementById('roe-equity') as HTMLInputElement).value);

    if (equity <= 0) {
      formError.classList.remove('hidden');
      formError.textContent = 'กรุณากรอกส่วนผู้ถือหุ้นให้ถูกต้อง (ต้องมากกว่า 0)';
      return;
    }

    const roe = (income / equity) * 100;
    (document.getElementById('res-roe') as HTMLElement).textContent = roe.toFixed(2) + '%';

    const benchEl = document.getElementById('res-roe-bench') as HTMLElement;
    const benchCard = document.getElementById('roe-bench-card') as HTMLElement;
    const interpEl = document.getElementById('res-roe-interpretation') as HTMLElement;

    if (roe < 8) {
      benchEl.textContent = 'ต่ำกว่าค่าเฉลี่ย';
      benchEl.className = 'text-xl font-bold text-red-600';
      benchCard.className = 'rounded-lg p-4 text-center bg-red-50';
      interpEl.textContent = `ROE ${roe.toFixed(2)}% ต่ำกว่าค่าเฉลี่ย SET (~12%) บริษัทอาจต้องปรับปรุงประสิทธิภาพหรือทบทวนโครงสร้างทุน`;
    } else if (roe < 12) {
      benchEl.textContent = 'ใกล้เคียงค่าเฉลี่ย';
      benchEl.className = 'text-xl font-bold text-yellow-600';
      benchCard.className = 'rounded-lg p-4 text-center bg-yellow-50';
      interpEl.textContent = `ROE ${roe.toFixed(2)}% ใกล้เคียงค่าเฉลี่ย SET (~12%) บริษัทมีผลตอบแทนพอใช้ ควรดูแนวโน้มต่อเนื่อง`;
    } else if (roe < 20) {
      benchEl.textContent = 'ดีกว่าค่าเฉลี่ย';
      benchEl.className = 'text-xl font-bold text-green-700';
      benchCard.className = 'rounded-lg p-4 text-center bg-green-50';
      interpEl.textContent = `ROE ${roe.toFixed(2)}% ดีกว่าค่าเฉลี่ย SET (~12%) สัญญาณบริษัทมีคุณภาพดี ควรตรวจสอบ Debt/Equity ประกอบ`;
    } else {
      benchEl.textContent = 'ดีเยี่ยม';
      benchEl.className = 'text-xl font-bold text-green-700';
      benchCard.className = 'rounded-lg p-4 text-center bg-green-50';
      interpEl.textContent = `ROE ${roe.toFixed(2)}% ดีเยี่ยม สูงกว่าค่าเฉลี่ย SET มาก บริษัทมี Competitive Advantage ชัดเจน หรือใช้ Financial Leverage สูง — ควรตรวจสอบ D/E`;
    }

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
