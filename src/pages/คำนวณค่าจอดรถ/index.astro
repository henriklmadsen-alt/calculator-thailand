---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าจอดรถ | ค่าที่จอด | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าจอดรถ ตามสถานที่และเวลา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าจอดรถ/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าจอดรถ">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าจอดรถ</h1>
    <p class="text-gray-600 mb-6">คำนวณค่าที่จอดรถ ตามสถานที่และจำนวนชั่วโมง</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="location" class="block text-sm font-medium text-gray-700 mb-1">สถานที่</label>
          <select id="location" class="w-full px-3 py-2 border border-gray-300 rounded-md">
            <option value="mall">ห้างสรรพสินค้า</option>
            <option value="hospital">โรงพยาบาล</option>
            <option value="street">จอดริมถนน</option>
            <option value="airport">สนามบิน</option>
          </select>
        </div>
        <div>
          <label for="hours" class="block text-sm font-medium text-gray-700 mb-1">ชั่วโมง</label>
          <input type="number" id="hours" min="1" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" />
        </div>
      </div>
      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white rounded-md">คำนวณ</button>
      <div id="result" class="hidden mt-6 p-4 bg-blue-50 rounded-lg">
        <div class="flex justify-between"><span>ค่าจอดรถ</span><span id="total" class="text-lg font-bold text-primary-600">-</span></div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  import { calculateParkingFee } from '../../lib/parking-fee-calculator';
  document.getElementById('btn-calculate').addEventListener('click', () => {
    const result = calculateParkingFee({
      location: document.getElementById('location').value as any,
      hours: parseInt(document.getElementById('hours').value)
    });
    document.getElementById('total').textContent = result.totalFee.toLocaleString('th-TH') + ' บาท';
    document.getElementById('result').classList.remove('hidden');
  });
</script>
