---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณแลกเปลี่ยนเงินตรา 2569 | อัตราแลกเปลี่ยนเงินสกุลต่างๆ | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณการแลกเปลี่ยนเงินตราต่างประเทศด้วยอัตราอ้างอิง พร้อมเปรียบเทียบแหล่งแลกเงิน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณแลกเปลี่ยนเงินตรา/`;

const faqData = [
  {
    question: 'อัตราแลกเปลี่ยนเงินตราต่างประเทศในไทยดูได้จากที่ไหน?',
    answer: 'สามารถดูอัตราแลกเปลี่ยนอ้างอิงได้จากเว็บไซต์ธนาคารแห่งประเทศไทย (bot.or.th) หรือเว็บไซต์ธนาคารพาณิชย์แต่ละแห่ง อัตราจะแตกต่างกันระหว่างอัตราซื้อ อัตราขาย และ mid-rate',
  },
  {
    question: 'แลกเงินที่ไหนได้อัตราดีที่สุด?',
    answer: 'โดยทั่วไปร้านแลกเงิน (money changer) มักให้อัตราดีกว่าธนาคาร แต่ต้องระวังร้านที่ไม่ได้รับอนุญาต แนะนำให้เปรียบเทียบอัตราจากหลายแหล่งและตรวจสอบใบอนุญาตจากธปท.',
  },
  {
    question: 'อัตราแลกเปลี่ยนในเครื่องคำนวณนี้น่าเชื่อถือแค่ไหน?',
    answer: 'อัตราที่แสดงเป็นค่าอ้างอิงเพื่อประมาณการเท่านั้น อัตราจริงเปลี่ยนแปลงตลอดวันและขึ้นอยู่กับแหล่งแลกเงิน ควรตรวจสอบอัตราจริงจากธนาคารหรือร้านแลกเงินก่อนทำธุรกรรมจริงเสมอ',
  },
];

const currencies = [
  { code: 'USD', name: 'ดอลลาร์สหรัฐ (USD)', rate: 36 },
  { code: 'EUR', name: 'ยูโร (EUR)', rate: 39 },
  { code: 'GBP', name: 'ปอนด์สเตอร์ลิง (GBP)', rate: 46 },
  { code: 'JPY', name: 'เยนญี่ปุ่น (JPY)', rate: 0.24 },
  { code: 'CNY', name: 'หยวนจีน (CNY)', rate: 5.0 },
  { code: 'SGD', name: 'ดอลลาร์สิงคโปร์ (SGD)', rate: 27 },
  { code: 'AUD', name: 'ดอลลาร์ออสเตรเลีย (AUD)', rate: 23 },
  { code: 'HKD', name: 'ดอลลาร์ฮ่องกง (HKD)', rate: 4.6 },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณแลกเปลี่ยนเงินตรา',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณแลกเปลี่ยนเงินตรา">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณแลกเปลี่ยนเงินตรา 2569</h1>
    <p class="mb-4 text-gray-600">คำนวณจำนวนเงินที่จะได้รับเมื่อแลกเปลี่ยนเงินตราต่างประเทศด้วยอัตราอ้างอิง</p>
    <div class="mb-6 rounded-lg border border-yellow-200 bg-yellow-50 p-3 text-sm text-yellow-800">
      ⚠️ อัตราแลกเปลี่ยนเป็นค่าประมาณอ้างอิง โปรดตรวจสอบอัตราจริงจากธนาคารหรือตัวแทน
    </div>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc-form" class="space-y-4">
        <div>
          <label for="amount" class="mb-1 block text-sm font-medium text-gray-700">จำนวนเงิน (บาท)</label>
          <input id="amount" type="text" inputmode="numeric" placeholder="เช่น 10000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="currency" class="mb-1 block text-sm font-medium text-gray-700">เลือกสกุลเงิน</label>
          <select id="currency"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64">
            {currencies.map((c) => (
              <option value={c.code} data-rate={c.rate}>{c.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราแลกเปลี่ยน (บาทต่อ 1 หน่วยสกุลเงิน)</label>
          <input id="rate" type="text" inputmode="decimal" placeholder="เช่น 36"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
          <p class="mt-1 text-xs text-gray-500">อัตราอ้างอิงจะถูกกรอกให้อัตโนมัติเมื่อเลือกสกุลเงิน</p>
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินที่ได้รับ (สกุลต่างประเทศ)</div>
            <div id="res-foreign" class="text-3xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">หากแลกกลับเป็นบาท</div>
            <div id="res-back" class="text-3xl font-bold text-orange-700">-</div>
          </div>
        </div>
        <p id="res-note" class="mt-3 text-xs text-gray-500"></p>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณแลกเปลี่ยนเงินตรา/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const rates: Record<string, number> = { USD: 36, EUR: 39, GBP: 46, JPY: 0.24, CNY: 5.0, SGD: 27, AUD: 23, HKD: 4.6 };
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n > 0 ? n : 0;
  };

  const currencyEl = document.getElementById('currency') as HTMLSelectElement;
  const rateEl = document.getElementById('rate') as HTMLInputElement;

  function updateRate() {
    const code = currencyEl.value;
    if (rates[code]) rateEl.value = String(rates[code]);
  }
  currencyEl.addEventListener('change', updateRate);
  updateRate();

  document.getElementById('calc-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const amount = parseNum((document.getElementById('amount') as HTMLInputElement).value);
    const rate = parseNum(rateEl.value);
    const code = currencyEl.value;
    if (!amount || !rate) return;

    const foreign = amount / rate;
    const back = amount; // แลกกลับด้วยอัตราเดิม = เท่าเดิม (ในทางทฤษฎี)

    const fmtForeign = foreign.toLocaleString('th-TH', { maximumFractionDigits: 2 });
    document.getElementById('res-foreign')!.textContent = `${fmtForeign} ${code}`;
    document.getElementById('res-back')!.textContent = '฿' + Math.round(back).toLocaleString('th-TH');
    document.getElementById('res-note')!.textContent = `อัตราที่ใช้: 1 ${code} = ฿${rate} (อ้างอิงเท่านั้น ไม่ใช่อัตราจริง)`;
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
