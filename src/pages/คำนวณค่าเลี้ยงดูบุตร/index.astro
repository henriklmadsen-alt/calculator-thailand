  <script type="module">
    import { calculateChildSupport } from '../../lib/child-support-calculator.ts';

    function parseNum(value) {
      const normalized = String(value).replace(/,/g, '').trim();
      if (normalized === '') return NaN;
      const num = Number(normalized);
      return Number.isFinite(num) ? num : NaN;
    }

    function formatMoney(num) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(num)} บาท`;
    }

    function formatPercent(ratio) {
      return `${(ratio * 100).toFixed(1)}%`;
    }

    const form = document.getElementById('cs-form');
    const formError = document.getElementById('cs-form-error');
    const resultBox = document.getElementById('cs-results');
    const useCustomExpenses = document.getElementById('use-custom-expenses');
    const customExpensesField = document.getElementById('custom-expenses-field');

    function clearFieldError(id) {
      const el = document.getElementById(id);
      if (!el) return;
      el.classList.add('hidden');
      el.textContent = '';
    }

    function setFieldError(id, message) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearErrors() {
      formError?.classList.add('hidden');
      clearFieldError('parent-a-error');
      clearFieldError('parent-b-error');
      clearFieldError('child-expenses-error');
    }

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    useCustomExpenses?.addEventListener('change', () => {
      if (useCustomExpenses.checked) {
        customExpensesField?.classList.remove('hidden');
      } else {
        customExpensesField?.classList.add('hidden');
      }
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      clearErrors();

      if (typeof window.trackCalculatorStart === 'function') {
        window.trackCalculatorStart('child_support');
      }

      const parentAIncome = parseNum(document.getElementById('parent-a-income')?.value || '');
      const parentBIncome = parseNum(document.getElementById('parent-b-income')?.value || '');
      const numberOfChildren = Number(document.getElementById('num-children')?.value || '1');
      const useCustom = useCustomExpenses?.checked || false;
      const childExpenses = useCustom ? parseNum(document.getElementById('child-expenses')?.value || '') : undefined;

      let hasError = false;

      if (!Number.isFinite(parentAIncome) || parentAIncome < 0) {
        setFieldError('parent-a-error', 'กรุณากรอกรายได้ที่ถูกต้อง (0 ขึ้นไป)');
        hasError = true;
      }

      if (!Number.isFinite(parentBIncome) || parentBIncome < 0) {
        setFieldError('parent-b-error', 'กรุณากรอกรายได้ที่ถูกต้อง (0 ขึ้นไป)');
        hasError = true;
      }

      if (!hasError && parentAIncome === 0 && parentBIncome === 0) {
        setFieldError('parent-a-error', 'รายได้อย่างน้อยหนึ่งฝ่ายต้องมากกว่า 0');
        hasError = true;
      }

      if (useCustom && (!Number.isFinite(childExpenses) || childExpenses <= 0)) {
        setFieldError('child-expenses-error', 'กรุณากรอกค่าใช้จ่ายบุตรที่ถูกต้อง');
        hasError = true;
      }

      if (hasError) {
        formError?.classList.remove('hidden');
        resultBox?.classList.add('hidden');
        return;
      }

      try {
        const result = calculateChildSupport({
          parentAIncome,
          parentBIncome,
          numberOfChildren,
          childExpenses: useCustom ? childExpenses : undefined,
        });

        setText('res-total-support', formatMoney(result.totalSupport));
        setText('res-per-child', formatMoney(result.perChildSupport));
        setText('res-percentage', formatPercent(result.childPercentage));

        setText('res-combined-income', formatMoney(result.combinedIncome));
        setText('res-parent-a-share', formatPercent(result.parentAShare));
        setText('res-parent-a-amount', formatMoney(result.parentAContribution));
        setText('res-parent-b-share', formatPercent(result.parentBShare));
        setText('res-parent-b-amount', formatMoney(result.parentBContribution));
        setText('res-total-bottom', formatMoney(result.totalSupport));

        resultBox?.classList.remove('hidden');
        resultBox?.scrollIntoView({ behavior: 'smooth', block: 'start' });

        if (typeof window.trackCalculatorComplete === 'function') {
          window.trackCalculatorComplete('child_support', result.totalSupport);
        }
      } catch (_error) {
        formError?.classList.remove('hidden');
        resultBox?.classList.add('hidden');
      }
    });
  </script>
</BaseLayout>
