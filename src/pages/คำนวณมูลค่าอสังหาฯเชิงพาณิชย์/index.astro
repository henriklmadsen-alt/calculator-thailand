---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณมูลค่าอสังหาฯเชิงพาณิชย์ 2569 | วิธี Income Approach | Kamnuanlek';
const pageDescription = 'คำนวณมูลค่าอสังหาฯเชิงพาณิชย์ด้วยวิธี Income Approach โดยใช้ Net Operating Income และ Cap Rate ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณมูลค่าอสังหาฯเชิงพาณิชย์/`;

const faqData = [
  {
    question: 'Income Approach คืออะไร?',
    answer: 'Income Approach เป็นวิธีประเมินมูลค่าอสังหาฯจากรายได้ที่สร้างได้ โดยใช้สูตร: มูลค่า = Net Operating Income ÷ Cap Rate คำนวณจากความสามารถในการสร้างรายได้ของทรัพย์สิน',
  },
  {
    question: 'Net Operating Income (NOI) คืออะไร?',
    answer: 'NOI = รายได้เช่าทั้งหมด - ค่าใช้จ่ายในการดำเนินการ (ไม่รวมค่าดอกเบี้ยจำนอง) เป็นรายได้สุทธิที่เสมือนเจ้าของทรัพย์สิน',
  },
  {
    question: 'Cap Rate คืออะไรและเท่าไร?',
    answer: 'Cap Rate = NOI ÷ มูลค่าทรัพย์สิน ส่วนใหญ่อสังหาฯเชิงพาณิชย์ใช้ 4-8% ขึ้นอยู่กับสภาพ location และอุตสาหกรรม',
  },
,
  { question: 'ค่าโอนบ้านปี 2569 คิดอัตราเท่าไร?', answer: 'ค่าธรรมเนียมโอน 2% ของราคาประเมิน (ลดเหลือ 1% สำหรับที่อยู่อาศัยราคาไม่เกิน 3 ล้าน จนถึง 31 ธ.ค. 2568), ค่าจดจำนอง 1% ของวงเงิน (ลดเหลือ 0.01% สำหรับกู้ไม่เกิน 3 ล้าน)' },
  { question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ต่างกันอย่างไร?', answer: 'ภาษีธุรกิจเฉพาะ 3.3% (ถือครองน้อยกว่า 5 ปีหรือไม่ได้มีชื่อในทะเบียนบ้าน) | อากรแสตมป์ 0.5% (ถือครอง 5 ปีขึ้นไปและมีชื่อในทะเบียนบ้านครบ 1 ปี) เสียอย่างใดอย่างหนึ่ง' },
  { question: 'ราคาประเมินกรมที่ดินกับราคาตลาดต่างกันอย่างไร?', answer: 'ราคาประเมินคือราคาที่กรมที่ดินกำหนดเพื่อใช้คิดค่าธรรมเนียม อัปเดตทุก 4 ปี มักต่ำกว่าราคาตลาด 20-50% ภาษีและค่าธรรมเนียมใช้ราคาประเมินหรือราคาซื้อขาย แล้วแต่อย่างไหนสูงกว่า' },
  { question: 'ซื้อบ้านมือสองต้องระวังค่าใช้จ่ายอะไร?', answer: 'ค่าธรรมเนียมโอน ค่าภาษีธุรกิจเฉพาะหรืออากรแสตมป์ ค่าจดจำนอง ค่าตรวจสอบภาระผูกพัน ค่าประเมินราคา ค่าซ่อมแซม และค่าประกันภัย รวมกันอาจสูงถึง 5-10% ของราคาซื้อ' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณมูลค่าอสังหาฯเชิงพาณิชย์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณมูลค่าอสังหาฯเชิงพาณิชย์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-emerald-100 bg-emerald-50 p-4">
      <p class="text-sm font-semibold text-emerald-700">ประเมินมูลค่าอสังหาฯเชิงพาณิชย์</p>
      <p class="mt-1 text-sm text-slate-700">วิธี Income Approach คำนวณจาก NOI และ Cap Rate สำหรับอาคารพาณิชย์ ห้องเช่า สำนักงาน</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณมูลค่าอสังหาฯเชิงพาณิชย์ ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      ประเมินมูลค่าทรัพย์สินพาณิชย์จากรายได้ที่สร้างได้ โดยใช้สูตร Income Approach ที่เป็นมาตรฐานสากล
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'สถาบันสำรวจราคาอสังหาฯไทย (TAREA): Cap Rate ย่างสำหรับทรัพย์สินพาณิชย์',
        'ธนาคารแห่งประเทศไทย: การประเมินมูลค่าอสังหาฯด้วย Income Approach',
      ]}
      assumptions={[
        'Cap Rate ตั้งแต่ 4-8% ขึ้นอยู่กับประเภทและสภาพทรัพย์สิน',
        'NOI = รายได้เช่า - ค่าดำเนินการ (ไม่รวมค่าดอกเบี้ยจำนอง)',
        'ข้อมูลรายได้เช่าและค่าดำเนินการเป็นจำนวนประมาณ',
      ]}
      references={[
        {
          label: 'TAREA: Commercial Property Valuation',
          href: 'https://www.tarea.or.th/',
        },
        {
          label: 'ธนาคารแห่งประเทศไทย: Property Valuation',
          href: 'https://www.bot.or.th/',
        },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="commercial-valuation-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="annual-rent" class="block text-sm font-medium text-gray-700 mb-1">รายได้เช่าต่อปี (บาท)</label>
            <input id="annual-rent" type="text" inputmode="numeric" placeholder="เช่น 500,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="operating-cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าดำเนินการต่อปี (บาท)</label>
            <input id="operating-cost" type="text" inputmode="numeric" placeholder="เช่น 100,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div>
          <label for="cap-rate" class="block text-sm font-medium text-gray-700 mb-1">Cap Rate (%)</label>
          <input id="cap-rate" type="text" inputmode="decimal" placeholder="เช่น 6.5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" value="6" />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          คำนวณมูลค่า
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการประเมินมูลค่า</h2>

        <div class="rounded-lg bg-primary-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">มูลค่าทรัพย์สิน (Income Approach)</div>
          <div id="res-property-value" class="text-2xl font-bold text-primary-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">รายได้เช่า/ปี</span>
            <span id="res-annual-rent" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าดำเนินการ/ปี</span>
            <span id="res-operating-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">NOI (Net Operating Income)</span>
            <span id="res-noi" class="font-bold text-emerald-700">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">Cap Rate</span>
            <span id="res-cap-rate" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">มูลค่าทรัพย์สิน (NOI ÷ Cap Rate)</span>
            <span id="res-calc-value" class="font-bold text-lg text-primary-700">-</span>
          </div>
        </div>

        <p class="text-xs text-gray-500 mt-4">
          หมายเหตุ: มูลค่าคำนวณจากข้อมูลที่คุณกรอก เป็นการประมาณเพื่อการวิเคราะห์เบื้องต้นเท่านั้น
        </p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="mb-8 bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 prose prose-slate max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>NOI</strong> = รายได้เช่าต่อปี - ค่าดำเนินการต่อปี</li>
        <li><strong>มูลค่าทรัพย์สิน</strong> = NOI ÷ Cap Rate</li>
        <li><strong>Cap Rate</strong> = อัตราผลตอบแทนจากการลงทุนในอสังหาฯ (ปกติ 4-8% สำหรับเชิงพาณิชย์)</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <RelatedArticles currentHref="/คำนวณมูลค่าอสังหาฯเชิงพาณิชย์/" />
    <RelatedCalculators currentHref="/คำนวณมูลค่าอสังหาฯเชิงพาณิชย์/" />

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#commercial-valuation-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const annualRent = parseNumber(document.querySelector('#annual-rent')?.value || '');
    const operatingCost = parseNumber(document.querySelector('#operating-cost')?.value || '');
    const capRate = parseNumber(document.querySelector('#cap-rate')?.value || '');

    if (!(Number.isFinite(annualRent) && annualRent > 0 && Number.isFinite(operatingCost) && operatingCost >= 0 && Number.isFinite(capRate) && capRate > 0)) {
      results?.classList.add('hidden');
      return;
    }

    const noi = annualRent - operatingCost;
    const capRateDecimal = capRate / 100;
    const propertyValue = noi / capRateDecimal;

    document.querySelector('#res-property-value').textContent = formatCurrency(propertyValue);
    document.querySelector('#res-annual-rent').textContent = formatCurrency(annualRent);
    document.querySelector('#res-operating-cost').textContent = formatCurrency(operatingCost);
    document.querySelector('#res-noi').textContent = formatCurrency(noi);
    document.querySelector('#res-cap-rate').textContent = `${capRate.toFixed(2)}%`;
    document.querySelector('#res-calc-value').textContent = formatCurrency(propertyValue);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
