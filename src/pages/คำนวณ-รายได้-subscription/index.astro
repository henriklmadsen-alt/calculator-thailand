---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ รายได้ Subscription 2569 | Kamnuanlek';
const pageDescription = 'คำนวณรายได้จากรูปแบบ Subscription/Membership ประเมิน MRR, ARR และ Churn Rate อย่างแม่นยำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-รายได้-subscription/`;

const faqData = [
  {
    question: 'Subscription Model คืออะไร?',
    answer: 'ลูกค้าจ่ายค่าเป็นประจำ (รายเดือน/รายปี) เพื่อใช้บริการของคุณต่อไป ตัวอย่าง: Netflix ฟิตเนส Membership Online Course Platform รายได้คาดการณ์ได้ Retention สำคัญมาก',
  },
  {
    question: 'MRR และ ARR ต่างกันอย่างไร?',
    answer: 'MRR (Monthly Recurring Revenue) = รายได้ประจำรายเดือน ARR (Annual Recurring Revenue) = รายได้ประจำรายปี (MRR × 12) ARR เป็นตัวชี้วัดคุณค่า Startup SaaS หลัก ธนาคารใช้ ARR ประเมิน Valuation',
  },
  {
    question: 'Churn Rate คืออะไร?',
    answer: 'ร้อยละของลูกค้าที่ยกเลิกสมาชิกในเดือน ตัวอย่าง: 100 ลูกค้า 10 คนยกเลิก = 10% Churn Rate ต่ำก็ดี Sustainable Business ต้อง < 5% ต่อเดือน',
  },
  {
    question: 'วิธีลดค่า Churn Rate?',
    answer: 'ให้คุณค่าที่มากกว่าราคา: อัปเดต/ใหม่อย่างสม่ำเสมอ ติดต่อลูกค้า: Email/Chat ถามประสบการณ์ ตอบปัญหาอย่างรวดเร็ว ทำให้เลิกง่ายเกินไป: มีกระบวนการเพื่อให้ลูกค้าหลักคิดก่อนยกเลิก',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณรายได้ Subscription',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณรายได้ Subscription">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      📊 คำนวณรายได้ Subscription/Membership
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณรายได้จากรูปแบบ Subscription/Membership
      ประเมิน MRR, ARR และ Churn Rate อย่างแม่นยำ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="sub-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="subscribers" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนสมาชิก
            </label>
            <input
              type="text"
              id="subscribers"
              inputmode="numeric"
              placeholder="เช่น 100"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="monthly-price" class="block text-sm font-medium text-gray-700 mb-1">
              ราคา/เดือน (บาท)
            </label>
            <input
              type="text"
              id="monthly-price"
              inputmode="numeric"
              placeholder="เช่น 299"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="churn-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Churn Rate (%)
            </label>
            <input
              type="text"
              id="churn-rate"
              inputmode="numeric"
              placeholder="เช่น 5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="new-subscribers" class="block text-sm font-medium text-gray-700 mb-1">
              สมาชิกใหม่/เดือน
              <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
            </label>
            <input
              type="text"
              id="new-subscribers"
              inputmode="numeric"
              placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="payment-fee" class="block text-sm font-medium text-gray-700 mb-1">
            ค่า Payment Gateway (%)
            <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
          </label>
          <input
            type="text"
            id="payment-fee"
            inputmode="numeric"
            placeholder="เช่น 2.5"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณรายได้
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณรายได้ Subscription</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">MRR (ต่อเดือน)</div>
            <div id="res-mrr" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ARR (ต่อปี)</div>
            <div id="res-arr" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยกเลิก/เดือน</div>
            <div id="res-churn-count" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">สุทธิหลังค่า</div>
            <div id="res-net-mrr" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนสมาชิก</span>
            <span id="res-subscribers" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ราคา/เดือน</span>
            <span id="res-price" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">Churn Rate</span>
            <span id="res-churn" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">สมาชิกคาดการณ์ (3 เดือน)</span>
            <span id="res-projected-3m" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">Subscription Model: ส่วนหนึ่งของ Modern Business</h2>

      <p>
        Subscription Model เป็นแบบธุรกิจที่สำคัญในยุคดิจิทัล
        เนื่องจากรายได้ที่คาดการณ์ได้ ผู้ลงทุนชอบ Recurring Revenue
        และความสัมพันธ์ลูกค้าระยะยาว
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวชี้วัดสำคัญของ Subscription</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>MRR</strong> — Monthly Recurring Revenue รายได้ประจำรายเดือน</li>
        <li><strong>ARR</strong> — Annual Recurring Revenue (MRR × 12)</li>
        <li><strong>Churn Rate</strong> — ร้อยละของลูกค้าที่ยกเลิกต่อเดือน</li>
        <li><strong>CAC</strong> — Customer Acquisition Cost ต้นทุนหาลูกค้า 1 คน</li>
        <li><strong>LTV</strong> — Lifetime Value รายได้รวมต่อลูกค้า 1 คน</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการคำนวณ Subscription</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>500 สมาชิก × 299 บาท = 149,500 บาท MRR</li>
        <li>149,500 × 12 = 1,794,000 บาท ARR</li>
        <li>5% Churn = 25 คนยกเลิก = 7,475 บาท สูญหายต่อเดือน</li>
        <li>หากเพิ่ม 10 สมาชิกใหม่ต่อเดือน = ค่อยๆ เติบโต</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีปรับปรุง Subscription Model</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ลดค่า Churn: ให้คุณค่าสม่ำเสมอ ฟัง feedback ลูกค้า</li>
        <li>เพิ่ม CAC ROI: ใช้ Referral/Word-of-mouth แทน Ads แพง</li>
        <li>เพิ่ม LTV: ขึ้นราคา Upsell Advanced Plan เพิ่มคุณค่า</li>
        <li>Retention Marketing: ส่ง Email, In-app Notification ให้ลูกค้ารู้มูลค่า</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-รายได้-subscription/" />
    <RelatedCalculators currentHref="/คำนวณ-รายได้-subscription/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ
      ตัวเลขจริงขึ้นอยู่กับการเก็บรักษา ฤดูกาล และปัจจัยตลาด
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('sub-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const subscribers = parseNum((document.getElementById('subscribers') as HTMLInputElement).value);
      const monthlyPrice = parseNum((document.getElementById('monthly-price') as HTMLInputElement).value);
      const churnRate = parseNum((document.getElementById('churn-rate') as HTMLInputElement).value);
      const newSubscribers = parseNum((document.getElementById('new-subscribers') as HTMLInputElement).value);
      const paymentFee = parseNum((document.getElementById('payment-fee') as HTMLInputElement).value);

      if (subscribers <= 0) { (document.getElementById('subscribers') as HTMLInputElement).focus(); return; }
      if (monthlyPrice <= 0) { (document.getElementById('monthly-price') as HTMLInputElement).focus(); return; }
      if (churnRate < 0 || churnRate > 100) { (document.getElementById('churn-rate') as HTMLInputElement).focus(); return; }

      const mrr = subscribers * monthlyPrice;
      const arr = mrr * 12;
      const churnCount = Math.floor((subscribers * churnRate) / 100);
      const churnMoney = churnCount * monthlyPrice;
      const paymentFeeAmount = (mrr * paymentFee) / 100;
      const netMrr = mrr - paymentFeeAmount;

      // โปรเจคต์ 3 เดือน ถ้ามีสมาชิกใหม่
      let projected = subscribers;
      for (let i = 0; i < 3; i++) {
        projected = projected + newSubscribers - (projected * churnRate) / 100;
      }

      (document.getElementById('res-mrr') as HTMLElement).textContent = fmt(mrr) + ' บาท';
      (document.getElementById('res-arr') as HTMLElement).textContent = fmt(arr) + ' บาท';
      (document.getElementById('res-churn-count') as HTMLElement).textContent = churnCount + ' คน';
      (document.getElementById('res-net-mrr') as HTMLElement).textContent = fmt(netMrr) + ' บาท';
      (document.getElementById('res-subscribers') as HTMLElement).textContent = subscribers.toFixed(0);
      (document.getElementById('res-price') as HTMLElement).textContent = fmt(monthlyPrice) + ' บาท';
      (document.getElementById('res-churn') as HTMLElement).textContent = churnRate.toFixed(2) + '%';
      (document.getElementById('res-projected-3m') as HTMLElement).textContent = projected.toFixed(0);

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('subscription-revenue');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('subscription-revenue');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
