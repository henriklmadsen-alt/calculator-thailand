---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าวัคซีน | Kamnuanlek';
const pageDescription = 'คำนวณค่าวัคซีนตามช่วงอายุ วัคซีนเด็ก วัคซีนผู้ใหญ่ วัคซีนท่องเที่ยว ตามอัตราโรงพยาบาลไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0409-ค่าวัคซีน/`;

const faqData = [
  { question: 'วัคซีนเด็กพื้นฐานในไทยฟรีไหม?', answer: 'วัคซีนพื้นฐานตามแผนงานสร้างเสริมภูมิคุ้มกันโรคของกระทรวงสาธารณสุข เช่น DTP, MMR, Polio ให้ฟรีที่โรงพยาบาลรัฐ' },
  { question: 'วัคซีนไข้หวัดใหญ่ราคาเท่าไหร่?', answer: 'วัคซีนไข้หวัดใหญ่ 400-800 บาทต่อเข็ม ควรฉีดทุกปีก่อนฤดูฝน เนื่องจากสายพันธุ์ไวรัสเปลี่ยนทุกปี' },
  { question: 'วัคซีนมะเร็งปากมดลูก HPV ราคาเท่าไหร่?', answer: 'วัคซีน HPV 2 เข็ม ราคา 3,000-5,000 บาทต่อชุด รัฐบาลให้ฟรีแก่เด็กหญิงชั้น ป.5 ตามโครงการ' },
  { question: 'ควรฉีดวัคซีนอะไรก่อนเดินทาง?', answer: 'ขึ้นอยู่กับประเทศปลายทาง เช่น วัคซีนไข้เหลือง ไทฟอยด์ ตับอักเสบ A/B ควรปรึกษาแพทย์อย่างน้อย 4-6 สัปดาห์ก่อนเดินทาง' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าวัคซีน">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าวัคซีน</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">ประมาณการค่าวัคซีนตามประเภทและจำนวนเข็ม</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="flu_vaccine" class="block text-sm font-medium text-gray-700 mb-1">วัคซีนไข้หวัดใหญ่ (จำนวนคน)</label><input type="number" id="flu_vaccine" min="0" max="10" placeholder="เช่น 2" value="2" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="hpv_vaccine" class="block text-sm font-medium text-gray-700 mb-1">วัคซีน HPV (จำนวนชุด × 4,000 บาท)</label><input type="number" id="hpv_vaccine" min="0" max="5" placeholder="เช่น 1" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="hep_vaccine" class="block text-sm font-medium text-gray-700 mb-1">วัคซีนตับอักเสบ B (จำนวนชุด × 1,500 บาท)</label><input type="number" id="hep_vaccine" min="0" max="5" placeholder="เช่น 0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="other_vaccine" class="block text-sm font-medium text-gray-700 mb-1">วัคซีนอื่นๆ (บาท)</label><input type="text" id="other_vaccine" inputmode="decimal" placeholder="เช่น 1000" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="admin_fee" class="block text-sm font-medium text-gray-700 mb-1">ค่าบริการฉีดวัคซีน (บาท/ครั้ง)</label><input type="text" id="admin_fee" inputmode="decimal" placeholder="เช่น 100" value="100" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าวัคซีนรวม</p>
            <p id="vaccine_total" class="font-bold">-</p>
          </div>
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าบริการฉีด</p>
            <p id="admin_total" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">รวมค่าวัคซีนทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const fluCount = parseInt((document.getElementById('flu_vaccine') as HTMLInputElement).value) || 0;
      const hpvCount = parseInt((document.getElementById('hpv_vaccine') as HTMLInputElement).value) || 0;
      const hepCount = parseInt((document.getElementById('hep_vaccine') as HTMLInputElement).value) || 0;
      const otherVaccine = parseFloat((document.getElementById('other_vaccine') as HTMLInputElement).value) || 0;
      const adminFee = parseFloat((document.getElementById('admin_fee') as HTMLInputElement).value) || 0;

      const vaccineTotal = (fluCount * 600) + (hpvCount * 4000) + (hepCount * 1500) + otherVaccine;
      const totalDoses = fluCount + (hpvCount * 2) + (hepCount * 3);
      const adminTotal = adminFee * totalDoses;
      const total = vaccineTotal + adminTotal;

      (document.getElementById('vaccine_total') as HTMLElement).textContent = vaccineTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('admin_total') as HTMLElement).textContent = adminTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('vaccine-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
