---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณ ROI ธุรกิจ | Kamnuanlek';
const pageDescription = 'คำนวณ ROI ผลตอบแทนการลงทุนธุรกิจ Return on Investment กำไรต่อเงินลงทุน ปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0459-roi-ธุรกิจ/`;
const faqData = [
  { question: 'ROI ที่ดีสำหรับธุรกิจไทยควรเป็นเท่าไหร่?', answer: 'ROI ที่ดีขึ้นอยู่กับประเภทธุรกิจ ธุรกิจทั่วไปควรมี ROI อย่างน้อย 15-20% ต่อปี สูงกว่าอัตราดอกเบี้ยเงินกู้และอัตราเงินเฟ้อ' },
  { question: 'ROI คำนวณอย่างไร?', answer: 'ROI = (กำไรสุทธิ ÷ เงินลงทุน) × 100% หรือ ROI = (รายได้ - ต้นทุน ÷ ต้นทุน) × 100% ยิ่งสูงยิ่งดี' },
  { question: 'ROI ต่างจาก ROIC อย่างไร?', answer: 'ROI วัดผลตอบแทนต่อเงินลงทุนทั้งหมด ROIC (Return on Invested Capital) วัดเฉพาะทุนที่ใช้ในการดำเนินงาน ROIC เหมาะกับการเปรียบเทียบบริษัท' },
  { question: 'ระยะเวลาคืนทุน Payback Period คืออะไร?', answer: 'Payback Period = เงินลงทุน ÷ กำไรสุทธิต่อปี คือจำนวนปีที่ใช้คืนทุน ธุรกิจเสี่ยงต่ำ Payback 2-3 ปี ธุรกิจปกติ 3-5 ปี' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ ROI ธุรกิจ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณ ROI ธุรกิจ</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณผลตอบแทนการลงทุนธุรกิจ ROI และระยะเวลาคืนทุน</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="investment_roi" class="block text-sm font-medium text-gray-700 mb-1">เงินลงทุนทั้งหมด (บาท)</label><input type="text" id="investment_roi" inputmode="decimal" placeholder="เช่น 500000" value="500000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="annual_revenue_roi" class="block text-sm font-medium text-gray-700 mb-1">รายได้ต่อปี (บาท)</label><input type="text" id="annual_revenue_roi" inputmode="decimal" placeholder="เช่น 800000" value="800000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="annual_cost_roi" class="block text-sm font-medium text-gray-700 mb-1">ค่าใช้จ่ายต่อปี (บาท)</label><input type="text" id="annual_cost_roi" inputmode="decimal" placeholder="เช่น 600000" value="600000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">กำไรสุทธิต่อปี</p><p id="net_profit_roi" class="font-bold">-</p></div>
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ROI ต่อปี</p><p id="roi_percent" class="font-bold">-</p></div>
          <div class="bg-indigo-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">ระยะเวลาคืนทุน</p><p id="payback" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const investment = parseFloat((document.getElementById('investment_roi') as HTMLInputElement).value) || 0;
      const revenue = parseFloat((document.getElementById('annual_revenue_roi') as HTMLInputElement).value) || 0;
      const cost = parseFloat((document.getElementById('annual_cost_roi') as HTMLInputElement).value) || 0;
      const netProfit = revenue - cost;
      const roi = investment > 0 ? (netProfit / investment * 100) : 0;
      const payback = netProfit > 0 ? investment / netProfit : 0;
      (document.getElementById('net_profit_roi') as HTMLElement).textContent = netProfit.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('roi_percent') as HTMLElement).textContent = roi.toFixed(2) + '%';
      (document.getElementById('payback') as HTMLElement).textContent = payback > 0 ? payback.toFixed(1) + ' ปี' : 'ไม่คุ้มทุน';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('business-roi');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
