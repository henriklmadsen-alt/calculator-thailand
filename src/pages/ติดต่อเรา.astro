---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ติดต่อเรา | Kamnuanlek คำนวณเลข"
  description="ติดต่อทีม Kamnuanlek — แนะนำเครื่องคำนวณใหม่ แจ้งข้อผิดพลาด หรือสอบถามการร่วมมือทางธุรกิจ"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "ติดต่อเรา", "item": "https://www.kamnuanlek.com/ติดต่อเรา/"}
    ]
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "ติดต่อ Kamnuanlek",
    "url": "https://www.kamnuanlek.com/ติดต่อเรา/",
    "mainEntity": {
      "@type": "Organization",
      "name": "Kamnuanlek",
      "url": "https://www.kamnuanlek.com",
      "email": "info@kamnuanlek.com",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@kamnuanlek.com",
        "contactType": "customer support",
        "availableLanguage": ["Thai", "English"]
      }
    }
  }</script>

  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-2">ติดต่อเรา</h1>
    <p class="text-lg text-gray-600 mb-10">เราพร้อมรับฟังทุกความคิดเห็น คำแนะนำ และคำถามจากท่าน</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">

      <!-- Contact Cards -->
      <a href="mailto:info@kamnuanlek.com"
         class="flex items-start gap-4 p-6 bg-white border-2 border-primary-200 rounded-xl hover:border-primary-500 hover:shadow-md transition-all group">
        <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary-200 transition-colors">
          <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-gray-900 text-lg">อีเมล</h2>
          <p class="text-primary-600 font-medium mt-1">info@kamnuanlek.com</p>
          <p class="text-gray-500 text-sm mt-1">ตอบกลับภายใน 1–2 วันทำการ</p>
        </div>
      </a>

      <div class="flex items-start gap-4 p-6 bg-white border border-gray-200 rounded-xl">
        <div class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
          </svg>
        </div>
        <div>
          <h2 class="font-bold text-gray-900 text-lg">เว็บไซต์</h2>
          <p class="text-gray-700 font-medium mt-1">www.kamnuanlek.com</p>
          <p class="text-gray-500 text-sm mt-1">เครื่องคำนวณออนไลน์ฟรี 800+ รายการ</p>
        </div>
      </div>

    </div>

    <!-- Topics -->
    <div class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-4">เราช่วยอะไรได้บ้าง?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          { icon: '🐛', title: 'แจ้งข้อผิดพลาด', desc: 'พบว่าเครื่องคำนวณคำนวณผิด หรือหน้าเว็บไม่ทำงาน' },
          { icon: '💡', title: 'แนะนำเครื่องคำนวณใหม่', desc: 'อยากได้เครื่องคำนวณสำหรับงานเฉพาะทาง' },
          { icon: '🤝', title: 'ความร่วมมือทางธุรกิจ', desc: 'Affiliate, sponsorship, หรือ content partnership' },
          { icon: '📰', title: 'สื่อมวลชนและนักข่าว', desc: 'ขอสัมภาษณ์ ข้อมูลสถิติ หรือ press kit' },
          { icon: '📊', title: 'คำถามเกี่ยวกับข้อมูล', desc: 'สอบถามแหล่งอ้างอิงอัตราและสูตรที่ใช้' },
          { icon: '⚖️', title: 'กฎหมายและความเป็นส่วนตัว', desc: 'ข้อกังวลด้าน PDPA หรือการใช้ข้อมูล' },
        ].map((item) => (
          <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-lg">
            <span class="text-xl flex-shrink-0">{item.icon}</span>
            <div>
              <p class="font-semibold text-gray-900 text-sm">{item.title}</p>
              <p class="text-gray-600 text-xs mt-0.5">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- About -->
    <div class="p-6 bg-blue-50 border border-blue-200 rounded-xl">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 bg-primary-600 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <h2 class="font-bold text-gray-900 text-lg">เกี่ยวกับ Kamnuanlek</h2>
      </div>
      <p class="text-gray-700 text-sm">
        Kamnuanlek (คำนวณเลข) คือแพลตฟอร์มเครื่องคำนวณออนไลน์ฟรีสำหรับคนไทย
        ครอบคลุมการคำนวณภาษี สินเชื่อ เงินเดือน ค่าสาธารณูปโภค ประกัน และอีกกว่า 800 รายการ
        ทุกอัตราอ้างอิงจากหน่วยงานราชการไทยและอัปเดตสำหรับปี 2569
      </p>
      <a href="/เกี่ยวกับ-kamnuanlek/" class="inline-block mt-3 text-primary-600 text-sm font-medium hover:underline">
        อ่านเพิ่มเติมเกี่ยวกับเรา →
      </a>
    </div>
  </div>
</BaseLayout>
