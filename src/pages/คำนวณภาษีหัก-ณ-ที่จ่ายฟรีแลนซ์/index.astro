---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณภาษีหัก ณ ที่จ่ายฟรีแลนซ์ 2569 | 3% ค่าบริการ | Kamnuanlek';
const pageDescription = 'คำนวณภาษีหัก ณ ที่จ่าย 3% สำหรับฟรีแลนซ์ แสดงยอดก่อน/หลังหักภาษี สร้างตัวเลขสำหรับออกใบแจ้งหนี้ และคำนวณภาษีหัก ณ ที่จ่ายที่ต้องนำส่ง ปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีหัก-ณ-ที่จ่ายฟรีแลนซ์/`;

const faqData = [
  {
    question: 'ฟรีแลนซ์ถูกหักภาษี ณ ที่จ่ายเท่าไร?',
    answer: 'ค่าบริการและค่าจ้างฟรีแลนซ์ประเภท 40(2) ถูกหักภาษี ณ ที่จ่าย 3% ของยอดก่อนหักทุกครั้งที่จ่ายเงิน ผู้จ่ายต้องนำส่งภาษีให้กรมสรรพากรภายในวันที่ 7 ของเดือนถัดไป',
  },
  {
    question: 'ฟรีแลนซ์ต้องออกใบกำกับภาษีหรือไม่?',
    answer: 'ฟรีแลนซ์ที่ไม่ได้จดทะเบียน VAT ไม่ต้องออกใบกำกับภาษี แต่ผู้จ่ายเงินต้องออกหนังสือรับรองการหักภาษี ณ ที่จ่าย (ใบ 50 ทวิ) ให้ฟรีแลนซ์ทุกครั้ง',
  },
  {
    question: 'ภาษีหัก ณ ที่จ่ายที่ถูกหักไปนำไปใช้ได้อย่างไร?',
    answer: 'ภาษีที่ถูกหักตลอดปีสามารถนำมาหักออกจากภาษีที่ต้องชำระเมื่อยื่นแบบ ภ.ง.ด.90 ปลายปี ถ้าหักเกินจะได้รับเงินคืน ถ้าหักน้อยต้องจ่ายเพิ่ม',
  },
  {
    question: 'ใบ 50 ทวิ คืออะไร?',
    answer: 'หนังสือรับรองการหักภาษี ณ ที่จ่าย (50 ทวิ) คือเอกสารที่ผู้จ่ายเงินออกให้ฟรีแลนซ์เพื่อยืนยันว่าได้หักภาษีและนำส่งแล้ว ฟรีแลนซ์ต้องเก็บไว้เพื่อใช้ยื่นแบบภาษีปลายปี',
  },
  {
    question: 'ฟรีแลนซ์ที่รายได้น้อยกว่า 30,000 บาทต่อครั้งถูกหักภาษีไหม?',
    answer: 'ถูกหัก ถ้าผู้จ่ายเป็นบริษัทหรือห้างฯ ต้องหักภาษี 3% ทุกครั้งไม่ว่าจำนวนเงินเท่าใด แต่ถ้าผู้จ่ายเป็นบุคคลธรรมดาที่ไม่ได้ทำธุรกิจ ไม่ต้องหัก',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณภาษีหัก ณ ที่จ่ายฟรีแลนซ์ 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีหัก-ณ-ที่จ่ายฟรีแลนซ์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">สำหรับฟรีแลนซ์และผู้ว่าจ้าง</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณภาษีหัก ณ ที่จ่าย 3% ตามประเภท 40(2)</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัตราภาษีปี 2569 (กรมสรรพากร)</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณภาษีหัก ณ ที่จ่ายฟรีแลนซ์ 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณภาษีหัก ณ ที่จ่าย 3% สำหรับค่าบริการฟรีแลนซ์
      แสดงยอดที่ต้องระบุในใบแจ้งหนี้ และยอดที่รับจริงหลังหักภาษี
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูลค่าบริการ</h2>
      <form id="freelance-form" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">โหมดการคำนวณ</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="calc-mode" id="mode-from-gross" value="gross" checked class="w-4 h-4 text-primary-600" />
              <span class="text-sm text-gray-700">รู้ยอดก่อนหักภาษี (ต้องการรู้ยอดหัก)</span>
            </label>
          </div>
          <div class="flex gap-4 mt-2">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="calc-mode" id="mode-from-net" value="net" class="w-4 h-4 text-primary-600" />
              <span class="text-sm text-gray-700">รู้ยอดที่ต้องการรับสุทธิ (ต้องการรู้ยอดในใบแจ้งหนี้)</span>
            </label>
          </div>
        </div>

        <div id="gross-input">
          <label for="gross-amount" class="block text-sm font-medium text-gray-700 mb-1">ค่าบริการก่อนหักภาษี (บาท)</label>
          <input type="text" id="gross-amount" inputmode="numeric" placeholder="เช่น 30,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>

        <div id="net-input" class="hidden">
          <label for="net-amount" class="block text-sm font-medium text-gray-700 mb-1">ยอดที่ต้องการรับสุทธิ (บาท)</label>
          <input type="text" id="net-amount" inputmode="numeric" placeholder="เช่น 29,100"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>

        <div>
          <label for="invoice-count" class="block text-sm font-medium text-gray-700 mb-1">จำนวนใบแจ้งหนี้ต่อปี — ไม่บังคับ (สำหรับดูยอดหัก ณ ที่จ่ายทั้งปี)</label>
          <input type="number" id="invoice-count" min="1" max="365" placeholder="เช่น 12"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>

        <button type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดในใบแจ้งหนี้</div>
            <div id="r-gross" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ภาษีหัก ณ ที่จ่าย 3%</div>
            <div id="r-wht" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รับสุทธิ</div>
            <div id="r-net" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>
        <div id="r-annual-row" class="hidden space-y-2 text-sm border-t border-gray-100 pt-4">
          <div class="flex justify-between py-1">
            <span class="text-gray-600">ภาษีหัก ณ ที่จ่ายทั้งปี (ต่อ <span id="r-inv-count">-</span> ใบ)</span>
            <span id="r-annual-wht" class="font-medium text-red-600">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">รายได้ทั้งปี (ก่อนหักภาษี)</span>
            <span id="r-annual-gross" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ภาษีหัก ณ ที่จ่ายฟรีแลนซ์คืออะไร?</h2>
      <p>เมื่อบริษัทหรือห้างฯ จ้างฟรีแลนซ์ทำงาน ผู้จ่ายต้องหัก 3% จากค่าบริการก่อนจ่ายเงิน และนำส่งกรมสรรพากรแทนฟรีแลนซ์ พร้อมออกหนังสือรับรองการหักภาษี ณ ที่จ่าย (50 ทวิ)</p>
      <h3 class="text-lg font-semibold mt-4 mb-2">ตัวอย่าง</h3>
      <p>ฟรีแลนซ์ออกใบแจ้งหนี้ 30,000 บาท → ผู้จ่ายหัก 900 บาท (3%) → ฟรีแลนซ์รับสุทธิ 29,100 บาท</p>
      <p>ผู้จ่ายนำส่ง 900 บาทให้กรมสรรพากรแทนฟรีแลนซ์ เมื่อปิดปีภาษี ฟรีแลนซ์นำ 900 บาทนี้หักออกจากภาษีที่ต้องชำระ</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณภาษีหัก-ณ-ที่จ่ายฟรีแลนซ์/" />
    <RelatedCalculators currentHref="/คำนวณภาษีหัก-ณ-ที่จ่ายฟรีแลนซ์/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ อ้างอิงอัตราภาษีกรมสรรพากรปี 2569 กรุณาปรึกษาผู้เชี่ยวชาญสำหรับกรณีเฉพาะ
    </div>
  </article>

  <script>
    function parseNum(v: string) { return Math.max(0, parseFloat((v || '0').replace(/,/g, '')) || 0); }
    function fmt(n: number) { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' บาท'; }

    const modeGross = document.getElementById('mode-from-gross') as HTMLInputElement;
    const modeNet = document.getElementById('mode-from-net') as HTMLInputElement;
    const grossInput = document.getElementById('gross-input') as HTMLElement;
    const netInput = document.getElementById('net-input') as HTMLElement;

    function toggleMode() {
      const isGross = modeGross.checked;
      grossInput.classList.toggle('hidden', !isGross);
      netInput.classList.toggle('hidden', isGross);
    }

    modeGross.addEventListener('change', toggleMode);
    modeNet.addEventListener('change', toggleMode);

    const form = document.getElementById('freelance-form') as HTMLFormElement;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const isGross = modeGross.checked;
      let gross: number;

      if (isGross) {
        gross = parseNum((document.getElementById('gross-amount') as HTMLInputElement).value);
      } else {
        const net = parseNum((document.getElementById('net-amount') as HTMLInputElement).value);
        gross = net / 0.97;
      }

      if (gross <= 0) return;

      const wht = gross * 0.03;
      const net = gross - wht;
      const invCount = parseInt((document.getElementById('invoice-count') as HTMLInputElement).value) || 0;

      (document.getElementById('r-gross') as HTMLElement).textContent = fmt(gross);
      (document.getElementById('r-wht') as HTMLElement).textContent = fmt(wht);
      (document.getElementById('r-net') as HTMLElement).textContent = fmt(net);

      const annualRow = document.getElementById('r-annual-row') as HTMLElement;
      if (invCount > 0) {
        annualRow.classList.remove('hidden');
        (document.getElementById('r-inv-count') as HTMLElement).textContent = invCount.toString();
        (document.getElementById('r-annual-wht') as HTMLElement).textContent = fmt(wht * invCount);
        (document.getElementById('r-annual-gross') as HTMLElement).textContent = fmt(gross * invCount);
      } else {
        annualRow.classList.add('hidden');
      }

      const resultsDiv = document.getElementById('results') as HTMLElement;
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('freelance_withholding_tax');
      trackCalculatorUsed('freelance_withholding_tax');
    });

    form.addEventListener('input', () => { trackCalculatorStart('freelance_withholding_tax'); }, { once: true });
  </script>
</BaseLayout>
