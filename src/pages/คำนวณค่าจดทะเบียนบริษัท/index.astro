---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณค่าจดทะเบียนบริษัท DBD 2569 | ค่าอากร ค่าธรรมเนียม ฟรี | Calculator Thailand';
const pageDescription = 'คำนวณค่าจดทะเบียนบริษัท ค่าธรรมเนียม DBD อากรแสตมป์ ค่าสัญญา ตามอัตรา 2569 คำนวณออนไลน์ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าจดทะเบียนบริษัท/`;

const faqData = [
  {
    question: 'ค่าจดทะเบียนบริษัท DBD ประกอบด้วยอะไรบ้าง?',
    answer: 'ค่าจดทะเบียนบริษัท DBD ประกอบด้วย 4 ส่วน: (1) ค่าธรรมเนียมการจดทะเบียน DBD ตามขนาดทุนจด (2) อากรแสตมป์บันทึกการจัดตั้ง (3) อากรแสตมป์วัสดุอื่น และ (4) ค่าบริการอื่น ๆ',
  },
  {
    question: 'ค่าธรรมเนียมการจดทะเบียน DBD คำนวณอย่างไร?',
    answer: 'ค่าธรรมเนียม DBD ขึ้นอยู่กับทุนจดทะเบียนของบริษัท: ไม่เกิน 100,000 บาท เสียค่า 500 บาท, เกิน 100,000 ถึง 500,000 บาท เสีย 750 บาท, เกิน 500,000 ถึง 1,000,000 บาท เสีย 1,000 บาท ฯลฯ',
  },
  {
    question: 'อากรแสตมป์ในการจดทะเบียนบริษัท มีเท่าไร?',
    answer: 'อากรแสตมป์กำหนดตามมูลค่าทุนจดทะเบียน โดยอัตรา 0.5% ของทุนจดทะเบียนสำหรับบันทึกการจัดตั้งบริษัท อัตรา 0.5% อื่น ๆ สำหรับเอกสารอื่น',
  },
  {
    question: 'ค่าธรรมเนียมสัญญาแนบ (วัสดุอื่น) เท่าไร?',
    answer: 'ค่าธรรมเนียมสัญญาแนบตามปกติประมาณ 100-300 บาท ซึ่งสามารถให้ธุรกิจหรือบุคลากรจัดการได้ หรือหากจ้างทนายความจะมีค่าสัญญา 2,000-10,000 บาท ขึ้นอยู่กับวิธีดำเนินการ',
  },
  {
    question: 'ต้องมีทุนจดทะเบียนขั้นต่ำเท่าไร?',
    answer: 'ท้องบ้านที่จดทะเบียนบริษัท ไม่มีข้อกำหนดทุนจดทะเบียนขั้นต่ำ แต่ทั่วไปจะจดทะเบียนตั้งแต่ 100,000 บาทขึ้นไป เพื่อให้มีความสามารถในการดำเนินกิจการและเชื่อถือได้',
  },
  {
    question: 'วิธีชำระค่าธรรมเนียมการจดทะเบียนบริษัท?',
    answer: 'สามารถชำระค่าธรรมเนียมที่สำนักงาน DBD โดยตรง หรือหากมีตัวแทน (นายหน้า) สามารถชำระหรือให้จัดการแทนได้ ช่วงเวลาการจดทะเบียนมักใช้เวลา 1-2 วันทำการเพื่อให้เสร็จสิ้น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าจดทะเบียนบริษัท',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณค่าจดทะเบียนบริษัท',
  description: 'ขั้นตอนการคำนวณค่าจดทะเบียนบริษัทตามอัตราค่าธรรมเนียม DBD และอากรแสตมป์ ปี 2569',
  step: [
    {
      '@type': 'HowToStep',
      name: 'เลือกประเภทบริษัท',
      text: 'เลือกประเภทของบริษัทที่ต้องการจดทะเบียน เช่น บริษัทจำกัด บริษัทมหาชนจำกัด ห้างหุ้นส่วน เป็นต้น',
    },
    {
      '@type': 'HowToStep',
      name: 'ระบุทุนจดทะเบียน',
      text: 'ระบุจำนวนทุนจดทะเบียนของบริษัท (หน่วยเป็นบาท) ซึ่งจะใช้คำนวณค่าธรรมเนียม DBD และอากรแสตมป์',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกบริการเพิ่มเติม',
      text: 'เลือกว่าต้องการบริการเพิ่มเติมหรือไม่ เช่น ค่าธรรมเนียมนายหน้า (ธรรมเนียม DBD) ค่าสัญญาจาก ทนายความ หรือค่าสัญญาเพิ่มเติม',
    },
    {
      '@type': 'HowToStep',
      name: 'ดูผลการคำนวณ',
      text: 'ระบบจะแสดงค่าธรรมเนียมแต่ละส่วน รวมถึงค่าธรรมเนียมทั้งหมด (รวมภาษี VAT 7%)',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าจดทะเบียนบริษัท">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าจดทะเบียนบริษัท
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2">
      <p class="text-xs font-semibold text-blue-800">[ตามอัตรา DBD ปี 2569 — อัปเดต]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าจดทะเบียนบริษัท ค่าธรรมเนียม DBD อากรแสตมป์ และค่าบริการเพิ่มเติม ตามอัตรา 2569 ออนไลน์ฟรี
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="companyType" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทบริษัท
          </label>
          <select
            id="companyType"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          >
            <option value="limited">บริษัทจำกัด (Limited Company)</option>
            <option value="unlimited">บริษัทมหาชนจำกัด (Public Company)</option>
            <option value="partnership">ห้างหุ้นส่วนสามัญ (Partnership)</option>
          </select>
        </div>
        <div>
          <label for="capital" class="block text-sm font-medium text-gray-700 mb-1">
            ทุนจดทะเบียน (บาท)
          </label>
          <input
            type="text"
            id="capital"
            inputmode="decimal"
            placeholder="เช่น 1000000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-3">
          บริการเพิ่มเติม (ถ้ามี)
        </label>
        <div class="space-y-2">
          <label class="flex items-center">
            <input
              type="checkbox"
              id="includeNotary"
              class="w-4 h-4 border-gray-300 rounded focus:ring-2 focus:ring-primary-500"
            />
            <span class="ml-2 text-sm text-gray-700">ค่าธรรมเนียมนายหน้า DBD (ประมาณ 1,000 บาท)</span>
          </label>
          <label class="flex items-center">
            <input
              type="checkbox"
              id="includeLawyer"
              class="w-4 h-4 border-gray-300 rounded focus:ring-2 focus:ring-primary-500"
            />
            <span class="ml-2 text-sm text-gray-700">ค่าสัญญาจากทนายความ (ประมาณ 3,500 บาท)</span>
          </label>
          <label class="flex items-center">
            <input
              type="checkbox"
              id="includeSeal"
              class="w-4 h-4 border-gray-300 rounded focus:ring-2 focus:ring-primary-500"
            />
            <span class="ml-2 text-sm text-gray-700">สัญญาบริษัท (ประมาณ 500 บาท)</span>
          </label>
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณค่าจดทะเบียน
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6">
        <div class="mb-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
          <h3 class="font-semibold text-gray-900 mb-4">สรุปค่าธรรมเนียม</h3>

          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าธรรมเนียม DBD</span>
              <span id="fee-dbd" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">อากรแสตมป์ บันทึกการจัดตั้ง</span>
              <span id="fee-stamp1" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">อากรแสตมป์ อื่น</span>
              <span id="fee-stamp2" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าธรรมเนียมนายหน้า (ถ้ามี)</span>
              <span id="fee-notary" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าสัญญาทนายความ (ถ้ามี)</span>
              <span id="fee-lawyer" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">สัญญาบริษัท (ถ้ามี)</span>
              <span id="fee-seal" class="font-medium text-gray-900">-</span>
            </div>
          </div>

          <div class="border-t border-blue-300 my-3"></div>

          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-sm font-medium text-gray-700">รวมค่าธรรมเนียมก่อน VAT</span>
              <span id="subtotal" class="font-semibold text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm font-medium text-gray-700">ภาษี VAT 7%</span>
              <span id="vat-amount" class="font-semibold text-gray-900">-</span>
            </div>
          </div>

          <div class="border-t-2 border-blue-400 my-3"></div>

          <div class="flex justify-between">
            <span class="text-base font-bold text-gray-900">รวมทั้งสิ้น</span>
            <span id="total" class="text-2xl font-bold text-primary-600">-</span>
          </div>
        </div>

        <!-- Note -->
        <div class="bg-yellow-50 rounded-lg p-4 border border-yellow-200">
          <p class="text-sm text-gray-700">
            <strong>หมายเหตุ:</strong> ค่าธรรมเนียมข้างต้นเป็นตามอัตรา DBD ปี 2569 อาจมีการเปลี่ยนแปลง
            โปรดตรวจสอบกับ DBD หรือ ทนายความที่ปรึกษาเพื่อยืนยันจำนวนเงินที่แน่นอน
          </p>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ค่าจดทะเบียนบริษัท DBD ประกอบด้วยอะไร?</h2>
      <p>ค่าจดทะเบียนบริษัทตามพระราชกฤษฎีกาว่าด้วยการจดทะเบียนนิติบุคคล ประกอบด้วยสี่ส่วนหลักดังนี้</p>

      <h3>1. ค่าธรรมเนียมการจดทะเบียน DBD</h3>
      <p>เป็นค่าธรรมเนียมหลักที่เรียกเก็บจากสำนักงานพัฒนาธุรกิจกระลาษฎีย์ (DBD) ซึ่งขึ้นอยู่กับจำนวนทุนจดทะเบียน</p>
      <ul>
        <li>ทุน 0-100,000 บาท: 500 บาท</li>
        <li>ทุน 100,001-500,000 บาท: 750 บาท</li>
        <li>ทุน 500,001-1,000,000 บาท: 1,000 บาท</li>
        <li>ทุนสูงกว่า 1,000,000 บาท: คำนวณตามอัตราเพิ่มเติม</li>
      </ul>

      <h3>2. อากรแสตมป์</h3>
      <p>อากรแสตมป์ตามพระราชกฤษฎีกาว่าด้วยอากรแสตมป์ กำหนดตามมูลค่าทุนจดทะเบียน อัตรา 0.5% สำหรับบันทึกการจัดตั้งและเอกสารอื่น</p>

      <h3>3. ค่าธรรมเนียมและค่าใช้จ่ายอื่น</h3>
      <p>รวมถึงค่าธรรมเนียมนายหน้า ค่าสัญญา (ถ้าจ้างทนายความ) และค่าบริการอื่นที่เกี่ยวข้อง</p>

      <h3>4. ภาษีมูลค่าเพิ่ม (VAT)</h3>
      <p>บริการของทนายความและนายหน้าจะเสียภาษีมูลค่าเพิ่มอัตรา 7%</p>
    </section>

    <!-- FAQ Section -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((item) => (
          <div class="border border-gray-200 rounded-lg p-4 hover:border-gray-300 transition-colors">
            <h3 class="font-semibold text-gray-900 mb-2">{item.question}</h3>
            <p class="text-gray-600 text-sm">{item.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Trust Panel -->
    <section class="bg-gray-50 rounded-lg p-4 sm:p-6 mb-8 border border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📌 แหล่งข้อมูลอ้างอิง</h2>
      <ul class="text-sm text-gray-700 space-y-2">
        <li>• สำนักงานพัฒนาธุรกิจกระลาษฎีย์ (DBD) — อัตราค่าธรรมเนียมการจดทะเบียน 2567-2569</li>
        <li>• พระราชกฤษฎีกาว่าด้วยการจดทะเบียนนิติบุคคล พ.ศ. 2534</li>
        <li>• พระราชกฤษฎีกาว่าด้วยอากรแสตมป์ พ.ศ. 2520</li>
        <li>• กรมสรรพากร — ประมวลรายได้และค่าใช้จ่าย</li>
      </ul>
    </section>
  </article>
</BaseLayout>

<script>
  import { calculateCompanyRegistrationCost } from '../../lib/company-registration-cost-calculator';

  const btnCalculate = document.getElementById('btn-calculate');
  const companyTypeSelect = document.getElementById('companyType');
  const capitalInput = document.getElementById('capital');
  const includeNotaryCheckbox = document.getElementById('includeNotary');
  const includeLawyerCheckbox = document.getElementById('includeLawyer');
  const includeSealCheckbox = document.getElementById('includeSeal');
  const resultDiv = document.getElementById('result');

  function formatCurrency(value: number): string {
    return new Intl.NumberFormat('th-TH', {
      style: 'currency',
      currency: 'THB',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(value);
  }

  function handleCalculate() {
    const capitalStr = capitalInput.value.replace(/,/g, '');
    const capital = parseFloat(capitalStr);

    if (!capital || capital <= 0 || isNaN(capital)) {
      alert('โปรดระบุทุนจดทะเบียนที่ถูกต้อง');
      return;
    }

    const result = calculateCompanyRegistrationCost({
      companyType: companyTypeSelect.value as any,
      registeredCapital: capital,
      numberOfPartners: 1,
      includeNotaryFee: includeNotaryCheckbox.checked,
      includeLawyerFee: includeLawyerCheckbox.checked,
      includeSeal: includeSealCheckbox.checked,
    });

    // Update UI
    document.getElementById('fee-dbd').textContent = formatCurrency(result.dbdRegistrationFee);
    document.getElementById('fee-stamp1').textContent = formatCurrency(result.stampDutyMOA);
    document.getElementById('fee-stamp2').textContent = formatCurrency(result.stampDutyAOA);
    document.getElementById('fee-notary').textContent = formatCurrency(result.notaryFee);
    document.getElementById('fee-lawyer').textContent = formatCurrency(result.lawyerFee);
    document.getElementById('fee-seal').textContent = formatCurrency(result.sealCost);
    document.getElementById('subtotal').textContent = formatCurrency(result.subtotal);
    document.getElementById('vat-amount').textContent = formatCurrency(result.vat);
    document.getElementById('total').textContent = formatCurrency(result.total);

    resultDiv.classList.remove('hidden');
  }

  btnCalculate.addEventListener('click', handleCalculate);

  // Allow Enter key to calculate
  capitalInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleCalculate();
  });

  // Format capital input with thousand separators
  capitalInput.addEventListener('blur', () => {
    const value = parseFloat(capitalInput.value.replace(/,/g, ''));
    if (!isNaN(value)) {
      capitalInput.value = value.toLocaleString('th-TH');
    }
  });
</script>
