---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณต้นทุนอาหารสัตว์เลี้ยง 2569 | วัว หมู ไก่ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนอาหารสัตว์เลี้ยง รายเดือน รายปี สำหรับวัว หมู ไก่ พร้อมประมาณการรายได้และกำไร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุนอาหารสัตว์/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนอาหารสัตว์">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "เครื่องคำนวณต้นทุนอาหารสัตว์เลี้ยง",
      "description": "คำนวณต้นทุนอาหารสัตว์เลี้ยง",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "THB"
      },
      "inLanguage": "th"
    }
  </script>

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณต้นทุนอาหารสัตว์เลี้ยง
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2">
      <p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณต้นทุนอาหารสัตว์เลี้ยง วัว หมู ไก่ รายเดือน รายปี สำหรับการวางแผนค่าใช้จ่ายเลี้ยงสัตว์
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div>
          <label for="animalType" class="block text-sm font-medium text-gray-700 mb-1">
            ชนิดสัตว์เลี้ยง
          </label>
          <select id="animalType" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base">
            <option value="cattle">วัว</option>
            <option value="pig">หมู</option>
            <option value="chicken">ไก่</option>
          </select>
        </div>

        <div>
          <label for="numberOfAnimals" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนตัว
          </label>
          <input
            type="text"
            id="numberOfAnimals"
            inputmode="numeric"
            placeholder="เช่น 10"
            value="10"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base"
      >
        คำนวณต้นทุน
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-blue-50 rounded-lg p-3">
            <p class="text-xs text-gray-600">ต้นทุนต่อตัว/วัน</p>
            <p id="daily-cost" class="text-lg font-bold text-gray-900">-</p>
          </div>
          <div class="bg-blue-50 rounded-lg p-3">
            <p class="text-xs text-gray-600">ต้นทุนต่อตัว/เดือน</p>
            <p id="monthly-cost" class="text-lg font-bold text-gray-900">-</p>
          </div>
          <div class="bg-green-50 rounded-lg p-3">
            <p class="text-xs text-gray-600">ต้นทุนรวมทั้งหมด/เดือน</p>
            <p id="total-monthly" class="text-lg font-bold text-green-600">-</p>
          </div>
          <div class="bg-green-50 rounded-lg p-3">
            <p class="text-xs text-gray-600">ต้นทุนรวมต่อปี</p>
            <p id="total-yearly" class="text-lg font-bold text-green-600">-</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ต้นทุนอาหารสัตว์เลี้ยง</h2>

      <p>
        ต้นทุนอาหารสัตว์เป็นส่วนใหญ่ของค่าใช้จ่ายในการเลี้ยงสัตว์ การประมาณการอย่างถูกต้องช่วยให้เกษตรกรสามารถวางแผนทางการเงินได้อย่างมีประสิทธิภาพ
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ต้นทุนอาหารต่างๆ</h3>

      <ul class="list-disc pl-6 text-gray-700">
        <li><strong>วัว:</strong> ประมาณ 120 บาท/วัน (หญ้า + เมล็ด + อาหารเสริม)</li>
        <li><strong>หมู:</strong> ประมาณ 25 บาท/วัน (อาหารครบสูตร)</li>
        <li><strong>ไก่:</strong> ประมาณ 3 บาท/วัน (เมล็ดและอาหารเสริม)</li>
      </ul>
    </section>
  </article>

  <script>
    function formatCurrency(num: number): string {
      return new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(num);
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const animalType = (document.getElementById('animalType') as HTMLSelectElement).value;
      const numberOfAnimals = parseFloat((document.getElementById('numberOfAnimals') as HTMLInputElement).value) || 10;

      const dailyCosts: Record<string, number> = {
        cattle: 120,
        pig: 25,
        chicken: 3,
      };

      const dailyCost = dailyCosts[animalType] || 120;
      const monthlyCost = dailyCost * 30;
      const totalMonthly = monthlyCost * numberOfAnimals;
      const totalYearly = totalMonthly * 12;

      (document.getElementById('daily-cost') as HTMLElement).textContent = formatCurrency(dailyCost);
      (document.getElementById('monthly-cost') as HTMLElement).textContent = formatCurrency(monthlyCost);
      (document.getElementById('total-monthly') as HTMLElement).textContent = formatCurrency(totalMonthly);
      (document.getElementById('total-yearly') as HTMLElement).textContent = formatCurrency(totalYearly);

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('livestock-feed');
    });

    // Auto-calculate
    document.getElementById('btn-calculate')!.click();
  </script>
</BaseLayout>
