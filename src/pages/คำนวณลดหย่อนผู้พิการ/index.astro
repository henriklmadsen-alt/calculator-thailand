---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณลดหย่อนผู้พิการ/ทุพพลภาพ 2569 | 60,000 บาทต่อคน | Kamnuanlek';
const pageDescription = 'คำนวณค่าลดหย่อนผู้พิการหรือทุพพลภาพ 2569 ฟรี ลดหย่อนได้ 60,000 บาทต่อคน เช็กเงื่อนไขและจำนวนเงินที่ประหยัดได้ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณลดหย่อนผู้พิการ/`;

const faqData = [
  {
    question: 'ลดหย่อนผู้พิการได้คนละเท่าไร?',
    answer: 'ลดหย่อนได้ 60,000 บาทต่อคน สำหรับผู้พิการหรือทุพพลภาพที่อยู่ในความอุปการะ',
  },
  {
    question: 'ผู้พิการในที่นี้หมายถึงใคร?',
    answer: 'หมายถึงบุคคลที่มีบัตรประจำตัวคนพิการตามกฎหมาย หรือบุคคลทุพพลภาพที่มีรายได้ไม่เกิน 30,000 บาทต่อปี',
  },
  {
    question: 'สามารถลดหย่อนผู้พิการที่เป็นตัวเองได้ไหม?',
    answer: 'ได้ หากผู้มีเงินได้เองเป็นผู้พิการ สามารถนำมาลดหย่อนเพิ่มเติมจากค่าลดหย่อนส่วนตัว 60,000 บาทได้อีก 60,000 บาท',
  },
  {
    question: 'ลดหย่อนผู้พิการซ้ำกับค่าลดหย่อนบุตรหรือบิดามารดาได้ไหม?',
    answer: 'ได้ หากผู้พิการคือบุตรหรือบิดามารดา สามารถใช้ทั้งค่าลดหย่อนบุตร/บิดามารดา และค่าลดหย่อนผู้พิการพร้อมกันได้',
  },
  {
    question: 'ต้องมีเอกสารอะไรบ้าง?',
    answer: 'ต้องมีบัตรประจำตัวคนพิการ และหนังสือรับรองการเป็นผู้อุปการะจากกรมส่งเสริมและพัฒนาคุณภาพชีวิตคนพิการ หรือสำเนาบัตรประจำตัวคนพิการ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณลดหย่อนผู้พิการ/ทุพพลภาพ 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณลดหย่อนผู้พิการ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณลดหย่อนผู้พิการ/ทุพพลภาพ ปี 2569 (2026)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าลดหย่อนผู้พิการหรือทุพพลภาพตามเกณฑ์กรมสรรพากร ลดหย่อนได้ 60,000 บาทต่อคน
      สำหรับผู้พิการหรือทุพพลภาพที่อยู่ในความอุปการะ
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกจำนวนผู้พิการ/ทุพพลภาพในความอุปการะ</h2>

      <form id="disability-form" class="space-y-6">
        <div>
          <label for="disability-count" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนผู้พิการ/ทุพพลภาพที่อุปการะ (คน)
          </label>
          <input
            type="number"
            id="disability-count"
            min="0"
            max="20"
            value="1"
            class="w-32 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base text-center"
          />
          <p class="mt-1 text-xs text-gray-500">ลดหย่อนได้ 60,000 บาทต่อคน ไม่จำกัดจำนวน</p>
        </div>

        <div>
          <label for="marginal-rate" class="block text-sm font-medium text-gray-700 mb-1">
            ฐานภาษีของคุณ (%) — สำหรับประมาณภาษีที่ประหยัดได้
          </label>
          <select
            id="marginal-rate"
            class="w-48 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
          >
            <option value="0.05">5%</option>
            <option value="0.10">10%</option>
            <option value="0.15">15%</option>
            <option value="0.20" selected>20%</option>
            <option value="0.25">25%</option>
            <option value="0.30">30%</option>
            <option value="0.35">35%</option>
          </select>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณลดหย่อนผู้พิการ</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">จำนวนผู้พิการ</div>
            <div id="result-count" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าลดหย่อนรวม</div>
            <div id="result-total" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประหยัดภาษีโดยประมาณ</div>
            <div id="result-tax-saved" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <p id="result-note" class="text-xs text-gray-500 mt-2"></p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ค่าลดหย่อนผู้พิการ/ทุพพลภาพ 2569</h2>
      <p>
        ผู้มีเงินได้สามารถนำค่าอุปการะเลี้ยงดูผู้พิการหรือทุพพลภาพมาหักลดหย่อนได้
        60,000 บาทต่อคน โดยไม่จำกัดจำนวน (ขึ้นอยู่กับจำนวนคนที่อุปการะจริง)
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เงื่อนไขการลดหย่อน</h3>
      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li>ผู้พิการต้องมีบัตรประจำตัวคนพิการตามกฎหมาย <strong>หรือ</strong> เป็นบุคคลทุพพลภาพ</li>
        <li>ผู้พิการต้องมีรายได้ <strong>ไม่เกิน 30,000 บาทต่อปี</strong></li>
        <li>ต้องมีหนังสือรับรองการอุปการะจากหน่วยงานที่เกี่ยวข้อง</li>
        <li>สามารถใช้ร่วมกับค่าลดหย่อนบุตร บิดามารดา ในกรณีที่ผู้พิการคือบุคคลในครอบครัว</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณลดหย่อนผู้พิการ/" />
    <RelatedCalculators currentHref="/คำนวณลดหย่อนผู้พิการ/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางภาษีหรือกฎหมาย กรุณาปรึกษาผู้เชี่ยวชาญด้านภาษีสำหรับกรณีเฉพาะ
    </div>
  </article>

  <script>
    function formatThai(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(num);
    }

    const form = document.getElementById('disability-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const count = parseInt((document.getElementById('disability-count') as HTMLInputElement).value) || 0;
      const rate = parseFloat((document.getElementById('marginal-rate') as HTMLSelectElement).value);
      const total = count * 60_000;
      const taxSaved = total * rate;

      (document.getElementById('result-count') as HTMLElement).textContent = `${count} คน`;
      (document.getElementById('result-total') as HTMLElement).textContent = `${formatThai(total)} บาท`;
      (document.getElementById('result-tax-saved') as HTMLElement).textContent = `~${formatThai(taxSaved)} บาท`;
      (document.getElementById('result-note') as HTMLElement).textContent =
        `*คำนวณที่อัตราภาษีขั้นบันได ${(rate * 100).toFixed(0)}% ที่คุณเลือก จริงขึ้นอยู่กับรายได้สุทธิรวมทั้งปี`;

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('disability_allowance');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('disability_allowance');
    });

    form.addEventListener('input', () => {
      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('disability_allowance');
    }, { once: true });
  </script>
</BaseLayout>
