---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณงบแลกเงินเดินทาง ปี 2569 — Currency Trip Budget | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณงบเดินทางต่างประเทศหลังแลกเงิน ป้อนงบประมาณบาท อัตราแลกเปลี่ยนและค่าธรรมเนียม ทราบเงินต่างประเทศที่ได้รับและแผนการใช้จ่าย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบแลกเงินเดินทาง/`;

const faqData = [
  {
    question: 'ควรแลกเงินที่ไหนได้อัตราดีที่สุด?',
    answer: 'ร้านแลกเงินที่สนามบินมักมีอัตราแย่กว่า ควรแลกที่ร้านแลกเงินในเมืองเช่น SuperRich หรือ Vasu เพราะมักให้อัตราดีกว่าธนาคาร 0.5–1%',
  },
  {
    question: 'ควรแลกเงินก่อนเดินทางหรือแลกที่ปลายทาง?',
    answer: 'ขึ้นอยู่กับประเทศ บางประเทศเช่น ญี่ปุ่น ยุโรป อัตราที่ไทยดีกว่า บางประเทศเช่น เวียดนาม กัมพูชา ควรแลกที่นั่น ควรเปรียบเทียบอัตราก่อนตัดสินใจ',
  },
  {
    question: 'ควรพกเงินสดเท่าไหร่?',
    answer: 'แนะนำพกเงินสด 30–50% ของงบประมาณ ส่วนที่เหลือใช้บัตรเดบิต/เครดิต หรือถอนเงินต่างประเทศผ่านตู้ ATM ซึ่งมักได้อัตราดีกว่าการแลกเงิน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบแลกเงินเดินทาง',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบแลกเงินเดินทาง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณงบแลกเงินเดินทาง — Currency Trip Budget</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: เงินต่างประเทศ = (งบบาท − ค่าธรรมเนียม) ÷ อัตราแลก</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณงบแลกเงินเดินทาง ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนงบประมาณบาท อัตราแลกเปลี่ยน และค่าธรรมเนียม เพื่อวางแผนงบเดินทางต่างประเทศ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="tb-form" class="space-y-5">
        <p id="tb-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="tb-budget" class="mb-1 block text-sm font-medium text-gray-700">งบประมาณ (บาท)</label>
            <input type="text" id="tb-budget" inputmode="numeric" placeholder="เช่น 50,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="tb-budget-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="tb-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราแลกเปลี่ยน (บาท/1 หน่วยต่างประเทศ)</label>
            <input type="text" id="tb-rate" inputmode="decimal" placeholder="เช่น 34.50 (USD)"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="tb-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="tb-fee" class="mb-1 block text-sm font-medium text-gray-700">ค่าธรรมเนียมแลกเงิน (บาท) — ไม่บังคับ</label>
            <input type="text" id="tb-fee" inputmode="numeric" placeholder="เช่น 0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="tb-days" class="mb-1 block text-sm font-medium text-gray-700">จำนวนวันเดินทาง — ไม่บังคับ</label>
            <input type="number" id="tb-days" min="1" max="365" placeholder="เช่น 7"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div>
          <label for="tb-currency" class="mb-1 block text-sm font-medium text-gray-700">สกุลเงินปลายทาง</label>
          <input type="text" id="tb-currency" placeholder="เช่น USD, JPY, EUR"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          <p class="mt-1 text-xs text-gray-500">ใช้แสดงในผลลัพธ์เท่านั้น</p>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณงบแลกเงิน
        </button>
      </form>
    </div>

    <div id="tb-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินต่างประเทศที่ได้</div>
            <div id="res-tb-foreign" class="text-2xl font-bold text-sky-700">-</div>
          </div>
          <div id="tb-daily-box" class="hidden rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">งบต่อวัน</div>
            <div id="res-tb-daily" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">งบบาทสุทธิ</div>
            <div id="res-tb-net-thb" class="text-xl font-bold text-blue-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>งบบาทสุทธิ = งบประมาณ − ค่าธรรมเนียม</li>
        <li>เงินต่างประเทศ = งบบาทสุทธิ ÷ อัตราแลกเปลี่ยน</li>
        <li>งบต่อวัน = เงินต่างประเทศ ÷ จำนวนวัน</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณเปรียบเทียบร้านแลกเงิน/">เปรียบเทียบร้านแลกเงิน</a></li>
        <li><a href="/คำนวณงบเดินทางท่องเที่ยว/">คำนวณงบเดินทางท่องเที่ยว</a></li>
        <li><a href="/คำนวณ-wire-transfer/">เปรียบเทียบ Wire Transfer</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#tb-results" />
    <RelatedArticles currentHref="/คำนวณงบแลกเงินเดินทาง/" />
    <RelatedCalculators currentHref="/คำนวณงบแลกเงินเดินทาง/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> อัตราแลกเปลี่ยนเปลี่ยนแปลงทุกวัน ควรตรวจสอบอัตราจริงก่อนแลกเงิน
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n, decimals = 2) {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: decimals, maximumFractionDigits: decimals }).format(n);
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('tb-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      ['tb-budget-error','tb-rate-error'].forEach(id => setErr(id, ''));

      const budget = parseNum(document.getElementById('tb-budget').value);
      const rate = parseNum(document.getElementById('tb-rate').value);
      const fee = parseNum(document.getElementById('tb-fee').value) || 0;
      const days = parseInt(document.getElementById('tb-days').value);
      const currency = document.getElementById('tb-currency').value.trim() || 'หน่วย';

      let hasError = false;
      if (!Number.isFinite(budget) || budget <= 0) { setErr('tb-budget-error', 'กรอกงบประมาณมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(rate) || rate <= 0) { setErr('tb-rate-error', 'กรอกอัตราแลกเปลี่ยนมากกว่า 0'); hasError = true; }
      if (hasError) { document.getElementById('tb-error').classList.remove('hidden'); document.getElementById('tb-results').classList.add('hidden'); return; }
      document.getElementById('tb-error').classList.add('hidden');

      const netThb = budget - fee;
      const foreign = netThb / rate;

      setText('res-tb-foreign', `${fmt(foreign, 2)} ${currency}`);
      setText('res-tb-net-thb', `${fmt(netThb, 2)} บาท`);

      const dailyBox = document.getElementById('tb-daily-box');
      if (days && days > 0) {
        setText('res-tb-daily', `${fmt(foreign / days, 2)} ${currency}`);
        dailyBox.classList.remove('hidden');
      } else {
        dailyBox.classList.add('hidden');
      }

      document.getElementById('tb-results').classList.remove('hidden');
      document.getElementById('tb-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
