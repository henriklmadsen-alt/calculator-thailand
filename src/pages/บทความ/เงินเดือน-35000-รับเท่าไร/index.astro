---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'เงินเดือน 35,000 บาท รับเงินเดือนจริงเท่าไร หักทุกอย่างแล้ว | Kamnuanlek';
const description = 'คำนวณเงินเดือนสุทธิจากเงินเดือน 35,000 บาท หักประกันสังคม ภาษี กองทุนสำรองเลี้ยงชีพ เปรียบเทียบหลายกรณีและวิธีเพิ่มเงินสุทธิ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/เงินเดือน-35000-รับเท่าไร/`;

const faqData = [
  {
    question: 'เงินเดือน 35,000 บาท รับสุทธิเท่าไรหลังหักประกันสังคมและภาษี?',
    answer: 'ตัวอย่างคนโสด ไม่สมัครกองทุนสำรองเลี้ยงชีพ จะหักประกันสังคม 1,050 บาท และภาษีประมาณ 823 บาท เหลือเงินสุทธิประมาณ 33,127 บาทต่อเดือน',
  },
  {
    question: 'เงินเดือน 35,000 บาท ต้องเสียภาษีเดือนละเท่าไร?',
    answer: 'โดยประมาณราว 823 บาทต่อเดือนสำหรับกรณีคนโสดที่มีค่าลดหย่อนพื้นฐานและประกันสังคมเท่านั้น ยอดจริงจะเปลี่ยนตามสถานะสมรสและค่าลดหย่อนที่ใช้',
  },
  {
    question: 'เงินเดือน 35,000 บาท ถ้าสมัครกองทุนสำรองเลี้ยงชีพจะเหลือเท่าไร?',
    answer: 'หากสะสมกองทุน 3% จะถูกหักเพิ่ม 1,050 บาท จากสุทธิกรณีพื้นฐานประมาณ 33,127 บาท ทำให้เหลือรับจริงประมาณ 32,077 บาทต่อเดือน',
  },
  {
    question: 'เงินเดือน 35,000 บาท ลดภาษีอย่างไรให้เงินสุทธิเพิ่มขึ้น?',
    answer: 'แนวทางหลักคือใช้สิทธิลดหย่อนให้ครบ เช่น คู่สมรส บิดามารดา ประกันชีวิต และกองทุนที่เข้าเงื่อนไขสรรพากร เพื่อลดภาษีหัก ณ ที่จ่ายและเพิ่มเงินรับสุทธิรายเดือน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    เงินเดือน 35,000 บาท รับเงินเดือนจริงเท่าไร หักทุกอย่างแล้ว
  </h1>

  <p>
    พนักงานที่ได้เงินเดือน 35,000 บาท/เดือนต้องการรู้ว่า "สุดท้ายจะได้เงินจริงเท่าไร" บทความนี้สาธิตการคำนวณโดยละเอียด แบ่งตัวอย่างตามสถานการณ์ต่างๆ
  </p>

  <section id="net-salary-35000-article-intent-cluster" class="my-6 rounded-xl border border-blue-100 bg-blue-50/60 p-4">
    <h2 class="m-0 text-lg font-semibold text-blue-900">คำนวณเงินเดือนสุทธิ 35,000 บาทให้ชัดก่อนวางแผนใช้เงิน</h2>
    <p class="mt-2 text-sm leading-7 text-blue-900">
      ใช้ลิงก์ลัดเพื่อคำนวณเงินเดือนสุทธิแบบทันที และดูแนวทางหักประกันสังคมกับภาษีแบบละเอียดสำหรับปี 2569
    </p>
    <ul class="mt-3 space-y-2">
      <li><a href="/คำนวณเงินเดือนสุทธิ/" class="font-medium text-blue-800 underline decoration-blue-300 underline-offset-2">คำนวณเงินเดือนสุทธิ</a></li>
      <li><a href="/บทความ/เงินเดือนสุทธิ-2569-คำนวณหัก-ประกันสังคม-ภาษี/" class="font-medium text-blue-800 underline decoration-blue-300 underline-offset-2">เงินเดือนสุทธิ 2569 คำนวณหักประกันสังคมและภาษี</a></li>
    </ul>
  </section>

  <ArticleCalculatorCTA
    title="คำนวณเงินเดือนสุทธิ"
    description="ใส่เงินเดือนของคุณ คำนวณเงินที่ได้รับจริงทันที"
    href="/คำนวณเงินเดือนสุทธิ/"
    buttonLabel="คำนวณเงินสุทธิฟรี"
  />

  <h2>ตัวอย่าง 1: พนักงาน 35,000 บาท กรุงเทพฯ คนเดี่ยว</h2>

  <ol>
    <li>เงินเดือนรวม: 35,000 บาท</li>
    <li>หักประกันสังคม (3%): 1,050 บาท</li>
    <li>หักภาษีเงินได้: ≈ 823 บาท/เดือน
      <ul>
        <li>รายได้ต่อปี: 420,000 บาท</li>
        <li>หักลดหย่อนพื้นฐาน: 60,000 บาท</li>
        <li>ภาษีรวมต่อปี: 9,870 บาท → 823 บาท/เดือน</li>
      </ul>
    </li>
    <li><strong>เงินเดือนสุทธิ = 33,127 บาท</strong></li>
  </ol>

  <h2>ตัวอย่าง 2: สมัครใจกองทุน 3%</h2>

  <p>หากเลือกเข้าร่วมกองทุนสำรองเลี้ยงชีพ:</p>
  <ul>
    <li>หักกองทุน: 35,000 × 3% = 1,050 บาท</li>
    <li><strong>เงินเดือนสุทธิ = 32,077 บาท</strong></li>
  </ul>

  <h2>เปรียบเทียบเงินจริงตามสถานการณ์</h2>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">สถานการณ์</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">SSO</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">ภาษี</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">สุทธิ</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">กรุงเทพฯ คนเดี่ยว ไม่กองทุน</td><td class="border border-gray-200 px-3 py-2 text-right">1,050</td><td class="border border-gray-200 px-3 py-2 text-right">823</td><td class="border border-gray-200 px-3 py-2 text-right font-semibold">33,127</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">กรุงเทพฯ คนเดี่ยว มีกองทุน 3%</td><td class="border border-gray-200 px-3 py-2 text-right">1,050</td><td class="border border-gray-200 px-3 py-2 text-right">823</td><td class="border border-gray-200 px-3 py-2 text-right">32,077</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">กรุงเทพฯ สมรส ไม่กองทุน</td><td class="border border-gray-200 px-3 py-2 text-right">1,050</td><td class="border border-gray-200 px-3 py-2 text-right">400</td><td class="border border-gray-200 px-3 py-2 text-right">33,550</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">ต่างจังหวัด คนเดี่ยว ไม่กองทุน</td><td class="border border-gray-200 px-3 py-2 text-right">1,050</td><td class="border border-gray-200 px-3 py-2 text-right">500</td><td class="border border-gray-200 px-3 py-2 text-right">33,450</td></tr>
      </tbody>
    </table>
  </div>

  <h2>วิธีเพิ่มเงินเดือนสุทธิ</h2>

  <ol>
    <li><strong>จดทะเบียนสมรส</strong> — ลดหย่อนเพิ่มขึ้น ภาษีลดลงประมาณ 400-500 บาท/เดือน</li>
    <li><strong>เลี้ยงบิดามารดา</strong> — ลดหย่อนเพิ่ม 30,000 บาทต่อคน</li>
    <li><strong>ซื้อประกันชีวิต</strong> — หักลดหย่อนได้สูงสุด 100,000 บาท</li>
  </ol>

  <h2>แผนการใช้เงิน 33,127 บาท</h2>

  <ul>
    <li>ที่อยู่อาศัย: 10,000 บาท (30%)</li>
    <li>อาหาร/ของใช้: 8,000 บาท (24%)</li>
    <li>คมนาคม/สาธารณูปโภค: 3,000 บาท (9%)</li>
    <li>ประกัน/สุขภาพ: 1,500 บาท (5%)</li>
    <li>ออมและลงทุน: 5,000 บาท (15%)</li>
    <li>สนุกสนาน/เสื้อผ้า: 3,000 บาท (9%)</li>
    <li>สำรอง: 2,627 บาท (8%)</li>
  </ul>

  <ArticleCalculatorCTA
    title="คำนวณเงินเดือนสุทธิของคุณ"
    description="ปรับตามสถานการณ์จริง ดูเงินที่ได้รับทันที"
    href="/คำนวณเงินเดือนสุทธิ/"
    buttonLabel="คำนวณตอนนี้"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
