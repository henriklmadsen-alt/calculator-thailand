---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'ค่าไฟฟ้า MEA กับ PEA ต่างกันอย่างไร คำนวณอย่างไร 2569 | เครื่องคำนวณไทย';
const description = 'อธิบายความแตกต่างระหว่าง MEA และ PEA อัตราค่าไฟฟ้าแบบขั้นบันได ค่า Ft 2569 และวิธีคำนวณค่าไฟบ้านพร้อมตัวอย่าง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ค่าไฟฟ้า-mea-กับ-pea/`;

const faqData = [
  {
    question: 'MEA และ PEA ต่างกันอย่างไร?',
    answer: 'MEA (การไฟฟ้านครหลวง) ให้บริการกรุงเทพฯ นนทบุรี และสมุทรปราการ PEA (การไฟฟ้าส่วนภูมิภาค) ให้บริการ 74 จังหวัดที่เหลือ โครงสร้างอัตราค่าไฟคล้ายกัน แต่บางรายละเอียดอาจต่างกันเล็กน้อย',
  },
  {
    question: 'ค่า Ft คืออะไรและเปลี่ยนเมื่อไหร่?',
    answer: 'ค่า Ft (Fuel Adjustment Charge) คือค่าไฟฟ้าผันแปรตามต้นทุนเชื้อเพลิงและพลังงาน ปรับทุก 4 เดือน ปี 2569 รอบ ม.ค.–เม.ย. = 0.0972 บาท/หน่วย และ พ.ค.–ส.ค. = 0.1623 บาท/หน่วย',
  },
  {
    question: 'ค่าไฟแบบขั้นบันไดคืออะไร?',
    answer: 'ยิ่งใช้ไฟมาก อัตราต่อหน่วยยิ่งแพง เช่น 150 หน่วยแรกอัตราหนึ่ง ส่วนที่เกิน 150 หน่วยจะแพงขึ้น ทำให้คนที่ใช้น้อยจ่ายถูกกว่าสัดส่วน',
  },
  {
    question: 'ทำไมค่าไฟเดือนนี้แพงขึ้นทั้งที่ใช้เท่าเดิม?',
    answer: 'อาจเกิดจากค่า Ft ที่ปรับขึ้น, รอบบิลมีวันมากกว่าปกติ, หรือใช้ไฟข้ามช่วงอัตราขั้นบันได ควรตรวจสอบรอบประกาศ Ft และเทียบจำนวนหน่วยที่ใช้จริง',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  modifiedDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    ค่าไฟฟ้า MEA กับ PEA ต่างกันอย่างไร คำนวณอย่างไร 2569
  </h1>

  <p>
    คนไทยจ่ายค่าไฟฟ้าให้กับสองหน่วยงานหลักคือ <strong>MEA (การไฟฟ้านครหลวง)</strong>
    สำหรับกรุงเทพฯ และปริมณฑล และ <strong>PEA (การไฟฟ้าส่วนภูมิภาค)</strong> สำหรับต่างจังหวัด
    ทั้งสองมีโครงสร้างอัตราค่าไฟคล้ายกัน แต่มีความแตกต่างในรายละเอียดที่ควรรู้
    ใช้ <a href="/คำนวณค่าไฟฟ้า/">เครื่องคำนวณค่าไฟฟ้า</a> ของเราเพื่อคำนวณบิลของคุณได้ทันที
  </p>

  <ArticleCalculatorCTA
    title="คำนวณค่าไฟฟ้าบ้านของคุณ"
    description="ใส่จำนวนหน่วยไฟและเลือกรอบ Ft เพื่อดูยอดประมาณการรวม VAT"
    href="/คำนวณค่าไฟฟ้า/"
    buttonLabel="คำนวณค่าไฟฟ้าตอนนี้"
  />

  <h2>MEA และ PEA คืออะไร ให้บริการพื้นที่ไหน</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">หน่วยงาน</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ชื่อเต็ม</th>
          <th class="border border-gray-200 px-3 py-2 text-left">พื้นที่ให้บริการ</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">MEA</td><td class="border border-gray-200 px-3 py-2">การไฟฟ้านครหลวง</td><td class="border border-gray-200 px-3 py-2">กรุงเทพฯ นนทบุรี สมุทรปราการ</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">PEA</td><td class="border border-gray-200 px-3 py-2">การไฟฟ้าส่วนภูมิภาค</td><td class="border border-gray-200 px-3 py-2">74 จังหวัดที่เหลือทั่วประเทศ</td></tr>
      </tbody>
    </table>
  </div>

  <h2>โครงสร้างอัตราค่าไฟฟ้าบ้านอยู่อาศัย</h2>

  <p>
    ทั้ง MEA และ PEA ใช้โครงสร้างอัตราขั้นบันไดสำหรับบ้านอยู่อาศัยประเภทที่ 1 คล้ายกัน
    ยิ่งใช้ไฟมากขึ้น อัตราต่อหน่วยในแต่ละช่วงก็สูงขึ้น:
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ช่วงหน่วย</th>
          <th class="border border-gray-200 px-3 py-2 text-left">อัตรา (บาท/หน่วย)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">1–15 หน่วย</td><td class="border border-gray-200 px-3 py-2">2.3488</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">16–25 หน่วย</td><td class="border border-gray-200 px-3 py-2">2.9882</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">26–35 หน่วย</td><td class="border border-gray-200 px-3 py-2">3.2405</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">36–100 หน่วย</td><td class="border border-gray-200 px-3 py-2">3.6237</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">101–150 หน่วย</td><td class="border border-gray-200 px-3 py-2">3.7171</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">151–400 หน่วย</td><td class="border border-gray-200 px-3 py-2">4.2218</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">401 หน่วยขึ้นไป</td><td class="border border-gray-200 px-3 py-2">4.4217</td></tr>
      </tbody>
    </table>
  </div>

  <h2>ค่า Ft คืออะไร และมีผลอย่างไร</h2>

  <p>
    ค่า Ft (Fuel Adjustment Charge) คือค่าไฟฟ้าผันแปรที่ปรับตามต้นทุนเชื้อเพลิงและพลังงาน
    ประกาศทุก 4 เดือน สำหรับปี 2569:
  </p>

  <ul>
    <li><strong>ม.ค.–เม.ย. 2569:</strong> 0.0972 บาท/หน่วย</li>
    <li><strong>พ.ค.–ส.ค. 2569:</strong> 0.1623 บาท/หน่วย</li>
  </ul>

  <p>
    ค่า Ft บวกเข้ากับทุกหน่วยไฟที่ใช้ ดังนั้นถ้า Ft ปรับขึ้น บิลจะแพงขึ้นแม้ใช้ไฟเท่าเดิม
  </p>

  <h2>สูตรคำนวณค่าไฟฟ้าแบบสมบูรณ์</h2>

  <ol>
    <li>คำนวณค่าไฟฐานตามช่วงขั้นบันได</li>
    <li>บวกค่าบริการรายเดือน (ไม่เกิน 150 หน่วย: 8.19 บาท / เกิน 150 หน่วย: 24.62 บาท)</li>
    <li>บวกค่า Ft = หน่วยไฟ × อัตรา Ft รอบนั้น</li>
    <li>รวมทั้งหมด แล้วคูณ 1.07 สำหรับ VAT 7%</li>
  </ol>

  <ArticleCalculatorCTA
    title="ลองคำนวณค่าไฟของคุณทันที"
    description="ใส่หน่วยไฟและรอบ Ft เพื่อดูยอดสุทธิรวม VAT"
    href="/คำนวณค่าไฟฟ้า/"
    buttonLabel="คำนวณค่าไฟฟ้า MEA/PEA"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณค่าไฟฟ้า/">คำนวณค่าไฟฟ้า</a> สำหรับคำนวณบิลค่าไฟฟ้าบ้าน</li>
    <li><a href="/คำนวณค่าน้ำ/">คำนวณค่าน้ำ</a> สำหรับคำนวณค่าน้ำประปา</li>
    <li><a href="/คำนวณภาษีมูลค่าเพิ่ม/">คำนวณภาษีมูลค่าเพิ่ม</a> สำหรับเช็ก VAT 7%</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/บ้านใช้ไฟ-300-หน่วย-ค่าไฟเท่าไร/">บ้านใช้ไฟ 300 หน่วย ค่าไฟฟ้าเดือนนี้เท่าไร พร้อม Ft ปี 2569</a></li>
    <li><a href="/บทความ/คำนวณค่าไฟฟ้า-2569-สูตร-pea-mea/">คำนวณค่าไฟฟ้า 2569 สูตร PEA/MEA + ค่า Ft</a></li>
  </ul>

  <h2>แหล่งอ้างอิง</h2>
  <ul>
    <li><a href="https://www.mea.or.th" target="_blank" rel="noopener noreferrer">การไฟฟ้านครหลวง (MEA)</a></li>
    <li><a href="https://www.pea.co.th" target="_blank" rel="noopener noreferrer">การไฟฟ้าส่วนภูมิภาค (PEA)</a></li>
  </ul>
</BlogPostLayout>
