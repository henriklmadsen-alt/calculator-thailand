---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'ฝาก 100,000 บาท 1 ปี ได้ดอกเบี้ยเท่าไร หลังหักภาษี 15% | Kamnuanlek';
const description = 'คำนวณดอกเบี้ยจากการฝาก 100,000 บาท 1 ปี เปรียบเทียบบัญชีออมทรัพย์ ฝากประจำ 6 เดือน และ 1 ปี พร้อมยอดสุทธิหลังหักภาษี 15%';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ฝาก-100000-บาท-ได้ดอกเบี้ยเท่าไร/`;

const faqData = [
  {
    question: 'ฝาก 100,000 บาทในออมทรัพย์ได้ดอกเบี้ยเท่าไรต่อปี?',
    answer: 'ที่อัตรา 1%/ปี ได้ดอกเบี้ย 1,000 บาท หลังหักภาษี 15% เหลือ 850 บาท รวมเงินทั้งหมด 100,850 บาทหลัง 1 ปี',
  },
  {
    question: 'ฝากประจำ 1 ปีที่ 100,000 บาทได้ดอกเบี้ยเท่าไร?',
    answer: 'ที่อัตรา 2.75%/ปี ได้ดอกเบี้ย 2,750 บาท หลังหักภาษี 15% เหลือ 2,337.50 บาท รวมเงินทั้งหมด 102,337.50 บาท',
  },
  {
    question: 'ดอกเบี้ยเงินฝากถูกหักภาษีอัตราไหน?',
    answer: 'ดอกเบี้ยเงินฝากธนาคารถูกหักภาษี ณ ที่จ่าย 15% โดยอัตโนมัติก่อนโอนเข้าบัญชี ไม่ต้องยื่นเพิ่มเติม หรือเลือกรวมคำนวณในภาษีประจำปีได้',
  },
  {
    question: 'ควรฝาก 100,000 บาทในธนาคารเล็กหรือใหญ่?',
    answer: 'ธนาคารเล็กมักให้ดอกเบี้ยสูงกว่า แต่ควรตรวจสอบว่าอยู่ภายใต้การคุ้มครองของสถาบันคุ้มครองเงินฝาก (CDIC) ซึ่งคุ้มครองวงเงินไม่เกิน 1 ล้านบาทต่อสถาบัน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  modifiedDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    ฝาก 100,000 บาท 1 ปี ได้ดอกเบี้ยเท่าไร หลังหักภาษี 15%
  </h1>

  <p>
    มีเงิน 100,000 บาทและอยากให้เงินทำงานแทนคุณ คำถามคือ: ควรฝากประเภทไหนเพื่อให้ได้ดอกเบี้ยมากที่สุด
    และจะได้รับเงินจริงเท่าไรหลังหักภาษี 15%
    ใช้ <a href="/คำนวณดอกเบี้ยเงินฝาก/">เครื่องคำนวณดอกเบี้ยเงินฝาก</a> ของเราเพื่อดูตัวเลขที่แม่นยำสำหรับกรณีของคุณ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณดอกเบี้ยเงิน 100,000 บาทของคุณ"
    description="ใส่จำนวนเงิน ระยะเวลา และอัตราดอกเบี้ย แล้วดูยอดสุทธิหลังหักภาษี"
    href="/คำนวณดอกเบี้ยเงินฝาก/"
    buttonLabel="คำนวณดอกเบี้ยเงินฝาก"
  />

  <h2>สถานการณ์ที่ 1: บัญชีออมทรัพย์ (อัตรา 1%)</h2>

  <p>
    บัญชีออมทรัพย์ถอนได้ทุกเมื่อ แต่ดอกเบี้ยต่ำ ที่อัตรา 1%/ปี กับเงิน 100,000 บาท:
  </p>

  <ul>
    <li>ดอกเบี้ยก่อนหักภาษี = 100,000 × 1% = <strong>1,000 บาท</strong></li>
    <li>ภาษีหัก ณ ที่จ่าย 15% = 1,000 × 15% = 150 บาท</li>
    <li>ดอกเบี้ยสุทธิ = <strong>850 บาท</strong></li>
    <li>เงินรวมหลัง 1 ปี = <strong>100,850 บาท</strong></li>
  </ul>

  <h2>สถานการณ์ที่ 2: เงินฝากประจำ 6 เดือน (อัตรา 2.25%)</h2>

  <p>
    ฝากสองรอบ (6 เดือน × 2) ดอกเบี้ยรวมต่อปี:
  </p>

  <ul>
    <li>ดอกเบี้ยก่อนหักภาษี = 100,000 × 2.25% = <strong>2,250 บาท</strong></li>
    <li>ภาษีหัก ณ ที่จ่าย 15% = 2,250 × 15% = 337.50 บาท</li>
    <li>ดอกเบี้ยสุทธิ = <strong>1,912.50 บาท</strong></li>
    <li>เงินรวมหลัง 1 ปี = <strong>101,912.50 บาท</strong></li>
  </ul>

  <h2>สถานการณ์ที่ 3: เงินฝากประจำ 1 ปี (อัตรา 2.75%)</h2>

  <p>
    ดอกเบี้ยสูงที่สุด แต่ต้องรอครบ 1 ปี:
  </p>

  <ul>
    <li>ดอกเบี้ยก่อนหักภาษี = 100,000 × 2.75% = <strong>2,750 บาท</strong></li>
    <li>ภาษีหัก ณ ที่จ่าย 15% = 2,750 × 15% = 412.50 บาท</li>
    <li>ดอกเบี้ยสุทธิ = <strong>2,337.50 บาท</strong></li>
    <li>เงินรวมหลัง 1 ปี = <strong>102,337.50 บาท</strong></li>
  </ul>

  <h2>เปรียบเทียบทุกกรณี</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[600px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ประเภทบัญชี</th>
          <th class="border border-gray-200 px-3 py-2 text-left">อัตราดอกเบี้ย</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ดอกเบี้ยก่อนภาษี</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ดอกเบี้ยสุทธิ (หลังหัก 15%)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">เงินรวม</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">ออมทรัพย์</td><td class="border border-gray-200 px-3 py-2">1.00%</td><td class="border border-gray-200 px-3 py-2">1,000 บาท</td><td class="border border-gray-200 px-3 py-2">850 บาท</td><td class="border border-gray-200 px-3 py-2">100,850 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ฝากประจำ 6 เดือน</td><td class="border border-gray-200 px-3 py-2">2.25%</td><td class="border border-gray-200 px-3 py-2">2,250 บาท</td><td class="border border-gray-200 px-3 py-2">1,912.50 บาท</td><td class="border border-gray-200 px-3 py-2">101,912.50 บาท</td></tr>
        <tr class="bg-green-50"><td class="border border-gray-200 px-3 py-2"><strong>ฝากประจำ 1 ปี</strong></td><td class="border border-gray-200 px-3 py-2"><strong>2.75%</strong></td><td class="border border-gray-200 px-3 py-2"><strong>2,750 บาท</strong></td><td class="border border-gray-200 px-3 py-2"><strong>2,337.50 บาท</strong></td><td class="border border-gray-200 px-3 py-2"><strong>102,337.50 บาท</strong></td></tr>
      </tbody>
    </table>
  </div>

  <h2>เคล็ดลับเพิ่มดอกเบี้ย</h2>

  <ul>
    <li><strong>เปรียบเทียบธนาคาร:</strong> ธนาคารเล็กและฟินเทคบางแห่งให้อัตราสูงกว่ามาก</li>
    <li><strong>Laddering:</strong> แบ่งฝากหลายก้อนให้ครบกำหนดต่างเวลา ได้ทั้งสภาพคล่องและดอกเบี้ยสูง</li>
    <li><strong>ติดตาม BOT:</strong> เมื่อ BOT ขึ้นดอกเบี้ยนโยบาย อัตราเงินฝากมักปรับสูงตาม</li>
    <li><strong>อย่าลืมประกันเงินฝาก:</strong> CDIC คุ้มครองสูงสุด 1 ล้านบาทต่อสถาบัน</li>
  </ul>

  <ArticleCalculatorCTA
    title="คำนวณดอกเบี้ยตามจำนวนและระยะเวลาของคุณ"
    description="ลองเปลี่ยนอัตราดอกเบี้ยและระยะเวลาเพื่อดูว่าแต่ละตัวเลือกให้ผลตอบแทนต่างกันเท่าไร"
    href="/คำนวณดอกเบี้ยเงินฝาก/"
    buttonLabel="คำนวณดอกเบี้ยเงินฝากตอนนี้"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณดอกเบี้ยเงินฝาก/">คำนวณดอกเบี้ยเงินฝาก</a> ป้อนจำนวนเงินและดูผลทันที</li>
    <li><a href="/คำนวณเงินเกษียณ/">คำนวณเงินเกษียณ</a> วางแผนออมระยะยาว</li>
    <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a> วางแผนว่าจะออมได้เดือนละเท่าไร</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/เงินฝากประจำ-vs-ออมทรัพย์/">เงินฝากประจำ vs ออมทรัพย์ ดอกเบี้ยต่างกันอย่างไร 2569</a></li>
    <li><a href="/บทความ/ดอกเบี้ยเงินฝาก-2569-ฝากประจำออมทรัพย์-ภาษี/">ดอกเบี้ยเงินฝาก 2569 ฝากประจำและออมทรัพย์ หลังหักภาษี</a></li>
    <li><a href="/บทความ/เงินฝาก-vs-กองทุน-เปรียบเทียบ-2569/">เงินฝาก vs กองทุน เปรียบเทียบ 2569</a></li>
  </ul>

  <h2>แหล่งอ้างอิง</h2>
  <ul>
    <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer">ธนาคารแห่งประเทศไทย (Bank of Thailand)</a></li>
  </ul>
</BlogPostLayout>
