---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าทิป 2569 | วิธีคิดทิป หารค่าอาหาร | Kamnuanlek';
const description = 'วิธีคิดทิปในไทย ให้ทิปเท่าไรดี อัตราทิปตามประเภทร้าน พร้อมเครื่องคำนวณทิปและหารค่าอาหาร ครอบคลุมร้านอาหาร โรงแรม สปา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าทิป-2569-วิธีคิดทิป-หารค่าอาหาร/`;

const faqData = [
  {
    question: 'ในไทยต้องให้ทิปหรือไม่?',
    answer: 'ไม่มีกฎหมายบังคับให้ทิปในประเทศไทย แต่เป็นธรรมเนียมที่ปฏิบัติกันโดยเฉพาะในร้านอาหารระดับกลาง-สูง โรงแรม และบริการสปา',
  },
  {
    question: 'Service Charge กับทิปต่างกันยังไง?',
    answer: 'Service Charge คือค่าบริการ 10% ที่ร้านบวกเข้าไปในบิลโดยอัตโนมัติ เป็นรายได้ของร้าน ส่วนทิปคือเงินที่ลูกค้าให้เพิ่มเติมตามความสมัครใจ มักให้โดยตรงกับพนักงาน',
  },
  {
    question: 'ทิปร้านอาหารทั่วไปควรให้เท่าไร?',
    answer: 'ร้านอาหารทั่วไปในไทยนิยมทิ้งเศษเหรียญ 20–50 บาท ร้านระดับกลาง 5–10% ร้านหรู 10–15% หากบิลมี Service Charge 10% อยู่แล้ว ไม่จำเป็นต้องให้ทิปเพิ่ม',
  },
  {
    question: 'วิธีหารค่าอาหารแบบยุติธรรมคืออะไร?',
    answer: 'นำยอดบิลรวม (รวมทิปแล้ว) หารด้วยจำนวนคน เช่น บิล 1,500 + ทิป 150 = 1,650 บาท หาร 5 คน = คนละ 330 บาท',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-20"
  modifiedDate="2026-04-20"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    คำนวณค่าทิป 2569: วิธีคิดทิป หารค่าอาหาร ให้เท่าไรถึงพอดี
  </h1>

  <p>
    ทิปเป็นธรรมเนียมที่ปฏิบัติกันในหลายบริการทั้งร้านอาหาร โรงแรม สปา และแท็กซี่
    แต่คำถามที่คนถามบ่อยที่สุดคือ "ให้เท่าไรดี?" และ "หารค่าอาหารกันยังไง?"
    บทความนี้สรุปอัตราทิปตามประเภทร้านในไทย พร้อมเทคนิคหารค่าอาหารแบบง่ายและยุติธรรม
  </p>

  <ArticleCalculatorCTA
    title="คำนวณทิปและหารค่าอาหารทันที"
    description="กรอกยอดบิล เลือกเปอร์เซ็นต์ทิป และจำนวนคน เพื่อดูทิปรวมและค่าต่อหัว"
    href="/คำนวณค่าทิป/"
    buttonLabel="ไปที่เครื่องคำนวณทิป"
  />

  <h2>อัตราทิปตามประเภทร้าน/บริการในไทย</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[520px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ประเภท</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ทิปที่นิยม</th>
          <th class="border border-gray-200 px-3 py-2 text-left">หมายเหตุ</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ร้านอาหารทั่วไป / Street Food</td>
          <td class="border border-gray-200 px-3 py-2">ทิ้งเศษเหรียญ 20–50 บาท</td>
          <td class="border border-gray-200 px-3 py-2">ไม่บังคับ</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ร้านอาหารระดับกลาง</td>
          <td class="border border-gray-200 px-3 py-2">5–10%</td>
          <td class="border border-gray-200 px-3 py-2">หากไม่มี Service Charge</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ร้านอาหารหรู / Fine Dining</td>
          <td class="border border-gray-200 px-3 py-2">10–15%</td>
          <td class="border border-gray-200 px-3 py-2">หลายร้านมี SC 10% แล้ว</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">โรงแรม (Bellboy / แม่บ้าน)</td>
          <td class="border border-gray-200 px-3 py-2">50–100 บาท</td>
          <td class="border border-gray-200 px-3 py-2">ต่อครั้ง</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">สปา / นวดแผนไทย</td>
          <td class="border border-gray-200 px-3 py-2">50–200 บาท</td>
          <td class="border border-gray-200 px-3 py-2">ตามระยะเวลาและระดับร้าน</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">แท็กซี่ / Grab</td>
          <td class="border border-gray-200 px-3 py-2">ปัดเศษขึ้น / 20–50 บาท</td>
          <td class="border border-gray-200 px-3 py-2">ไม่จำเป็น แต่เป็นมารยาท</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ไกด์ / ทัวร์</td>
          <td class="border border-gray-200 px-3 py-2">200–500 บาท/วัน</td>
          <td class="border border-gray-200 px-3 py-2">ขึ้นอยู่กับกรุ๊ปและบริการ</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>สูตรคำนวณทิป</h2>

  <p><strong>ทิป = ยอดบิล × เปอร์เซ็นต์ทิป ÷ 100</strong></p>

  <h3>ตัวอย่าง: บิลอาหาร 1,200 บาท ทิป 10%</h3>

  <ul>
    <li>ทิป: 1,200 × 10 ÷ 100 = <strong>120 บาท</strong></li>
    <li>ยอดรวม: 1,200 + 120 = <strong>1,320 บาท</strong></li>
  </ul>

  <h2>Service Charge กับทิป: ต่างกันยังไง?</h2>

  <p>
    <strong>Service Charge (SC)</strong> คือค่าบริการ 10% ที่ร้านบวกเข้าไปในบิลโดยอัตโนมัติ
    เงินส่วนนี้เป็นรายได้ของร้าน อาจแบ่งให้พนักงานหรือไม่ก็ได้ตามนโยบายร้าน
  </p>

  <p>
    <strong>ทิป (Tip/Gratuity)</strong> คือเงินที่ลูกค้าให้เพิ่มเติมตามความสมัครใจ
    มักให้โดยตรงกับพนักงานที่บริการ
  </p>

  <p>
    หากบิลมี Service Charge 10% อยู่แล้ว ไม่จำเป็นต้องให้ทิปเพิ่ม
    แต่หากบริการดีมากอาจให้เพิ่มเล็กน้อยได้ตามสมัครใจ
  </p>

  <h2>หารค่าอาหารง่ายๆ</h2>

  <p><strong>ค่าต่อหัว = ยอดรวม (รวมทิป) ÷ จำนวนคน</strong></p>

  <h3>ตัวอย่าง: 4 คน บิล 2,000 บาท ทิป 10%</h3>

  <ol>
    <li>ทิป: 2,000 × 10% = <strong>200 บาท</strong></li>
    <li>ยอดรวม: 2,000 + 200 = <strong>2,200 บาท</strong></li>
    <li>ค่าต่อหัว: 2,200 ÷ 4 = <strong>550 บาท</strong></li>
  </ol>

  <ArticleCalculatorCTA
    title="ลองหารค่าอาหารกับเพื่อน"
    description="กรอกยอดบิล เลือกทิป ใส่จำนวนคน ดูค่าต่อหัวทันที"
    href="/คำนวณค่าทิป/"
    buttonLabel="เปิดเครื่องคำนวณทิป"
  />

  <h2>เทคนิคคิดทิปเร็วในใจ</h2>

  <ol>
    <li>
      <strong>ทิป 10%:</strong> แค่เลื่อนจุดทศนิยม เช่น บิล 850 → ทิป 85 บาท
    </li>
    <li>
      <strong>ทิป 5%:</strong> คิด 10% แล้วหาร 2 เช่น 850 → 85 ÷ 2 = 42.50 บาท
    </li>
    <li>
      <strong>ทิป 15%:</strong> คิด 10% + 5% เช่น 85 + 42.50 = 127.50 บาท
    </li>
    <li>
      <strong>ทิป 20%:</strong> คิด 10% แล้วคูณ 2 เช่น 85 × 2 = 170 บาท
    </li>
  </ol>

  <h2>มารยาทการให้ทิปในไทย</h2>

  <ul>
    <li>ทิปเป็นความสมัครใจ ไม่มีการบังคับตามกฎหมาย</li>
    <li>ให้เป็นเงินสด ใส่ถาดรับเงิน หรือบอกพนักงานโดยตรง</li>
    <li>อย่าใช้เหรียญ 1 บาทหรือ 5 บาทเป็นทิป อาจถูกมองว่าไม่สุภาพ</li>
    <li>หากบริการไม่ดีจริงๆ ไม่ให้ทิปก็ได้ ไม่ต้องรู้สึกผิด</li>
    <li>ชาวต่างชาติในไทยมักให้ทิปมากกว่าคนไทย เป็นเรื่องวัฒนธรรม</li>
  </ul>

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณค่าทิป/">คำนวณค่าทิป</a> คิดทิปและหารค่าอาหารง่ายๆ</li>
    <li><a href="/คำนวณเปอร์เซ็นต์/">คำนวณเปอร์เซ็นต์</a> คำนวณส่วนลด กำไร เปอร์เซ็นต์ทุกแบบ</li>
    <li><a href="/คำนวณอัตราแลกเปลี่ยน/">คำนวณอัตราแลกเปลี่ยน</a> สำหรับนักท่องเที่ยวต่างชาติ</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/คำนวณค่าห้องพัก-2569-ค่าเช่า-มัดจำ-สาธารณูปโภค/">คำนวณค่าห้องพัก 2569 ค่าเช่า มัดจำ สาธารณูปโภค</a></li>
    <li><a href="/บทความ/คำนวณเปอร์เซ็นต์-2569-ส่วนลด-กำไร/">คำนวณเปอร์เซ็นต์ 2569 ส่วนลด กำไร</a></li>
  </ul>
</BlogPostLayout>
