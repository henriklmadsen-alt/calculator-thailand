---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'BMI 27 หมายความว่าอะไร ต้องลดน้ำหนักอีกเท่าไร | เครื่องคำนวณไทย';
const description = 'BMI 27 อยู่ในเกณฑ์น้ำหนักเกิน มีความเสี่ยงต่อโรคอะไรบ้าง และต้องลดน้ำหนักอีกกี่กิโลจึงจะกลับมาอยู่ในเกณฑ์ปกติ พร้อมแผนปฏิบัติ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/bmi-27-หมายความว่าอะไร/`;

const faqData = [
  {
    question: 'BMI 27 อันตรายไหม?',
    answer: 'BMI 27 อยู่ในเกณฑ์น้ำหนักเกิน (Overweight) ยังไม่ถึงระดับอ้วน แต่มีความเสี่ยงต่อโรคเบาหวาน ความดันโลหิตสูง และโรคหัวใจเพิ่มขึ้น ควรเริ่มปรับพฤติกรรมก่อนที่ค่าจะสูงขึ้น',
  },
  {
    question: 'ต้องลดน้ำหนักเท่าไรให้ BMI กลับมาเป็นปกติ?',
    answer: 'ขึ้นอยู่กับส่วนสูง เช่น ส่วนสูง 165 ซม. น้ำหนักปัจจุบัน ~73.5 กก. ต้องลดให้เหลือไม่เกิน 67.9 กก. (BMI 25) หรือดีที่สุดคือ 67.4 กก. (BMI 24.9) ประมาณ 6–7 กิโลกรัม',
  },
  {
    question: 'ลดน้ำหนักจาก BMI 27 ใช้เวลานานแค่ไหน?',
    answer: 'การลดน้ำหนักอย่างปลอดภัยไม่ควรเกิน 0.5–1 กก./สัปดาห์ ดังนั้นการลด 6–7 กก. ใช้เวลาประมาณ 6–12 สัปดาห์ด้วยการปรับอาหารและออกกำลังกายอย่างสม่ำเสมอ',
  },
  {
    question: 'BMI 27 สำหรับคนไทยถือว่าเสี่ยงแค่ไหน?',
    answer: 'สำหรับคนเอเชียรวมถึงคนไทย BMI 27 ถือว่าเสี่ยงค่อนข้างสูง เพราะเกณฑ์เอเชียถือว่าน้ำหนักเกินตั้งแต่ BMI 23 ขึ้นไป ควรเริ่มปรับพฤติกรรมโดยเร็ว',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  modifiedDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    BMI 27 หมายความว่าอะไร ต้องลดน้ำหนักอีกเท่าไร
  </h1>

  <p>
    คุณเพิ่งคำนวณ BMI แล้วพบว่าได้ค่า 27 หมายความว่าอะไร และควรทำอย่างไรต่อไป
    BMI 27 จัดอยู่ในหมวดหมู่ <strong>น้ำหนักเกิน (Overweight)</strong> ตามมาตรฐาน WHO
    ยังไม่ถึงระดับอ้วน แต่มีความเสี่ยงสุขภาพที่ควรใส่ใจ
    ใช้ <a href="/คำนวณ-bmi/">เครื่องคำนวณ BMI</a> ของเราเพื่อตรวจสอบค่าของคุณและดูว่าต้องลดน้ำหนักอีกเท่าไร
  </p>

  <ArticleCalculatorCTA
    title="คำนวณว่าต้องลดน้ำหนักอีกเท่าไร"
    description="ใส่น้ำหนักและส่วนสูงเพื่อดู BMI ปัจจุบันและน้ำหนักเป้าหมาย"
    href="/คำนวณ-bmi/"
    buttonLabel="คำนวณ BMI และน้ำหนักเป้าหมาย"
  />

  <h2>BMI 27 หมายความว่าอะไร</h2>

  <p>
    ตามเกณฑ์ WHO มาตรฐาน BMI 27 อยู่ในช่วง 25.0–29.9 ซึ่งจัดเป็น <strong>น้ำหนักเกิน (Overweight)</strong>
    ยังไม่ถึงระดับอ้วน (30 ขึ้นไป) แต่มีความเสี่ยงสุขภาพสูงกว่าค่าปกติ
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">หมวดหมู่</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ค่า BMI</th>
          <th class="border border-gray-200 px-3 py-2 text-left">สถานะ</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">น้ำหนักน้อย</td><td class="border border-gray-200 px-3 py-2">ต่ำกว่า 18.5</td><td class="border border-gray-200 px-3 py-2">ต้องเพิ่มน้ำหนัก</td></tr>
        <tr class="bg-green-50"><td class="border border-gray-200 px-3 py-2">ปกติ</td><td class="border border-gray-200 px-3 py-2">18.5–24.9</td><td class="border border-gray-200 px-3 py-2">เกณฑ์ที่ดีที่สุด</td></tr>
        <tr class="bg-yellow-50"><td class="border border-gray-200 px-3 py-2"><strong>น้ำหนักเกิน (BMI 27 อยู่ที่นี่)</strong></td><td class="border border-gray-200 px-3 py-2"><strong>25.0–29.9</strong></td><td class="border border-gray-200 px-3 py-2">ควรลดน้ำหนัก</td></tr>
        <tr class="bg-red-50"><td class="border border-gray-200 px-3 py-2">อ้วน</td><td class="border border-gray-200 px-3 py-2">30 ขึ้นไป</td><td class="border border-gray-200 px-3 py-2">ความเสี่ยงสูง</td></tr>
      </tbody>
    </table>
  </div>

  <h2>ต้องลดน้ำหนักอีกเท่าไรให้กลับสู่ค่าปกติ</h2>

  <p>
    เป้าหมายคือให้ BMI ลงมาอยู่ที่ต่ำกว่า 25 (หรือ 23 ตามเกณฑ์เอเชีย)
    ตัวอย่างการคำนวณตามส่วนสูงต่างๆ:
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[560px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ส่วนสูง</th>
          <th class="border border-gray-200 px-3 py-2 text-left">น้ำหนักที่ BMI 27</th>
          <th class="border border-gray-200 px-3 py-2 text-left">เป้าหมาย (BMI 25)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ต้องลด</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">155 ซม.</td><td class="border border-gray-200 px-3 py-2">64.9 กก.</td><td class="border border-gray-200 px-3 py-2">60.1 กก.</td><td class="border border-gray-200 px-3 py-2">~4.8 กก.</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">160 ซม.</td><td class="border border-gray-200 px-3 py-2">69.1 กก.</td><td class="border border-gray-200 px-3 py-2">64.0 กก.</td><td class="border border-gray-200 px-3 py-2">~5.1 กก.</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">165 ซม.</td><td class="border border-gray-200 px-3 py-2">73.5 กก.</td><td class="border border-gray-200 px-3 py-2">68.1 กก.</td><td class="border border-gray-200 px-3 py-2">~5.4 กก.</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">170 ซม.</td><td class="border border-gray-200 px-3 py-2">78.0 กก.</td><td class="border border-gray-200 px-3 py-2">72.3 กก.</td><td class="border border-gray-200 px-3 py-2">~5.7 กก.</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">175 ซม.</td><td class="border border-gray-200 px-3 py-2">82.7 กก.</td><td class="border border-gray-200 px-3 py-2">76.6 กก.</td><td class="border border-gray-200 px-3 py-2">~6.1 กก.</td></tr>
      </tbody>
    </table>
  </div>

  <h2>แผนปฏิบัติสำหรับ BMI 27</h2>

  <p>
    ข่าวดีคือ BMI 27 ยังอยู่ในช่วงที่สามารถปรับได้ด้วยพฤติกรรมชีวิต งานวิจัยแสดงว่าการลดน้ำหนัก 5–10%
    ของน้ำหนักตัวสามารถลดความเสี่ยงโรคเรื้อรังได้อย่างมีนัยสำคัญ
  </p>

  <ul>
    <li><strong>อาหาร:</strong> เพิ่มผักและโปรตีน ลดน้ำตาลและแป้งขัดขาว ลดแคลอรี่วันละ 300–500 แคล</li>
    <li><strong>ออกกำลังกาย:</strong> เดินเร็วหรือออกกำลังกายอย่างน้อย 150 นาที/สัปดาห์</li>
    <li><strong>การนอน:</strong> นอนหลับ 7–9 ชั่วโมง ช่วยควบคุมฮอร์โมนความหิว</li>
    <li><strong>ติดตามผล:</strong> ชั่งน้ำหนักสัปดาห์ละครั้ง และคำนวณ BMI ทุกเดือน</li>
  </ul>

  <h2>ความเสี่ยงสุขภาพที่เพิ่มขึ้นเมื่อ BMI 27</h2>

  <p>
    การมี BMI 27 เพิ่มความเสี่ยงต่อ: โรคเบาหวานชนิดที่ 2, ความดันโลหิตสูง, ไขมันในเลือดสูง,
    โรคข้อเสื่อม และภาวะหยุดหายใจขณะหลับ การลดน้ำหนักให้ได้ 5–10% จะลดความเสี่ยงเหล่านี้ลงได้ชัดเจน
  </p>

  <ArticleCalculatorCTA
    title="คำนวณน้ำหนักเป้าหมายของคุณ"
    description="ใส่น้ำหนักและส่วนสูงเพื่อดูว่าต้องลดอีกเท่าไรให้ BMI กลับสู่เกณฑ์ปกติ"
    href="/คำนวณ-bmi/"
    buttonLabel="คำนวณ BMI ของฉัน"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณ-bmi/">คำนวณ BMI</a> ตรวจสอบดัชนีมวลกายและน้ำหนักเป้าหมาย</li>
    <li><a href="/คำนวณแคลอรี่/">คำนวณแคลอรี่</a> วางแผนโภชนาการเพื่อลดน้ำหนัก</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/วิธีวัด-bmi-อย่างถูกต้อง/">วิธีวัด BMI อย่างถูกต้อง และแปลผลตามมาตรฐาน WHO</a></li>
    <li><a href="/บทความ/bmi-คำนวณค่าดัชนีมวลกาย-วิธีลดน้ำหนัก/">BMI คำนวณค่าดัชนีมวลกาย วิธีลดน้ำหนัก</a></li>
  </ul>

  <h2>แหล่งอ้างอิง</h2>
  <ul>
    <li><a href="https://www.moph.go.th" target="_blank" rel="noopener noreferrer">กระทรวงสาธารณสุข (Ministry of Public Health)</a></li>
    <li><a href="https://www.who.int/news-room/fact-sheets/detail/obesity-and-overweight" target="_blank" rel="noopener noreferrer">WHO — Obesity and overweight</a></li>
  </ul>
</BlogPostLayout>
