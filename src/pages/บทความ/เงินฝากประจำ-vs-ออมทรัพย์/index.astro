---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'เงินฝากประจำ vs ออมทรัพย์ ดอกเบี้ยต่างกันอย่างไร 2569 | Kamnuanlek';
const description = 'เปรียบเทียบเงินฝากประจำและบัญชีออมทรัพย์ อัตราดอกเบี้ย 2569 ข้อดีข้อเสีย และควรเลือกประเภทไหนให้เหมาะกับเป้าหมายการออม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/เงินฝากประจำ-vs-ออมทรัพย์/`;

const faqData = [
  {
    question: 'เงินฝากประจำและบัญชีออมทรัพย์ต่างกันอย่างไร?',
    answer: 'บัญชีออมทรัพย์ถอนได้ทุกเวลา ดอกเบี้ยต่ำ (0.5–1.25%/ปี) เงินฝากประจำต้องฝากครบกำหนด ดอกเบี้ยสูงกว่า (1.75–3.0%/ปี) แต่ถ้าถอนก่อนกำหนดจะเสียดอกเบี้ยบางส่วน',
  },
  {
    question: 'ดอกเบี้ยเงินฝากประจำ 2569 อยู่ที่เท่าไร?',
    answer: 'เงินฝากประจำ 3 เดือนประมาณ 1.75–2.25%/ปี, 6 เดือนประมาณ 2.00–2.50%/ปี, 1 ปีประมาณ 2.25–3.00%/ปี ขึ้นอยู่กับธนาคารและโปรโมชั่นในช่วงเวลานั้น',
  },
  {
    question: 'ดอกเบี้ยเงินฝากถูกหักภาษีไหม?',
    answer: 'ใช่ ดอกเบี้ยเงินฝากถูกหักภาษี ณ ที่จ่าย 15% โดยอัตโนมัติ เช่น ได้ดอกเบี้ย 1,000 บาท จะได้รับจริง 850 บาท หรือสามารถนำไปยื่นรวมกับภาษีประจำปีได้',
  },
  {
    question: 'ควรฝากประจำหรือออมทรัพย์ถ้ามีเงิน 100,000 บาท?',
    answer: 'ถ้าไม่ต้องใช้เงินในระยะสั้น ควรฝากประจำเพราะดอกเบี้ยสูงกว่า แต่ควรเก็บเงินฉุกเฉิน 3–6 เดือนไว้ในออมทรัพย์ก่อน แล้วส่วนที่เหลือค่อยฝากประจำ',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  modifiedDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    เงินฝากประจำ vs ออมทรัพย์ ดอกเบี้ยต่างกันอย่างไร 2569
  </h1>

  <p>
    เงินฝากในธนาคารมีหลายประเภท แต่ที่คนไทยใช้บ่อยที่สุดคือ <strong>บัญชีออมทรัพย์</strong>
    และ <strong>เงินฝากประจำ</strong> ทั้งสองแตกต่างกันในเรื่องดอกเบี้ยและความยืดหยุ่นในการถอน
    บทความนี้จะช่วยให้คุณเลือกได้ถูกต้องตามเป้าหมาย
    ใช้ <a href="/คำนวณดอกเบี้ยเงินฝาก/">เครื่องคำนวณดอกเบี้ยเงินฝาก</a> เพื่อดูว่าเงินของคุณจะเติบโตเท่าไรในแต่ละประเภท
  </p>

  <ArticleCalculatorCTA
    title="คำนวณดอกเบี้ยเงินฝากของคุณ"
    description="เปรียบเทียบดอกเบี้ยออมทรัพย์และฝากประจำ แล้วดูว่าได้เงินเท่าไรหลังหักภาษี"
    href="/คำนวณดอกเบี้ยเงินฝาก/"
    buttonLabel="คำนวณดอกเบี้ยเงินฝาก"
  />

  <h2>เปรียบเทียบบัญชีออมทรัพย์และเงินฝากประจำ</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[560px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ลักษณะ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">บัญชีออมทรัพย์</th>
          <th class="border border-gray-200 px-3 py-2 text-left">เงินฝากประจำ</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">ดอกเบี้ย (ปัจจุบัน)</td><td class="border border-gray-200 px-3 py-2">0.50–1.25%/ปี</td><td class="border border-gray-200 px-3 py-2">1.75–3.00%/ปี</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ความยืดหยุ่น</td><td class="border border-gray-200 px-3 py-2">ถอนได้ทุกเมื่อ</td><td class="border border-gray-200 px-3 py-2">ต้องรอครบกำหนด</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ระยะเวลา</td><td class="border border-gray-200 px-3 py-2">ไม่มีกำหนด</td><td class="border border-gray-200 px-3 py-2">3, 6, 12 เดือน</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ถอนก่อนกำหนด</td><td class="border border-gray-200 px-3 py-2">ได้เลย</td><td class="border border-gray-200 px-3 py-2">เสียดอกเบี้ยบางส่วน</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">เหมาะสำหรับ</td><td class="border border-gray-200 px-3 py-2">เงินฉุกเฉิน ใช้บ่อย</td><td class="border border-gray-200 px-3 py-2">เงินออมระยะกลาง</td></tr>
      </tbody>
    </table>
  </div>

  <h2>อัตราดอกเบี้ยเงินฝากประจำปี 2569</h2>

  <p>
    ธนาคารแต่ละแห่งแข่งขันอัตราดอกเบี้ย โดยเฉพาะช่วงที่ธนาคารแห่งประเทศไทย (BOT) ปรับนโยบายดอกเบี้ย
    ตัวอย่างอัตราดอกเบี้ยโดยประมาณในปี 2569:
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ประเภทบัญชี</th>
          <th class="border border-gray-200 px-3 py-2 text-left">อัตราดอกเบี้ย (ต่อปี)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ดอกเบี้ยสุทธิหลังหัก 15%</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">บัญชีออมทรัพย์</td><td class="border border-gray-200 px-3 py-2">0.50–1.25%</td><td class="border border-gray-200 px-3 py-2">0.43–1.06%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">เงินฝากประจำ 3 เดือน</td><td class="border border-gray-200 px-3 py-2">1.75–2.25%</td><td class="border border-gray-200 px-3 py-2">1.49–1.91%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">เงินฝากประจำ 6 เดือน</td><td class="border border-gray-200 px-3 py-2">2.00–2.50%</td><td class="border border-gray-200 px-3 py-2">1.70–2.13%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">เงินฝากประจำ 1 ปี</td><td class="border border-gray-200 px-3 py-2">2.25–3.00%</td><td class="border border-gray-200 px-3 py-2">1.91–2.55%</td></tr>
      </tbody>
    </table>
  </div>

  <h2>ควรเลือกแบบไหน</h2>

  <p>
    หลักการง่ายๆ สำหรับการตัดสินใจ:
  </p>

  <ul>
    <li><strong>ออมทรัพย์</strong> เหมาะกับเงินสำรองฉุกเฉิน 3–6 เดือนที่ต้องพร้อมใช้ทุกเมื่อ</li>
    <li><strong>ฝากประจำ 3–6 เดือน</strong> เหมาะกับเงินที่รู้ว่าจะใช้ในไม่กี่เดือน เช่น ค่าเทอม ค่าท่องเที่ยว</li>
    <li><strong>ฝากประจำ 1 ปี</strong> เหมาะกับเงินออมที่ไม่ต้องการใช้ในระยะสั้น ได้ดอกเบี้ยสูงที่สุด</li>
  </ul>

  <p>
    กลยุทธ์ที่ดีคือ <strong>Laddering</strong> แบ่งเงินฝากประจำออกเป็นหลายก้อน ครบกำหนดต่างเวลากัน
    เพื่อให้ได้ดอกเบี้ยสูงขณะยังมีสภาพคล่องพอสมควร
  </p>

  <ArticleCalculatorCTA
    title="คำนวณดอกเบี้ยเปรียบเทียบแต่ละประเภท"
    description="ดูว่าเงินของคุณเติบโตเท่าไรในแต่ละประเภทบัญชี พร้อมคำนวณหลังหักภาษี 15%"
    href="/คำนวณดอกเบี้ยเงินฝาก/"
    buttonLabel="คำนวณดอกเบี้ยเงินฝาก"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณดอกเบี้ยเงินฝาก/">คำนวณดอกเบี้ยเงินฝาก</a> เปรียบเทียบดอกเบี้ยแต่ละประเภทบัญชี</li>
    <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a> วางแผนว่าจะออมได้เดือนละเท่าไร</li>
    <li><a href="/คำนวณเงินเกษียณ/">คำนวณเงินเกษียณ</a> วางแผนออมเงินระยะยาว</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/ฝาก-100000-บาท-ได้ดอกเบี้ยเท่าไร/">ฝาก 100,000 บาท 1 ปี ได้ดอกเบี้ยเท่าไร หลังหักภาษี 15%</a></li>
    <li><a href="/บทความ/ดอกเบี้ยเงินฝาก-2569-ฝากประจำออมทรัพย์-ภาษี/">ดอกเบี้ยเงินฝาก 2569 ฝากประจำและออมทรัพย์ หลังหักภาษี</a></li>
    <li><a href="/บทความ/เงินฝาก-vs-กองทุน-เปรียบเทียบ-2569/">เงินฝาก vs กองทุน เปรียบเทียบ 2569</a></li>
  </ul>

  <h2>แหล่งอ้างอิง</h2>
  <ul>
    <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer">ธนาคารแห่งประเทศไทย (Bank of Thailand)</a></li>
  </ul>
</BlogPostLayout>
