---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณเปอร์เซ็นต์ 2569 | สูตรลัดส่วนลด กำไร และ % การเปลี่ยนแปลง | เครื่องคำนวณไทย';
const description = 'รวมสูตรคำนวณเปอร์เซ็นต์ที่ใช้จริงปี 2569 ครบทั้งหา X% ของ Y, หา X เป็นกี่% ของ Y, เพิ่ม/ลดตาม %, และ % การเปลี่ยนแปลง พร้อมตัวอย่างคำนวณแบบเร็ว';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณเปอร์เซ็นต์-2569-สูตรลัด-ส่วนลด-กำไร/`;

const faqData = [
  {
    question: 'ถ้าลดราคา 20% จาก 3,500 บาท ต้องจ่ายเท่าไร?',
    answer: 'ส่วนลดเท่ากับ 3,500 × 20% = 700 บาท ราคาหลังลดคือ 3,500 - 700 = 2,800 บาท',
  },
  {
    question: 'ยอดขายจาก 250,000 เป็น 300,000 เพิ่มขึ้นกี่เปอร์เซ็นต์?',
    answer: 'ใช้สูตร ((300,000 - 250,000) ÷ 250,000) × 100 = 20% แปลว่าเพิ่มขึ้น 20%',
  },
  {
    question: 'ทำไมบางครั้งต้องใช้ส่วนต่างเป็นจุดเปอร์เซ็นต์ ไม่ใช่เปอร์เซ็นต์การเปลี่ยนแปลง?',
    answer: 'จุดเปอร์เซ็นต์เหมาะกับการเทียบค่าเปอร์เซ็นต์ต่อเปอร์เซ็นต์ เช่น 12% เป็น 15% คือเพิ่ม 3 จุดเปอร์เซ็นต์ แต่เปอร์เซ็นต์การเปลี่ยนแปลงคือเพิ่ม 25%',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-16"
  modifiedDate="2026-04-16"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    คำนวณเปอร์เซ็นต์ 2569: สูตรลัดส่วนลด กำไร และ % การเปลี่ยนแปลง
  </h1>

  <p>
    การคำนวณเปอร์เซ็นต์เป็นทักษะที่ใช้ทุกวัน ตั้งแต่เช็กราคาหลังลด ดูกำไรขั้นต้น ไปจนถึงวิเคราะห์ยอดขายรายเดือน
    ปัญหาที่เจอบ่อยคือใช้สูตรไม่ตรงโจทย์ เช่น ต้องการหา “เพิ่มขึ้นกี่เปอร์เซ็นต์” แต่ไปใช้การลบเปอร์เซ็นต์ตรงๆ ทำให้ผลคลาดเคลื่อน
    บทความนี้สรุปสูตรที่ใช้จริงพร้อมตัวอย่างไทย เพื่อให้หยิบใช้ได้ทันทีในปี 2569
  </p>

  <ArticleCalculatorCTA
    title="ลองคำนวณจากตัวเลขจริงของคุณทันที"
    description="สลับได้ 4 โหมดในหน้าเดียว พร้อมแสดงวิธีทำทีละขั้น"
    href="/คำนวณเปอร์เซ็นต์/"
    buttonLabel="ไปที่เครื่องคำนวณเปอร์เซ็นต์"
  />

  <h2>4 สูตรหลักที่ต้องใช้ให้ถูกโจทย์</h2>

  <ul>
    <li><strong>X% ของ Y</strong> = (X ÷ 100) × Y</li>
    <li><strong>X เป็นกี่% ของ Y</strong> = (X ÷ Y) × 100</li>
    <li><strong>เพิ่ม/ลด X ด้วย Y%</strong> = X ± (X × Y ÷ 100)</li>
    <li><strong>% การเปลี่ยนแปลง</strong> = ((ค่าใหม่ - ค่าเดิม) ÷ ค่าเดิม) × 100</li>
  </ul>

  <h2>ตัวอย่างใช้งานเร็ว</h2>

  <h3>1) หา X% ของ Y</h3>
  <p>
    โบนัส 7.5% ของเงินเดือน 42,000 บาท เท่ากับ (7.5 ÷ 100) × 42,000 = 3,150 บาท
  </p>

  <h3>2) หา X เป็นกี่% ของ Y</h3>
  <p>
    ขายได้ 18,000 จากเป้า 24,000 คิดเป็น (18,000 ÷ 24,000) × 100 = 75%
  </p>

  <h3>3) เพิ่ม/ลดตามเปอร์เซ็นต์</h3>
  <p>
    ต้นทุน 12,500 บาท เพิ่ม 6% จะเป็น 12,500 + (12,500 × 6 ÷ 100) = 13,250 บาท
  </p>

  <h3>4) เปอร์เซ็นต์การเปลี่ยนแปลง</h3>
  <p>
    ค่าใช้จ่ายจาก 9,800 เป็น 8,900 เปลี่ยนแปลง ((8,900 - 9,800) ÷ 9,800) × 100 = -9.18%
    แปลว่าลดลง 9.18%
  </p>

  <h2>จุดที่คนมักพลาด</h2>

  <ul>
    <li>ใช้ฐานผิด: สูตรเปอร์เซ็นต์การเปลี่ยนแปลงต้องหารด้วย “ค่าเดิม” เสมอ</li>
    <li>สลับระหว่าง “เปอร์เซ็นต์” กับ “จุดเปอร์เซ็นต์” โดยไม่ตั้งใจ</li>
    <li>ปัดเศษเร็วเกินไป ทำให้ผลสุดท้ายเพี้ยน โดยเฉพาะงานบัญชีและราคา</li>
  </ul>

  <h2>สรุป</h2>
  <p>
    ถ้าเลือกสูตรตรงกับโจทย์ การคำนวณเปอร์เซ็นต์จะตรงและเร็วมาก
    แนะนำให้ใช้เครื่องคำนวณเปอร์เซ็นต์ของเราเมื่อทำงานที่ต้องคำนวณหลายเคสในครั้งเดียว
    ระบบจะแสดงวิธีคำนวณทุกขั้น ช่วยลดความผิดพลาดในการตรวจงานและส่งรายงาน
  </p>

  <h2>แหล่งข้อมูลทางการ</h2>
  <ul>
    <li><a href="https://dltv.ac.th/utils/files/download/137473" target="_blank" rel="noopener noreferrer">DLTV (กระทรวงศึกษาธิการ): บทเรียนคณิตศาสตร์เรื่องร้อยละและตัวอย่างการคิด</a></li>
    <li><a href="https://proj14.ipst.ac.th/p6/p6-math-book1/math-p6b1-044/" target="_blank" rel="noopener noreferrer">Project 14 สสวท.: บทเรียนร้อยละและอัตราส่วน</a></li>
    <li><a href="https://phetchabun.mol.go.th/wp-content/uploads/sites/24/2022/02/สถานการณ์แรงงานไตรมาส-4-ปี-64-ปรับปรุง-2.pdf" target="_blank" rel="noopener noreferrer">กระทรวงแรงงาน: ตัวอย่างสูตรอัตราการเปลี่ยนแปลงร้อยละ (YoY)</a></li>
  </ul>

  <h2>เครื่องคำนวณและบทความที่เกี่ยวข้อง</h2>
  <ul>
    <li><a href="/คำนวณเปอร์เซ็นต์/">คำนวณเปอร์เซ็นต์</a></li>
    <li><a href="/คำนวณภาษีมูลค่าเพิ่ม/">คำนวณ VAT 7%</a></li>
    <li><a href="/คำนวณดอกเบี้ยบัตรเครดิต/">คำนวณดอกเบี้ยบัตรเครดิต</a></li>
    <li><a href="/บทความ/ภาษีมูลค่าเพิ่ม-7-คิดยังไง-สูตรบวกภาษี-ถอดภาษี-ตั้งราคาขายให้ไม่ขาดทุน/">ภาษีมูลค่าเพิ่ม 7% คิดยังไง</a></li>
  </ul>

  <h2>คำถามที่พบบ่อย</h2>
  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
