---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าภาษีรถยนต์ 2569 | ภาษีประจำปี + พ.ร.บ. ครบจบ | เครื่องคำนวณไทย';
const description = 'วิธีคำนวณภาษีรถยนต์ประจำปี 2569 สำหรับรถเก๋ง กระบะ และมอเตอร์ไซค์ พร้อมตาราง CC น้ำหนัก ส่วนลดตามอายุรถ และค่า พ.ร.บ. อ้างอิงกรมการขนส่งทางบก';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าภาษีรถยนต์-2569-ภาษีประจำปี-พรบ/`;

const faqData = [
  {
    question: 'ภาษีรถยนต์ประจำปีคิดจากอะไร?',
    answer: 'รถเก๋งคิดจากขนาดเครื่องยนต์ (CC) รถกระบะคิดจากน้ำหนักรถ ส่วนมอเตอร์ไซค์เป็นอัตราคงที่ 100 บาท โดยรถเก๋งอายุ 6 ปีขึ้นไปจะได้ส่วนลดตามอายุรถ',
  },
  {
    question: 'รถอายุกี่ปีถึงได้ส่วนลดภาษี?',
    answer: 'รถเก๋งอายุ 6 ปีขึ้นไปเริ่มได้ส่วนลด 10% และเพิ่มขึ้นปีละ 10% จนสูงสุด 50% เมื่ออายุ 10 ปีขึ้นไป ส่วนรถกระบะและมอเตอร์ไซค์ไม่มีส่วนลดตามอายุ',
  },
  {
    question: 'ค่า พ.ร.บ. รวมอยู่ในภาษีรถยนต์ประจำปีหรือไม่?',
    answer: 'ค่า พ.ร.บ. เป็นค่าใช้จ่ายแยกต่างหากที่ต้องชำระพร้อมกัน รถเก๋ง 645.21 บาท กระบะ 967.28 บาท มอเตอร์ไซค์ 323.14 บาท',
  },
  {
    question: 'รถอายุ 7 ปีขึ้นไปต้องตรวจสภาพก่อนต่อภาษีไหม?',
    answer: 'ใช่ รถยนต์อายุ 7 ปีขึ้นไปต้องผ่านการตรวจสภาพรถ (ตรอ.) ก่อนต่อภาษี ค่าตรวจรถยนต์ 200 บาท มอเตอร์ไซค์ 60 บาท',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-20"
  modifiedDate="2026-04-20"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    คำนวณค่าภาษีรถยนต์ 2569: ภาษีประจำปี + พ.ร.บ. ครบจบในที่เดียว
  </h1>

  <p>
    ทุกปีเจ้าของรถต้องต่อภาษีรถยนต์ประจำปี แต่หลายคนยังสับสนว่าภาษีคิดจากอะไร
    ค่า พ.ร.บ. รวมอยู่ด้วยหรือไม่ และรถเก่ากี่ปีจะได้ส่วนลด บทความนี้อธิบายวิธีคำนวณภาษีรถยนต์ปี 2569
    แยกตามประเภทรถ พร้อมตารางอัตราและตัวอย่างเป็นเงินบาท อ้างอิงจากกรมการขนส่งทางบก (DLT)
  </p>

  <ArticleCalculatorCTA
    title="คำนวณภาษีรถยนต์ของคุณทันที"
    description="เลือกประเภทรถ กรอก CC หรือน้ำหนัก และอายุรถ เพื่อดูยอดภาษี + พ.ร.บ. รวมที่ต้องจ่าย"
    href="/คำนวณค่าภาษีรถยนต์/"
    buttonLabel="ไปที่เครื่องคำนวณภาษีรถยนต์"
  />

  <h2>ภาษีรถยนต์ประจำปีคิดจากอะไร?</h2>

  <p>
    หลักการคำนวณภาษีรถยนต์ขึ้นอยู่กับ <strong>ประเภทรถ</strong> เป็นหลัก
    รถเก๋ง (ไม่เกิน 7 ที่นั่ง) คิดจากขนาดเครื่องยนต์เป็น CC
    รถกระบะคิดจากน้ำหนักรถเปล่า และมอเตอร์ไซค์เป็นอัตราคงที่
    แต่ละประเภทมีตารางอัตราที่ต่างกันชัดเจน
  </p>

  <h2>ตารางอัตราภาษีรถเก๋ง (คิดตาม CC)</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ขนาดเครื่องยนต์</th>
          <th class="border border-gray-200 px-3 py-2 text-left">อัตราภาษี (บาท/CC)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ตัวอย่าง</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">1–600 CC</td>
          <td class="border border-gray-200 px-3 py-2">0.50 บาท/CC</td>
          <td class="border border-gray-200 px-3 py-2">600 CC = 300 บาท</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">601–1,800 CC</td>
          <td class="border border-gray-200 px-3 py-2">1.50 บาท/CC</td>
          <td class="border border-gray-200 px-3 py-2">1,500 CC = 2,250 บาท</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">1,801 CC ขึ้นไป</td>
          <td class="border border-gray-200 px-3 py-2">4.00 บาท/CC</td>
          <td class="border border-gray-200 px-3 py-2">2,000 CC = 8,000 บาท</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p>
    ข้อสังเกต: อัตราภาษีกระโดดค่อนข้างมากเมื่อข้ามช่วง โดยเฉพาะจาก 1,800 CC ไป 1,801 CC ที่เปลี่ยนจาก 1.50 เป็น 4.00 บาท/CC
    รถเก๋งเครื่อง 2,000 CC จึงเสียภาษีฐานสูงกว่ารถ 1,500 CC อย่างเห็นได้ชัด
  </p>

  <h2>ตารางอัตราภาษีรถกระบะ (คิดตามน้ำหนัก)</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">น้ำหนักรถ (กก.)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ภาษี (บาท/ปี)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">0–500</td>
          <td class="border border-gray-200 px-3 py-2">300</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">501–750</td>
          <td class="border border-gray-200 px-3 py-2">450</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">751–1,000</td>
          <td class="border border-gray-200 px-3 py-2">600</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">1,001–1,250</td>
          <td class="border border-gray-200 px-3 py-2">750</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">1,251–1,500</td>
          <td class="border border-gray-200 px-3 py-2">900</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">1,501–1,750</td>
          <td class="border border-gray-200 px-3 py-2">1,050</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">1,751–2,000</td>
          <td class="border border-gray-200 px-3 py-2">1,350</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">2,001–2,500</td>
          <td class="border border-gray-200 px-3 py-2">1,650</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">2,501–3,000</td>
          <td class="border border-gray-200 px-3 py-2">1,950</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p>
    รถกระบะส่วนใหญ่ในไทย เช่น Hilux, Ranger, D-Max มีน้ำหนักอยู่ในช่วง 1,500–2,000 กก.
    ภาษีจึงอยู่ประมาณ 900–1,350 บาทต่อปี ซึ่งถูกกว่ารถเก๋งเครื่อง 2,000 CC อย่างมาก
  </p>

  <h2>ส่วนลดภาษีตามอายุรถ (เฉพาะรถเก๋ง)</h2>

  <p>
    รถเก๋งที่จดทะเบียนมานานจะได้ส่วนลดภาษีตามขั้นบันได เริ่มตั้งแต่ปีที่ 6 เป็นต้นไป
    ส่วนรถกระบะและมอเตอร์ไซค์ไม่มีส่วนลดตามอายุ
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[400px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">อายุรถ (ปี)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ส่วนลด</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">1–5 ปี</td><td class="border border-gray-200 px-3 py-2">ไม่มีส่วนลด</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ปีที่ 6</td><td class="border border-gray-200 px-3 py-2">ลด 10%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ปีที่ 7</td><td class="border border-gray-200 px-3 py-2">ลด 20%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ปีที่ 8</td><td class="border border-gray-200 px-3 py-2">ลด 30%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ปีที่ 9</td><td class="border border-gray-200 px-3 py-2">ลด 40%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">10 ปีขึ้นไป</td><td class="border border-gray-200 px-3 py-2">ลด 50%</td></tr>
      </tbody>
    </table>
  </div>

  <h2>ตัวอย่างคำนวณจริง: รถเก๋ง 1,500 CC อายุ 8 ปี</h2>

  <ol>
    <li>ภาษีฐาน: 1,500 × 1.50 = <strong>2,250 บาท</strong></li>
    <li>ส่วนลดอายุรถปีที่ 8 = 30% → 2,250 × 0.30 = 675 บาท</li>
    <li>ภาษีหลังลด: 2,250 – 675 = <strong>1,575 บาท</strong></li>
    <li>ค่า พ.ร.บ. รถเก๋ง: <strong>645.21 บาท</strong></li>
    <li>ค่าตรวจสภาพรถ (อายุเกิน 7 ปี): <strong>200 บาท</strong></li>
    <li>รวมทั้งสิ้น: 1,575 + 645.21 + 200 = <strong>2,420.21 บาท</strong></li>
  </ol>

  <p>
    เปรียบเทียบกับรถใหม่คัน 1,500 CC ที่ยังไม่ได้ส่วนลด จะจ่าย 2,250 + 645.21 = 2,895.21 บาท
    ส่วนลด 30% ช่วยประหยัดได้ 675 บาทต่อปี
  </p>

  <ArticleCalculatorCTA
    title="ลองคำนวณกับรถของคุณ"
    description="เปลี่ยน CC น้ำหนัก หรืออายุรถ เพื่อดูยอดรวมภาษี + พ.ร.บ. ที่ต้องจ่ายจริง"
    href="/คำนวณค่าภาษีรถยนต์/"
    buttonLabel="เปิดเครื่องคำนวณภาษีรถยนต์"
  />

  <h2>ค่า พ.ร.บ. คืออะไร? ทำไมต้องจ่ายพร้อมภาษี</h2>

  <p>
    พ.ร.บ. คุ้มครองผู้ประสบภัยจากรถ พ.ศ. 2535 กำหนดให้รถทุกคันต้องมีประกันภัยภาคบังคับ
    ค่า พ.ร.บ. จ่ายพร้อมกับภาษีประจำปี โดยอัตราคงที่ตามประเภทรถ:
  </p>

  <ul>
    <li><strong>รถเก๋ง:</strong> 645.21 บาท</li>
    <li><strong>รถกระบะ:</strong> 967.28 บาท</li>
    <li><strong>มอเตอร์ไซค์:</strong> 323.14 บาท</li>
  </ul>

  <p>
    หลายคนเข้าใจผิดว่าค่า พ.ร.บ. รวมอยู่ในภาษีรถยนต์แล้ว แต่จริงๆ เป็นค่าใช้จ่ายแยกต่างหาก
    หากไม่ต่อ พ.ร.บ. จะไม่สามารถต่อภาษีได้
  </p>

  <h2>รถอายุ 7 ปีขึ้นไป: ค่าตรวจสภาพรถ (ตรอ.)</h2>

  <p>
    รถยนต์ที่จดทะเบียนมา 7 ปีขึ้นไป ต้องผ่านการตรวจสภาพจากสถานตรวจสภาพรถเอกชน (ตรอ.)
    ก่อนนำหลักฐานไปต่อภาษี ค่าตรวจสภาพ:
  </p>

  <ul>
    <li>รถยนต์ (เก๋ง/กระบะ): <strong>200 บาท</strong></li>
    <li>มอเตอร์ไซค์: <strong>60 บาท</strong></li>
  </ul>

  <p>
    หากรถไม่ผ่านการตรวจสภาพ ต้องแก้ไขจุดที่ไม่ผ่านแล้วกลับไปตรวจใหม่ จึงควรเผื่อเวลาก่อนวันภาษีหมดอย่างน้อย 2 สัปดาห์
  </p>

  <h2>มอเตอร์ไซค์: ภาษี 100 บาทคงที่</h2>

  <p>
    ไม่ว่าจะเป็นมอเตอร์ไซค์ 110 CC หรือ 400 CC ภาษีประจำปีคงที่ <strong>100 บาท</strong>
    บวกค่า พ.ร.บ. 323.14 บาท รวมเป็น <strong>423.14 บาท</strong> ต่อปี
    สำหรับมอเตอร์ไซค์อายุ 5 ปีขึ้นไป ต้องตรวจสภาพเพิ่มอีก 60 บาท
  </p>

  <h2>สรุปค่าใช้จ่ายต่อภาษีรถยนต์ทั้งหมด</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[560px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">รายการ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">รถเก๋ง</th>
          <th class="border border-gray-200 px-3 py-2 text-left">กระบะ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">มอเตอร์ไซค์</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ภาษีประจำปี</td>
          <td class="border border-gray-200 px-3 py-2">ตาม CC</td>
          <td class="border border-gray-200 px-3 py-2">ตามน้ำหนัก</td>
          <td class="border border-gray-200 px-3 py-2">100 บาท</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ส่วนลดอายุรถ</td>
          <td class="border border-gray-200 px-3 py-2">10–50%</td>
          <td class="border border-gray-200 px-3 py-2">ไม่มี</td>
          <td class="border border-gray-200 px-3 py-2">ไม่มี</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ค่า พ.ร.บ.</td>
          <td class="border border-gray-200 px-3 py-2">645.21</td>
          <td class="border border-gray-200 px-3 py-2">967.28</td>
          <td class="border border-gray-200 px-3 py-2">323.14</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ค่าตรวจสภาพ (7 ปี+)</td>
          <td class="border border-gray-200 px-3 py-2">200</td>
          <td class="border border-gray-200 px-3 py-2">200</td>
          <td class="border border-gray-200 px-3 py-2">60</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>ข้อผิดพลาดที่เจอบ่อยเมื่อต่อภาษีรถ</h2>

  <ol>
    <li>
      <strong>ลืมต่อ พ.ร.บ. ก่อน:</strong> ถ้า พ.ร.บ. หมดอายุจะต่อภาษีไม่ได้ ควรเช็กวันหมดอายุ พ.ร.บ. ล่วงหน้า
    </li>
    <li>
      <strong>ไม่ได้ตรวจสภาพรถ (รถเก่า 7 ปี+):</strong> ต้องมีใบตรวจสภาพก่อนต่อภาษี ถ้าลืมต้องเสียเวลากลับไปตรวจ
    </li>
    <li>
      <strong>เข้าใจว่ารถกระบะคิดตาม CC:</strong> กระบะคิดตามน้ำหนัก ไม่ใช่ CC ทำให้ประเมินยอดผิด
    </li>
    <li>
      <strong>ต่อภาษีล่าช้า:</strong> หากเลยกำหนดจะมีค่าปรับ 1% ต่อเดือน และหากเกิน 3 ปี ทะเบียนจะถูกระงับ
    </li>
  </ol>

  <h2>ช่องทางต่อภาษีรถยนต์ปี 2569</h2>

  <ul>
    <li>สำนักงานขนส่งจังหวัด/เขต</li>
    <li>เว็บไซต์ DLT e-Service ของกรมการขนส่งทางบก</li>
    <li>แอป DLT Vehicle Tax</li>
    <li>เคาน์เตอร์เซอร์วิส, ไปรษณีย์ไทย, ธนาคาร (บางแห่ง)</li>
  </ul>

  <p>
