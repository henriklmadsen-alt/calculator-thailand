---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';

const title = 'คำนวณอายุจากวันเกิด 2569 ปี เดือน วัน พ.ศ. | Kamnuanlek';
const description = 'วิธีคำนวณอายุจากวันเกิดแบบละเอียด ปี เดือน วัน รองรับปฏิทิน พ.ศ. พร้อมตัวอย่างการนับอายุสำหรับสมัครงาน ราชการ และเกษียณ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณอายุ-จากวันเกิด-2569-ปี-เดือน-วัน/`;

const faqData = [
  {
    question: 'คำนวณอายุจากวันเกิดทำอย่างไร?',
    answer: 'นำวันที่ปัจจุบันลบด้วยวันเกิด โดยนับปีเต็มก่อน จากนั้นนับเดือนเต็ม แล้วนับวันที่เหลือ ตัวอย่าง: เกิด 15 มกราคม 2530 ถึงวันที่ 19 เมษายน 2569 = 39 ปี 3 เดือน 4 วัน',
  },
  {
    question: 'พ.ศ. กับ ค.ศ. แปลงอย่างไร?',
    answer: 'พ.ศ. = ค.ศ. + 543 เช่น ค.ศ. 2026 = พ.ศ. 2569 และ พ.ศ. 2530 = ค.ศ. 1987 เครื่องคำนวณอายุของเรารองรับทั้งสองระบบ',
  },
  {
    question: 'อายุครบ 20 ปีบริบูรณ์ หมายความว่าอย่างไร?',
    answer: 'อายุครบ 20 ปีบริบูรณ์ หมายถึง ผ่านวันเกิดปีที่ 20 แล้ว ตามกฎหมายไทย (ประมวลกฎหมายแพ่งและพาณิชย์ มาตรา 19) ถือว่าบรรลุนิติภาวะ สามารถทำนิติกรรมได้ด้วยตนเอง',
  },
  {
    question: 'นับอายุในใบสมัครงานใช้วันไหนเป็นฐาน?',
    answer: 'ส่วนใหญ่นับถึงวันที่ยื่นใบสมัครหรือวันปิดรับสมัคร สำหรับงานราชการมักระบุชัดว่า "นับถึงวันปิดรับสมัคร" ควรอ่านประกาศให้ละเอียด',
  },
  {
    question: 'เกษียณอายุราชการไทยกี่ปี?',
    answer: 'ข้าราชการพลเรือนเกษียณอายุเมื่ออายุครบ 60 ปีบริบูรณ์ โดยจะพ้นจากราชการเมื่อสิ้นปีงบประมาณที่อายุครบ 60 ปี (30 กันยายน) ตาม พ.ร.บ.บำเหน็จบำนาญข้าราชการ',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-19"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    คำนวณอายุจากวันเกิด 2569 — วิธีนับอายุ ปี เดือน วัน แบบถูกต้อง
  </h1>

  <p>
    การคำนวณอายุจากวันเกิดเป็นเรื่องที่คนไทยต้องทำบ่อย ไม่ว่าจะกรอกใบสมัครงาน ตรวจสอบสิทธิ์เกษียณ สมัครเรียน หรือทำเอกสารราชการ แต่หลายคนยังสับสนระหว่างการนับปี พ.ศ. กับ ค.ศ. และไม่แน่ใจว่าจะนับเดือนกับวันที่เหลืออย่างไร บทความนี้อธิบายวิธีคำนวณอายุแบบละเอียดพร้อมตัวอย่างจริง
  </p>

  <div class="my-6 p-4 bg-primary-50 rounded-lg border border-primary-200 text-center">
    <p class="text-sm text-primary-800 mb-2 font-medium">คำนวณอายุของคุณเลย</p>
    <a href="/คำนวณอายุ/" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors text-sm">
      เครื่องคำนวณอายุ
    </a>
  </div>

  <h2>วิธีคำนวณอายุจากวันเกิด</h2>

  <p>
    หลักการคำนวณอายุคือการหาระยะเวลาระหว่างวันเกิดกับวันปัจจุบัน แบ่งเป็น 3 ขั้นตอน:
  </p>

  <ol>
    <li><strong>นับปีเต็ม</strong> — นับจำนวนวันเกิดที่ผ่านมาแล้ว</li>
    <li><strong>นับเดือนเต็ม</strong> — จากวันเกิดครั้งล่าสุด นับเดือนเต็มที่ผ่านไป</li>
    <li><strong>นับวันที่เหลือ</strong> — จำนวนวันตั้งแต่เดือนสุดท้ายที่นับจนถึงวันนี้</li>
  </ol>

  <h2>ตัวอย่างการคำนวณ</h2>

  <div class="my-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
    <p class="font-medium text-gray-900 mb-2">สมมติวันเกิด: 15 มกราคม พ.ศ. 2530 (ค.ศ. 1987)</p>
    <p class="text-gray-700 mb-2">วันที่คำนวณ: 19 เมษายน พ.ศ. 2569 (ค.ศ. 2026)</p>
    <ul class="text-gray-700 space-y-1">
      <li>ปีเต็ม: 2569 - 2530 = 39 ปี (วันเกิดปี 2569 ผ่านไปแล้ว เพราะ 15 ม.ค. อยู่ก่อน 19 เม.ย.)</li>
      <li>เดือนเต็ม: จาก 15 ม.ค. 2569 ถึง 15 เม.ย. 2569 = 3 เดือน</li>
      <li>วันที่เหลือ: จาก 15 เม.ย. ถึง 19 เม.ย. = 4 วัน</li>
      <li class="font-semibold text-gray-900">ผลลัพธ์: 39 ปี 3 เดือน 4 วัน</li>
    </ul>
  </div>

  <p>
    ถ้าวันเกิดยังไม่ถึงในปีปัจจุบัน ต้องลดปีลง 1 แล้วนับเดือนจากวันเกิดปีที่แล้ว ตัวอย่างเช่น ถ้าเกิดวันที่ 10 ธันวาคม 2530 ณ วันที่ 19 เมษายน 2569 จะได้ 38 ปี 4 เดือน 9 วัน (เพราะยังไม่ถึงวันเกิดปี 2569)
  </p>

  <h2>พ.ศ. กับ ค.ศ. — ความแตกต่างที่ต้องรู้</h2>

  <p>
    ประเทศไทยใช้ปฏิทินพุทธศักราช (พ.ศ.) เป็นหลัก ซึ่งมากกว่าคริสต์ศักราช (ค.ศ.) อยู่ 543 ปี การแปลงทำได้ง่าย:
  </p>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">การแปลง</th>
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">สูตร</th>
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">ตัวอย่าง</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ค.ศ. เป็น พ.ศ.</td>
          <td class="border border-gray-200 px-3 py-2">พ.ศ. = ค.ศ. + 543</td>
          <td class="border border-gray-200 px-3 py-2">2026 + 543 = <strong>2569</strong></td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-200 px-3 py-2">พ.ศ. เป็น ค.ศ.</td>
          <td class="border border-gray-200 px-3 py-2">ค.ศ. = พ.ศ. - 543</td>
          <td class="border border-gray-200 px-3 py-2">2569 - 543 = <strong>2026</strong></td>
        </tr>
      </tbody>
    </table>
  </div>

  <p>
    ข้อควรระวัง: เอกสารราชการไทยส่วนใหญ่ใช้ พ.ศ. แต่เอกสารนานาชาติ หนังสือเดินทาง และระบบออนไลน์ต่างประเทศใช้ ค.ศ. เช่น เกิดปี พ.ศ. 2530 เวลากรอกแบบฟอร์มภาษาอังกฤษต้องกรอกว่า 1987
  </p>

  <h2>เมื่อไรที่ต้องคำนวณอายุ?</h2>

  <h3>1. สมัครงานและสอบราชการ</h3>
  <p>
    ประกาศรับสมัครงานราชการและรัฐวิสาหกิจมักกำหนดอายุขั้นต่ำและสูงสุด เช่น "อายุไม่ต่ำกว่า 18 ปี และไม่เกิน 35 ปี นับถึงวันปิดรับสมัคร" การนับอายุผิดอาจทำให้เสียโอกาส ตรวจสอบอายุ ณ วันปิดรับสมัคร ไม่ใช่วันที่ยื่นใบสมัคร
  </p>

  <h3>2. บรรลุนิติภาวะ</h3>
  <p>
    ตามประมวลกฎหมายแพ่งและพาณิชย์ มาตรา 19 บุคคลจะบรรลุนิติภาวะเมื่ออายุ 20 ปีบริบูรณ์ ซึ่งหมายความว่าต้องผ่านวันเกิดปีที่ 20 แล้ว จึงจะทำนิติกรรมได้ด้วยตนเอง เช่น เปิดบัญชีธนาคาร ทำสัญญาเช่า หรือจดทะเบียนสมรส (กรณีไม่มีการอนุญาตจากผู้ปกครอง)
  </p>

  <h3>3. เกษียณอายุ</h3>
  <p>
    ข้าราชการพลเรือนเกษียณเมื่ออายุครบ 60 ปีบริบูรณ์ โดยจะพ้นจากราชการเมื่อสิ้นปีงบประมาณ (30 กันยายน) ของปีที่อายุครบ 60 ปี ตาม พ.ร.บ. บำเหน็จบำนาญข้าราชการ พ.ศ. 2494 ส่วนพนักงานเอกชน อายุเกษียณขึ้นอยู่กับระเบียบของแต่ละบริษัท แต่ตาม พ.ร.บ. คุ้มครองแรงงาน ลูกจ้างที่อายุครบ 60 ปี มีสิทธิแจ้งเกษียณและได้รับค่าชดเชยตามกฎหมาย
  </p>

  <h3>4. สมัครเรียนและเข้าเรียน</h3>
  <p>
    กระทรวงศึกษาธิการกำหนดอายุเข้าเรียนชั้น ป.1 ที่ 6 ปีบริบูรณ์ (นับถึงวันที่ 16 พฤษภาคมของปีการศึกษา) ระดับอุดมศึกษาบางหลักสูตรมีกำหนดอายุสูงสุด เช่น โรงเรียนทหาร ตำรวจ มีข้อกำหนดอายุเข้มงวด
  </p>

  <h3>5. สิทธิประกันสังคมและบำนาญ</h3>
  <p>
    ผู้ประกันตนมาตรา 33 ที่อายุครบ 55 ปี และส่งเงินสมทบกองทุนชราภาพครบ 180 เดือน จะได้รับบำนาญชราภาพรายเดือน ส่วนผู้ที่ส่งไม่ครบ 180 เดือน จะได้รับเป็นบำเหน็จ (เงินก้อน) การรู้อายุที่แน่นอนช่วยวางแผนการเงินหลังเกษียณได้
  </p>

  <h2>ข้อผิดพลาดที่พบบ่อยในการนับอายุ</h2>

  <ul>
    <li><strong>สับสน พ.ศ. กับ ค.ศ.</strong> — กรอกปี พ.ศ. ในช่องที่ต้องการ ค.ศ. ทำให้อายุคลาดเคลื่อน 543 ปี ต้องดูว่าระบบต้องการปีแบบไหน</li>
    <li><strong>ลืมตรวจว่าวันเกิดปีนี้ผ่านไปแล้วหรือยัง</strong> — ถ้าเอาปีปัจจุบันลบปีเกิดตรงๆ โดยไม่ดูว่าวันเกิดยังไม่ถึง อายุจะเกินจริง 1 ปี</li>
    <li><strong>นับ "ย่างเข้า" กับ "เต็ม" สลับกัน</strong> — ภาษาไทยมีคำว่า "อายุย่างเข้า 40" กับ "อายุ 39 ปีเต็ม" ซึ่งหมายถึงช่วงเดียวกัน เอกสารราชการใช้ "ปีบริบูรณ์" ซึ่งหมายถึงปีเต็ม</li>
    <li><strong>ไม่นับเดือนและวัน</strong> — หลายคนคิดแค่ปี แต่บางกรณีต้องการอายุละเอียดถึงเดือนและวัน เช่น การประกันชีวิต หรือการยื่นเอกสารราชการ</li>
  </ul>

  <h2>"อายุย่างเข้า" vs "อายุเต็ม" ต่างกันอย่างไร?</h2>

  <p>
    คนไทยมักพูดว่า "อายุย่างเข้า 40" ซึ่งหมายความว่ากำลังจะครบ 40 ปี แต่ยังไม่ถึง กล่าวคือ อายุจริงคือ 39 ปีเต็ม + เศษเดือนวัน แต่กำลังย่างก้าวเข้าปีที่ 40
  </p>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">คำเรียก</th>
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">ความหมาย</th>
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">ใช้ในบริบท</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">อายุ 39 ปีเต็ม / 39 ปีบริบูรณ์</td>
          <td class="border border-gray-200 px-3 py-2">ผ่านวันเกิดครั้งที่ 39 แล้ว</td>
          <td class="border border-gray-200 px-3 py-2">เอกสารราชการ กฎหมาย ใบสมัครงาน</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-200 px-3 py-2">อายุย่างเข้า 40</td>
          <td class="border border-gray-200 px-3 py-2">ยังไม่ครบ 40 แต่กำลังจะถึง</td>
          <td class="border border-gray-200 px-3 py-2">ภาษาพูดทั่วไป พระราชพิธี</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p>
    เวลากรอกเอกสาร ให้ใช้อายุ "ปีบริบูรณ์" เสมอ ยกเว้นเอกสารระบุเป็นอย่างอื่น
  </p>

  <h2>Generation (เจเนอเรชัน) แบ่งตามปีเกิด</h2>

  <p>
    นอกจากอายุเป็นตัวเลข การรู้ว่าตัวเองอยู่ใน Generation ไหนก็มีประโยชน์ในการทำความเข้าใจพฤติกรรมผู้บริโภค การตลาด และวัฒนธรรมร่วมสมัย:
  </p>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">Generation</th>
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">ปีเกิด (พ.ศ.)</th>
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">ปีเกิด (ค.ศ.)</th>
          <th class="border border-gray-200 px-3 py-2 text-center font-semibold">อายุในปี 2569</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">Baby Boomer</td>
          <td class="border border-gray-200 px-3 py-2">2489–2507</td>
          <td class="border border-gray-200 px-3 py-2">1946–1964</td>
          <td class="border border-gray-200 px-3 py-2 text-center">62–80 ปี</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-200 px-3 py-2">Gen X</td>
          <td class="border border-gray-200 px-3 py-2">2508–2523</td>
          <td class="border border-gray-200 px-3 py-2">1965–1980</td>
          <td class="border border-gray-200 px-3 py-2 text-center">46–61 ปี</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">Gen Y (Millennials)</td>
          <td class="border border-gray-200 px-3 py-2">2524–2539</td>
          <td class="border border-gray-200 px-3 py-2">1981–1996</td>
          <td class="border border-gray-200 px-3 py-2 text-center">30–45 ปี</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-200 px-3 py-2">Gen Z</td>
          <td class="border border-gray-200 px-3 py-2">2540–2555</td>
          <td class="border border-gray-200 px-3 py-2">1997–2012</td>
          <td class="border border-gray-200 px-3 py-2 text-center">14–29 ปี</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">Gen Alpha</td>
          <td class="border border-gray-200 px-3 py-2">2556 เป็นต้นไป</td>
          <td class="border border-gray-200 px-3 py-2">2013+</td>
          <td class="border border-gray-200 px-3 py-2 text-center">ต่ำกว่า 14 ปี</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>ราศีกับวันเกิด</h2>

  <p>
    จักรราศีสากล (Western Zodiac) แบ่งตามเดือนและวันเกิด มี 12 ราศี โดยแต่ละราศีมีช่วงวันที่ที่แน่นอน เช่น เกิดวันที่ 21 มีนาคม ถึง 19 เมษายน เป็นราศีเมษ (Aries) <a href="/คำนวณอายุ/">เครื่องคำนวณอายุ</a>ของเราจะแสดงราศีให้อัตโนมัติเมื่อกรอกวันเกิด
  </p>

  <div class="my-6 p-4 bg-primary-50 rounded-lg border border-primary-200 text-center">
    <p class="text-sm text-primary-800 mb-2">ตรวจสอบอายุ ราศี และ Generation ของคุณ</p>
    <a href="/คำนวณอายุ/" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors text-sm">
