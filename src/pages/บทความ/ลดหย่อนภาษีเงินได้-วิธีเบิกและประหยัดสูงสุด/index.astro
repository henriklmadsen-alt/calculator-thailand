---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';

const title = 'ลดหย่อนภาษีเงินได้ วิธีเบิกและประหยัดสูงสุด 2569 | Kamnuanlek';
const description = 'ลดหย่อนภาษีเงินได้ทั้งหมด วิธีเบิก เงื่อนไข และการประหยัดภาษีอย่างถูกต้องตามกฎหมาย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ลดหย่อนภาษีเงินได้-วิธีเบิกและประหยัดสูงสุด/`;

const faqData = [
  {
    question: 'ลดหย่อนภาษีมีกี่ประเภท?',
    answer: 'ประเภทหลัก: ลดหย่อนพื้นฐาน 60,000 บาท + ลดหย่อนอื่นๆ (ประกัน กองทุน บ้านเรือน ลาน) สูงสุด 500,000+ บาท/ปี',
  },
  {
    question: 'ลดหย่อนประกันชีวิตต้องมีใบรับรองอะไร?',
    answer: 'ต้องมีใบรับรองหักลดหย่อนจากบริษัทประกัน (แบบ 1 ใบ) ถ้าไม่มีใบรับรอง ธนาคารหรือสรรพากรจะไม่ยอมรับ',
  },
  {
    question: 'บัญชี ก.ศ.ร.ร. ลดหย่อนได้กี่บาท?',
    answer: 'ลดหย่อนสูงสุด 500,000 บาท/ปี สำหรับเงินหักจากเดือนที่อยู่ใน ก.ศ.ร.ร. แต่ต้องเก็บเอกสารจากกองทุน',
  },
  {
    question: 'ลดหย่อนบ้านหรือที่ดินจริงได้กี่บาท?',
    answer: 'ลดหย่อนได้ 3 ล้านบาทต่อครั้ง สูงสุด 5 ปีต่อโครงการ ต้องผ่านการอนุมัติจากรัฐ และใช้เพื่ออยู่อาศัยหรือสวนเกษตร',
  },
  {
    question: 'ต้องเสียภาษีเท่าไรหลังการลดหย่อนทั้งหมด?',
    answer: 'เสียภาษี = (รายได้ - ลดหย่อนทั้งหมด) × อัตราภาษี ยิ่งลดหย่อนเยอะ ยิ่งเสียภาษีน้อย',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-26"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    ลดหย่อนภาษีเงินได้ วิธีเบิกและประหยัดสูงสุด 2569
  </h1>

  <p class="text-gray-700 mb-4">
    ลดหย่อนภาษีเงินได้เป็นวิธีที่ถูกกฎหมายในการลดรายได้สำหรับการคำนวณภาษี ทำให้เสียภาษีน้อยลง บทความนี้จะอธิบายลดหย่อนทั้งหมด วิธีเบิก เงื่อนไข และการประหยัดภาษีอย่างสูงสุด
  </p>

  <div class="my-6 p-4 bg-primary-50 rounded-lg border border-primary-200 text-center">
    <p class="text-sm text-primary-800 mb-2 font-medium">คำนวณภาษีที่เสียหลังลดหย่อน</p>
    <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors text-sm">
      ใช้เครื่องคำนวณภาษีเงินได้
    </a>
  </div>

  <h2>ลดหย่อนภาษีเงินได้มีกี่ประเภท?</h2>

  <p class="text-gray-700 mb-4">
    ลดหย่อนภาษีแบ่งออกเป็น 2 ประเภท: ลดหย่อนพื้นฐาน (ได้ทุกคน) และลดหย่อนอื่นๆ (ตามเงื่อนไข)
  </p>

  <h3>1. ลดหย่อนพื้นฐาน (Personal Deduction)</h3>

  <p class="text-gray-700 mb-4">
    ได้ลดหย่อน <strong>60,000 บาท/ปี</strong> (5,000 บาท/เดือน) ทุกคนได้ โดยไม่ต้องเก็บเอกสาร ไม่จำเป็นต้องหักจากเงินเดือน เรียกว่า "มาตรฐาน"
  </p>

  <h3>2. ลดหย่อนประกันชีวิต (Life Insurance)</h3>

  <p class="text-gray-700 mb-4">
    <strong>สูงสุด 100,000 บาท/ปี</strong> ซื้อประกันชีวิตจากบริษัทประกัน ต้องเก็บใบรับรองหักลดหย่อน (ท.ค.ส. 1 ใบ) จากบริษัทประกัน
  </p>

  <p class="text-gray-700 mb-4 text-sm">
    <strong>เงื่อนไข:</strong> ประกันต้องเป็นประกันชีวิตคุ้มครองตัวผู้เสียภาษี มีกำหนดจ่ายเบี้ยอย่างน้อย 10 ปี
  </p>

  <h3>3. ลดหย่อนประกันสุขภาพ (Health Insurance)</h3>

  <p class="text-gray-700 mb-4">
    <strong>สูงสุด 25,000 บาท/ปี</strong> สำหรับประกันสุขภาพส่วนตัว ต้องเก็บใบรับรองจากบริษัทประกัน
  </p>

  <h3>4. ลดหย่อนกองทุนสำรองเลี้ยงชีพ (Provident Fund)</h3>

  <p class="text-gray-700 mb-4">
    <strong>สูงสุด 500,000 บาท/ปี</strong> เมื่อหักจากเงินเดือนไป ต้องเก็บเอกสารจากกองทุน (ใบสำคัญการหัก)
  </p>

  <p class="text-gray-700 mb-4 text-sm">
    <strong>เงื่อนไข:</strong> ต้องเป็นสมาชิกกองทุนสำรองเลี้ยงชีพ และตัวหักต่อเดือนต้องปรากฏในสลิปเงินเดือน
  </p>

  <h3>5. ลดหย่อนเงินสมทบกองทุนสำรองเลี้ยงชีพ (Voluntary Contribution)</h3>

  <p class="text-gray-700 mb-4">
    <strong>สูงสุด 500,000 บาท/ปี</strong> เมื่อสมทบเพิ่มเติมเข้ากองทุน นอกเหนือจากการหักปกติ ต้องเก็บใบสำคัญ
  </p>

  <h3>6. ลดหย่อนเงินฝากธนาคาร (Bank Savings)</h3>

  <p class="text-gray-700 mb-4">
    <strong>สูงสุด 200,000 บาท/ปี</strong> ดอกเบี้ยจากการฝากเงินออมกับธนาคาร ต้องเก็บรายงานดอกเบี้ยจากธนาคาร
  </p>

  <h3>7. ลดหย่อนบ้านหรือที่ดิน (Property Deduction)</h3>

  <p class="text-gray-700 mb-4">
    <strong>3 ล้านบาท/ครั้ง สูงสุด 5 ปี</strong> สำหรับการสร้าง ซื้อ หรือปรับปรุงบ้านใช้เพื่ออยู่อาศัยหรือสวนเกษตร ต้องผ่านการอนุมัติจากรัฐ
  </p>

  <p class="text-gray-700 mb-4 text-sm">
    <strong>เงื่อนไข:</strong> ต้องเป็นพื้นที่เกษตร หรือบ้านเรือนใหม่ ต้องส่งใบอนุมัติจากเขตสัตยา
  </p>

  <h2>วิธีเบิกลดหย่อนแต่ละประเภท</h2>

  <h3>การเบิกผ่านการหักภาษีที่ต้นทาง (ลดหย่อนโดยปริยาย)</h3>

  <p class="text-gray-700 mb-4">
    หากการหักลดหย่อนเป็นอัตโนมัติจากนายจ้าง หรือจากกองทุน ให้เสนอเอกสารลดหย่อนให้นายจ้างก่อนวันตั้งหักประกาศ เพื่อให้นายจ้างนำไปหักออกจากเงินเดือน
  </p>

  <h3>การเบิกผ่านการยื่นแบบ ภ.ง.ด. 91</h3>

  <p class="text-gray-700 mb-4">
    สำหรับลดหย่อนตามเงื่อนไข (ประกัน บ้าน เป็นต้น) ต้องเก็บเอกสาร แล้วยื่นแบบ ภ.ง.ด. 91 (ประมาณการภาษีฯ) ให้สรรพากรเพื่อขอลดหย่อน
  </p>

  <h2>เอกสารที่ต้องเก็บสำหรับลดหย่อน</h2>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-100">
          <th class="border border-gray-300 px-3 py-2 text-left font-semibold">ลดหย่อน</th>
          <th class="border border-gray-300 px-3 py-2 text-left font-semibold">เอกสารที่ต้องเก็บ</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-300 px-3 py-2">ประกันชีวิต</td>
          <td class="border border-gray-300 px-3 py-2">ใบรับรองหักลดหย่อน (ท.ค.ส. 1)</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-300 px-3 py-2">ประกันสุขภาพ</td>
          <td class="border border-gray-300 px-3 py-2">ใบรับรองจากบริษัทประกัน</td>
        </tr>
        <tr>
          <td class="border border-gray-300 px-3 py-2">กองทุนสำรองเลี้ยงชีพ</td>
          <td class="border border-gray-300 px-3 py-2">ใบสำคัญการหักจากกองทุน</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-300 px-3 py-2">บ้าน/ที่ดิน</td>
          <td class="border border-gray-300 px-3 py-2">ใบอนุมัติจากเขตสัตยา เอกสารอื่นตามเงื่อนไข</td>
        </tr>
        <tr>
          <td class="border border-gray-300 px-3 py-2">ดอกเบี้ยธนาคาร</td>
          <td class="border border-gray-300 px-3 py-2">หนังสือรายงานดอกเบี้ยจากธนาคาร</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>ตัวอย่างการคำนวณลดหย่อนทั้งหมด</h2>

  <p class="text-gray-700 mb-4">
    สมมติคุณเป็นพนักงานเงินเดือน 60,000 บาท/เดือน ทั้งปี โดยมี:
  </p>

  <ul class="list-disc pl-6 text-gray-700 mb-4">
    <li>ประกันชีวิต: 50,000 บาท/ปี</li>
    <li>กองทุนสำรองเลี้ยงชีพ: 30,000 บาท/ปี</li>
    <li>ประกันสุขภาพ: 10,000 บาท/ปี</li>
  </ul>

  <div class="bg-blue-50 rounded-lg p-4 mb-4 text-sm">
    <p class="font-semibold text-gray-900 mb-2">การคำนวณลดหย่อนรวม:</p>
    <ul class="list-decimal pl-6 text-gray-700 space-y-1">
      <li>รายได้ทั้งปี = 60,000 × 12 = 720,000 บาท</li>
      <li>ลดหย่อนพื้นฐาน = 60,000 บาท</li>
      <li>ลดหย่อนประกันชีวิต = 50,000 บาท</li>
      <li>ลดหย่อนกองทุน = 30,000 บาท</li>
      <li>ลดหย่อนประกันสุขภาพ = 10,000 บาท</li>
      <li><strong>ลดหย่อนรวม = 150,000 บาท</strong></li>
      <li>รายได้หลังลดหย่อน = 720,000 - 150,000 = 570,000 บาท</li>
      <li>ภาษี (อัตรา 10%) = 570,000 × 10% = 57,000 บาท</li>
    </ul>
  </div>

  <h2>ข้อผิดพลาดทั่วไปในการลดหย่อน</h2>

  <ul class="space-y-3 text-gray-700">
    <li>
      <strong>ไม่เก็บเอกสารลดหย่อน:</strong> เบิกลดหย่อนแล้วแต่ไม่มีใบรับรอง สรรพากรจะไม่ยอมรับ ต้องเก็บใบรับรองทุกครั้ง
    </li>
    <li>
      <strong>นับลดหย่อนเกินจำนวน:</strong> ลดหย่อนประกันชีวิตสูงสุด 100,000 บาท ซื้อเกินแล้ว ส่วนเกิน ใช้ไม่ได้
    </li>
    <li>
      <strong>ไม่รู้ว่าประกันต้องมีอายุขั้นต่ำ:</strong> ประกันต้องมี term อย่างน้อย 10 ปี ประกันระยะสั้นใช้ลดหย่อนไม่ได้
    </li>
    <li>
      <strong>คิดว่าเก็บเอกสารแล้วหักได้เอง:</strong> ต้องส่งเอกสารให้นายจ้างหรือสรรพากร ก่อนการคำนวณ เก็บไว้อย่างเดียวไม่ได้
    </li>
  </ul>

  <h2>วิธีใช้ลดหย่อนให้สูงสุด</h2>

  <ol class="space-y-2 text-gray-700 list-decimal pl-6">
    <li>เบิกลดหย่อนพื้นฐาน 60,000 บาท เสมอ (ไม่ต้องเก็บเอกสาร)</li>
    <li>ซื้อประกันชีวิต + สุขภาพ รวม 125,000 บาท (ต้องเก็บใบรับรอง)</li>
    <li>สมัครกองทุนสำรองเลี้ยงชีพ หักจากเงินเดือน สูงสุด 500,000 บาท/ปี</li>
    <li>ฝากเงินออมกับธนาคาร ลดหย่อนดอกเบี้ย สูงสุด 200,000 บาท/ปี</li>
    <li>หากมีเงินพอ ไถ่บ้านใหม่ ลดหย่อน 3 ล้านบาท ได้นาน 5 ปี</li>
  </ol>

  <h2>สรุป</h2>

  <p class="text-gray-700">
    ลดหย่อนภาษีเงินได้เป็นวิธีที่ถูกกฎหมายในการลดภาษี แต่ต้องมีเอกสารสำคัญ และยื่นให้สรรพากรก่อนกำหนด เก็บเอกสารให้ดี และใช้เครื่องคำนวณภาษีเงินได้ของ Kamnuanlek เพื่อดูว่าหากลดหย่อนต่างๆ จะได้ประหยัดภาษีเท่าไร
  </p>
</BlogPostLayout>
