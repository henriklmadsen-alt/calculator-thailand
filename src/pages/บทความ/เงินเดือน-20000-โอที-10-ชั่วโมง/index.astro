---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'เงินเดือน 20,000 บาท ทำโอที 10 ชั่วโมง/เดือน ได้เพิ่มเท่าไร | เครื่องคำนวณไทย';
const description = 'คำนวณค่าโอทีสำหรับเงินเดือน 20,000 บาท ทำโอที 10 ชั่วโมงต่อเดือน เปรียบเทียบ 3 สถานการณ์ตามกฎหมายแรงงานไทย พร้อมตัวเลขชัดเจน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/เงินเดือน-20000-โอที-10-ชั่วโมง/`;

const faqData = [
  {
    question: 'เงินเดือน 20,000 บาท ค่าแรงต่อชั่วโมงเท่าไร?',
    answer: 'คำนวณจาก 20,000 ÷ 160 ชั่วโมง (20 วัน × 8 ชม.) = 125 บาท/ชั่วโมง หรือถ้าทำงาน 22 วัน = 20,000 ÷ 176 = 113.64 บาท/ชั่วโมง',
  },
  {
    question: 'โอที 10 ชั่วโมง วันธรรมดา เงินเดือน 20,000 ได้เท่าไร?',
    answer: 'ค่าแรง 125 บาท/ชม. × 1.5 × 10 = 1,875 บาท เงินเดือนรวมเดือนนั้น = 20,000 + 1,875 = 21,875 บาท',
  },
  {
    question: 'โอทีวันหยุด 10 ชั่วโมง เงินเดือน 20,000 ได้เท่าไร?',
    answer: 'ถ้าเป็นวันหยุดนักขัตฤกษ์: 125 × 2 × 10 = 2,500 บาท ถ้าเป็นโอทีในวันหยุด (เกินเวลา 8 ชม.): 125 × 3 × 10 = 3,750 บาท',
  },
  {
    question: 'ค่าโอทีต้องเสียภาษีไหม?',
    answer: 'ใช่ ค่าโอทีถือเป็นรายได้และต้องรวมในการคำนวณภาษีเงินได้บุคคลธรรมดาประจำปี นายจ้างจะหักภาษี ณ ที่จ่ายรวมกับเงินเดือนทุกเดือน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  modifiedDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    เงินเดือน 20,000 บาท ทำโอที 10 ชั่วโมง/เดือน ได้เพิ่มเท่าไร
  </h1>

  <p>
    เดือนนี้ทำงานเพิ่ม 10 ชั่วโมง อยากรู้ว่าจะได้เงินเพิ่มเท่าไร
    คำตอบขึ้นอยู่กับว่าทำโอทีในวันธรรมดาหรือวันหยุด กฎหมายแรงงานไทยกำหนดอัตราต่างกัน
    ใช้ <a href="/คำนวณค่าโอที/">เครื่องคำนวณค่าโอที</a> ของเราเพื่อดูตัวเลขที่แม่นยำ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณค่าโอทีสำหรับเงินเดือนของคุณ"
    description="ใส่เงินเดือน ชั่วโมงโอที และประเภทวัน แล้วดูยอดเงินที่ควรได้รับ"
    href="/คำนวณค่าโอที/"
    buttonLabel="คำนวณค่าโอทีตอนนี้"
  />

  <h2>ขั้นตอนที่ 1: คำนวณค่าแรงต่อชั่วโมง</h2>

  <p>
    เงินเดือน 20,000 บาท ทำงาน 5 วัน/สัปดาห์ วันละ 8 ชั่วโมง = 160 ชั่วโมง/เดือน (4 สัปดาห์)
  </p>

  <div class="not-prose my-4 rounded-lg border border-gray-200 bg-gray-50 p-4">
    <p class="font-semibold text-gray-900">ค่าแรงต่อชั่วโมง = 20,000 ÷ 160 = <span class="text-blue-700">125 บาท/ชั่วโมง</span></p>
  </div>

  <h2>สถานการณ์ที่ 1: โอที 10 ชั่วโมงในวันธรรมดา (อัตรา 1.5x)</h2>

  <p>
    ทำงานเกิน 8 ชั่วโมงในวันจันทร์–ศุกร์ ได้ค่าโอที 1.5 เท่า:
  </p>

  <ul>
    <li>ค่าโอที = 125 × 1.5 × 10 = <strong>1,875 บาท</strong></li>
    <li>เงินเดือนรวมเดือนนี้ = 20,000 + 1,875 = <strong>21,875 บาท</strong></li>
  </ul>

  <h2>สถานการณ์ที่ 2: โอทีผสม 6 ชั่วโมงวันธรรมดา + 4 ชั่วโมงวันหยุด</h2>

  <ul>
    <li>โอทีวันธรรมดา: 125 × 1.5 × 6 = <strong>1,125 บาท</strong></li>
    <li>โอทีวันหยุดนักขัตฤกษ์: 125 × 2 × 4 = <strong>1,000 บาท</strong></li>
    <li>รวมค่าโอที = <strong>2,125 บาท</strong></li>
    <li>เงินเดือนรวมเดือนนี้ = 20,000 + 2,125 = <strong>22,125 บาท</strong></li>
  </ul>

  <h2>สถานการณ์ที่ 3: โอที 10 ชั่วโมงในวันหยุดส่วนตัว (อัตรา 3x)</h2>

  <p>
    ถ้าถูกเรียกให้ทำงานในวันหยุดประจำสัปดาห์ของคุณเอง ได้ค่าโอทีสูงที่สุด:
  </p>

  <ul>
    <li>ค่าโอที = 125 × 3 × 10 = <strong>3,750 บาท</strong></li>
    <li>เงินเดือนรวมเดือนนี้ = 20,000 + 3,750 = <strong>23,750 บาท</strong></li>
  </ul>

  <h2>สรุปเปรียบเทียบทั้งสามสถานการณ์</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[560px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">สถานการณ์</th>
          <th class="border border-gray-200 px-3 py-2 text-left">อัตรา</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ค่าโอที</th>
          <th class="border border-gray-200 px-3 py-2 text-left">เงินเดือนรวม</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">โอที 10 ชม. วันธรรมดา</td><td class="border border-gray-200 px-3 py-2">1.5x</td><td class="border border-gray-200 px-3 py-2">1,875 บาท</td><td class="border border-gray-200 px-3 py-2">21,875 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">โอทีผสม (6+4 ชม.)</td><td class="border border-gray-200 px-3 py-2">1.5x + 2x</td><td class="border border-gray-200 px-3 py-2">2,125 บาท</td><td class="border border-gray-200 px-3 py-2">22,125 บาท</td></tr>
        <tr class="bg-green-50"><td class="border border-gray-200 px-3 py-2">โอที 10 ชม. วันหยุดส่วนตัว</td><td class="border border-gray-200 px-3 py-2">3x</td><td class="border border-gray-200 px-3 py-2"><strong>3,750 บาท</strong></td><td class="border border-gray-200 px-3 py-2"><strong>23,750 บาท</strong></td></tr>
      </tbody>
    </table>
  </div>

  <h2>วิธีตรวจสอบบัญชีเงินเดือน</h2>

  <ul>
    <li>ตรวจว่าค่าโอทีแยกรายการชัดเจนและครบจำนวนชั่วโมง</li>
    <li>ตรวจว่าอัตราที่ใช้ถูกต้อง (1.5x, 2x, หรือ 3x)</li>
    <li>ตรวจว่าฐานค่าแรงที่ใช้คือเงินเดือนพื้นฐาน ไม่ใช่รวมโบนัส</li>
    <li>หากได้รับไม่ครบ แจ้งฝ่าย HR หรือกรมสวัสดิการและคุ้มครองแรงงาน</li>
  </ul>

  <ArticleCalculatorCTA
    title="คำนวณค่าโอทีสำหรับเงินเดือนของคุณ"
    description="ลองเปลี่ยนจำนวนชั่วโมงและประเภทวันเพื่อเปรียบเทียบได้ทันที"
    href="/คำนวณค่าโอที/"
    buttonLabel="คำนวณค่าโอทีของฉัน"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณค่าโอที/">คำนวณค่าโอที</a> คำนวณค่าโอทีตามเงินเดือนและชั่วโมงของคุณ</li>
    <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a> หักประกันสังคมและภาษีเงินได้</li>
    <li><a href="/คำนวณค่าจ้างรายวัน/">คำนวณค่าจ้างรายวัน</a> แปลงเงินเดือนเป็นค่าแรงรายวัน</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/ค่าโอที-กฎหมายแรงงานไทย/">ค่าโอทีตามกฎหมายแรงงานไทย คิดยังไง 1.5x 2x 3x</a></li>
    <li><a href="/บทความ/คำนวณค่าโอที-2569-กฎหมายแรงงาน/">คำนวณค่าโอที 2569 ตามกฎหมายแรงงาน</a></li>
    <li><a href="/บทความ/เงินเดือนสุทธิ-2569-คำนวณหัก-ประกันสังคม-ภาษี/">เงินเดือนสุทธิ 2569 คำนวณหักประกันสังคม ภาษี</a></li>
  </ul>

  <h2>แหล่งอ้างอิง</h2>
  <ul>
    <li><a href="https://www.labour.go.th" target="_blank" rel="noopener noreferrer">กระทรวงแรงงาน (Ministry of Labour)</a></li>
  </ul>
</BlogPostLayout>
