---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณส่วนลด 20% ของ 1,500 บาท และสูตรลดราคาที่ควรรู้ก่อนช้อป | เครื่องคำนวณไทย';
const description = 'วิธีคำนวณส่วนลด 20% ของ 1,500 บาท พร้อมสูตรลดราคาแบบต่างๆ ส่วนลดซ้อนทับ Buy 2 Get 1 และเคล็ดลับซื้อของให้คุ้มค่า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณส่วนลด-20-เปอร์เซ็นต์/`;

const faqData = [
  {
    question: 'คำนวณส่วนลด 20% ของ 1,500 บาท ได้เท่าไร?',
    answer: 'ส่วนลด = 20% × 1,500 = 300 บาท ราคาที่ต้องจ่ายจริง = 1,500 - 300 = 1,200 บาท',
  },
  {
    question: 'ส่วนลดซ้อนทับ 10% + 5% เท่ากับ 15% หรือเปล่า?',
    answer: 'ไม่ใช่ ส่วนลดซ้อนทับคำนวณจากราคาที่เหลือแต่ละครั้ง เช่น ราคา 2,000 ลด 10% = 1,800 แล้วลด 5% = 1,710 (ไม่ใช่ 1,700)',
  },
  {
    question: 'โปรโมชั่น Buy 2 Get 1 Free คิดเป็นส่วนลดกี่เปอร์เซ็นต์?',
    answer: 'คิดเป็นส่วนลดประมาณ 33.3% เพราะซื้อ 3 ชิ้นในราคา 2 ชิ้น',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    คำนวณส่วนลด 20% ของ 1,500 บาท และสูตรลดราคาที่ควรรู้ก่อนช้อป
  </h1>

  <p>
    เวลาไปช้อปปิ้งและเห็นป้าย "ลดราคา 20%" หรือ "แถมฟรี" นักช้อปส่วนใหญ่อยากรู้ว่าจ่ายจริงเท่าไร บทความนี้จะสอนวิธีคำนวณส่วนลด พร้อมตัวอย่างจริงหลายแบบ ตั้งแต่ส่วนลดเดี่ยว ส่วนลดแบบสะสม ไปจนถึงสูตรลดราคาที่อื่นๆ
  </p>

  <ArticleCalculatorCTA
    title="เครื่องคำนวณเปอร์เซ็นต์และส่วนลด"
    description="คำนวณส่วนลด ราคาหลังลด และเปอร์เซ็นต์ทุกรูปแบบ"
    href="/คำนวณเปอร์เซ็นต์/"
    buttonLabel="คำนวณส่วนลดฟรี"
  />

  <h2>คำนวณส่วนลด 20% ของ 1,500 บาท</h2>

  <p>สมมติว่ากระเป๋าราคา 1,500 บาท มีป้ายลด 20% เรามาคำนวณกัน:</p>

  <ol>
    <li><strong>คำนวณจำนวนลด:</strong> 20% × 1,500 = (20 ÷ 100) × 1,500 = <strong>300 บาท</strong></li>
    <li><strong>คำนวณราคาที่จ่ายจริง:</strong> 1,500 - 300 = <strong>1,200 บาท</strong></li>
  </ol>

  <p>ดังนั้น <strong>คุณจะจ่ายเพียง 1,200 บาท</strong> เซฟได้ 300 บาท</p>

  <h2>โปรโมชั่นและสูตรลดราคาแบบต่างๆ</h2>

  <h3>1. ลดราคาแบบเดี่ยว (Single Discount)</h3>
  <p>เสื้อราคา 800 บาท ลด 30%</p>
  <ul>
    <li>ลดจำนวน = 30% × 800 = 240 บาท</li>
    <li>ราคาสุดท้าย = 800 - 240 = <strong>560 บาท</strong></li>
  </ul>

  <h3>2. ลดราคาซ้อนทับ (Stacking Discounts)</h3>
  <p>สินค้า 2,000 บาท มีส่วนลดจากการค้นหา 10% + ส่วนลดจากคูปอง 5%:</p>
  <ul>
    <li>ส่วนลดแรก: 10% = 200 บาท → เหลือ 1,800 บาท</li>
    <li>ส่วนลดที่สอง: 5% ของ 1,800 = 90 บาท → เหลือ <strong>1,710 บาท</strong></li>
    <li><strong>คำเตือน:</strong> ส่วนลดซ้อนทับไม่ใช่การบวกเปอร์เซ็นต์ แต่คำนวณจากจำนวนที่เหลือแต่ละครั้ง</li>
  </ul>

  <h3>3. โปรโมชั่น Buy 2 Get 1 Free</h3>
  <p>สินค้าราคา 200 บาท ซื้อ 2 ได้ 3:</p>
  <ul>
    <li>ปกติซื้อ 3: 200 × 3 = 600 บาท</li>
    <li>โปรโมชั่นซื้อ 2: 200 × 2 = 400 บาท</li>
    <li>เซฟได้: 200 บาท (คิดเป็น <strong>33.3% ส่วนลด</strong>)</li>
  </ul>

  <h3>4. ลดราคาตามปริมาณซื้อ</h3>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">ปริมาณ</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">ราคาต่อหน่วย</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">1-10 ชิ้น</td><td class="border border-gray-200 px-3 py-2 text-right">100 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">11-20 ชิ้น</td><td class="border border-gray-200 px-3 py-2 text-right">95 บาท (ลด 5%)</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">21+ ชิ้น</td><td class="border border-gray-200 px-3 py-2 text-right">90 บาท (ลด 10%)</td></tr>
      </tbody>
    </table>
  </div>

  <h2>เคล็ดลับการเลือกซื้อของให้คุ้มค่า</h2>

  <ol>
    <li><strong>เปรียบเทียบราคา</strong> — เช็คราคาเดิมก่อน เพื่อรู้ว่าส่วนลดจริงคือเท่าไร</li>
    <li><strong>รู้จักส่วนลดซ้อนทับ</strong> — ส่วนลดหลายชั้นไม่ใช่การบวกกัน</li>
    <li><strong>ตรวจสอบเงื่อนไขวาวเชอร์</strong> — มักมีขั้นต่ำในการซื้อ</li>
    <li><strong>ซื้อตามแผน</strong> — ไม่ซื้อเพราะการลดราคา ซื้อสิ่งที่ต้องการจริงๆ</li>
  </ol>

  <ArticleCalculatorCTA
    title="คำนวณส่วนลดทุกรูปแบบ"
    description="ใส่ราคาและเปอร์เซ็นต์ส่วนลด ได้ผลลัพธ์ทันที"
    href="/คำนวณเปอร์เซ็นต์/"
    buttonLabel="เปิดเครื่องคำนวณ"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
