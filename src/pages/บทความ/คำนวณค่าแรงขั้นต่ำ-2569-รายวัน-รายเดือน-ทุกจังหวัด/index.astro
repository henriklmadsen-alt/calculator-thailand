---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าแรงขั้นต่ำ 2569 | รายวัน รายเดือน ค่าโอที ทุกจังหวัด | เครื่องคำนวณไทย';
const description = 'สรุปอัตราค่าแรงขั้นต่ำปี 2569 ทั้ง 77 จังหวัด พร้อมวิธีคำนวณค่าจ้างรายเดือน ค่าโอที 1.5-3 เท่า และตัวอย่างจริงเป็นเงินบาท อ้างอิงประกาศคณะกรรมการค่าจ้าง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าแรงขั้นต่ำ-2569-รายวัน-รายเดือน-ทุกจังหวัด/`;

const faqData = [
  {
    question: 'ค่าแรงขั้นต่ำปี 2569 กรุงเทพเท่าไร?',
    answer: 'ค่าแรงขั้นต่ำกรุงเทพฯ ปี 2569 อยู่ที่ 400 บาทต่อวัน ตามประกาศคณะกรรมการค่าจ้าง ฉบับที่ 14 มีผลบังคับใช้ 1 กรกฎาคม 2568',
  },
  {
    question: 'ค่าแรงขั้นต่ำต่างจังหวัดเท่ากันหมดไหม?',
    answer: 'ไม่เท่ากัน มีหลายอัตราตั้งแต่ 337 ถึง 400 บาทต่อวัน ขึ้นอยู่กับจังหวัด โดยกรุงเทพ ชลบุรี ระยอง ภูเก็ต เกาะสมุย อยู่ที่ 400 บาท',
  },
  {
    question: 'คิดค่าแรงขั้นต่ำเป็นรายเดือนได้ยังไง?',
    answer: 'นำค่าแรงรายวันคูณจำนวนวันทำงานต่อเดือน เช่น 400 × 26 = 10,400 บาท หรือ 400 × 22 = 8,800 บาท ขึ้นอยู่กับจำนวนวันทำงานจริง',
  },
  {
    question: 'ค่าแรงขั้นต่ำครอบคลุมค่าโอทีด้วยไหม?',
    answer: 'ไม่ครอบคลุม ค่าโอทีเป็นค่าตอบแทนที่แยกต่างหากตาม พ.ร.บ. คุ้มครองแรงงาน มาตรา 61-63 คิดเป็น 1.5 เท่า 2 เท่า หรือ 3 เท่าของค่าจ้างต่อชั่วโมงตามประเภทงาน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-20"
  modifiedDate="2026-04-20"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    ค่าแรงขั้นต่ำ 2569: อัตรารายวัน รายเดือน พร้อมค่าโอที ทุกจังหวัด
  </h1>

  <p>
    ค่าแรงขั้นต่ำเป็นฐานสำคัญที่มีผลต่อทั้งลูกจ้างและนายจ้าง ตั้งแต่เงินเดือน ค่าล่วงเวลา ไปจนถึงเงินสมทบประกันสังคม
    บทความนี้สรุปอัตราค่าแรงขั้นต่ำปี 2569 ทั้ง 77 จังหวัด พร้อมวิธีแปลงเป็นรายเดือน
    คำนวณค่าโอที และตัวอย่างจริงเป็นเงินบาท อ้างอิงจากประกาศคณะกรรมการค่าจ้าง ฉบับที่ 14
  </p>

  <ArticleCalculatorCTA
    title="คำนวณค่าแรงขั้นต่ำของจังหวัดคุณ"
    description="เลือกจังหวัด ระบุวันทำงาน และชั่วโมงโอที เพื่อดูรายได้ต่อเดือนทันที"
    href="/คำนวณค่าแรงขั้นต่ำ/"
    buttonLabel="ไปที่เครื่องคำนวณค่าแรงขั้นต่ำ"
  />

  <h2>อัตราค่าแรงขั้นต่ำ 2569 ตามกลุ่มจังหวัด</h2>

  <p>
    ค่าแรงขั้นต่ำในไทยไม่ได้เป็นอัตราเดียวกันทั้งประเทศ แต่แบ่งตามกลุ่มจังหวัด
    ตามประกาศคณะกรรมการค่าจ้าง ฉบับที่ 14 มีผลบังคับใช้ตั้งแต่ 1 กรกฎาคม 2568
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[560px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">อัตรา (บาท/วัน)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">จังหวัดตัวอย่าง</th>
          <th class="border border-gray-200 px-3 py-2 text-left">รายเดือน (26 วัน)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2"><strong>400</strong></td>
          <td class="border border-gray-200 px-3 py-2">กรุงเทพ, ชลบุรี, ระยอง, ภูเก็ต, ฉะเชิงเทรา, เกาะสมุย</td>
          <td class="border border-gray-200 px-3 py-2">10,400</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2"><strong>380–395</strong></td>
          <td class="border border-gray-200 px-3 py-2">นนทบุรี, ปทุมธานี, สมุทรปราการ, เชียงใหม่, นครราชสีมา</td>
          <td class="border border-gray-200 px-3 py-2">9,880–10,270</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2"><strong>355–375</strong></td>
          <td class="border border-gray-200 px-3 py-2">ขอนแก่น, อุดรธานี, เชียงราย, สุราษฎร์ธานี</td>
          <td class="border border-gray-200 px-3 py-2">9,230–9,750</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2"><strong>337–354</strong></td>
          <td class="border border-gray-200 px-3 py-2">นราธิวาส, ปัตตานี, ยะลา, แม่ฮ่องสอน</td>
          <td class="border border-gray-200 px-3 py-2">8,762–9,204</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p>
    ส่วนต่างระหว่างจังหวัดที่สูงสุดและต่ำสุดคือ 400 – 337 = <strong>63 บาทต่อวัน</strong>
    หรือประมาณ 1,638 บาทต่อเดือน (คิดที่ 26 วันทำงาน) ซึ่งมีผลต่อการตัดสินใจเลือกพื้นที่ทำงาน
  </p>

  <h2>วิธีแปลงค่าแรงขั้นต่ำรายวันเป็นรายเดือน</h2>

  <p>
    สูตรง่าย: <strong>เงินเดือน = ค่าแรงรายวัน × จำนวนวันทำงานต่อเดือน</strong>
  </p>

  <p>
    จำนวนวันทำงานขึ้นอยู่กับนโยบายบริษัท ส่วนใหญ่อยู่ระหว่าง 22–26 วัน:
  </p>

  <ul>
    <li>ทำงาน 5 วัน/สัปดาห์ ≈ 22 วัน/เดือน</li>
    <li>ทำงาน 6 วัน/สัปดาห์ ≈ 26 วัน/เดือน</li>
  </ul>

  <h3>ตัวอย่าง: กรุงเทพ 400 บาท/วัน</h3>

  <ul>
    <li>ทำงาน 22 วัน: 400 × 22 = <strong>8,800 บาท/เดือน</strong></li>
    <li>ทำงาน 26 วัน: 400 × 26 = <strong>10,400 บาท/เดือน</strong></li>
  </ul>

  <h2>คำนวณค่าโอทีจากฐานค่าแรงขั้นต่ำ</h2>

  <p>
    ค่าโอทีคำนวณจากค่าจ้างต่อชั่วโมง ซึ่งได้จาก ค่าจ้างรายวัน ÷ 8 ชั่วโมง
    จากนั้นคูณตัวคูณตามประเภทงานตาม พ.ร.บ. คุ้มครองแรงงาน มาตรา 61–63:
  </p>

  <ul>
    <li><strong>OT วันทำงานปกติ:</strong> ค่าจ้าง/ชม. × 1.5 (มาตรา 61)</li>
    <li><strong>ค่าทำงานวันหยุด:</strong> ค่าจ้าง/ชม. × 2 (มาตรา 62)</li>
    <li><strong>OT วันหยุด:</strong> ค่าจ้าง/ชม. × 3 (มาตรา 63)</li>
  </ul>

  <h3>ตัวอย่าง: ค่าแรง 400 บาท/วัน ทำ OT วันทำงาน 2 ชม.</h3>

  <ol>
    <li>ค่าจ้างต่อชั่วโมง: 400 ÷ 8 = <strong>50 บาท</strong></li>
    <li>ค่า OT: 50 × 1.5 × 2 = <strong>150 บาท</strong></li>
  </ol>

  <p>
    ถ้าทำ OT วันทำงาน 2 ชม. ทุกวัน ตลอด 22 วัน ค่าโอทีรวม = 150 × 22 = <strong>3,300 บาท/เดือน</strong>
  </p>

  <ArticleCalculatorCTA
    title="ลองคำนวณค่าแรงขั้นต่ำ + โอทีของคุณ"
    description="เลือกจังหวัด ระบุวันทำงานและชั่วโมงโอที เพื่อดูรายได้รวมต่อเดือน"
    href="/คำนวณค่าแรงขั้นต่ำ/"
    buttonLabel="เปิดเครื่องคำนวณค่าแรงขั้นต่ำ"
  />

  <h2>ตัวอย่างคำนวณรายได้รวมต่อเดือน (รวมโอที)</h2>

  <p>
    สมมติพนักงานรับค่าแรงขั้นต่ำ กรุงเทพ 400 บาท/วัน ทำงาน 26 วัน
    มี OT วันทำงาน 10 ชม. และทำงานวันหยุด 8 ชม. ต่อเดือน:
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[560px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">รายการ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">การคำนวณ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">จำนวนเงิน</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ค่าจ้างรายเดือน</td>
          <td class="border border-gray-200 px-3 py-2">400 × 26</td>
          <td class="border border-gray-200 px-3 py-2">10,400 บาท</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">OT วันทำงาน (10 ชม.)</td>
          <td class="border border-gray-200 px-3 py-2">50 × 1.5 × 10</td>
          <td class="border border-gray-200 px-3 py-2">750 บาท</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ค่าทำงานวันหยุด (8 ชม.)</td>
          <td class="border border-gray-200 px-3 py-2">50 × 2 × 8</td>
          <td class="border border-gray-200 px-3 py-2">800 บาท</td>
        </tr>
        <tr class="font-bold bg-green-50">
          <td class="border border-gray-200 px-3 py-2">รวมรายได้ต่อเดือน</td>
          <td class="border border-gray-200 px-3 py-2"></td>
          <td class="border border-gray-200 px-3 py-2">11,950 บาท</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>ค่าแรงขั้นต่ำกับเงินสมทบประกันสังคม</h2>

  <p>
    ลูกจ้างที่รับค่าแรงขั้นต่ำต้องจ่ายเงินสมทบประกันสังคม (มาตรา 33) ที่ 5% ของเงินเดือน
    โดยมีเพดานค่าจ้างที่ 15,000 บาท (สมทบสูงสุด 750 บาท/เดือน)
  </p>

  <ul>
    <li>เงินเดือน 10,400 บาท → สมทบ 5% = <strong>520 บาท/เดือน</strong></li>
    <li>เงินเดือน 8,800 บาท → สมทบ 5% = <strong>440 บาท/เดือน</strong></li>
  </ul>

  <p>
    นายจ้างสมทบเพิ่มอีก 5% ในอัตราเดียวกัน
    ลูกจ้างที่รับค่าแรงขั้นต่ำจะไม่ถึงเพดานสมทบ 750 บาท จึงคำนวณจากเงินเดือนจริง
  </p>

  <h2>ข้อผิดพลาดที่พบบ่อย</h2>

  <ol>
    <li>
      <strong>ใช้อัตราค่าแรงผิดจังหวัด:</strong> ค่าแรงขั้นต่ำต่างกันตามจังหวัด
      หากย้ายที่ทำงานต้องเช็กอัตราใหม่
    </li>
    <li>
      <strong>คิดว่าค่าโอทีรวมในค่าแรงขั้นต่ำแล้ว:</strong> ค่าโอทีเป็นสิทธิแยกต่างหาก
      นายจ้างไม่สามารถนำค่าโอทีมารวมเป็นค่าแรงขั้นต่ำได้
    </li>
    <li>
      <strong>ไม่แยกประเภทโอที:</strong> ตัวคูณ 1.5 / 2 / 3 เท่าใช้คนละกรณี
      การใช้ 1.5 เท่ากับทุกสถานการณ์ทำให้ได้เงินน้อยกว่าที่ควร
    </li>
    <li>
      <strong>ใช้จำนวนวันทำงานไม่ตรงจริง:</strong> จำนวนวันทำงาน 22 หรือ 26 วัน
      มีผลต่อเงินเดือนรวมค่อนข้างมาก ต้องนับจากวันทำงานจริง
    </li>
  </ol>

  <h2>สิทธิของลูกจ้างที่ควรรู้ตาม พ.ร.บ. คุ้มครองแรงงาน</h2>

  <ul>
    <li>นายจ้างต้องจ่ายค่าจ้างไม่ต่ำกว่าค่าแรงขั้นต่ำตามจังหวัดที่ทำงาน</li>
    <li>ค่าล่วงเวลาต้องจ่ายไม่น้อยกว่าอัตราตามกฎหมาย (1.5 / 2 / 3 เท่า)</li>
    <li>ลูกจ้างมีสิทธิหยุดพักอย่างน้อย 1 ชม./วัน หลังทำงานต่อเนื่อง 5 ชม.</li>
    <li>วันหยุดประจำสัปดาห์อย่างน้อย 1 วัน/สัปดาห์ ห่างกันไม่เกิน 6 วัน</li>
    <li>หากนายจ้างจ่ายต่ำกว่าค่าแรงขั้นต่ำ ลูกจ้างร้องเรียนได้ที่สายด่วนแรงงาน 1506</li>
  </ul>

