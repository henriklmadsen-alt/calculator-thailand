---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'เงินเดือนสุทธิ คืออะไร ต่างจากเงินเดือนรวมอย่างไร ปี 2569 | เครื่องคำนวณไทย';
const description = 'อธิบายความต่างระหว่างเงินเดือนรวม (Gross Salary) และเงินเดือนสุทธิ (Net Salary) ปี 2569 การหักประกันสังคม ภาษี กองทุนสำรองเลี้ยงชีพ พร้อมตัวอย่างคำนวณ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/เงินเดือนสุทธิ-คืออะไร/`;

const faqData = [
  {
    question: 'เงินเดือนสุทธิแตกต่างจากเงินเดือนรวมอย่างไร?',
    answer: 'เงินเดือนรวม (Gross) คือจำนวนที่นายจ้างตกลงจ่ายก่อนหักใดๆ เงินเดือนสุทธิ (Net) คือเงินที่ได้รับจริงหลังหักประกันสังคม ภาษี และกองทุนสำรองเลี้ยงชีพ',
  },
  {
    question: 'เงินเดือน 40,000 บาท จะหักอะไรบ้าง?',
    answer: 'หักประกันสังคม (3%): 1,200 บาท หักภาษีเงินได้: ประมาณ 1,625 บาท/เดือน รวมหัก ≈ 2,825 บาท เงินสุทธิประมาณ 37,175 บาท',
  },
  {
    question: 'กองทุนสำรองเลี้ยงชีพบังคับหักหรือเปล่า?',
    answer: 'ไม่บังคับ เป็นการสมัครใจ ปกติหัก 3-5% ของเงินเดือน นายจ้างจะสมทบเพิ่มตามสัญญา เงินนี้จะสะสมเพื่อใช้ยามเกษียณ',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    เงินเดือนสุทธิ คืออะไร ต่างจากเงินเดือนรวมอย่างไร ปี 2569
  </h1>

  <p>
    เมื่อได้เงินเดือนจากนายจ้าง ตัวเลขที่ปรากฏในสลีปเงินเดือนและตัวเลขที่ได้รับจริงในบัญชีธนาคารอาจต่างกัน สาเหตุมาจากการหักเงินหลายอย่าง เช่น ประกันสังคม ภาษี และกองทุนสำรองเลี้ยงชีพ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณเงินเดือนสุทธิ"
    description="ใส่เงินเดือนรวม คำนวณเงินที่ได้รับจริงหลังหักทุกรายการ"
    href="/คำนวณเงินเดือนสุทธิ/"
    buttonLabel="คำนวณเงินเดือนสุทธิฟรี"
  />

  <h2>เงินเดือนรวม (Gross Salary) คืออะไร</h2>

  <p>
    เงินเดือนรวมคือจำนวนเงินที่นายจ้างตกลงจ่ายให้คุณก่อนการหักเงิน นี่คือตัวเลขทั้งหมดที่ปรากฏในสัญญาจ้างงาน
  </p>

  <h2>เงินเดือนสุทธิ (Net Salary) คืออะไร</h2>

  <p>
    เงินเดือนสุทธิคือเงินที่ได้รับจริงสุดท้าย หลังจากหักเงินต่างๆ นี่คือเงินที่สามารถนำไปใช้จ่ายส่วนตัวได้
  </p>

  <p>ตัวอย่าง: เงินเดือนรวม 40,000 บาท → หักเบี้ยและภาษี → <strong>เงินเดือนสุทธิ ≈ 37,175 บาท</strong></p>

  <h2>สิ่งที่ถูกหักออกจากเงินเดือนรวม</h2>

  <h3>1. ประกันสังคม (SSO)</h3>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">ประเภท</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">อัตรา</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">ตัวอย่าง (40,000 บาท)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">หักจากพนักงาน</td><td class="border border-gray-200 px-3 py-2 text-right">3%</td><td class="border border-gray-200 px-3 py-2 text-right">1,200 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">หักจากนายจ้าง</td><td class="border border-gray-200 px-3 py-2 text-right">5%</td><td class="border border-gray-200 px-3 py-2 text-right">2,000 บาท (นายจ้างจ่าย)</td></tr>
      </tbody>
    </table>
  </div>

  <h3>2. ภาษีเงินได้ (Personal Income Tax)</h3>

  <p>สำหรับเงินเดือน 40,000 บาท คนเดี่ยว ภาษีรายเดือน ≈ <strong>1,625 บาท</strong></p>

  <h3>3. กองทุนสำรองเลี้ยงชีพ (สมัครใจ)</h3>

  <p>ปกติหัก 3-5% ของเงินเดือน เช่น 3% ของ 40,000 = 1,200 บาท/เดือน</p>

  <h2>ตัวอย่างการคำนวณเงินเดือนสุทธิ: 40,000 บาท</h2>

  <ul>
    <li>เงินเดือนรวม: 40,000 บาท</li>
    <li>หัก SSO (3%): 1,200 บาท</li>
    <li>หักภาษี: 1,625 บาท</li>
    <li><strong>เงินเดือนสุทธิ (ไม่มีกองทุน): 37,175 บาท</strong></li>
    <li>หากสมัครกองทุน 3%: 37,175 - 1,200 = <strong>35,975 บาท</strong></li>
  </ul>

  <ArticleCalculatorCTA
    title="คำนวณเงินเดือนสุทธิของคุณ"
    description="ใส่เงินเดือน เลือกสถานะ ดูเงินที่ได้รับจริงทันที"
    href="/คำนวณเงินเดือนสุทธิ/"
    buttonLabel="คำนวณตอนนี้"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
