---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'ภาษีมูลค่าเพิ่ม 7% คิดยังไง 2569: สูตรบวกภาษี ถอดภาษี ตั้งราคาขายไม่ขาดทุน | เครื่องคำนวณไทย';
const description = 'สรุปวิธีคิด VAT 7% ปี 2569 ทั้งสูตรบวกและสูตรถอด พร้อมตัวอย่างตั้งราคา ข้อพลาดที่พบบ่อย ลิงก์คำนวณต่อ และแหล่งอ้างอิงกรมสรรพากร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ภาษีมูลค่าเพิ่ม-7-คิดยังไง-สูตรบวกภาษี-ถอดภาษี-ตั้งราคาขายให้ไม่ขาดทุน/`;

const faqData = [
  {
    question: 'สูตรบวก VAT 7% ที่ใช้เร็วที่สุดคืออะไร?',
    answer: 'นำราคาก่อน VAT คูณ 1.07 จะได้ราคารวม VAT ทันที ส่วนจำนวน VAT เท่ากับราคาก่อน VAT คูณ 0.07',
  },
  {
    question: 'สูตรถอด VAT จากราคารวมใช้แบบไหน?',
    answer: 'นำราคารวม VAT หาร 1.07 จะได้ราคาก่อน VAT และนำราคารวมลบราคาก่อน VAT จะได้จำนวน VAT',
  },
  {
    question: 'ทำไมบางครั้งตั้งราคาแล้วกำไรหาย?',
    answer: 'สาเหตุหลักคือเผลอบวก VAT ซ้ำ หรือใช้ฐานคำนวณผิด (เอาราคารวม VAT ไปคิดต้นทุนและมาร์จินโดยไม่ถอดภาษีก่อน)',
  },
  {
    question: 'ธุรกิจเล็กควรใช้เครื่องมือคำนวณ VAT ทุกครั้งไหม?',
    answer: 'ควรใช้ทุกครั้งโดยเฉพาะตอนทำใบเสนอราคาและใบกำกับภาษี เพื่อให้ยอดก่อนภาษี ภาษี และยอดรวมตรงกันทุกเอกสาร',
  },
  {
    question: 'VAT 7% ใช้ถึงเมื่อไหร่?',
    answer: 'อัตราตามกฎหมายคือ 10% แต่มีมาตรการลดเหลือ 7% (รวมภาษีท้องถิ่น) โดยประกาศล่าสุดขยายถึงวันที่ 30 กันยายน 2569 และควรตรวจประกาศล่าสุดก่อนใช้งานจริง',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-14"
  modifiedDate="2026-04-19"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    ภาษีมูลค่าเพิ่ม 7% คิดยังไง: สูตรบวกภาษี ถอดภาษี และตั้งราคาขายให้ไม่ขาดทุน
  </h1>

  <p>
    ถ้าคุณออกใบเสนอราคา ออกบิล หรือขายของทุกวัน การคิด VAT ให้ถูกต้องคือเรื่องที่พลาดไม่ได้
    บทความนี้รวมสูตรที่ใช้จริงพร้อมตัวอย่างที่นำไปใช้ได้ทันที เพื่อช่วยลดข้อผิดพลาดทางบัญชีและกำไรที่หายไปโดยไม่รู้ตัว
  </p>

  <ArticleCalculatorCTA
    title="คำนวณ VAT 7% ด้วยข้อมูลจริงของคุณ"
    description="เลือกโหมดบวก VAT หรือถอด VAT แล้วคำนวณได้ทั้งรายการเดียวและหลายรายการ"
    href="/คำนวณภาษีมูลค่าเพิ่ม/"
    buttonLabel="ไปที่คำนวณ VAT 7%"
  />

  <h2>อัตรา VAT ปี 2569 ที่ต้องใช้ก่อนเริ่มคำนวณ</h2>

  <p>
    ก่อนลงสูตร ควรกำหนดอัตราภาษีให้ตรงช่วงเวลาใช้งานจริงก่อนเสมอ ปัจจุบันอัตราภาษีมูลค่าเพิ่มที่ใช้งานทั่วไปคือ 7%
    (รวมภาษีท้องถิ่น) โดยประกาศล่าสุดขยายถึงวันที่ 30 กันยายน 2569
    ถ้าคุณออกเอกสารขายในช่วงเวลาหลังจากนั้น ควรตรวจประกาศล่าสุดของกรมสรรพากรอีกครั้งเพื่อป้องกันการใช้อัตราผิด
  </p>

  <p>
    ถ้าต้องคำนวณเร็วในงานจริง ให้เริ่มที่
    <a href="/คำนวณภาษีมูลค่าเพิ่ม/" data-preserve-utm>เครื่องคำนวณภาษีมูลค่าเพิ่ม</a>
    แล้วค่อยย้อนกลับมาตรวจหลักการและจุดพลาดจากบทความนี้
  </p>

  <h2>สูตรบวก VAT และสูตรถอด VAT (พร้อมตัวอย่าง)</h2>

  <h3>1) สูตรบวก VAT (จากราคาก่อนภาษี)</h3>
  <ul>
    <li>VAT = ราคาก่อนภาษี x 0.07</li>
    <li>ราคารวม VAT = ราคาก่อนภาษี x 1.07</li>
  </ul>

  <p>
    ตัวอย่าง: ราคาสินค้า 5,000 บาท
    VAT = 5,000 x 0.07 = 350 บาท
    ราคารวม VAT = 5,350 บาท
  </p>

  <p>
    หลังจากลองสูตรมือแล้ว ให้ตรวจความถูกต้องด้วย
    <a href="/คำนวณภาษีมูลค่าเพิ่ม/" data-preserve-utm>เครื่องคำนวณภาษีมูลค่าเพิ่ม</a>
    เพื่อลดความผิดพลาดก่อนออกเอกสารจริง
  </p>

  <h3>2) สูตรถอด VAT (จากราคารวมภาษี)</h3>
  <ul>
    <li>ราคาก่อนภาษี = ราคารวม VAT ÷ 1.07</li>
    <li>VAT = ราคารวม VAT - ราคาก่อนภาษี</li>
  </ul>

  <p>
    ตัวอย่าง: ราคารวม 10,700 บาท
    ราคาก่อนภาษี = 10,700 ÷ 1.07 = 10,000 บาท
    VAT = 700 บาท
  </p>

  <h2>ข้อผิดพลาดที่เจอบ่อย</h2>

  <ul>
    <li>บวก VAT ซ้ำ: เอาราคาที่รวม VAT แล้วไปคูณ 1.07 อีกครั้ง</li>
    <li>ตีความฐานภาษีผิด: ใช้ยอดสุทธิหลังส่วนลดไม่ถูกต้อง</li>
    <li>ตั้งราคาขายจากยอดรวม VAT โดยไม่ถอดภาษีก่อน ทำให้มาร์จินจริงหาย</li>
    <li>ปัดเศษไม่สม่ำเสมอระหว่างระบบขายและระบบบัญชี</li>
  </ul>

  <h2>ตารางตัวอย่างราคา 10 จุด (ก่อนภาษี/หลังภาษี)</h2>

  <table class="w-full text-sm border-collapse my-4">
    <thead>
      <tr class="border-b border-gray-200 text-left">
        <th class="py-2 pr-2">ลำดับ</th>
        <th class="py-2 pr-2 text-right">ก่อน VAT</th>
        <th class="py-2 pr-2 text-right">VAT 7%</th>
        <th class="py-2 text-right">หลัง VAT</th>
      </tr>
    </thead>
    <tbody>
      <tr class="border-b border-gray-100"><td class="py-2 pr-2">1</td><td class="py-2 pr-2 text-right">100</td><td class="py-2 pr-2 text-right">7</td><td class="py-2 text-right">107</td></tr>
      <tr class="border-b border-gray-100"><td class="py-2 pr-2">2</td><td class="py-2 pr-2 text-right">250</td><td class="py-2 pr-2 text-right">17.50</td><td class="py-2 text-right">267.50</td></tr>
      <tr class="border-b border-gray-100"><td class="py-2 pr-2">3</td><td class="py-2 pr-2 text-right">500</td><td class="py-2 pr-2 text-right">35</td><td class="py-2 text-right">535</td></tr>
      <tr class="border-b border-gray-100"><td class="py-2 pr-2">4</td><td class="py-2 pr-2 text-right">750</td><td class="py-2 pr-2 text-right">52.50</td><td class="py-2 text-right">802.50</td></tr>
      <tr class="border-b border-gray-100"><td class="py-2 pr-2">5</td><td class="py-2 pr-2 text-right">1,000</td><td class="py-2 pr-2 text-right">70</td><td class="py-2 text-right">1,070</td></tr>
      <tr class="border-b border-gray-100"><td class="py-2 pr-2">6</td><td class="py-2 pr-2 text-right">1,500</td><td class="py-2 pr-2 text-right">105</td><td class="py-2 text-right">1,605</td></tr>
      <tr class="border-b border-gray-100"><td class="py-2 pr-2">7</td><td class="py-2 pr-2 text-right">2,000</td><td class="py-2 pr-2 text-right">140</td><td class="py-2 text-right">2,140</td></tr>
      <tr class="border-b border-gray-100"><td class="py-2 pr-2">8</td><td class="py-2 pr-2 text-right">2,500</td><td class="py-2 pr-2 text-right">175</td><td class="py-2 text-right">2,675</td></tr>
      <tr class="border-b border-gray-100"><td class="py-2 pr-2">9</td><td class="py-2 pr-2 text-right">5,000</td><td class="py-2 pr-2 text-right">350</td><td class="py-2 text-right">5,350</td></tr>
      <tr><td class="py-2 pr-2">10</td><td class="py-2 pr-2 text-right">10,000</td><td class="py-2 pr-2 text-right">700</td><td class="py-2 text-right">10,700</td></tr>
    </tbody>
  </table>

  <p>
    ถ้าคุณเป็นเจ้าของกิจการและต้องวางแผนค่าจ้างสุทธิของตัวเองต่อ ควรเช็กผลกระทบรายรับหลังภาษีร่วมด้วย
    โดยต่อไปที่ <a href="/คำนวณเงินเดือนสุทธิ/" data-preserve-utm>คำนวณเงินเดือนสุทธิ</a>
  </p>

  <p>
    ในกรณีที่ต้องตั้งราคาโดยล็อกมาร์จินเป้าหมาย (เช่น ต้องการกำไร 35% หลังถอด VAT)
    ให้ใช้ <a href="/คำนวณเปอร์เซ็นต์/" data-preserve-utm>คำนวณเปอร์เซ็นต์</a> ต่อจากผลลัพธ์ VAT
    เพื่อแยกขั้นภาษีออกจากขั้นมาร์จินอย่างชัดเจน
  </p>

  <ArticleCalculatorCTA
    title="ขั้นตอนถัดไป: วางแผนเงินเดือนสุทธิหลังภาษี"
    description="ดูรายรับสุทธิหลังหักภาษีและประกันสังคม เพื่อเช็กเงินที่ใช้ได้จริง"
    href="/คำนวณเงินเดือนสุทธิ/"
    buttonLabel="ไปที่คำนวณเงินเดือนสุทธิ"
  />

  <h2>เกณฑ์จด VAT และข้อยกเว้นที่ต้องเช็กก่อนออกเอกสาร</h2>

  <p>
    หากกิจการมีมูลค่าฐานภาษีเกิน 1,800,000 บาทต่อปี จะเข้าหลักเกณฑ์จดทะเบียน VAT และต้องจัดการเอกสารภาษีให้ครบตามกฎหมาย
    ส่วนกิจการที่ได้รับยกเว้นต้องตรวจเงื่อนไขตามมาตรา 81(1) และมาตรา 81/1 ให้ชัดก่อนออกใบกำกับภาษี
    เพราะการตีความประเภทกิจการผิดเพียงจุดเดียวอาจทำให้ยอดภาษีและเอกสารคลาดเคลื่อนทั้งระบบ
  </p>

  <h2>แหล่งอ้างอิงทางการ (สูตรและกติกา VAT)</h2>

  <ul>
    <li>
      กรมสรรพากร: ข่าว ปชส. 34/2568 ขยาย VAT 7% ถึงวันที่ 30 กันยายน 2569
      <a href="https://www.rd.go.th/fileadmin/user_upload/news/2568thai/news34_2568.pdf" target="_blank" rel="noopener noreferrer">
        https://www.rd.go.th/fileadmin/user_upload/news/2568thai/news34_2568.pdf
      </a>
    </li>
    <li>
      กรมสรรพากร: ประมวลรัษฎากร ภาษีมูลค่าเพิ่ม (มาตรา 80-82 และมาตรา 81/1)
      <a href="https://www.rd.go.th/5206.html" target="_blank" rel="noopener noreferrer">
        https://www.rd.go.th/5206.html
      </a>
    </li>
    <li>
      กรมสรรพากร: แนววินิจฉัยกรณีเกณฑ์จดทะเบียน VAT 1,800,000 บาทต่อปี
      <a href="https://www.rd.go.th/27801.html" target="_blank" rel="noopener noreferrer">
        https://www.rd.go.th/27801.html
      </a>
    </li>
  </ul>

  <h2>เครื่องมือที่เกี่ยวข้องในคลัสเตอร์ภาษี</h2>

  <ul>
    <li><a href="/คำนวณภาษีมูลค่าเพิ่ม/" data-preserve-utm>คำนวณภาษีมูลค่าเพิ่ม</a> สำหรับคำนวณบวก/ถอด VAT แบบทันที</li>
    <li><a href="/คำนวณเปอร์เซ็นต์/" data-preserve-utm>คำนวณเปอร์เซ็นต์</a> สำหรับเทียบมาร์จิน ส่วนลด และราคาเป้าหมายหลังภาษี</li>
    <li><a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" data-preserve-utm>คำนวณภาษีเงินได้บุคคลธรรมดา</a> สำหรับเช็กภาษีปลายปีจากกำไรสุทธิ</li>
    <li><a href="/บทความ/ภาษีเงินได้-2569-คำนวณ-วิธีลดหย่อน/" data-preserve-utm>บทความภาษีเงินได้ 2569</a> สำหรับวางแผนลดหย่อนต่อจากการตั้งราคา</li>
  </ul>

  <h2>สรุป</h2>

  <p>
    คิด VAT ให้ถูกต้องต้องเริ่มจากฐานภาษีที่ถูกต้อง เลือกสูตรให้ตรงกรณี (บวกหรือถอด) และตรวจซ้ำก่อนออกเอกสารทุกครั้ง
    แนวทางนี้ช่วยลดงานแก้บิลและปกป้องมาร์จินของธุรกิจได้ทันที
  </p>

  <p>
    เริ่มจาก <a href="/คำนวณภาษีมูลค่าเพิ่ม/" data-preserve-utm>คำนวณภาษีมูลค่าเพิ่ม</a>
    แล้วต่อด้วย <a href="/คำนวณเงินเดือนสุทธิ/" data-preserve-utm>คำนวณเงินเดือนสุทธิ</a>
    เพื่อวางแผนกระแสเงินสดแบบครบขั้นตอน
  </p>

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
