---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าไฟฟ้า 2569 | สูตรคิดค่าไฟบ้าน PEA/MEA + Ft | เครื่องคำนวณไทย';
const description = 'เช็กบิลค่าไฟบ้านปี 2569 แบบทีละขั้น: ค่าไฟฐาน ค่า Ft ค่าบริการ และ VAT 7% พร้อมตัวอย่าง 200/300/400 หน่วย และลิงก์เครื่องคำนวณค่าไฟฟ้า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าไฟฟ้า-2569-สูตร-pea-mea/`;

const faqData = [
  {
    question: 'ค่าไฟ 200 หน่วย กี่บาทในปี 2569?',
    answer:
      'ถ้าใช้ไฟ 200 หน่วยแบบบ้านอยู่อาศัยและใส่ค่า Ft รอบ พ.ค.-ส.ค. 2569 ที่ 0.1623 บาทต่อหน่วย ยอดรวมประมาณ 808.31 บาท แต่ถ้าใช้ Ft 0.0972 บาทต่อหน่วย จะอยู่ราว 794.38 บาท',
  },
  {
    question: 'ค่า Ft คืออะไร และเปลี่ยนเมื่อไหร่?',
    answer:
      'ค่า Ft คือค่าไฟฟ้าผันแปรที่ปรับตามต้นทุนเชื้อเพลิงและระบบไฟฟ้า โดยปกติจะประกาศเป็นรอบทุก 4 เดือน เช่น ม.ค.-เม.ย. 2569 เท่ากับ 0.0972 บาทต่อหน่วย และ พ.ค.-ส.ค. 2569 เท่ากับ 0.1623 บาทต่อหน่วย',
  },
  {
    question: 'ทำไมใช้ไฟเท่าเดิมแต่บิลไม่เท่ากัน?',
    answer:
      'เพราะบิลจริงมีหลายองค์ประกอบ ไม่ใช่เฉพาะหน่วยไฟ เช่น ค่า Ft คนละรอบประกาศ ค่าบริการรายเดือน และ VAT 7% นอกจากนี้จำนวนวันในรอบบิลที่ต่างกันเล็กน้อยก็ทำให้ยอดต่างกันได้',
  },
  {
    question: 'PEA กับ MEA คิดค่าไฟต่างกันไหม?',
    answer:
      'โครงสร้างหลักใกล้เคียงกันสำหรับบ้านอยู่อาศัย แต่ต้องตรวจสอบประกาศที่ใช้อยู่จริงในช่วงเวลานั้น โดยเฉพาะค่า Ft และเงื่อนไขประเภทผู้ใช้ไฟ เพราะการอัปเดตประกาศอาจทำให้ยอดเปลี่ยนได้',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-16"
  modifiedDate="2026-04-19"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    คำนวณค่าไฟฟ้า 2569: สูตรคิดค่าไฟบ้าน PEA/MEA และวิธีเช็กบิลจริง
  </h1>

  <p>
    ถ้าคุณกำลังสงสัยว่าบิลไฟเดือนนี้มาถูกหรือแพงเกินจริง หรืออยากรู้ว่าบ้านใช้ไฟ 200, 300, 400 หน่วยควรจ่ายประมาณเท่าไร
    บทความนี้ออกแบบมาเพื่อช่วยให้คุณ
    <strong>อ่านบิลไฟอย่างเป็นระบบ</strong> และ <strong>คำนวณยอดล่วงหน้าได้เอง</strong>
    โดยใช้สูตรเดียวกับที่ใช้ในทางปฏิบัติจริงของผู้ใช้ไฟบ้านอยู่อาศัยในไทย
    พร้อมตัวอย่างตัวเลขที่ตรวจกลับได้ทีละขั้น เพื่อให้เห็นตั้งแต่ค่าไฟฐาน ค่า Ft ค่าบริการ
    ไปจนถึง VAT 7% ก่อนเป็นยอดสุทธิที่ต้องจ่าย
  </p>

  <p>
    จุดสำคัญที่ทำให้หลายคนคำนวณพลาด คือการเอาแค่หน่วยไฟคูณราคาต่อหน่วยแบบเดียวตลอดทั้งบิล
    ซึ่งไม่ตรงกับโครงสร้างจริงที่เป็นขั้นบันได และยังมีองค์ประกอบอื่นที่ต้องบวกเพิ่มทุกเดือน
    บทความนี้จึงสรุปให้ครบทั้งสูตร ตัวอย่าง 200 หน่วย และแนวทางเทียบเคียง 300 หน่วยกับ 400 หน่วย
    เพื่อให้คุณสามารถนำไปเช็กบิลจริงหรือวางแผนค่าใช้จ่ายครัวเรือนได้ทันที
  </p>

  <ArticleCalculatorCTA
    title="เช็กค่าไฟบ้านของคุณทันที"
    description="กรอกหน่วยไฟจริงของบ้าน แล้วดูยอดประมาณการรวมค่า Ft และ VAT ได้ในหน้าเดียว"
    href="/คำนวณค่าไฟฟ้า/"
    buttonLabel="ไปที่เครื่องคำนวณค่าไฟฟ้า"
  />

  <h2>ค่าไฟฟ้าในไทยคิดจากอะไรบ้าง</h2>

  <p>
    ค่าไฟฟ้าบ้านอยู่อาศัยไม่ได้มีแค่ตัวเลขหน่วยไฟที่เห็นบนบิล แต่ประกอบด้วย 4 ส่วนหลักที่ต้องคำนวณรวมกัน
    หากขาดส่วนใดส่วนหนึ่ง ยอดสุดท้ายจะคลาดเคลื่อนทันที โดยเฉพาะในช่วงที่ค่า Ft ปรับขึ้นหรือปรับลง
    ซึ่งเห็นผลกับยอดชำระจริงค่อนข้างชัด
  </p>

  <ol>
    <li><strong>ค่าไฟฐานแบบขั้นบันได</strong> คิดตามช่วงหน่วยที่ใช้จริง</li>
    <li><strong>ค่าบริการรายเดือน</strong> ขึ้นกับระดับการใช้ไฟในรอบบิล</li>
    <li><strong>ค่า Ft</strong> เป็นค่าผันแปรตามรอบประกาศ</li>
    <li><strong>VAT 7%</strong> คิดจากยอดรวมก่อนภาษี</li>
  </ol>

  <p>
    ในกลุ่มบ้านอยู่อาศัย วิธีคิดค่าไฟฐานต้องแยก 2 กรณีตามหน่วยรวมทั้งเดือน เพราะบิลจริงและเครื่องคำนวณจะสลับใช้อัตราเมื่อยอดเกิน 150 หน่วย
    การแยกกรณีให้ถูกตั้งแต่ต้นช่วยลดความคลาดเคลื่อนของผลลัพธ์ได้มากที่สุด
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[820px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">กรณีผู้ใช้ไฟบ้านอยู่อาศัย</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ช่วงหน่วยไฟ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">อัตรา (บาท/หน่วย)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">ไม่เกิน 150 หน่วย (ประเภท 1.1)</td><td class="border border-gray-200 px-3 py-2">1-15 หน่วย</td><td class="border border-gray-200 px-3 py-2">2.3488</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ไม่เกิน 150 หน่วย (ประเภท 1.1)</td><td class="border border-gray-200 px-3 py-2">16-25 หน่วย</td><td class="border border-gray-200 px-3 py-2">2.9882</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ไม่เกิน 150 หน่วย (ประเภท 1.1)</td><td class="border border-gray-200 px-3 py-2">26-35 หน่วย</td><td class="border border-gray-200 px-3 py-2">3.2405</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ไม่เกิน 150 หน่วย (ประเภท 1.1)</td><td class="border border-gray-200 px-3 py-2">36-100 หน่วย</td><td class="border border-gray-200 px-3 py-2">3.6237</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ไม่เกิน 150 หน่วย (ประเภท 1.1)</td><td class="border border-gray-200 px-3 py-2">101-150 หน่วย</td><td class="border border-gray-200 px-3 py-2">3.7171</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">เกิน 150 หน่วย (ประเภท 1.2)</td><td class="border border-gray-200 px-3 py-2">1-150 หน่วย</td><td class="border border-gray-200 px-3 py-2">3.2484</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">เกิน 150 หน่วย (ประเภท 1.2)</td><td class="border border-gray-200 px-3 py-2">151-400 หน่วย</td><td class="border border-gray-200 px-3 py-2">4.2218</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">เกิน 150 หน่วย (ประเภท 1.2)</td><td class="border border-gray-200 px-3 py-2">401 หน่วยขึ้นไป</td><td class="border border-gray-200 px-3 py-2">4.4217</td></tr>
      </tbody>
    </table>
  </div>

  <p>
    ส่วนค่าบริการรายเดือนของบ้านอยู่อาศัย หากใช้ไฟไม่เกิน 150 หน่วย คิด 8.19 บาทต่อเดือน และถ้าใช้เกิน 150 หน่วย คิด 24.62 บาทต่อเดือน
    ขณะที่ตัวเลือกธุรกิจขนาดเล็กในเครื่องคำนวณ ใช้ค่าบริการ 33.29 บาทต่อเดือน
    สำหรับค่า Ft ล่าสุดที่ต้องใช้ในปี 2569 ตามรอบประกาศที่เกี่ยวข้องคือ
    ม.ค.-เม.ย. 2569 = 0.0972 บาทต่อหน่วย และ พ.ค.-ส.ค. 2569 = 0.1623 บาทต่อหน่วย
    จากนั้นรวมทั้งหมดก่อนคิด VAT 7% ซึ่งปัจจุบันยังใช้อัตรา 7% ตามประกาศที่ขยายถึงวันที่ 30 กันยายน 2569
  </p>

  <h2>สูตรคำนวณค่าไฟฟ้าแบบใช้งานจริง</h2>

  <p>
    เมื่อรู้ส่วนประกอบครบแล้ว สูตรที่ใช้คำนวณแบบตรงไปตรงมาจะมี 2 บรรทัดหลัก และสามารถนำไปทำตารางเปรียบเทียบหลายสถานการณ์ได้ง่าย
    วิธีนี้เหมาะทั้งกับคนที่ต้องการเช็กบิลย้อนหลัง และคนที่ต้องการคาดการณ์ค่าใช้จ่ายล่วงหน้าก่อนถึงรอบจ่ายจริง
  </p>

  <ul>
    <li><strong>ค่าไฟก่อน VAT</strong> = ค่าไฟฐานตามขั้นบันได + ค่าบริการรายเดือน + (หน่วยไฟ x ค่า Ft)</li>
    <li><strong>ค่าไฟสุทธิ</strong> = ค่าไฟก่อน VAT x 1.07</li>
  </ul>

  <p>
    ขั้นที่ต้องละเอียดที่สุดคือการคำนวณค่าไฟฐาน เพราะต้องตัดหน่วยลงแต่ละช่วงอย่างถูกต้อง ไม่ใช่คูณอัตราเดียวทั้งก้อน
    ถ้าคิดผิดจุดนี้ ต่อให้ค่า Ft และ VAT ถูกต้อง ยอดรวมก็ยังคลาดเคลื่อนอยู่ดี
    วิธีที่ปลอดภัยคือจดหน่วยตามช่วงลงทีละบรรทัด แล้วเช็กผลรวมอีกครั้งก่อนคูณ VAT
  </p>

  <h2>ตัวอย่างคำนวณจริง: บ้านใช้ 200 หน่วย</h2>

  <p>
    กรณีตัวอย่างนี้เป็นเคสยอดนิยมที่คนค้นหาบ่อยมาก เพราะหลายบ้านอยู่ในช่วงการใช้ไฟประมาณนี้
    เราจะคำนวณตามสูตรเดียวกับบิลจริง โดยสมมติว่าค่า Ft ที่ใช้คือรอบ พ.ค.-ส.ค. 2569 ที่ 0.1623 บาทต่อหน่วย
    และเป็นผู้ใช้ไฟบ้านอยู่อาศัยทั่วไปที่ใช้เกิน 150 หน่วย
  </p>

  <ul>
    <li>หน่วยไฟที่ใช้: 200 หน่วย</li>
    <li>ค่าไฟฐาน: (150 x 3.2484) + (50 x 4.2218) = 698.35 บาท</li>
    <li>ค่าบริการรายเดือน: 24.62 บาท</li>
    <li>ค่า Ft: 200 x 0.1623 = 32.46 บาท</li>
    <li>รวมก่อน VAT: 698.35 + 24.62 + 32.46 = 755.43 บาท</li>
    <li>VAT 7%: 52.88 บาท</li>
    <li><strong>ยอดรวมโดยประมาณ: 808.31 บาท</strong></li>
  </ul>

  <p>
    จุดที่ควรจำคือ ถ้าค่า Ft เปลี่ยน ยอดรวมจะเปลี่ยนตามทันที แม้จำนวนหน่วยไฟจะเท่าเดิม เช่น
    หากเปลี่ยนไปใช้ Ft รอบ ม.ค.-เม.ย. 2569 ที่ 0.0972 บาทต่อหน่วย ค่า Ft ของ 200 หน่วยจะลดลง
    ทำให้ยอดสุทธิที่ต้องจ่ายต่ำลงจากกรณี 0.1623 บาทต่อหน่วยอย่างมีนัยสำคัญ
    ดังนั้นการอ่านรอบประกาศ Ft ให้ตรงเดือนบิลจริงเป็นขั้นตอนที่ห้ามข้าม
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[760px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">เปรียบเทียบเคส 200 หน่วย</th>
          <th class="border border-gray-200 px-3 py-2 text-left">Ft 0.0972</th>
          <th class="border border-gray-200 px-3 py-2 text-left">Ft 0.1623</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">ค่าไฟฐาน</td><td class="border border-gray-200 px-3 py-2">698.35</td><td class="border border-gray-200 px-3 py-2">698.35</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ค่าบริการ</td><td class="border border-gray-200 px-3 py-2">24.62</td><td class="border border-gray-200 px-3 py-2">24.62</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ค่า Ft</td><td class="border border-gray-200 px-3 py-2">19.44</td><td class="border border-gray-200 px-3 py-2">32.46</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">รวมก่อน VAT</td><td class="border border-gray-200 px-3 py-2">742.41</td><td class="border border-gray-200 px-3 py-2">755.43</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">VAT 7%</td><td class="border border-gray-200 px-3 py-2">51.97</td><td class="border border-gray-200 px-3 py-2">52.88</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2"><strong>ยอดสุทธิ</strong></td><td class="border border-gray-200 px-3 py-2"><strong>794.38</strong></td><td class="border border-gray-200 px-3 py-2"><strong>808.31</strong></td></tr>
      </tbody>
    </table>
  </div>

  <h2>ค่าไฟ 300 หน่วย และ 400 หน่วย ควรประเมินอย่างไร</h2>

  <p>
    ถ้าบ้านของคุณใช้ไฟมากกว่า 200 หน่วยเป็นประจำ วิธีคิดยังใช้สูตรเดิมทุกประการ เพียงแต่จำนวนหน่วยในช่วง 151 ถึง 400 จะมากขึ้น
    และทำให้ค่าไฟฐานรวมสูงขึ้นแบบต่อเนื่อง ยิ่งใช้ใกล้ 400 หน่วย ยอดรวมยิ่งไวต่อการเปลี่ยนค่า Ft มากขึ้น
    จึงควรทำประมาณการหลายฉากทัศน์ เช่น Ft ต่ำสุดในรอบปี และ Ft รอบล่าสุด เพื่อเตรียมงบให้พอ
  </p>

  <p>
    แนวทางปฏิบัติที่ช่วยได้จริงคือเก็บหน่วยไฟย้อนหลังอย่างน้อย 6 เดือน แล้วดูว่าบ้านมีรูปแบบใช้ไฟตามฤดูกาลหรือไม่
    เช่น ช่วงอากาศร้อนเปิดแอร์นานขึ้น หรือช่วงที่มีสมาชิกอยู่บ้านทั้งวัน ทำให้หน่วยเฉลี่ยกระโดด
    เมื่อเห็นแนวโน้มแล้วค่อยเอาหน่วยเฉลี่ยไปยิงในเครื่องคำนวณ จะได้งบที่ใกล้บิลจริงกว่าการเดาแบบเดือนต่อเดือน
  </p>

  <h2>จุดที่คนคำนวณค่าไฟพลาดบ่อย</h2>

  <ol>
    <li><strong>ใช้อัตราไม่ตรงกรณี</strong> โดยเฉพาะสับสนระหว่างกรณีไม่เกิน 150 หน่วยกับเกิน 150 หน่วย</li>
    <li><strong>ลืมบวกค่า Ft</strong> หรือใช้ค่า Ft คนละรอบประกาศกับเดือนบิล</li>
    <li><strong>ลืมค่าบริการรายเดือน</strong> ทำให้ยอดต่ำกว่าความจริงทุกครั้ง</li>
    <li><strong>คิด VAT จากฐานผิด</strong> VAT ต้องคิดจากผลรวมก่อนภาษีทั้งหมด ไม่ใช่เฉพาะค่าไฟฐาน</li>
    <li><strong>ไม่ตรวจรอบบิล</strong> รอบบิลยาวหรือสั้นกว่าปกติอาจทำให้หน่วยใช้ไฟเปลี่ยนและยอดคลาดเคลื่อน</li>
  </ol>

  <p>
    ถ้าคุณต้องการให้ผลใกล้เคียงบิลจริงมากขึ้น ให้เตรียมข้อมูลแค่ 3 อย่างคือ หน่วยไฟล่าสุด ค่า Ft ที่ตรงรอบบิล และประเภทผู้ใช้ไฟ
    จากนั้นคำนวณตามสูตรทีละขั้น และตรวจผลรวมก่อน VAT ก่อนเสมอ
    วิธีนี้ลดความผิดพลาดได้มากกว่าการคูณลัดแบบหน่วยเดียว และช่วยให้เห็นว่าบิลขึ้นเพราะส่วนไหนเป็นหลัก
  </p>

  <h2>วิธีเช็กบิลค่าไฟทีละบรรทัดให้แม่นขึ้น</h2>

  <p>
    สำหรับคนที่อยากตรวจความถูกต้องของบิลจริง แนะนำให้ใช้วิธีเทียบข้อมูลจากบิลกับสูตรในบทความแบบทีละบรรทัด
    โดยเริ่มจากยืนยันหน่วยใช้ไฟรวมในรอบนั้นก่อน แล้วเช็กว่ารอบบิลอยู่ในช่วงประกาศ Ft ใด
    หลังจากนั้นแยกคำนวณค่าไฟฐาน ค่าบริการ และค่า Ft เป็นคนละช่องให้ชัด
    วิธีนี้ช่วยลดข้อผิดพลาดจากการรวมตัวเลขเร็วเกินไป และทำให้รู้ทันทีว่าความคลาดเคลื่อนมาจากจุดไหน
  </p>

  <ol>
    <li>ดูหน่วยใช้ไฟรวมบนบิล แล้วแยกหน่วยเข้าช่วงอัตราให้ครบทุกขั้น</li>
    <li>ยืนยันค่าบริการว่าอยู่กลุ่มไม่เกิน 150 หน่วยหรือเกิน 150 หน่วย</li>
    <li>ตรวจรอบเดือนของบิลและจับคู่ค่า Ft ให้ตรงประกาศรอบนั้น</li>
    <li>รวมยอดก่อน VAT และคูณ 1.07 เป็นขั้นตอนสุดท้ายเท่านั้น</li>
    <li>เทียบผลลัพธ์กับบิลจริง โดยยอมให้ต่างได้เล็กน้อยจากการปัดเศษ</li>
  </ol>

  <p>
    หากคุณเก็บบิลย้อนหลังไว้ การทำตารางเทียบ 3 ถึง 6 เดือนจะเห็นแนวโน้มชัดว่าเดือนใดใช้ไฟพุ่งและเกิดจากอะไร
    เช่น พฤติกรรมใช้แอร์ยาวขึ้น การทำงานจากบ้าน หรือมีสมาชิกอยู่บ้านเพิ่ม
    เมื่อเห็นรูปแบบแล้วสามารถวางงบรายเดือนแบบสมจริงขึ้น และลดโอกาสเจอบิลสูงผิดคาดในเดือนถัดไป
  </p>

  <h2>แนวทางลดค่าไฟโดยไม่ต้องเดา</h2>

  <p>
    หลังคำนวณค่าไฟได้แล้ว ขั้นถัดไปคือการเลือกมาตรการลดหน่วยไฟที่เห็นผลจริงกับบ้านของคุณ
    หลักคิดคือเน้นอุปกรณ์ที่กินไฟสูงและเปิดใช้นานก่อน เพราะจะให้ผลลดค่าใช้จ่ายต่อเดือนชัดกว่า
    จากนั้นติดตามผลด้วยหน่วยไฟจริงในบิลรอบถัดไป ไม่ต้องคาดหวังจากความรู้สึกเพียงอย่างเดียว
  </p>

  <ul>
    <li>ตั้งอุณหภูมิแอร์ที่ 26 องศาและล้างแผ่นกรองตามรอบ ช่วยลดโหลดเครื่องได้ต่อเนื่อง</li>
    <li>เปลี่ยนหลอดไฟที่ใช้นานเป็น LED และปิดไฟจุดที่ไม่จำเป็นทันทีเมื่อเลิกใช้งาน</li>
    <li>ตั้งเวลาเครื่องทำน้ำอุ่นหรือปั๊มน้ำเฉพาะช่วงจำเป็น ลดการทำงานทิ้งไว้ทั้งวัน</li>
    <li>หลีกเลี่ยงเปิดเครื่องใช้กำลังสูงหลายตัวพร้อมกันในช่วงเวลาเดียว</li>
    <li>ติดตามหน่วยไฟรายสัปดาห์เพื่อจับสัญญาณผิดปกติได้เร็วขึ้นก่อนปิดรอบบิล</li>
  </ul>

  <p>
    เมื่อใช้แนวทางข้างต้นร่วมกับเครื่องคำนวณ คุณจะประเมินได้ว่าถ้าลดหน่วยไฟลง 20 หรือ 30 หน่วย
    ยอดสุทธิจะลดจริงประมาณเท่าไรหลังรวมค่า Ft และ VAT แล้ว
    มุมมองแบบนี้ช่วยให้ตัดสินใจได้แม่นกว่าการเดาว่าอุปกรณ์ใดประหยัด และเหมาะกับการวางแผนค่าใช้จ่ายระยะยาวของครัวเรือน
  </p>

