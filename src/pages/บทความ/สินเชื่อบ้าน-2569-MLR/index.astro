---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'สินเชื่อบ้าน 2569 ดอกเบี้ย MLR คืออะไร กู้ได้เท่าไรต่อเดือน | Kamnuanlek';
const description = 'คู่มือสินเชื่อบ้าน 2569 อธิบาย MLR MRR MOR คืออะไร วิธีคำนวณค่าผ่อน LTV Ratio และรายได้ที่ต้องมีก่อนตัดสินใจซื้อบ้าน อ้างอิงธนาคารแห่งประเทศไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/สินเชื่อบ้าน-2569-MLR/`;

const faqData = [
  {
    question: 'MLR กับ MRR ต่างกันอย่างไร?',
    answer: 'MLR (Minimum Loan Rate) คืออัตราดอกเบี้ยต่ำสุดของสินเชื่อทุกประเภท MRR (Mortgage Reference Rate) คืออัตราอ้างอิงสำหรับสินเชื่อที่อยู่อาศัยโดยเฉพาะ',
  },
  {
    question: 'ค่าผ่อนบ้านไม่ควรเกินกี่เปอร์เซ็นต์ของรายได้?',
    answer: 'ธนาคารมักกำหนดให้ค่าผ่อนบ้านไม่เกิน 40-50% ของรายได้สุทธิ เพื่อให้มีเงินเหลือสำหรับค่าใช้จ่ายอื่น',
  },
  {
    question: 'LTV Ratio คืออะไร ส่งผลต่อสินเชื่อบ้านอย่างไร?',
    answer: 'LTV (Loan to Value) คือสัดส่วนเงินกู้ต่อมูลค่าทรัพย์สิน ธนาคารยินดีกู้ LTV ไม่เกิน 90% สำหรับบ้านแรก LTV ยิ่งต่ำยิ่งได้อัตราดอกเบี้ยที่ดีกว่า',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    สินเชื่อบ้าน 2569 ดอกเบี้ย MLR คืออะไร กู้ได้เท่าไรต่อเดือน
  </h1>

  <p>
    การซื้อบ้านเป็นการตัดสินใจครั้งใหญ่ในชีวิต ปีนี้ (2569) ธนาคารใช้อัตราดอกเบี้ยที่เรียกว่า "MLR" (Minimum Loan Rate) หรือ "MRR" (Mortgage Reference Rate) เป็นอัตราอ้างอิง บทความนี้อธิบายระบบดอกเบี้ยบ้านอย่างละเอียด
  </p>
  <section id="home-loan-secondary-intent-cluster" class="my-6 rounded-lg border border-emerald-200 bg-emerald-50 p-4">
    <h2 class="text-xl font-semibold text-gray-900 mb-2">วางแผนผ่อนบ้านและเทียบทางเลือกก่อนยื่นกู้</h2>
    <p class="text-sm text-gray-700 mb-3">
      เริ่มจากคำนวณค่างวดบ้านตามงบจริงของคุณ แล้วเทียบแนวทางรีไฟแนนซ์กับโปะบ้านเพื่อเลือกแผนที่คุ้มระยะยาว
      และควบคุมดอกเบี้ยรวมได้ดีขึ้น
    </p>
    <ul class="list-disc pl-5 space-y-1 text-sm">
      <li>
        <a href="/คำนวณผ่อนบ้าน/" class="text-primary-700 hover:underline">
          คำนวณผ่อนบ้านจากราคาทรัพย์ ดาวน์ ดอกเบี้ย และจำนวนปีผ่อน
        </a>
      </li>
      <li>
        <a href="/บทความ/รีไฟแนนซ์บ้าน-vs-โปะบ้าน-แบบไหนคุ้ม-2569/" class="text-primary-700 hover:underline">
          อ่านเปรียบเทียบรีไฟแนนซ์บ้าน vs โปะบ้าน แบบไหนคุ้มในปี 2569
        </a>
      </li>
    </ul>
  </section>
  <ArticleCalculatorCTA
    title="คำนวณผ่อนบ้าน"
    description="ใส่ราคาบ้าน เงินดาวน์ อัตราดอกเบี้ย คำนวณค่าผ่อนรายเดือนทันที"
    href="/คำนวณผ่อนบ้าน/"
    buttonLabel="คำนวณผ่อนบ้านฟรี"
  />

  <h2>อัตราดอกเบี้ยสินเชื่อบ้าน: MLR, MRR, MOR คืออะไร</h2>

  <p><strong>1. MLR (Minimum Loan Rate)</strong></p>
  <ul>
    <li>อัตราดอกเบี้ยต่ำสุดของสินเชื่อ</li>
    <li>ปัจจุบัน (2569): ประมาณ 4.5% - 5.5%</li>
  </ul>

  <p><strong>2. MRR (Mortgage Reference Rate)</strong></p>
  <ul>
    <li>อัตราอ้างอิงสำหรับสินเชื่อที่อยู่อาศัยเท่านั้น</li>
    <li>ปัจจุบัน (2569): ประมาณ 3.0% - 4.0%</li>
  </ul>

  <p><strong>3. MOR (Market Offer Rate)</strong></p>
  <ul>
    <li>อัตราที่ธนาคารกำหนดโดยใช้อัตราอ้างอิง MLR หรือ MRR + Margin</li>
    <li>ตัวอย่าง: MRR 3.5% + Margin 1.0% = อัตราสินเชื่อ 4.5%</li>
  </ul>

  <p>ข้อมูลอัตราอ้างอิงล่าสุดดูได้ที่ <a href="https://www.bot.or.th/" rel="noopener noreferrer" target="_blank">ธนาคารแห่งประเทศไทย (bot.or.th)</a></p>

  <h2>LTV (Loan to Value) Ratio คืออะไร</h2>

  <p>LTV คือสัดส่วนของเงินกู้เทียบกับมูลค่าของทรัพย์สิน</p>

  <p><strong>สูตร:</strong> LTV = (จำนวนเงินกู้ ÷ มูลค่าทรัพย์สิน) × 100</p>

  <p>ตัวอย่าง: บ้านราคา 3,000,000 บาท ดาวน์ 10% = 300,000 บาท กู้ 2,700,000 บาท</p>
  <ul>
    <li>LTV = (2,700,000 ÷ 3,000,000) × 100 = 90%</li>
    <li>ธนาคารยินดีกู้ LTV ไม่เกิน 90% สำหรับบ้านแรก</li>
    <li>LTV ยิ่งต่ำ อาจได้อัตราดอกเบี้ยที่ดีกว่า</li>
  </ul>

  <h2>ระยะเวลาผ่อนบ้าน</h2>

  <ul>
    <li><strong>10 ปี:</strong> ค่าผ่อนสูง แต่ดอกเบี้ยน้อยที่สุด</li>
    <li><strong>15 ปี:</strong> เหมาะสำหรับคนส่วนใหญ่</li>
    <li><strong>20 ปี:</strong> ค่าผ่อนพอดี ดุลยภาพที่ดี</li>
    <li><strong>30 ปี:</strong> ค่าผ่อนต่ำสุด แต่ดอกเบี้ยมากที่สุด</li>
  </ul>

  <h2>วิธีคำนวณว่ากู้ได้เท่าไร</h2>

  <p>ธนาคารมักกำหนดให้ค่าผ่อนบ้านไม่เกิน <strong>40-50%</strong> ของรายได้สุทธิ</p>
  <ul>
    <li>รายได้สุทธิ 50,000 บาท → ค่าผ่อนสูงสุด 20,000 บาท</li>
    <li>ค่าผ่อน 20,000 บาท ระยะเวลา 20 ปี อัตรา 4% → กู้ได้ประมาณ 3,500,000 บาท</li>
  </ul>
  
  <ArticleCalculatorCTA
    title="คำนวณสินเชื่อบ้านของคุณ"
    description="ใส่ราคาบ้านและรายได้ คำนวณค่าผ่อนและดูว่ากู้ได้เท่าไร"
    href="/คำนวณผ่อนบ้าน/"
    buttonLabel="คำนวณผ่อนบ้านตอนนี้"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>


