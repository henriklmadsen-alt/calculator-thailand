---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณผ่อนกู้ 2569 | เทียบคงที่-ลดต้นลดดอก | เครื่องคำนวณไทย';
const description = 'วางแผนผ่อนกู้ปี 2569 ด้วยตัวอย่างค่างวดจริง เปรียบเทียบดอกเบี้ยแบบลดต้นลดดอกกับแบบคงที่ พร้อมเช็กลิสต์ก่อนตัดสินใจยื่นกู้';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณผ่อนกู้-2569-วิธีคิดค่างวดลดต้นลดดอก-vs-คงที่/`;

const faqData = [
  {
    question: 'ลดต้นลดดอกกับคงที่ แบบไหนคุ้มกว่า?',
    answer: 'โดยหลักการ แบบลดต้นลดดอกมักทำให้ดอกเบี้ยรวมต่ำกว่า เพราะดอกเบี้ยคิดจากยอดหนี้คงเหลือที่ลดลงทุกงวด ส่วนแบบคงที่คิดบนเงินต้นทั้งก้อนตลอดสัญญา',
  },
  {
    question: 'ถ้าธนาคารหนึ่งบอกดอกเบี้ยแบบ Flat Rate และอีกธนาคารบอก Effective Rate เทียบอย่างไร?',
    answer: 'ควรแปลงให้อยู่ในวิธีคิดเดียวกันก่อนเปรียบเทียบ ธปท.แนะนำการแปลงแบบคร่าว ๆ ว่า Flat Rate x 1.8 เพื่อประมาณ Effective Rate',
  },
  {
    question: 'ผ่อนยาวช่วยให้คุ้มขึ้นหรือไม่?',
    answer: 'ผ่อนยาวช่วยลดค่างวดต่อเดือน แต่ดอกเบี้ยรวมมักเพิ่มขึ้น จึงควรเทียบทั้งค่างวดและดอกเบี้ยรวมพร้อมกันก่อนตัดสินใจ',
  },
  {
    question: 'ใช้ตัวเลขจากบทความนี้ไปยื่นสินเชื่อได้เลยไหม?',
    answer: 'ใช้ได้ในเชิงวางแผนเบื้องต้นเท่านั้น ตัวเลขจริงขึ้นกับเงื่อนไขสัญญา วันตัดรอบดอกเบี้ย ค่าธรรมเนียม และข้อเสนอเฉพาะของแต่ละสถาบันการเงิน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-19"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    คำนวณผ่อนกู้ 2569: วิธีคิดค่างวดลดต้นลดดอก vs คงที่
  </h1>

  <p>
    ก่อนเซ็นสัญญากู้ ควรเทียบให้ครบทั้ง <strong>ค่างวดรายเดือน</strong>, <strong>ดอกเบี้ยรวมทั้งสัญญา</strong>
    และ <strong>สภาพคล่องหลังผ่อน</strong> ไม่ใช่ดูแค่อัตราดอกเบี้ยที่ประกาศหน้าโปรโมชั่น
    เพราะสินเชื่อต่างประเภทอาจใช้วิธีคิดดอกเบี้ยไม่เหมือนกัน ทำให้เทียบผิดได้ง่าย
  </p>

  <ArticleCalculatorCTA
    title="เริ่มจากตัวเลขของคุณเองก่อน"
    description="กรอกเงินต้น ดอกเบี้ย และระยะเวลาผ่อน เพื่อดูค่างวดและดอกเบี้ยรวมทันที"
    href="/คำนวณผ่อนกู้/"
    buttonLabel="ไปที่คำนวณผ่อนกู้"
  />

  <h2>เลือกวิธีคิดดอกเบี้ยให้ถูกก่อนเทียบข้อเสนอ</h2>

  <ul>
    <li><strong>ลดต้นลดดอก (Effective/Reducing):</strong> ดอกเบี้ยคิดจากยอดหนี้คงเหลือในแต่ละงวด</li>
    <li><strong>คงที่ (Flat Rate):</strong> ดอกเบี้ยคิดจากเงินต้นก้อนแรกตลอดสัญญา</li>
    <li><strong>ผลที่ต่างกัน:</strong> แม้ค่างวดอาจดูใกล้กัน แต่ดอกเบี้ยรวมปลายทางต่างกันมากได้</li>
  </ul>

  <p>
    ธนาคารแห่งประเทศไทยระบุชัดว่า การเปรียบเทียบสินเชื่อต่างประเภทต้องเทียบด้วยวิธีคิดเดียวกันก่อน
    เพื่อไม่ให้เข้าใจว่าอัตราที่เห็นต่ำกว่าคือถูกกว่าเสมอ
  </p>

  <h2>ตัวอย่างค่างวดจริง (สอดคล้องกับเครื่องคำนวณ)</h2>

  <p>
    กู้ 1,200,000 บาท ดอกเบี้ย 6.2% ต่อปี ผ่อน 15 ปี (180 งวด):
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[680px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">วิธีคิด</th>
          <th class="border border-gray-200 px-3 py-2 text-right">ค่างวด/เดือน</th>
          <th class="border border-gray-200 px-3 py-2 text-right">ดอกเบี้ยรวม</th>
          <th class="border border-gray-200 px-3 py-2 text-right">ยอดชำระรวม</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ลดต้นลดดอก</td>
          <td class="border border-gray-200 px-3 py-2 text-right">10,256.40 บาท</td>
          <td class="border border-gray-200 px-3 py-2 text-right">646,152.33 บาท</td>
          <td class="border border-gray-200 px-3 py-2 text-right">1,846,152.33 บาท</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-200 px-3 py-2">คงที่ (Flat)</td>
          <td class="border border-gray-200 px-3 py-2 text-right">12,866.67 บาท</td>
          <td class="border border-gray-200 px-3 py-2 text-right">1,116,000.00 บาท</td>
          <td class="border border-gray-200 px-3 py-2 text-right">2,316,000.00 บาท</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p>
    ในตัวอย่างนี้ แบบคงที่ทำให้จ่ายดอกเบี้ยมากกว่าแบบลดต้นลดดอกประมาณ <strong>469,847.67 บาท</strong>
    จึงควรดู “ยอดจ่ายรวมทั้งสัญญา” ทุกครั้ง ไม่ใช่ดูเฉพาะค่างวดรายเดือน
  </p>

  <h2>ขั้นตอนตัดสินใจ 10 นาทีก่อนเลือกโปรสินเชื่อ</h2>

  <p>
    เวลาธนาคารหรือไฟแนนซ์ส่งข้อเสนอมาให้ หลายคนมักโฟกัสที่คำว่า “ดอกเบี้ยต่ำ” เพียงอย่างเดียว
    แต่ในทางปฏิบัติ การตัดสินใจที่ดีควรเช็กทั้งวิธีคิดดอกเบี้ย ค่าใช้จ่ายหน้าโต๊ะ และสภาพคล่องหลังเริ่มผ่อน
    เพื่อไม่ให้ได้ค่างวดที่ดูไหวในเดือนแรก แต่ตึงมือในเดือนที่มีรายจ่ายพิเศษ เช่น ประกันรถ ค่าเล่าเรียน หรือค่าซ่อมบ้าน
  </p>

  <ol>
    <li>
      <strong>เริ่มจากยอดกู้จริง ไม่ใช่วงเงินสูงสุด:</strong>
      กรอกยอดเงินที่คุณจะใช้จริงใน <a href="/คำนวณผ่อนกู้/" data-preserve-utm>คำนวณผ่อนกู้</a>
      เพื่อเห็นค่างวดตามสถานการณ์จริง แทนการประเมินจากวงเงินเผื่อเกินความจำเป็น
    </li>
    <li>
      <strong>ยืนยันวิธีคิดดอกเบี้ยให้ชัด:</strong>
      หากอีกเจ้าพูดว่า Flat Rate แต่อีกเจ้าพูด Effective Rate ให้แปลงให้อยู่ฐานเดียวกันก่อน
      แล้วจึงเทียบยอดจ่ายรวม ไม่ควรเทียบแค่อัตราหน้าโบรชัวร์
    </li>
    <li>
      <strong>ดูค่างวดคู่กับเงินเหลือหลังหักค่าใช้จ่าย:</strong>
      หลังได้ค่างวดแล้ว ให้ต่อยอดไปที่
      <a href="/คำนวณเงินเดือนสุทธิ/" data-preserve-utm>คำนวณเงินเดือนสุทธิ</a>
      เพื่อดูเงินคงเหลือรายเดือนหลังภาษีและประกันสังคม จะช่วยบอกได้ว่าค่างวดนี้อยู่กับชีวิตจริงได้หรือไม่
    </li>
    <li>
      <strong>แยก “ค่าใช้จ่ายวันทำสัญญา” ออกจากค่างวด:</strong>
      ค่าธรรมเนียม ค่าประกัน หรือค่าใช้จ่ายเปิดบัญชีบางรายการไม่ได้อยู่ในสูตรค่างวด
      แต่กระทบเงินสดก้อนแรกทันที ควรใส่ไว้ในแผนกระแสเงินสดตั้งแต่ต้น
    </li>
    <li>
      <strong>เทียบแผนสั้นกับแผนยาวพร้อมกัน:</strong>
      วางอย่างน้อย 2 ทางเลือก เช่น 10 ปีกับ 15 ปี หรือ 15 ปีกับ 20 ปี
      เพื่อชั่งน้ำหนักระหว่าง “ค่างวดที่เบา” กับ “ดอกเบี้ยรวมที่เพิ่มขึ้น” ให้เห็นภาพเดียวกัน
    </li>
  </ol>

  <p>
    ถ้าเป็นหนี้บ้านและมีแผนย้ายสัญญาในอนาคต แนะนำให้เทียบต่อใน
    <a href="/คำนวณผ่อนบ้าน/" data-preserve-utm>คำนวณผ่อนบ้าน + รีไฟแนนซ์</a>
    เพื่อดูจุดคุ้มทุนก่อนตัดสินใจย้ายหนี้จริง
  </p>

  <h2>เทียบระยะเวลาผ่อนก่อนตัดสินใจ</h2>

  <p>
    ตัวอย่างเงินกู้ 2,000,000 บาท ดอกเบี้ย 6.5% แบบลดต้นลดดอก:
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[680px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ระยะเวลา</th>
          <th class="border border-gray-200 px-3 py-2 text-right">ค่างวด/เดือน</th>
          <th class="border border-gray-200 px-3 py-2 text-right">ดอกเบี้ยรวม</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">10 ปี</td>
          <td class="border border-gray-200 px-3 py-2 text-right">22,709.60 บาท</td>
          <td class="border border-gray-200 px-3 py-2 text-right">725,151.45 บาท</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-200 px-3 py-2">15 ปี</td>
          <td class="border border-gray-200 px-3 py-2 text-right">17,422.15 บาท</td>
          <td class="border border-gray-200 px-3 py-2 text-right">1,135,986.52 บาท</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">20 ปี</td>
          <td class="border border-gray-200 px-3 py-2 text-right">14,911.46 บาท</td>
          <td class="border border-gray-200 px-3 py-2 text-right">1,578,751.05 บาท</td>
        </tr>
        <tr class="bg-gray-50">
          <td class="border border-gray-200 px-3 py-2">25 ปี</td>
          <td class="border border-gray-200 px-3 py-2 text-right">13,504.14 บาท</td>
          <td class="border border-gray-200 px-3 py-2 text-right">2,051,242.97 บาท</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p>
    ผ่อนยาวช่วยให้ค่างวดเบาลง แต่ดอกเบี้ยรวมเพิ่มขึ้นชัดเจน จึงควรเลือกระยะเวลาที่ “ไหวจริง” และยังเหลือเงินฉุกเฉินในแต่ละเดือน
  </p>

  <h2>จำลองความเสี่ยงค่างวด 3 สถานการณ์ก่อนเซ็นสัญญา</h2>

  <p>
    การคำนวณแบบฐานเดียวอาจยังไม่พอ เพราะชีวิตจริงมีความไม่แน่นอนเสมอ
    ก่อนตัดสินใจ ควรลองปรับตัวเลขอย่างน้อย 3 สถานการณ์ในเครื่องมือเดียวกัน
    แล้วดูว่าค่างวดและเงินคงเหลือหลังผ่อนยังอยู่ในระดับที่รับได้หรือไม่
  </p>

  <ul>
    <li>
      <strong>สถานการณ์ฐาน (Base Case):</strong>
      ใช้รายได้ปัจจุบันและอัตราดอกเบี้ยที่ได้รับจริง เพื่อดูภาพปกติของงบรายเดือน
    </li>
    <li>
      <strong>สถานการณ์ตึงมือ (Stress Case):</strong>
      ลองลดรายได้สุทธิลงชั่วคราว หรือเพิ่มค่าใช้จ่ายประจำ แล้วเช็กว่ายังผ่อนไหวต่อเนื่องได้กี่เดือน
    </li>
    <li>
      <strong>สถานการณ์ดอกเบี้ยขยับ (Rate-up Case):</strong>
      ทดลองเพิ่มอัตราดอกเบี้ยจากเดิมเป็นช่วง ๆ เพื่อดูว่าค่างวดจะขยับขึ้นเท่าไร และยังมีเงินสำรองพอหรือไม่
    </li>
  </ul>

  <p>
    วิธีทำที่เร็วที่สุดคือคำนวณรอบแรกใน <a href="/คำนวณผ่อนกู้/" data-preserve-utm>คำนวณผ่อนกู้</a>
    จากนั้นจดค่างวดที่ได้ไปเทียบกับเงินเหลือจริงใน
    <a href="/คำนวณเงินเดือนสุทธิ/" data-preserve-utm>คำนวณเงินเดือนสุทธิ</a>
    หากพบว่าคงเหลือน้อยเกินไป ให้ย้อนกลับมาปรับยอดกู้หรือระยะเวลาผ่อนทันที
    การปรับก่อนเซ็นสัญญาจะถูกกว่าการแก้ปัญหาหลังเริ่มมีหนี้เสมอ
  </p>

  <p>
    สำหรับผู้ที่กำลังชั่งใจระหว่างผ่อนรถกับผ่อนกู้แบบอื่น ควรเปิด
    <a href="/คำนวณผ่อนรถ/" data-preserve-utm>คำนวณผ่อนรถ</a>
    เทียบพร้อมกัน เพราะสินเชื่อรถจำนวนมากเสนออัตราแบบคงที่ ซึ่งตีความผิดได้ง่ายถ้าเทียบกับสินเชื่อแบบลดต้นลดดอกโดยตรง
  </p>

  <h2>สูตรที่ใช้ในบทความนี้</h2>

  <ul>
    <li><strong>ลดต้นลดดอก:</strong> ค่างวด = P × [r(1+r)^n] / [(1+r)^n - 1]</li>
    <li><strong>คงที่:</strong> ดอกเบี้ยรวม = P × อัตราดอกเบี้ยต่อปี × จำนวนปี</li>
    <li><strong>คงที่:</strong> ค่างวด = (เงินต้น + ดอกเบี้ยรวม) ÷ จำนวนงวด</li>
  </ul>

  <p>
    ตัวอย่างตัวเลขทั้งหมดในบทความนี้ตรวจสอบให้สอดคล้องกับตรรกะเดียวกับเครื่องมือ
    ผ่านโมดูลคำนวณในระบบ `src/lib/loan-calculator.ts`
  </p>

  <h2>เช็กลิสต์ก่อนยื่นสินเชื่อ</h2>

  <ol>
    <li>เทียบข้อเสนออย่างน้อย 2-3 แห่ง และแปลงอัตราให้อยู่ในวิธีคิดเดียวกัน</li>
    <li>ดูดอกเบี้ยเฉลี่ยหลายปี ไม่ดูเฉพาะโปรโมชันปีแรก</li>
    <li>รวมค่าธรรมเนียมและค่าใช้จ่ายแฝงก่อนตัดสินใจ</li>
    <li>จำลองกรณีรายได้ลดลงหรือดอกเบี้ยปรับขึ้น เพื่อดูความเสี่ยงค่างวด</li>
    <li>คงเงินสำรองฉุกเฉินอย่างน้อย 3-6 เดือนของค่าใช้จ่ายจำเป็น</li>
  </ol>

  <h2>แหล่งอ้างอิงสูตรและแนวคิด</h2>

  <ul>
    <li>
      ธนาคารแห่งประเทศไทย:
      <a href="https://www.bot.or.th/th/satang-story/rights-responsibility/effectiverate.html" target="_blank" rel="noopener noreferrer">
        ดอกเบี้ยเงินกู้แบบลดต้นลดดอก (Effective Rate) และการเทียบ Flat Rate
      </a>
    </li>
    <li>
      ธนาคารแห่งประเทศไทย:
