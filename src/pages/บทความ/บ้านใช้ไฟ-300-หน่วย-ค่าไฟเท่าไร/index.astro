---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'บ้านใช้ไฟ 300 หน่วย ค่าไฟฟ้าเดือนนี้เท่าไร พร้อม Ft ปี 2569 | เครื่องคำนวณไทย';
const description = 'คำนวณค่าไฟฟ้าสำหรับบ้านที่ใช้ 300 หน่วยต่อเดือน พร้อมค่า Ft ปี 2569 ทั้งรอบ ม.ค.–เม.ย. และ พ.ค.–ส.ค. รวม VAT 7%';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/บ้านใช้ไฟ-300-หน่วย-ค่าไฟเท่าไร/`;

const faqData = [
  {
    question: 'ใช้ไฟ 300 หน่วย ค่าไฟเท่าไร (Ft พ.ค.–ส.ค. 2569)?',
    answer: 'ที่ค่า Ft = 0.1623 บาท/หน่วย ค่าไฟบ้าน 300 หน่วยประมาณ 1,210–1,230 บาท (รวม VAT 7%) ขึ้นอยู่กับขนาดมิเตอร์และค่าบริการรายเดือน',
  },
  {
    question: 'ค่าไฟ 300 หน่วยต่างจาก 200 หน่วยมากไหม?',
    answer: 'ต่างกันมาก เพราะหน่วยที่ 151–300 ถูกคิดในอัตรา 4.2218 บาท/หน่วย ซึ่งสูงกว่า 100 หน่วยแรก ทำให้ค่าไฟ 300 หน่วยสูงกว่า 200 หน่วยอย่างเห็นได้ชัด',
  },
  {
    question: 'อุปกรณ์ไหนทำให้ใช้ไฟถึง 300 หน่วยต่อเดือน?',
    answer: 'ส่วนใหญ่มาจากแอร์ (1 เครื่อง 8–12 ชม./วัน ใช้ไฟ 120–180 หน่วย/เดือน) ตู้เย็น (30–50 หน่วย) และเครื่องใช้ไฟฟ้าอื่นๆ รวมกัน',
  },
  {
    question: 'จะลดจาก 300 หน่วยลงเหลือ 200 หน่วยได้อย่างไร?',
    answer: 'ตั้งอุณหภูมิแอร์ที่ 26–28°C ล้างแผ่นกรองแอร์ทุก 2 สัปดาห์ ปิดแอร์เมื่อไม่อยู่ห้อง เปลี่ยนหลอดไฟเป็น LED และปิดอุปกรณ์ standby ที่ไม่ใช้งาน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  modifiedDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    บ้านใช้ไฟ 300 หน่วย ค่าไฟฟ้าเดือนนี้เท่าไร พร้อม Ft ปี 2569
  </h1>

  <p>
    บ้านที่ใช้ไฟ 300 หน่วยต่อเดือนถือว่าอยู่ในระดับกลาง-สูง มักเกิดจากการเปิดแอร์นาน
    บทความนี้จะคำนวณค่าไฟจริงสำหรับ 300 หน่วยตามอัตราปี 2569 ทั้งสองรอบ Ft
    ใช้ <a href="/คำนวณค่าไฟฟ้า/">เครื่องคำนวณค่าไฟฟ้า</a> ของเราเพื่อดูยอดที่แม่นยำสำหรับบ้านของคุณ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณค่าไฟ 300 หน่วยของคุณ"
    description="ใส่หน่วยไฟและเลือกรอบ Ft เพื่อดูยอดรวม VAT อย่างแม่นยำ"
    href="/คำนวณค่าไฟฟ้า/"
    buttonLabel="คำนวณค่าไฟฟ้าตอนนี้"
  />

  <h2>คำนวณค่าไฟ 300 หน่วย ทีละขั้นตอน</h2>

  <p>
    สำหรับบ้านอยู่อาศัยประเภทที่ 1 ที่ใช้ 300 หน่วย (เกิน 150 หน่วย ใช้ค่าบริการ 24.62 บาท/เดือน):
  </p>

  <p><strong>ค่าไฟฐาน (แยกตามช่วง):</strong></p>
  <ul>
    <li>1–15 หน่วย: 15 × 2.3488 = 35.23 บาท</li>
    <li>16–25 หน่วย: 10 × 2.9882 = 29.88 บาท</li>
    <li>26–35 หน่วย: 10 × 3.2405 = 32.41 บาท</li>
    <li>36–100 หน่วย: 65 × 3.6237 = 235.54 บาท</li>
    <li>101–150 หน่วย: 50 × 3.7171 = 185.86 บาท</li>
    <li>151–300 หน่วย: 150 × 4.2218 = 633.27 บาท</li>
    <li><strong>ค่าไฟฐานรวม = 1,152.19 บาท</strong></li>
  </ul>

  <h2>สรุปยอดค่าไฟ 300 หน่วย เปรียบเทียบ 2 รอบ Ft</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[600px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">รายการ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">Ft = 0.0972 (ม.ค.–เม.ย. 2569)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">Ft = 0.1623 (พ.ค.–ส.ค. 2569)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">ค่าไฟฐาน</td><td class="border border-gray-200 px-3 py-2">1,152.19 บาท</td><td class="border border-gray-200 px-3 py-2">1,152.19 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ค่าบริการ</td><td class="border border-gray-200 px-3 py-2">24.62 บาท</td><td class="border border-gray-200 px-3 py-2">24.62 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ค่า Ft (300 หน่วย)</td><td class="border border-gray-200 px-3 py-2">29.16 บาท</td><td class="border border-gray-200 px-3 py-2">48.69 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">รวมก่อน VAT</td><td class="border border-gray-200 px-3 py-2">1,205.97 บาท</td><td class="border border-gray-200 px-3 py-2">1,225.50 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">VAT 7%</td><td class="border border-gray-200 px-3 py-2">84.42 บาท</td><td class="border border-gray-200 px-3 py-2">85.79 บาท</td></tr>
        <tr class="bg-blue-50"><td class="border border-gray-200 px-3 py-2"><strong>ยอดสุทธิ</strong></td><td class="border border-gray-200 px-3 py-2"><strong>~1,290 บาท</strong></td><td class="border border-gray-200 px-3 py-2"><strong>~1,311 บาท</strong></td></tr>
      </tbody>
    </table>
  </div>

  <h2>อุปกรณ์ที่ทำให้ใช้ไฟถึง 300 หน่วย</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[540px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">อุปกรณ์</th>
          <th class="border border-gray-200 px-3 py-2 text-left">กำลังไฟ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ใช้งาน</th>
          <th class="border border-gray-200 px-3 py-2 text-left">หน่วย/เดือน</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">แอร์ 1 เครื่อง</td><td class="border border-gray-200 px-3 py-2">1,200W</td><td class="border border-gray-200 px-3 py-2">10 ชม./วัน</td><td class="border border-gray-200 px-3 py-2">~360 หน่วย</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ตู้เย็น</td><td class="border border-gray-200 px-3 py-2">150W</td><td class="border border-gray-200 px-3 py-2">24 ชม./วัน</td><td class="border border-gray-200 px-3 py-2">~108 หน่วย</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">เครื่องทำน้ำอุ่น</td><td class="border border-gray-200 px-3 py-2">3,500W</td><td class="border border-gray-200 px-3 py-2">20 นาที/วัน</td><td class="border border-gray-200 px-3 py-2">~35 หน่วย</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ไฟ LED รวม</td><td class="border border-gray-200 px-3 py-2">200W</td><td class="border border-gray-200 px-3 py-2">6 ชม./วัน</td><td class="border border-gray-200 px-3 py-2">~36 หน่วย</td></tr>
      </tbody>
    </table>
  </div>

  <h2>วิธีลดค่าไฟจาก 300 หน่วย</h2>

  <ul>
    <li>ตั้งแอร์ที่ 26°C แทน 20°C ประหยัดได้ถึง 6% ต่อองศา</li>
    <li>ล้างแผ่นกรองแอร์ทุก 2 สัปดาห์ ลดไฟที่แอร์ต้องทำงานหนักขึ้น</li>
    <li>เปลี่ยนตู้เย็นเก่าเป็นรุ่น 5 ดาวประหยัดไฟ</li>
    <li>ปิด standby ทีวี เครื่องเสียง เราเตอร์ที่ไม่ใช้กลางคืน</li>
    <li>ใช้เครื่องซักผ้าเต็มถัง ไม่ซักรอบสั้นบ่อยๆ</li>
  </ul>

  <ArticleCalculatorCTA
    title="คำนวณว่าถ้าลดหน่วยไฟ ค่าไฟจะลดเท่าไร"
    description="ลองเปลี่ยนจำนวนหน่วยไฟแล้วดูว่าค่าไฟจะลดลงเท่าไหร่"
    href="/คำนวณค่าไฟฟ้า/"
    buttonLabel="ทดลองคำนวณค่าไฟฟ้า"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณค่าไฟฟ้า/">คำนวณค่าไฟฟ้า</a> สำหรับคำนวณบิลค่าไฟ</li>
    <li><a href="/คำนวณค่าน้ำ/">คำนวณค่าน้ำ</a> สำหรับคำนวณค่าน้ำประปา</li>
    <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a> วางงบค่าสาธารณูปโภคต่อเดือน</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/ค่าไฟฟ้า-mea-กับ-pea/">ค่าไฟฟ้า MEA กับ PEA ต่างกันอย่างไร</a></li>
    <li><a href="/บทความ/คำนวณค่าไฟฟ้า-2569-สูตร-pea-mea/">คำนวณค่าไฟฟ้า 2569 สูตร PEA/MEA + ค่า Ft</a></li>
  </ul>

  <h2>แหล่งอ้างอิง</h2>
  <ul>
    <li><a href="https://www.mea.or.th" target="_blank" rel="noopener noreferrer">การไฟฟ้านครหลวง (MEA)</a></li>
    <li><a href="https://www.pea.co.th" target="_blank" rel="noopener noreferrer">การไฟฟ้าส่วนภูมิภาค (PEA)</a></li>
  </ul>
</BlogPostLayout>
