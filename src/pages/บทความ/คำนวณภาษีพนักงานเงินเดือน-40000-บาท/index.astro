---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณภาษีพนักงานเงินเดือน 40,000 บาท ปี 2569 ต้องจ่ายเท่าไร | Kamnuanlek';
const description = 'สาธิตขั้นตอนคำนวณภาษีเงินเดือน 40,000 บาท ปี 2569 ตัวอย่างเปรียบเทียบหลายกรณี วิธีลดภาษี และเงินสุทธิที่ได้รับจริง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณภาษีพนักงานเงินเดือน-40000-บาท/`;

const faqData = [
  {
    question: 'เงินเดือน 40,000 บาท ต้องจ่ายภาษีเท่าไรต่อปี?',
    answer: 'หากเป็นคนเดี่ยว ไม่มีลดหย่อนพิเศษ จะต้องจ่ายภาษีประมาณ 18,600 บาทต่อปี หรือประมาณ 1,550 บาทต่อเดือน',
  },
  {
    question: 'เงินเดือน 40,000 บาท เงินสุทธิที่ได้รับจริงคือเท่าไร?',
    answer: 'หลังหักประกันสังคมและภาษี เงินสุทธิที่ได้รับจริงประมาณ 37,700 บาทต่อเดือน',
  },
  {
    question: 'วิธีลดภาษีสำหรับเงินเดือน 40,000 บาทมีอะไรบ้าง?',
    answer: 'สมัครสมทบกองทุนสำรองเลี้ยงชีพ ซื้อประกันชีวิต มีบุตร เลี้ยงบิดามารดา หรือจดทะเบียนสมรส ล้วนช่วยลดภาษีได้',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    คำนวณภาษีพนักงานเงินเดือน 40,000 บาท ปี 2569 ต้องจ่ายเท่าไร
  </h1>

  <p>
    พนักงานที่ได้เงินเดือน 40,000 บาทต่อเดือน (480,000 บาทต่อปี) เป็นกรณีทั่วไปในประเทศไทย แต่หลายคนกังวลว่าต้องจ่ายภาษีเท่าไรและสิ่งใดจะช่วยลดภาษี บทความนี้จะสาธิตขั้นตอนการคำนวณอย่างละเอียด พร้อมตัวอย่างตารางเปรียบเทียบ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณภาษีเงินได้บุคคลธรรมดา"
    description="ใส่เงินเดือนและค่าลดหย่อน คำนวณภาษีที่ต้องจ่ายทันที"
    href="/คำนวณภาษีเงินได้บุคคลธรรมดา/"
    buttonLabel="คำนวณภาษีฟรี"
  />

  <h2>ตัวอย่างคนเดี่ยว เงินเดือน 40,000 บาท ไม่มีรายได้อื่น</h2>

  <p>สมมติสมชายเป็นพนักงานบริษัท อาศัยอยู่คนเดี่ยว ไม่มีผู้ติดตามหรือลดหย่อนพิเศษ:</p>

  <ol>
    <li><strong>เงินได้รวม:</strong> 480,000 บาท</li>
    <li><strong>หักประกันสังคม (SSO):</strong> 9,000 บาทต่อปี</li>
    <li><strong>หักลดหย่อนพื้นฐาน (คนเดี่ยว):</strong> 60,000 บาท</li>
    <li><strong>เงินได้ที่ต้องเสียภาษี:</strong> 411,000 บาท</li>
    <li>คำนวณภาษี:
      <ul>
        <li>0 - 150,000 บาท × 0% = 0 บาท</li>
        <li>150,001 - 300,000 บาท × 5% = 7,500 บาท</li>
        <li>300,001 - 411,000 บาท × 10% = 11,100 บาท</li>
        <li><strong>รวมภาษี = 18,600 บาท</strong></li>
      </ul>
    </li>
    <li><strong>เงินเดือนสุทธิ: ประมาณ 37,700 บาท/เดือน</strong></li>
  </ol>

  <h2>เปรียบเทียบกรณีต่างๆ ของเงินเดือน 40,000 บาท</h2>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">กรณี</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">ภาษีที่จ่าย</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">เงินสุทธิ/ปี</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">คนเดี่ยว ไม่มีลดหย่อน</td><td class="border border-gray-200 px-3 py-2 text-right">18,600</td><td class="border border-gray-200 px-3 py-2 text-right">452,400</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">สมรส (เงินเดือนเท่ากัน)</td><td class="border border-gray-200 px-3 py-2 text-right">13,000</td><td class="border border-gray-200 px-3 py-2 text-right">458,000</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">บิดามารดาเลี้ยง 1 คน</td><td class="border border-gray-200 px-3 py-2 text-right">13,100</td><td class="border border-gray-200 px-3 py-2 text-right">457,900</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">มีบุตร 1 คน</td><td class="border border-gray-200 px-3 py-2 text-right">15,600</td><td class="border border-gray-200 px-3 py-2 text-right">454,400</td></tr>
      </tbody>
    </table>
  </div>

  <h2>วิธีลดภาษีสำหรับคนเงินเดือน 40,000 บาท</h2>

  <ol>
    <li><strong>จดทะเบียนสมรส</strong> — ลดหย่อนจะเพิ่มจาก 60,000 เป็น 120,000 บาท ลดภาษีประมาณ 2,800 บาท/ปี</li>
    <li><strong>เลี้ยงบิดามารดา</strong> — เพิ่มลดหย่อน 30,000 บาทต่อคน ลดภาษีประมาณ 3,000 บาทต่อคน</li>
    <li><strong>มีบุตร</strong> — เพิ่มลดหย่อน 15,000 บาทต่อบุตร (สูงสุด 4 คน)</li>
    <li><strong>สมัครกองทุนสำรองเลี้ยงชีพ</strong> — หักได้ไม่เกิน 8% ของเงินได้ต่อปี</li>
    <li><strong>ซื้อประกันชีวิต</strong> — หักได้ไม่เกิน 100,000 บาท</li>
  </ol>

  <ArticleCalculatorCTA
    title="ลองคำนวณภาษีของคุณ"
    description="ปรับสถานการณ์ของคุณ ดูผลภาษีที่ต้องจ่ายจริงทันที"
    href="/คำนวณภาษีเงินได้บุคคลธรรมดา/"
    buttonLabel="คำนวณภาษีตอนนี้"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
