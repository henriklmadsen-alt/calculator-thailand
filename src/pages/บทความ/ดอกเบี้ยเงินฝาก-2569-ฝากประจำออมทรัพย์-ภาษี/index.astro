---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณดอกเบี้ยเงินฝาก 2569: สูตรคิดรายเดือนและดอกเบี้ยสุทธิหลังภาษี | Kamnuanlek';
const description = 'สรุปสูตรคำนวณดอกเบี้ยเงินฝากปี 2569 สำหรับฝากประจำและออมทรัพย์ พร้อมตัวอย่างตัวเลขจริงที่ตรงกับเครื่องคำนวณ และวิธีดูผลตอบแทนสุทธิหลังภาษี 15%';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ดอกเบี้ยเงินฝาก-2569-ฝากประจำออมทรัพย์-ภาษี/`;

const faqData = [
  {
    question: 'สูตรดอกเบี้ยฝากประจำที่ใช้ในเครื่องคำนวณคืออะไร?',
    answer: 'สูตรหลักคือ ดอกเบี้ยก่อนภาษี = เงินต้น × อัตราดอกเบี้ยต่อปี × (จำนวนเดือน ÷ 12) จากนั้นคำนวณดอกเบี้ยสุทธิ = ดอกเบี้ยก่อนภาษี × (1 - 0.15)',
  },
  {
    question: 'ทำไมโหมดออมทรัพย์ฝากเพิ่มรายเดือน ยอดฝากรวมไม่เท่ากับเงินต้น + ฝากเพิ่ม 12 งวด?',
    answer: 'ในตรรกะปัจจุบันของเครื่องมือ ระบบนับเงินฝากเริ่มต้นในเดือนแรก และเริ่มเพิ่มเงินฝากรายเดือนตั้งแต่เดือนที่ 2 จึงเท่ากับเงินต้น + (จำนวนเดือน - 1) × เงินฝากรายเดือน',
  },
  {
    question: 'ควรกรอกอัตราดอกเบี้ยแบบไหน?',
    answer: 'ให้กรอกอัตราดอกเบี้ยต่อปีของบัญชีหรือโปรโมชันที่คุณใช้จริง เพื่อให้ผลลัพธ์ใกล้เคียงสถานการณ์จริงที่สุด',
  },
  {
    question: 'ดอกเบี้ยเงินฝากต้องหักภาษีทุกกรณีหรือไม่?',
    answer: 'โดยหลักทั่วไปดอกเบี้ยเงินฝากถูกหักภาษี ณ ที่จ่าย 15% แต่มีกรณียกเว้นตามหลักเกณฑ์กรมสรรพากรและประเภทบัญชี เครื่องมือหน้านี้แสดงฐานคำนวณแบบหัก 15% เพื่อความระมัดระวัง',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-19"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    คำนวณดอกเบี้ยเงินฝาก 2569: สูตรคิดรายเดือนและดอกเบี้ยสุทธิหลังภาษี
  </h1>

  <p>
    ถ้าคุณกำลังเทียบว่า “บัญชีนี้คุ้มไหม” สิ่งที่ต้องดูไม่ใช่แค่อัตราดอกเบี้ยหน้าโฆษณา แต่ต้องดูดอกเบี้ยสุทธิหลังภาษีและจังหวะการฝากจริง บทความนี้สรุปสูตรที่ใช้ใน
    <a href="/คำนวณดอกเบี้ยเงินฝาก/">เครื่องคำนวณดอกเบี้ยเงินฝาก</a> พร้อมตัวอย่างที่ตรวจสอบตัวเลขได้ทันที
  </p>

  <ArticleCalculatorCTA
    title="ลองคำนวณจากยอดเงินจริงของคุณ"
    description="กรอกเงินต้น ดอกเบี้ย และระยะเวลาฝาก เพื่อเห็นดอกเบี้ยก่อนภาษี-หลังภาษีทันที"
    href="/คำนวณดอกเบี้ยเงินฝาก/"
    targetCalculator="deposit"
    buttonLabel="เปิดเครื่องคำนวณดอกเบี้ยเงินฝาก"
  />

  <h2>1) ตัวแปรที่ต้องใช้ก่อนคำนวณ</h2>
  <ul>
    <li><strong>เงินต้นเริ่มต้น</strong> (บาท)</li>
    <li><strong>อัตราดอกเบี้ยต่อปี</strong> (%)</li>
    <li><strong>ระยะเวลาฝาก</strong> (เดือน)</li>
    <li><strong>ประเภทเงินฝาก</strong> ฝากประจำ หรือ ออมทรัพย์แบบฝากเพิ่มรายเดือน</li>
  </ul>

  <p>
    ถ้าคุณยังไม่ชัดเจนว่าดอกเบี้ยสุทธิกระทบเงินรับจริงทั้งปีแค่ไหน ให้เทียบต่อใน
    <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/">เครื่องคำนวณภาษีเงินได้บุคคลธรรมดา</a> เพื่อปิดภาพภาษีทั้งระบบ
  </p>

  <h2>2) สูตรที่เครื่องมือใช้ (ให้ผลตรงกับหน้าเครื่องคำนวณ)</h2>

  <h3>ฝากประจำ</h3>
  <ul>
    <li><strong>ดอกเบี้ยก่อนภาษี</strong> = เงินต้น × อัตราดอกเบี้ยต่อปี × (จำนวนเดือน ÷ 12)</li>
    <li><strong>ภาษีหัก ณ ที่จ่าย</strong> = ดอกเบี้ยก่อนภาษี × 15%</li>
    <li><strong>ดอกเบี้ยสุทธิ</strong> = ดอกเบี้ยก่อนภาษี − ภาษี</li>
    <li><strong>ยอดรวมปลายงวด</strong> = เงินต้น + ดอกเบี้ยสุทธิ</li>
  </ul>

  <h3>ออมทรัพย์แบบฝากเพิ่มรายเดือน (ทบยอดรายเดือน)</h3>
  <ul>
    <li>ดอกเบี้ยรายเดือน = ยอดคงเหลือเดือนก่อน × (อัตราดอกเบี้ยต่อปี ÷ 12)</li>
    <li>ระบบจะบวกดอกเบี้ยเข้ายอด และเพิ่มเงินฝากรายเดือนตั้งแต่เดือนที่ 2</li>
    <li>เมื่อครบงวดจึงคำนวณภาษี 15% กับดอกเบี้ยรวม และสรุปเป็นดอกเบี้ยสุทธิ</li>
  </ul>

  <h2>3) ตัวอย่างคำนวณ (ชุดตัวเลขตรวจซ้ำได้)</h2>

  <h3>ตัวอย่าง A: ฝากประจำ</h3>
  <p>เงินต้น 100,000 บาท, ดอกเบี้ย 2.00% ต่อปี, ระยะเวลา 12 เดือน</p>
  <ul>
    <li>ดอกเบี้ยก่อนภาษี = 100,000 × 2% × (12/12) = <strong>2,000.00 บาท</strong></li>
    <li>ภาษีหัก ณ ที่จ่าย 15% = 2,000 × 15% = <strong>300.00 บาท</strong></li>
    <li>ดอกเบี้ยสุทธิ = 2,000 − 300 = <strong>1,700.00 บาท</strong></li>
    <li>ยอดรวมปลายงวด = 100,000 + 1,700 = <strong>101,700.00 บาท</strong></li>
  </ul>

  <h3>ตัวอย่าง B: ออมทรัพย์ + ฝากเพิ่มรายเดือน</h3>
  <p>เงินต้น 50,000 บาท, ฝากเพิ่ม 2,000 บาท/เดือน, ดอกเบี้ย 1.80% ต่อปี, ระยะเวลา 12 เดือน</p>
  <ul>
    <li>ยอดฝากรวมตามตรรกะเครื่องมือ = 50,000 + (11 × 2,000) = <strong>72,000.00 บาท</strong></li>
    <li>ดอกเบี้ยรวมก่อนภาษี = <strong>1,073.21 บาท</strong></li>
    <li>ภาษีหัก ณ ที่จ่าย 15% = <strong>160.98 บาท</strong></li>
    <li>ดอกเบี้ยสุทธิ = <strong>912.23 บาท</strong></li>
    <li>ยอดรวมปลายงวด = <strong>72,912.23 บาท</strong></li>
  </ul>

  <h2>4) วิธีใช้ผลลัพธ์ให้ตัดสินใจได้ดีขึ้น</h2>
  <ul>
    <li>เปรียบเทียบ <strong>ผลตอบแทนสุทธิ (% ต่อปี)</strong> แทนอัตราหน้าป้าย</li>
    <li>เทียบ 2-3 ทางเลือกด้วยเงินต้นและระยะเวลาเดียวกัน แล้วดูส่วนต่างผ่าน <a href="/คำนวณเปอร์เซ็นต์/">เครื่องคำนวณเปอร์เซ็นต์</a></li>
    <li>ตั้งงบออมจากเงินรับจริง โดยคำนวณฐานรายเดือนที่ <a href="/คำนวณเงินเดือนสุทธิ/">เครื่องคำนวณเงินเดือนสุทธิ</a></li>
    <li>ถ้าเป็นเงินออมระยะกลาง-ยาว ให้เทียบกับทางเลือกลงทุนจากบทความ <a href="/บทความ/เงินฝาก-vs-กองทุน-เปรียบเทียบ-2569/">เงินฝาก vs กองทุน 2569</a></li>
    <li>ถ้าวางแผนเกษียณ ให้ต่อยอดที่ <a href="/คำนวณเงินเกษียณ/">เครื่องคำนวณเงินเกษียณ</a> เพื่อดูเงินก้อนเป้าหมาย</li>
  </ul>

  <ArticleCalculatorCTA
    title="เช็กตัวเลขจริงก่อนตัดสินใจฝาก"
    description="ใส่ข้อมูลตามบัญชีจริง แล้วเทียบดอกเบี้ยสุทธิของแต่ละทางเลือกในหน้าเดียว"
    href="/คำนวณดอกเบี้ยเงินฝาก/"
    targetCalculator="deposit"
    buttonLabel="คำนวณดอกเบี้ยเงินฝากตอนนี้"
  />

  <h2>แหล่งข้อมูลอ้างอิง</h2>
  <ul>
    <li>
      กรมสรรพากร: ระบบนำส่งข้อมูลดอกเบี้ยออมทรัพย์ (ด.บ.01) และการใช้สิทธิยกเว้นภาษี
      <a href="https://www.rd.go.th/66737.html" target="_blank" rel="noopener noreferrer">https://www.rd.go.th/66737.html</a>
    </li>
    <li>
      กรมสรรพากร: เอกสารภาษีเงินได้บุคคลธรรมดาหัก ณ ที่จ่าย (ระบุหลักทั่วไปดอกเบี้ยหัก 15% และกรณียกเว้น)
      <a href="https://www.rd.go.th/publish/seminar/seminar_251261.pdf" target="_blank" rel="noopener noreferrer">https://www.rd.go.th/publish/seminar/seminar_251261.pdf</a>
    </li>
    <li>
      สถาบันคุ้มครองเงินฝาก (DPA): วงเงินคุ้มครองผู้ฝากเงิน
      <a href="https://www.dpa.or.th/coverage-limit" target="_blank" rel="noopener noreferrer">https://www.dpa.or.th/coverage-limit</a>
    </li>
    <li>ตรรกะสูตรคำนวณของหน้าเครื่องมือ: `src/lib/deposit-calculator.ts`</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>
  <ul>
    <li><a href="/บทความ/เงินเดือนสุทธิ-2569-คำนวณหัก-ประกันสังคม-ภาษี/">เงินเดือนสุทธิ 2569 คำนวณหักประกันสังคมและภาษี</a></li>
    <li><a href="/บทความ/เงินฝาก-vs-กองทุน-เปรียบเทียบ-2569/">เงินฝาก vs กองทุน เปรียบเทียบ 2569</a></li>
    <li><a href="/บทความ/คำนวณเงินเกษียณ-2569-วางแผนเงินพอใช้/">คำนวณเงินเกษียณ 2569: ต้องมีเงินเท่าไรถึงพอใช้</a></li>
    <li><a href="/บทความ/ภาษีเงินได้-2569-คำนวณ-วิธีลดหย่อน/">ภาษีเงินได้ 2569 คำนวณ พร้อมวิธีลดหย่อน</a></li>
  </ul>

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
