---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณประกันสังคม 2569 มาตรา 33 39 40 เงินสมทบเท่าไร | เครื่องคำนวณไทย';
const description = 'อธิบายวิธีคำนวณเงินสมทบประกันสังคม มาตรา 33 39 40 ปี 2569 พร้อมตารางเปรียบเทียบ สิทธิประโยชน์ และตัวอย่างคำนวณจริง อ้างอิงสำนักงานประกันสังคม (SSO)';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณประกันสังคม-2569-มาตรา-33-39-40-เงินสมทบ/`;

const faqData = [
  {
    question: 'ประกันสังคมมาตรา 33 หักเดือนละเท่าไร?',
    answer: 'ลูกจ้างจ่ายสมทบ 5% ของเงินเดือน โดยคำนวณจากฐานค่าจ้างขั้นต่ำ 1,650 บาท สูงสุด 15,000 บาท ดังนั้นจ่ายขั้นต่ำ 83 บาท สูงสุด 750 บาทต่อเดือน นายจ้างจ่ายสมทบเท่ากัน',
  },
  {
    question: 'ประกันสังคมมาตรา 39 จ่ายเดือนละเท่าไร ปี 2569?',
    answer: 'ผู้ประกันตนมาตรา 39 จ่ายเงินสมทบคงที่เดือนละ 432 บาท โดยรัฐบาลร่วมจ่าย 120 บาท คุ้มครอง 6 กรณี เหมาะสำหรับผู้ที่ลาออกจากงานแต่ต้องการรักษาสิทธิ์ประกันสังคมต่อ',
  },
  {
    question: 'ประกันสังคมมาตรา 40 ทางเลือกไหนคุ้มสุด?',
    answer: 'ขึ้นอยู่กับความต้องการ ทางเลือก 1 (70 บาท) คุ้มครอง 3 กรณี เหมาะกับงบน้อย ทางเลือก 2 (100 บาท) เพิ่มเงินชราภาพ ทางเลือก 3 (300 บาท) ครอบคลุมที่สุด 5 กรณี รวมสงเคราะห์บุตร เหมาะกับผู้ที่ต้องการสิทธิ์เต็ม',
  },
  {
    question: 'ลาออกจากงานแล้วต้องทำอย่างไรกับประกันสังคม?',
    answer: 'หลังลาออก สิทธิ์มาตรา 33 คุ้มครองต่ออีก 6 เดือน ภายใน 6 เดือนสามารถสมัครมาตรา 39 (จ่าย 432 บาท/เดือน) เพื่อรักษาสิทธิ์ต่อ หรือหากเป็นฟรีแลนซ์สามารถสมัครมาตรา 40 ได้ทันที',
  },
  {
    question: 'เงินสมทบประกันสังคมลดหย่อนภาษีได้ไหม?',
    answer: 'ได้ เงินสมทบประกันสังคมที่ลูกจ้างจ่ายสามารถใช้ลดหย่อนภาษีเงินได้บุคคลธรรมดาได้ทั้งจำนวน สูงสุด 9,000 บาทต่อปี (กรณีมาตรา 33 จ่ายเต็มเพดาน 750 บาท x 12 เดือน)',
  },
  {
    question: 'ประกันสังคมคุ้มครองกรณีอะไรบ้าง?',
    answer: 'มาตรา 33 คุ้มครอง 7 กรณี: เจ็บป่วย คลอดบุตร ทุพพลภาพ เสียชีวิต สงเคราะห์บุตร ชราภาพ ว่างงาน มาตรา 39 คุ้มครอง 6 กรณี (ไม่รวมว่างงาน) มาตรา 40 คุ้มครอง 3-5 กรณีตามทางเลือก',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-20"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    คำนวณประกันสังคม 2569: มาตรา 33 39 40 จ่ายเงินสมทบเท่าไร?
  </h1>

  <p>
    ทุกเดือนพนักงานประจำจะถูกหักเงินเข้ากองทุนประกันสังคมโดยอัตโนมัติ แต่หลายคนยังไม่แน่ใจว่าจ่ายเท่าไร ได้สิทธิ์อะไรบ้าง และมาตรา 33 39 40 ต่างกันอย่างไร บทความนี้อธิบายวิธีคำนวณเงินสมทบประกันสังคมทุกมาตราปี 2569 พร้อมตัวอย่างจริง อ้างอิงข้อมูลจากสำนักงานประกันสังคม (SSO)
  </p>

  <ArticleCalculatorCTA
    title="คำนวณเงินสมทบประกันสังคมของคุณทันที"
    description="เลือกมาตรา กรอกเงินเดือน ดูผลรวมเงินสมทบลูกจ้าง-นายจ้าง-รัฐบาล ทั้งรายเดือนและรายปี"
    href="/คำนวณประกันสังคม/"
    buttonLabel="คำนวณประกันสังคม"
    targetCalculator="social_security"
    placement="top_article_cta"
  />

  <h2>ประกันสังคมคืออะไร?</h2>

  <p>
    ประกันสังคมเป็นระบบสวัสดิการของรัฐที่คุ้มครองผู้ประกันตนเมื่อเจ็บป่วย พิการ เสียชีวิต คลอดบุตร ชราภาพ ตกงาน และสงเคราะห์บุตร โดยทั้งลูกจ้าง นายจ้าง และรัฐบาลร่วมกันจ่ายเงินสมทบเข้ากองทุน ซึ่งดูแลโดย <strong>สำนักงานประกันสังคม (สปส.)</strong> กระทรวงแรงงาน
  </p>

  <p>
    ปัจจุบันแบ่งผู้ประกันตนออกเป็น 3 มาตราหลัก ตามสถานะการทำงาน:
  </p>

  <ul>
    <li><strong>มาตรา 33</strong> — ลูกจ้างที่มีนายจ้าง (พนักงานประจำ)</li>
    <li><strong>มาตรา 39</strong> — ผู้ที่เคยเป็นลูกจ้างมาตรา 33 แล้วลาออก สมัครต่อเอง</li>
    <li><strong>มาตรา 40</strong> — ผู้ประกอบอาชีพอิสระ ฟรีแลนซ์ ค้าขาย</li>
  </ul>

  <h2>มาตรา 33: วิธีคำนวณเงินสมทบลูกจ้าง</h2>

  <p>
    ผู้ประกันตนมาตรา 33 คือลูกจ้างที่ทำงานในสถานประกอบการ นายจ้างต้องขึ้นทะเบียนลูกจ้างทุกคนเข้าระบบประกันสังคม โดยจ่ายเงินสมทบทั้งสองฝ่ายในอัตราเดียวกัน
  </p>

  <h3>สูตรคำนวณเงินสมทบมาตรา 33</h3>

  <div class="bg-gray-50 rounded-lg p-4 my-4">
    <p class="font-semibold">เงินสมทบ = ฐานค่าจ้าง x 5%</p>
    <p class="text-sm text-gray-600 mt-1">ฐานค่าจ้าง: ขั้นต่ำ 1,650 บาท — สูงสุด 15,000 บาท</p>
    <p class="text-sm text-gray-600">จ่ายต่ำสุด 83 บาท — สูงสุด 750 บาทต่อเดือน</p>
    <p class="text-xs text-gray-400 mt-2">อ้างอิง: สำนักงานประกันสังคม (SSO) อัตราปี 2569</p>
  </div>

  <p>
    ทั้งลูกจ้างและนายจ้างจ่ายสมทบฝ่ายละ 5% ของค่าจ้าง รัฐบาลร่วมจ่ายอีก 2.75% รวม 3 ฝ่าย:
  </p>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left border-b-2 border-gray-300">
          <th class="py-2 pr-4">ผู้จ่าย</th>
          <th class="py-2 pr-4">อัตราสมทบ</th>
          <th class="py-2 pr-4">ต่ำสุด/เดือน</th>
          <th class="py-2">สูงสุด/เดือน</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-gray-100"><td class="py-2 pr-4">ลูกจ้าง</td><td class="py-2 pr-4">5%</td><td class="py-2 pr-4">83 บาท</td><td class="py-2">750 บาท</td></tr>
        <tr class="border-b border-gray-100"><td class="py-2 pr-4">นายจ้าง</td><td class="py-2 pr-4">5%</td><td class="py-2 pr-4">83 บาท</td><td class="py-2">750 บาท</td></tr>
        <tr><td class="py-2 pr-4">รัฐบาล</td><td class="py-2 pr-4">2.75%</td><td class="py-2 pr-4">45.38 บาท</td><td class="py-2">412.50 บาท</td></tr>
      </tbody>
    </table>
  </div>

  <h3>ตัวอย่างการคำนวณมาตรา 33</h3>

  <p><strong>ตัวอย่างที่ 1: เงินเดือน 15,000 บาท</strong></p>
  <ul>
    <li>ฐานค่าจ้าง = 15,000 บาท (ไม่เกินเพดาน)</li>
    <li>ลูกจ้าง: 15,000 x 5% = <strong>750 บาท/เดือน</strong></li>
    <li>นายจ้าง: 15,000 x 5% = 750 บาท/เดือน</li>
    <li>รัฐบาล: 15,000 x 2.75% = 412.50 บาท/เดือน</li>
    <li>รวมทั้ง 3 ฝ่าย: 1,912.50 บาท/เดือน</li>
  </ul>

  <p><strong>ตัวอย่างที่ 2: เงินเดือน 25,000 บาท</strong></p>
  <ul>
    <li>เงินเดือนเกินเพดาน 15,000 บาท → คำนวณจากเพดาน 15,000 บาท</li>
    <li>ลูกจ้าง: 15,000 x 5% = <strong>750 บาท/เดือน</strong></li>
    <li>นายจ้าง: 750 บาท/เดือน</li>
    <li>รวมหักจากสลิปเงินเดือน = 750 บาทเท่ากัน ไม่ว่าเงินเดือนจะสูงแค่ไหน</li>
  </ul>

  <p><strong>ตัวอย่างที่ 3: เงินเดือน 10,000 บาท</strong></p>
  <ul>
    <li>ฐานค่าจ้าง = 10,000 บาท (ไม่เกินเพดาน)</li>
    <li>ลูกจ้าง: 10,000 x 5% = <strong>500 บาท/เดือน</strong></li>
    <li>นายจ้าง: 500 บาท/เดือน</li>
    <li>รัฐบาล: 10,000 x 2.75% = 275 บาท/เดือน</li>
  </ul>

  <h3>ตารางเงินสมทบมาตรา 33 ตามระดับเงินเดือน</h3>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left border-b-2 border-gray-300">
          <th class="py-2 pr-4">เงินเดือน</th>
          <th class="py-2 pr-4">เงินสมทบ/เดือน</th>
          <th class="py-2">เงินสมทบ/ปี</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-gray-100"><td class="py-2 pr-4">10,000 บาท</td><td class="py-2 pr-4">500 บาท</td><td class="py-2">6,000 บาท</td></tr>
        <tr class="border-b border-gray-100"><td class="py-2 pr-4">12,000 บาท</td><td class="py-2 pr-4">600 บาท</td><td class="py-2">7,200 บาท</td></tr>
        <tr class="border-b border-gray-100"><td class="py-2 pr-4">15,000 บาท</td><td class="py-2 pr-4">750 บาท</td><td class="py-2">9,000 บาท</td></tr>
        <tr class="border-b border-gray-100"><td class="py-2 pr-4">20,000 บาท</td><td class="py-2 pr-4">750 บาท</td><td class="py-2">9,000 บาท</td></tr>
        <tr class="border-b border-gray-100"><td class="py-2 pr-4">25,000 บาท</td><td class="py-2 pr-4">750 บาท</td><td class="py-2">9,000 บาท</td></tr>
        <tr class="border-b border-gray-100"><td class="py-2 pr-4">30,000 บาท</td><td class="py-2 pr-4">750 บาท</td><td class="py-2">9,000 บาท</td></tr>
        <tr><td class="py-2 pr-4">50,000+ บาท</td><td class="py-2 pr-4">750 บาท</td><td class="py-2">9,000 บาท</td></tr>
      </tbody>
    </table>
  </div>

  <p class="text-sm text-gray-500">
    * เงินเดือนตั้งแต่ 15,000 บาทขึ้นไปจ่ายเท่ากันที่ 750 บาท/เดือน เพราะเพดานฐานค่าจ้างอยู่ที่ 15,000 บาท
  </p>

  <ArticleCalculatorCTA
    title="ลองคำนวณเงินสมทบของคุณเลย"
    description="กรอกเงินเดือน ดูเงินสมทบที่ต้องจ่าย ทั้งส่วนลูกจ้าง นายจ้าง และรัฐบาล พร้อมสรุปรายปี"
    href="/คำนวณประกันสังคม/"
    buttonLabel="คำนวณประกันสังคมทันที"
    targetCalculator="social_security"
    placement="mid_article_cta"
  />

  <h2>มาตรา 39: สำหรับผู้ที่ลาออกจากงาน</h2>

  <p>
    มาตรา 39 ออกแบบมาสำหรับผู้ที่เคยเป็นลูกจ้างมาตรา 33 มาแล้วอย่างน้อย 12 เดือน และลาออกจากงานไม่เกิน 6 เดือน สามารถสมัครเป็นผู้ประกันตนต่อเพื่อรักษาสิทธิ์ประกันสังคม
  </p>

  <h3>เงื่อนไขการสมัครมาตรา 39</h3>

  <ul>
    <li>เคยเป็นผู้ประกันตนมาตรา 33 ไม่น้อยกว่า 12 เดือน</li>
    <li>ลาออกจากงานไม่เกิน 6 เดือน</li>
    <li>ยื่นแบบ สปส. 1-20 ที่สำนักงานประกันสังคมพื้นที่</li>
  </ul>

  <h3>เงินสมทบมาตรา 39</h3>

  <div class="bg-gray-50 rounded-lg p-4 my-4">
    <p class="font-semibold">จ่ายคงที่: 432 บาท/เดือน (5,184 บาท/ปี)</p>
    <p class="text-sm text-gray-600 mt-1">รัฐบาลร่วมจ่าย: 120 บาท/เดือน</p>
    <p class="text-sm text-gray-600">คุ้มครอง 6 กรณี: เจ็บป่วย คลอดบุตร ทุพพลภาพ เสียชีวิต สงเคราะห์บุตร ชราภาพ</p>
    <p class="text-xs text-gray-400 mt-2">อ้างอิง: สำนักงานประกันสังคม (SSO)</p>
  </div>

  <p>
    <strong>ข้อควรระวัง:</strong> หากไม่จ่ายเงินสมทบ 3 เดือนติดต่อกัน หรือภายใน 12 เดือนไม่จ่ายเกิน 9 เดือน สิ้นสุดความเป็นผู้ประกันตนมาตรา 39 ทันที
  </p>

  <h2>มาตรา 40: สำหรับฟรีแลนซ์และอาชีพอิสระ</h2>

  <p>
    ผู้ที่ไม่ได้เป็นลูกจ้างสามารถสมัครมาตรา 40 ได้ อายุ 15-65 ปี ไม่ต้องเคยอยู่ในระบบประกันสังคมมาก่อน มี 3 ทางเลือกที่ให้สิทธิ์คุ้มครองแตกต่างกัน:
  </p>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left border-b-2 border-gray-300">
          <th class="py-2 pr-4">ทางเลือก</th>
          <th class="py-2 pr-4">เงินสมทบ/เดือน</th>
          <th class="py-2 pr-4">รัฐบาลร่วมจ่าย</th>
          <th class="py-2">สิทธิ์คุ้มครอง</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-gray-100">
          <td class="py-2 pr-4 font-medium">ทางเลือก 1</td>
          <td class="py-2 pr-4">70 บาท</td>
          <td class="py-2 pr-4">30 บาท</td>
          <td class="py-2">เจ็บป่วย ทุพพลภาพ เสียชีวิต (3 กรณี)</td>
        </tr>
        <tr class="border-b border-gray-100">
          <td class="py-2 pr-4 font-medium">ทางเลือก 2</td>
          <td class="py-2 pr-4">100 บาท</td>
          <td class="py-2 pr-4">50 บาท</td>
          <td class="py-2">เจ็บป่วย ทุพพลภาพ เสียชีวิต ชราภาพ (4 กรณี)</td>
        </tr>
        <tr>
          <td class="py-2 pr-4 font-medium">ทางเลือก 3</td>
          <td class="py-2 pr-4">300 บาท</td>
          <td class="py-2 pr-4">150 บาท</td>
          <td class="py-2">เจ็บป่วย ทุพพลภาพ เสียชีวิต ชราภาพ สงเคราะห์บุตร (5 กรณี)</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p class="text-sm text-gray-500">อ้างอิง: สำนักงานประกันสังคม (SSO) อัตราปี 2569</p>

  <h3>เลือกทางเลือกไหนดี?</h3>

  <ul>
    <li><strong>ทางเลือก 1 (70 บาท)</strong> — เหมาะกับผู้มีรายได้น้อย ต้องการความคุ้มครองพื้นฐาน เจ็บป่วย ทุพพลภาพ เสียชีวิต</li>
    <li><strong>ทางเลือก 2 (100 บาท)</strong> — เพิ่มเงินบำเหน็จชราภาพ เหมาะกับผู้ที่ต้องการออมเงินระยะยาว</li>
    <li><strong>ทางเลือก 3 (300 บาท)</strong> — ครอบคลุมที่สุด เพิ่มเงินสงเคราะห์บุตร เหมาะกับฟรีแลนซ์ที่มีครอบครัว</li>
  </ul>

