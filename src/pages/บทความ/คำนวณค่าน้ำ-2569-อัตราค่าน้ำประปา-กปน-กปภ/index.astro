---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าน้ำ 2569 | เช็กบิลก่อนจ่ายจริง | เครื่องคำนวณไทย';
const description = 'สรุปวิธีคำนวณค่าน้ำ 2569 สำหรับ กปน. และ กปภ. พร้อมเคส 50/51 หน่วย ขั้นต่ำ 150 บาท จุดพลาดที่พบบ่อย และลิงก์เครื่องคำนวณค่าน้ำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าน้ำ-2569-อัตราค่าน้ำประปา-กปน-กปภ/`;

const faqData = [
  {
    question: 'ค่าน้ำประปา กปน. ปี 2569 คิดอย่างไร?',
    answer: 'ค่าน้ำ กปน. คิดแบบขั้นบันไดตามปริมาณใช้น้ำรายเดือน จากนั้นบวกค่าบริการรายเดือนตามขนาดมิเตอร์ และค่าน้ำดิบ 0.15 บาทต่อ ลบ.ม. ก่อนคิด VAT ตามอัตราที่ใช้งานจริงในบิล',
  },
  {
    question: 'ค่าน้ำ กปภ. บ้านอยู่อาศัย ถ้าใช้เกิน 50 หน่วยต้องคิดแบบไหน?',
    answer: 'ตามประกาศการจัดประเภทผู้ใช้น้ำของ กปภ. ผู้ใช้น้ำประเภทที่อยู่อาศัยประเภท 1 หากใช้น้ำเกิน 50 ลบ.ม./เดือน จะคิดอัตราเท่ากับประเภท 2 ตั้งแต่หน่วยที่ 51 เป็นต้นไป',
  },
  {
    question: 'ทำไมค่าน้ำคำนวณเองยังไม่ตรงบิลจริง?',
    answer: 'โดยทั่วไปเกิดจากการปัดเศษ การนับรอบวันจดมาตรวัดไม่เท่ากับจำนวนวันในปฏิทิน และรายการอื่นเฉพาะพื้นที่ที่อาจปรากฏในใบแจ้งค่าน้ำของหน่วยงาน',
  },
  {
    question: 'ค่าน้ำขั้นต่ำ 150 บาทของ กปภ. ใช้เมื่อไร?',
    answer: 'หากค่าน้ำตามขั้นบันไดต่ำกว่าเกณฑ์ขั้นต่ำของพื้นที่ ระบบจะปรับยอดขึ้นเป็นขั้นต่ำ 150 บาทต่อเดือนตามตารางอัตราที่ประกาศ (ก่อน VAT)',
  },
  {
    question: 'ทำไมบางเดือนใช้น้ำ 0 หน่วยแต่ยังมียอดค่าน้ำ?',
    answer: 'กรณี กปน. อาจยังมีค่าบริการรายเดือนตามขนาดมิเตอร์ ส่วนกรณี กปภ. ถ้าใช้น้ำต่ำมากและยอดตามขั้นบันไดต่ำกว่าเกณฑ์ ระบบอาจถูกปรับขึ้นเป็นขั้นต่ำตามตารางพื้นที่ก่อนคิด VAT',
  },
  {
    question: 'ค่าน้ำ กปภ. ต้องเลือกตาราง 1, 2 หรือ 3 อย่างไร?',
    answer: 'ให้ยึดประเภทตารางจากใบแจ้งค่าน้ำหรือพื้นที่บริการจริงเป็นหลัก เพราะแต่ละตารางมีอัตราต่างกัน หากเลือกผิดจะทำให้ยอดคำนวณคลาดทั้งบิลทันที',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-17"
  modifiedDate="2026-04-19"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    คำนวณค่าน้ำ 2569: วิธีคิดบิลประปา กปน. และ กปภ. แบบใช้ได้จริง
  </h1>

  <p>
    ถ้าคุณกำลังหาคำตอบว่า <strong>คำนวณค่าน้ำ 2569</strong> ต้องเริ่มจากจุดไหน บทความนี้ออกแบบมาให้ใช้ได้กับชีวิตจริง ไม่ใช่แค่สูตรสั้น ๆ
    เป้าหมายคือช่วยให้คุณอ่านบิลเป็น แยกที่มาของตัวเลขได้ และวางงบค่าน้ำรายเดือนแบบมีเหตุผล โดยเฉพาะบ้านที่ต้องการควบคุมค่าสาธารณูปโภคพร้อมค่าไฟและค่างวดอื่นในเดือนเดียวกัน
  </p>

  <p>
    เนื้อหานี้สรุปอัตราจากแหล่งทางการของการประปานครหลวง (กปน.) และการประปาส่วนภูมิภาค (กปภ.) พร้อมอธิบายเงื่อนไขสำคัญที่หลายคนพลาด
    เช่น กรณี กปภ. ที่ใช้น้ำเกิน 50 หน่วยแล้วอัตรากระโดดขึ้น รวมถึงวิธีเช็กขั้นต่ำค่าน้ำ 150 บาทว่าถูกใช้ในเดือนไหน
  </p>

  <ArticleCalculatorCTA
    title="เช็กค่าน้ำบ้านคุณทันทีด้วยตัวเลขจริง"
    description="กรอกจำนวนหน่วยที่ใช้ เลือก กปน. หรือ กปภ. แล้วดูผลก่อน/หลัง VAT พร้อมแยกตามช่วงหน่วย"
    href="/คำนวณค่าน้ำ/"
    buttonLabel="ไปที่เครื่องคำนวณค่าน้ำ"
    targetCalculator="water_bill"
    placement="top_article_cta"
  />

  <h2>คำนวณค่าน้ำต้องรู้ข้อมูลอะไรบ้างก่อนเริ่ม</h2>

  <p>
    ก่อนคิดตัวเลข ให้รวบรวม 4 อย่างนี้จากบิลล่าสุดหรือข้อมูลบ้านของคุณ
  </p>

  <ol>
    <li><strong>จำนวนหน่วยใช้น้ำต่อเดือน (ลบ.ม.)</strong> ที่จดจริงในรอบบิล</li>
    <li><strong>หน่วยงานผู้ให้บริการ</strong> ว่าเป็น กปน. หรือ กปภ. และอยู่ในตารางอัตราใด</li>
    <li><strong>ขนาดมาตรวัดน้ำ</strong> สำหรับกรณี กปน. ที่มีค่าบริการรายเดือนตามขนาดมิเตอร์</li>
    <li><strong>VAT</strong> เพื่อสรุปยอดชำระรวมปลายบิลให้ใกล้เคียงของจริง</li>
  </ol>

  <p>
    ถ้าข้ามขั้นตอนนี้ไปคำนวณทันที โอกาสสูงที่จะได้ตัวเลขต่ำกว่าบิลจริง โดยเฉพาะบ้านที่ใช้สูตรคูณหน่วยด้วยอัตราเดียวทั้งบิล
    ทั้งที่ระบบคิดจริงเป็นขั้นบันได และบางพื้นที่มีเงื่อนไขขั้นต่ำหรือเปลี่ยนอัตราหลังหน่วยที่กำหนด
  </p>

  <h2>วิธีคิดค่าน้ำ กปน. (บ้านอยู่อาศัย) ปี 2569</h2>

  <p>
    จากหน้าอัตราค่าน้ำของ กปน. อัตราบ้านอยู่อาศัยคิดแบบขั้นบันได และยังมี <strong>ค่าบริการรายเดือนตามขนาดมิเตอร์</strong>
    รวมถึง <strong>ค่าน้ำดิบ 0.15 บาท/ลบ.ม.</strong> ที่ระบุไว้ในหมายเหตุของหน่วยงานก่อนนำไปคิด VAT
  </p>

  <p>
    สูตรย่อที่ใช้งานได้จริงมีดังนี้
    <br />
    <strong>ยอดก่อน VAT = ค่าน้ำตามขั้นบันได + ค่าบริการรายเดือน + (หน่วยน้ำ × 0.15)</strong>
  </p>

  <h3>ตัวอย่างจริง (กปน.): ใช้น้ำ 35 หน่วย, มิเตอร์ 1/2 นิ้ว</h3>

  <ul>
    <li>หน่วย 0-30: 30 × 8.50 = 255.00 บาท</li>
    <li>หน่วย 31-35: 5 × 10.03 = 50.15 บาท</li>
    <li>รวมค่าน้ำตามขั้นบันได = <strong>305.15 บาท</strong></li>
    <li>ค่าบริการรายเดือนมิเตอร์ 1/2 นิ้ว = <strong>25.00 บาท</strong></li>
    <li>ค่าน้ำดิบ = 35 × 0.15 = <strong>5.25 บาท</strong></li>
    <li>ยอดก่อน VAT = 305.15 + 25.00 + 5.25 = <strong>335.40 บาท</strong></li>
    <li>VAT 7% = <strong>23.48 บาท</strong></li>
    <li>ยอดรวมสุทธิ = <strong>358.88 บาท</strong></li>
  </ul>

  <p>
    ตัวอย่างนี้ช่วยให้เห็นชัดว่า ถ้าลืมค่าบริการหรือค่าน้ำดิบ แม้จะคิดขั้นบันไดถูกแล้ว ก็ยังคลาดจากบิลได้ทันที
  </p>

  <h2>วิธีคิดค่าน้ำ กปภ. ปี 2569 และจุดสำคัญที่คนพลาดบ่อย</h2>

  <p>
    กปภ. มีตารางอัตราตามพื้นที่ (ตาราง 1, 2, 3) แต่หลักที่ต้องจำคือ สำหรับผู้ใช้น้ำที่อยู่อาศัยประเภท 1
    หากใช้น้ำเกิน 50 ลบ.ม./เดือน จะคิดอัตราเท่ากับประเภท 2 ตั้งแต่หน่วยที่ 51 เป็นต้นไปตามประกาศการจัดประเภทผู้ใช้น้ำ
  </p>

  <p>
    อีกจุดคือเรื่องขั้นต่ำค่าน้ำ 150 บาท/เดือนในแต่ละตารางพื้นที่ หากค่าน้ำตามขั้นบันไดต่ำกว่าเกณฑ์ ระบบจะปรับขึ้นตามขั้นต่ำก่อนคิด VAT
  </p>

  <h3>ตัวอย่างจริง (กปภ. ตาราง 3): ใช้น้ำ 5 หน่วย</h3>

  <ul>
    <li>ค่าน้ำตามขั้นบันได: 5 × 10.20 = <strong>51.00 บาท</strong></li>
    <li>ขั้นต่ำค่าน้ำตามตาราง: <strong>150.00 บาท</strong></li>
    <li>ส่วนเพิ่มจากขั้นต่ำ: 150.00 - 51.00 = <strong>99.00 บาท</strong></li>
    <li>ยอดก่อน VAT = <strong>150.00 บาท</strong></li>
    <li>VAT 7% = <strong>10.50 บาท</strong></li>
    <li>ยอดรวมสุทธิ = <strong>160.50 บาท</strong></li>
  </ul>

  <h3>ตัวอย่างจริง (กปภ. ตาราง 1): ใช้น้ำ 120 หน่วย</h3>

  <p>
    กรณีนี้ใช้สูตรแบบขั้นบันไดช่วง 1-50 หน่วยตามอัตราที่อยู่อาศัยประเภท 1 แล้วหน่วยที่ 51 ขึ้นไปให้ใช้อัตราประเภท 2
  </p>

  <ul>
    <li>หน่วย 0-10: 10 × 10.20 = 102.00 บาท</li>
    <li>หน่วย 11-20: 10 × 16.00 = 160.00 บาท</li>
    <li>หน่วย 21-30: 10 × 19.00 = 190.00 บาท</li>
    <li>หน่วย 31-50: 20 × 21.20 = 424.00 บาท</li>
    <li>หน่วย 51-80: 30 × 23.00 = 690.00 บาท (เริ่มใช้อัตราประเภท 2)</li>
    <li>หน่วย 81-100: 20 × 24.00 = 480.00 บาท</li>
    <li>หน่วย 101-120: 20 × 27.40 = 548.00 บาท</li>
    <li>รวมค่าน้ำก่อน VAT = <strong>2,594.00 บาท</strong></li>
    <li>VAT 7% = <strong>181.58 บาท</strong></li>
    <li>ยอดรวมสุทธิ = <strong>2,775.58 บาท</strong></li>
  </ul>

  <h2>เคส Long-tail ที่คนค้นบ่อยก่อนจ่ายบิลค่าน้ำ</h2>

  <h3>เคสที่ 1: ใช้น้ำ 50 หน่วย vs 51 หน่วย (กปภ. ตาราง 1)</h3>
  <p>
    กรณีนี้เป็นจุดเปลี่ยนสำคัญตามประกาศ กปภ. เพราะหน่วยที่ 51 จะเริ่มคิดแบบอัตราประเภท 2 ทันที
  </p>
  <ul>
    <li>ที่ 50 หน่วย: ค่าน้ำก่อน VAT = <strong>876.00 บาท</strong>, รวม VAT 7% = <strong>937.32 บาท</strong></li>
    <li>ที่ 51 หน่วย: ค่าน้ำก่อน VAT = <strong>899.00 บาท</strong>, รวม VAT 7% = <strong>961.93 บาท</strong></li>
    <li>ต่างกันเพียง 1 หน่วย แต่ยอดรวมเพิ่ม <strong>24.61 บาท</strong></li>
  </ul>

  <h3>เคสที่ 2: หน่วยเท่าเดิม แต่บิล กปน. ต่างเพราะขนาดมิเตอร์</h3>
  <p>
    สำหรับ กปน. นอกจากขั้นบันได ต้องรวมค่าบริการรายเดือนตามขนาดมิเตอร์และค่าน้ำดิบ 0.15 บาท/ลบ.ม. ด้วย
  </p>
  <ul>
    <li>ตัวอย่างใช้น้ำ 30 หน่วย มิเตอร์ 1/2 นิ้ว: รวม VAT แล้ว <strong>304.42 บาท</strong></li>
    <li>ตัวอย่างใช้น้ำ 30 หน่วย มิเตอร์ 3/4 นิ้ว: รวม VAT แล้ว <strong>320.47 บาท</strong></li>
    <li>หน่วยน้ำเท่ากัน แต่ยอดต่าง <strong>16.05 บาท</strong> จากค่าบริการรายเดือน</li>
  </ul>

  <h3>เคสที่ 3: ใช้น้ำน้อยมาก แต่ยังเจอขั้นต่ำ 150 บาท</h3>
  <p>
    ถ้าอยู่ในพื้นที่ กปภ. และค่าน้ำตามขั้นบันไดต่ำกว่าเกณฑ์ขั้นต่ำ ระบบจะยกยอดเป็นขั้นต่ำก่อนคิด VAT
  </p>
  <ul>
    <li>ตัวอย่างใช้น้ำ 8 หน่วย (กปภ. ตาราง 3): ค่าน้ำตามขั้นบันได 81.60 บาท</li>
    <li>เมื่อเจอเกณฑ์ขั้นต่ำ: ยอดก่อน VAT = <strong>150.00 บาท</strong></li>
    <li>ยอดรวมสุทธิหลัง VAT = <strong>160.50 บาท</strong></li>
  </ul>

  <p>
    ถ้าคุณต้องคุมงบค่าน้ำรายเดือนแบบใกล้เคียงบิลจริง ควรจำลองอย่างน้อย 2-3 ฉากทัศน์รอบจุดเปลี่ยน (เช่น 50/51 หน่วย หรือเปลี่ยนขนาดมิเตอร์)
    แล้วค่อยตั้งงบเผื่อปลอดภัยสำหรับเดือนถัดไป
  </p>

  <h2>ข้อผิดพลาดที่ทำให้ค่าน้ำคำนวณผิดบ่อยที่สุด</h2>

  <ol>
    <li><strong>คูณหน่วยทั้งหมดด้วยอัตราเดียว</strong> ทั้งที่ค่าน้ำคิดแบบหลายช่วงหน่วย</li>
    <li><strong>เลือกตารางพื้นที่ กปภ. ผิด</strong> ทำให้อัตราทุกขั้นคลาดตั้งแต่ต้น</li>
    <li><strong>ลืมกติกาเกิน 50 หน่วยของ กปภ.</strong> แล้วใช้เรตอยู่อาศัยประเภท 1 ต่อเนื่องทั้งบิล</li>
    <li><strong>ไม่คิดขั้นต่ำค่าน้ำ</strong> ในเดือนที่ใช้น้ำน้อย ทำให้ประเมินต่ำเกินจริง</li>
    <li><strong>ลืมค่าบริการรายเดือนและค่าน้ำดิบของ กปน.</strong> โดยเฉพาะบ้านที่ใช้มิเตอร์ขนาดใหญ่ขึ้น</li>
    <li><strong>คิดเฉพาะยอดก่อน VAT</strong> แล้วนำไปวางงบปลายเดือนทันที</li>
  </ol>

  <h2>วิธีใช้เครื่องคำนวณให้ใกล้บิลจริงที่สุด</h2>

  <ul>
    <li>ดึงหน่วยใช้น้ำจากบิลเดือนล่าสุด ไม่ใช้ค่าเฉลี่ยย้อนหลังแบบคร่าว ๆ</li>
    <li>ตรวจให้แน่ใจว่าเลือกหน่วยงานและตารางอัตราตรงพื้นที่บริการจริง</li>
    <li>กรอกขนาดมิเตอร์ให้ตรงบิล หากคำนวณฝั่ง กปน.</li>
    <li>คำนวณอย่างน้อย 2 ฉากทัศน์ เช่น เดือนปกติและเดือนใช้น้ำสูง เพื่อกันงบพลาด</li>
    <li>ใช้ผลลัพธ์ร่วมกับเครื่องคำนวณค่าไฟ เพื่อวางเพดานค่าสาธารณูปโภคทั้งบ้าน</li>
  </ul>

