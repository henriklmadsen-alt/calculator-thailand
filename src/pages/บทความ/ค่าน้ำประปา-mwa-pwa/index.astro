---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'ค่าน้ำประปา MWA กับ PWA ต่างกันอย่างไร อัตราขั้นบันได 2569 | เครื่องคำนวณไทย';
const description = 'อธิบายความแตกต่างระหว่าง MWA และ PWA อัตราค่าน้ำแบบขั้นบันได 2569 องค์ประกอบของบิลน้ำ และวิธีคำนวณค่าน้ำประปาที่ถูกต้อง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ค่าน้ำประปา-mwa-pwa/`;

const faqData = [
  {
    question: 'MWA และ PWA ต่างกันอย่างไร?',
    answer: 'MWA (การประปานครหลวง) ให้บริการกรุงเทพฯ นนทบุรี และสมุทรปราการ PWA (การประปาส่วนภูมิภาค) ให้บริการ 74 จังหวัดที่เหลือ อัตราค่าน้ำของ PWA อาจต่ำกว่า MWA เล็กน้อยในบางช่วง',
  },
  {
    question: 'ค่าน้ำประปาคำนวณจากอะไร?',
    answer: 'คำนวณจากปริมาณน้ำที่ใช้ (ลูกบาศก์เมตร หรือ ม³) บวกค่าบำรุงท่อส่ง ค่าน้ำเสีย และค่าบริการคงที่ จากนั้นรวม VAT 7%',
  },
  {
    question: 'หน่วยลูกบาศก์เมตรเท่ากับกี่ลิตร?',
    answer: '1 ลูกบาศก์เมตร (1 ม³) เท่ากับ 1,000 ลิตร บ้านทั่วไปใช้น้ำเฉลี่ย 10–20 ม³ต่อเดือนต่อคน',
  },
  {
    question: 'ทำไมค่าน้ำใช้ระบบขั้นบันได?',
    answer: 'ระบบขั้นบันไดกระตุ้นให้ประหยัดน้ำ ผู้ใช้น้อยจ่ายถูก ผู้ใช้มากจ่ายแพงขึ้นต่อหน่วย เพื่อลดการสูญเสียน้ำและส่งเสริมการอนุรักษ์ทรัพยากรน้ำ',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  modifiedDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    ค่าน้ำประปา MWA กับ PWA ต่างกันอย่างไร อัตราขั้นบันได 2569
  </h1>

  <p>
    ค่าน้ำประปาในไทยให้บริการโดย <strong>MWA (การประปานครหลวง)</strong> ในกรุงเทพฯ และปริมณฑล
    และ <strong>PWA (การประปาส่วนภูมิภาค)</strong> ในต่างจังหวัด
    ทั้งสองใช้อัตราขั้นบันไดที่คล้ายกัน บทความนี้จะอธิบายโครงสร้างและวิธีคำนวณ
    ใช้ <a href="/คำนวณค่าน้ำ/">เครื่องคำนวณค่าน้ำ</a> เพื่อดูยอดรวมที่แม่นยำ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณค่าน้ำประปาของคุณ"
    description="ใส่ปริมาณน้ำที่ใช้ แล้วดูยอดค่าน้ำรวม VAT ได้ทันที"
    href="/คำนวณค่าน้ำ/"
    buttonLabel="คำนวณค่าน้ำประปา"
  />

  <h2>MWA และ PWA คืออะไร ให้บริการพื้นที่ไหน</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">หน่วยงาน</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ชื่อเต็ม</th>
          <th class="border border-gray-200 px-3 py-2 text-left">พื้นที่ให้บริการ</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">MWA</td><td class="border border-gray-200 px-3 py-2">การประปานครหลวง</td><td class="border border-gray-200 px-3 py-2">กรุงเทพฯ นนทบุรี สมุทรปราการ</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">PWA</td><td class="border border-gray-200 px-3 py-2">การประปาส่วนภูมิภาค</td><td class="border border-gray-200 px-3 py-2">74 จังหวัดที่เหลือทั่วประเทศ</td></tr>
      </tbody>
    </table>
  </div>

  <h2>อัตราค่าน้ำแบบขั้นบันได MWA</h2>

  <p>
    MWA ใช้อัตราขั้นบันไดสำหรับที่อยู่อาศัย ยิ่งใช้มาก ราคาต่อหน่วยสูงขึ้น:
  </p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[480px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ระดับการใช้ (ม³)</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ราคา (บาท/ม³)</th>
        </tr>
      </thead>
      <tbody>
        <tr class="bg-green-50"><td class="border border-gray-200 px-3 py-2">0–10 ม³</td><td class="border border-gray-200 px-3 py-2">8.50</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">11–20 ม³</td><td class="border border-gray-200 px-3 py-2">9.50</td></tr>
        <tr class="bg-yellow-50"><td class="border border-gray-200 px-3 py-2">21–30 ม³</td><td class="border border-gray-200 px-3 py-2">11.00</td></tr>
        <tr class="bg-orange-50"><td class="border border-gray-200 px-3 py-2">31–40 ม³</td><td class="border border-gray-200 px-3 py-2">12.50</td></tr>
        <tr class="bg-red-50"><td class="border border-gray-200 px-3 py-2">มากกว่า 40 ม³</td><td class="border border-gray-200 px-3 py-2">14.00</td></tr>
      </tbody>
    </table>
  </div>

  <h2>องค์ประกอบของบิลค่าน้ำ</h2>

  <p>บิลค่าน้ำประกอบด้วยมากกว่าแค่ค่าน้ำพื้นฐาน:</p>

  <ul>
    <li><strong>ค่าน้ำพื้นฐาน:</strong> คำนวณจากปริมาณน้ำที่ใช้ตามอัตราขั้นบันได</li>
    <li><strong>ค่าบำรุงท่อส่ง:</strong> ประมาณ 20% ของค่าน้ำพื้นฐาน</li>
    <li><strong>ค่าน้ำเสีย:</strong> เพื่อระบบสาธารณูปโภคบำบัดน้ำเสีย</li>
    <li><strong>ค่าบริการคงที่:</strong> 10–50 บาท/เดือน ตามขนาดท่อ</li>
    <li><strong>VAT 7%:</strong> คิดจากยอดรวมก่อนภาษี</li>
  </ul>

  <h2>วิธีอ่านมิเตอร์น้ำ</h2>

  <p>
    มิเตอร์น้ำแสดงตัวเลขสะสมตั้งแต่เริ่มต้น ค่าน้ำแต่ละเดือนคำนวณจากส่วนต่างระหว่างเดือนนี้กับเดือนที่แล้ว
    ตัวอย่าง: เดือนที่แล้วอ่านได้ 350 ม³ เดือนนี้ 380 ม³ → ใช้น้ำ 30 ม³ เดือนนี้
  </p>

  <ArticleCalculatorCTA
    title="คำนวณค่าน้ำจากปริมาณที่ใช้"
    description="ใส่จำนวนลูกบาศก์เมตร แล้วดูยอดค่าน้ำรวม VAT สำหรับ MWA หรือ PWA"
    href="/คำนวณค่าน้ำ/"
    buttonLabel="คำนวณค่าน้ำประปาตอนนี้"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณค่าน้ำ/">คำนวณค่าน้ำ</a> คำนวณบิลค่าน้ำประปา</li>
    <li><a href="/คำนวณค่าไฟฟ้า/">คำนวณค่าไฟฟ้า</a> คำนวณบิลค่าไฟฟ้า</li>
    <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a> วางงบค่าสาธารณูปโภครายเดือน</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/ใช้น้ำ-30-ลูกบาศก์เมตร-ค่าน้ำเท่าไร/">ใช้น้ำ 30 ลูกบาศก์เมตร ค่าน้ำเดือนนี้เท่าไร รวม VAT</a></li>
    <li><a href="/บทความ/คำนวณค่าน้ำ-2569-อัตราค่าน้ำประปา-กปน-กปภ/">คำนวณค่าน้ำ 2569 อัตราค่าน้ำประปา กปน กปภ</a></li>
  </ul>

  <h2>แหล่งอ้างอิง</h2>
  <ul>
    <li><a href="https://www.mwa.co.th" target="_blank" rel="noopener noreferrer">การประปานครหลวง (MWA)</a></li>
    <li><a href="https://www.pwa.co.th" target="_blank" rel="noopener noreferrer">การประปาส่วนภูมิภาค (PWA)</a></li>
  </ul>
</BlogPostLayout>
