const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'หน้าแรก',
      item: siteUrl + '/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'บทความ',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="บทความ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />

  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">
    บทความการเงินไทย
  </h1>
  <p class="text-gray-600 mb-8">
    เคล็ดลับวางแผนภาษี คำนวณเงินเดือน ผ่อนรถ ดอกเบี้ยเงินฝาก และสุขภาพ อัปเดตล่าสุดปี 2569
  </p>

  <div class="space-y-6">
    {articles.map((article) => (
      <a href={`/บทความ/${article.slug}/`} class="block bg-white rounded-lg shadow-sm border border-gray-200 p-5 sm:p-6 hover:shadow-md hover:border-primary-200 transition-all group">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs font-medium px-2 py-0.5 bg-primary-50 text-primary-700 rounded-full">{article.category}</span>
          <time class="text-xs text-gray-400" datetime={article.date}>
            {new Date(article.date).toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
        <h2 class="text-lg font-bold text-gray-900 group-hover:text-primary-600 transition-colors mb-2">
          {article.title}
        </h2>
        <p class="text-sm text-gray-600 leading-relaxed mb-3">
          {article.description}
        </p>
        <span class="inline-flex items-center text-sm text-primary-600 font-medium">
          อ่านบทความ
          <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>
    ))}
  </div>

  <!-- AdSense placeholder -->
  <div class="my-8 p-4 bg-gray-50 rounded-lg border border-dashed border-gray-200 text-center text-sm text-gray-400">
    <!-- AdSense ad unit will go here -->
  </div>

  <!-- Link back to calculators -->
  <div class="mt-8">
    <h2 class="text-lg font-bold text-gray-900 mb-4">เครื่องคำนวณยอดนิยม</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">คำนวณภาษี</a>
      <a href="/คำนวณเงินเดือนสุทธิ/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">เงินเดือนสุทธิ</a>
      <a href="/คำนวณผ่อนรถ/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">ผ่อนรถ</a>
      <a href="/คำนวณ-bmi/" class="p-3 bg-white rounded-lg border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all text-sm font-medium text-gray-700 text-center">คำนวณ BMI</a>
    </div>
  </div>
</BaseLayout>
