---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าเช่าร้าน 2569 | ค่าเช่า มัดจำ เซ้ง ค่าใช้จ่ายเปิดร้าน | Kamnuanlek';
const description = 'สรุปวิธีคำนวณค่าเช่าร้านค้า สำนักงาน ปี 2569 ค่ามัดจำ ค่าเซ้ง ค่าส่วนกลาง ค่าที่จอดรถ พร้อมเคสตัวอย่างจริง และลิงก์เครื่องคำนวณค่าเช่าร้าน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าเช่าร้าน-2569-ค่าเช่า-มัดจำ-เซ้ง/`;

const faqData = [
  {
    question: 'ค่าเช่าร้านค้าในกรุงเทพฯ เฉลี่ยเท่าไหร่ต่อตารางเมตร?',
    answer: 'ค่าเช่าร้านค้าในกรุงเทพฯ แตกต่างตามทำเล ย่านศูนย์กลาง (สยาม สีลม สุขุมวิท) อยู่ที่ 800-3,000 บาท/ตร.ม./เดือน ย่านชุมชนทั่วไปอยู่ที่ 200-600 บาท/ตร.ม./เดือน ตลาดนัดหรือพื้นที่ชั่วคราวเริ่มต้นที่ 3,000-15,000 บาท/เดือน',
  },
  {
    question: 'ค่าเซ้งคุ้มไหม ควรจ่ายเท่าไหร่?',
    answer: 'ค่าเซ้งคุ้มค่าหากทำเลดีมีลูกค้าสม่ำเสมอ วิธีประเมินคือ คิดรายได้คาดการณ์ต่อเดือนหลังหักค่าใช้จ่าย ถ้าค่าเซ้งสามารถคืนทุนได้ภายใน 6-12 เดือน ถือว่าอยู่ในเกณฑ์ที่ยอมรับได้ ถ้าเกิน 2 ปีถือว่าเสี่ยง',
  },
  {
    question: 'สัญญาเช่าร้านค้าควรทำกี่ปี?',
    answer: 'ร้านค้าทั่วไปมักเริ่มที่สัญญา 1-3 ปี ร้านที่ต้องลงทุนตกแต่งมากควรทำสัญญา 3-5 ปีเพื่อให้คุ้มค่าการลงทุน สัญญาเกิน 3 ปีต้องจดทะเบียนที่สำนักงานที่ดินจึงจะมีผลบังคับใช้ตามกฎหมาย',
  },
  {
    question: 'ค่าส่วนกลางร้านค้าในศูนย์การค้าคิดอย่างไร?',
    answer: 'ค่าส่วนกลางในศูนย์การค้าคิดตามพื้นที่เช่า ประมาณ 100-300 บาท/ตร.ม./เดือน ครอบคลุมค่ารปภ. ทำความสะอาด แอร์ส่วนกลาง ลิฟต์ และบำรุงรักษาอาคาร บางที่คิดรวมค่าส่งเสริมการขายด้วย',
  },
  {
    question: 'เตรียมเงินเท่าไหร่ก่อนเปิดร้าน?',
    answer: 'ค่าใช้จ่ายเริ่มต้นที่ต้องเตรียม: ค่ามัดจำ (2-6 เดือน) + ค่าเช่าล่วงหน้า (1-2 เดือน) + ค่าเซ้ง (ถ้ามี) + ค่าตกแต่ง + เงินหมุนเวียน 3-6 เดือน ควรมีเงินสำรองอย่างน้อย 6 เดือนของค่าใช้จ่ายรวม',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-20"
  modifiedDate="2026-04-20"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    คำนวณค่าเช่าร้าน 2569: ค่าเช่า มัดจำ เซ้ง สรุปทุกค่าใช้จ่ายก่อนเปิดร้าน
  </h1>

  <p>
    ก่อนเซ็นสัญญาเช่าร้านค้าหรือสำนักงาน สิ่งที่หลายคนพลาดคือ <strong>ดูแค่ค่าเช่ารายเดือน</strong> โดยลืมค่าใช้จ่ายแฝงอื่น ๆ
    ที่ทำให้ต้นทุนจริงสูงกว่าที่คิดมาก บทความนี้สรุปทุกรายการค่าใช้จ่ายที่ต้องเตรียม พร้อมวิธีคำนวณเพื่อวางแผนงบประมาณก่อนเปิดกิจการ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณค่าเช่าร้าน"
    href="/คำนวณค่าเช่าร้าน/"
    description="กรอกค่าเช่า ค่าส่วนกลาง ค่าที่จอดรถ ค่าสาธารณูปโภค และค่าเซ้ง — ดูค่าใช้จ่ายรวมทันที"
  />

  <h2>1. ค่าเช่ารายเดือน — ตัวเลขหลักที่ต้องรู้</h2>

  <p>
    ค่าเช่ารายเดือนคือฐานของค่าใช้จ่ายทั้งหมด อัตราค่าเช่าขึ้นอยู่กับทำเล ขนาดพื้นที่ ชั้นของอาคาร และประเภทกิจการที่เปิด
    การเปรียบเทียบควรดูที่ <strong>ค่าเช่าต่อตารางเมตรต่อเดือน</strong> เพื่อให้เทียบทำเลต่างกันได้อย่างยุติธรรม
  </p>

  <table>
    <thead>
      <tr>
        <th>ทำเล</th>
        <th>ค่าเช่าโดยประมาณ (บาท/ตร.ม./เดือน)</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>ย่านศูนย์กลาง กรุงเทพฯ</td>
        <td>800 - 3,000</td>
      </tr>
      <tr>
        <td>ย่านชุมชนทั่วไป</td>
        <td>200 - 600</td>
      </tr>
      <tr>
        <td>ตลาดนัด / ริมถนน</td>
        <td>3,000 - 15,000 บาท/เดือน (เหมาจ่าย)</td>
      </tr>
      <tr>
        <td>ศูนย์การค้า</td>
        <td>1,000 - 5,000</td>
      </tr>
    </tbody>
  </table>

  <h2>2. ค่ามัดจำ — ใช้เงินก้อนแรกเท่าไหร่</h2>

  <p>
    ร้านค้าและพื้นที่พาณิชย์มักเรียกเก็บค่ามัดจำ <strong>2-6 เดือน</strong> ของค่าเช่ารายเดือน
    สูงกว่าห้องพักทั่วไปที่เรียก 1-2 เดือน เนื่องจากความเสี่ยงทางธุรกิจสูงกว่า
    ศูนย์การค้าบางแห่งอาจเรียกค่ามัดจำ 3 เดือน บวกค่าเช่าล่วงหน้า 1-2 เดือน
  </p>

  <p><strong>สูตร:</strong> ค่ามัดจำ = ค่าเช่ารายเดือน × จำนวนเดือนมัดจำ</p>

  <p>
    ตัวอย่าง: ค่าเช่า 25,000 บาท/เดือน มัดจำ 3 เดือน = <strong>75,000 บาท</strong>
  </p>

  <h2>3. ค่าเซ้ง (Key Money) — จ่ายครั้งเดียวแต่ต้องคิดให้ดี</h2>

  <p>
    ค่าเซ้งคือเงินที่จ่ายครั้งเดียวเพื่อได้สิทธิ์เช่าพื้นที่ ไม่ใช่ทุกที่มีค่าเซ้ง แต่ทำเลค้าขายดีมักมี
    ค่าเซ้งอาจตั้งแต่หลักหมื่นถึงหลักล้านบาท ขึ้นอยู่กับทำเลและศักยภาพรายได้
  </p>

  <p>
    <strong>คำแนะนำ:</strong> หารค่าเซ้งด้วยจำนวนเดือนสัญญาเช่า แล้วบวกกับค่าเช่ารายเดือน
    จะได้ต้นทุนค่าเช่าที่แท้จริงต่อเดือน
  </p>

  <h2>4. ค่าส่วนกลางและค่าที่จอดรถ</h2>

  <p>
    ค่าส่วนกลางในอาคารพาณิชย์หรือศูนย์การค้าครอบคลุมค่า รปภ. ทำความสะอาด แอร์ส่วนกลาง ลิฟต์ และบำรุงรักษาอาคาร
    มักคิดตามพื้นที่เช่าประมาณ 100-300 บาท/ตร.ม./เดือน
  </p>

  <p>
    ค่าที่จอดรถสำหรับร้านค้าที่ต้องมีที่จอดให้พนักงานหรือลูกค้า อาจอยู่ที่ 1,500-3,000 บาท/คัน/เดือน
    ในย่านศูนย์กลาง
  </p>

  <h2>5. ค่าสาธารณูปโภค — ค่าไฟ ค่าน้ำ อินเทอร์เน็ต</h2>

  <p>
    ร้านค้าใช้ไฟมากกว่าที่พักอาศัยเนื่องจากเครื่องปรับอากาศ ระบบไฟส่องสว่าง และอุปกรณ์ไฟฟ้า
    ร้านอาหารขนาด 50 ตร.ม. ค่าไฟอาจ 3,000-8,000 บาท/เดือน ร้านค้าทั่วไป 1,500-4,000 บาท/เดือน
  </p>

  <p>
    ใช้ <a href="/คำนวณค่าไฟฟ้า/">เครื่องคำนวณค่าไฟฟ้า</a> และ <a href="/คำนวณค่าน้ำ/">เครื่องคำนวณค่าน้ำ</a>
    เพื่อประมาณค่าใช้จ่ายแต่ละรายการ
  </p>

  <h2>6. สรุปสูตรคำนวณ</h2>

  <ul>
    <li><strong>ค่าใช้จ่ายย้ายเข้า</strong> = ค่ามัดจำ + ค่าเช่าล่วงหน้า + ค่าเซ้ง</li>
    <li><strong>ค่าใช้จ่ายรายเดือนรวม</strong> = ค่าเช่า + ค่าส่วนกลาง + ค่าที่จอดรถ + ค่าไฟ + ค่าน้ำ + ค่าอินเทอร์เน็ต + อื่น ๆ</li>
    <li><strong>ค่าใช้จ่ายตลอดสัญญา</strong> = ค่าใช้จ่ายย้ายเข้า + (ค่าใช้จ่ายรายเดือนรวม × จำนวนเดือนสัญญา)</li>
  </ul>

  <ArticleCalculatorCTA
    title="คำนวณค่าเช่าร้าน"
    href="/คำนวณค่าเช่าร้าน/"
    description="ลองคำนวณค่าเช่าร้านของคุณ — กรอกตัวเลขจริง ดูค่าใช้จ่ายครบทุกรายการ"
  />

  <h2>7. ตัวอย่างคำนวณจริง</h2>

  <p>ร้านกาแฟขนาด 40 ตร.ม. ในย่านชุมชน:</p>

  <table>
    <thead>
      <tr>
        <th>รายการ</th>
        <th>จำนวนเงิน (บาท)</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>ค่าเช่ารายเดือน</td>
        <td>15,000</td>
      </tr>
      <tr>
        <td>ค่าส่วนกลาง</td>
        <td>2,000</td>
      </tr>
      <tr>
        <td>ค่าที่จอดรถ (1 คัน)</td>
        <td>1,500</td>
      </tr>
      <tr>
        <td>ค่าไฟฟ้า</td>
        <td>4,000</td>
      </tr>
      <tr>
        <td>ค่าน้ำ</td>
        <td>500</td>
      </tr>
      <tr>
        <td>ค่าอินเทอร์เน็ต</td>
        <td>799</td>
      </tr>
      <tr>
        <td><strong>รวมรายเดือน</strong></td>
        <td><strong>23,799</strong></td>
      </tr>
    </tbody>
  </table>

  <p>
    ค่ามัดจำ 3 เดือน = 45,000 บาท | ค่าเช่าล่วงหน้า 1 เดือน = 15,000 บาท | ค่าเซ้ง = 100,000 บาท<br/>
    <strong>ค่าใช้จ่ายย้ายเข้า = 160,000 บาท</strong><br/>
    <strong>รวมตลอดสัญญา 1 ปี = 160,000 + (23,799 × 12) = 445,588 บาท</strong>
  </p>

  <h2>8. ข้อควรระวังก่อนเซ็นสัญญา</h2>

  <ul>
    <li>ตรวจสอบว่าค่าเช่ารวมหรือไม่รวม VAT — ร้านค้าในศูนย์การค้ามักบวก VAT 7% เพิ่มจากค่าเช่า</li>
    <li>อ่านเงื่อนไขค่ามัดจำคืน — บางสัญญาหักค่าซ่อมแซมก่อนคืน</li>
    <li>สัญญาเกิน 3 ปีต้องจดทะเบียนที่สำนักงานที่ดิน มิฉะนั้นมีผลบังคับแค่ 3 ปี</li>
    <li>ค่าเซ้งไม่ได้คืนทุกกรณี — ตรวจสอบสัญญาให้ชัดเจน</li>
    <li>ค่าส่วนกลางอาจปรับขึ้นทุกปี — สอบถามประวัติการปรับราคา</li>
  </ul>

  <p>
    <strong>ข้อจำกัดความรับผิดชอบ:</strong> ข้อมูลในบทความนี้ใช้เพื่อการวางแผนเบื้องต้นเท่านั้น
    ค่าใช้จ่ายจริงขึ้นอยู่กับเงื่อนไขสัญญาเช่าแต่ละราย ควรปรึกษาผู้เชี่ยวชาญด้านอสังหาริมทรัพย์หรือทนายความก่อนเซ็นสัญญา
  </p>
</BlogPostLayout>
