---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'รีไฟแนนซ์บ้าน 2569 คุ้มไหม: ดอกเบี้ยใหม่ต้องลดเท่าไรถึงคุ้มค่าปิดเก่า | เครื่องคำนวณไทย';
const description = 'สรุปเช็กลิสต์รีไฟแนนซ์บ้านปี 2569 พร้อมตัวอย่าง 3 สถานการณ์ และสูตรดูว่าดอกเบี้ยใหม่ต้องลดกี่เปอร์เซ็นต์ถึงจะคุ้ม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://calculator-thailand-production.up.railway.app').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/รีไฟแนนซ์บ้าน-2569-คุ้มไหม-ดอกเบี้ยใหม่ต้องลดเท่าไร/`;

const faqData = [
  {
    question: 'รีไฟแนนซ์บ้านต้องดอกเบี้ยลดอย่างน้อยเท่าไร?',
    answer: 'โดยทั่วไปควรเห็นส่วนต่างเฉลี่ยอย่างน้อย 0.75-1.00% ต่อปี และเมื่อนำส่วนต่างดอกเบี้ยไปเทียบกับค่าธรรมเนียมทั้งหมดแล้วต้องคืนทุนได้ในช่วง 18-24 เดือน',
  },
  {
    question: 'ควรดูเฉพาะดอกเบี้ยปีแรกหรือไม่?',
    answer: 'ไม่ควร ดูอย่างน้อย 3 ปีแรกพร้อมเงื่อนไขหลังหมดโปรโมชัน เพราะต้นทุนจริงมักเกิดจากอัตราเฉลี่ยหลายปี ไม่ใช่แค่ปีแรก',
  },
  {
    question: 'ค่าธรรมเนียมที่ต้องรวมตอนคิดความคุ้มมีอะไรบ้าง?',
    answer: 'ค่าประเมินหลักประกัน ค่าจดจำนอง ค่าอากร ค่าดำเนินการธนาคาร และค่าปรับปิดบัญชีก่อนกำหนด (ถ้ามี) ต้องรวมทั้งหมดก่อนตัดสินใจ',
  },
  {
    question: 'ถ้ายังไม่แน่ใจควรเริ่มจากอะไร?',
    answer: 'เริ่มจากคำนวณค่างวดใหม่เทียบสัญญาเดิม แล้วเช็กโอกาสนำเงินส่วนต่างไปออมต่อเพื่อรักษาสภาพคล่อง',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-14"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    รีไฟแนนซ์บ้าน 2569 คุ้มไหม: ดอกเบี้ยใหม่ต้องลดเท่าไรถึงคุ้มค่าปิดเก่า
  </h1>

  <p>
    ปี 2569 หลายครอบครัวเริ่มกลับมาทบทวนสินเชื่อบ้าน เพราะดอกเบี้ยสัญญาเดิมหลังพ้นโปรโมชันสูงขึ้นอย่างเห็นได้ชัด
    คำถามคือควรรีไฟแนนซ์ตอนนี้หรือรออีกระยะ บทความนี้สรุปวิธีคิดแบบใช้งานจริงเพื่อช่วยตัดสินใจได้เร็วและแม่นขึ้น
  </p>

  <ArticleCalculatorCTA
    title="เช็กค่างวดใหม่ก่อนตัดสินใจรีไฟแนนซ์"
    description="กรอกวงเงิน ดอกเบี้ย และระยะเวลาคงเหลือ เพื่อเทียบภาระผ่อนเดิมกับทางเลือกใหม่"
    href="/คำนวณผ่อนกู้/"
    buttonLabel="ไปที่คำนวณผ่อนกู้"
  />

  <h2>เช็กลิสต์ก่อนรีไฟแนนซ์บ้าน</h2>

  <ul>
    <li>สรุปเงินต้นคงเหลือและระยะเวลาผ่อนที่เหลือจากสัญญาเดิม</li>
    <li>เก็บข้อเสนอใหม่อย่างน้อย 2-3 ธนาคาร พร้อมอัตราเฉลี่ย 3 ปีแรก</li>
    <li>รวมค่าธรรมเนียมทั้งหมด: ค่าประเมิน, ค่าจดจำนอง, ค่าอากร และค่าดำเนินการ</li>
    <li>ตรวจค่าปรับปิดบัญชีก่อนกำหนด (ถ้ายังอยู่ในช่วง lock-in)</li>
    <li>ประเมินสภาพคล่องรายเดือนหลังรีไฟแนนซ์ ว่าค่างวดใหม่สบายขึ้นจริงหรือไม่</li>
  </ul>

  <h2>ตัวอย่าง 3 สถานการณ์ (วงเงินคงเหลือสูง/กลาง/ต่ำ)</h2>

  <p>
    ตัวอย่างด้านล่างใช้แนวคิดเดียวกัน: เทียบ “ดอกเบี้ยที่ประหยัดได้ต่อปี” กับ “ค่าธรรมเนียมย้ายสัญญา”
    เพื่อดูว่าคืนทุนภายในกี่เดือน
  </p>

  <table class="w-full text-sm border-collapse my-4">
    <thead>
      <tr class="border-b border-gray-200 text-left">
        <th class="py-2 pr-2">สถานการณ์</th>
        <th class="py-2 pr-2 text-right">เงินต้นคงเหลือ</th>
        <th class="py-2 pr-2 text-right">ดอกเบี้ยเดิม</th>
        <th class="py-2 pr-2 text-right">ดอกเบี้ยใหม่</th>
        <th class="py-2 text-right">ค่าธรรมเนียมรวม</th>
      </tr>
    </thead>
    <tbody>
      <tr class="border-b border-gray-100">
        <td class="py-2 pr-2">สูง</td>
        <td class="py-2 pr-2 text-right">3,000,000</td>
        <td class="py-2 pr-2 text-right">6.40%</td>
        <td class="py-2 pr-2 text-right">4.95%</td>
        <td class="py-2 text-right">58,000</td>
      </tr>
      <tr class="border-b border-gray-100">
        <td class="py-2 pr-2">กลาง</td>
        <td class="py-2 pr-2 text-right">1,900,000</td>
        <td class="py-2 pr-2 text-right">6.20%</td>
        <td class="py-2 pr-2 text-right">5.20%</td>
        <td class="py-2 text-right">52,000</td>
      </tr>
      <tr>
        <td class="py-2 pr-2">ต่ำ</td>
        <td class="py-2 pr-2 text-right">1,100,000</td>
        <td class="py-2 pr-2 text-right">6.00%</td>
        <td class="py-2 pr-2 text-right">5.35%</td>
        <td class="py-2 text-right">48,000</td>
      </tr>
    </tbody>
  </table>

  <p>
    กรณีเงินต้นคงเหลือสูง ส่วนต่างดอกเบี้ยเพียง 1.0-1.5% ก็มักเห็นผลประหยัดชัดเจนกว่าค่าธรรมเนียม
    ลองแทนค่าจริงของคุณใน
    <a href="/คำนวณผ่อนกู้/" data-preserve-utm>เครื่องคำนวณผ่อนกู้</a>
    เพื่อดูค่างวดและดอกเบี้ยรวมแบบเจาะจงทันที
  </p>

  <h2>จุดตัดสินใจ: ดอกเบี้ยใหม่ต้องลดอย่างน้อยกี่ % ถึงคุ้ม</h2>

  <p>
    สูตรคิดเร็ว:
    <strong>ส่วนต่างดอกเบี้ยขั้นต่ำต่อปี (%) ≈ (ค่าธรรมเนียมรวม ÷ เงินต้นคงเหลือ) x 100</strong>
  </p>

  <p>
    ตัวอย่างเงินต้นคงเหลือ 2,200,000 บาท และค่าธรรมเนียมรวม 55,000 บาท
    จะได้จุดคุ้มประมาณ 2.5% ต่อปี หากข้อเสนอใหม่ลดลงน้อยกว่านี้อาจไม่คุ้มในระยะสั้น
    แต่หากวางแผนถือสัญญายาว จุดคุ้มจริงอาจลดลงได้
  </p>

  <p>
    หลังได้ค่างวดใหม่แล้ว ควรเช็ก “เงินส่วนต่างรายเดือน” ว่าควรเก็บออมหรือเร่งปิดหนี้ต่อ
    เพื่อไม่ให้สภาพคล่องตึงในอนาคต
  </p>

  <ArticleCalculatorCTA
    title="ขั้นตอนถัดไป: วางแผนเงินส่วนต่างจากค่างวดใหม่"
    description="ประเมินว่าถ้านำส่วนต่างค่างวดไปออมต่อ จะมีเงินสำรองเพิ่มขึ้นเท่าไร"
    href="/คำนวณดอกเบี้ยเงินฝาก/"
    buttonLabel="ไปที่คำนวณดอกเบี้ยเงินฝาก"
  />

  <h2>สรุป</h2>

  <p>
    รีไฟแนนซ์จะคุ้มเมื่อส่วนต่างดอกเบี้ยชนะค่าธรรมเนียมได้เร็วพอ และไม่กระทบสภาพคล่องของครัวเรือน
    วิธีที่ปลอดภัยคือคำนวณจากตัวเลขจริงก่อนทุกครั้ง แล้วค่อยตัดสินใจปิดสัญญาเดิม
  </p>

  <p>
    เริ่มจาก <a href="/คำนวณผ่อนกู้/" data-preserve-utm>คำนวณผ่อนกู้</a>
    แล้วต่อด้วย <a href="/คำนวณดอกเบี้ยเงินฝาก/" data-preserve-utm>คำนวณดอกเบี้ยเงินฝาก</a>
    เพื่อวางแผนทางการเงินหลังรีไฟแนนซ์ให้ครบวงจร
  </p>

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
