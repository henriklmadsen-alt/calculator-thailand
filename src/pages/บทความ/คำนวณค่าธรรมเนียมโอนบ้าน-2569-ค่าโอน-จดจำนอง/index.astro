---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าธรรมเนียมโอนบ้าน 2569 | ค่าโอน จดจำนอง ภาษี | Kamnuanlek';
const description = 'คำนวณค่าธรรมเนียมโอนบ้าน 2569 เช็กค่าโอน ค่าจดจำนอง ภาษีธุรกิจเฉพาะ และอากรแสตมป์ตามเกณฑ์กรมที่ดิน พร้อมตัวอย่างจริงเป็นบาท';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าธรรมเนียมโอนบ้าน-2569-ค่าโอน-จดจำนอง/`;

const faqData = [
  {
    question: 'ค่าโอนบ้านทั้งหมดเท่าไร (ค่าโอน + จดจำนอง + ภาษี)?',
    answer: 'ค่าจดทะเบียนโอนคำนวณจากราคาประเมินทุนทรัพย์เป็นหลัก โดยอัตราปกติอยู่ที่ 2% และต้องพิจารณารายการอื่นร่วมด้วย เช่น ค่าจดจำนอง ภาษีธุรกิจเฉพาะ หรืออากรแสตมป์',
  },
  {
    question: 'ผู้ซื้อหรือผู้ขายใครจ่ายค่าโอนบ้านมากกว่ากัน?',
    answer: 'ตามเอกสารกระทรวงการคลัง ฉบับวันที่ 8 เมษายน 2568 มาตรการอ้างอิงนี้มีผลถึงวันที่ 30 มิถุนายน 2569 สำหรับธุรกรรมที่เข้าเงื่อนไข',
  },
  {
    question: 'ค่าโอนบ้านปี 2569 ถ้าเข้าเกณฑ์ 0.01% ต้องเช็กอะไรบ้าง?',
    answer: 'การแบ่งภาระจริงมักตกลงกันในสัญญาซื้อขาย แม้กฎหมายกำหนดวิธีคิดค่าธรรมเนียมและภาษีไว้ชัดเจน จึงควรตกลงก่อนวันโอนว่ารายการใดเป็นความรับผิดชอบของฝ่ายใด',
  },
  {
    question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ ต่างกันอย่างไรและเสียซ้ำไหม?',
    answer: 'ไม่ต้องเสียซ้ำในรายการอากรแสตมป์ หากกรณีเดียวกันต้องเสียภาษีธุรกิจเฉพาะ',
  },
  {
    question: 'ทำไมยอดคำนวณเบื้องต้นไม่ตรงยอดจริงที่สำนักงานที่ดิน',
    answer: 'ความต่างมักเกิดจากฐานคำนวณที่ใช้, เงื่อนไขเฉพาะของผู้ขาย, การปัดเศษ และเอกสารสิทธิที่ตรวจสอบเพิ่มเติมในวันทำรายการ',
  },
];
---

