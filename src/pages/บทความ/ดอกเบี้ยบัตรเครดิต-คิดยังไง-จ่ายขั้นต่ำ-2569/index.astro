---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'ดอกเบี้ยบัตรเครดิตคิดยังไง ปี 2569 พร้อมวิธีจ่ายให้เสียดอกเบี้ยน้อยลง | เครื่องคำนวณไทย';
const description = 'อธิบายวิธีคิดดอกเบี้ยบัตรเครดิตแบบรายวัน ปี 2569 ตามเกณฑ์ ธปท. พร้อมตัวอย่างคำนวณจริง วิธีจ่ายขั้นต่ำ และแนวทางลดภาระดอกเบี้ย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ดอกเบี้ยบัตรเครดิต-คิดยังไง-จ่ายขั้นต่ำ-2569/`;

const faqData = [
  {
    question: 'ปี 2569 ดอกเบี้ยบัตรเครดิตสูงสุดเท่าไร?',
    answer: 'ดอกเบี้ย ค่าปรับ ค่าบริการ และค่าธรรมเนียมรวมกันเรียกเก็บได้ไม่เกิน 16% ต่อปี ตามหลักเกณฑ์ของธนาคารแห่งประเทศไทย',
  },
  {
    question: 'ขั้นต่ำบัตรเครดิตปี 2569 ต้องจ่ายกี่เปอร์เซ็นต์?',
    answer: 'ธปท. ขยายมาตรการช่วยเหลือ โดยคงอัตราชำระขั้นต่ำบัตรเครดิตไว้ที่ 8% จนถึงสิ้นปี 2569',
  },
  {
    question: 'จ่ายขั้นต่ำทุกเดือนจะเกิดอะไรขึ้น?',
    answer: 'ยอดหนี้จะลดช้าและเสียดอกเบี้ยรวมสูง เพราะระบบบัตรเครดิตเป็นหนี้หมุนเวียน ยิ่งชำระมากกว่าขั้นต่ำได้เท่าไร ยิ่งลดดอกเบี้ยได้เร็ว',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-15"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    ดอกเบี้ยบัตรเครดิตคิดยังไง ปี 2569 พร้อมวิธีจ่ายให้เสียดอกเบี้ยน้อยลง
  </h1>

  <p>
    หลายคนเข้าใจว่าจ่ายขั้นต่ำก็เพียงพอ แต่ความจริงคือหนี้บัตรเครดิตจะมีดอกเบี้ยแบบรายวันเมื่อจ่ายไม่เต็มจำนวน ทำให้ยอดคงค้างลดช้ากว่าที่คิดมาก บทความนี้สรุปเกณฑ์ปี 2569 พร้อมตัวอย่างคำนวณที่ใช้งานได้จริง
  </p>

  <ArticleCalculatorCTA
    title="ลองคำนวณดอกเบี้ยจากยอดจริงของคุณ"
    description="กรอกข้อมูลไม่กี่ช่อง แล้วเห็นดอกเบี้ยและยอดคงค้างรอบถัดไปทันที"
    href="/คำนวณดอกเบี้ยบัตรเครดิต/"
    buttonLabel="ไปที่เครื่องคำนวณ"
  />

  <h2>กติกาสำคัญของบัตรเครดิตปี 2569</h2>

  <ul>
    <li>อัตราดอกเบี้ย ค่าปรับ ค่าบริการ และค่าธรรมเนียม รวมกันไม่เกิน <strong>16% ต่อปี</strong></li>
    <li>การเบิกเงินสดจากบัตรเครดิต มีค่าธรรมเนียมไม่เกิน <strong>3%</strong> ของยอดเบิก และมี VAT บนค่าธรรมเนียม</li>
    <li>มาตรการช่วยเหลือปี 2569 คง <strong>ขั้นต่ำ 8%</strong> ของยอดคงค้าง (ชั่วคราวตามประกาศ ธปท.)</li>
  </ul>

  <h2>ดอกเบี้ยบัตรเครดิตคิดแบบไหน?</h2>

  <p>
    เมื่อจ่ายไม่เต็มจำนวนภายในวันครบกำหนด ดอกเบี้ยมักถูกคำนวณเป็น 2 ช่วง:
  </p>

  <ol>
    <li>ช่วงก่อนครบกำหนดชำระ: คิดจากยอดค้างชำระด้วยอัตรารายวัน</li>
    <li>ช่วงหลังชำระถึงรอบถัดไป: คิดจากยอดคงเหลือหลังหักเงินที่จ่ายแล้ว</li>
  </ol>

  <p>สูตรประมาณการที่ใช้ได้กับการวางแผนส่วนใหญ่:</p>

  <ul>
    <li>ดอกเบี้ยช่วงก่อนครบกำหนด = ยอดค้างชำระ × (อัตราดอกเบี้ย ÷ 365) × จำนวนวัน</li>
    <li>ดอกเบี้ยช่วงหลังชำระ = ยอดคงเหลือหลังจ่าย × (อัตราดอกเบี้ย ÷ 365) × จำนวนวัน</li>
    <li>ดอกเบี้ยรวม = ดอกเบี้ย 2 ช่วง + ดอกเบี้ยเบิกเงินสด (ถ้ามี)</li>
  </ul>

  <h3>ตัวอย่างคำนวณ</h3>

  <p>
    สมมติยอดค้างชำระ 30,000 บาท จ่ายในวันครบกำหนด 8,000 บาท อัตราดอกเบี้ย 16% ต่อปี ช่วงก่อนครบกำหนด 20 วัน และช่วงหลังชำระ 25 วัน:
  </p>

  <ul>
    <li>ดอกเบี้ยช่วงก่อนครบกำหนด ≈ 263.01 บาท</li>
    <li>ดอกเบี้ยช่วงหลังชำระ ≈ 241.10 บาท</li>
    <li>ดอกเบี้ยรวม ≈ <strong>504.11 บาท</strong></li>
    <li>ยอดคงค้างรอบถัดไป ≈ <strong>22,504.11 บาท</strong></li>
  </ul>

  <h2>จ่ายขั้นต่ำ 8% ควรทำไหม?</h2>

  <p>
    การจ่ายขั้นต่ำช่วยรักษาสภาพคล่องระยะสั้นได้ แต่มีผลข้างเคียงคือดอกเบี้ยสะสมสูงขึ้นและปิดหนี้ช้าลง หากทำได้ ควรจ่ายมากกว่าขั้นต่ำทุกงวด หรือทยอยปิดก้อนที่ดอกเบี้ยสูงก่อน
  </p>

  <h2>วิธีลดดอกเบี้ยบัตรเครดิตแบบทำได้จริง</h2>

  <ol>
    <li>จ่ายเต็มจำนวนทุกครั้งเมื่อทำได้ เพื่อรักษาระยะปลอดดอกเบี้ย</li>
    <li>อย่างน้อยควรจ่ายมากกว่าขั้นต่ำ 8% เพื่อลดยอดคงค้างเร็วขึ้น</li>
    <li>หยุดรูดเพิ่มชั่วคราวระหว่างเร่งปิดหนี้</li>
    <li>หลีกเลี่ยงการเบิกเงินสดจากบัตรเครดิต เพราะมีทั้งดอกเบี้ยและค่าธรรมเนียมเพิ่ม</li>
    <li>หากเริ่มจ่ายขั้นต่ำไม่ไหว ให้รีบติดต่อผู้ออกบัตรเพื่อปรับโครงสร้างหนี้ก่อนเป็น NPL</li>
  </ol>

  <ArticleCalculatorCTA
    title="คำนวณแผนจ่ายของคุณก่อนตัดรอบบิล"
    description="ประเมินผลลัพธ์ทันทีว่าถ้าจ่ายเพิ่มขึ้น ดอกเบี้ยจะลดลงเท่าไร"
    href="/คำนวณดอกเบี้ยบัตรเครดิต/"
    buttonLabel="เปิดเครื่องคำนวณดอกเบี้ยบัตรเครดิต"
  />

  <h2>แหล่งอ้างอิงทางการ</h2>

  <ul>
    <li>
      ธปท. ความรู้เรื่องบัตรเครดิต:
      <a href="https://www.bot.or.th/th/satang-story/digital-fin-lit/creditcard.html" target="_blank" rel="noopener noreferrer">การคิดดอกเบี้ยและค่าธรรมเนียม</a>
    </li>
    <li>
      ข่าว ธปท. ฉบับที่ 47/2568:
      <a href="https://www.bot.or.th/th/news-and-media/news/news-20251204-2.html" target="_blank" rel="noopener noreferrer">ขยายขั้นต่ำบัตรเครดิต 8% ถึงสิ้นปี 2569</a>
    </li>
  </ul>

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>

