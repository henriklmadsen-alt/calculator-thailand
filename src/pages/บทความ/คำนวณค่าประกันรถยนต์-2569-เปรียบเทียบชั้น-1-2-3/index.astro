---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าประกันรถยนต์ 2569 | เปรียบเทียบชั้น 1/2+/2/3+/3 | เครื่องคำนวณไทย';
const description = 'เปรียบเทียบประกันรถยนต์ 5 ชั้นปี 2569 ชั้น 1 2+ 2 3+ 3 ความคุ้มครอง เบี้ยโดยประมาณ วิธีเลือกให้เหมาะกับรถและงบ อ้างอิง คปภ.';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าประกันรถยนต์-2569-เปรียบเทียบชั้น-1-2-3/`;

const faqData = [
  {
    question: 'ประกันชั้น 1 กับ 2+ ต่างกันยังไง?',
    answer: 'ชั้น 1 คุ้มครองครอบคลุมที่สุด รวมรถตัวเองเสียหายทุกกรณี + น้ำท่วม ส่วนชั้น 2+ คุ้มครองรถตัวเองเฉพาะชนกับยานพาหนะที่มีคู่กรณีระบุได้ ไม่รวมน้ำท่วมหรืออุบัติเหตุเดี่ยว',
  },
  {
    question: 'รถเก่ากี่ปีควรเปลี่ยนจากชั้น 1 เป็นชั้นอื่น?',
    answer: 'โดยทั่วไปรถอายุ 4–5 ปีขึ้นไปที่มูลค่ารถลดลงมาก หลายคนเลือกเปลี่ยนเป็นชั้น 2+ หรือ 3+ เพราะเบี้ยถูกกว่าและยังได้ความคุ้มครองรถตัวเองกรณีมีคู่กรณี',
  },
  {
    question: 'เบี้ยประกันรถยนต์คำนวณจากอะไรบ้าง?',
    answer: 'คำนวณจากมูลค่ารถ กลุ่มรถ (เล็ก-กลาง-ใหญ่-หรู) อายุรถ อายุผู้ขับ และชั้นประกัน โดยแต่ละบริษัทอาจมีอัตราต่างกันเล็กน้อย',
  },
  {
    question: 'ประกันชั้น 3 คุ้มครองอะไรบ้าง?',
    answer: 'ชั้น 3 คุ้มครองเฉพาะบุคคลภายนอก (ค่าเสียหายรถคู่กรณี บาดเจ็บ เสียชีวิตของบุคคลภายนอก) ไม่คุ้มครองรถตัวเอง เหมาะสำหรับรถเก่าที่ต้องการเบี้ยต่ำสุด',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-20"
  modifiedDate="2026-04-20"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    ประกันรถยนต์ 2569: เปรียบเทียบชั้น 1 / 2+ / 2 / 3+ / 3 เลือกยังไงให้คุ้ม
  </h1>

  <p>
    ประกันรถยนต์มี 5 ชั้น แต่ละชั้นให้ความคุ้มครองต่างกัน เบี้ยต่างกัน
    การเลือกถูกชั้นช่วยประหยัดเบี้ยได้หลายพันบาท โดยไม่เสียความคุ้มครองที่จำเป็น
    บทความนี้เปรียบเทียบทั้ง 5 ชั้นอย่างละเอียด พร้อมตัวอย่างเบี้ยโดยประมาณ
    และแนวทางเลือกให้เหมาะกับรถและงบ อ้างอิงจาก คปภ. (สำนักงานคณะกรรมการกำกับและส่งเสริมการประกอบธุรกิจประกันภัย)
  </p>

  <ArticleCalculatorCTA
    title="เปรียบเทียบเบี้ยประกัน 5 ชั้นสำหรับรถของคุณ"
    description="กรอกมูลค่ารถ กลุ่มรถ อายุรถ และอายุผู้ขับ เพื่อดูเบี้ยโดยประมาณทุกชั้น"
    href="/คำนวณค่าประกันรถยนต์/"
    buttonLabel="ไปที่เครื่องคำนวณประกันรถยนต์"
  />

  <h2>เปรียบเทียบความคุ้มครอง 5 ชั้น</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[640px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">ความคุ้มครอง</th>
          <th class="border border-gray-200 px-3 py-2 text-center">ชั้น 1</th>
          <th class="border border-gray-200 px-3 py-2 text-center">ชั้น 2+</th>
          <th class="border border-gray-200 px-3 py-2 text-center">ชั้น 2</th>
          <th class="border border-gray-200 px-3 py-2 text-center">ชั้น 3+</th>
          <th class="border border-gray-200 px-3 py-2 text-center">ชั้น 3</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">รถตัวเอง (ทุกกรณี)</td>
          <td class="border border-gray-200 px-3 py-2 text-center">✓</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
        </tr>
