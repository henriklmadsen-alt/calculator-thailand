          <td class="border border-gray-200 px-3 py-2 text-center">✓</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
          <td class="border border-gray-200 px-3 py-2 text-center">✓</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ไฟไหม้ / โจรกรรม</td>
          <td class="border border-gray-200 px-3 py-2 text-center">✓</td>
          <td class="border border-gray-200 px-3 py-2 text-center">✓</td>
          <td class="border border-gray-200 px-3 py-2 text-center">✓</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">น้ำท่วม</td>
          <td class="border border-gray-200 px-3 py-2 text-center">✓</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
          <td class="border border-gray-200 px-3 py-2 text-center">–</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ทรัพย์สินบุคคลภายนอก</td>
          <td class="border border-gray-200 px-3 py-2 text-center">✓</td>
          <td class="border border-gray-200 px-3 py-2 text-center">✓</td>
