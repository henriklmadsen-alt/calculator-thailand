---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';

const title = 'ภาษีเงินได้ 2569 คำนวณ พร้อมวิธีลดหย่อน | เครื่องคำนวณไทย';
const description = 'วิธีคำนวณภาษีเงินได้บุคคลธรรมดาปี 2569 อัตราภาษีขั้นบันได ค่าลดหย่อนทั้งหมด และเคล็ดลับประหยัดภาษีอย่างถูกกฎหมาย';
const siteUrl = 'https://calculator-thailand-production.up.railway.app';
const canonical = `${siteUrl}/บทความ/ภาษีเงินได้-2569-คำนวณ-วิธีลดหย่อน/`;

const faqData = [
  {
    question: 'ภาษีเงินได้ 2569 เริ่มเสียที่รายได้เท่าไร?',
    answer: 'หลังหักค่าใช้จ่ายและค่าลดหย่อนแล้ว หากรายได้สุทธิไม่เกิน 150,000 บาทต่อปี จะได้รับยกเว้นภาษี สำหรับผู้มีเงินเดือนอย่างเดียว หากรายได้ต่อปีไม่เกิน 310,000 บาท (ประมาณ 25,833 บาทต่อเดือน) มักจะไม่ต้องเสียภาษี',
  },
  {
    question: 'ค่าลดหย่อนภาษี 2569 มีอะไรบ้าง?',
    answer: 'ค่าลดหย่อนหลักได้แก่ ค่าลดหย่อนส่วนตัว 60,000 บาท คู่สมรส 60,000 บาท บุตร 30,000 บาทต่อคน ประกันสังคมสูงสุด 9,000 บาท ประกันชีวิตสูงสุด 100,000 บาท กองทุน SSF/RMF/Thai ESG ตามเงื่อนไข เงินบริจาค และดอกเบี้ยบ้านสูงสุด 100,000 บาท',
  },
  {
    question: 'อัตราภาษีขั้นบันไดปี 2569 เป็นอย่างไร?',
    answer: 'อัตราภาษีขั้นบันไดปี 2569 คือ 0-150,000 บาท ยกเว้นภาษี, 150,001-300,000 บาท 5%, 300,001-500,000 บาท 10%, 500,001-750,000 บาท 15%, 750,001-1,000,000 บาท 20%, 1,000,001-2,000,000 บาท 25%, 2,000,001-5,000,000 บาท 30%, เกิน 5,000,000 บาท 35%',
  },
  {
    question: 'วิธีประหยัดภาษีที่ดีที่สุดคืออะไร?',
    answer: 'วิธีประหยัดภาษีที่ดีที่สุดคือการใช้สิทธิ์ลดหย่อนให้ครบถ้วน โดยเฉพาะกองทุน SSF/RMF ที่ลดหย่อนได้สูงถึง 30% ของรายได้ ประกันชีวิต และเงินบริจาค ควรวางแผนตั้งแต่ต้นปีเพื่อกระจายการลงทุน',
  },
  {
    question: 'ต้องยื่นภาษีเมื่อไร?',
    answer: 'การยื่นภาษีเงินได้บุคคลธรรมดาประจำปี ต้องยื่นภายในวันที่ 31 มีนาคมของปีถัดไป หากยื่นออนไลน์ผ่านระบบ e-Filing ของกรมสรรพากร จะได้ขยายเวลาถึง 8 เมษายน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-12"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    ภาษีเงินได้ 2569 คำนวณ พร้อมวิธีลดหย่อน
  </h1>

  <p>
    การคำนวณภาษีเงินได้บุคคลธรรมดาเป็นเรื่องที่มนุษย์เงินเดือนและผู้มีรายได้ทุกคนควรทำความเข้าใจ ปี 2569 (พ.ศ. 2569 / ค.ศ. 2026) กรมสรรพากรยังคงใช้อัตราภาษีแบบขั้นบันไดเช่นเดิม แต่มีการปรับปรุงสิทธิประโยชน์ทางภาษีบางรายการ บทความนี้จะอธิบายวิธีคำนวณภาษีทีละขั้นตอน พร้อมแนะนำวิธีลดหย่อนภาษีอย่างถูกกฎหมาย
  </p>

  <div class="my-6 p-4 bg-primary-50 rounded-lg border border-primary-200 text-center">
    <p class="text-sm text-primary-800 mb-2 font-medium">ลองคำนวณภาษีของคุณเลย</p>
    <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors text-sm">
      เครื่องคำนวณภาษีเงินได้ 2569
    </a>
  </div>

  <h2>อัตราภาษีเงินได้บุคคลธรรมดา 2569 (ขั้นบันได)</h2>

  <p>
    ประเทศไทยใช้ระบบภาษีแบบขั้นบันได (Progressive Tax) หมายความว่ายิ่งมีรายได้สุทธิมาก อัตราภาษีก็ยิ่งสูงขึ้น โดยแบ่งเป็น 8 ขั้น ดังนี้:
  </p>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">รายได้สุทธิ (บาท/ปี)</th>
          <th class="border border-gray-200 px-3 py-2 text-center font-semibold">อัตราภาษี</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">ภาษีสูงสุดต่อขั้น</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">0 - 150,000</td><td class="border border-gray-200 px-3 py-2 text-center">ยกเว้น</td><td class="border border-gray-200 px-3 py-2 text-right">0 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">150,001 - 300,000</td><td class="border border-gray-200 px-3 py-2 text-center">5%</td><td class="border border-gray-200 px-3 py-2 text-right">7,500 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">300,001 - 500,000</td><td class="border border-gray-200 px-3 py-2 text-center">10%</td><td class="border border-gray-200 px-3 py-2 text-right">20,000 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">500,001 - 750,000</td><td class="border border-gray-200 px-3 py-2 text-center">15%</td><td class="border border-gray-200 px-3 py-2 text-right">37,500 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">750,001 - 1,000,000</td><td class="border border-gray-200 px-3 py-2 text-center">20%</td><td class="border border-gray-200 px-3 py-2 text-right">50,000 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">1,000,001 - 2,000,000</td><td class="border border-gray-200 px-3 py-2 text-center">25%</td><td class="border border-gray-200 px-3 py-2 text-right">250,000 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">2,000,001 - 5,000,000</td><td class="border border-gray-200 px-3 py-2 text-center">30%</td><td class="border border-gray-200 px-3 py-2 text-right">900,000 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">เกิน 5,000,000</td><td class="border border-gray-200 px-3 py-2 text-center">35%</td><td class="border border-gray-200 px-3 py-2 text-right">-</td></tr>
      </tbody>
    </table>
  </div>

  <h2>วิธีคำนวณภาษีเงินได้ทีละขั้นตอน</h2>

  <p>
    การคำนวณภาษีเงินได้มี 4 ขั้นตอนหลัก:
  </p>

  <ol>
    <li><strong>รวมรายได้ทั้งปี</strong> — รวมเงินเดือน โบนัส ค่าคอมมิชชั่น และรายได้อื่นๆ ทั้งหมดในปีภาษี</li>
    <li><strong>หักค่าใช้จ่าย</strong> — สำหรับเงินเดือน (เงินได้ 40(1)) หักค่าใช้จ่ายเหมา 50% แต่ไม่เกิน 100,000 บาท</li>
    <li><strong>หักค่าลดหย่อน</strong> — หักค่าลดหย่อนส่วนตัว คู่สมรส บุตร ประกัน กองทุน ฯลฯ ตามสิทธิ์ที่มี</li>
    <li><strong>คำนวณตามขั้นบันได</strong> — นำรายได้สุทธิ (หลังหักค่าใช้จ่ายและค่าลดหย่อน) มาคำนวณภาษีตามตารางขั้นบันไดข้างต้น</li>
  </ol>

  <h3>ตัวอย่างการคำนวณ</h3>

  <p>
    สมมติคุณมีเงินเดือน 40,000 บาท/เดือน (รายได้ทั้งปี 480,000 บาท) ไม่มีคู่สมรสหรือบุตร:
  </p>

  <ul>
    <li>รายได้ทั้งปี: 480,000 บาท</li>
    <li>หักค่าใช้จ่าย (50% ไม่เกิน 100,000): -100,000 บาท</li>
    <li>หักค่าลดหย่อนส่วนตัว: -60,000 บาท</li>
    <li>หักประกันสังคม: -9,000 บาท</li>
    <li><strong>รายได้สุทธิ: 311,000 บาท</strong></li>
    <li>ภาษี 150,000 แรก: ยกเว้น = 0 บาท</li>
    <li>ภาษี 150,001-300,000 (150,000 บาท x 5%): 7,500 บาท</li>
    <li>ภาษี 300,001-311,000 (11,000 บาท x 10%): 1,100 บาท</li>
    <li><strong>ภาษีทั้งปี: 8,600 บาท</strong> (ประมาณเดือนละ 717 บาท)</li>
  </ul>

  <div class="my-6 p-4 bg-primary-50 rounded-lg border border-primary-200 text-center">
    <p class="text-sm text-primary-800 mb-2">ลองคำนวณภาษีตามรายได้ของคุณ</p>
    <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block px-5 py-2.5 bg-primary-600 text-white rounded-lg font-medium hover:bg-primary-700 transition-colors text-sm">
      คำนวณภาษีเงินได้ 2569
    </a>
  </div>

  <h2>ค่าลดหย่อนภาษีปี 2569 ที่ต้องรู้</h2>

  <p>
    ค่าลดหย่อนคือจำนวนเงินที่กฎหมายอนุญาตให้หักจากรายได้ก่อนคำนวณภาษี ยิ่งมีค่าลดหย่อนมาก รายได้สุทธิที่ต้องเสียภาษีก็ยิ่งน้อย รายการหลักๆ มีดังนี้:
  </p>

  <h3>ค่าลดหย่อนส่วนตัวและครอบครัว</h3>
  <ul>
    <li><strong>ส่วนตัว:</strong> 60,000 บาท (ทุกคนได้สิทธิ์อัตโนมัติ)</li>
    <li><strong>คู่สมรส</strong> (ที่ไม่มีรายได้): 60,000 บาท</li>
    <li><strong>บุตร:</strong> คนละ 30,000 บาท (บุตรคนที่ 2 ขึ้นไปเกิดตั้งแต่ปี 2561 ได้ 60,000 บาท)</li>
    <li><strong>บิดามารดา</strong> (อายุ 60 ปีขึ้นไป รายได้ไม่เกิน 30,000): คนละ 30,000 บาท</li>
  </ul>

  <h3>ค่าลดหย่อนประกันและกองทุน</h3>
  <ul>
    <li><strong>ประกันสังคม:</strong> ตามจ่ายจริง สูงสุด 9,000 บาท</li>
    <li><strong>ประกันชีวิต:</strong> ตามจ่ายจริง สูงสุด 100,000 บาท</li>
    <li><strong>ประกันสุขภาพ:</strong> ตามจ่ายจริง สูงสุด 25,000 บาท (รวมกับประกันชีวิตไม่เกิน 100,000 บาท)</li>
    <li><strong>กองทุน SSF:</strong> ตามจ่ายจริง สูงสุด 30% ของรายได้ ไม่เกิน 200,000 บาท</li>
    <li><strong>กองทุน RMF:</strong> ตามจ่ายจริง สูงสุด 30% ของรายได้ ไม่เกิน 500,000 บาท</li>
    <li><strong>กองทุน Thai ESG:</strong> ตามจ่ายจริง สูงสุด 30% ของรายได้ ไม่เกิน 300,000 บาท</li>
    <li><strong>กองทุนสำรองเลี้ยงชีพ (PVD):</strong> ตามจ่ายจริง สูงสุด 500,000 บาท</li>
  </ul>

  <p>
    <strong>สำคัญ:</strong> กองทุน SSF + RMF + PVD + กบข. + กองทุนการออมแห่งชาติ + ประกันชีวิตบำนาญ รวมกันต้องไม่เกิน 500,000 บาท
  </p>

  <h3>ค่าลดหย่อนอื่นๆ</h3>
  <ul>
    <li><strong>ดอกเบี้ยบ้าน:</strong> ตามจ่ายจริง สูงสุด 100,000 บาท</li>
    <li><strong>เงินบริจาคทั่วไป:</strong> ตามจ่ายจริง สูงสุด 10% ของรายได้หลังหักค่าลดหย่อนอื่น</li>
    <li><strong>เงินบริจาคเพื่อการศึกษา กีฬา สาธารณสุข:</strong> หักได้ 2 เท่าของที่จ่ายจริง</li>
    <li><strong>ช้อปดีมีคืน</strong> (ถ้ามี): ตามประกาศจากรัฐบาลแต่ละปี</li>
  </ul>

  <h2>เคล็ดลับประหยัดภาษี 2569</h2>

  <ol>
    <li><strong>วางแผนตั้งแต่ต้นปี</strong> — อย่ารอถึงปลายปีค่อยลงทุนกองทุนลดหย่อน ควรทำแผน DCA (Dollar Cost Averaging) ตั้งแต่เดือนมกราคม</li>
    <li><strong>ใช้สิทธิ์ SSF/RMF ให้เต็ม</strong> — กองทุน SSF และ RMF ช่วยลดหย่อนได้สูงสุดถึง 30% ของรายได้ และยังเป็นการออมระยะยาวที่ดี</li>
    <li><strong>อย่าลืมประกันสุขภาพ</strong> — ลดหย่อนได้สูงสุด 25,000 บาท และยังคุ้มครองค่ารักษาพยาบาลในกรณีเจ็บป่วย</li>
    <li><strong>ตรวจสอบสิทธิ์บิดามารดา</strong> — หลายคนลืมใช้สิทธิ์ลดหย่อนบิดามารดาที่อายุ 60 ปีขึ้นไป</li>
    <li><strong>เก็บหลักฐานให้ครบ</strong> — ใบเสร็จประกัน ใบรับรองกองทุน หนังสือรับรองดอกเบี้ยบ้าน ต้องเก็บไว้สำหรับยื่นภาษี</li>
  </ol>

  <h2>กำหนดยื่นภาษีเงินได้ 2569</h2>

  <p>
    สำหรับรายได้ปีภาษี 2568 (มกราคม-ธันวาคม 2568) ต้องยื่นแบบ ภ.ง.ด.90 หรือ ภ.ง.ด.91 ภายในวันที่ 31 มีนาคม 2569 หากยื่นผ่านระบบ e-Filing ของกรมสรรพากร จะได้ขยายเวลาถึง 8 เมษายน 2569
  </p>

  <p>
    การยื่นภาษีล่าช้าจะมีค่าปรับ 200 บาท และอาจถูกเรียกเก็บเงินเพิ่ม 1.5% ต่อเดือนของภาษีที่ต้องชำระ ดังนั้นควรเตรียมเอกสารให้พร้อมและยื่นให้ทันเวลา
  </p>

  <h2>สรุป</h2>

  <p>
    การคำนวณภาษีเงินได้ไม่ยากอย่างที่คิด เพียงแค่เข้าใจขั้นตอนการหักค่าใช้จ่าย ค่าลดหย่อน และอัตราภาษีขั้นบันได ก็สามารถวางแผนภาษีได้อย่างมีประสิทธิภาพ สิ่งสำคัญคือการเริ่มวางแผนตั้งแต่ต้นปี ใช้สิทธิ์ลดหย่อนให้ครบ และยื่นภาษีให้ตรงเวลา
  </p>

  <p>
    ใช้ <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/">เครื่องคำนวณภาษีเงินได้ 2569</a> ของเราเพื่อคำนวณภาษีของคุณได้ทันที หรือลองใช้ <a href="/คำนวณเงินเดือนสุทธิ/">เครื่องคำนวณเงินเดือนสุทธิ</a> เพื่อดูว่าเงินเดือนหลังหักภาษีและประกันสังคมจะเหลือเท่าไร
  </p>

  <!-- FAQ Section -->
  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
