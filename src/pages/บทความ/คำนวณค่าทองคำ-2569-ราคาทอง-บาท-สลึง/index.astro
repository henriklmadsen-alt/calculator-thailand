---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'คำนวณค่าทองคำ 2569 | ราคาทองวันนี้ บาท สลึง กรัม | เครื่องคำนวณไทย';
const description = 'วิธีคำนวณราคาทองคำ แปลงน้ำหนักบาททอง สลึง กรัม พร้อมอธิบายราคาซื้อ-ขาย ทองแท่ง-ทองรูปพรรณ อ้างอิงสมาคมค้าทองคำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/คำนวณค่าทองคำ-2569-ราคาทอง-บาท-สลึง/`;

const faqData = [
  {
    question: '1 บาททอง หนักกี่กรัม?',
    answer: '1 บาททอง = 15.244 กรัม โดย 1 บาท = 4 สลึง ดังนั้น 1 สลึง = 3.811 กรัม มาตรฐานนี้ใช้กับทองคำไทยความบริสุทธิ์ 96.5%',
  },
  {
    question: 'ทองแท่งกับทองรูปพรรณราคาต่างกันยังไง?',
    answer: 'ทองแท่งราคาถูกกว่าทองรูปพรรณ เพราะทองรูปพรรณมีค่ากำเหน็จ (ค่าแรงช่าง) บวกเพิ่ม ทำให้ราคาซื้อแพงกว่าและราคาขายคืนต่ำกว่าทองแท่ง',
  },
  {
    question: 'ราคาซื้อกับราคาขายต่างกันทำไม?',
    answer: 'ราคาซื้อ (Buy) คือราคาที่ร้านซื้อคืนจากลูกค้า ราคาขาย (Sell) คือราคาที่ร้านขายให้ลูกค้า ส่วนต่าง (Spread) คือกำไรของร้านทอง',
  },
  {
    question: 'ทองไทย 96.5% กับทอง 99.99% ต่างกันยังไง?',
    answer: 'ทองไทยมาตรฐาน 96.5% (23.16 กะรัต) มีทองผสม 3.5% เพื่อความทนทาน ส่วนทอง 99.99% เป็นทองบริสุทธิ์ (24 กะรัต) นิยมในรูปแบบทองแท่งสำหรับลงทุน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-20"
  modifiedDate="2026-04-20"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    คำนวณค่าทองคำ 2569: ราคาทองวันนี้ แปลงบาท สลึง กรัม
  </h1>

  <p>
    ทองคำเป็นสินทรัพย์ที่คนไทยนิยมซื้อเก็บมาอย่างยาวนาน ทั้งเพื่อการลงทุนและสะสมเป็นของขวัญ
    แต่การคำนวณราคาทองไม่ได้ง่ายอย่างที่คิด เพราะต้องแยกระหว่างทองแท่งกับทองรูปพรรณ
    เข้าใจราคาซื้อ-ขาย และแปลงหน่วยน้ำหนักให้ถูกต้อง บทความนี้อธิบายทุกสิ่งที่ต้องรู้เกี่ยวกับราคาทองคำ
    อ้างอิงจากสมาคมค้าทองคำ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณราคาทองคำตามน้ำหนักที่ต้องการ"
    description="เลือกประเภททอง ใส่น้ำหนัก และราคาวันนี้ เพื่อดูมูลค่าซื้อ-ขายทันที"
    href="/คำนวณค่าทองคำ/"
    buttonLabel="ไปที่เครื่องคำนวณค่าทองคำ"
  />

  <h2>หน่วยน้ำหนักทองคำในไทย</h2>

  <p>ทองคำในไทยใช้หน่วยน้ำหนักเฉพาะ ซึ่งต่างจากระบบสากล:</p>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[400px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">หน่วย</th>
          <th class="border border-gray-200 px-3 py-2 text-left">เทียบกับกรัม</th>
          <th class="border border-gray-200 px-3 py-2 text-left">เทียบกับบาททอง</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">1 บาททอง</td>
          <td class="border border-gray-200 px-3 py-2">15.244 กรัม</td>
          <td class="border border-gray-200 px-3 py-2">1 บาท</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">1 สลึง</td>
          <td class="border border-gray-200 px-3 py-2">3.811 กรัม</td>
          <td class="border border-gray-200 px-3 py-2">0.25 บาท (¼)</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">2 สลึง (ครึ่งบาท)</td>
          <td class="border border-gray-200 px-3 py-2">7.622 กรัม</td>
          <td class="border border-gray-200 px-3 py-2">0.50 บาท (½)</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p>
    ข้อสังเกต: "บาททอง" ไม่เกี่ยวกับ "บาท" ที่เป็นสกุลเงิน
    1 บาททอง = 4 สลึง = 15.244 กรัม เป็นหน่วยวัดน้ำหนักเฉพาะของทองคำในประเทศไทย
  </p>

  <h2>ทองแท่ง vs ทองรูปพรรณ: ต่างกันอย่างไร</h2>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[520px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">เปรียบเทียบ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ทองแท่ง</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ทองรูปพรรณ</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ราคาซื้อ (ร้านขาย)</td>
          <td class="border border-gray-200 px-3 py-2">ต่ำกว่า</td>
          <td class="border border-gray-200 px-3 py-2">สูงกว่า (มีค่ากำเหน็จ)</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">ราคาขายคืน (ร้านรับซื้อ)</td>
          <td class="border border-gray-200 px-3 py-2">สูงกว่า</td>
          <td class="border border-gray-200 px-3 py-2">ต่ำกว่า</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">Spread (ส่วนต่าง)</td>
          <td class="border border-gray-200 px-3 py-2">แคบ (100–200 บาท/บาททอง)</td>
          <td class="border border-gray-200 px-3 py-2">กว้าง (ค่ากำเหน็จ + Spread)</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">เหมาะสำหรับ</td>
          <td class="border border-gray-200 px-3 py-2">ลงทุน / ซื้อ-ขายบ่อย</td>
          <td class="border border-gray-200 px-3 py-2">สะสม / ใส่เป็นเครื่องประดับ</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>สูตรคำนวณราคาทองคำ</h2>

  <p><strong>มูลค่าซื้อ = น้ำหนัก (บาททอง) × ราคาขาย (Sell) ต่อบาททอง</strong></p>
  <p><strong>มูลค่าขายคืน = น้ำหนัก (บาททอง) × ราคาซื้อ (Buy) ต่อบาททอง</strong></p>

  <h3>ตัวอย่าง: ซื้อทองแท่ง 2 บาท</h3>

  <p>สมมติราคาทองแท่งวันนี้: ซื้อ 42,250 บาท / ขาย 42,350 บาท</p>

  <ul>
    <li>ค่าซื้อ 2 บาท: 2 × 42,350 = <strong>84,700 บาท</strong></li>
    <li>ถ้าขายคืนทันที: 2 × 42,250 = <strong>84,500 บาท</strong></li>
    <li>ส่วนต่าง (Spread): 84,700 – 84,500 = <strong>200 บาท</strong></li>
  </ul>

  <h3>ตัวอย่าง: คำนวณจากกรัม</h3>

  <p>ต้องการรู้ราคาทอง 10 กรัม:</p>

  <ol>
    <li>แปลง 10 กรัม เป็นบาททอง: 10 ÷ 15.244 = <strong>0.656 บาททอง</strong></li>
    <li>มูลค่าซื้อ: 0.656 × 42,350 = <strong>27,782 บาท</strong></li>
  </ol>

  <ArticleCalculatorCTA
    title="คำนวณราคาทองตามน้ำหนักจริงของคุณ"
    description="แปลงหน่วยน้ำหนักและดูมูลค่าซื้อ-ขายทันที"
    href="/คำนวณค่าทองคำ/"
    buttonLabel="เปิดเครื่องคำนวณค่าทองคำ"
  />

  <h2>ทองคำไทยมาตรฐาน 96.5%</h2>

  <p>
    ทองคำในไทยมีมาตรฐานความบริสุทธิ์ที่ 96.5% หรือเทียบเท่า 23.16 กะรัต
    กำหนดโดยสมาคมค้าทองคำ มีทองผสม (เงิน ทองแดง) 3.5% เพื่อให้เนื้อทองแข็งแรงทนทาน
    เหมาะกับการทำเป็นเครื่องประดับ
  </p>

  <p>
    ทองคำ 99.99% (24 กะรัต) มีจำหน่ายในรูปทองแท่งสำหรับการลงทุน
    ราคาต่อกรัมจะสูงกว่าทอง 96.5% ตามสัดส่วนความบริสุทธิ์
  </p>

  <h2>ปัจจัยที่มีผลต่อราคาทองคำ</h2>

  <ul>
    <li><strong>ราคาทองตลาดโลก (Gold Spot):</strong> เป็นปัจจัยหลัก ราคาทองในไทยเคลื่อนไหวตามราคาตลาดโลก</li>
    <li><strong>อัตราแลกเปลี่ยน:</strong> ทองคำซื้อขายเป็นดอลลาร์ เมื่อเงินบาทอ่อนค่า ราคาทองในไทยจะสูงขึ้น</li>
    <li><strong>อุปสงค์ในประเทศ:</strong> ช่วงเทศกาลตรุษจีน สงกรานต์ หรือฤดูแต่งงาน ความต้องการสูง ราคาอาจปรับขึ้น</li>
    <li><strong>นโยบายดอกเบี้ย:</strong> เมื่อดอกเบี้ยต่ำ ทองคำน่าสนใจขึ้นเป็นทางเลือกการลงทุน</li>
  </ul>

  <h2>เทคนิคซื้อทองให้คุ้ม</h2>

  <ol>
    <li><strong>ซื้อทองแท่งเพื่อลงทุน:</strong> Spread แคบกว่า ซื้อ-ขายขาดทุนน้อยกว่า</li>
    <li><strong>เปรียบเทียบราคาหลายร้าน:</strong> ราคาทองแต่ละร้านอาจต่างกันเล็กน้อย</li>
    <li><strong>ซื้อจากร้านสมาชิกสมาคมค้าทองคำ:</strong> มั่นใจเรื่องมาตรฐานและความบริสุทธิ์</li>
    <li><strong>เก็บใบเสร็จ:</strong> ต้องใช้เมื่อขายคืน เพื่อยืนยันน้ำหนักและความบริสุทธิ์</li>
    <li><strong>ทยอยซื้อ (Dollar Cost Average):</strong> ซื้อทีละเล็กน้อยเป็นประจำเพื่อเฉลี่ยต้นทุน</li>
  </ol>

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}

  <h2>เครื่องคำนวณที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณค่าทองคำ/">คำนวณค่าทองคำ</a> แปลงน้ำหนักและดูราคาซื้อ-ขายทันที</li>
    <li><a href="/คำนวณอัตราแลกเปลี่ยน/">คำนวณอัตราแลกเปลี่ยน</a> เช็กค่าเงินบาทที่มีผลต่อราคาทอง</li>
    <li><a href="/คำนวณเปอร์เซ็นต์/">คำนวณเปอร์เซ็นต์</a> คำนวณกำไร-ขาดทุนจากการซื้อขายทอง</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/เงินฝาก-vs-กองทุน-เปรียบเทียบ-2569/">เงินฝาก vs กองทุน เปรียบเทียบ 2569</a></li>
    <li><a href="/บทความ/คำนวณอัตราแลกเปลี่ยน-บาท-สกุลเงิน-2569/">คำนวณอัตราแลกเปลี่ยน บาท-สกุลเงิน 2569</a></li>
  </ul>
</BlogPostLayout>
