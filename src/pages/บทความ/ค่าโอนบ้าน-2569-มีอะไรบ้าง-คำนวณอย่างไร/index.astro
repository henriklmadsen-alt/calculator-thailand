---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'ค่าโอนบ้าน 2569 มีอะไรบ้าง คำนวณอย่างไร | เครื่องคำนวณไทย';
const description = 'สรุปค่าโอนบ้านปี 2569 พร้อมสูตรที่ใช้จริง แหล่งอ้างอิงทางการกรมที่ดิน/กรมสรรพากร และตัวอย่างคำนวณที่ตรงกับเครื่องคำนวณค่าโอนบ้าน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ค่าโอนบ้าน-2569-มีอะไรบ้าง-คำนวณอย่างไร/`;

const faqData = [
  {
    question: 'ค่าโอนบ้าน 2% คิดจากอะไร?',
    answer: 'ค่าธรรมเนียมโอนคิดจากราคาประเมินทุนทรัพย์ตามหลักเกณฑ์กรมที่ดิน โดยใช้อัตราทั่วไป 2% เว้นแต่มีมาตรการพิเศษในช่วงเวลาที่รัฐกำหนด',
  },
  {
    question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ต้องจ่ายพร้อมกันไหม?',
    answer: 'โดยหลักในรายการโอนเดียวกันจะไม่จ่ายซ้ำทั้งสองรายการ หากเข้าเกณฑ์ภาษีธุรกิจเฉพาะจะได้รับยกเว้นอากรแสตมป์',
  },
  {
    question: 'ผู้ขายบุคคลธรรมดาคิดภาษีหัก ณ ที่จ่ายแบบเดียวกับนิติบุคคลไหม?',
    answer: 'ไม่เหมือนกัน นิติบุคคลมักใช้อัตรา 1% ของฐานมูลค่าที่กฎหมายกำหนด ส่วนบุคคลธรรมดาใช้วิธีคำนวณตามปีถือครองและอัตราภาษีก้าวหน้าตามแนวทางกรมที่ดิน',
  },
  {
    question: 'ผลคำนวณออนไลน์ใช้แทนยอดจริงที่สำนักงานที่ดินได้หรือไม่?',
    answer: 'ใช้เพื่อวางแผนงบเบื้องต้นเท่านั้น ยอดจริงขึ้นกับเอกสาร สิทธิ และข้อเท็จจริงในวันจดทะเบียน',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-15"
  modifiedDate="2026-04-19"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">ค่าโอนบ้าน 2569 มีอะไรบ้าง และคำนวณอย่างไรให้ไม่พลาดวันโอน</h1>

  <p>
    ดีลซื้อขายบ้านมักสะดุดเพราะคำนวณเฉพาะราคาบ้าน แต่ไม่เตรียมค่าใช้จ่ายวันโอนให้ครบ
    บทความนี้สรุปรายการหลักที่ต้องเจอจริงในปี 2569 และอธิบายวิธีคิดแบบอ่านแล้วนำไปใช้งานได้ทันที
    เพื่อให้ผู้ซื้อ ผู้ขาย และนายหน้าใช้ตัวเลขชุดเดียวกันก่อนเข้ากรมที่ดิน โดยแนะนำให้คำนวณคู่กับ
    <a href="/คำนวณค่าโอนบ้าน/">เครื่องคำนวณค่าโอนบ้าน</a> เพื่อเช็กยอดรวมแบบแยกรายการทันที
  </p>

  <ArticleCalculatorCTA
    title="คำนวณค่าโอนบ้านจากข้อมูลดีลของคุณ"
    description="กรอกราคาประเมิน ราคาซื้อขาย ประเภทผู้โอน และปีถือครอง เพื่อดูยอดประมาณการแบบแยกรายการ"
    href="/คำนวณค่าโอนบ้าน/"
    buttonLabel="ไปที่เครื่องคำนวณค่าโอนบ้าน"
  />

  <h2>ค่าใช้จ่ายวันโอนบ้านหลัก ๆ มีอะไรบ้าง</h2>

  <ul>
    <li><strong>ค่าธรรมเนียมโอนกรรมสิทธิ์</strong> ใช้อัตราตามประกาศกรมที่ดิน</li>
    <li><strong>ภาษีธุรกิจเฉพาะ (SBT)</strong> สำหรับกรณีที่เข้าเงื่อนไขตามกฎหมาย</li>
    <li><strong>อากรแสตมป์</strong> ใช้ในกรณีที่ไม่เสียภาษีธุรกิจเฉพาะ</li>
    <li><strong>ภาษีหัก ณ ที่จ่าย</strong> แยกวิธีคิดตามประเภทผู้ขาย (บุคคลธรรมดา/นิติบุคคล)</li>
    <li><strong>ค่าจดจำนอง</strong> กรณีกู้ธนาคารและมีการจดจำนองในวันโอน</li>
  </ul>

  <p>
    จุดสำคัญคือแต่ละรายการใช้ฐานคำนวณไม่เหมือนกัน เช่น บางรายการอิงราคาประเมิน บางรายการอิงมูลค่าที่สูงกว่า
    ระหว่างราคาประเมินกับราคาซื้อขาย จึงไม่ควรใช้สูตรเดียวคูณทั้งดีล
  </p>

  <h2>สูตรที่ใช้จริงก่อนวันโอน (พร้อมแหล่งอ้างอิง)</h2>

  <ul>
    <li><strong>ค่าธรรมเนียมโอน (อัตราปกติ)</strong> = ราคาประเมินทุนทรัพย์ × 2% <sup>[1]</sup></li>
    <li><strong>ภาษีธุรกิจเฉพาะ (SBT)</strong> = ฐานมูลค่าที่สูงกว่า (ราคาประเมิน/ราคาซื้อขาย) × 3.3% <sup>[1]</sup></li>
    <li><strong>อากรแสตมป์</strong> = ฐานมูลค่าที่สูงกว่า × 0.5% (ใช้เมื่อไม่เสีย SBT) <sup>[1]</sup></li>
    <li><strong>ภาษีหัก ณ ที่จ่าย (นิติบุคคล)</strong> = ฐานมูลค่าที่สูงกว่า × 1% <sup>[1]</sup></li>
    <li><strong>ภาษีหัก ณ ที่จ่าย (บุคคลธรรมดา)</strong> คำนวณจากราคาประเมิน โดยหักค่าใช้จ่ายตามปีถือครอง และคำนวณภาษีก้าวหน้า <sup>[2][4]</sup></li>
  </ul>

  <p>
    หมายเหตุเชิงปฏิบัติ: ค่าธรรมเนียมโอนตามกฎหมายมีอัตราปกติ 2% และอาจมีช่วงที่ภาครัฐออกมาตรการลดอัตราเป็นกรณีพิเศษ
    ตามหลักเกณฑ์ที่คณะรัฐมนตรีกำหนด <sup>[1]</sup>
    ดังนั้นก่อนวันโอนจริงควรตรวจสอบประกาศที่มีผลบังคับกับสำนักงานที่ดินอีกครั้ง
  </p>

  <h2>ตรรกะที่เครื่องคำนวณใช้เพื่อให้ตัวเลขตรงกัน</h2>

  <ul>
    <li>ฐานภาษี SBT/อากรแสตมป์ ใช้ “ราคาที่สูงกว่า” ระหว่างราคาประเมินกับราคาซื้อขาย</li>
    <li>กรณีผู้ขายเป็นนิติบุคคลและโอนแบบซื้อขาย ระบบคำนวณ SBT 3.3% และหัก ณ ที่จ่าย 1%</li>
    <li>กรณีผู้ขายเป็นบุคคลธรรมดา ระบบพิจารณาปีถือครอง และปัดปีขึ้นเพื่อคำนวณภาษีหัก ณ ที่จ่าย</li>
    <li>กรณีไม่เข้าเงื่อนไข SBT ระบบจะใช้ค่าอากรแสตมป์แทนตามกติกาไม่เก็บซ้ำ</li>
  </ul>

  <p>
    หากต้องการดูผลตามเงื่อนไขผู้ขายแต่ละแบบ แนะนำทดลองหลายสถานการณ์ใน
    <a href="/คำนวณค่าโอนบ้าน/">เครื่องคำนวณค่าโอนบ้าน</a>
    แล้วใช้บทความนี้เป็นเช็กลิสต์ตรวจสูตรทีละรายการ
  </p>

  <h2>ตัวอย่างคำนวณแบบย่อ (ข้อมูลสมมติ)</h2>

  <p>สมมติข้อมูลดีลดังนี้</p>
  <ul>
    <li>ราคาประเมินทุนทรัพย์ 4,000,000 บาท</li>
    <li>ราคาซื้อขาย 4,500,000 บาท</li>
    <li>วงเงินจำนอง 3,000,000 บาท</li>
    <li>ผู้ขายเป็นนิติบุคคล และเป็นการโอนแบบซื้อขาย</li>
  </ul>

  <p>คำนวณแบบย่อ</p>
  <ol>
    <li>ค่าธรรมเนียมโอน = 4,000,000 × 2% = 80,000 บาท</li>
    <li>ภาษีธุรกิจเฉพาะ = 4,500,000 × 3.3% = 148,500 บาท</li>
    <li>อากรแสตมป์ = 0 บาท (กรณีนี้เสีย SBT แล้ว)</li>
    <li>ภาษีหัก ณ ที่จ่าย (นิติบุคคล) = 4,500,000 × 1% = 45,000 บาท</li>
  </ol>

  <p>
    ตัวอย่างนี้ยังไม่รวมค่าจดจำนองและค่าใช้จ่ายย่อยอื่นที่อาจเกิดจากเงื่อนไขเฉพาะของสัญญา
    จึงควรเผื่องบสำรองไว้ก่อนวันโอนทุกครั้ง
  </p>

  <h2>วิธีเตรียมงบวันโอนให้ปลอดภัย</h2>

  <ol>
    <li>แยกรายการค่าใช้จ่ายเป็นบรรทัดและระบุผู้รับผิดชอบให้ชัดในสัญญา</li>
    <li>ตรวจราคาประเมินและข้อมูลเอกสารล่าสุดก่อนวันโอนอย่างน้อย 3-5 วันทำการ</li>
    <li>คำนวณสองรอบ: รอบแรกจากข้อมูลปัจจุบัน และรอบสองก่อนนัดโอน</li>
    <li>เผื่องบสำรอง 5-10% สำหรับความต่างจากการปัดเศษหรือเงื่อนไขหน้างาน</li>
  </ol>

  <p>
    ถ้าดีลมีหลายฝ่าย เช่น ผู้ซื้อร่วม ผู้ขายหลายราย หรือมีเงื่อนไขพิเศษเรื่องกรรมสิทธิ์
    ควรสรุปตัวเลขสุดท้ายล่วงหน้าเป็นเอกสารเดียวเพื่อเลี่ยงการตีความไม่ตรงกันวันโอนจริง
    หากมีการวางแผนผ่อนหลังโอน ควรเช็กต่อที่
    <a href="/คำนวณผ่อนบ้าน/">คำนวณผ่อนบ้าน</a>
    หรือ <a href="/คำนวณผ่อนกู้/">คำนวณผ่อนกู้</a>
    และถ้าต้องรวมภาระภาษีทั้งปีให้ตรวจซ้ำที่
    <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/">คำนวณภาษีเงินได้บุคคลธรรมดา</a>
  </p>

  <h2>เครื่องมือที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/คำนวณค่าโอนบ้าน/">คำนวณค่าโอนบ้าน</a> สำหรับรวมค่าใช้จ่ายวันโอนแบบแยกรายการ</li>
    <li><a href="/คำนวณผ่อนบ้าน/">คำนวณผ่อนบ้าน</a> เพื่อวางแผนค่างวดหลังโอนกรรมสิทธิ์</li>
    <li><a href="/คำนวณผ่อนกู้/">คำนวณผ่อนกู้</a> เพื่อดูภาระเงินสดรายเดือนหลังรับภาระสินเชื่อ</li>
    <li><a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/">คำนวณภาษีเงินได้บุคคลธรรมดา</a> สำหรับวางแผนภาษีรวมทั้งปี</li>
  </ul>

  <h2>บทความที่เกี่ยวข้อง</h2>

  <ul>
    <li><a href="/บทความ/รีไฟแนนซ์บ้าน-2569-คุ้มไหม-ดอกเบี้ยใหม่ต้องลดเท่าไร/">รีไฟแนนซ์บ้าน 2569 คุ้มไหม</a></li>
    <li><a href="/บทความ/รีไฟแนนซ์บ้าน-vs-โปะบ้าน-แบบไหนคุ้ม-2569/">รีไฟแนนซ์บ้าน vs โปะบ้าน แบบไหนคุ้ม</a></li>
    <li><a href="/บทความ/ภาษีเงินได้-2569-คำนวณ-วิธีลดหย่อน/">ภาษีเงินได้ 2569 คำนวณและวางแผนลดหย่อน</a></li>
  </ul>

  <h2>แหล่งอ้างอิงทางการ</h2>

  <ul>
    <li>
      [1] กรมที่ดิน: ค่าธรรมเนียม ภาษี และอากร
      <a href="https://www.dol.go.th/dol-services/public-service-manual/land-registration/fees-taxes-duties/" target="_blank" rel="noopener noreferrer">
        https://www.dol.go.th/dol-services/public-service-manual/land-registration/fees-taxes-duties/
      </a>
    </li>
    <li>
      [2] กรมที่ดิน: ตัวอย่างการคำนวณภาษีเงินได้หัก ณ ที่จ่าย
      <a href="https://www.dol.go.th/media/716929789247754240/migration/2025/10/dxtE3FP9oCjV4ThN86z5Jm0n.pdf" target="_blank" rel="noopener noreferrer">
        https://www.dol.go.th/media/716929789247754240/migration/2025/10/dxtE3FP9oCjV4ThN86z5Jm0n.pdf
      </a>
    </li>
    <li>
      [3] กรมที่ดิน: คู่มือจดทะเบียนโอนอสังหาริมทรัพย์
      <a href="https://www.dol.go.th/media/813280203299229696/migration/2025/10/tTJRbqDE5jo7rNC2LdcGUWFn.pdf" target="_blank" rel="noopener noreferrer">
        https://www.dol.go.th/media/813280203299229696/migration/2025/10/tTJRbqDE5jo7rNC2LdcGUWFn.pdf
      </a>
    </li>
    <li>
      [4] กรมสรรพากร: ภาษีที่เกี่ยวข้องกับการขายอสังหาริมทรัพย์ (ภาษีหัก ณ ที่จ่าย/การถือครอง)
      <a href="https://rdsrv2.rd.go.th/landwht/landwht05.asp" target="_blank" rel="noopener noreferrer">
        https://rdsrv2.rd.go.th/landwht/landwht05.asp
      </a>
    </li>
  </ul>

  <h2>คำถามที่พบบ่อย</h2>
  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">{faq.question}</summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">{faq.answer}</div>
    </details>
  ))}
</BlogPostLayout>
