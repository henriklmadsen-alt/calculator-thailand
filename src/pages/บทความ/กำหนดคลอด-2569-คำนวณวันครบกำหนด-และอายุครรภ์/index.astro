---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'กำหนดคลอด 2569: คำนวณวันครบกำหนดและอายุครรภ์จากรอบเดือน';
const description = 'สรุปสูตรคำนวณกำหนดคลอด (EDD) และอายุครรภ์แบบเข้าใจง่าย พร้อมตัวอย่างจริง แหล่งอ้างอิงทางการแพทย์ และลิงก์เครื่องมือใช้งานต่อบนเส้นทางที่เปิดใช้งานแล้ว';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/กำหนดคลอด-2569-คำนวณวันครบกำหนด-และอายุครรภ์/`;

const faqData = [
  {
    question: 'สูตรคำนวณกำหนดคลอดพื้นฐานคืออะไร?',
    answer: 'สูตรพื้นฐานคือใช้วันแรกของประจำเดือนครั้งสุดท้าย (LMP) แล้วบวก 280 วัน (40 สัปดาห์) เพื่อประมาณวันครบกำหนดคลอด',
  },
  {
    question: 'ถ้ารอบเดือนไม่สม่ำเสมอ ใช้สูตร LMP ได้ไหม?',
    answer: 'ใช้เป็นจุดเริ่มต้นได้ แต่ความคลาดเคลื่อนอาจสูงขึ้น ควรยืนยันอายุครรภ์ด้วยอัลตราซาวด์ตามคำแนะนำของแพทย์',
  },
  {
    question: 'อายุครรภ์นับเป็นสัปดาห์อย่างไร?',
    answer: 'อายุครรภ์โดยทั่วไปนับจากวันแรกของ LMP ถึงวันที่อ้างอิง แล้วแปลงวันเป็นสัปดาห์+วัน (หาร 7 แล้วดูเศษ)',
  },
  {
    question: 'ทำไมวันกำหนดคลอดที่คำนวณเองกับที่โรงพยาบาลอาจไม่ตรงกัน?',
    answer: 'เพราะแพทย์อาจใช้ข้อมูลเพิ่มเติม เช่น อัลตราซาวด์ช่วงไตรมาสแรก เพื่อปรับประมาณวันกำหนดคลอดให้แม่นยำขึ้นสำหรับการดูแลจริง',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-19"
  modifiedDate="2026-04-19"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
    กำหนดคลอด 2569: วิธีคำนวณวันครบกำหนดและอายุครรภ์แบบใช้งานจริง
  </h1>

  <p>
    ถ้าคุณกำลังวางแผนติดตามการตั้งครรภ์ สิ่งที่ต้องรู้ตั้งแต่ต้นคือ
    <strong>วันครบกำหนดคลอด (Estimated Due Date: EDD)</strong> และ
    <strong>อายุครรภ์เป็นสัปดาห์</strong> เพราะสองค่านี้จะใช้ร่วมกันตลอดการฝากครรภ์
    บทความนี้สรุปสูตรที่ใช้จริงในทางคลินิกแบบอ่านง่าย พร้อมตัวอย่างคำนวณทีละขั้นและจุดที่ควรระวัง
  </p>

  <ArticleCalculatorCTA
    title="ใช้เครื่องมือคำนวณวัน/สัปดาห์บนเส้นทางที่เปิดใช้งานแล้ว"
    description="คำนวณระยะห่างของวันจากวันที่อ้างอิง เช่น วันแรกของประจำเดือนครั้งสุดท้าย (LMP) เพื่อช่วยตรวจสอบอายุครรภ์เบื้องต้น"
    href="/คำนวณอายุ/"
    buttonLabel="ไปที่เครื่องคำนวณอายุ"
  />

  <h2>สูตรคำนวณกำหนดคลอดที่ใช้เป็นมาตรฐานเบื้องต้น</h2>

  <p>
    วิธีที่ใช้กันทั่วไปคืออ้างอิงจากวันแรกของประจำเดือนครั้งสุดท้าย (LMP):
  </p>
  <ul>
    <li><strong>EDD = LMP + 280 วัน</strong> (หรือ 40 สัปดาห์)</li>
    <li>
      เขียนอีกแบบตามกฎ Naegele:
      <strong>EDD = LMP + 1 ปี - 3 เดือน + 7 วัน</strong>
    </li>
  </ul>
  <p>
    ทั้งสองรูปแบบให้ผลเทียบเท่ากันในทางปฏิบัติ และเหมาะสำหรับการประเมินตั้งต้นก่อนมีข้อมูลอัลตราซาวด์
  </p>

  <h2>ตัวอย่างคำนวณจริง (กำหนดคลอด + อายุครรภ์)</h2>

  <p>สมมติข้อมูลดังนี้:</p>
  <ul>
    <li><strong>LMP:</strong> 12 มกราคม 2569</li>
    <li><strong>วันที่อ้างอิง:</strong> 19 เมษายน 2569</li>
  </ul>

  <div class="not-prose my-4 overflow-x-auto">
    <table class="w-full min-w-[720px] border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="border border-gray-200 px-3 py-2 text-left">รายการ</th>
          <th class="border border-gray-200 px-3 py-2 text-left">วิธีคิด</th>
          <th class="border border-gray-200 px-3 py-2 text-left">ผลลัพธ์</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-gray-200 px-3 py-2">กำหนดคลอด (EDD)</td>
          <td class="border border-gray-200 px-3 py-2">12 ม.ค. 2569 + 280 วัน</td>
          <td class="border border-gray-200 px-3 py-2">19 ต.ค. 2569</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">อายุครรภ์ ณ 19 เม.ย. 2569</td>
          <td class="border border-gray-200 px-3 py-2">จำนวนวันจาก LMP ถึงวันอ้างอิง = 97 วัน</td>
          <td class="border border-gray-200 px-3 py-2">13 สัปดาห์ 6 วัน</td>
        </tr>
        <tr>
          <td class="border border-gray-200 px-3 py-2">วันคงเหลือถึงกำหนดคลอด</td>
          <td class="border border-gray-200 px-3 py-2">EDD - วันอ้างอิง</td>
          <td class="border border-gray-200 px-3 py-2">183 วัน</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>เมื่อไรควรระวังว่าผลคำนวณอาจคลาดเคลื่อน</h2>

  <ul>
    <li>จำวันแรกของ LMP ไม่ชัดเจน</li>
    <li>รอบเดือนไม่สม่ำเสมอหรือยาว/สั้นกว่าปกติอย่างมาก</li>
    <li>มีเลือดออกผิดปกติช่วงต้นที่ทำให้สับสนกับรอบเดือน</li>
    <li>ผลประเมินจากอัลตราซาวด์ช่วงไตรมาสแรกต่างจาก LMP อย่างมีนัยสำคัญ</li>
  </ul>
  <p>
    ในสถานการณ์เหล่านี้ ควรให้ทีมแพทย์เป็นผู้กำหนดอายุครรภ์และวันครบกำหนดตามข้อมูลตรวจจริง
    บทความนี้ใช้เพื่อการวางแผนและทำความเข้าใจเบื้องต้น ไม่ใช่การวินิจฉัยแทนแพทย์
  </p>

  <h2>Internal-link readiness (เส้นทางใช้งานตอนนี้)</h2>

  <p>
    ระหว่างรอหน้าเครื่องคำนวณเฉพาะทางเปิดใช้งานเต็มรูปแบบ
    คุณยังเชื่อมการใช้งานได้จากเส้นทางที่ใช้งานได้จริงดังนี้:
  </p>
  <ul>
    <li><a href="/คำนวณอายุ/">คำนวณอายุ</a> เพื่อเช็กจำนวนวันและสัปดาห์จากวันที่อ้างอิง</li>
    <li><a href="/บทความ/คำนวณอายุ-2569-นับอายุจากวันเกิด-แบบละเอียด/">บทความคำนวณอายุ</a> สำหรับวิธีนับช่วงเวลาแบบปี-เดือน-วัน</li>
    <li><a href="/คำนวณ-bmi/">คำนวณ BMI</a> สำหรับผู้ใช้ทั่วไป (ไม่ใช้เป็นเกณฑ์หลักในหญิงตั้งครรภ์)</li>
    <li><a href="/บทความ/bmi-คำนวณค่าดัชนีมวลกาย-วิธีลดน้ำหนัก/">บทความ BMI</a> เพื่ออ่านข้อจำกัดและบริบทการใช้งาน</li>
  </ul>
  <p>
    หมายเหตุ readiness: เส้นทางเครื่องคำนวณเฉพาะทางที่กำลังเตรียมงานในคลัสเตอร์นี้คือ
    <code>/คำนวณวันกำหนดคลอด/</code> และ <code>/คำนวณอายุครรภ์/</code>
  </p>

  <h2>แหล่งอ้างอิงสูตรและหลักทางคลินิก</h2>
  <ul>
    <li>
      NHS: Pregnancy due date calculator (ใช้หลักการคำนวณจาก LMP และช่วง 40 สัปดาห์)
      <br />
      <a href="https://www.nhs.uk/pregnancy/finding-out/due-date-calculator/" target="_blank" rel="noopener noreferrer">
        https://www.nhs.uk/pregnancy/finding-out/due-date-calculator/
      </a>
    </li>
    <li>
      Johns Hopkins Medicine: Calculating a Due Date (อธิบาย 280 วัน และรูปแบบ +1 ปี +7 วัน)
      <br />
      <a href="https://www.hopkinsmedicine.org/health/wellness-and-prevention/calculating-a-due-date" target="_blank" rel="noopener noreferrer">
        https://www.hopkinsmedicine.org/health/wellness-and-prevention/calculating-a-due-date
      </a>
    </li>
    <li>
      ACOG Committee Opinion No. 700: Methods for Estimating the Due Date (แนวทางอ้างอิงทางสูติศาสตร์)
      <br />
      <a href="https://journals.lww.com/greenjournal/fulltext/2017/05000/committee_opinion_no_700__methods_for_estimating.50.aspx" target="_blank" rel="noopener noreferrer">
        https://journals.lww.com/greenjournal/fulltext/2017/05000/committee_opinion_no_700__methods_for_estimating.50.aspx
      </a>
    </li>
  </ul>

  <h2>สรุป</h2>

  <p>
    การคำนวณกำหนดคลอดและอายุครรภ์เริ่มต้นได้จากสูตร LMP + 280 วัน
    และควรใช้ควบคู่กับการติดตามทางการแพทย์โดยเฉพาะเมื่อรอบเดือนไม่สม่ำเสมอ
    สำหรับการใช้งานบนเว็บไซต์ คุณสามารถเริ่มจาก <a href="/คำนวณอายุ/">คำนวณอายุ</a>
    และย้อนอ่าน <a href="/บทความ/คำนวณอายุ-2569-นับอายุจากวันเกิด-แบบละเอียด/">คู่มือการนับช่วงเวลา</a>
    เพื่อเช็กตัวเลขให้สอดคล้องก่อนนำไปคุยกับทีมแพทย์
  </p>

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 transition-colors hover:bg-gray-50">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-sm leading-relaxed text-gray-600">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
