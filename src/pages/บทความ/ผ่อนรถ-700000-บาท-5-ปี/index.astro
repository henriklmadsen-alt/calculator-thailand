---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'ผ่อนรถ 700,000 บาท นาน 5 ปี ดอกเบี้ย 3% ต้องจ่ายรายเดือนเท่าไร | เครื่องคำนวณไทย';
const description = 'สาธิตการคำนวณผ่อนรถ 700,000 บาท ระยะเวลา 5 ปี ดอกเบี้ย 3% ขั้นตอนละเอียด เปรียบเทียบผ่อน 3-7 ปี และการตรวจสอบความสามารถชำระเงิน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ผ่อนรถ-700000-บาท-5-ปี/`;

const faqData = [
  {
    question: 'ผ่อนรถ 700,000 บาท 5 ปี ดอกเบี้ย 3% ค่าผ่อนเดือนละเท่าไร?',
    answer: 'วางเงินดาวน์ 20% (140,000 บาท) กู้ 560,000 บาท ค่าผ่อนประมาณ 10,052 บาท/เดือน ดอกเบี้ยรวมประมาณ 43,120 บาท',
  },
  {
    question: 'เงินเดือนเท่าไรถึงจะผ่อนรถ 700,000 บาทได้?',
    answer: 'ค่าผ่อน 10,052 บาท ควรมีเงินเดือนสุทธิอย่างน้อย 33,500 บาท (ค่าผ่อนไม่เกิน 30% ของเงินเดือนสุทธิ)',
  },
  {
    question: 'ผ่อน 3 ปีกับ 7 ปี ดอกเบี้ยต่างกันเท่าไร?',
    answer: 'ผ่อน 3 ปีดอกเบี้ยรวมประมาณ 21,400 บาท ผ่อน 7 ปีดอกเบี้ยรวมประมาณ 71,680 บาท ต่างกันถึง 50,280 บาท',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    ผ่อนรถ 700,000 บาท นาน 5 ปี ดอกเบี้ย 3% ต้องจ่ายรายเดือนเท่าไร
  </h1>

  <p>
    เมื่อตัดสินใจซื้อรถยนต์ราคา 700,000 บาท หลายคนอยากรู้ว่า "ผ่อนรายเดือนเท่าไร" และ "จ่ายดอกเบี้ยทั้งหมดเท่าไร" บทความนี้จะสาธิตการคำนวณโดยละเอียด พร้อมเปรียบเทียบระยะเวลาผ่อนต่างๆ
  </p>

  <ArticleCalculatorCTA
    title="คำนวณผ่อนรถยนต์"
    description="ใส่ราคารถ เงินดาวน์ อัตราดอกเบี้ย ระยะเวลา คำนวณทันที"
    href="/คำนวณผ่อนรถ/"
    buttonLabel="คำนวณผ่อนรถฟรี"
  />

  <h2>ตัวอย่างคำนวณ: ผ่อน 700,000 นาน 5 ปี ดอกเบี้ย 3%</h2>

  <p><strong>รายละเอียดการกู้:</strong></p>
  <ul>
    <li>ราคารถ: 700,000 บาท</li>
    <li>เงินดาวน์: 20% = 140,000 บาท</li>
    <li>จำนวนกู้: 560,000 บาท</li>
    <li>ระยะเวลา: 5 ปี (60 เดือน)</li>
    <li>อัตราดอกเบี้ย: 3% ต่อปี</li>
  </ul>

  <p><strong>ขั้นตอนการคำนวณ:</strong></p>
  <ol>
    <li>อัตราดอกเบี้ยรายเดือน = 3% ÷ 12 = 0.25% ต่อเดือน</li>
    <li>ใช้สูตร: ค่าผ่อน = เงินกู้ × [r(1+r)^n] / [(1+r)^n - 1]</li>
    <li><strong>ค่าผ่อน ≈ 10,052 บาท/เดือน</strong></li>
    <li>ดอกเบี้ยทั้งหมด = (10,052 × 60) - 560,000 = <strong>43,120 บาท</strong></li>
  </ol>

  <h2>สรุปค่าใช้จ่าย</h2>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">รายการ</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">จำนวน</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">ราคาเดิม</td><td class="border border-gray-200 px-3 py-2 text-right">700,000 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">เงินดาวน์ (20%)</td><td class="border border-gray-200 px-3 py-2 text-right">140,000 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">จำนวนกู้</td><td class="border border-gray-200 px-3 py-2 text-right">560,000 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">ค่าผ่อนรายเดือน</td><td class="border border-gray-200 px-3 py-2 text-right font-semibold">10,052 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">ดอกเบี้ยสุทธิ</td><td class="border border-gray-200 px-3 py-2 text-right">43,120 บาท</td></tr>
      </tbody>
    </table>
  </div>

  <h2>เปรียบเทียบระยะเวลาผ่อนต่างๆ</h2>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">ระยะเวลา</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">ค่าผ่อน/เดือน</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">ดอกเบี้ยรวม</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">3 ปี (36 เดือน)</td><td class="border border-gray-200 px-3 py-2 text-right">16,150 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">21,400 บาท</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">5 ปี (60 เดือน)</td><td class="border border-gray-200 px-3 py-2 text-right font-semibold">10,052 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">43,120 บาท</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">7 ปี (84 เดือน)</td><td class="border border-gray-200 px-3 py-2 text-right">7,520 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">71,680 บาท</td></tr>
      </tbody>
    </table>
  </div>

  <h2>ตรวจสอบความสามารถในการชำระเงิน</h2>

  <p>ค่าผ่อนรถไม่ควรเกิน <strong>25-30% ของเงินเดือนสุทธิ</strong></p>
  <ul>
    <li>ค่าผ่อน 10,052 บาท → ต้องการเงินเดือนสุทธิ ≥ 33,500 บาท</li>
    <li>เงินเดือน 40,000 บาท → เงินสุทธิประมาณ 37,950 บาท ✓ (เพียงพอ)</li>
  </ul>

  <p>ตรวจสอบเงินสุทธิของคุณได้ที่ <a href="/คำนวณเงินเดือนสุทธิ/">เครื่องคำนวณเงินเดือนสุทธิ</a></p>

  <ArticleCalculatorCTA
    title="คำนวณค่าผ่อนรถของคุณ"
    description="ลองปรับราคา เงินดาวน์ และระยะเวลา เปรียบเทียบผลทันที"
    href="/คำนวณผ่อนรถ/"
    buttonLabel="คำนวณผ่อนรถตอนนี้"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
