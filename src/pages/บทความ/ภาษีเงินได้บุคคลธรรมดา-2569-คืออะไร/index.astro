---
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import ArticleCalculatorCTA from '../../../components/templates/ArticleCalculatorCTA.astro';

const title = 'ภาษีเงินได้บุคคลธรรมดา 2569: ใครต้องยื่นภาษี และคำนวณภาษีอย่างไรให้ถูกต้อง | Kamnuanlek';
const description = 'สรุปภาษีเงินได้บุคคลธรรมดา 2569 แบบเข้าใจง่าย ว่าใครต้องยื่นภาษี และคำนวณภาษีอย่างไรให้ถูกต้องจากรายได้จริง ขั้นภาษี และค่าลดหย่อนหลัก';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/บทความ/ภาษีเงินได้บุคคลธรรมดา-2569-คืออะไร/`;

const faqData = [
  {
    question: 'ภาษีเงินได้บุคคลธรรมดาคำนวณอย่างไรในปี 2569?',
    answer: 'เริ่มจากรวมรายได้ทั้งปี หักค่าใช้จ่ายตามประเภทเงินได้ แล้วหักค่าลดหย่อนที่ใช้ได้จริง จากนั้นนำเงินได้สุทธิไปคำนวณตามขั้นภาษีแบบอัตราก้าวหน้า',
  },
  {
    question: 'ใครต้องยื่นภาษีเงินได้บุคคลธรรมดา?',
    answer: 'ผู้มีเงินได้ที่เข้าเกณฑ์ตามกฎหมายต้องยื่นแบบทุกปี แม้บางกรณีภาษีที่คำนวณได้เป็นศูนย์ โดยพิจารณาจากประเภทเงินได้และเกณฑ์รายได้ของปีภาษีนั้น',
  },
  {
    question: 'คำนวณภาษีจากเงินเดือนต้องเริ่มจากอะไร?',
    answer: 'ใช้รายได้ทั้งปีจากเงินเดือนเป็นฐาน ตั้งค่าลดหย่อนพื้นฐานและสิทธิที่มีหลักฐานครบ แล้วตรวจขั้นภาษีแต่ละช่วงเพื่อดูภาษีที่ต้องจ่ายจริง',
  },
  {
    question: 'วางแผนค่าลดหย่อนอย่างไรให้เสียภาษีถูกต้องและไม่พลาดสิทธิ?',
    answer: 'จัดลำดับค่าลดหย่อนที่ใช้ได้แน่นอนก่อน เช่น ส่วนตัว ประกันสังคม และสิทธิครอบครัว จากนั้นเติมสิทธิจากประกันหรือกองทุนตามเพดาน พร้อมเก็บเอกสารเพื่อยืนยันตอนยื่นแบบ',
  },
];
---

<BlogPostLayout
  title={title}
  description={description}
  publishDate="2026-04-21"
  canonical={canonical}
  faqData={faqData}
>
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
    ภาษีเงินได้บุคคลธรรมดา 2569: ใครต้องยื่นภาษี และคำนวณภาษีอย่างไรให้ถูกต้อง
  </h1>

  <p>
    ภาษีเงินได้บุคคลธรรมดาเป็นภาษีที่ประชาชนไทยต้องจ่ายกับรัฐบาลจากรายได้ต่างๆ ที่ได้รับในปีนั้น ไม่ว่าจะเป็นเงินเดือน กำไรจากธุรกิจ ดอกเบี้ย หรือค่าเช่า ปีนี้ (2569) มีการปรับเปลี่ยนขั้นภาษีหลายรายการที่ส่งผลให้อัตราภาษีเปลี่ยนไป บทความนี้จะอธิบายครบทั้งสิ้นว่าภาษีเงินได้คืออะไร ใครต้องจ่าย และจะคำนวณได้อย่างไร
  </p>

  <section id="income-tax-basics-article-intent-cluster" class="my-6 rounded-xl border border-amber-100 bg-amber-50/60 p-4">
    <h2 class="m-0 text-lg font-semibold text-amber-900">เริ่มจากพื้นฐานภาษีเงินได้ แล้วคำนวณให้เห็นตัวเลขจริง</h2>
    <p class="mt-2 text-sm leading-7 text-amber-900">
      ใช้ลิงก์ลัดเพื่อคำนวณภาษีเงินได้บุคคลธรรมดาทันที และอ่านแนวทางคำนวณภาษีปี 2569 พร้อมรายการลดหย่อนสำคัญ
    </p>
    <ul class="mt-3 space-y-2">
      <li><a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="font-medium text-amber-800 underline decoration-amber-300 underline-offset-2">คำนวณภาษีเงินได้บุคคลธรรมดา</a></li>
      <li><a href="/บทความ/ภาษีเงินได้-2569-คำนวณ-วิธีลดหย่อน/" class="font-medium text-amber-800 underline decoration-amber-300 underline-offset-2">ภาษีเงินได้ 2569 คำนวณและวิธีลดหย่อน</a></li>
    </ul>
  </section>

  <ArticleCalculatorCTA
    title="คำนวณภาษีเงินได้บุคคลธรรมดา"
    description="ใส่รายได้และค่าลดหย่อน คำนวณภาษีที่ต้องจ่ายทันที"
    href="/คำนวณภาษีเงินได้บุคคลธรรมดา/"
    buttonLabel="คำนวณภาษีฟรี"
  />

  <h2>ภาษีเงินได้คืออะไร และใครต้องจ่าย</h2>

  <p>
    ภาษีเงินได้บุคคลธรรมดา ตามกฎหมายของไทย เป็นภาษีที่เรียกเก็บจากรายได้ของบุคคลธรรมดาในประเทศไทย ตามพระราชกฤษฎีกาว่าด้วยภาษีเงินได้ พ.ศ. 2481 ซึ่งได้รับการแก้ไขเพิ่มเติมหลายครั้ง
  </p>

  <p>หากคุณเป็นผู้มีรายได้ต่อไปนี้ คุณต้องจ่ายภาษี:</p>
  <ul>
    <li>เงินเดือนหรือค่าจ้างจากการทำงาน</li>
    <li>กำไรจากการประกอบธุรกิจหรืออาชีพอิสระ</li>
    <li>ดอกเบี้ยและเงินปันผล</li>
    <li>ค่าเช่าทรัพย์สิน</li>
    <li>ค่าตอบแทนจากการให้บริการ</li>
  </ul>

  <h2>ขั้นภาษีเงินได้ 2569</h2>

  <p>ในประเทศไทย มีขั้นภาษี 7 ระดับ ที่เพิ่มขึ้นตามจำนวนรายได้ที่ได้รับ:</p>

  <div class="overflow-x-auto my-4">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="border border-gray-200 px-3 py-2 text-left font-semibold">รายได้สะสม</th>
          <th class="border border-gray-200 px-3 py-2 text-right font-semibold">อัตราภาษี</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-gray-200 px-3 py-2">0 - 150,000 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">ไม่มีภาษี (0%)</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">150,001 - 300,000 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">5%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">300,001 - 500,000 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">10%</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">500,001 - 750,000 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">15%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">750,001 - 1,000,000 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">20%</td></tr>
        <tr class="bg-gray-50"><td class="border border-gray-200 px-3 py-2">1,000,001 - 2,000,000 บาท</td><td class="border border-gray-200 px-3 py-2 text-right">25%</td></tr>
        <tr><td class="border border-gray-200 px-3 py-2">2,000,001 บาท ขึ้นไป</td><td class="border border-gray-200 px-3 py-2 text-right">35%</td></tr>
      </tbody>
    </table>
  </div>

  <h2>ลดหย่อนและสิ่งที่ลดภาษี</h2>

  <p>เงินได้ของคุณไม่ได้นำมาคำนวณภาษีทั้งหมด เพราะมีสิ่งต่างๆ ที่ลดหย่อนภาษี:</p>

  <p><strong>ลดหย่อนพื้นฐาน:</strong></p>
  <ul>
    <li>บุคคลเดี่ยว: 60,000 บาท</li>
    <li>สมรส: 120,000 บาท</li>
    <li>บิดามารดา: 30,000 บาทต่อคน</li>
    <li>บุตร: 15,000 บาทต่อคน (ไม่เกิน 4 คน)</li>
  </ul>

  <p><strong>ลดหย่อนพิเศษ:</strong></p>
  <ul>
    <li>ประกันสังคม (SSO): ตามที่จ่ายจริง</li>
    <li>กองทุนสำรองเลี้ยงชีพ: ไม่เกิน 8% ของเงินได้ต่อปี</li>
    <li>ค่าซื้อประกันชีวิต: ไม่เกิน 100,000 บาท</li>
    <li>ค่าใช้จ่ายการศึกษา: ไม่เกิน 50,000 บาท</li>
  </ul>

  <h2>ตัวอย่างการคำนวณ</h2>

  <p>สมมติว่าคุณเป็นพนักงานเงินเดือน 40,000 บาท ต่อเดือน (480,000 ต่อปี) อยู่คนเดี่ยว ไม่มีรายได้อื่น:</p>

  <ol>
    <li>รายได้รวม: 480,000 บาท</li>
    <li>ลดหย่อนพื้นฐาน: 60,000 บาท</li>
    <li>เงินได้สุทธิ: 420,000 บาท</li>
    <li>คำนวณภาษี:
      <ul>
        <li>0-150,000: ไม่มีภาษี</li>
        <li>150,001-300,000: 150,000 × 5% = 7,500 บาท</li>
        <li>300,001-420,000: 120,000 × 10% = 12,000 บาท</li>
      </ul>
    </li>
    <li><strong>ภาษีรวม: 19,500 บาท</strong></li>
  </ol>

  <h2>วิธีจ่ายและการยื่นแบบแสดงผล</h2>

  <p>
    คุณต้องยื่นแบบแสดงผล ภ.ง.ด.91 (ส่วนบุคคล) หรือ ภ.ง.ด.90 (นายจ้าง) ขึ้นอยู่กับประเภทรายได้ เดือนเมษายนของทุกปีเป็นกำหนดการยื่นแบบแสดงผลให้กรมสรรพากรทราบ ข้อมูลเพิ่มเติมดูได้ที่ <a href="https://www.rd.go.th/" rel="noopener noreferrer" target="_blank">กรมสรรพากร (rd.go.th)</a>
  </p>

  <ArticleCalculatorCTA
    title="คำนวณภาษีของคุณเอง"
    description="ใส่รายได้และค่าลดหย่อน ดูผลลัพธ์ทันที ฟรี ไม่ต้องสมัครสมาชิก"
    href="/คำนวณภาษีเงินได้บุคคลธรรมดา/"
    buttonLabel="เริ่มคำนวณภาษี"
  />

  <h2>คำถามที่พบบ่อย (FAQ)</h2>

  {faqData.map((faq) => (
    <details class="mb-3 bg-white rounded-lg border border-gray-200 overflow-hidden">
      <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors">
        {faq.question}
      </summary>
      <div class="px-4 pb-3 text-gray-600 text-sm leading-relaxed">
        {faq.answer}
      </div>
    </details>
  ))}
</BlogPostLayout>
