---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณแคลอรี่ BMR TDEE 2569 | ความต้องการแคลอรี่รายวัน ฟรี | Calculator Thailand';
const pageDescription = 'คำนวณแคลอรี่ BMR TDEE ออนไลน์ฟรี วางแผนน้ำหนักด้วยสูตร Mifflin-St Jeor ที่แม่นยำ พร้อมฐานข้อมูลอาหารไทย ผลลัพธ์ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณแคลอรี่/`;

const faqData = [
  {
    question: 'BMR คืออะไร?',
    answer: 'BMR (Basal Metabolic Rate) หรือ "อัตราเผาผลาญพื้นฐาน" คือจำนวนแคลอรี่ที่ร่างกายต้องการขั้นต่ำเพื่อรักษาการทำงานพื้นฐานในสภาวะพักผ่อนสมบูรณ์ เช่น การหายใจ การสูบฉีดเลือด การย่อยอาหาร คำนวณด้วยสูตร Mifflin-St Jeor ซึ่งแม่นยำที่สุดในปัจจุบัน',
  },
  {
    question: 'TDEE คืออะไร?',
    answer: 'TDEE (Total Daily Energy Expenditure) คือแคลอรี่รวมที่ร่างกายใช้ทั้งวัน รวมทั้ง BMR และแคลอรี่จากกิจกรรมต่าง ๆ คำนวณจาก BMR × ตัวคูณกิจกรรม (1.2–1.9) ซึ่งขึ้นอยู่กับระดับการออกกำลังกายของแต่ละคน',
  },
  {
    question: 'ต้องกินแคลอรี่เท่าไรเพื่อลดน้ำหนัก 0.5 กก./สัปดาห์?',
    answer: 'ต้องสร้างแคลอรี่ขาดดุล (Deficit) ประมาณ 500 kcal/วัน เพราะ 1 กก. ไขมัน ≈ 7,700 kcal ดังนั้น 500 × 7 ÷ 7,700 ≈ 0.45 กก./สัปดาห์ อย่าลดแคลอรี่ต่ำกว่า 1,200 kcal/วัน เพราะอาจสูญเสียกล้ามเนื้อและสารอาหาร',
  },
  {
    question: 'ทำไม BMR ของผู้หญิงต่ำกว่าผู้ชาย?',
    answer: 'เพราะโดยเฉลี่ยผู้ชายมีมวลกล้ามเนื้อมากกว่าผู้หญิง กล้ามเนื้อเผาผลาญแคลอรี่ได้มากกว่าไขมัน สูตร Mifflin-St Jeor สะท้อนความแตกต่างนี้โดยบวก +5 สำหรับชาย และลบ -161 สำหรับหญิง',
  },
  {
    question: 'ควรกินน้อยกว่า BMR ได้ไหม?',
    answer: 'ไม่ควร BMR คือความต้องการขั้นต่ำของร่างกาย การกินต่ำกว่า BMR จะทำให้ร่างกายสลายกล้ามเนื้อเพื่อหาพลังงาน ส่งผลเสียระยะยาว ควรลดแคลอรี่ให้อยู่ระหว่าง BMR ถึง TDEE เพื่อลดน้ำหนักอย่างปลอดภัย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณแคลอรี่ BMR TDEE',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณแคลอรี่ BMR และ TDEE สำหรับวางแผนน้ำหนัก',
  description: 'ขั้นตอนการคำนวณ BMR และ TDEE ด้วยสูตร Mifflin-St Jeor พร้อมวิธีตั้งเป้าหมายแคลอรี่รายวัน',
  step: [
    {
      '@type': 'HowToStep',
      name: 'กรอกข้อมูลส่วนตัว',
      text: 'ระบุอายุ เพศ น้ำหนัก (กก.) และส่วนสูง (ซม.) ให้ครบถ้วนและแม่นยำ เพราะข้อมูลเหล่านี้มีผลโดยตรงต่อค่า BMR',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกระดับกิจกรรม',
      text: 'เลือกระดับการออกกำลังกายที่ตรงกับชีวิตประจำวันมากที่สุด ตั้งแต่นั่งส่วนใหญ่ (1.2×) ถึงออกกำลังหนักมาก (1.9×) เพื่อคำนวณ TDEE ที่แม่นยำ',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกเป้าหมายน้ำหนัก',
      text: 'เลือกว่าต้องการลดน้ำหนัก รักษาน้ำหนัก หรือเพิ่มน้ำหนัก หากเลือกลดน้ำหนักให้ระบุอัตราที่ต้องการ (0.25–1.0 กก./สัปดาห์)',
    },
    {
      '@type': 'HowToStep',
      name: 'อ่านผลลัพธ์',
      text: 'ระบบแสดง BMR, TDEE, เป้าหมายแคลอรี่รายวัน และการคาดการณ์น้ำหนักใน 30 และ 90 วัน ใช้เป็นแนวทางวางแผนการกินและออกกำลังกาย',
    },
    {
      '@type': 'HowToStep',
      name: 'วางแผนมื้ออาหาร',
      text: 'ใช้ฐานข้อมูลอาหารไทยเพื่อดูแคลอรี่ของอาหารที่กินเป็นประจำ และวางแผนให้ผลรวมแคลอรี่ต่อวันไม่เกินเป้าหมาย',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณแคลอรี่">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณแคลอรี่และเป้าหมายน้ำหนักของคุณ
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2">
      <p class="text-xs font-semibold text-green-800">[สูตร Mifflin-St Jeor 1990 | ฐานข้อมูลอาหารไทย]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณ BMR TDEE และแคลอรี่เป้าหมายรายวัน พร้อมการคาดการณ์น้ำหนักในอนาคต
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">

      <!-- Inputs -->
      <div class="grid gap-4 sm:grid-cols-2 mb-4">
        <div>
          <label for="age" class="block text-sm font-medium text-gray-700 mb-1">อายุ (ปี)</label>
          <input
            type="text"
            id="age"
            inputmode="numeric"
            placeholder="เช่น 30"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="gender" class="block text-sm font-medium text-gray-700 mb-1">เพศ</label>
          <select
            id="gender"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="male">ชาย</option>
            <option value="female">หญิง</option>
          </select>
        </div>
        <div>
          <label for="weight" class="block text-sm font-medium text-gray-700 mb-1">น้ำหนัก (กิโลกรัม)</label>
          <input
            type="text"
            id="weight"
            inputmode="decimal"
            placeholder="เช่น 70"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="height" class="block text-sm font-medium text-gray-700 mb-1">ส่วนสูง (เซนติเมตร)</label>
          <input
            type="text"
            id="height"
            inputmode="decimal"
            placeholder="เช่น 170"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 mb-4">
        <div>
          <label for="activity" class="block text-sm font-medium text-gray-700 mb-1">ระดับกิจกรรม</label>
          <select
            id="activity"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="sedentary">นั่ง/นอนส่วนใหญ่ (×1.2)</option>
            <option value="light">ออกกำลังเบา 1–3 วัน/สัปดาห์ (×1.375)</option>
            <option value="moderate" selected>ออกกำลังปานกลาง 3–5 วัน/สัปดาห์ (×1.55)</option>
            <option value="active">ออกกำลังหนัก 6–7 วัน/สัปดาห์ (×1.725)</option>
            <option value="very_active">ออกกำลังหนักมาก/งานหนัก (×1.9)</option>
          </select>
        </div>
        <div>
          <label for="goal" class="block text-sm font-medium text-gray-700 mb-1">เป้าหมาย</label>
          <select
            id="goal"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="lose">ลดน้ำหนัก</option>
            <option value="maintain" selected>รักษาน้ำหนัก</option>
            <option value="gain">เพิ่มน้ำหนัก</option>
          </select>
        </div>
      </div>

      <!-- Weight loss rate (shown only when goal=lose) -->
      <div id="loss-rate-row" class="hidden mb-4">
        <label for="loss-rate" class="block text-sm font-medium text-gray-700 mb-1">
          อัตราการลดน้ำหนัก (กก./สัปดาห์)
        </label>
        <select
          id="loss-rate"
          class="w-full sm:w-64 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
        >
          <option value="0.25">0.25 กก./สัปดาห์ (ลดช้า ปลอดภัยมาก)</option>
          <option value="0.5" selected>0.5 กก./สัปดาห์ (แนะนำ)</option>
          <option value="0.75">0.75 กก./สัปดาห์</option>
          <option value="1">1.0 กก./สัปดาห์ (สูงสุดที่แนะนำ)</option>
        </select>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณแคลอรี่
      </button>

      <!-- Results -->
      <div id="result" class="hidden mt-6">

        <!-- Primary metrics row -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
          <div class="bg-blue-50 rounded-lg p-3 text-center">
            <div class="text-xs text-blue-600 font-semibold mb-1">BMR</div>
            <div id="res-bmr" class="text-2xl font-bold text-blue-700">—</div>
            <div class="text-xs text-gray-500">kcal/วัน</div>
          </div>
          <div class="bg-green-50 rounded-lg p-3 text-center">
            <div class="text-xs text-green-600 font-semibold mb-1">TDEE</div>
            <div id="res-tdee" class="text-2xl font-bold text-green-700">—</div>
            <div class="text-xs text-gray-500">kcal/วัน</div>
          </div>
          <div class="col-span-2 sm:col-span-1 bg-orange-50 rounded-lg p-3 text-center">
            <div class="text-xs text-orange-600 font-semibold mb-1">เป้าหมายรายวัน</div>
            <div id="res-daily-goal" class="text-2xl font-bold text-orange-700">—</div>
            <div class="text-xs text-gray-500">kcal/วัน</div>
          </div>
        </div>

        <!-- Deficit/Surplus info -->
        <div id="deficit-box" class="rounded-lg p-4 mb-4">
          <p id="deficit-text" class="text-sm font-medium"></p>
        </div>

        <!-- Weight projections -->
        <div class="bg-gray-50 rounded-lg p-4 mb-4">
          <h3 class="font-semibold text-gray-900 mb-3">การคาดการณ์น้ำหนัก</h3>
          <div class="grid grid-cols-2 gap-3 text-sm">
            <div>
              <div class="text-gray-500 mb-1">น้ำหนักใน 30 วัน</div>
              <div id="res-30d" class="text-lg font-bold text-gray-900">—</div>
              <div class="text-xs text-gray-400">กก.</div>
            </div>
            <div>
              <div class="text-gray-500 mb-1">น้ำหนักใน 90 วัน</div>
              <div id="res-90d" class="text-lg font-bold text-gray-900">—</div>
              <div class="text-xs text-gray-400">กก.</div>
            </div>
            <div>
              <div class="text-gray-500 mb-1">เป้าหมายรายสัปดาห์</div>
              <div id="res-weekly" class="text-lg font-bold text-gray-900">—</div>
              <div class="text-xs text-gray-400">kcal/สัปดาห์</div>
            </div>
            <div>
              <div class="text-gray-500 mb-1">การเปลี่ยนน้ำหนัก/เดือน</div>
              <div id="res-monthly-change" class="text-lg font-bold text-gray-900">—</div>
              <div class="text-xs text-gray-400">กก./เดือน</div>
            </div>
          </div>
        </div>

        <!-- Safe minimum warning if applicable -->
        <div id="min-warning" class="hidden p-3 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800 mb-4">
          ⚠️ เป้าหมายแคลอรี่ถูกปรับให้ไม่ต่ำกว่า 1,200 kcal/วัน เพื่อความปลอดภัย
        </div>

      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- Thai Food Reference Table -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ตารางแคลอรี่อาหารไทย (อ้างอิง)</h2>
      <p class="text-sm text-gray-600 mb-4">
        แคลอรี่ของอาหารไทยที่พบบ่อย อ้างอิงจากฐานข้อมูลโภชนาการไทยและ USDA
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b-2 border-gray-300 bg-gray-50">
              <th class="py-2 px-3">ชื่ออาหาร</th>
              <th class="py-2 px-3">หน่วย</th>
              <th class="py-2 px-3 text-right">แคลอรี่ (kcal)</th>
              <th class="py-2 px-3 text-right hidden sm:table-cell">โปรตีน (g)</th>
              <th class="py-2 px-3 text-right hidden sm:table-cell">คาร์บ (g)</th>
              <th class="py-2 px-3 text-right hidden sm:table-cell">ไขมัน (g)</th>
            </tr>
          </thead>
          <tbody id="food-table-body">
            <!-- populated by JS -->
          </tbody>
        </table>
      </div>
    </section>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">BMR และ TDEE คืออะไร?</h2>

      <p>
        <strong>BMR (Basal Metabolic Rate)</strong> หรืออัตราเผาผลาญพื้นฐาน คือจำนวนแคลอรี่ขั้นต่ำที่ร่างกายต้องการ
        เพื่อรักษาการทำงานสำคัญเมื่ออยู่นิ่ง เช่น การหายใจ การสูบฉีดเลือด การทำงานของอวัยวะ
        เครื่องคำนวณนี้ใช้สูตร <strong>Mifflin-St Jeor (1990)</strong> ซึ่งเป็นสูตรที่แม่นยำที่สุดในปัจจุบัน
      </p>

      <div class="bg-gray-50 rounded-lg p-4 my-4">
        <p class="text-sm font-semibold text-gray-900 mb-2">สูตร Mifflin-St Jeor:</p>
        <ul class="text-sm space-y-1 text-gray-700 list-none pl-0">
          <li><strong>ชาย:</strong> BMR = (10 × น้ำหนัก) + (6.25 × ส่วนสูง) − (5 × อายุ) + 5</li>
          <li><strong>หญิง:</strong> BMR = (10 × น้ำหนัก) + (6.25 × ส่วนสูง) − (5 × อายุ) − 161</li>
        </ul>
        <p class="text-xs text-gray-500 mt-2">น้ำหนัก = กก., ส่วนสูง = ซม., อายุ = ปี</p>
      </div>

      <p>
        <strong>TDEE (Total Daily Energy Expenditure)</strong> คือแคลอรี่รวมทั้งวัน
        คำนวณจาก BMR × ตัวคูณกิจกรรม ซึ่งสะท้อนพลังงานที่ใช้ในการเคลื่อนไหวและออกกำลังกาย
      </p>

      <div class="overflow-x-auto my-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b-2 border-gray-300">
              <th class="py-2 pr-4">ระดับกิจกรรม</th>
              <th class="py-2 pr-4">ตัวคูณ</th>
              <th class="py-2">คำอธิบาย</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 font-medium">Sedentary</td>
              <td class="py-2 pr-4">× 1.2</td>
              <td class="py-2">นั่งทำงาน ไม่ออกกำลังกาย</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 font-medium">Light</td>
              <td class="py-2 pr-4">× 1.375</td>
              <td class="py-2">ออกกำลังเบา 1–3 วัน/สัปดาห์</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 font-medium">Moderate</td>
              <td class="py-2 pr-4">× 1.55</td>
              <td class="py-2">ออกกำลังปานกลาง 3–5 วัน/สัปดาห์</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4 font-medium">Active</td>
              <td class="py-2 pr-4">× 1.725</td>
              <td class="py-2">ออกกำลังหนัก 6–7 วัน/สัปดาห์</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 font-medium">Very Active</td>
              <td class="py-2 pr-4">× 1.9</td>
              <td class="py-2">ออกกำลังหนักมากหรืองานใช้แรงกาย</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-xl font-semibold text-gray-900 mt-6 mb-3">วางแผนน้ำหนักด้วยแคลอรี่ขาดดุลและเกินดุล</h2>

      <p>
        หลักการพื้นฐาน: ไขมัน 1 กก. ≈ 7,700 kcal ดังนั้น:
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ขาดดุล 500 kcal/วัน → ลดน้ำหนัก ≈ 0.5 กก./สัปดาห์</li>
        <li>ขาดดุล 1,000 kcal/วัน → ลดน้ำหนัก ≈ 1 กก./สัปดาห์ (สูงสุดที่แนะนำ)</li>
        <li>เกินดุล 500 kcal/วัน → เพิ่มน้ำหนัก ≈ 0.5 กก./สัปดาห์</li>
      </ul>

      <div class="p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700 my-4">
        <strong>⚠️ ข้อควรระวัง:</strong> ห้ามกินแคลอรี่ต่ำกว่า 1,200 kcal/วัน (หญิง) หรือ 1,500 kcal/วัน (ชาย)
        เพราะอาจทำให้ร่างกายสลายกล้ามเนื้อและขาดสารอาหาร
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">ตัวอย่างการคำนวณ: หญิง อายุ 30 ปี น้ำหนัก 65 กก. สูง 160 ซม.</h3>

      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <p class="font-semibold text-gray-900 mb-2">ขั้นตอน:</p>
        <ol class="list-decimal pl-6 space-y-1 text-gray-700">
          <li>BMR = (10 × 65) + (6.25 × 160) − (5 × 30) − 161 = 650 + 1,000 − 150 − 161 = <strong>1,339 kcal/วัน</strong></li>
          <li>TDEE (ออกกำลังปานกลาง) = 1,339 × 1.55 = <strong>2,075 kcal/วัน</strong></li>
          <li>เป้าหมายลดน้ำหนัก 0.5 กก./สัปดาห์ = 2,075 − 500 = <strong>1,575 kcal/วัน</strong></li>
          <li>คาดการณ์น้ำหนักใน 90 วัน = 65 − (0.5 × 4 × 3) = <strong>59 กก.</strong></li>
        </ol>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณแคลอรี่/" />
    <RelatedCalculators currentHref="/คำนวณแคลอรี่/" />

    <!-- Official References -->
    <section class="mb-8">
      <h3 class="mb-3 text-lg font-semibold text-gray-900">แหล่งอ้างอิงทางการ</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>
          <a href="https://www.anamai.moph.go.th/" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">
            กรมอนามัย กระทรวงสาธารณสุข — มาตรฐานโภชนาการและการควบคุมน้ำหนัก
          </a>
        </li>
        <li>
          <a href="https://www.who.int/news-room/fact-sheets/detail/healthy-diet" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 font-medium">
            WHO — Healthy Diet Fact Sheet
          </a>
        </li>
        <li>
          Mifflin MD, St Jeor ST et al. (1990) "A new predictive equation for resting energy expenditure." <em>Am J Clin Nutr</em> 51(2):241–247.
        </li>
      </ul>
    </section>

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการจากสูตรมาตรฐานสากล
      ไม่ถือเป็นคำแนะนำทางการแพทย์ กรุณาปรึกษาแพทย์หรือนักโภชนาการก่อนเปลี่ยนแปลงโปรแกรมอาหารอย่างมีนัยสำคัญ
    </div>
  </article>

  <script>
    // ---- Calorie Calculator Logic (Mifflin-St Jeor) ----

    type Gender = 'male' | 'female';
    type ActivityLevel = 'sedentary' | 'light' | 'moderate' | 'active' | 'very_active';
    type Goal = 'lose' | 'maintain' | 'gain';

    const ACTIVITY_MULTIPLIERS: Record<ActivityLevel, number> = {
      sedentary: 1.2,
      light: 1.375,
      moderate: 1.55,
      active: 1.725,
      very_active: 1.9,
    };

    function calculateBMR(age: number, gender: Gender, weight: number, height: number): number {
      const base = 10 * weight + 6.25 * height - 5 * age;
      return gender === 'male' ? base + 5 : base - 161;
    }

    function calculateTDEE(bmr: number, activity: ActivityLevel): number {
      return Math.round(bmr * ACTIVITY_MULTIPLIERS[activity]);
    }

    function getDailyGoal(tdee: number, goal: Goal, lossRate: number): { goal: number; clamped: boolean } {
      let daily: number;
      if (goal === 'lose') {
        daily = tdee - lossRate * 1000;
      } else if (goal === 'gain') {
        daily = tdee + 500;
      } else {
        daily = tdee;
      }
      const MIN = 1200;
      if (daily < MIN) return { goal: MIN, clamped: true };
      return { goal: Math.round(daily), clamped: false };
    }

    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    const fmt = new Intl.NumberFormat('th-TH', { maximumFractionDigits: 0 });
    const fmtDec = new Intl.NumberFormat('th-TH', { minimumFractionDigits: 1, maximumFractionDigits: 1 });

    function setText(id: string, text: string) {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    }

    // Goal select → show/hide loss rate row
    const goalSelect = document.getElementById('goal') as HTMLSelectElement;
    const lossRateRow = document.getElementById('loss-rate-row') as HTMLDivElement;

    function updateLossRateVisibility() {
      lossRateRow.classList.toggle('hidden', goalSelect.value !== 'lose');
    }
    goalSelect.addEventListener('change', updateLossRateVisibility);

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const age = parseNum((document.getElementById('age') as HTMLInputElement).value);
      const gender = (document.getElementById('gender') as HTMLSelectElement).value as Gender;
      const weight = parseNum((document.getElementById('weight') as HTMLInputElement).value);
      const height = parseNum((document.getElementById('height') as HTMLInputElement).value);
      const activity = (document.getElementById('activity') as HTMLSelectElement).value as ActivityLevel;
      const goal = goalSelect.value as Goal;
      const lossRate = parseFloat((document.getElementById('loss-rate') as HTMLSelectElement).value) || 0.5;

      if (age <= 0 || age > 120) { (document.getElementById('age') as HTMLInputElement).focus(); return; }
      if (weight <= 0 || weight > 300) { (document.getElementById('weight') as HTMLInputElement).focus(); return; }
      if (height <= 0 || height > 250) { (document.getElementById('height') as HTMLInputElement).focus(); return; }

      const bmr = Math.round(calculateBMR(age, gender, weight, height));
      const tdee = calculateTDEE(bmr, activity);
      const { goal: dailyGoal, clamped } = getDailyGoal(tdee, goal, lossRate);

      const deficit = dailyGoal - tdee;
      // 1 kg = 7700 kcal
      const weeklyKgChange = (deficit * 7) / 7700;
      const monthlyKgChange = weeklyKgChange * 4;
      const threeMonthKgChange = weeklyKgChange * 12;

      setText('res-bmr', fmt.format(bmr));
      setText('res-tdee', fmt.format(tdee));
      setText('res-daily-goal', fmt.format(dailyGoal));
      setText('res-weekly', fmt.format(Math.round(dailyGoal * 7)));
      setText('res-30d', fmtDec.format(weight + monthlyKgChange));
      setText('res-90d', fmtDec.format(weight + threeMonthKgChange));
      setText('res-monthly-change', (monthlyKgChange >= 0 ? '+' : '') + fmtDec.format(monthlyKgChange));

      // Deficit/surplus info box
      const deficitBox = document.getElementById('deficit-box') as HTMLElement;
      const deficitText = document.getElementById('deficit-text') as HTMLElement;
      if (goal === 'maintain') {
        deficitBox.className = 'rounded-lg p-4 mb-4 bg-green-50 border border-green-200';
        deficitText.textContent = 'กินตาม TDEE เพื่อรักษาน้ำหนักปัจจุบัน';
        deficitText.className = 'text-sm font-medium text-green-800';
      } else if (goal === 'lose') {
        deficitBox.className = 'rounded-lg p-4 mb-4 bg-blue-50 border border-blue-200';
        deficitText.textContent = `ขาดดุล ${fmt.format(Math.abs(deficit))} kcal/วัน → ลดน้ำหนัก ≈ ${fmtDec.format(Math.abs(weeklyKgChange))} กก./สัปดาห์`;
        deficitText.className = 'text-sm font-medium text-blue-800';
      } else {
        deficitBox.className = 'rounded-lg p-4 mb-4 bg-orange-50 border border-orange-200';
        deficitText.textContent = `เกินดุล ${fmt.format(deficit)} kcal/วัน → เพิ่มน้ำหนัก ≈ ${fmtDec.format(weeklyKgChange)} กก./สัปดาห์`;
        deficitText.className = 'text-sm font-medium text-orange-800';
      }

      // Show/hide clamped warning
      const minWarn = document.getElementById('min-warning') as HTMLElement;
      minWarn.classList.toggle('hidden', !clamped);

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('calorie');
    });

    // Enter key support
    ['age', 'weight', 'height'].forEach((id) => {
      (document.getElementById(id) as HTMLInputElement).addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });

    // Track result viewport
    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('calorie');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(document.getElementById('result')!);

    // ---- Thai Food Table ----
    interface ThaiFood {
      name: string;
      nameEn: string;
      unit: string;
      calories: number;
      protein: number;
      carbs: number;
      fat: number;
    }

    const thaiFoods: ThaiFood[] = [
      { name: 'ข้าวสวย', nameEn: 'Steamed white rice', unit: 'ชาม', calories: 206, protein: 4, carbs: 45, fat: 0.3 },
      { name: 'ข้าวกล้อง', nameEn: 'Brown rice', unit: 'ชาม', calories: 215, protein: 5, carbs: 45, fat: 2 },
      { name: 'ข้าวเหนียว', nameEn: 'Sticky rice', unit: 'ชาม', calories: 216, protein: 4, carbs: 48, fat: 0.3 },
      { name: 'ผัดไทย', nameEn: 'Pad Thai', unit: 'จาน', calories: 358, protein: 13, carbs: 45, fat: 14 },
      { name: 'กะเพราหมูสับ', nameEn: 'Pork basil stir-fry', unit: 'จาน', calories: 245, protein: 22, carbs: 8, fat: 14 },
      { name: 'ต้มยำกุ้ง', nameEn: 'Tom yam goong', unit: 'ชาม', calories: 140, protein: 18, carbs: 12, fat: 2 },
      { name: 'แกงเขียวหวาน', nameEn: 'Green curry', unit: 'ชาม', calories: 300, protein: 20, carbs: 14, fat: 20 },
      { name: 'ไก่ต้มเกลือ', nameEn: 'Boiled chicken', unit: '100g', calories: 165, protein: 31, carbs: 0, fat: 3.6 },
      { name: 'โจ๊กไก่', nameEn: 'Chicken congee', unit: 'ชาม', calories: 180, protein: 12, carbs: 28, fat: 2 },
      { name: 'ลาบหมู', nameEn: 'Pork larb', unit: 'จาน', calories: 180, protein: 24, carbs: 5, fat: 8 },
      { name: 'ต้มจืดหมูกระดูก', nameEn: 'Clear pork soup', unit: 'ชาม', calories: 120, protein: 14, carbs: 8, fat: 3 },
      { name: 'ชาไทย', nameEn: 'Thai iced tea', unit: 'แก้ว', calories: 150, protein: 1, carbs: 30, fat: 2 },
      { name: 'กาแฟสด', nameEn: 'Black coffee', unit: 'แก้ว', calories: 2, protein: 0, carbs: 0, fat: 0 },
      { name: 'นมสด', nameEn: 'Fresh milk', unit: 'แก้ว', calories: 161, protein: 8, carbs: 12, fat: 9 },
    ];

    const tbody = document.getElementById('food-table-body') as HTMLTableSectionElement;
    thaiFoods.forEach((food, i) => {
      const tr = document.createElement('tr');
      tr.className = i % 2 === 0 ? 'border-b border-gray-100' : 'border-b border-gray-100 bg-gray-50';
      tr.innerHTML = `
        <td class="py-2 px-3 font-medium">${food.name}</td>
        <td class="py-2 px-3 text-gray-500">${food.unit}</td>
        <td class="py-2 px-3 text-right font-semibold">${food.calories}</td>
        <td class="py-2 px-3 text-right hidden sm:table-cell text-gray-600">${food.protein}</td>
        <td class="py-2 px-3 text-right hidden sm:table-cell text-gray-600">${food.carbs}</td>
        <td class="py-2 px-3 text-right hidden sm:table-cell text-gray-600">${food.fat}</td>
      `;
      tbody.appendChild(tr);
    });
  </script>
</BaseLayout>
