---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าเสื่อมราคา | Kamnuanlek';
const pageDescription = 'คำนวณค่าเสื่อมราคาสินทรัพย์ถาวร แบบเส้นตรง Straight-Line อัตรากรมสรรพากรไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0468-ค่าเสื่อมราคา/`;
const faqData = [
  { question: 'อัตราค่าเสื่อมราคาตามกฎหมายไทยเท่าไหร่?', answer: 'อาคาร 5% ต่อปี เครื่องจักร 20% ต่อปี คอมพิวเตอร์/ซอฟต์แวร์ 33% ต่อปี รถยนต์ 20% ต่อปี เฟอร์นิเจอร์ 10% ต่อปี ตามประกาศกรมสรรพากร' },
  { question: 'วิธีคำนวณค่าเสื่อมราคาแบบเส้นตรงคืออะไร?', answer: 'ค่าเสื่อมราคาต่อปี = (ราคาต้นทุน - มูลค่าซาก) ÷ อายุใช้งาน เช่น เครื่องจักรราคา 500,000 บาท อายุ 5 ปี มูลค่าซาก 50,000 บาท ค่าเสื่อม = 90,000 บาท/ปี' },
  { question: 'ค่าเสื่อมราคามีผลต่อภาษีอย่างไร?', answer: 'ค่าเสื่อมราคาเป็นรายจ่ายที่หักได้ตามกฎหมายภาษี ลดกำไรทางบัญชีและกำไรสุทธิก่อนภาษี ทำให้ภาษีนิติบุคคลที่ต้องจ่ายน้อยลง' },
  { question: 'สินทรัพย์ที่คิดค่าเสื่อมได้มีอะไรบ้าง?', answer: 'สินทรัพย์ที่คิดค่าเสื่อมได้ ได้แก่ อาคาร เครื่องจักร ยานพาหนะ เฟอร์นิเจอร์ คอมพิวเตอร์ แต่ที่ดินไม่คิดค่าเสื่อมราคา' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเสื่อมราคา">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเสื่อมราคาสินทรัพย์</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าเสื่อมราคาสินทรัพย์ถาวรแบบเส้นตรง</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="asset_cost" class="block text-sm font-medium text-gray-700 mb-1">ราคาต้นทุนสินทรัพย์ (บาท)</label><input type="text" id="asset_cost" inputmode="decimal" placeholder="เช่น 500000" value="500000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="salvage_value" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าซาก (บาท)</label><input type="text" id="salvage_value" inputmode="decimal" placeholder="เช่น 50000" value="50000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="useful_life" class="block text-sm font-medium text-gray-700 mb-1">อายุใช้งาน (ปี)</label><input type="number" id="useful_life" min="1" max="40" placeholder="เช่น 5" value="5" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ค่าเสื่อมราคาต่อปี</p><p id="annual_dep" class="font-bold">-</p></div>
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ค่าเสื่อมราคาต่อเดือน</p><p id="monthly_dep" class="font-bold">-</p></div>
          <div class="bg-indigo-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">อัตราค่าเสื่อมต่อปี</p><p id="dep_rate" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const cost = parseFloat((document.getElementById('asset_cost') as HTMLInputElement).value) || 0;
      const salvage = parseFloat((document.getElementById('salvage_value') as HTMLInputElement).value) || 0;
      const life = parseInt((document.getElementById('useful_life') as HTMLInputElement).value) || 1;
      const annualDep = (cost - salvage) / life;
      const monthlyDep = annualDep / 12;
      const depRate = cost > 0 ? (annualDep / cost * 100) : 0;
      (document.getElementById('annual_dep') as HTMLElement).textContent = Math.round(annualDep).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('monthly_dep') as HTMLElement).textContent = Math.round(monthlyDep).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('dep_rate') as HTMLElement).textContent = depRate.toFixed(2) + '% ต่อปี';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('asset-depreciation');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
