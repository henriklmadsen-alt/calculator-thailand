---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนการปลูกมันสำปะหลัง 2569 | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการปลูกมันสำปะหลัง เตรียมพื้นที่ เมล็ด ปุ๋ย ยา แรงงาน ผลผลิต กำไร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุนมันสำปะหลัง/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนมันสำปะหลัง">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนการปลูกมันสำปะหลัง</h1>
    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2">
      <p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p>
    </div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนการปลูกมันสำปะหลังต่อไร่ เตรียมพื้นที่ เมล็ด ปุ๋ย ยา แรงงาน ผลผลิตและกำไร</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div>
          <label for="raiSize" class="block text-sm font-medium text-gray-700 mb-1">ขนาดพื้นที่ (ไร่)</label>
          <input type="text" id="raiSize" inputmode="decimal" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div class="flex items-center">
          <input type="checkbox" id="irrigated" checked class="h-4 w-4 border-gray-300 text-primary-600" />
          <label for="irrigated" class="ml-2 text-sm text-gray-700">มีระบบชลประทาน</label>
        </div>
        <div class="flex items-center">
          <input type="checkbox" id="hireLabor" class="h-4 w-4 border-gray-300 text-primary-600" />
          <label for="hireLabor" class="ml-2 text-sm text-gray-700">จ้างแรงงาน</label>
        </div>
      </div>
      <button type="button" id="btn-calc" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700">คำนวณต้นทุน</button>
      <div id="result" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-2"><p class="text-xs text-gray-600">ต้นทุนรวม</p><p id="total-cost" class="text-lg font-bold">-</p></div>
          <div class="bg-green-50 rounded p-2"><p class="text-xs text-gray-600">ผลผลิต</p><p id="yield" class="text-lg font-bold">-</p></div>
          <div class="bg-green-50 rounded p-2"><p class="text-xs text-gray-600">รายได้</p><p id="income" class="text-lg font-bold">-</p></div>
          <div class="bg-green-50 rounded p-2"><p class="text-xs text-gray-600">กำไร</p><p id="profit" class="text-lg font-bold">-</p></div>
        </div>
      </div>
    </div>
  </article>

  <script>
    function fmt(n: number) { return new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n); }
    document.getElementById('btn-calc')!.addEventListener('click', () => {
      const rai = parseFloat((document.getElementById('raiSize') as HTMLInputElement).value) || 0;
      if (rai <= 0) return;
      const base = rai * 12000, water = (document.getElementById('irrigated') as HTMLInputElement).checked ? rai * 500 : 0, labor = (document.getElementById('hireLabor') as HTMLInputElement).checked ? rai * 3000 : 0;
      const total = base + water + labor, yield_ = rai * 4000, income = yield_ * 3.5, profit = income - total;
      (document.getElementById('total-cost') as HTMLElement).textContent = fmt(total);
      (document.getElementById('yield') as HTMLElement).textContent = Math.round(yield_).toLocaleString('th-TH') + ' กก.';
      (document.getElementById('income') as HTMLElement).textContent = fmt(income);
      (document.getElementById('profit') as HTMLElement).textContent = fmt(profit);
      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('cassava-farming');
    });
    document.getElementById('btn-calc')!.click();
  </script>
</BaseLayout>
