---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณมูลค่าอนาคต Future Value ฟรี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณมูลค่าอนาคต (Future Value) เงินก้อน Lump Sum และเงินฝากสม่ำเสมอ Annuity วางแผนการออมและการลงทุนระยะยาว ฟรีทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-มูลค่าอนาคต-future-value/`;

const faqData = [
  {
    question: 'มูลค่าอนาคต (Future Value) คืออะไร?',
    answer: 'มูลค่าอนาคต (FV) คือมูลค่าของเงินในอนาคต หลังจากได้รับดอกเบี้ยหรือผลตอบแทนสะสมตามระยะเวลาที่กำหนด ใช้วางแผนว่าเงินที่มีหรือฝากสม่ำเสมอในวันนี้จะเติบโตเป็นเท่าไรเมื่อถึงเป้าหมาย เช่น เกษียณอายุ',
  },
  {
    question: 'FV เงินก้อน (Lump Sum) ต่างจาก Annuity อย่างไร?',
    answer: 'FV เงินก้อน: ลงทุนครั้งเดียวแล้วทิ้งไว้ สูตร: FV = PV × (1+r)^n. FV Annuity: ฝากสม่ำเสมอทุกงวด เช่น เดือนละ 5,000 บาท สูตร: FV = PMT × [((1+r)^n − 1) ÷ r] Annuity เหมาะกับการออมสม่ำเสมอ เช่น กองทุนสำรองเลี้ยงชีพ RMF SSF',
  },
  {
    question: 'จะต้องออมเดือนละเท่าไรเพื่อเกษียณด้วย 10 ล้านบาท?',
    answer: 'ใช้สูตร FV Annuity กลับด้าน: PMT = FV × r ÷ ((1+r)^n − 1) เช่น ต้องการ 10M ในอีก 30 ปี ผลตอบแทน 8%/ปี (รายเดือน r=0.6667%): PMT = 10,000,000 × 0.006667 ÷ ((1.006667)^360 − 1) ≈ 8,827 บาท/เดือน',
  },
  {
    question: 'ผลของอัตราดอกเบี้ยต่อมูลค่าอนาคต',
    answer: 'อัตราดอกเบี้ยมีผลอย่างมากต่อมูลค่าอนาคตในระยะยาว เช่น ออม 1,000 บาท/เดือน เป็นเวลา 30 ปี: ที่ 5%/ปี → 834,813 บาท, ที่ 8%/ปี → 1,490,359 บาท, ที่ 10%/ปี → 2,260,488 บาท ความแตกต่างของอัตราดอกเบี้ยเพียง 2-3% ส่งผลกว่าเท่าตัวในระยะ 30 ปี',
  },
  {
    question: 'Annuity Due ต่างจาก Ordinary Annuity อย่างไร?',
    answer: 'Ordinary Annuity ฝากปลายงวด (เช่น สิ้นเดือน) ส่วน Annuity Due ฝากต้นงวด (เช่น ต้นเดือน) Annuity Due ให้ FV สูงกว่าเล็กน้อยเพราะเงินแต่ละงวดทบต้นได้หนึ่งงวดเพิ่ม: FV_Due = FV_Ordinary × (1+r) เครื่องคำนวณนี้ใช้ Ordinary Annuity',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณมูลค่าอนาคต Future Value',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณมูลค่าอนาคต (Future Value)',
  description: 'ขั้นตอนการคำนวณ FV สำหรับเงินก้อนและเงินฝากสม่ำเสมอ',
  step: [
    {
      '@type': 'HowToStep',
      name: 'เลือกโหมดการคำนวณ',
      text: 'เลือก "เงินก้อน (Lump Sum)" หากลงทุนครั้งเดียว หรือ "ฝากสม่ำเสมอ (Annuity)" หากออมทุกงวด',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกจำนวนเงิน',
      text: 'กรอก PV (เงินก้อนเริ่มต้น) หรือ PMT (เงินฝากต่องวด) เป็นบาท',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกอัตราผลตอบแทนและจำนวนงวด',
      text: 'กรอกอัตราดอกเบี้ยต่อปี% และจำนวนปี ระบบคำนวณทบต้นรายปี',
    },
    {
      '@type': 'HowToStep',
      name: 'อ่านผล FV',
      text: 'ระบบแสดงมูลค่าอนาคต เงินฝากรวม และดอกเบี้ยสะสม',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-มูลค่าอนาคต-future-value">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณมูลค่าอนาคต — Future Value</p>
      <p class="mt-1 text-sm text-slate-700">เงินก้อน (Lump Sum) และฝากสม่ำเสมอ (Annuity)</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณมูลค่าอนาคต (Future Value) เงินก้อนและฝากสม่ำเสมอ 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณมูลค่าอนาคตสำหรับทั้งการลงทุนเงินก้อนครั้งเดียวและการออมสม่ำเสมอทุกงวด วางแผนเป้าหมายการเงินระยะยาว
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'กองทุนบัวหลวง: คู่มือการออมเพื่อเกษียณ',
        'ธนาคารแห่งประเทศไทย: การออมของครัวเรือนไทย',
      ]}
      assumptions={[
        'Lump Sum: FV = PV × (1+r)^n',
        'Annuity: FV = PMT × [((1+r)^n − 1) ÷ r]',
        'ทบต้นรายปี, ฝากปลายงวด (Ordinary Annuity)',
      ]}
      references={[
        { label: 'ธนาคารแห่งประเทศไทย', href: 'https://www.bot.or.th' },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="fv-form" class="space-y-5">
        <p id="fv-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-2">โหมดการคำนวณ</legend>
          <div class="flex gap-4 flex-wrap">
            <label class="flex items-center gap-2">
              <input type="radio" name="fv-mode" value="lump" checked class="w-4 h-4 text-primary-600" />
              <span class="text-sm text-gray-700">เงินก้อน (Lump Sum)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="radio" name="fv-mode" value="annuity" class="w-4 h-4 text-primary-600" />
              <span class="text-sm text-gray-700">ฝากสม่ำเสมอ (Annuity)</span>
            </label>
          </div>
        </fieldset>

        <div id="fv-lump-group">
          <label for="fv-pv" class="block text-sm font-medium text-gray-700 mb-1">เงินต้น — Present Value (บาท)</label>
          <input type="text" id="fv-pv" inputmode="numeric" placeholder="เช่น 100,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>

        <div id="fv-annuity-group" class="hidden">
          <label for="fv-pmt" class="block text-sm font-medium text-gray-700 mb-1">เงินฝากต่องวด — PMT (บาท)</label>
          <input type="text" id="fv-pmt" inputmode="numeric" placeholder="เช่น 5,000 ต่อปี"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="fv-rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราผลตอบแทน (% ต่อปี)</label>
            <input type="text" id="fv-rate" inputmode="decimal" placeholder="เช่น 8"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="fv-periods" class="block text-sm font-medium text-gray-700 mb-1">จำนวนปี</label>
            <input type="text" id="fv-periods" inputmode="decimal" placeholder="เช่น 20"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
        </div>

        <button type="submit" id="fv-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณมูลค่าอนาคต
        </button>
      </form>
    </div>

    <div id="fv-results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-4">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">มูลค่าอนาคต (FV)</div>
            <div id="res-fv" class="text-2xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินฝากรวม</div>
            <div id="res-fv-deposited" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ย/กำไรสะสม</div>
            <div id="res-fv-interest" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#fv-results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรมูลค่าอนาคต</h2>
      <div class="bg-gray-50 rounded-lg p-4 my-4">
        <p class="font-semibold mb-1">เงินก้อน (Lump Sum):</p>
        <p class="text-sm">FV = PV × (1 + r)^n</p>
        <p class="font-semibold mt-3 mb-1">ฝากสม่ำเสมอ (Ordinary Annuity):</p>
        <p class="text-sm">FV = PMT × [((1+r)^n − 1) ÷ r]</p>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่าง: ออม 5,000 บาท/ปี อัตรา 8% เป็นเวลา 20 ปี</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>FV = 5,000 × [((1.08)^20 − 1) ÷ 0.08]</li>
          <li>= 5,000 × [(4.661 − 1) ÷ 0.08]</li>
          <li>= 5,000 × 45.762</li>
          <li><strong>= 228,810 บาท (ฝากรวม 100,000 บาท กำไร 128,810 บาท)</strong></li>
        </ul>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        <strong>แหล่งอ้างอิง:</strong>
        <a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">ธนาคารแห่งประเทศไทย</a>
      </p>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-มูลค่าอนาคต-future-value/" />
    <RelatedCalculators currentHref="/คำนวณ-มูลค่าอนาคต-future-value/" slugs={['คำนวณ-มูลค่าปัจจุบัน-present-value', 'คำนวณ-ดอกเบี้ยทบต้น', 'คำนวณ-cagr-อัตราเติบโตทบต้นรายปี']} />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ ผลตอบแทนจริงอาจแตกต่าง ไม่ถือเป็นคำแนะนำการลงทุน
    </div>
  </article>
</BaseLayout>

<script>
  function parseNum(v: string): number {
    return parseFloat(String(v).replace(/,/g, '').trim()) || 0;
  }
  function fmt(n: number): string {
    return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
  }

  const modeRadios = document.querySelectorAll('input[name="fv-mode"]');
  const lumpGroup = document.getElementById('fv-lump-group') as HTMLElement;
  const annuityGroup = document.getElementById('fv-annuity-group') as HTMLElement;

  modeRadios.forEach(radio => {
    radio.addEventListener('change', () => {
      const val = (document.querySelector('input[name="fv-mode"]:checked') as HTMLInputElement).value;
      if (val === 'annuity') {
        lumpGroup.classList.add('hidden');
        annuityGroup.classList.remove('hidden');
      } else {
        lumpGroup.classList.remove('hidden');
        annuityGroup.classList.add('hidden');
      }
    });
  });

  const form = document.getElementById('fv-form') as HTMLFormElement;
  const formError = document.getElementById('fv-form-error') as HTMLElement;
  const resultsDiv = document.getElementById('fv-results') as HTMLElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    formError.classList.add('hidden');

    const mode = (document.querySelector('input[name="fv-mode"]:checked') as HTMLInputElement).value;
    const r = parseNum((document.getElementById('fv-rate') as HTMLInputElement).value) / 100;
    const n = parseNum((document.getElementById('fv-periods') as HTMLInputElement).value);

    if (r <= 0 || n <= 0) {
      formError.classList.remove('hidden');
      formError.textContent = 'กรุณากรอกอัตราผลตอบแทนและจำนวนปีให้ถูกต้อง';
      return;
    }

    let fv = 0;
    let deposited = 0;

    if (mode === 'lump') {
      const pv = parseNum((document.getElementById('fv-pv') as HTMLInputElement).value);
      if (pv <= 0) {
        formError.classList.remove('hidden');
        formError.textContent = 'กรุณากรอกเงินต้นให้ถูกต้อง';
        return;
      }
      fv = pv * Math.pow(1 + r, n);
      deposited = pv;
    } else {
      const pmt = parseNum((document.getElementById('fv-pmt') as HTMLInputElement).value);
      if (pmt <= 0) {
        formError.classList.remove('hidden');
        formError.textContent = 'กรุณากรอกเงินฝากต่องวดให้ถูกต้อง';
        return;
      }
      fv = pmt * ((Math.pow(1 + r, n) - 1) / r);
      deposited = pmt * n;
    }

    const interest = fv - deposited;

    (document.getElementById('res-fv') as HTMLElement).textContent = fmt(fv) + ' บาท';
    (document.getElementById('res-fv-deposited') as HTMLElement).textContent = fmt(deposited) + ' บาท';
    (document.getElementById('res-fv-interest') as HTMLElement).textContent = fmt(interest) + ' บาท';

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
