---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าฟันขาว | Kamnuanlek';
const pageDescription = 'คำนวณค่าฟอกสีฟัน ค่าฟันขาว ค่า Veneer ค่า Zoom ตามอัตราคลินิกทันตกรรมไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0420-ค่าฟันขาว/`;

const faqData = [
  { question: 'ค่าฟอกสีฟัน Zoom ราคาเท่าไหร่?', answer: 'Zoom Whitening (ทำในคลินิก) ราคา 8,000-15,000 บาท ใช้เวลา 1-2 ชั่วโมง ผลขาวขึ้น 2-8 เฉด ทำซ้ำได้ทุก 1-2 ปี' },
  { question: 'ฟอกสีฟันที่บ้านราคาเท่าไหร่?', answer: 'ชุดฟอกสีฟันที่บ้าน (Home Whitening Kit) จากทันตแพทย์ 3,000-6,000 บาท ผลดีกว่าชุดตามร้านซึ่งราคา 500-1,500 บาท แต่ความเข้มข้นต่ำกว่า' },
  { question: 'Veneer ฟันคืออะไรและราคาเท่าไหร่?', answer: 'Veneer คือการติดแผ่นเซรามิกบางๆ ด้านหน้าฟัน ราคา 5,000-15,000 บาทต่อซี่ เหมาะกับฟันที่สีเหลืองถาวร หรือต้องการเปลี่ยนรูปร่าง' },
  { question: 'ฟอกสีฟันมีผลข้างเคียงไหม?', answer: 'ผลข้างเคียงที่พบบ่อยคืออาการเสียวฟันชั่วคราว 1-3 วันหลังการรักษา ไม่ควรทำบ่อยเกินไป และควรหลีกเลี่ยงอาหารสีเข้มใน 48 ชั่วโมงแรก' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าฟันขาว">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าฟันขาว</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าฟอกสีฟัน Veneer และการทำฟันขาว</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div>
          <label for="whitening_type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทการทำฟันขาว</label>
          <select id="whitening_type" class="w-full px-3 py-2 border border-gray-300 rounded-md">
            <option value="4000">Home Whitening Kit (ทำเอง) ~4,000 บาท</option>
            <option value="10000" selected>Zoom In-Office Whitening ~10,000 บาท</option>
            <option value="5000">Veneer ต่อซี่ ~5,000 บาท/ซี่</option>
          </select>
        </div>
        <div><label for="whitening_qty" class="block text-sm font-medium text-gray-700 mb-1">จำนวนซี่ (สำหรับ Veneer)</label><input type="number" id="whitening_qty" min="1" max="20" placeholder="เช่น 1" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="maintenance" class="block text-sm font-medium text-gray-700 mb-1">ค่าบำรุงรักษาต่อปี (บาท)</label><input type="text" id="maintenance" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าทำฟันขาว</p>
            <p id="whitening_cost" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมค่าใช้จ่ายปีแรก</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const whiteningRate = parseFloat((document.getElementById('whitening_type') as HTMLSelectElement).value) || 0;
      const qty = parseInt((document.getElementById('whitening_qty') as HTMLInputElement).value) || 1;
      const maintenance = parseFloat((document.getElementById('maintenance') as HTMLInputElement).value) || 0;

      const whiteningCost = whiteningRate * qty;
      const total = whiteningCost + maintenance;

      (document.getElementById('whitening_cost') as HTMLElement).textContent = whiteningCost.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('teeth-whitening-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
