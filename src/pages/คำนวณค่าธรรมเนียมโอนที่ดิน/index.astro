---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณค่าธรรมเนียมโอนที่ดิน 2569 | ค่าจดจำนอง | Kamnuanlek';
const pageDescription = 'คำนวณค่าจดทะเบียนโอนที่ดิน บ้าน ค่าจดจำนอง ตามอัตรา กรมที่ดิน อัปเดตปี 2569 ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าธรรมเนียมโอนที่ดิน/`;

const faqData = [
  {
    question: 'ค่าธรรมเนียมโอนมีกี่ประเภท?',
    answer: 'มี 2 ประเภท: (1) ค่าจดทะเบียนโอน = 2% ของราคาประเมิน (หรือ 0.01% หากเข้าเงื่อนไขมาตรการ) และ (2) ค่าจดจำนอง = 1% ของวงเงินกู้ (สูงสุด 200,000 บาท)',
  },
  {
    question: 'ใครต้องจ่ายค่าธรรมเนียมโอน?',
    answer: 'สามารถตกลงกันระหว่างผู้ซื้อและผู้ขายได้ แต่โดยปกติผู้ซื้อจ่ายค่าสรรพสามิต และผู้ขายจ่ายค่าจดทะเบียน',
  },
  {
    question: 'ใช้ราคาประเมินหรือราคาตลาด?',
    answer: 'ใช้ราคาประเมินทุนทรัพย์จากสำนักงานที่ดิน ซึ่งอาจแตกต่างจากราคาตลาด โดยทั่วไปต่ำกว่า',
  },
,
  { question: 'ค่าโอนบ้านปี 2569 คิดอัตราเท่าไร?', answer: 'ค่าธรรมเนียมโอน 2% ของราคาประเมิน (ลดเหลือ 1% สำหรับที่อยู่อาศัยราคาไม่เกิน 3 ล้าน จนถึง 31 ธ.ค. 2568), ค่าจดจำนอง 1% ของวงเงิน (ลดเหลือ 0.01% สำหรับกู้ไม่เกิน 3 ล้าน)' },
  { question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ต่างกันอย่างไร?', answer: 'ภาษีธุรกิจเฉพาะ 3.3% (ถือครองน้อยกว่า 5 ปีหรือไม่ได้มีชื่อในทะเบียนบ้าน) | อากรแสตมป์ 0.5% (ถือครอง 5 ปีขึ้นไปและมีชื่อในทะเบียนบ้านครบ 1 ปี) เสียอย่างใดอย่างหนึ่ง' },
  { question: 'ราคาประเมินกรมที่ดินกับราคาตลาดต่างกันอย่างไร?', answer: 'ราคาประเมินคือราคาที่กรมที่ดินกำหนดเพื่อใช้คิดค่าธรรมเนียม อัปเดตทุก 4 ปี มักต่ำกว่าราคาตลาด 20-50% ภาษีและค่าธรรมเนียมใช้ราคาประเมินหรือราคาซื้อขาย แล้วแต่อย่างไหนสูงกว่า' },
  { question: 'ซื้อบ้านมือสองต้องระวังค่าใช้จ่ายอะไร?', answer: 'ค่าธรรมเนียมโอน ค่าภาษีธุรกิจเฉพาะหรืออากรแสตมป์ ค่าจดจำนอง ค่าตรวจสอบภาระผูกพัน ค่าประเมินราคา ค่าซ่อมแซม และค่าประกันภัย รวมกันอาจสูงถึง 5-10% ของราคาซื้อ' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียมโอนที่ดิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าธรรมเนียมโอนที่ดิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-emerald-100 bg-emerald-50 p-4">
      <p class="text-sm font-semibold text-emerald-700">ค่าธรรมเนียมโอนที่ดิน</p>
      <p class="mt-1 text-sm text-slate-700">รวมค่าจดทะเบียนโอน + ค่าจดจำนอง ตามอัตราของ กรมที่ดิน</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณค่าธรรมเนียมโอนที่ดิน ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกราคาประเมินและวงเงินจำนอง ระบบจะคำนวณค่าจดทะเบียนโอนและค่าจดจำนอง
    </p>

    <PublicTrustPanel
      lastUpdated="20 เม.ย. 2569"
      sources={[
        'กรมที่ดิน: อัตราค่าจดทะเบียน 2569',
      ]}
      assumptions={[
        'ราคาประเมิน = ฐานคำนวณค่าจดทะเบียนโอน',
        'ค่าจดจำนอง = 1% (สูงสุด 200,000 บาท)',
      ]}
      references={[
        {
          label: 'กรมที่ดิน',
          href: 'https://www.dol.go.th/',
        },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="transfer-fee-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="appraised-value" class="block text-sm font-medium text-gray-700 mb-1">ราคาประเมิน (บาท)</label>
            <input id="appraised-value" type="text" inputmode="numeric" placeholder="เช่น 5,800,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="mortgage-amount" class="block text-sm font-medium text-gray-700 mb-1">วงเงินจำนอง (บาท)</label>
            <input id="mortgage-amount" type="text" inputmode="numeric" placeholder="เช่น 4,500,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณค่าธรรมเนียม
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 mb-6">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าจดทะเบียนโอน</div>
            <div id="res-transfer-fee" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าจดจำนอง</div>
            <div id="res-mortgage-fee" class="text-xl font-bold text-sky-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าจดทะเบียนโอน (2%)</span>
            <span id="res-calc-transfer" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าจดจำนอง (1%)</span>
            <span id="res-calc-mortgage" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">รวมค่าธรรมเนียม</span>
            <span id="res-total-fee" class="font-bold text-lg text-primary-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="mb-8 bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 prose prose-slate max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ค่าจดทะเบียนโอน = ราคาประเมิน × 2%</li>
        <li>ค่าจดจำนอง = วงเงินจำนอง × 1% (สูงสุด 200,000 บาท)</li>
        <li>รวมค่าธรรมเนียม = ค่าจดทะเบียนโอน + ค่าจดจำนอง</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <RelatedArticles currentHref="/คำนวณค่าธรรมเนียมโอนที่ดิน/" />
    <RelatedCalculators currentHref="/คำนวณค่าธรรมเนียมโอนที่ดิน/" />

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#transfer-fee-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const appraisedValue = parseNumber(document.querySelector('#appraised-value')?.value || '');
    const mortgageAmount = parseNumber(document.querySelector('#mortgage-amount')?.value || '0');

    if (!(Number.isFinite(appraisedValue) && appraisedValue > 0 && mortgageAmount >= 0)) {
      results?.classList.add('hidden');
      return;
    }

    const transferFee = appraisedValue * 0.02;
    const mortgageFee = Math.min(mortgageAmount * 0.01, 200000);
    const totalFee = transferFee + mortgageFee;

    document.querySelector('#res-transfer-fee').textContent = formatCurrency(transferFee);
    document.querySelector('#res-mortgage-fee').textContent = formatCurrency(mortgageFee);
    document.querySelector('#res-calc-transfer').textContent = formatCurrency(transferFee);
    document.querySelector('#res-calc-mortgage').textContent = formatCurrency(mortgageFee);
    document.querySelector('#res-total-fee').textContent = formatCurrency(totalFee);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
