---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'ธุรกิจขนาดเล็กต้องจดทะเบียน VAT ไหม?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ต้องจดทะเบียน VAT เมื่อรายได้เกิน 1.8 ล้านบาทต่อปี ถ้ารายได้ต่ำกว่านี้ไม่จำเป็นต้องจด แต่สามารถจดทะเบียนโดยสมัครใจได้'
      }
    },
    {
      '@type': 'Question',
      name: 'ภาษีเงินได้นิติบุคคลคิดอัตราเท่าไหร่?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'SME ที่มีทุนจดทะเบียนไม่เกิน 5 ล้านบาท: 15% บนกำไรสุทธิ 300,000-3,000,000 บาท และ 20% บนกำไรเกิน 3 ล้านบาท บริษัทขนาดใหญ่: 20% flat rate'
      }
    },
    {
      '@type': 'Question',
      name: 'SME ไทยมีสิทธิประโยชน์ภาษีอะไรบ้าง?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'SME ได้รับ: อัตราภาษีพิเศษ 15% สำหรับกำไรสุทธิ 300,000-3,000,000 บาท, ยกเว้นภาษีกำไรสุทธิ 300,000 บาทแรก, และสิทธิหักค่าเสื่อมเร็วกว่าปกติ'
      }
    }
  ]
};
---

<BaseLayout
  title="ภาษีธุรกิจขนาดเล็ก SME — อัตราภาษี VAT ภาษีนิติบุคคล ปี 2569 | Kamnuanlek"
  description="คู่มือภาษีธุรกิจขนาดเล็กและ SME ไทย อัตราภาษีนิติบุคคล เกณฑ์จดทะเบียน VAT ภาษีหัก ณ ที่จ่าย และค่าใช้จ่ายที่หักได้ อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "ภาษีธุรกิจขนาดเล็ก SME — อัตราภาษี VAT ภาษีนิติบุคคล ปี 2569", "item": "https://www.kamnuanlek.com/ภาษีธุรกิจขนาดเล็ก/"}
    ]
  }</script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">คู่มือภาษีธุรกิจขนาดเล็ก SME ปี 2569</h1>

    <div class="mb-12 p-6 bg-blue-50 border border-blue-200 rounded-lg">
      <p class="text-lg text-gray-800">
        ดำเนินธุรกิจขนาดเล็กในไทย? คู่มือนี้ครอบคลุมภาษีทุกประเภทที่คุณต้องรู้ ภาษีเงินได้นิติบุคคล VAT ภาษีหัก ณ ที่จ่าย และสิทธิประโยชน์ SME ที่มีอยู่
      </p>
    </div>

    <div class="space-y-10">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">อัตราภาษีนิติบุคคล SME (ปี 2569)</h2>
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-gradient-to-r from-primary-600 to-primary-700 text-white">
              <tr>
                <th class="text-left px-4 py-3">กำไรสุทธิ (บาท)</th>
                <th class="text-left px-4 py-3">อัตราภาษี</th>
                <th class="text-left px-4 py-3">ใช้กับ</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t">
                <td class="px-4 py-3 text-gray-900">300,000 บาทแรก</td>
                <td class="px-4 py-3 font-bold text-green-600">ยกเว้น (0%)</td>
                <td class="px-4 py-3 text-gray-600">เฉพาะ SME</td>
              </tr>
              <tr class="border-t bg-gray-50">
                <td class="px-4 py-3 text-gray-900">300,001 – 3,000,000</td>
                <td class="px-4 py-3 font-bold text-blue-600">15%</td>
                <td class="px-4 py-3 text-gray-600">SME (ทุนจดทะเบียน ≤5 ล้านบาท)</td>
              </tr>
              <tr class="border-t">
                <td class="px-4 py-3 text-gray-900">เกิน 3,000,000</td>
                <td class="px-4 py-3 font-bold text-orange-600">20%</td>
                <td class="px-4 py-3 text-gray-600">บริษัททุกขนาด</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-gray-600 text-sm mt-2">* SME = บริษัทที่มีทุนจดทะเบียน ≤ 5 ล้านบาท และรายได้ประจำปี ≤ 30 ล้านบาท</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">ภาษีธุรกิจที่สำคัญ</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="text-lg font-bold text-gray-900 mb-2">VAT (7%)</h3>
            <p class="text-gray-700 text-sm mb-2">จดทะเบียนเมื่อรายได้ประจำปีเกิน 1.8 ล้านบาท เก็บ VAT จากการขาย และขอคืน VAT จากการซื้อได้</p>
            <a href="/คำนวณมูลค่าเพิ่ม/" class="text-primary-600 text-sm font-medium hover:underline">เครื่องคำนวณ VAT →</a>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="text-lg font-bold text-gray-900 mb-2">ภาษีหัก ณ ที่จ่าย</h3>
            <p class="text-gray-700 text-sm mb-2">หัก 3-5% จากการจ่ายเงินค่าบริการเกิน 1,000 บาท นำส่งกรมสรรพากรทุกเดือน</p>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="text-lg font-bold text-gray-900 mb-2">ประกันสังคม</h3>
            <p class="text-gray-700 text-sm mb-2">นายจ้างจ่าย 5% ของเงินเดือนพนักงานแต่ละคน (สูงสุด 750 บาท/คน/เดือน) ยื่นรายเดือนกับสำนักงานประกันสังคม</p>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="text-lg font-bold text-gray-900 mb-2">การยื่นประจำปี</h3>
            <p class="text-gray-700 text-sm mb-2">ยื่นแบบภาษีนิติบุคคลภายใน 150 วันหลังสิ้นรอบบัญชี ชำระภาษีล่วงหน้าครึ่งปีภายใน 31 สิงหาคม</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">ธุรกิจขนาดเล็กต้องจดทะเบียน VAT ไหม?</h3>
            <p class="text-gray-700 text-sm">ต้องจดทะเบียน VAT เมื่อรายได้เกิน 1.8 ล้านบาทต่อปี ถ้าต่ำกว่านี้ไม่จำเป็น แต่จดสมัครใจได้</p>
          </div>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">ภาษีเงินได้นิติบุคคลคิดอัตราเท่าไหร่?</h3>
            <p class="text-gray-700 text-sm">SME (ทุนจดทะเบียน ≤ 5 ล้านบาท): ยกเว้นกำไร 300k แรก, 15% บน 300k-3M, 20% บนส่วนเกิน</p>
          </div>
          <div class="p-4 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-semibold text-gray-900 mb-2">SME ไทยมีสิทธิประโยชน์ภาษีอะไรบ้าง?</h3>
            <p class="text-gray-700 text-sm">อัตราภาษีพิเศษ 15%, ยกเว้นกำไร 300,000 บาทแรก, หักค่าเสื่อมเร็ว, หักค่าฝึกอบรมพนักงาน 200%</p>
          </div>
        </div>
      </section>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องคำนวณธุรกิจ</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/เครื่องคำนวณธุรกิจ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 วิเคราะห์ธุรกิจ</span>
          <p class="text-gray-600 text-sm mt-2">จุดคุ้มทุน ROE ROA WACC</p>
        </a>
        <a href="/เปรียบเทียบเครื่องคำนวณภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💼 เปรียบเทียบภาษี</span>
          <p class="text-gray-600 text-sm mt-2">ภาษีนิติบุคคล vs VAT vs ภาษีหัก ณ ที่จ่าย</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 ศูนย์รวมการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">เครื่องคำนวณการเงินทุกประเภท</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
