---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ ROI Email Marketing 2569 | Kamnuanlek';
const pageDescription = 'คำนวณ ROI จากการทำ Email Marketing ประเมิน Open Rate, Click Rate และความสามารถในการทำกำไร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-roi-email-marketing/`;

const faqData = [
  {
    question: 'Email Marketing ROI คิดอย่างไร?',
    answer: 'ROI = (ยอดขาย - ค่า Email Platform) ÷ ค่า × 100 Email ถูกที่สุด ค่า Email Platform 0-500 บาท/เดือน ROI ส่วนใหญ่ 30:1 หรือมากกว่า ทำให้เป็นช่องทางที่คุ้มค่าที่สุด',
  },
  {
    question: 'Open Rate และ Click Rate ควรเป็นเท่าไร?',
    answer: 'Open Rate ทั่วไป 15-25% Click Rate 2-5% ถ้าต่ำกว่านี้ ต้องปรับปรุง Subject Line, Content, CTA E-commerce อาจต่ำกว่า (10-15%) B2B อาจสูงกว่า (25-40%)',
  },
  {
    question: 'ประเภท Email Marketing ไหนได้ ROI ดีที่สุด?',
    answer: 'Welcome Series คนใหม่ได้ 30-40% กำไร, Abandoned Cart 20-30%, Product Recommendation 15-25%, Newsletter 5-10% Segmentation สำคัญ ส่ง Email ตามพฤติกรรมลูกค้า',
  },
  {
    question: 'วิธีปรับปรุง Email ROI?',
    answer: 'Subject Line: ทำให้สนใจ Test หลายแบบ Personalization: ใช้ชื่อ ส่วนตัว Segment: ส่ง Email ตามหมวด CTA: ชัดเจน สร้าง Urgency Timing: ส่งเมื่อไร ได้ Open สูงสุด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ ROI Email Marketing',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ ROI Email Marketing">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      📧 คำนวณ ROI Email Marketing
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณ ROI จากการทำ Email Marketing
      ประเมิน Open Rate, Click Rate และความสามารถในการทำกำไร
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="email-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="email-list" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวน Email List
            </label>
            <input
              type="text"
              id="email-list"
              inputmode="numeric"
              placeholder="เช่น 5000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="open-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Open Rate (%)
            </label>
            <input
              type="text"
              id="open-rate"
              inputmode="numeric"
              placeholder="เช่น 20"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="click-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Click Rate (%)
            </label>
            <input
              type="text"
              id="click-rate"
              inputmode="numeric"
              placeholder="เช่น 3"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="conversion-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Conversion Rate (%)
            </label>
            <input
              type="text"
              id="conversion-rate"
              inputmode="numeric"
              placeholder="เช่น 5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="avg-value" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Conversion เฉลี่ย (บาท)
            </label>
            <input
              type="text"
              id="avg-value"
              inputmode="numeric"
              placeholder="เช่น 1000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="platform-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Platform/เดือน (บาท)
              <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
            </label>
            <input
              type="text"
              id="platform-cost"
              inputmode="numeric"
              placeholder="เช่น 0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ ROI
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ ROI Email</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รายได้</div>
            <div id="res-revenue" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ต้นทุน</div>
            <div id="res-cost" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">กำไร</div>
            <div id="res-profit" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ROI %</div>
            <div id="res-roi" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">Email List</span>
            <span id="res-list" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">Clicks</span>
            <span id="res-clicks" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">Conversions</span>
            <span id="res-conversions" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">Cost per Conversion</span>
            <span id="res-cpc" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">Email Marketing: ROI สูงสุด ต้นทุนต่ำสุด</h2>

      <p>
        Email Marketing มี ROI สูงสุด (30:1 ขึ้นไป) และต้นทุนต่ำที่สุดในการตลาดดิจิทัล
        ลูกค้ามีประสิทธิภาพของอีเมลสูงกว่า Social Media Ads
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณ-roi-email-marketing/" />
    <RelatedCalculators currentHref="/คำนวณ-roi-email-marketing/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ ขึ้นอยู่กับคุณภาพ List และเนื้อหา
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('email-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const emailList = parseNum((document.getElementById('email-list') as HTMLInputElement).value);
      const openRate = parseNum((document.getElementById('open-rate') as HTMLInputElement).value);
      const clickRate = parseNum((document.getElementById('click-rate') as HTMLInputElement).value);
      const conversionRate = parseNum((document.getElementById('conversion-rate') as HTMLInputElement).value);
      const avgValue = parseNum((document.getElementById('avg-value') as HTMLInputElement).value);
      const platformCost = parseNum((document.getElementById('platform-cost') as HTMLInputElement).value);

      if (emailList <= 0) { (document.getElementById('email-list') as HTMLInputElement).focus(); return; }
      if (openRate <= 0) { (document.getElementById('open-rate') as HTMLInputElement).focus(); return; }
      if (clickRate <= 0) { (document.getElementById('click-rate') as HTMLInputElement).focus(); return; }
      if (conversionRate <= 0) { (document.getElementById('conversion-rate') as HTMLInputElement).focus(); return; }
      if (avgValue <= 0) { (document.getElementById('avg-value') as HTMLInputElement).focus(); return; }

      const opens = (emailList * openRate) / 100;
      const clicks = (opens * clickRate) / 100;
      const conversions = (clicks * conversionRate) / 100;
      const revenue = conversions * avgValue;
      const profit = revenue - platformCost;
      const roi = platformCost > 0 ? (profit / platformCost) * 100 : revenue > 0 ? 10000 : 0;
      const cpc = conversions > 0 ? platformCost / conversions : 0;

      (document.getElementById('res-revenue') as HTMLElement).textContent = fmt(revenue) + ' บาท';
      (document.getElementById('res-cost') as HTMLElement).textContent = fmt(platformCost) + ' บาท';
      (document.getElementById('res-profit') as HTMLElement).textContent = fmt(profit) + ' บาท';
      (document.getElementById('res-roi') as HTMLElement).textContent = roi > 1000 ? 'N/A' : roi.toFixed(0) + '%';
      (document.getElementById('res-list') as HTMLElement).textContent = emailList.toFixed(0);
      (document.getElementById('res-clicks') as HTMLElement).textContent = clicks.toFixed(0);
      (document.getElementById('res-conversions') as HTMLElement).textContent = conversions.toFixed(0);
      (document.getElementById('res-cpc') as HTMLElement).textContent = fmt(cpc) + ' บาท';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('email-marketing-roi');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('email-marketing-roi');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
