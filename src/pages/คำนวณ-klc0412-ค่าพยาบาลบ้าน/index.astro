---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าพยาบาลที่บ้าน | Kamnuanlek';
const pageDescription = 'คำนวณค่าพยาบาลที่บ้าน Home Nursing ค่าดูแลผู้ป่วย ผู้สูงอายุที่บ้าน ตามอัตราไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0412-ค่าพยาบาลบ้าน/`;

const faqData = [
  { question: 'ค่าพยาบาลที่บ้านต่อวันเท่าไหร่?', answer: 'ค่าพยาบาลวิชาชีพที่บ้าน 800-2,000 บาทต่อวัน ผู้ดูแล (Caregiver) 400-800 บาทต่อวัน ขึ้นอยู่กับระดับทักษะและชั่วโมงดูแล' },
  { question: 'ดูแลผู้ป่วยที่บ้านดีกว่าโรงพยาบาลไหม?', answer: 'ขึ้นอยู่กับสภาพผู้ป่วย อาการเรื้อรังที่ไม่รุนแรง ดูแลที่บ้านอาจดีกว่าทั้งใจและค่าใช้จ่าย แต่อาการหนักต้องโรงพยาบาล' },
  { question: 'จ้างผู้ดูแลผู้สูงอายุเต็มเวลาเดือนละเท่าไหร่?', answer: 'ผู้ดูแลอยู่ประจำ 12,000-20,000 บาทต่อเดือน รวมค่าอาหารและที่พัก ผู้ดูแลมาเช้า-เย็น 8,000-15,000 บาทต่อเดือน' },
  { question: 'บริการพยาบาลที่บ้านมีอะไรบ้าง?', answer: 'บริการพยาบาลที่บ้าน ได้แก่ ทำแผล ให้ยา กายภาพบำบัด ดูแลสาย NG tube สายสวนปัสสาวะ เจาะเลือด ตรวจสุขภาพพื้นฐาน' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าพยาบาลที่บ้าน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าพยาบาลที่บ้าน</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าใช้จ่ายการดูแลผู้ป่วยหรือผู้สูงอายุที่บ้าน</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div>
          <label for="nurse_type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทผู้ดูแล</label>
          <select id="nurse_type" class="w-full px-3 py-2 border border-gray-300 rounded-md">
            <option value="600">ผู้ดูแล (Caregiver) ~600 บาท/วัน</option>
            <option value="1200" selected>พยาบาลวิชาชีพ ~1,200 บาท/วัน</option>
            <option value="2000">พยาบาลเฉพาะทาง ~2,000 บาท/วัน</option>
          </select>
        </div>
        <div><label for="care_days" class="block text-sm font-medium text-gray-700 mb-1">จำนวนวันดูแลต่อเดือน</label><input type="number" id="care_days" min="1" max="31" placeholder="เช่น 30" value="30" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="medical_supplies" class="block text-sm font-medium text-gray-700 mb-1">ค่าอุปกรณ์การแพทย์ต่อเดือน (บาท)</label><input type="text" id="medical_supplies" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="months_care" class="block text-sm font-medium text-gray-700 mb-1">จำนวนเดือนที่ต้องดูแล</label><input type="number" id="months_care" min="1" max="60" placeholder="เช่น 6" value="6" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อเดือน</p>
            <p id="monthly_care" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมค่าดูแลทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const nurseRate = parseFloat((document.getElementById('nurse_type') as HTMLSelectElement).value) || 0;
      const careDays = parseInt((document.getElementById('care_days') as HTMLInputElement).value) || 30;
      const supplies = parseFloat((document.getElementById('medical_supplies') as HTMLInputElement).value) || 0;
      const months = parseInt((document.getElementById('months_care') as HTMLInputElement).value) || 1;

      const monthlyCare = (nurseRate * careDays) + supplies;
      const total = monthlyCare * months;

      (document.getElementById('monthly_care') as HTMLElement).textContent = monthlyCare.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('home-nursing-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
