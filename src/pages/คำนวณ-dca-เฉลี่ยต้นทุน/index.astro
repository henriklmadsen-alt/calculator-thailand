---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ DCA เฉลี่ยต้นทุน 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณกลยุทธ์ DCA ซื้อกองทุนสม่ำเสมอ 2569 ฟรี — รู้ต้นทุนเฉลี่ยและมูลค่าพอร์ตเมื่อลงทุนรายเดือน เปรียบเทียบกับลงทุนก้อนเดียว';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-dca-เฉลี่ยต้นทุน/`;

const faqData = [
  {
    question: 'DCA (Dollar-Cost Averaging) คืออะไร?',
    answer: 'DCA คือกลยุทธ์การลงทุนด้วยเงินจำนวนคงที่สม่ำเสมอทุกงวด เช่น ทุกเดือน โดยไม่สนใจราคาตลาด เมื่อราคาสูงจะได้หน่วยน้อย เมื่อราคาต่ำจะได้หน่วยมากขึ้น ทำให้ต้นทุนเฉลี่ยต่ำกว่าการซื้อครั้งเดียวในราคาสูง',
  },
  {
    question: 'DCA เหมาะกับการลงทุนในอะไรบ้าง?',
    answer: 'DCA เหมาะกับสินทรัพย์ที่มีความผันผวนและเติบโตในระยะยาว เช่น กองทุนรวมหุ้น กองทุนดัชนี (Index Fund) หุ้นรายตัว และคริปโตเคอเรนซี ไม่เหมาะกับเงินฝากประจำที่ราคาไม่ผันผวน',
  },
  {
    question: 'DCA กับการลงทุนก้อนเดียว (Lump Sum) อะไรดีกว่า?',
    answer: 'ในตลาดที่เติบโตระยะยาว การลงทุนก้อนเดียวมักให้ผลตอบแทนสูงกว่า DCA เพราะเงินทั้งหมดทำงานตั้งแต่ต้น แต่ DCA ลดความเสี่ยงด้านจิตวิทยาและเหมาะกับผู้มีรายได้สม่ำเสมอที่ไม่มีเงินก้อนใหญ่',
  },
  {
    question: 'ควรทำ DCA กี่ปีจึงจะเห็นผล?',
    answer: 'DCA ให้ผลชัดเจนในระยะยาว 5 ปีขึ้นไป ยิ่งนานยิ่งเห็นพลังของดอกเบี้ยทบต้น การทำ DCA ต่อเนื่อง 10-20 ปีในกองทุนหุ้นระยะยาวมักให้ผลตอบแทนสูงกว่าดอกเบี้ยเงินฝากมาก',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ DCA เฉลี่ยต้นทุน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-dca-เฉลี่ยต้นทุน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณ DCA เฉลี่ยต้นทุน 2569 — ลงทุนสม่ำเสมอรายเดือน
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณมูลค่าพอร์ตและต้นทุนเฉลี่ยจากการทำ DCA พร้อมเปรียบเทียบกับการลงทุนก้อนเดียว
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="dca-form" class="space-y-5">
        <p id="dca-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="dca-monthly" class="block text-sm font-medium text-gray-700 mb-1">
              เงินลงทุนรายเดือน (บาท)
            </label>
            <input
              type="text"
              id="dca-monthly"
              inputmode="numeric"
              placeholder="เช่น 5,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="dca-monthly-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="dca-months" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลา (เดือน)
            </label>
            <input
              type="text"
              id="dca-months"
              inputmode="numeric"
              placeholder="เช่น 120 (10 ปี)"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="dca-months-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="dca-rate" class="block text-sm font-medium text-gray-700 mb-1">
              ผลตอบแทนเฉลี่ยต่อปี (%)
            </label>
            <input
              type="text"
              id="dca-rate"
              inputmode="decimal"
              placeholder="เช่น 8.0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="dca-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="dca-initial" class="block text-sm font-medium text-gray-700 mb-1">
              เงินต้นเริ่มต้น (บาท, ไม่บังคับ)
            </label>
            <input
              type="text"
              id="dca-initial"
              inputmode="numeric"
              placeholder="เช่น 50,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          id="dca-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">มูลค่าพอร์ต</div>
            <div id="res-dca-portfolio" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ต้นทุนรวม</div>
            <div id="res-dca-cost" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">กำไร/ขาดทุน</div>
            <div id="res-dca-profit" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ผลตอบแทน %</div>
            <div id="res-dca-return" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>

        <!-- Lump Sum Comparison -->
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
          <h3 class="text-sm font-semibold text-amber-800 mb-2">เปรียบเทียบ: ลงทุนก้อนเดียว (Lump Sum)</h3>
          <p class="text-sm text-amber-700">หากนำเงินลงทุนรวมทั้งหมดลงทุนตั้งแต่วันแรก:</p>
          <div class="mt-2 grid gap-2 sm:grid-cols-3">
            <div class="text-center">
              <div class="text-xs text-amber-600">มูลค่า Lump Sum</div>
              <div id="res-lump-portfolio" class="font-bold text-amber-800">-</div>
            </div>
            <div class="text-center">
              <div class="text-xs text-amber-600">กำไร Lump Sum</div>
              <div id="res-lump-profit" class="font-bold text-amber-800">-</div>
            </div>
            <div class="text-center">
              <div class="text-xs text-amber-600">ส่วนต่าง DCA vs Lump Sum</div>
              <div id="res-diff" class="font-bold text-amber-800">-</div>
            </div>
          </div>
        </div>

        <details class="mt-4">
          <summary class="cursor-pointer font-semibold text-gray-900 hover:text-primary-600 mb-2">
            เป้าหมายรายปี (คลิกเพื่อดู)
          </summary>
          <div class="overflow-x-auto mt-2">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-gray-500 border-b border-gray-200">
                  <th class="py-2 pr-2">ปีที่</th>
                  <th class="py-2 pr-2 text-right">ต้นทุนสะสม</th>
                  <th class="py-2 pr-2 text-right">กำไรสะสม</th>
                  <th class="py-2 text-right">มูลค่าพอร์ต</th>
                </tr>
              </thead>
              <tbody id="dca-yearly-body"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">กลยุทธ์ DCA คืออะไรและทำงานอย่างไร?</h2>

      <p>
        Dollar-Cost Averaging (DCA) หรือการลงทุนแบบถัวเฉลี่ยต้นทุน คือการลงทุนด้วยเงินจำนวนคงที่
        ในช่วงเวลาสม่ำเสมอ โดยไม่คำนึงถึงราคาตลาด ณ ขณะนั้น
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ข้อดีของ DCA</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ลดความเสี่ยงจากการซื้อในราคาสูงสุด (Market Timing Risk)</li>
        <li>สร้างวินัยการลงทุนสม่ำเสมอ</li>
        <li>เหมาะกับมนุษย์เงินเดือนที่มีรายได้ประจำทุกเดือน</li>
        <li>ลดผลกระทบทางจิตวิทยาเมื่อตลาดผันผวน</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่าง DCA 10 ปี</h3>
      <p>ลงทุนเดือนละ 5,000 บาท ผลตอบแทนเฉลี่ย 8% ต่อปี เป็นเวลา 10 ปี (120 เดือน):</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ต้นทุนรวม: 5,000 × 120 = <strong>600,000 บาท</strong></li>
        <li>มูลค่าพอร์ต: ประมาณ <strong>918,000 บาท</strong></li>
        <li>กำไร: ประมาณ <strong>318,000 บาท</strong> (53%)</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณ-dca-เฉลี่ยต้นทุน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ผลตอบแทนจริงขึ้นอยู่กับสภาวะตลาดและไม่มีการรับประกัน ไม่ถือเป็นคำแนะนำทางการลงทุน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('dca-form') as HTMLFormElement;
    const submitBtn = document.getElementById('dca-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('dca-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    const monthlyInput = document.getElementById('dca-monthly') as HTMLInputElement;
    const monthsInput = document.getElementById('dca-months') as HTMLInputElement;
    const rateInput = document.getElementById('dca-rate') as HTMLInputElement;
    const initialInput = document.getElementById('dca-initial') as HTMLInputElement;

    function setFieldError(id: string, msg: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.remove('hidden');
    }

    function clearFieldError(id: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      ['dca-monthly-error', 'dca-months-error', 'dca-rate-error'].forEach(clearFieldError);
    }

    [monthlyInput, monthsInput, rateInput, initialInput].forEach(input => {
      input.addEventListener('input', clearValidation);
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearValidation();

      const monthly = parseNum(monthlyInput.value);
      const months = parseInt(monthsInput.value.replace(/,/g, '')) || 0;
      const annualRate = parseFloat(rateInput.value.replace(/,/g, '')) || 0;
      const initial = parseNum(initialInput.value);

      let hasError = false;
      if (monthly <= 0) { setFieldError('dca-monthly-error', 'กรุณากรอกเงินลงทุนรายเดือน'); hasError = true; }
      if (months <= 0 || months > 600) { setFieldError('dca-months-error', 'กรุณากรอกระยะเวลา 1-600 เดือน'); hasError = true; }
      if (annualRate <= 0) { setFieldError('dca-rate-error', 'กรุณากรอกผลตอบแทนเฉลี่ยที่ถูกต้อง'); hasError = true; }

      if (hasError) {
        formError.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('dca');

      const r = annualRate / 100 / 12;
      let balance = initial;
      let totalCost = initial;

      interface YearRow { year: number; cost: number; profit: number; portfolio: number; }
      const yearlyRows: YearRow[] = [];

      for (let m = 1; m <= months; m++) {
        balance = balance * (1 + r) + monthly;
        totalCost += monthly;
        if (m % 12 === 0) {
          yearlyRows.push({ year: m / 12, cost: totalCost, profit: balance - totalCost, portfolio: balance });
        }
      }

      const profit = balance - totalCost;
      const returnPct = totalCost > 0 ? (profit / totalCost) * 100 : 0;

      // Lump sum comparison: invest totalCost at month 0
      const lumpFv = totalCost * Math.pow(1 + r, months);
      const lumpProfit = lumpFv - totalCost;
      const diff = balance - lumpFv;

      (document.getElementById('res-dca-portfolio') as HTMLElement).textContent = fmt(balance) + ' บาท';
      (document.getElementById('res-dca-cost') as HTMLElement).textContent = fmt(totalCost) + ' บาท';
      const profitEl = document.getElementById('res-dca-profit') as HTMLElement;
      profitEl.textContent = (profit >= 0 ? '+' : '') + fmt(profit) + ' บาท';
      profitEl.className = 'text-xl font-bold ' + (profit >= 0 ? 'text-green-700' : 'text-red-600');
      (document.getElementById('res-dca-return') as HTMLElement).textContent = returnPct.toFixed(2) + '%';

      (document.getElementById('res-lump-portfolio') as HTMLElement).textContent = fmt(lumpFv) + ' บาท';
      (document.getElementById('res-lump-profit') as HTMLElement).textContent = fmt(lumpProfit) + ' บาท';
      const diffEl = document.getElementById('res-diff') as HTMLElement;
      diffEl.textContent = (diff >= 0 ? 'DCA +' : 'Lump Sum +') + fmt(Math.abs(diff)) + ' บาท';

      const filteredRows = yearlyRows.filter((_, i) => {
        const yr = yearlyRows[i].year;
        const totalYears = months / 12;
        return yr <= 5 || yr % 5 === 0 || yr === Math.floor(totalYears);
      });

      const tbody = document.getElementById('dca-yearly-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      filteredRows.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';
        tr.innerHTML = `
          <td class="py-2 pr-2 text-gray-600">${row.year}</td>
          <td class="py-2 pr-2 text-right">${fmt(row.cost)}</td>
          <td class="py-2 pr-2 text-right text-green-700">+${fmt(row.profit)}</td>
          <td class="py-2 text-right font-medium">${fmt(row.portfolio)}</td>
        `;
        tbody.appendChild(tr);
      });

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('dca');
      trackCalculatorUsed('dca');
    });
  </script>
</BaseLayout>
