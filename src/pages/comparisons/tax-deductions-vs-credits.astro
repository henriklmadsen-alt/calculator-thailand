---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'ลดหย่อน vs หักลดหย่อน — เปรียบเทียบเต็ม';
const pageDescription = 'เปรียบเทียบลดหย่อนภาษีและหักลดหย่อนภาษีอย่างถูกต้อง รู้ความต่างและประหยัดภาษีได้สูงสุด';
const canonical = `${siteUrl}/comparisons/tax-deductions-vs-credits/`;
const authorDate = '2026-05-01';

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDescription,
  image: {
    '@type': 'ImageObject',
    url: `${siteUrl}/og-image.jpg`,
    width: 1200,
    height: 630,
  },
  datePublished: authorDate,
  author: {
    '@type': 'Organization',
    name: 'Kamnuanlek',
  },
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} />

  <article class="prose prose-gray max-w-none">

    <h1>ลดหย่อน vs หักลดหย่อน — เปรียบเทียบเต็ม</h1>

    <p>คนไทยหลายคนสับสนระหว่าง "ลดหย่อนภาษี" (Deduction) และ "หักลดหย่อนภาษี" (Tax Credit) อันที่จริง แม้ชื่อใกล้เคียง แต่ผลประหยัดต่างกันมาก บทความนี้อธิบายความต่างและวิธีใช้อย่างถูกต้อง</p>

    <h2>ความต่างในอธิบาย</h2>

    <table class="w-full border-collapse border border-gray-300 my-4">
      <thead>
        <tr class="bg-gray-100">
          <th class="border p-3">เกณฑ์</th>
          <th class="border p-3">ลดหย่อน (Deduction)</th>
          <th class="border p-3">หักลดหย่อน (Tax Credit)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border p-3"><strong>คำนิยาม</strong></td>
          <td class="border p-3">จำนวนเงินหักออกจากเงินได้ก่อนคำนวณภาษี</td>
          <td class="border p-3">จำนวนเงินหักออกจากภาษีที่ต้องจ่ายโดยตรง</td>
        </tr>
        <tr>
          <td class="border p-3"><strong>ประหยัดขึ้นอยู่กับ</strong></td>
          <td class="border p-3">อัตราภาษีของคุณ (15%, 20%, 35%)</td>
          <td class="border p-3">จำนวนเงินที่หักลดหย่อน (100%, 1:1)</td>
        </tr>
        <tr>
          <td class="border p-3"><strong>ตัวอย่าง</strong></td>
          <td class="border p-3">ลดหย่อน 100,000 บาท @ 20% = ประหยัด 20,000 บาท</td>
          <td class="border p-3">หักลดหย่อน 100,000 บาท = ประหยัด 100,000 บาท</td>
        </tr>
        <tr>
          <td class="border p-3"><strong>ประเทศที่มี</strong></td>
          <td class="border p-3">ทุกประเทศ (ไทยมี)</td>
          <td class="border p-3">เฉพาะบางประเทศ (ไทยไม่มี)</td>
        </tr>
      </tbody>
    </table>

    <h2>ตัวอย่างการเปรียบเทียบ — รู้ความต่างจริง ๆ</h2>

    <h3>ตัวอย่างที่ 1: ลดหย่อนเงินได้ 100,000 บาท</h3>

    <p><strong>สถานการณ์:</strong> เงินได้รวม 500,000 บาท / ปี | อัตราภาษี 20% ที่เงินอายุสุดท้าย</p>

    <ul>
      <li><strong>ไม่ลดหย่อน:</strong> ภาษี = 500,000 × 20% = 100,000 บาท</li>
      <li><strong>ลดหย่อน 100,000 บาท:</strong> ภาษี = (500,000 - 100,000) × 20% = 80,000 บาท | ประหยัด = 20,000 บาท</li>
      <li><strong>หักลดหย่อน 100,000 บาท (ถ้าไทยมี):</strong> ภาษี = 100,000 - 100,000 = 0 บาท | ประหยัด = 100,000 บาท</li>
    </ul>

    <h3>ตัวอย่างที่ 2: ลดหย่อนเงินได้ 500,000 บาท (เงินสมทบ RMF)</h3>

    <p><strong>สถานการณ์:</strong> เงินได้รวม 1,000,000 บาท / ปี | อัตราภาษี 35% (ชั้นสูง)</p>

    <ul>
      <li><strong>ไม่ลดหย่อน:</strong> ภาษี = 1,000,000 × 35% = 350,000 บาท</li>
      <li><strong>ลดหย่อน 500,000 บาท (RMF):</strong> ภาษี = (1,000,000 - 500,000) × 35% = 175,000 บาท | ประหยัด = 175,000 บาท</li>
      <li><strong>หักลดหย่อน 500,000 บาท (ถ้าไทยมี):</strong> ภาษี = 350,000 - 500,000 = ติดลบ (ได้คืน 150,000 บาท!)</li>
    </ul>

    <h2>ลดหย่อนประเภทต่างๆ ที่ไทยมี</h2>

    <h3>1. ลดหย่อนส่วนบุคคล (Personal Exemption)</h3>

    <p><strong>อะไร:</strong> 60,000 บาท (ผู้ใหญ่โสด)<br/>
    <strong>ประหยัด:</strong> 60,000 × 20% = 12,000 บาท (ที่อัตรา 20%)</p>

    <h3>2. ลดหย่อนผู้ติดตาม (Dependent Exemption)</h3>

    <p><strong>อะไร:</strong> 30,000 บาท ต่อคน (บิดามารดา, ลูก)<br/>
    <strong>ประหยัด:</strong> 30,000 × 20% = 6,000 บาท ต่อคน</p>

    <h3>3. ลดหย่อนประกันชีวิต (Life Insurance Deduction)</h3>

    <p><strong>อะไร:</strong> สูงสุด 100,000 บาท / ปี<br/>
    <strong>ประหยัด:</strong> 100,000 × 35% = 35,000 บาท (ที่อัตรา 35%)</p>

    <h3>4. ลดหย่อนกองทุนเงินบำนาญกลาง (RMF)</h3>

    <p><strong>อะไร:</strong> สูงสุด 500,000 บาท / ปี หรือ 15% ของเงินได้<br/>
    <strong>ประหยัด:</strong> 500,000 × 35% = 175,000 บาท (ที่อัตรา 35%!)</p>

    <h2>ทำไมการลดหย่อนไม่เท่าหักลดหย่อน?</h2>

    <p>เพราะการลดหย่อนจะลดเงินได้ก่อนคำนวณภาษี ต่างจากการหักลดหย่อนที่หักตรงจากภาษีจำนวนเงิน</p>

    <h3>ตัวอย่างการคำนวณขั้น-ต่อ-ขั้น</h3>

    <ul>
      <li>เงินได้รวม: 1,000,000 บาท</li>
      <li>ลบ ลดหย่อน: 500,000 บาท (RMF)</li>
      <li>= เงินได้คงเหลือ: 500,000 บาท</li>
      <li>ภาษี @ 35%: 500,000 × 35% = 175,000 บาท</li>
      <li>หัก หักลดหย่อน (ถ้ามี): เช่น 50,000 บาท</li>
      <li>= ภาษีจ่ายจริง: 175,000 - 50,000 = 125,000 บาท</li>
    </ul>

    <h2>ประเภทลดหย่อนที่มีประหยัดสูงสุด</h2>

    <ol>
      <li><strong>RMF (ลดหย่อน 500,000 บาท)</strong> — ประหยัด 175,000 บาท (ที่ 35%)</li>
      <li><strong>ประกันชีวิต (ลดหย่อน 100,000 บาท)</strong> — ประหยัด 35,000 บาท (ที่ 35%)</li>
      <li><strong>บำรุงการศึกษา (ลดหย่อน 15,000 บาท)</strong> — ประหยัด 5,250 บาท (ที่ 35%)</li>
      <li><strong>ผู้ติดตาม (ลดหย่อน 30,000 บาท)</strong> — ประหยัด 10,500 บาท (ที่ 35%)</li>
    </ol>

    <h2>เคล็ดลับการใช้ลดหย่อนให้ได้ประโยชน์สูงสุด</h2>

    <h3>1. ใช้ลดหย่อนที่สูงเปอร์เซ็นต์อัตราภาษี</h3>

    <p>ถ้าเงินได้ของคุณอยู่ที่ 35% ให้ลงทุนลดหย่อนมากขึ้น (เช่น RMF) เพราะจะประหยัด 35% แต่ละบาท ไม่ใช่แค่ 15% หรือ 20%</p>

    <h3>2. จัดลำดับลดหย่อน</h3>

    <p>ลำดับที่มีประโยชน์มากที่สุด: RMF → ประกันชีวิต → บำรุงการศึกษา → ผู้ติดตาม</p>

    <h3>3. วางแผนล่วงหน้า</h3>

    <p>ลดหย่อนต้องสำเร็จก่อน 31 ธันวาคม เพื่อนำใช้ลดหย่อนในปีเดียวกัน</p>

    <h2>ลดหย่อนที่มักมองข้าม</h2>

    <ul>
      <li><strong>ค่าธรรมชาติบ้าน:</strong> ได้ลดหย่อนตามสิทธิ</li>
      <li><strong>อุจีวิทย์ประจำปี:</strong> ได้ลดหย่อน 20,000 บาท (บริจาค)</li>
      <li><strong>สมาชิกสหกรณ์:</strong> ได้ลดหย่อน 15,000 บาท</li>
      <li><strong>ค่าเบี้ยประกันสังคม (นายจ้างเบิก):</strong> ได้ลดหย่อน (ส่วนของพนักงาน)</li>
    </ul>

    <h2>สรุป</h2>

    <p><strong>ลดหย่อน</strong> = ลดเงินได้ก่อนคำนวณภาษี (ประหยัด = ลดหย่อน × อัตราภาษี)<br/>
    <strong>หักลดหย่อน</strong> = ลดภาษีตรงๆ (ประหยัด = หักลดหย่อน × 100%)<br/>
    <strong>ไทย</strong> = มี ลดหย่อน แต่ไม่มี หักลดหย่อน</p>

    <p>ใช้ลดหย่อนให้เต็มที่ และลดลดหย่อนที่มีประโยชน์สูงสุด (RMF) ได้ประหยัดศาสตร์ได้สูงสุด!</p>

  </article>
</BaseLayout>