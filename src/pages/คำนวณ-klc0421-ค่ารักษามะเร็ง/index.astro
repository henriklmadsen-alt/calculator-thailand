---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่ารักษามะเร็ง | Kamnuanlek';
const pageDescription = 'คำนวณงบประมาณค่ารักษามะเร็ง เคมีบำบัด ฉายรังสี ผ่าตัด ตามอัตราโรงพยาบาลไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0421-ค่ารักษามะเร็ง/`;

const faqData = [
  { question: 'ค่ารักษามะเร็งในไทยเท่าไหร่?', answer: 'ค่ารักษามะเร็งขึ้นอยู่กับประเภท ระยะ และโรงพยาบาล เคมีบำบัด 1-5 ล้านบาทต่อคอร์ส การฉายรังสี 200,000-600,000 บาท ผ่าตัด 100,000-500,000 บาท' },
  { question: 'บัตรทองครอบคลุมค่ารักษามะเร็งไหม?', answer: 'บัตรทองครอบคลุมค่ารักษามะเร็งพื้นฐาน เคมีบำบัดมาตรฐาน ฉายรังสี ผ่าตัด ที่โรงพยาบาลรัฐในสังกัด แต่ยาใหม่หรือการรักษาพิเศษอาจต้องจ่ายเพิ่ม' },
  { question: 'ประกันมะเร็งคุ้มค่าไหม?', answer: 'ประกันมะเร็งเบี้ยประมาณ 2,000-10,000 บาทต่อปี วงเงินคุ้มครอง 500,000-3,000,000 บาท คุ้มค่าโดยเฉพาะสำหรับคนที่มีความเสี่ยงหรือประวัติครอบครัว' },
  { question: 'ยา Targeted Therapy ราคาเท่าไหร่?', answer: 'ยา Targeted Therapy ราคา 50,000-500,000 บาทต่อเดือน ขึ้นอยู่กับชนิดยาและประเภทมะเร็ง บางชนิดอยู่ในบัญชียาบัตรทอง แต่หลายชนิดต้องจ่ายเอง' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่ารักษามะเร็ง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณงบประมาณค่ารักษามะเร็ง</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">ประมาณการค่าใช้จ่ายรักษามะเร็ง รวมเคมีบำบัด ฉายรังสี และผ่าตัด</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="chemo_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าเคมีบำบัดต่อรอบ (บาท)</label><input type="text" id="chemo_cost" inputmode="decimal" placeholder="เช่น 80000" value="80000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="chemo_rounds" class="block text-sm font-medium text-gray-700 mb-1">จำนวนรอบเคมีบำบัด</label><input type="number" id="chemo_rounds" min="0" max="20" placeholder="เช่น 6" value="6" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="radiation_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าฉายรังสีทั้งคอร์ส (บาท)</label><input type="text" id="radiation_cost" inputmode="decimal" placeholder="เช่น 300000" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="surgery_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าผ่าตัด (บาท)</label><input type="text" id="surgery_cost" inputmode="decimal" placeholder="เช่น 200000" value="200000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="targeted_monthly" class="block text-sm font-medium text-gray-700 mb-1">ค่ายา Targeted ต่อเดือน (บาท)</label><input type="text" id="targeted_monthly" inputmode="decimal" placeholder="เช่น 0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="treatment_months" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลารักษา (เดือน)</label><input type="number" id="treatment_months" min="1" max="60" placeholder="เช่น 12" value="12" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าเคมี + รังสี + ผ่าตัด</p>
            <p id="main_cost" class="font-bold">-</p>
          </div>
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่ายา Targeted รวม</p>
            <p id="targeted_total" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">งบประมาณรักษามะเร็งทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const chemoCost = parseFloat((document.getElementById('chemo_cost') as HTMLInputElement).value) || 0;
      const chemoRounds = parseInt((document.getElementById('chemo_rounds') as HTMLInputElement).value) || 0;
      const radiationCost = parseFloat((document.getElementById('radiation_cost') as HTMLInputElement).value) || 0;
      const surgeryCost = parseFloat((document.getElementById('surgery_cost') as HTMLInputElement).value) || 0;
      const targetedMonthly = parseFloat((document.getElementById('targeted_monthly') as HTMLInputElement).value) || 0;
      const months = parseInt((document.getElementById('treatment_months') as HTMLInputElement).value) || 1;

      const mainCost = (chemoCost * chemoRounds) + radiationCost + surgeryCost;
      const targetedTotal = targetedMonthly * months;
      const total = mainCost + targetedTotal;

      (document.getElementById('main_cost') as HTMLElement).textContent = mainCost.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('targeted_total') as HTMLElement).textContent = targetedTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('cancer-treatment-budget');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
