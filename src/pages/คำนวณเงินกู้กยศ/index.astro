---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเงินกู้ กยศ. 2569 | ค่างวด ดอกเบี้ย ยอดชำระรวม | Kamnuanlek';
const pageDescription = 'คำนวณค่างวดผ่อนชำระเงินกู้ กองทุนเงินให้กู้ยืมเพื่อการศึกษา (กยศ.) ดอกเบี้ย 1% ต่อปี พร้อมดอกเบี้ยสะสมช่วงผ่อนผัน และวันเริ่มต้นผ่อนชำระ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินกู้กยศ/`;

const faqData = [
  {
    question: 'กยศ. คิดดอกเบี้ยเท่าไร และเริ่มผ่อนเมื่อไร?',
    answer: 'กยศ. คิดดอกเบี้ย 1% ต่อปี แบบลดต้นลดดอก มีระยะผ่อนผัน 2 ปีหลังจบการศึกษา ในช่วงผ่อนผันดอกเบี้ยจะสะสม แต่ยังไม่ต้องชำระ จากนั้นจึงเริ่มผ่อนชำระ 15 ปี (180 งวด)',
  },
  {
    question: 'กยศ. กู้ได้สูงสุดเท่าไรต่อปี?',
    answer: 'วงเงินกู้ กยศ. ต่อปีการศึกษาขึ้นอยู่กับสาขาวิชา ระดับอาชีวศึกษาประมาณ 20,000-40,000 บาท/ปี ระดับอุดมศึกษาประมาณ 45,000-65,000 บาท/ปี ค่าครองชีพสูงสุด 22,000-26,000 บาท/ปี โปรดตรวจสอบจากเว็บไซต์ กยศ. ล่าสุด',
  },
  {
    question: 'ถ้าผ่อนไม่ไหวสามารถพักชำระได้ไหม?',
    answer: 'กยศ. มีมาตรการช่วยเหลือ เช่น การผ่อนผันชำระเป็นงวดตามความสามารถ ขยายระยะเวลาชำระ หรือโอนสิทธิ์ผู้ค้ำประกัน แนะนำติดต่อ กยศ. โดยตรงหรือผ่านธนาคารกรุงไทยซึ่งเป็นตัวแทนจัดเก็บ',
  },
  {
    question: 'ดอกเบี้ยผิดนัดชำระของ กยศ. คือเท่าไร?',
    answer: 'หากผิดนัดชำระ กยศ. คิดดอกเบี้ยเพิ่ม 0.5% ต่อปีบนยอดที่ค้างชำระ (รวมเป็น 1.5% ต่อปี) และอาจมีการฟ้องร้องผู้กู้และผู้ค้ำประกัน กยศ. ได้ยกเว้นดอกเบี้ยผิดนัดในบางช่วง โปรดติดตามประกาศล่าสุด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินกู้ กยศ.',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินกู้ กยศ.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🎓 คำนวณเงินกู้ กยศ. — ค่างวด ดอกเบี้ยสะสม และยอดชำระรวม
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าผ่อนชำระเงินกู้ กองทุนเงินให้กู้ยืมเพื่อการศึกษา (กยศ.) อัตราดอกเบี้ย 1% ต่อปี
      พร้อมดอกเบี้ยสะสมช่วงผ่อนผัน 2 ปี และประมาณการวันเริ่มต้นผ่อนชำระ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="gsl-form" class="space-y-5">
        <div>
          <label for="loan-amount" class="block text-sm font-medium text-gray-700 mb-1">
            ยอดเงินกู้ทั้งหมด (บาท)
          </label>
          <input
            type="text"
            id="loan-amount"
            inputmode="numeric"
            placeholder="เช่น 200,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="repay-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาชำระคืน (ปี)
            </label>
            <input
              type="text"
              id="repay-years"
              inputmode="numeric"
              placeholder="15"
              value="15"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="interest-rate" class="block text-sm font-medium text-gray-700 mb-1">
              ดอกเบี้ย (% ต่อปี)
            </label>
            <input
              type="text"
              id="interest-rate"
              inputmode="decimal"
              placeholder="1"
              value="1"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="grace-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะผ่อนผัน (ปี)
            </label>
            <input
              type="text"
              id="grace-years"
              inputmode="numeric"
              placeholder="2"
              value="2"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="grad-year" class="block text-sm font-medium text-gray-700 mb-1">
            ปีที่จบการศึกษา (พ.ศ. เช่น 2568)
          </label>
          <input
            type="text"
            id="grad-year"
            inputmode="numeric"
            placeholder="เช่น 2568"
            class="w-full sm:w-48 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p class="text-xs text-gray-500 mt-1">เว้นว่างได้ถ้าไม่ต้องการดูวันเริ่มผ่อน</p>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่างวดต่อเดือน</div>
            <div id="res-monthly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-yellow-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยช่วงผ่อนผัน</div>
            <div id="res-grace-interest" class="text-xl font-bold text-yellow-700">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยรวม</div>
            <div id="res-interest" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดชำระรวม</div>
            <div id="res-total" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ยอดเงินกู้เริ่มต้น</span>
            <span id="res-principal" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ยอดหนี้เมื่อเริ่มผ่อน (รวมดอกเบี้ยผ่อนผัน)</span>
            <span id="res-balance-after-grace" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนงวด</span>
            <span id="res-term" class="font-medium">-</span>
          </div>
          <div id="res-start-row" class="hidden flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ประมาณการวันเริ่มผ่อน</span>
            <span id="res-start-date" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">เงินกู้ กยศ. คืออะไร และผ่อนอย่างไร?</h2>

      <p>
        กองทุนเงินให้กู้ยืมเพื่อการศึกษา (กยศ.) เป็นโครงการของรัฐบาลไทย
        ให้กู้ยืมแก่นักเรียน นักศึกษาที่ขาดแคลนทุนทรัพย์หรือต้องการกู้เพื่อการศึกษา
        อัตราดอกเบี้ยต่ำเพียง 1% ต่อปี แบบลดต้นลดดอก
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ขั้นตอนการชำระคืน</h3>
      <ol class="list-decimal pl-6 space-y-1 text-gray-700">
        <li>ช่วงศึกษา: ไม่ต้องชำระ แต่ดอกเบี้ยสะสมทุกปี (1% ต่อปี)</li>
        <li>ระยะผ่อนผัน 2 ปีหลังจบ: ดอกเบี้ยยังสะสมต่อ ไม่ต้องชำระ</li>
        <li>เริ่มผ่อนชำระ: ภายในเดือนมกราคม 2 ปีหลังจบ ผ่อน 15 ปี (180 งวด)</li>
      </ol>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณ</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ดอกเบี้ยช่วงผ่อนผัน = เงินต้น × 1% × ระยะผ่อนผัน (ปี)</li>
        <li>ยอดหนี้เมื่อเริ่มผ่อน = เงินต้น + ดอกเบี้ยช่วงผ่อนผัน</li>
        <li>ค่างวด = PMT แบบลดต้นลดดอก จากยอดหนี้ที่แท้จริง × 1%/ปี × 15 ปี</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่าง</h3>
      <p>
        กู้ 200,000 บาท ผ่อนผัน 2 ปี ผ่อนชำระ 15 ปี ดอกเบี้ย 1%/ปี:
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ดอกเบี้ยช่วงผ่อนผัน = 200,000 × 1% × 2 = 4,000 บาท</li>
        <li>ยอดหนี้เริ่มผ่อน = 204,000 บาท</li>
        <li>ค่างวดประมาณ 1,224 บาท/เดือน</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อยเกี่ยวกับ กยศ.</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณเงินกู้กยศ/" />
    <RelatedCalculators currentHref="/คำนวณเงินกู้กยศ/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเบื้องต้น
      เงื่อนไขจริงของ กยศ. อาจเปลี่ยนแปลงตามประกาศของกองทุน
      โปรดตรวจสอบข้อมูลล่าสุดจากเว็บไซต์ กยศ. (www.studentloan.or.th) หรือธนาคารกรุงไทย
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('gsl-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const loanAmount = parseNum((document.getElementById('loan-amount') as HTMLInputElement).value);
      const repayYears = parseNum((document.getElementById('repay-years') as HTMLInputElement).value) || 15;
      const annualRate = parseNum((document.getElementById('interest-rate') as HTMLInputElement).value) || 1;
      const graceYears = parseNum((document.getElementById('grace-years') as HTMLInputElement).value);
      const gradYearStr = (document.getElementById('grad-year') as HTMLInputElement).value.trim();

      if (loanAmount <= 0) { (document.getElementById('loan-amount') as HTMLInputElement).focus(); return; }

      // Grace period interest (simple interest on original principal)
      const graceInterest = loanAmount * (annualRate / 100) * graceYears;
      const balanceAfterGrace = loanAmount + graceInterest;

      // PMT for repayment period (reducing balance)
      const monthlyRate = annualRate / 100 / 12;
      const n = Math.round(repayYears * 12);
      let monthlyPayment: number;
      if (monthlyRate === 0) {
        monthlyPayment = balanceAfterGrace / n;
      } else {
        monthlyPayment = balanceAfterGrace * (monthlyRate * Math.pow(1 + monthlyRate, n)) /
          (Math.pow(1 + monthlyRate, n) - 1);
      }
      const totalRepayment = monthlyPayment * n;
      const totalInterest = totalRepayment + graceInterest - loanAmount;

      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthlyPayment) + ' บาท';
      (document.getElementById('res-grace-interest') as HTMLElement).textContent = fmt(graceInterest) + ' บาท';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(totalRepayment + graceInterest) + ' บาท';
      (document.getElementById('res-principal') as HTMLElement).textContent = fmt(loanAmount) + ' บาท';
      (document.getElementById('res-balance-after-grace') as HTMLElement).textContent = fmt(balanceAfterGrace) + ' บาท';
      (document.getElementById('res-term') as HTMLElement).textContent = n + ' งวด (' + repayYears + ' ปี)';

      // Approximate start date
      const startRow = document.getElementById('res-start-row') as HTMLElement;
      if (gradYearStr) {
        const gradYear = parseInt(gradYearStr);
        if (!isNaN(gradYear)) {
          const startYear = gradYear + Math.ceil(graceYears);
          (document.getElementById('res-start-date') as HTMLElement).textContent =
            'ประมาณ มกราคม พ.ศ. ' + startYear;
          startRow.classList.remove('hidden');
          startRow.style.display = 'flex';
        }
      } else {
        startRow.classList.add('hidden');
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('gsl-loan');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('gsl-loan');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
