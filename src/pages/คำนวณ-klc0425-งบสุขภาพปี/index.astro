---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณงบสุขภาพรายปี | Kamnuanlek';
const pageDescription = 'คำนวณงบประมาณสุขภาพรายปี รวมค่าประกัน ค่าตรวจ ค่ายา ค่าออกกำลังกาย เพื่อวางแผนสุขภาพ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0425-งบสุขภาพปี/`;

const faqData = [
  { question: 'ควรจัดสรรงบสุขภาพเท่าไหร่ต่อปี?', answer: 'แนะนำจัดสรร 5-10% ของรายได้ต่อปีสำหรับสุขภาพ สำหรับรายได้ 30,000 บาท/เดือน ควรมีงบสุขภาพปีละ 18,000-36,000 บาท' },
  { question: 'ค่าใช้จ่ายสุขภาพอะไรบ้างที่ลดหย่อนภาษีได้?', answer: 'เบี้ยประกันสุขภาพลดหย่อนได้สูงสุด 25,000 บาท เบี้ยประกันชีวิตลดหย่อนได้ 100,000 บาท ค่ารักษาพยาบาลตัวเองและครอบครัวลดหย่อนได้ไม่จำกัด' },
  { question: 'วิธีประหยัดค่าสุขภาพทำอย่างไร?', answer: 'ป้องกันดีกว่ารักษา ออกกำลังกายสม่ำเสมอ ตรวจสุขภาพประจำปี ใช้สิทธิบัตรทองหรือประกันสังคม เปรียบเทียบราคาก่อนรักษา' },
  { question: 'ควรทำประกันสุขภาพหรือเก็บเงินสำรองเอง?', answer: 'แนะนำทั้งสองวิธีควบคู่กัน ประกันสุขภาพจัดการความเสี่ยงสูง เงินสำรองสุขภาพจัดการค่าใช้จ่ายทั่วไป เป้าหมายเงินสำรองฉุกเฉิน 3-6 เดือนของรายได้' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบสุขภาพรายปี">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณงบสุขภาพรายปี</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">วางแผนงบประมาณสุขภาพรายปีสำหรับตนเองและครอบครัว</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="insurance_premium" class="block text-sm font-medium text-gray-700 mb-1">เบี้ยประกันสุขภาพต่อปี (บาท)</label><input type="text" id="insurance_premium" inputmode="decimal" placeholder="เช่น 15000" value="15000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="annual_checkup" class="block text-sm font-medium text-gray-700 mb-1">ค่าตรวจสุขภาพประจำปี (บาท)</label><input type="text" id="annual_checkup" inputmode="decimal" placeholder="เช่น 5000" value="5000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="routine_meds" class="block text-sm font-medium text-gray-700 mb-1">ค่ายาและอาหารเสริมต่อเดือน (บาท)</label><input type="text" id="routine_meds" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="fitness_cost" class="block text-sm font-medium text="text-gray-700 mb-1">ค่าออกกำลังกายต่อเดือน (บาท)</label><input type="text" id="fitness_cost" inputmode="decimal" placeholder="เช่น 800" value="800" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="emergency_fund" class="block text-sm font-medium text-gray-700 mb-1">เงินสำรองฉุกเฉินสุขภาพ (บาท)</label><input type="text" id="emergency_fund" inputmode="decimal" placeholder="เช่น 20000" value="20000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายสุขภาพประจำปี</p>
            <p id="routine_yearly" class="font-bold">-</p>
          </div>
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">งบเตรียมพร้อมฉุกเฉิน</p>
            <p id="emergency_total" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">งบสุขภาพรวมทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const insurancePremium = parseFloat((document.getElementById('insurance_premium') as HTMLInputElement).value) || 0;
      const annualCheckup = parseFloat((document.getElementById('annual_checkup') as HTMLInputElement).value) || 0;
      const routineMeds = parseFloat((document.getElementById('routine_meds') as HTMLInputElement).value) || 0;
      const fitnessCost = parseFloat((document.getElementById('fitness_cost') as HTMLInputElement).value) || 0;
      const emergencyFund = parseFloat((document.getElementById('emergency_fund') as HTMLInputElement).value) || 0;

      const routineYearly = insurancePremium + annualCheckup + ((routineMeds + fitnessCost) * 12);
      const total = routineYearly + emergencyFund;

      (document.getElementById('routine_yearly') as HTMLElement).textContent = routineYearly.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('emergency_total') as HTMLElement).textContent = emergencyFund.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('annual-health-budget');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
