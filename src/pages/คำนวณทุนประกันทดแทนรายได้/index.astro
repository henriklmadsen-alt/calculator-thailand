---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณทุนประกันชีวิตทดแทนรายได้ 2569 | Life Cover Income Replacement ฟรี | Calculator Thailand';
const pageDescription = 'คำนวณทุนประกันชีวิตที่ต้องการเพื่อทดแทนรายได้ 2569 ให้ครอบครัวมีเงินใช้จ่ายได้ตามปกติ หลังหัก DIME Method: หนี้ รายได้ งบบุตร การศึกษา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณทุนประกันทดแทนรายได้/`;

const faqData = [
  { question: 'DIME Method คืออะไร?', answer: 'DIME ย่อจาก Debt (หนี้สิน) Income (รายได้ที่ต้องทดแทน) Mortgage (เงินกู้บ้าน) Education (ทุนการศึกษาบุตร) เป็นวิธีคำนวณทุนประกันชีวิตที่ครอบคลุมที่สุด โดยนำทุกค่าใช้จ่ายที่ครอบครัวจำเป็นต้องใช้หลังเสียชีวิตมารวมกัน' },
  { question: 'ทุนประกันชีวิตควรเป็นกี่เท่าของรายได้?', answer: 'กฎ DIME แม่นยำกว่าการคูณเท่า แต่กฎเร็วคือ 7-10 เท่าของรายได้ต่อปี บวกหนี้ทั้งหมด สำหรับผู้ที่มีบุตรอาจต้องการ 10-15 เท่าเพื่อรวมทุนการศึกษา' },
  { question: 'ควรพิจารณาปัจจัยอะไรในการคำนวณทุนประกัน?', answer: 'ปัจจัยหลัก: (1) จำนวนปีที่รายได้จำเป็นต่อครอบครัว (2) หนี้สินทั้งหมด (3) ค่าใช้จ่ายการศึกษาบุตร (4) เงินออมและสินทรัพย์ที่มีอยู่ (5) รายได้ของคู่สมรส (6) เงินเฟ้อในอนาคต' },
  { question: 'ทุนประกันที่มีอยู่แล้วควรหักออกไหม?', answer: 'ใช่ หลังคำนวณทุนประกันทั้งหมดที่ต้องการ ให้หักด้วยทุนประกันที่มีอยู่แล้ว (ทั้งประกันส่วนตัวและประกันกลุ่มจากที่ทำงาน) เพื่อให้รู้ว่าต้องซื้อประกันเพิ่มเท่าไร' },
];

const jsonLdWebApp = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'เครื่องคำนวณทุนประกันชีวิตทดแทนรายได้ 2569', description: pageDescription, url: canonical, applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' }, inLanguage: 'th' };
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณทุนประกันทดแทนรายได้">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณทุนประกันชีวิตด้วย DIME Method</p>
      <p class="mt-1 text-sm text-slate-700">หนี้ + รายได้ + การศึกษาบุตร = ทุนประกันที่ต้องการ</p>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณทุนประกันชีวิตทดแทนรายได้ 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">คำนวณทุนประกันชีวิตที่ครอบครัวต้องการเพื่อดำรงชีวิตได้ตามปกติ โดยใช้ DIME Method</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูล DIME</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>

        <div class="rounded-lg bg-blue-50 p-4 border border-blue-200">
          <p class="text-sm font-semibold text-blue-800 mb-3">D — Debt (หนี้สิน)</p>
          <div class="space-y-3">
            <div><label class="block text-xs text-gray-600 mb-1">หนี้บ้าน/เงินกู้อสังหา (บาท)</label><input type="text" id="debt-home" inputmode="numeric" placeholder="เช่น 2,000,000" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" /></div>
            <div><label class="block text-xs text-gray-600 mb-1">หนี้อื่นๆ รวม (รถ บัตรเครดิต ส่วนตัว) (บาท)</label><input type="text" id="debt-other" inputmode="numeric" placeholder="เช่น 300,000" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" /></div>
          </div>
        </div>

        <div class="rounded-lg bg-green-50 p-4 border border-green-200">
          <p class="text-sm font-semibold text-green-800 mb-3">I — Income (รายได้ที่ต้องทดแทน)</p>
          <div class="space-y-3">
            <div><label class="block text-xs text-gray-600 mb-1">รายได้ต่อปี (บาท)</label><input type="text" id="annual-income" inputmode="numeric" placeholder="เช่น 720,000" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" /></div>
            <div><label class="block text-xs text-gray-600 mb-1">จำนวนปีที่ต้องทดแทน</label><select id="income-years" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm bg-white"><option value="5">5 ปี</option><option value="10" selected>10 ปี</option><option value="15">15 ปี</option><option value="20">20 ปี</option></select></div>
          </div>
        </div>

        <div class="rounded-lg bg-orange-50 p-4 border border-orange-200">
          <p class="text-sm font-semibold text-orange-800 mb-3">E — Education (ทุนการศึกษาบุตร)</p>
          <div><label class="block text-xs text-gray-600 mb-1">งบการศึกษาบุตรรวม (บาท)</label><input type="text" id="education" inputmode="numeric" placeholder="เช่น 1,000,000" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" /></div>
        </div>

        <div>
          <label for="existing-assets" class="block text-sm font-medium text-gray-700 mb-1">สินทรัพย์สภาพคล่องที่มีอยู่ (บาท)</label>
          <input type="text" id="existing-assets" inputmode="numeric" placeholder="เช่น 500,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">เงินออม กองทุน ที่ครอบครัวใช้ได้ทันที (ไม่รวมบ้านที่อยู่อาศัย)</p>
        </div>

        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">คำนวณทุนประกันที่ต้องการ</button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ DIME</h2>
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 mb-4 text-center">
        <p class="text-sm text-primary-700 mb-1">ทุนประกันชีวิตที่แนะนำ</p>
        <p class="text-4xl font-bold text-primary-700" id="recommended-coverage">-</p>
        <p class="text-sm text-primary-600 mt-1" id="note">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b">รายละเอียด DIME</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">DIME Method คือวิธีที่ครอบคลุมที่สุด</h2>
      <p>DIME Method ช่วยให้คุณคำนวณทุนประกันชีวิตที่แม่นยำ โดยพิจารณาทุกภาระทางการเงินที่ครอบครัวต้องเผชิญหากคุณไม่อยู่ ต่างจากกฎ "10 เท่าของรายได้" ที่อาจขาดหรือเกินความต้องการจริง</p>
    </section>
    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (<details class="bg-white rounded-lg shadow-sm border border-gray-200"><summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary><div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div></details>))}
      </div>
    </section>
    <RelatedCalculators currentHref="/คำนวณทุนประกันทดแทนรายได้/" />
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800"><strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ ควรปรึกษาที่ปรึกษาการเงินเพื่อแผนที่เหมาะสม</div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const debtHome = parseNum((document.getElementById('debt-home') as HTMLInputElement).value);
      const debtOther = parseNum((document.getElementById('debt-other') as HTMLInputElement).value);
      const income = parseNum((document.getElementById('annual-income') as HTMLInputElement).value);
      const years = parseInt((document.getElementById('income-years') as HTMLSelectElement).value);
      const education = parseNum((document.getElementById('education') as HTMLInputElement).value);
      const assets = parseNum((document.getElementById('existing-assets') as HTMLInputElement).value);
      const err = document.getElementById('form-error')!;
      if (income < 60000) { err.textContent = 'กรุณากรอกรายได้ต่อปี'; err.classList.remove('hidden'); return; }
      err.classList.add('hidden');

      const D = debtHome + debtOther;
      const I = income * years;
      const E = education;
      const totalNeeded = D + I + E;
      const recommended = Math.max(0, totalNeeded - assets);

      const rows = [
        ['D — หนี้สินรวม (บ้าน + อื่นๆ)', '', `${fmt(D)} บาท`],
        ['I — รายได้ทดแทน', `${fmt(income)} × ${years} ปี`, `${fmt(I)} บาท`],
        ['E — ทุนการศึกษาบุตร', '', `${fmt(E)} บาท`],
        ['รวม D+I+E', '', `${fmt(totalNeeded)} บาท`],
        ['หัก: สินทรัพย์สภาพคล่องที่มีอยู่', '', `-${fmt(assets)} บาท`],
        ['ทุนประกันชีวิตที่แนะนำ', '', `<strong>${fmt(recommended)} บาท</strong>`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td><td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td></tr>`).join('');

      (document.getElementById('recommended-coverage') as HTMLElement).textContent = fmt(recommended) + ' บาท';
      (document.getElementById('note') as HTMLElement).textContent = `เทียบเท่า ${(recommended/income).toFixed(1)} เท่าของรายได้ต่อปี`;
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
