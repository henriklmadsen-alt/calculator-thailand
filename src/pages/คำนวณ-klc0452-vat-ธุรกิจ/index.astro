---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณภาษี VAT ธุรกิจ | Kamnuanlek';
const pageDescription = 'คำนวณภาษีมูลค่าเพิ่ม VAT ที่ต้องนำส่ง Output VAT ลบ Input VAT รายเดือน อัตรา 7%';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0452-vat-ธุรกิจ/`;

const faqData = [
  { question: 'ธุรกิจไหนต้องจดทะเบียน VAT?', answer: 'ธุรกิจที่มีรายได้เกิน 1,800,000 บาทต่อปีต้องจดทะเบียน VAT ภายใน 30 วัน ธุรกิจที่รายได้ต่ำกว่านี้อาจจดทะเบียนโดยสมัครใจ' },
  { question: 'Output VAT และ Input VAT ต่างกันอย่างไร?', answer: 'Output VAT คือ VAT ที่เรียกเก็บจากลูกค้า Input VAT คือ VAT ที่จ่ายเมื่อซื้อสินค้า/บริการ ต้องนำส่ง = Output VAT - Input VAT' },
  { question: 'ยื่น VAT ภายในวันที่เท่าไหร่?', answer: 'ยื่นแบบ ภ.พ.30 ภายในวันที่ 15 ของเดือนถัดไป หรือ e-Filing ได้ถึงวันที่ 23 ทุกเดือน ไม่ยื่นหรือยื่นช้ามีโทษปรับ' },
  { question: 'ธุรกิจที่ได้รับยกเว้น VAT มีอะไรบ้าง?', answer: 'ธุรกิจยกเว้น VAT ได้แก่ การศึกษา โรงพยาบาล วัด การเกษตร ส่งออก อสังหาริมทรัพย์บางประเภท ตรวจสอบประกาศกรมสรรพากร' }
,
  { question: 'ธุรกิจขนาดไหนต้องจดทะเบียน VAT?', answer: 'ผู้ประกอบการที่มีรายได้จากการขายสินค้าหรือบริการเกิน 1,800,000 บาทต่อปี ต้องจดทะเบียนภาษีมูลค่าเพิ่มภายใน 30 วันนับแต่วันที่รายได้เกิน' },
  { question: 'VAT Input และ Output Tax คืออะไร?', answer: 'Output VAT: ภาษีที่เรียกเก็บจากลูกค้า | Input VAT: ภาษีที่จ่ายให้ซัพพลายเออร์ | ภาษีที่ต้องนำส่งกรมสรรพากร = Output VAT - Input VAT ถ้าติดลบได้รับคืนหรือนำไปเครดิตเดือนถัดไป' },
  { question: 'สินค้าและบริการอะไรได้รับการยกเว้น VAT?', answer: 'อาหารสด พืชผักผลไม้ที่ยังไม่แปรรูป, สัตว์ที่ยังมีชีวิต, ปุ๋ยและยาป้องกันแมลง, หนังสือพิมพ์/นิตยสาร, บริการสุขภาพ/การศึกษา, การขนส่งผู้โดยสารภายในประเทศ' },
  { question: 'VAT Zero Rate ต่างจาก VAT Exempt อย่างไร?', answer: 'Zero Rate (0%): เสีย VAT แต่อัตรา 0% เช่น ส่งออกสินค้า — ยังขอคืน Input VAT ได้ | Exempt (ยกเว้น): ไม่ต้องเสีย VAT แต่ขอคืน Input VAT ไม่ได้ สำคัญมากสำหรับการวางแผนภาษี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษี VAT ธุรกิจ">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณภาษี VAT ธุรกิจ</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณ VAT ที่ต้องนำส่ง สรรพากร Output VAT ลบ Input VAT</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="sales_excl_vat" class="block text-sm font-medium text-gray-700 mb-1">ยอดขายก่อน VAT (บาท)</label><input type="text" id="sales_excl_vat" inputmode="decimal" placeholder="เช่น 500000" value="500000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="purchases_excl_vat" class="block text-sm font-medium text-gray-700 mb-1">ยอดซื้อก่อน VAT (บาท)</label><input type="text" id="purchases_excl_vat" inputmode="decimal" placeholder="เช่น 300000" value="300000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="vat_rate" class="block text-sm font-medium text-gray-700 mb-1">อัตรา VAT (%)</label><input type="number" id="vat_rate" min="0" max="20" placeholder="7" value="7" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">Output VAT (เก็บจากลูกค้า)</p>
            <p id="output_vat" class="font-bold">-</p>
          </div>
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">Input VAT (จ่ายให้ผู้ขาย)</p>
            <p id="input_vat" class="font-bold">-</p>
          </div>
          <div class="bg-indigo-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">VAT ที่ต้องนำส่งสรรพากร</p>
            <p id="vat_payable" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const sales = parseFloat((document.getElementById('sales_excl_vat') as HTMLInputElement).value) || 0;
      const purchases = parseFloat((document.getElementById('purchases_excl_vat') as HTMLInputElement).value) || 0;
      const vatRate = parseFloat((document.getElementById('vat_rate') as HTMLInputElement).value) || 7;

      const outputVat = sales * (vatRate / 100);
      const inputVat = purchases * (vatRate / 100);
      const vatPayable = Math.max(0, outputVat - inputVat);

      (document.getElementById('output_vat') as HTMLElement).textContent = outputVat.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('input_vat') as HTMLElement).textContent = inputVat.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('vat_payable') as HTMLElement).textContent = vatPayable.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('business-vat');
    });
    document.getElementById('btn')!.click();
  </script>

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.rd.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมสรรพากร (rd.go.th)</a> — ระบบภาษีมูลค่าเพิ่ม (VAT) 7%</li>
        <li><a href="https://www.rd.go.th/publish/27415.0.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">คู่มือ VAT สำหรับผู้ประกอบการ — กรมสรรพากร</a></li>
      </ul>
    </div>
</BaseLayout>
