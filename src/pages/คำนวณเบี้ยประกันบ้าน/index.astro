---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเบี้ยประกันบ้าน 2569 | ทรัพย์สินและสิ่งปลูกสร้าง | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันอัคคีภัยบ้านและทรัพย์สินภายใน พร้อมความคุ้มครองน้ำท่วม ลมพายุ และโจรกรรม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเบี้ยประกันบ้าน/`;

const faqData = [
  {
    question: 'ประกันบ้านต่างจากประกันอัคคีภัยธรรมดาอย่างไร?',
    answer: 'ประกันบ้านเป็นแบบรวมที่ครอบคลุมหลายความเสี่ยงในกรมธรรม์เดียว ได้แก่ ไฟไหม้ ฟ้าผ่า ระเบิด ลมพายุ น้ำท่วม แผ่นดินไหว และโจรกรรม ส่วนประกันอัคคีภัยพื้นฐานคุ้มครองเฉพาะไฟไหม้ ฟ้าผ่า และระเบิดเท่านั้น',
  },
  {
    question: 'ควรทำประกันบ้านวงเงินเท่าไหร่?',
    answer: 'ควรทำประกันบ้านในมูลค่าที่ต้องใช้สร้างใหม่ทั้งหลัง (ไม่ใช่ราคาตลาด) ซึ่งขึ้นอยู่กับขนาดบ้านและวัสดุก่อสร้าง โดยทั่วไปใช้ต้นทุนก่อสร้างประมาณ 8,000-15,000 บาท/ตรม. สำหรับบ้านทั่วไป',
  },
  {
    question: 'ทรัพย์สินภายในบ้านควรทำประกันแยกไหม?',
    answer: 'ควรทำประกันแยกสำหรับทรัพย์สินภายในที่มีมูลค่าสูง เช่น เฟอร์นิเจอร์ เครื่องใช้ไฟฟ้า อุปกรณ์อิเล็กทรอนิกส์ โดยควรทำรายการทรัพย์สินและมูลค่าทั้งหมดไว้ และทำประกันให้ครอบคลุมมูลค่าทดแทน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเบี้ยประกันบ้าน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเบี้ยประกันบ้าน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณเบี้ยประกันบ้าน 2569</p>
      <p class="mt-1 text-sm text-slate-700">ตัวเลขเป็นการประมาณการ เพื่อใช้วางแผนเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเบี้ยประกันบ้าน 2569 — อาคารและทรัพย์สิน
    </h1>

    <p class="text-gray-600 mb-6">
      ประมาณเบี้ยประกันบ้านและทรัพย์สินภายใน รวมความคุ้มครองเพิ่มเติมตามต้องการ
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="home-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="home-building" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าตัวบ้าน/สิ่งปลูกสร้าง (บาท)</label>
            <input type="text" id="home-building" inputmode="numeric" placeholder="เช่น 3,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="home-building-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="home-contents" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าทรัพย์สินภายใน (บาท)</label>
            <input type="text" id="home-contents" inputmode="numeric" placeholder="เช่น 500,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <div>
          <label for="home-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทบ้าน</label>
          <select id="home-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white sm:w-64">
            <option value="detached">บ้านเดี่ยว</option>
            <option value="townhouse" selected>ทาวน์เฮาส์</option>
            <option value="twin">บ้านแฝด</option>
          </select>
        </div>

        <div>
          <p class="block text-sm font-medium text-gray-700 mb-2">ความคุ้มครองเพิ่มเติม</p>
          <div class="space-y-2">
            <label class="flex items-center gap-2">
              <input type="checkbox" id="home-flood" class="rounded" />
              <span class="text-sm">น้ำท่วม (+0.05%)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" id="home-storm" class="rounded" />
              <span class="text-sm">ลมพายุ (+0.02%)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" id="home-theft" class="rounded" />
              <span class="text-sm">โจรกรรม (+0.08%)</span>
            </label>
          </div>
        </div>

        <button type="submit" id="home-submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ (ประมาณการ)</h2>
        <div class="space-y-2 mb-4">
          <div class="flex justify-between py-2 border-b border-gray-100"><span class="text-gray-600">เบี้ยอาคาร</span><span id="res-building" class="font-medium">-</span></div>
          <div class="flex justify-between py-2 border-b border-gray-100"><span class="text-gray-600">เบี้ยทรัพย์สิน</span><span id="res-contents" class="font-medium">-</span></div>
          <div class="flex justify-between py-2 border-b border-gray-100"><span class="text-gray-600">ความเสี่ยงเพิ่มเติม</span><span id="res-extra" class="font-medium">-</span></div>
          <div class="flex justify-between py-3 bg-primary-50 px-3 rounded-lg">
            <span class="font-bold">รวมเบี้ยรายปี</span>
            <span id="res-total" class="text-xl font-bold text-primary-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">อัตราเบี้ยประกันบ้าน (ประมาณการ)</h2>
      <p>เบี้ยอาคาร: 0.10% ของมูลค่าอาคาร | เบี้ยทรัพย์สิน: 0.15% | น้ำท่วม: +0.05% | ลมพายุ: +0.02% | โจรกรรม: +0.08%</p>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedCalculators currentHref="/คำนวณเบี้ยประกันบ้าน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงต้องสอบถามบริษัทประกันภัยโดยตรง
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n) + ' บาท'; }

    const form = document.getElementById('home-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    function setErr(id: string, msg: string) { const el = document.getElementById(id); if (el) { el.textContent = msg; el.classList.remove('hidden'); } }
    function clearErr(id: string) { const el = document.getElementById(id); if (el) { el.textContent = ''; el.classList.add('hidden'); } }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearErr('home-building-error');

      const building = parseNum((document.getElementById('home-building') as HTMLInputElement).value);
      const contents = parseNum((document.getElementById('home-contents') as HTMLInputElement).value);
      const flood = (document.getElementById('home-flood') as HTMLInputElement).checked;
      const storm = (document.getElementById('home-storm') as HTMLInputElement).checked;
      const theft = (document.getElementById('home-theft') as HTMLInputElement).checked;

      if (building <= 0) { setErr('home-building-error', 'กรุณากรอกมูลค่าอาคาร'); return; }

      trackCalculatorStart('home-insurance-premium');

      const buildingPremium = building * 0.001;
      const contentsPremium = contents * 0.0015;
      let extraRate = 0;
      if (flood) extraRate += 0.0005;
      if (storm) extraRate += 0.0002;
      if (theft) extraRate += 0.0008;
      const extraPremium = (building + contents) * extraRate;
      const total = buildingPremium + contentsPremium + extraPremium;

      (document.getElementById('res-building') as HTMLElement).textContent = fmt(buildingPremium);
      (document.getElementById('res-contents') as HTMLElement).textContent = contents > 0 ? fmt(contentsPremium) : 'ไม่รวม';
      (document.getElementById('res-extra') as HTMLElement).textContent = extraRate > 0 ? fmt(extraPremium) : 'ไม่เพิ่ม';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(total);

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('home-insurance-premium');
      trackCalculatorUsed('home-insurance-premium');
    });
  </script>
</BaseLayout>
