---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณและเปรียบเทียบค่าโฮสติ้ง Website Hosting ปี 2569';
const pageDescription = 'เปรียบเทียบค่าโฮสติ้งเวบไซต์ Shared Hosting VPS Dedicated Server พร้อมคำนวณค่าใช้จ่ายรายปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-เปรียบเทียบค่าโฮสติ้ง/`;

const faqData = [
  {
    question: 'ค่าโฮสติ้งมีประเภทใดบ้าง?',
    answer: 'มี 3 ประเภทหลัก: Shared Hosting (แชร์เซิร์ฟเวอร์) VPS (เซิร์ฟเวอร์เสมือน) และ Dedicated Server (เซิร์ฟเวอร์เฉพาะเจาะจง)',
  },
  {
    question: 'เลือกประเภทไหนเหมาะสมสำหรับธุรกิจเล็ก?',
    answer: 'สำหรับเริ่มต้นใช้ Shared Hosting เพราะราคาถูก เมื่อแสดงว่าจำเป็นให้อัปเกรดเป็น VPS',
  },
  {
    question: 'ต้องคำนึงถึงปัจจัยอะไรในการเลือกโฮสติ้ง?',
    answer: 'Uptime ความเร็ว Customer Support Storage และ Bandwidth ราคารายปีและนโยบายการต่ออายุ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าโฮสติ้ง',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-เปรียบเทียบค่าโฮสติ้ง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-cyan-100 bg-cyan-50 p-4">
      <p class="text-sm font-semibold text-cyan-700">คำนวณค่าโฮสติ้ง — เปรียบเทียบค่าใช้จ่ายเว็บโฮสติ้ง</p>
      <p class="mt-1 text-sm text-slate-700">ป้อนค่าโฮสติ้งรายเดือนเพื่อคำนวณค่าใช้จ่ายรายปี</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าโฮสติ้งเว็บไซต์ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนค่าโฮสติ้งของแต่ละแพลน เพื่อเปรียบเทียบและคำนวณค่าใช้จ่ายรายปี
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="hosting-form" class="space-y-5">
        <p id="hosting-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="shared" class="mb-1 block text-sm font-medium text-gray-700">Shared Hosting (บาท/เดือน)</label>
            <input type="text" id="shared" inputmode="decimal" placeholder="เช่น 99"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="vps" class="mb-1 block text-sm font-medium text-gray-700">VPS (บาท/เดือน)</label>
            <input type="text" id="vps" inputmode="decimal" placeholder="เช่น 299"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="dedicated" class="mb-1 block text-sm font-medium text-gray-700">Dedicated (บาท/เดือน)</label>
            <input type="text" id="dedicated" inputmode="decimal" placeholder="เช่น 999"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          เปรียบเทียบค่าใช้จ่ายรายปี
        </button>
      </form>
    </div>

    <!-- Results Section -->
    <div id="hosting-results" class="mb-8 hidden rounded-lg border border-green-200 bg-green-50 p-6">
      <h2 class="mb-4 text-lg font-bold text-gray-900">ผลการเปรียบเทียบรายปี</h2>
      <div class="space-y-2">
        <div class="flex justify-between border-b border-green-200 pb-2">
          <span class="text-gray-700">Shared Hosting</span>
          <span id="result-shared" class="font-semibold text-gray-900">0 บาท</span>
        </div>
        <div class="flex justify-between border-b border-green-200 pb-2">
          <span class="text-gray-700">VPS</span>
          <span id="result-vps" class="font-semibold text-gray-900">0 บาท</span>
        </div>
        <div class="flex justify-between bg-green-100 p-2 rounded font-bold">
          <span class="text-green-700">Dedicated Server</span>
          <span id="result-dedicated" class="text-green-700">0 บาท</span>
        </div>
      </div>
    </div>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="mb-4 text-lg font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="border-b border-gray-200 pb-4">
            <summary class="cursor-pointer font-semibold text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <p class="mt-2 text-sm text-gray-600">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <GuardedAdSlot position="after-content" class="my-8" />
  <RelatedCalculators currentPath="/คำนวณ-เปรียบเทียบค่าโฮสติ้ง/" limit={3} />
  <RelatedArticles limit={3} />
</BaseLayout>

<script>
  const form = document.getElementById('hosting-form') as HTMLFormElement;
  const resultsDiv = document.getElementById('hosting-results') as HTMLDivElement;
  const errorDiv = document.getElementById('hosting-error') as HTMLDivElement;

  const sharedInput = document.getElementById('shared') as HTMLInputElement;
  const vpsInput = document.getElementById('vps') as HTMLInputElement;
  const dedicatedInput = document.getElementById('dedicated') as HTMLInputElement;

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');

      const shared = sharedInput.value ? parseFloat(sharedInput.value.trim()) : 0;
      const vps = vpsInput.value ? parseFloat(vpsInput.value.trim()) : 0;
      const dedicated = dedicatedInput.value ? parseFloat(dedicatedInput.value.trim()) : 0;

      if (shared === 0 && vps === 0 && dedicated === 0) {
        errorDiv.classList.remove('hidden');
        resultsDiv.classList.add('hidden');
        return;
      }

      const sharedYearly = Math.round(shared * 12 * 100) / 100;
      const vpsYearly = Math.round(vps * 12 * 100) / 100;
      const dedicatedYearly = Math.round(dedicated * 12 * 100) / 100;

      document.getElementById('result-shared')!.textContent = sharedYearly.toLocaleString('th-TH', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }) + ' บาท';
      document.getElementById('result-vps')!.textContent = vpsYearly.toLocaleString('th-TH', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }) + ' บาท';
      document.getElementById('result-dedicated')!.textContent = dedicatedYearly.toLocaleString('th-TH', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }) + ' บาท';

      resultsDiv.classList.remove('hidden');
    });
  }
</script>
