---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเงินบำนาญรายปี (Annuity) 2569 | จ่ายรายปีจากกองทุนบำนาญ | Kamnuanlek';
const pageDescription = 'คำนวณเงินบำนาญรายปีหรือรายเดือนจากกองทุนบำนาญ ตามระยะเวลาและอัตราดอกเบี้ย คำนวณทั้งแบบ ordinary annuity และ annuity due สำหรับวางแผนเกษียณ อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินบำนาญรายปี/`;

const faqData = [
  {
    question: 'Ordinary Annuity กับ Annuity Due ต่างกันอย่างไร?',
    answer: 'Ordinary Annuity จ่ายเงินปลายงวด (สิ้นปีหรือสิ้นเดือน) เช่น บำนาญจากประกันชีวิตส่วนใหญ่ ส่วน Annuity Due จ่ายเงินต้นงวด (ต้นปีหรือต้นเดือน) ซึ่งได้รับเงินก่อนและมีเวลาลงทุนนานกว่า ทำให้จำนวนเงินต่องวดต่ำกว่า Ordinary Annuity เล็กน้อย',
  },
  {
    question: 'กองทุนบำนาญ 3 ล้านบาทจ่ายรายเดือนได้เท่าไร?',
    answer: 'ตัวอย่าง: กองทุน 3,000,000 บาท ดอกเบี้ย 4% ต่อปี ระยะเวลาจ่าย 20 ปี แบบ Ordinary ราย เดือน: จ่ายประมาณ 18,200 บาท/เดือน รวม 4,368,000 บาทตลอดระยะเวลา ดอกเบี้ยที่ใช้ 1,368,000 บาท',
  },
  {
    question: 'ความถี่การจ่ายมีผลต่อยอดเงินต่องวดอย่างไร?',
    answer: 'ความถี่รายเดือนให้ยอดต่องวดน้อยกว่ารายปี แต่รวมทั้งหมดเท่ากัน การจ่ายรายเดือนช่วยการวางแผนกระแสเงินสดรายเดือน ขณะที่รายปีเหมาะสำหรับค่าใช้จ่ายก้อนใหญ่ประจำปี',
  },
  {
    question: 'ควรเลือกระยะเวลาจ่ายบำนาญกี่ปี?',
    answer: 'แนะนำให้เลือกระยะเวลาให้ครอบคลุมอายุขัยที่คาดหวัง หากเกษียณ 60 ปีและคาดอายุขัย 85 ปี ควรเลือกระยะเวลา 25 ปี การเลือกระยะเวลานานกว่าจะทำให้ยอดรับต่องวดน้อยลง แต่มีความปลอดภัยมากขึ้น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินบำนาญรายปี (Annuity)',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินบำนาญรายปี">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเงินบำนาญรายปี (Annuity) 2569 — จ่ายรายปีจากกองทุนบำนาญ
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณเงินบำนาญรายปีหรือรายเดือนจากกองทุนบำนาญ รองรับทั้งแบบ Ordinary Annuity (จ่ายปลายงวด) และ Annuity Due (จ่ายต้นงวด) พร้อมตารางการจ่ายเงิน
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="annuity-form" class="space-y-5">
        <p id="annuity-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div>
          <label for="annuity-principal" class="block text-sm font-medium text-gray-700 mb-1">
            เงินต้นกองทุนบำนาญ (บาท)
          </label>
          <input
            type="text"
            id="annuity-principal"
            inputmode="numeric"
            placeholder="เช่น 3,000,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p id="annuity-principal-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="annuity-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราดอกเบี้ย (% ต่อปี)
            </label>
            <input
              type="text"
              id="annuity-rate"
              inputmode="decimal"
              placeholder="เช่น 4"
              value="4"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="annuity-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาจ่าย (ปี)
            </label>
            <input
              type="number"
              id="annuity-years"
              min="1"
              max="60"
              value="20"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">ประเภท Annuity</label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2">
                <input type="radio" name="annuity-type" value="ordinary" checked class="w-4 h-4 text-primary-600" />
                <span class="text-sm text-gray-700">Ordinary (จ่ายปลายงวด)</span>
              </label>
              <label class="flex items-center gap-2">
                <input type="radio" name="annuity-type" value="due" class="w-4 h-4 text-primary-600" />
                <span class="text-sm text-gray-700">Annuity Due (จ่ายต้นงวด)</span>
              </label>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">ความถี่การจ่าย</label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2">
                <input type="radio" name="annuity-frequency" value="monthly" checked class="w-4 h-4 text-primary-600" />
                <span class="text-sm text-gray-700">รายเดือน</span>
              </label>
              <label class="flex items-center gap-2">
                <input type="radio" name="annuity-frequency" value="annual" class="w-4 h-4 text-primary-600" />
                <span class="text-sm text-gray-700">รายปี</span>
              </label>
            </div>
          </div>
        </div>

        <button
          type="submit"
          id="annuity-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณเงินบำนาญ</h2>

        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1" id="res-annuity-pmt-label">เงินจ่ายต่องวด</div>
            <div id="res-annuity-pmt" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รวมจ่ายทั้งหมด</div>
            <div id="res-annuity-total" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-yellow-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยที่ใช้ไป</div>
            <div id="res-annuity-interest-used" class="text-xl font-bold text-yellow-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm mb-4">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินต้น</span>
            <span id="res-annuity-principal" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">อัตราดอกเบี้ย</span>
            <span id="res-annuity-rate-display" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ระยะเวลา</span>
            <span id="res-annuity-duration" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ประเภท</span>
            <span id="res-annuity-type-display" class="font-medium">-</span>
          </div>
        </div>

        <!-- Payment schedule -->
        <details class="mt-4">
          <summary class="cursor-pointer font-semibold text-gray-900 hover:text-primary-600 mb-2">
            ตารางการจ่ายเงิน (คลิกเพื่อดู)
          </summary>
          <div class="overflow-x-auto mt-2">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-gray-500 border-b border-gray-200">
                  <th class="py-2 pr-4">งวดที่</th>
                  <th class="py-2 pr-4 text-right">ดอกเบี้ย</th>
                  <th class="py-2 pr-4 text-right">จ่ายเงินต้น</th>
                  <th class="py-2 text-right">เงินต้นคงเหลือ</th>
                </tr>
              </thead>
              <tbody id="annuity-schedule-body"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรคำนวณเงินบำนาญรายปี (Annuity)</h2>
      <p>
        การคำนวณเงินบำนาญใช้สูตร Present Value of Annuity เพื่อหายอดเงินจ่ายต่องวดจากเงินต้นที่กำหนด
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">Ordinary Annuity</h3>
      <p>
        PMT = PV × r ÷ [1 - (1+r)^(-n)]<br/>
        โดย PV = เงินต้น, r = อัตราดอกเบี้ยต่องวด, n = จำนวนงวดทั้งหมด
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">Annuity Due</h3>
      <p>
        PMT (Due) = PMT (Ordinary) ÷ (1 + r)<br/>
        เนื่องจากรับเงินต้นงวด เงินจึงลงทุนได้นานกว่า ทำให้ยอดต่องวดน้อยกว่า Ordinary เล็กน้อย
      </p>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณเงินบำนาญรายปี/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางการเงิน ควรปรึกษาผู้เชี่ยวชาญก่อนตัดสินใจ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('annuity-form') as HTMLFormElement;
    const formError = document.getElementById('annuity-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const principal = parseNum((document.getElementById('annuity-principal') as HTMLInputElement).value);
      const annualRate = parseNum((document.getElementById('annuity-rate') as HTMLInputElement).value) || 4;
      const years = parseInt((document.getElementById('annuity-years') as HTMLInputElement).value) || 20;
      const annuityType = (document.querySelector('input[name="annuity-type"]:checked') as HTMLInputElement).value;
      const frequency = (document.querySelector('input[name="annuity-frequency"]:checked') as HTMLInputElement).value;

      if (principal <= 0) {
        formError.classList.remove('hidden');
        (document.getElementById('annuity-principal') as HTMLInputElement).focus();
        return;
      }

      trackCalculatorStart('annuity');

      const periodsPerYear = frequency === 'monthly' ? 12 : 1;
      const r = annualRate / 100 / periodsPerYear;
      const n = years * periodsPerYear;

      let ordinaryPMT: number;
      if (Math.abs(r) < 0.0000001) {
        ordinaryPMT = principal / n;
      } else {
        ordinaryPMT = principal * r / (1 - Math.pow(1 + r, -n));
      }

      const pmt = annuityType === 'due' ? ordinaryPMT / (1 + r) : ordinaryPMT;
      const totalPaid = pmt * n;
      const interestUsed = totalPaid - principal;

      const pmtLabel = frequency === 'monthly' ? 'เงินจ่ายต่อเดือน' : 'เงินจ่ายต่อปี';
      (document.getElementById('res-annuity-pmt-label') as HTMLElement).textContent = pmtLabel;
      (document.getElementById('res-annuity-pmt') as HTMLElement).textContent = fmt(pmt) + ' บาท';
      (document.getElementById('res-annuity-total') as HTMLElement).textContent = fmt(totalPaid) + ' บาท';
      (document.getElementById('res-annuity-interest-used') as HTMLElement).textContent = fmt(interestUsed) + ' บาท';
      (document.getElementById('res-annuity-principal') as HTMLElement).textContent = fmt(principal) + ' บาท';
      (document.getElementById('res-annuity-rate-display') as HTMLElement).textContent = annualRate.toFixed(2) + '% ต่อปี';
      (document.getElementById('res-annuity-duration') as HTMLElement).textContent = years + ' ปี (' + n + ' งวด)';
      (document.getElementById('res-annuity-type-display') as HTMLElement).textContent = annuityType === 'ordinary' ? 'Ordinary Annuity' : 'Annuity Due';

      // Build payment schedule (limit to 120 rows for display)
      const tbody = document.getElementById('annuity-schedule-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      let balance = principal;
      const maxRows = Math.min(n, 120);
      for (let i = 1; i <= maxRows; i++) {
        const interest = balance * r;
        const principal_payment = pmt - interest;
        balance = Math.max(0, balance - principal_payment);
        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';
        tr.innerHTML = `
          <td class="py-2 pr-4 text-gray-600">${i}</td>
          <td class="py-2 pr-4 text-right">${fmt(interest)}</td>
          <td class="py-2 pr-4 text-right">${fmt(principal_payment)}</td>
          <td class="py-2 text-right">${fmt(balance)}</td>
        `;
        tbody.appendChild(tr);
      }
      if (n > maxRows) {
        const tr = document.createElement('tr');
        tr.innerHTML = `<td colspan="4" class="py-2 text-center text-gray-500 text-xs">แสดง ${maxRows} งวดแรกจากทั้งหมด ${n} งวด</td>`;
        tbody.appendChild(tr);
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('annuity');
      trackCalculatorUsed('annuity');
    });
  </script>
</BaseLayout>
