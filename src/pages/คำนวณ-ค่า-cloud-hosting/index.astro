---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ ค่า Cloud Hosting 2569 | Kamnuanlek';
const pageDescription = 'คำนวณและเปรียบเทียบค่า Cloud Hosting (AWS, GCP, Azure, Linode)';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่า-cloud-hosting/`;

const faqData = [
  {
    question: 'Cloud Hosting ไหนถูกที่สุด?',
    answer: 'AWS: แพง แต่ Scalable ดี GCP: Free Tier ดี Azure: Windows ดี Linode: ถูก ใช้ง่าย DigitalOcean: ง่ายที่สุด $5-300/เดือน',
  },
  {
    question: 'ควรเลือก Platform ไหน?',
    answer: 'Startup: Linode/DO ราคาถูก Simple App: AWS/GCP ถ้า complex High Traffic: AWS/GCP Scalability ดี',
  },
  {
    question: 'ค่า Bandwidth แพงไหม?',
    answer: 'AWS: $0.09/GB Out GCP: $0.12/GB Linode: First 1TB ฟรี หลัง $0.05/GB ตรวจสอบ Egress ให้ดี',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่า Cloud Hosting',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่า Cloud Hosting">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      ☁️ คำนวณค่า Cloud Hosting
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณและเปรียบเทียบค่า Cloud Hosting
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="hosting-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="compute-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Compute/เดือน (บาท)
            </label>
            <input
              type="text"
              id="compute-cost"
              inputmode="numeric"
              placeholder="เช่น 5000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="storage-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Storage/เดือน (บาท)
            </label>
            <input
              type="text"
              id="storage-cost"
              inputmode="numeric"
              placeholder="เช่น 500"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="bandwidth-cost" class="block text-sm font-medium text-gray-700 mb-1">
            ค่า Bandwidth/เดือน (บาท)
          </label>
          <input
            type="text"
            id="bandwidth-cost"
            inputmode="numeric"
            placeholder="เช่น 500"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณค่า
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่า/เดือน</div>
            <div id="res-monthly" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่า/ปี</div>
            <div id="res-annual" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ต่อหน่วย Traffic</div>
            <div id="res-per-gb" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-ค่า-cloud-hosting/" />
    <RelatedCalculators currentHref="/คำนวณ-ค่า-cloud-hosting/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('hosting-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const computeCost = parseNum((document.getElementById('compute-cost') as HTMLInputElement).value);
      const storageCost = parseNum((document.getElementById('storage-cost') as HTMLInputElement).value);
      const bandwidthCost = parseNum((document.getElementById('bandwidth-cost') as HTMLInputElement).value);

      if (computeCost <= 0) { (document.getElementById('compute-cost') as HTMLInputElement).focus(); return; }

      const monthly = computeCost + storageCost + bandwidthCost;
      const annual = monthly * 12;
      const perGb = bandwidthCost > 0 ? bandwidthCost / 1000 : 0;

      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthly) + ' บาท';
      (document.getElementById('res-annual') as HTMLElement).textContent = fmt(annual) + ' บาท';
      (document.getElementById('res-per-gb') as HTMLElement).textContent = fmt(perGb) + ' บาท/GB';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('cloud-hosting-cost');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('cloud-hosting-cost');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
