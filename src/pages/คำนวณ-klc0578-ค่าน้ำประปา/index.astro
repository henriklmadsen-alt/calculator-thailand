---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าน้ำประปา | Calculator Thailand';
const pageDescription = 'คำนวณค่าน้ำประปารายเดือน ค่าบริการ ค่าระบายน้ำ ภาษีสาธารณูปโภค';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0578-ค่าน้ำประปา/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าน้ำประปา">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าน้ำประปา</h1>
    <div class="mb-4 inline-block rounded-lg border border-cyan-200 bg-cyan-50 px-3 py-2"><p class="text-xs font-semibold text-cyan-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าน้ำประปารายเดือน BMA/PWA ค่าระบายน้ำ ค่าบริการ</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="usage" class="block text-sm font-medium text-gray-700 mb-1">ปริมาณน้ำ (ลบ.ม./เดือน)</label><input type="text" id="usage" inputmode="decimal" placeholder="เช่น 20" value="20" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="region" class="block text-sm font-medium text-gray-700 mb-1">ท้องถิ่น</label><select id="region" class="w-full px-3 py-2 border border-gray-300 rounded-md"><option value="bma">BMA (กรุงเทพ)</option><option value="pwa">PWA (นอกกรุงเทพ)</option></select></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-cyan-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ค่าน้ำ</p><p id="water" class="font-bold">-</p></div><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ค่าระบายน้ำ</p><p id="drain" class="font-bold">-</p></div><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ค่าบริการ</p><p id="service" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รวมทั้งสิ้น</p><p id="total" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const usage = parseFloat((document.getElementById('usage') as HTMLInputElement).value) || 0;
      const region = (document.getElementById('region') as HTMLSelectElement).value;
      if (usage <= 0) return;
      const rates = region === 'bma' ? { tier1: [1, 8.32], tier2: [10, 11.5], tier3: [20, 13.5] } : { tier1: [1, 6.5], tier2: [15, 8], tier3: [25, 10] };
      let water = 0;
      if (usage <= rates.tier1[0]) water = usage * rates.tier1[1];
      else if (usage <= rates.tier2[0]) water = rates.tier1[0] * rates.tier1[1] + (usage - rates.tier1[0]) * rates.tier2[1];
      else water = rates.tier1[0] * rates.tier1[1] + (rates.tier2[0] - rates.tier1[0]) * rates.tier2[1] + (usage - rates.tier2[0]) * rates.tier3[1];
      const drain = usage * (region === 'bma' ? 5.32 : 4), service = 27, total = water + drain + service;
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('water') as HTMLElement).textContent = fmt(water);
      (document.getElementById('drain') as HTMLElement).textContent = fmt(drain);
      (document.getElementById('service') as HTMLElement).textContent = fmt(service);
      (document.getElementById('total') as HTMLElement).textContent = fmt(total);
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('water-bill');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
