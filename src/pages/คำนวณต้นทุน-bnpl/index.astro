---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณต้นทุน BNPL ผ่อน 0% 2569 | Calculator Thailand';
const pageDescription = 'คำนวณต้นทุนที่แท้จริงของ BNPL (Buy Now Pay Later) และผ่อน 0% ผ่านบัตรเครดิต เปิดเผยดอกเบี้ยซ่อนเร้น ค่าธรรมเนียม และต้นทุนจริงต่อปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุน-bnpl/`;

const faqData = [
  {
    question: 'BNPL (Buy Now Pay Later) คืออะไร?',
    answer: 'BNPL คือบริการซื้อก่อนจ่ายทีหลัง แบ่งชำระเป็นงวด มักโฆษณาว่า "ไม่มีดอกเบี้ย" แต่อาจมีค่าธรรมเนียมแอบแฝง หรือราคาสินค้าที่สูงกว่าราคาเงินสด ผู้ให้บริการในไทย เช่น Akulaku, Kredit Plus, บัตรเครดิตแบบ 0% ของธนาคาร',
  },
  {
    question: 'ผ่อน 0% จริงหรือมีต้นทุนซ่อนเร้น?',
    answer: 'ผ่อน 0% มักมีเงื่อนไข เช่น ต้องมีบัตรเครดิตเฉพาะ ราคาสินค้าอาจสูงกว่าราคาเงินสด ค่าธรรมเนียมแลกคะแนนสะสม หรือดอกเบี้ยย้อนหลัง 100% หากไม่จ่ายครบตามกำหนด ต้องอ่านเงื่อนไขให้ละเอียด',
  },
  {
    question: 'BNPL vs บัตรเครดิตปกติ อะไรดีกว่า?',
    answer: 'ขึ้นอยู่กับพฤติกรรมการจ่าย BNPL เหมาะกับผู้ที่ไม่มีบัตรเครดิตหรือต้องการแบ่งชำระแบบมีวินัย บัตรเครดิตให้ความยืดหยุ่นกว่าแต่หากจ่ายไม่ครบจะเสียดอกเบี้ย 16-28% ต่อปี ต้องประเมินตามสถานการณ์',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุน BNPL',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุน BNPL">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      คำนวณต้นทุน BNPL และผ่อน 0% — เปิดเผยต้นทุนที่แท้จริง
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">คำนวณต้นทุนจริงของการผ่อน BNPL เปรียบเทียบกับการจ่ายเงินสด</p>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6 mb-8">
      <form id="bnpl-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="cash-price" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ราคาเงินสด (บาท)</label>
            <input type="text" id="cash-price" inputmode="numeric" placeholder="เช่น 10,000"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
          <div>
            <label for="bnpl-price" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ราคาผ่อน BNPL (บาท)</label>
            <input type="text" id="bnpl-price" inputmode="numeric" placeholder="เช่น 10,500"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
            <p class="text-xs text-gray-500 mt-1">ใส่เท่ากับราคาเงินสดถ้าไม่มีราคาต่างกัน</p>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="installments" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">จำนวนงวด</label>
            <input type="text" id="installments" inputmode="numeric" placeholder="เช่น 6"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
          <div>
            <label for="fee-per-month" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ค่าธรรมเนียม/งวด (บาท)</label>
            <input type="text" id="fee-per-month" inputmode="numeric" placeholder="0"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
        </div>
        <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-4">
          <div class="bg-primary-50 dark:bg-primary-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ค่างวด/เดือน</div>
            <div id="res-installment" class="text-xl font-bold text-primary-700 dark:text-primary-300">-</div>
          </div>
          <div class="bg-red-50 dark:bg-red-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ต้นทุนส่วนเกิน</div>
            <div id="res-extra" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="bg-orange-50 dark:bg-orange-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">EIR ที่แท้จริง</div>
            <div id="res-eir" class="text-xl font-bold text-orange-700 dark:text-orange-300">-</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ชำระรวมทั้งหมด</div>
            <div id="res-total" class="text-xl font-bold text-gray-700 dark:text-gray-300">-</div>
          </div>
        </div>
        <div id="verdict" class="p-3 rounded-lg text-sm"></div>
      </div>
    </div>

    <GuardedAdSlot />

    <section class="prose prose-gray dark:prose-invert max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-3">BNPL มีต้นทุนซ่อนเร้นอะไรบ้าง?</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700 dark:text-gray-300">
        <li><strong>ราคาสินค้าสูงกว่า:</strong> ราคาผ่อนอาจสูงกว่าราคาเงินสด 3-10%</li>
        <li><strong>ค่าธรรมเนียมรายงวด:</strong> บางแพลตฟอร์มเก็บ 0.5-1.5% ต่อเดือน</li>
        <li><strong>ดอกเบี้ยย้อนหลัง:</strong> หากชำระไม่ตรงเวลา อาจถูกคิดดอกเบี้ยย้อนหลัง 100%</li>
        <li><strong>ต้นทุนโอกาส:</strong> เงินที่ต้องผ่อนจ่ายอาจนำไปลงทุนที่ให้ผลตอบแทนดีกว่า</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 dark:text-gray-100 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600 dark:text-gray-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณต้นทุน-bnpl/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุน-bnpl/" />

    <div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg text-sm text-yellow-800 dark:text-yellow-300">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ เงื่อนไขจริงขึ้นอยู่กับผู้ให้บริการ
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }

    function estimateEIR(principal: number, monthly: number, n: number): number {
      if (monthly <= 0 || n <= 0) return 0;
      let r = 0.01;
      for (let i = 0; i < 100; i++) {
        const pow = Math.pow(1 + r, n);
        const f = monthly * (pow - 1) / (r * pow) - principal;
        const df = monthly * ((pow - 1) * (-1) / (r * r * pow) + n * Math.pow(1 + r, n - 1) / (r * pow) - (pow - 1) * n * Math.pow(1 + r, n - 1) / (r * pow * pow));
        if (Math.abs(df) < 1e-15) break;
        const rNew = r - f / df;
        if (Math.abs(rNew - r) < 1e-10) { r = rNew; break; }
        r = Math.max(0.0001, rNew);
      }
      return r * 12 * 100;
    }

    document.getElementById('bnpl-form')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const cashPrice = parseNum((document.getElementById('cash-price') as HTMLInputElement).value);
      const bnplPrice = parseNum((document.getElementById('bnpl-price') as HTMLInputElement).value) || cashPrice;
      const n = parseNum((document.getElementById('installments') as HTMLInputElement).value) || 6;
      const feePerMonth = parseNum((document.getElementById('fee-per-month') as HTMLInputElement).value);
      if (!cashPrice) return;

      const installment = bnplPrice / n + feePerMonth;
      const totalPaid = installment * n;
      const extraCost = totalPaid - cashPrice;
      const eir = estimateEIR(cashPrice, installment, n);

      (document.getElementById('res-installment') as HTMLElement).textContent = fmt(installment) + ' บาท';
      (document.getElementById('res-extra') as HTMLElement).textContent = fmt(extraCost) + ' บาท';
      (document.getElementById('res-eir') as HTMLElement).textContent = eir > 0.01 ? eir.toFixed(2) + '%/ปี' : '~0%/ปี';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(totalPaid) + ' บาท';

      const verdict = document.getElementById('verdict') as HTMLElement;
      if (extraCost <= 0) {
        verdict.className = 'p-3 rounded-lg text-sm bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-300';
        verdict.textContent = 'ต้นทุน BNPL เท่ากับราคาเงินสด — เป็นการผ่อนที่ไม่มีต้นทุนเพิ่ม';
      } else {
        verdict.className = 'p-3 rounded-lg text-sm bg-orange-50 dark:bg-orange-900/20 text-orange-800 dark:text-orange-300';
        verdict.textContent = `การผ่อน BNPL ทำให้คุณจ่ายเพิ่ม ${fmt(extraCost)} บาท เทียบกับราคาเงินสด`;
      }

      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('bnpl');
    });
  </script>
</BaseLayout>
