---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณค่าตกแต่งบ้าน 2569 | ประมาณราคาตกแต่งห้อง | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณค่าตกแต่งบ้านออนไลน์ ประมาณราคาตกแต่งแต่ละห้อง เลือกสไตล์มินิมอล โมเดิร์น หรือหรูหรา พร้อมค่าเฟอร์นิเจอร์และค่าแรงช่างตามราคาตลาดไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าตกแต่งบ้าน/`;

const faqData = [
  {
    question: 'ค่าตกแต่งบ้านเฉลี่ยอยู่ที่เท่าไร?',
    answer: 'ราคาเป็นการประมาณจากอัตราตลาดเฉลี่ยในไทย (2568-2569) ราคาจริงขึ้นกับทำเลที่ตั้ง ผู้รับเหมา วัสดุที่เลือก และขอบเขตงานจริง ควรขอใบเสนอราคาจากผู้รับเหมาอย่างน้อย 2-3 ราย',
  },
  {
    question: 'ตกแต่งคอนโดกับบ้านเดี่ยวราคาต่างกันไหม?',
    answer: 'บ้านเดี่ยวมักมีค่าใช้จ่ายสูงกว่าคอนโดประมาณ 10% เพราะมีพื้นที่ภายนอกเพิ่มเติม การขนย้ายวัสดุง่ายกว่าคอนโด แต่มีค่าจัดสวน ทางเดิน และงานภายนอกเพิ่ม ทาวน์เฮาส์อยู่ระหว่างกลาง',
  },
  {
    question: 'ควรเผื่อสำรองเท่าไร?',
    answer: 'หมายเหตุ: ราคาเป็นการประมาณจากอัตราตลาดเฉลี่ยในไทย (2568-2569) ราคาจริงขึ้นกับทำเลที่ตั้ง ผู้รับเหมา วัสดุที่เลือก และขอบเขตงานจริง ควรขอใบเสนอราคาจากผู้รับเหมาอย่างน้อย 2-3 ราย',
  },
  {
    question: 'ห้องครัวและห้องน้ำทำไมแพงกว่าห้องอื่น?',
    answer: 'ห้องครัวมีค่าตัวคูณ 1.3 เท่า เพราะต้องทำเคาน์เตอร์ built-in ระบบท่อน้ำ ไฟฟ้าเพิ่มเติมสำหรับเครื่องใช้ไฟฟ้า ส่วนห้องน้ำมีค่าตัวคูณ 1.5 เท่า เพราะต้องทำกันซึม ปูกระเบื้อง ติดตั้งสุขภัณฑ์ และระบบท่อประปา',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าตกแต่งบ้าน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const rooms = [
  { id: 'living', label: 'ห้องนั่งเล่น', icon: '🛋️', defaultSqm: 25 },
  { id: 'bedroom', label: 'ห้องนอน', icon: '🛏️', defaultSqm: 16 },
  { id: 'kitchen', label: 'ห้องครัว', icon: '🍳', defaultSqm: 12 },
  { id: 'bathroom', label: 'ห้องน้ำ', icon: '🚿', defaultSqm: 6 },
  { id: 'dining', label: 'ห้องทานข้าว', icon: '🍽️', defaultSqm: 12 },
  { id: 'office', label: 'ห้องทำงาน', icon: '💻', defaultSqm: 10 },
  { id: 'balcony', label: 'ระเบียง', icon: '🌿', defaultSqm: 8 },
  { id: 'entrance', label: 'ทางเข้า', icon: '🚪', defaultSqm: 5 },
];
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าตกแต่งบ้าน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณค่าตกแต่งบ้าน 2569 — ประมาณราคาตกแต่งแต่ละห้อง</p>
      <p class="mt-1 text-sm text-slate-700">เลือกห้อง สไตล์ และวัสดุ ระบบจะคำนวณค่าใช้จ่ายเป็นช่วงต่ำ-สูงตามราคาตลาดไทย</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัตราอ้างอิงจากราคาเฉลี่ยผู้รับเหมาตกแต่งภายในไทย ปี 2568-2569</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าตกแต่งบ้าน 2569 — ประมาณราคาต่อห้อง
    </h1>

    <p class="mb-6 text-gray-600">
      เลือกห้องที่ต้องการตกแต่ง กำหนดพื้นที่ เลือกสไตล์การตกแต่ง ระบบจะคำนวณค่าวัสดุ ค่าแรงช่าง
      และค่าเฟอร์นิเจอร์ พร้อมแสดงราคาเป็นช่วงต่ำ-สูงตามอัตราตลาดไทย
    </p>

    <PublicTrustPanel
      lastUpdated="20 เม.ย. 2569"
      sources={[
        'อัตราค่าตกแต่งภายในเฉลี่ยตลาดไทย ปี 2568-2569',
        'ข้อมูลราคาวัสดุและค่าแรงช่างจากผู้รับเหมาตกแต่งภายใน',
      ]}
      assumptions={[
        'ราคาเป็นช่วงประมาณการ (ต่ำ-สูง) ขึ้นอยู่กับวัสดุและผู้รับเหมาจริง',
        'ห้องครัว ×1.3 (งาน built-in ท่อน้ำ) / ห้องน้ำ ×1.5 (กันซึม สุขภัณฑ์)',
        'ค่าเฟอร์นิเจอร์เพิ่ม 20-40% ของค่าตกแต่ง ขึ้นอยู่กับสไตล์',
      ]}
      references={[
        {
          label: 'คำนวณค่าธรรมเนียมโอนบ้าน — เครื่องคำนวณไทย',
          href: '/คำนวณค่าธรรมเนียมโอนบ้าน/',
        },
        {
          label: 'คำนวณผ่อนบ้าน — เครื่องคำนวณไทย',
          href: '/คำนวณผ่อนบ้าน/',
        },
      ]}
    />

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="deco-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          เลือกห้องอย่างน้อย 1 ห้อง
        </p>

        <!-- Room Selector -->
        <fieldset>
          <legend class="mb-3 text-sm font-semibold text-gray-700">ห้องที่ต้องการตกแต่ง</legend>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4" role="group" aria-label="เลือกห้อง">
            {rooms.map((room) => (
              <label
                class="room-card flex cursor-pointer flex-col items-center rounded-lg border-2 border-gray-200 p-3 text-center transition-colors hover:border-primary-300"
                data-room-id={room.id}
              >
                <input type="checkbox" name="rooms" value={room.id} data-default-sqm={room.defaultSqm} class="sr-only" />
                <span class="mb-1 text-2xl">{room.icon}</span>
                <span class="text-sm font-medium text-gray-700">{room.label}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <!-- Dynamic Area Inputs -->
        <div id="area-inputs" class="hidden space-y-3">
          <p class="text-sm font-semibold text-gray-700">พื้นที่แต่ละห้อง (ตร.ม.)</p>
          <div class="grid gap-3 sm:grid-cols-2">
            {rooms.map((room) => (
              <div id={`area-${room.id}`} class="hidden">
                <label for={`sqm-${room.id}`} class="mb-1 block text-sm font-medium text-gray-700">
                  พื้นที่{room.label} (ตร.ม.)
                </label>
                <input
                  id={`sqm-${room.id}`}
                  type="text"
                  inputmode="decimal"
                  placeholder={`เช่น ${room.defaultSqm}`}
                  value={String(room.defaultSqm)}
                  class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
                />
              </div>
            ))}
          </div>
        </div>

        <!-- Decoration Style -->
        <fieldset>
          <legend class="mb-3 text-sm font-semibold text-gray-700">สไตล์การตกแต่ง</legend>
          <div class="grid gap-3 sm:grid-cols-3">
            <label class="style-card flex cursor-pointer flex-col rounded-lg border-2 border-gray-200 p-4 transition-colors hover:border-primary-300">
              <input type="radio" name="style" value="minimal" class="sr-only" />
              <span class="mb-1 text-base font-semibold text-gray-900">มินิมอล</span>
              <span class="text-sm text-gray-500">5,000-10,000 บาท/ตร.ม.</span>
              <span class="mt-1 text-xs text-gray-400">เรียบง่าย ใช้งานได้จริง งบประหยัด</span>
            </label>
            <label class="style-card flex cursor-pointer flex-col rounded-lg border-2 border-primary-500 bg-primary-50 p-4 transition-colors hover:border-primary-300">
              <input type="radio" name="style" value="modern" class="sr-only" checked />
              <span class="mb-1 text-base font-semibold text-gray-900">โมเดิร์น</span>
              <span class="text-sm text-gray-500">10,000-20,000 บาท/ตร.ม.</span>
              <span class="mt-1 text-xs text-gray-400">ทันสมัย วัสดุคุณภาพดี</span>
            </label>
            <label class="style-card flex cursor-pointer flex-col rounded-lg border-2 border-gray-200 p-4 transition-colors hover:border-primary-300">
              <input type="radio" name="style" value="luxury" class="sr-only" />
              <span class="mb-1 text-base font-semibold text-gray-900">หรูหรา</span>
              <span class="text-sm text-gray-500">20,000-40,000 บาท/ตร.ม.</span>
              <span class="mt-1 text-xs text-gray-400">วัสดุพรีเมียม งาน built-in ครบ</span>
            </label>
          </div>
        </fieldset>

        <!-- Furniture Toggle -->
        <div class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3">
          <input type="checkbox" id="include-furniture" checked class="h-5 w-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
          <label for="include-furniture" class="text-sm font-medium text-gray-700">
            รวมค่าเฟอร์นิเจอร์ <span class="text-gray-400">(เพิ่ม 20-40% ของค่าตกแต่ง)</span>
          </label>
        </div>

        <!-- Property Type -->
        <div>
          <label for="property-type" class="mb-1 block text-sm font-medium text-gray-700">ประเภทที่อยู่อาศัย</label>
          <select id="property-type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-auto">
            <option value="condo">คอนโดมิเนียม</option>
            <option value="townhouse">ทาวน์เฮาส์</option>
            <option value="detached" selected>บ้านเดี่ยว</option>
            <option value="semi">บ้านแฝด/ตึกแถว</option>
          </select>
        </div>

        <button
          type="submit"
          id="btn-calculate"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          คำนวณค่าตกแต่งบ้าน
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณค่าตกแต่งบ้าน</h2>

        <!-- Summary Boxes -->
        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ประมาณการต่ำสุด</div>
            <div id="res-total-low" class="text-xl font-bold text-sky-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ประมาณการสูงสุด</div>
            <div id="res-total-high" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">พื้นที่รวม</div>
            <div id="res-total-area" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="rounded-lg bg-emerald-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนเฉลี่ย/ตร.ม.</div>
            <div id="res-avg-cost" class="text-xl font-bold text-emerald-700">-</div>
          </div>
        </div>

        <!-- Room Breakdown Table -->
        <h3 class="mb-2 text-base font-semibold text-gray-900">รายละเอียดแต่ละห้อง</h3>
        <div class="mb-6 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 text-left">
                <th class="px-2 py-2 font-medium text-gray-600">ห้อง</th>
                <th class="px-2 py-2 text-right font-medium text-gray-600">พื้นที่ (ตร.ม.)</th>
                <th class="px-2 py-2 text-right font-medium text-gray-600">ค่าตกแต่ง (ต่ำ-สูง)</th>
                <th id="th-furniture" class="hidden px-2 py-2 text-right font-medium text-gray-600">ค่าเฟอร์นิเจอร์ (ต่ำ-สูง)</th>
                <th class="px-2 py-2 text-right font-medium text-gray-600">รวม (ต่ำ-สูง)</th>
              </tr>
            </thead>
            <tbody id="room-breakdown"></tbody>
            <tfoot>
              <tr class="border-t-2 border-gray-300 font-bold">
                <td class="px-2 py-2 text-gray-900">รวมทั้งหมด</td>
                <td id="foot-area" class="px-2 py-2 text-right text-gray-900">-</td>
                <td id="foot-deco" class="px-2 py-2 text-right text-gray-900">-</td>
                <td id="foot-furn" class="hidden px-2 py-2 text-right text-gray-900">-</td>
                <td id="foot-total" class="px-2 py-2 text-right text-gray-900">-</td>
              </tr>
            </tfoot>
          </table>
        </div>

        <!-- Cost Category Breakdown -->
        <h3 class="mb-2 text-base font-semibold text-gray-900">สัดส่วนค่าใช้จ่าย (ประมาณการ)</h3>
        <div id="cost-bars" class="mb-6 space-y-3"></div>

        <!-- Info Note -->
        <div class="rounded-lg border border-blue-200 bg-blue-50 p-3 text-sm text-blue-800">
          <strong>หมายเหตุ:</strong> ราคาเป็นการประมาณจากอัตราตลาดเฉลี่ยในไทย (2568-2569)
          ราคาจริงขึ้นกับทำเลที่ตั้ง ผู้รับเหมา วัสดุที่เลือก และขอบเขตงานจริง
          ควรขอใบเสนอราคาจากผู้รับเหมาอย่างน้อย 2-3 ราย
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าตกแต่งห้อง = พื้นที่ (ตร.ม.) × อัตราค่าตกแต่ง (บาท/ตร.ม.) × ตัวคูณห้อง × ตัวคูณประเภทที่อยู่</li>
        <li>ตัวคูณห้อง: ห้องครัว ×1.3, ห้องน้ำ ×1.5, ห้องอื่น ×1.0</li>
        <li>ตัวคูณที่อยู่: คอนโด ×1.0, ทาวน์เฮาส์ ×1.05, บ้านเดี่ยว ×1.10, บ้านแฝด ×1.05</li>
        <li>ค่าเฟอร์นิเจอร์ = ค่าตกแต่ง × อัตราเฟอร์นิเจอร์ (มินิมอล 20-25%, โมเดิร์น 25-35%, หรูหรา 30-40%)</li>
        <li>รวมทั้งหมด = ผลรวมค่าตกแต่งทุกห้อง + ค่าเฟอร์นิเจอร์ (ถ้าเลือก)</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" />

    <RelatedArticles currentHref="/คำนวณค่าตกแต่งบ้าน/" />
    <RelatedCalculators currentHref="/คำนวณค่าตกแต่งบ้าน/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> เครื่องมือนี้ใช้เพื่อช่วยประมาณการค่าใช้จ่ายตกแต่งบ้านเบื้องต้น
      ราคาจริงขึ้นอยู่กับผู้รับเหมา วัสดุ ทำเล และขอบเขตงาน ควรขอใบเสนอราคาจากผู้รับเหมาอย่างน้อย 2-3 รายก่อนตัดสินใจ
    </div>
  </article>

  <script>
    // ─── Rate Data ───
    const STYLE_RATES: Record<string, { low: number; high: number; furnLow: number; furnHigh: number }> = {
      minimal: { low: 5000, high: 10000, furnLow: 0.20, furnHigh: 0.25 },
      modern:  { low: 10000, high: 20000, furnLow: 0.25, furnHigh: 0.35 },
      luxury:  { low: 20000, high: 40000, furnLow: 0.30, furnHigh: 0.40 },
    };

    const ROOM_MULTIPLIER: Record<string, number> = {
      kitchen: 1.3,
      bathroom: 1.5,
    };

    const PROPERTY_MULTIPLIER: Record<string, number> = {
      condo: 1.0,
      townhouse: 1.05,
      detached: 1.10,
      semi: 1.05,
    };

    // ─── Helpers ───
    const parseNum = (v: string): number => {
      const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
      return Number.isFinite(n) && n > 0 ? n : 0;
    };

    const fmtMoney = (v: number): string =>
      new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(Math.round(v));

    const show = (el: Element | null) => el?.classList.remove('hidden');
    const hide = (el: Element | null) => el?.classList.add('hidden');

    // ─── Room card selection ───
    const roomCards = document.querySelectorAll<HTMLLabelElement>('.room-card');
    const areaInputsContainer = document.getElementById('area-inputs');

    function updateRoomCards() {
      let anyChecked = false;
      roomCards.forEach((card) => {
        const cb = card.querySelector<HTMLInputElement>('input[type="checkbox"]');
        const roomId = card.dataset.roomId;
        const areaDiv = document.getElementById(`area-${roomId}`);
        if (cb?.checked) {
          anyChecked = true;
          card.classList.remove('border-gray-200');
          card.classList.add('border-primary-500', 'bg-primary-50');
          show(areaDiv);
        } else {
          card.classList.add('border-gray-200');
          card.classList.remove('border-primary-500', 'bg-primary-50');
          hide(areaDiv);
        }
      });
      if (anyChecked) show(areaInputsContainer); else hide(areaInputsContainer);
    }

    roomCards.forEach((card) => {
      card.addEventListener('click', () => {
        setTimeout(updateRoomCards, 0);
      });
    });

    // ─── Style card selection ───
    const styleCards = document.querySelectorAll<HTMLLabelElement>('.style-card');

    function updateStyleCards() {
      styleCards.forEach((card) => {
        const radio = card.querySelector<HTMLInputElement>('input[type="radio"]');
        if (radio?.checked) {
          card.classList.remove('border-gray-200');
          card.classList.add('border-primary-500', 'bg-primary-50');
        } else {
          card.classList.add('border-gray-200');
          card.classList.remove('border-primary-500', 'bg-primary-50');
        }
      });
    }

    styleCards.forEach((card) => {
      card.addEventListener('click', () => {
        setTimeout(updateStyleCards, 0);
      });
    });

    // ─── Room name lookup ───
    const ROOM_LABELS: Record<string, string> = {
      living: '🛋️ ห้องนั่งเล่น',
      bedroom: '🛏️ ห้องนอน',
      kitchen: '🍳 ห้องครัว',
      bathroom: '🚿 ห้องน้ำ',
      dining: '🍽️ ห้องทานข้าว',
      office: '💻 ห้องทำงาน',
      balcony: '🌿 ระเบียง',
      entrance: '🚪 ทางเข้า',
    };

    // ─── Calculate ───
    const form = document.getElementById('deco-form');
    const formError = document.getElementById('form-error');
    const resultsDiv = document.getElementById('results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      hide(formError);

      // Gather selected rooms
      const selectedRooms: { id: string; sqm: number }[] = [];
      roomCards.forEach((card) => {
        const cb = card.querySelector<HTMLInputElement>('input[type="checkbox"]');
        const roomId = card.dataset.roomId!;
        if (cb?.checked) {
          const sqmInput = document.getElementById(`sqm-${roomId}`) as HTMLInputElement;
          const sqm = parseNum(sqmInput?.value);
          if (sqm > 0 && sqm <= 500) {
            selectedRooms.push({ id: roomId, sqm });
          }
        }
      });

      if (selectedRooms.length === 0) {
        show(formError);
        hide(resultsDiv);
        return;
      }

      // Get style
      const styleRadio = document.querySelector<HTMLInputElement>('input[name="style"]:checked');
      const style = styleRadio?.value || 'modern';
      const rates = STYLE_RATES[style];

      // Get options
      const includeFurniture = (document.getElementById('include-furniture') as HTMLInputElement)?.checked;
      const propertyType = (document.getElementById('property-type') as HTMLSelectElement)?.value || 'condo';
      const propMul = PROPERTY_MULTIPLIER[propertyType] || 1.0;

      // Calculate each room
      interface RoomResult {
        id: string;
        label: string;
        sqm: number;
        decoLow: number;
        decoHigh: number;
        furnLow: number;
        furnHigh: number;
        totalLow: number;
        totalHigh: number;
      }

      let grandTotalLow = 0;
      let grandTotalHigh = 0;
      let grandDecoLow = 0;
      let grandDecoHigh = 0;
      let grandFurnLow = 0;
      let grandFurnHigh = 0;
      let totalArea = 0;

      const roomResults: RoomResult[] = selectedRooms.map((room) => {
        const roomMul = ROOM_MULTIPLIER[room.id] || 1.0;
        const decoLow = Math.round(room.sqm * rates.low * roomMul * propMul);
        const decoHigh = Math.round(room.sqm * rates.high * roomMul * propMul);
        const furnLow = includeFurniture ? Math.round(decoLow * rates.furnLow) : 0;
        const furnHigh = includeFurniture ? Math.round(decoHigh * rates.furnHigh) : 0;
        const totalLow = decoLow + furnLow;
        const totalHigh = decoHigh + furnHigh;

        grandDecoLow += decoLow;
        grandDecoHigh += decoHigh;
        grandFurnLow += furnLow;
        grandFurnHigh += furnHigh;
        grandTotalLow += totalLow;
        grandTotalHigh += totalHigh;
        totalArea += room.sqm;

        return {
          id: room.id,
          label: ROOM_LABELS[room.id] || room.id,
          sqm: room.sqm,
          decoLow, decoHigh,
          furnLow, furnHigh,
          totalLow, totalHigh,
        };
      });

      // ─── Render Results ───
      document.getElementById('res-total-low')!.textContent = `${fmtMoney(grandTotalLow)} บาท`;
      document.getElementById('res-total-high')!.textContent = `${fmtMoney(grandTotalHigh)} บาท`;
      document.getElementById('res-total-area')!.textContent = `${fmtMoney(totalArea)} ตร.ม.`;

      const avgLow = totalArea > 0 ? grandTotalLow / totalArea : 0;
      const avgHigh = totalArea > 0 ? grandTotalHigh / totalArea : 0;
      document.getElementById('res-avg-cost')!.textContent = `${fmtMoney(avgLow)}-${fmtMoney(avgHigh)} บาท`;

      // Room breakdown table
      const tbody = document.getElementById('room-breakdown')!;
      const thFurn = document.getElementById('th-furniture');
      const footFurn = document.getElementById('foot-furn');
      tbody.innerHTML = '';

      if (includeFurniture) {
        show(thFurn);
        show(footFurn);
      } else {
        hide(thFurn);
        hide(footFurn);
      }

      roomResults.forEach((r) => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';
        let html = `
          <td class="px-2 py-2 text-gray-700">${r.label}</td>
          <td class="px-2 py-2 text-right">${fmtMoney(r.sqm)}</td>
          <td class="px-2 py-2 text-right">${fmtMoney(r.decoLow)}-${fmtMoney(r.decoHigh)}</td>
        `;
        if (includeFurniture) {
          html += `<td class="px-2 py-2 text-right">${fmtMoney(r.furnLow)}-${fmtMoney(r.furnHigh)}</td>`;
        }
        html += `<td class="px-2 py-2 text-right font-medium">${fmtMoney(r.totalLow)}-${fmtMoney(r.totalHigh)}</td>`;
        tr.innerHTML = html;
        tbody.appendChild(tr);
      });

      document.getElementById('foot-area')!.textContent = String(fmtMoney(totalArea));
      document.getElementById('foot-deco')!.textContent = `${fmtMoney(grandDecoLow)}-${fmtMoney(grandDecoHigh)}`;
      if (footFurn) footFurn.textContent = `${fmtMoney(grandFurnLow)}-${fmtMoney(grandFurnHigh)}`;
      document.getElementById('foot-total')!.textContent = `${fmtMoney(grandTotalLow)}-${fmtMoney(grandTotalHigh)}`;

      // Cost category bars
      const costBars = document.getElementById('cost-bars')!;
      costBars.innerHTML = '';

      const midTotal = (grandTotalLow + grandTotalHigh) / 2;
      const midDeco = (grandDecoLow + grandDecoHigh) / 2;
      const midFurn = (grandFurnLow + grandFurnHigh) / 2;

      // Materials ~40%, Labor ~30% of deco; Furniture; Misc ~10% of deco
      const materialsCost = midDeco * 0.4;
      const laborCost = midDeco * 0.3;
      const miscCost = midDeco * 0.1;
      const decoOther = midDeco * 0.2; // remaining 20% of decoration

      interface BarItem { label: string; amount: number; pct: number; color: string }
      const bars: BarItem[] = [
        { label: 'ค่าวัสดุ', amount: materialsCost + decoOther, pct: midTotal > 0 ? ((materialsCost + decoOther) / midTotal) * 100 : 0, color: 'bg-blue-500' },
        { label: 'ค่าแรงช่าง', amount: laborCost, pct: midTotal > 0 ? (laborCost / midTotal) * 100 : 0, color: 'bg-green-500' },
      ];
      if (includeFurniture && midFurn > 0) {
        bars.push({ label: 'ค่าเฟอร์นิเจอร์', amount: midFurn, pct: midTotal > 0 ? (midFurn / midTotal) * 100 : 0, color: 'bg-purple-500' });
      }
      bars.push({ label: 'ค่าอื่นๆ (สำรอง)', amount: miscCost, pct: midTotal > 0 ? (miscCost / midTotal) * 100 : 0, color: 'bg-amber-500' });

      bars.forEach((bar) => {
        const div = document.createElement('div');
        div.innerHTML = `
          <div class="mb-1 flex justify-between text-sm">
            <span class="text-gray-700">${bar.label}</span>
            <span class="font-medium text-gray-900">~${fmtMoney(bar.amount)} บาท (${Math.round(bar.pct)}%)</span>
          </div>
          <div class="h-3 w-full rounded-full bg-gray-200">
            <div class="${bar.color} h-3 rounded-full" style="width: ${Math.min(bar.pct, 100)}%"></div>
          </div>
        `;
        costBars.appendChild(div);
      });

      show(resultsDiv);
      resultsDiv!.scrollIntoView({ behavior: 'smooth', block: 'start' });

      // GA4 tracking
      if (typeof (window as any).trackCalculatorStart === 'function') (window as any).trackCalculatorStart('home_decoration');
      if (typeof (window as any).trackCalculatorComplete === 'function') (window as any).trackCalculatorComplete('home_decoration', grandTotalHigh);
      if (typeof (window as any).trackCalculatorUsed === 'function') (window as any).trackCalculatorUsed('home_decoration');
      if (typeof (window as any).trackResultViewed === 'function') (window as any).trackResultViewed('home_decoration');
    });
  </script>
</BaseLayout>
