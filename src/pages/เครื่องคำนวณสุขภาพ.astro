---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เครื่องคำนวณสุขภาพ — BMI แคลอรี น้ำหนักมาตรฐาน คำนวณวันคลอด | Kamnuanlek"
  description="เครื่องคำนวณสุขภาพฟรี คำนวณ BMI น้ำหนักมาตรฐาน แคลอรีต่อวัน วันคลอด อายุครรภ์ และตัวชี้วัดสุขภาพสำหรับคนไทย อัปเดตตามเกณฑ์กรมอนามัย"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Health & Medical Calculators</h1>
    <p class="text-xl text-gray-600 mb-12">
      Calculate your health metrics instantly. BMI, ideal weight, calorie requirements, age, and pregnancy tools — all free and accurate.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณ-bmi/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">⚖️</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">BMI Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate your Body Mass Index and understand if you're at a healthy weight for your height.</p>
        <span class="text-primary-600 font-medium">Calculate BMI →</span>
      </a>

      <a href="/คำนวณน้ำหนักที่เหมาะสม/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🎯</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Ideal Weight Calculator</h3>
        <p class="text-gray-600 mb-3">Find your ideal weight range based on height, age, and body type.</p>
        <span class="text-primary-600 font-medium">Calculate →</span>
      </a>

      <a href="/คำนวณแคลอรี/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🥗</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Calorie Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate your daily calorie needs based on age, weight, height, and activity level.</p>
        <span class="text-primary-600 font-medium">Calculate Calories →</span>
      </a>

      <a href="/คำนวณวันคลอด/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">👶</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Pregnancy Due Date Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate your expected due date based on last menstrual period or conception date.</p>
        <span class="text-primary-600 font-medium">Calculate Due Date →</span>
      </a>

      <a href="/คำนวณอายุ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🎂</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Age Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate exact age in years, months, and days. Useful for legal documents and medical forms.</p>
        <span class="text-primary-600 font-medium">Calculate Age →</span>
      </a>

      <a href="/คำนวณเงินเกษียณ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🌴</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Retirement Planning Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate how much you need to save for a comfortable retirement in Thailand.</p>
        <span class="text-primary-600 font-medium">Plan Retirement →</span>
      </a>
    </div>

    <div class="p-6 bg-pink-50 border border-pink-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">BMI Categories (Asian Reference)</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-4 bg-blue-100 rounded-lg text-center">
          <p class="text-2xl font-bold text-blue-700">Below 18.5</p>
          <p class="text-gray-700 font-medium mt-1">Underweight</p>
        </div>
        <div class="p-4 bg-green-100 rounded-lg text-center">
          <p class="text-2xl font-bold text-green-700">18.5–22.9</p>
          <p class="text-gray-700 font-medium mt-1">Normal</p>
        </div>
        <div class="p-4 bg-yellow-100 rounded-lg text-center">
          <p class="text-2xl font-bold text-yellow-700">23–24.9</p>
          <p class="text-gray-700 font-medium mt-1">Overweight</p>
        </div>
        <div class="p-4 bg-red-100 rounded-lg text-center">
          <p class="text-2xl font-bold text-red-700">25+</p>
          <p class="text-gray-700 font-medium mt-1">Obese</p>
        </div>
      </div>
      <p class="text-gray-600 text-sm mt-3">* Asian populations have higher health risks at lower BMI levels than Western references.</p>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/เครื่องคำนวณการเงินชั้นยอด/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 Top 10 Financial Tools</span>
          <p class="text-gray-600 text-sm mt-2">Including retirement planning calculators</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Calculators</span>
          <p class="text-gray-600 text-sm mt-2">Tax, loans, and savings tools</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
