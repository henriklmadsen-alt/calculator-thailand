---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ประกันสังคมไทย — อัตราเงินสมทบ สิทธิประโยชน์ มาตรา 33 39 40 | Kamnuanlek"
  description="คู่มือประกันสังคมไทยฉบับสมบูรณ์ อัตราเงินสมทบ สิทธิประโยชน์ วิธีขอรับสิทธิ์ มาตรา 33 39 40 และสิ่งที่เกิดขึ้นเมื่อเปลี่ยนงาน อัปเดตปี 2569"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Thai Social Security Guide</h1>

    <div class="mb-10 p-6 bg-green-50 border border-green-200 rounded-lg">
      <p class="text-lg text-gray-800">
        Social security in Thailand provides healthcare, maternity, disability, and unemployment benefits. Learn what you pay, what you get, and your rights.
      </p>
      <a href="/คำนวณประกันสังคม/" class="inline-block mt-4 px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-medium">
        Calculate Social Security →
      </a>
    </div>

    <div class="space-y-10">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Contribution Rates</h2>
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full">
            <thead class="bg-gray-50 border-b">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">Who Pays</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">Rate</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">Min / Max</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b">
                <td class="px-4 py-3 font-semibold text-gray-900">Employee (Section 33)</td>
                <td class="px-4 py-3 text-primary-600 font-semibold">5% of salary</td>
                <td class="px-4 py-3 text-gray-600">83 – 750 THB/month</td>
              </tr>
              <tr class="border-b bg-gray-50">
                <td class="px-4 py-3 font-semibold text-gray-900">Employer (Section 33)</td>
                <td class="px-4 py-3 text-primary-600 font-semibold">5% of salary</td>
                <td class="px-4 py-3 text-gray-600">83 – 750 THB/month</td>
              </tr>
              <tr class="border-b">
                <td class="px-4 py-3 font-semibold text-gray-900">Government</td>
                <td class="px-4 py-3 text-primary-600 font-semibold">2.75% of salary</td>
                <td class="px-4 py-3 text-gray-600">Subsidy</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-semibold text-gray-900">Self-Employed (Section 39)</td>
                <td class="px-4 py-3 text-primary-600 font-semibold">432 THB fixed</td>
                <td class="px-4 py-3 text-gray-600">Voluntary opt-in</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-gray-600 text-sm mt-2">* Base salary for calculation: min 1,650 THB, max 15,000 THB/month</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Benefits You Receive</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { icon: '🏥', title: 'Healthcare', desc: 'Free medical treatment at registered hospitals. Includes outpatient, inpatient, emergency care.' },
            { icon: '🤰', title: 'Maternity Benefit', desc: '13,000 THB lump sum per birth + daily allowance up to 90 days (leave from work).' },
            { icon: '👶', title: 'Childcare Allowance', desc: '800 THB/month per child up to age 6 (max 3 children for SSO members only).' },
            { icon: '💼', title: 'Unemployment Benefit', desc: 'If laid off: 50% of salary for 6 months. If resign: 30% for 3 months. Minimum 6 months contribution required.' },
            { icon: '🏥', title: 'Disability Benefit', desc: '500 – 1,000 THB/month if permanently disabled. Plus medical care at SSO hospitals.' },
            { icon: '⚰️', title: 'Death Benefit', desc: '50,000 THB funeral expense + 1-2 months salary pension for dependents.' },
            { icon: '🌴', title: 'Old Age Pension', desc: '15-20% of average salary for life at age 55+ with 15+ years of contributions.' },
          ].map((b) => (
            <div class="p-4 bg-white border border-gray-200 rounded-lg">
              <h3 class="font-semibold text-gray-900 mb-2">{b.icon} {b.title}</h3>
              <p class="text-gray-700 text-sm">{b.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">What Happens When You Change Jobs?</h2>
        <div class="space-y-3">
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <span class="text-2xl">✓</span>
            <div>
              <p class="font-semibold text-gray-900">Contributions carry over</p>
              <p class="text-gray-700 text-sm">Your SSO history follows you. Months of contribution accumulate across employers.</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <span class="text-2xl">⚠️</span>
            <div>
              <p class="font-semibold text-gray-900">Hospital registration resets</p>
              <p class="text-gray-700 text-sm">You must re-register your hospital of choice within 30 days of starting new employment.</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <span class="text-2xl">ℹ️</span>
            <div>
              <p class="font-semibold text-gray-900">Gap in employment</p>
              <p class="text-gray-700 text-sm">If unemployed, join Section 39 voluntarily (432 THB/month) to maintain continuous coverage.</p>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/เครื่องคำนวณเงินเดือนและค่าแรง/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💰 Salary Calculators</span>
          <p class="text-gray-600 text-sm mt-2">Net salary after all deductions</p>
        </a>
        <a href="/ตรวจสอบหักลดหย่อนภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">✅ Tax Deductions</span>
          <p class="text-gray-600 text-sm mt-2">SSO contribution is tax-deductible</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Hub</span>
          <p class="text-gray-600 text-sm mt-2">All financial calculators</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
