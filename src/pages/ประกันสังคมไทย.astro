---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ประกันสังคมไทย — อัตราเงินสมทบ สิทธิประโยชน์ มาตรา 33 39 40 | Kamnuanlek"
  description="คู่มือประกันสังคมไทยฉบับสมบูรณ์ อัตราเงินสมทบ สิทธิประโยชน์ วิธีขอรับสิทธิ์ มาตรา 33 39 40 และสิ่งที่เกิดขึ้นเมื่อเปลี่ยนงาน อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "ประกันสังคมไทย — อัตราเงินสมทบ สิทธิประโยชน์ มาตรา 33 39 40", "item": "https://www.kamnuanlek.com/ประกันสังคมไทย/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">คู่มือประกันสังคมไทย</h1>

    <div class="mb-10 p-6 bg-green-50 border border-green-200 rounded-lg">
      <p class="text-lg text-gray-800">
        ประกันสังคมไทยให้สิทธิประโยชน์ด้านสุขภาพ คลอดบุตร ทุพพลภาพ และว่างงาน เรียนรู้ว่าคุณจ่ายเท่าไร ได้รับอะไร และสิทธิ์ของคุณมีอะไรบ้าง
      </p>
      <a href="/คำนวณประกันสังคม/" class="inline-block mt-4 px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-medium">
        คำนวณประกันสังคม →
      </a>
    </div>

    <div class="space-y-10">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">อัตราเงินสมทบ</h2>
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full">
            <thead class="bg-gray-50 border-b">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ผู้จ่าย</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">อัตรา</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ต่ำสุด / สูงสุด</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b">
                <td class="px-4 py-3 font-semibold text-gray-900">ลูกจ้าง (มาตรา 33)</td>
                <td class="px-4 py-3 text-primary-600 font-semibold">5% ของเงินเดือน</td>
                <td class="px-4 py-3 text-gray-600">83 – 750 บาท/เดือน</td>
              </tr>
              <tr class="border-b bg-gray-50">
                <td class="px-4 py-3 font-semibold text-gray-900">นายจ้าง (มาตรา 33)</td>
                <td class="px-4 py-3 text-primary-600 font-semibold">5% ของเงินเดือน</td>
                <td class="px-4 py-3 text-gray-600">83 – 750 บาท/เดือน</td>
              </tr>
              <tr class="border-b">
                <td class="px-4 py-3 font-semibold text-gray-900">รัฐบาล</td>
                <td class="px-4 py-3 text-primary-600 font-semibold">2.75% ของเงินเดือน</td>
                <td class="px-4 py-3 text-gray-600">เงินอุดหนุน</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-semibold text-gray-900">ผู้ประกอบอาชีพอิสระ (มาตรา 39)</td>
                <td class="px-4 py-3 text-primary-600 font-semibold">432 บาท คงที่</td>
                <td class="px-4 py-3 text-gray-600">สมัครใจ</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-gray-600 text-sm mt-2">* ฐานเงินเดือนสำหรับคำนวณ: ต่ำสุด 1,650 บาท สูงสุด 15,000 บาท/เดือน</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">สิทธิประโยชน์ที่คุณได้รับ</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { icon: '🏥', title: 'สิทธิรักษาพยาบาล', desc: 'รักษาพยาบาลฟรีที่โรงพยาบาลที่ลงทะเบียน ครอบคลุมผู้ป่วยนอก ผู้ป่วยใน และฉุกเฉิน' },
            { icon: '🤰', title: 'สิทธิคลอดบุตร', desc: 'เงินเหมาจ่าย 13,000 บาท ต่อการคลอด + เงินทดแทนรายวันสูงสุด 90 วัน (กรณีหยุดงาน)' },
            { icon: '👶', title: 'สิทธิเงินสงเคราะห์บุตร', desc: '800 บาท/เดือน ต่อบุตรอายุไม่เกิน 6 ปี (สูงสุด 3 คน เฉพาะผู้ประกันตน)' },
            { icon: '💼', title: 'สิทธิว่างงาน', desc: 'กรณีถูกเลิกจ้าง: 50% ของเงินเดือนนาน 6 เดือน กรณีลาออก: 30% นาน 3 เดือน ต้องส่งเงินสมทบอย่างน้อย 6 เดือน' },
            { icon: '🏥', title: 'สิทธิทุพพลภาพ', desc: '500 – 1,000 บาท/เดือน กรณีทุพพลภาพถาวร พร้อมรักษาพยาบาลที่โรงพยาบาลประกันสังคม' },
            { icon: '⚰️', title: 'สิทธิเสียชีวิต', desc: 'ค่าทำศพ 50,000 บาท + เงินสงเคราะห์แก่ทายาท 1-2 เดือนของเงินเดือน' },
            { icon: '🌴', title: 'สิทธิบำนาญชราภาพ', desc: '15-20% ของเงินเดือนเฉลี่ยตลอดชีวิต เมื่ออายุ 55 ปีขึ้นไป และส่งเงินสมทบ 15 ปีขึ้นไป' },
          ].map((b) => (
            <div class="p-4 bg-white border border-gray-200 rounded-lg">
              <h3 class="font-semibold text-gray-900 mb-2">{b.icon} {b.title}</h3>
              <p class="text-gray-700 text-sm">{b.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">เมื่อเปลี่ยนงานจะเกิดอะไรขึ้น?</h2>
        <div class="space-y-3">
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <span class="text-2xl">✓</span>
            <div>
              <p class="font-semibold text-gray-900">เงินสมทบสะสมต่อเนื่อง</p>
              <p class="text-gray-700 text-sm">ประวัติประกันสังคมติดตัวคุณ เดือนสมทบสะสมต่อเนื่องข้ามนายจ้าง</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <span class="text-2xl">⚠️</span>
            <div>
              <p class="font-semibold text-gray-900">ต้องลงทะเบียนโรงพยาบาลใหม่</p>
              <p class="text-gray-700 text-sm">ต้องเลือกโรงพยาบาลใหม่ภายใน 30 วัน นับจากวันเริ่มงานใหม่</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-white border border-gray-200 rounded-lg">
            <span class="text-2xl">ℹ️</span>
            <div>
              <p class="font-semibold text-gray-900">ช่วงว่างงาน</p>
              <p class="text-gray-700 text-sm">หากว่างงาน สมัครมาตรา 39 โดยสมัครใจ (432 บาท/เดือน) เพื่อรักษาความคุ้มครองต่อเนื่อง</p>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/เครื่องคำนวณเงินเดือนและค่าแรง/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💰 เครื่องคำนวณเงินเดือน</span>
          <p class="text-gray-600 text-sm mt-2">เงินเดือนสุทธิหลังหักทุกรายการ</p>
        </a>
        <a href="/ตรวจสอบหักลดหย่อนภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">✅ ลดหย่อนภาษี</span>
          <p class="text-gray-600 text-sm mt-2">เงินสมทบประกันสังคมหักภาษีได้</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 ศูนย์รวมการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">เครื่องคำนวณการเงินทุกประเภท</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
