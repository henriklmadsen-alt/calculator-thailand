---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
const pageTitle = 'คำนวณค่าชุดเพื่อนบ่าว 2569 | Calculator Thailand';
const pageDescription = 'คำนวณค่าชุดเพื่อนบ่าวแต่งงาน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าชุดเพื่อนบ่าวแต่งงาน/`;
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าชุดเพื่อนบ่าว">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าชุดเพื่อนบ่าว</h1>
    <p class="text-gray-600 mb-6">คำนวณค่าชุดเพื่อนบ่าวแต่งงาน</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="suit-cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าสูท (บาท)</label>
          <input type="text" id="suit-cost" inputmode="decimal" placeholder="0" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-base" />
        </div>
        <div>
          <label for="num-groomsmen" class="block text-sm font-medium text-gray-700 mb-1">จำนวนคน</label>
          <input type="text" id="num-groomsmen" inputmode="decimal" placeholder="0" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-base" />
        </div>
        <div>
          <label for="alteration" class="block text-sm font-medium text-gray-700 mb-1">ค่าปรับแต่ง (บาท)</label>
          <input type="text" id="alteration" inputmode="decimal" placeholder="0" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-base" />
        </div>
        <div>
          <label for="other" class="block text-sm font-medium text-gray-700 mb-1">ค่าอื่นๆ (บาท)</label>
          <input type="text" id="other" inputmode="decimal" placeholder="0" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-base" />
        </div>
      </div>
      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-blue-600 text-white font-semibold rounded-md hover:bg-blue-700 transition-colors text-base">คำนวณ</button>
      <div id="result" class="hidden mt-8">
        <div class="bg-blue-50 rounded-lg p-6 text-center">
          <div class="text-sm text-gray-600 mb-2">ค่ารวม</div>
          <div class="text-5xl font-bold text-blue-700"><span id="total">-</span></div>
          <div class="text-sm text-gray-600">บาท</div>
        </div>
      </div>
    </div>
    <RelatedCalculators />
    <RelatedArticles />
  </article>
</BaseLayout>
<script>
  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const suit = parseFloat(document.getElementById('suit-cost')?.value || 0);
    const num = parseFloat(document.getElementById('num-groomsmen')?.value || 1);
    const alter = parseFloat(document.getElementById('alteration')?.value || 0);
    const other = parseFloat(document.getElementById('other')?.value || 0);
    const total = (suit * num) + alter + other;
    if (total === 0) { alert('กรุณาป้อนค่า'); return; }
    document.getElementById('total').textContent = total.toLocaleString('th-TH');
    document.getElementById('result').classList.remove('hidden');
  });
</script>
