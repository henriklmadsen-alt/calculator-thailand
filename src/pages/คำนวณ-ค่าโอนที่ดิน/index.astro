---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculateLandTitleTransfer } from '../../lib/land-title-transfer-calculator';

const pageTitle = 'คำนวณค่าโอนที่ดิน 2569 | ค่าธรรมเนียมโอนที่ดิน | Kamnuanlek';
const pageDescription = 'คำนวณค่าโอนที่ดินออนไลน์ฟรี สำหรับ โอนขาย โอนให้ โอนทางมรดก คำนวณค่าธรรมเนียม ค่าแสตมป์ ภาษี ตามอัตรา 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าโอนที่ดิน/`;

const faqData = [
  {
    question: 'ค่าโอนที่ดินประกอบด้วยค่าอะไรบ้าง?',
    answer: 'ค่าโอนที่ดินประกอบด้วย: ค่าธรรมเนียมโอนที่ดิน ค่าแสตมป์ (0.5% ของราคา) ภาษีศุลกากร (เฉพาะบางกรณี) และค่าบริการเพิ่มเติมเช่น ค่าทนายความ ค่าจดหมายเหตุ',
  },
  {
    question: 'ผู้เป็นเจ้าของรับผิดชอบค่าใด?',
    answer: 'โดยปกติ ผู้รับโอน (ผู้ซื้อ/ผู้รับของขวัญ) จ่ายค่าธรรมเนียมและค่าแสตมป์ แต่อาจมีข้อตกลงระหว่างฝ่ายต่างๆ ให้ผู้ขายจ่ายบางส่วน ควรตกลงกันก่อนลงนาม',
  },
  {
    question: 'โอนให้เป็นของขวัญมีภาษีหรือไม่?',
    answer: 'ใช่ โอนของขวัญที่มีมูลค่า > 20,000 บาท ต้องเสียภาษีของขวัญ 7.5% ของมูลค่าที่เกิน 20,000 บาท และค่าธรรมเนียมอื่นๆ เช่นเดียวกับการโอนขาย',
  },
  {
    question: 'โอนทางมรดกต้องสียภาษีหรือไม่?',
    answer: 'โอนทางมรดก (มสธ.) ปกติจะเสียภาษีอากรที่ดิน (Specific taxes) แต่ปกติไม่ต้องจ่ายภาษีเงินได้ (Capital Gains Tax) เพราะถือว่าการถ่ายทอดสิ่งของหลังจากความตาย',
  },
  {
    question: 'ต้องจ่ายค่าทนายความหรือไม่?',
    answer: 'ไม่จำเป็น แต่แนะนำให้ปรึกษาทนายความเพื่อให้แน่ใจว่าเอกสารถูกต้อง ค่าทนายฯ โดยปกติ 2,000-5,000 บาท สูงกว่าขึ้นอยู่กับความซับซ้อน',
  },
  {
    question: 'เวลาในการโอนที่ดินนานแค่ไหน?',
    answer: 'โดยปกติ 1-2 สัปดาห์ ตั้งแต่ยื่นเอกสารจนกว่าจะได้โฉนด (โฉนดใบใหม่) ขึ้นอยู่กับความเร็วของ สำนักที่ดินท้องถิ่นและความครบถ้วนของเอกสาร',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าโอนที่ดิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าโอนที่ดิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าโอนที่ดิน
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-indigo-200 bg-indigo-50 px-3 py-2">
      <p class="text-xs font-semibold text-indigo-800">[อัปเดตอัตรา กรมที่ดิน 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าโอนที่ดิน (โอนขาย โอนให้ โอนมรดก) ออนไลน์ฟรี พร้อมค่าธรรมเนียม ค่าแสตมป์ ภาษี ตามอัตราปัจจุบัน
    </p>

    <!-- Calculator Section -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <!-- Transfer Type -->
      <div class="mb-6">
        <label for="transfer-type" class="block text-sm font-medium text-gray-700 mb-2">
          ประเภทการโอน
        </label>
        <select
          id="transfer-type"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-base"
        >
          <option value="sale">โอนจากการขาย (Sale)</option>
          <option value="gift">โอนให้เป็นของขวัญ (Gift)</option>
          <option value="inheritance">โอนทางมรดก (Inheritance)</option>
          <option value="exchange">โอนโดยแลกเปลี่ยน (Exchange)</option>
        </select>
      </div>

      <!-- Land Value -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div>
          <label for="land-value" class="block text-sm font-medium text-gray-700 mb-1">
            มูลค่าที่ดิน (บาท)
          </label>
          <input
            type="number"
            id="land-value"
            inputmode="decimal"
            placeholder="เช่น 3000000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-base"
          />
        </div>
        <div>
          <label for="land-area" class="block text-sm font-medium text-gray-700 mb-1">
            พื้นที่ (ไร่)
          </label>
          <input
            type="number"
            id="land-area"
            inputmode="decimal"
            placeholder="เช่น 1"
            value="1"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-base"
          />
        </div>
      </div>

      <!-- Additional Options -->
      <div class="mb-6 space-y-3">
        <label class="block text-sm font-medium text-gray-700">ตัวเลือกเพิ่มเติม</label>
        <div class="flex items-center">
          <input
            type="checkbox"
            id="first-owner"
            checked
            class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
          />
          <label for="first-owner" class="ml-2 block text-sm text-gray-700">
            ผู้รับเป็นเจ้าของครั้งแรก (First-time owner)
          </label>
        </div>
        <div class="flex items-center">
          <input
            type="checkbox"
            id="notary-fee"
            class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
          />
          <label for="notary-fee" class="ml-2 block text-sm text-gray-700">
            รวมค่าจดหมายเหตุ (+1,500 บาท)
          </label>
        </div>
        <div class="flex items-center">
          <input
            type="checkbox"
            id="lawyer-fee"
            class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
          />
          <label for="lawyer-fee" class="ml-2 block text-sm text-gray-700">
            รวมค่าทนายความ (+3,500 บาท)
          </label>
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-indigo-600 text-white font-semibold rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณค่าโอนที่ดิน
      </button>

      <!-- Results -->
      <div id="result" class="hidden mt-6 pt-6 border-t border-gray-200">
        <!-- Cost Breakdown -->
        <div class="grid gap-4 sm:grid-cols-2 mb-6">
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-sm text-gray-600">ค่าธรรมเนียม &amp; ภาษี</div>
            <div id="fees-subtotal" class="text-2xl font-bold text-gray-900">0 บาท</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-sm text-gray-600">ค่าบริการเพิ่มเติม</div>
            <div id="service-fees" class="text-2xl font-bold text-gray-900">0 บาท</div>
          </div>
        </div>

        <!-- Total -->
        <div class="bg-indigo-50 rounded-lg p-4 border border-indigo-200 mb-6">
          <div class="text-sm text-indigo-600 font-semibold mb-1">ค่าโอนที่ดินรวมทั้งสิ้น</div>
          <div id="total-fee" class="text-4xl font-bold text-indigo-900">0 บาท</div>
        </div>

        <!-- Details -->
        <div id="details-section" class="bg-gray-50 rounded-lg p-4 text-sm mb-4"></div>

        <!-- Notes -->
        <div id="notes-section" class="hidden bg-yellow-50 rounded-lg border border-yellow-200 p-4"></div>
      </div>
    </div>

    <!-- Information Section -->
    <div class="grid gap-6 sm:grid-cols-2 mb-8">
      <div class="bg-blue-50 rounded-lg border border-blue-200 p-6">
        <h2 class="text-lg font-semibold text-blue-900 mb-4">💡 ประเภทการโอน</h2>
        <ul class="space-y-2 text-sm text-gray-700">
          <li><strong>โอนขาย:</strong> มีภาษีเงินได้ (Capital Gains)</li>
          <li><strong>โอนให้:</strong> มีภาษีของขวัญ 7.5%</li>
          <li><strong>โอนมรดก:</strong> มักปลอดภาษีเงินได้</li>
          <li><strong>โอนแลกเปลี่ยน:</strong> มีค่าธรรมเนียมเต็มจำนวน</li>
        </ul>
      </div>

      <div class="bg-green-50 rounded-lg border border-green-200 p-6">
        <h2 class="text-lg font-semibold text-green-900 mb-4">📋 ค่าเพิ่มเติม</h2>
        <ul class="space-y-2 text-sm text-gray-700">
          <li><strong>ค่าแสตมป์:</strong> 0.5% ของราคา</li>
          <li><strong>ค่าจดหมายเหตุ:</strong> 1,500 บาท</li>
          <li><strong>ค่าทนายความ:</strong> 2,000-5,000 บาท</li>
          <li><strong>VAT 7%:</strong> ค่าบริการเพิ่มเติม</li>
        </ul>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="bg-gray-50 rounded-lg p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-6">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg border border-gray-200 p-4">
            <summary class="font-semibold text-gray-900 cursor-pointer">
              {faq.question}
            </summary>
            <p class="text-gray-600 mt-3 text-sm">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <!-- Trust Section -->
    <div class="bg-yellow-50 rounded-lg border border-yellow-200 p-6 mb-8">
      <h2 class="text-lg font-semibold text-yellow-900 mb-3">⚖️ ความน่าเชื่อถือ</h2>
      <p class="text-sm text-gray-700 mb-3">
        เครื่องคำนวณนี้อ้างอิงจาก:
      </p>
      <ul class="text-sm text-gray-700 space-y-1">
        <li>• <strong>แหล่งที่มา:</strong> กรมที่ดิน สำนักที่ดิน Revenue Code</li>
        <li>• <strong>อัปเดต:</strong> ปี 2569 (2026)</li>
        <li>• <strong>หมายเหตุ:</strong> ตัวเลขเป็นการประมาณ ควรปรึกษาทนายหรือ สำนักที่ดินสำหรับจำนวนเต็มเนื่องจากอาจมีค่าบริการเพิ่มเติม</li>
      </ul>
    </div>

    <!-- Related Calculators -->
    <RelatedCalculators categoryId="government" />
  </article>
</BaseLayout>

<script>
  import { calculateLandTitleTransfer } from '../../lib/land-title-transfer-calculator';

  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const transferType = (document.getElementById('transfer-type') as HTMLSelectElement)
      .value as 'gift' | 'sale' | 'inheritance' | 'exchange';
    const landValue = parseFloat(
      (document.getElementById('land-value') as HTMLInputElement).value || '0'
    );
    const landArea = parseFloat(
      (document.getElementById('land-area') as HTMLInputElement).value || '1'
    );
    const isFirstTimeOwner = (document.getElementById('first-owner') as HTMLInputElement)
      .checked;
    const includeNotaryFee = (document.getElementById('notary-fee') as HTMLInputElement)
      .checked;
    const includeLawyerFee = (document.getElementById('lawyer-fee') as HTMLInputElement)
      .checked;

    if (landValue <= 0) {
      alert('โปรดระบุมูลค่าที่ดินที่มากกว่า 0');
      return;
    }

    const result = calculateLandTitleTransfer({
      transferType,
      landValue,
      landArea,
      isFirstTimeOwner,
      includeNotaryFee,
      includeLawyerFee,
    });

    const resultDiv = document.getElementById('result');
    if (resultDiv) {
      resultDiv.classList.remove('hidden');

      const totalFees = result.registrationFee + result.stampDutyFee + result.landBuildingTax + result.capitalGainsTax;
      const totalServices = result.notaryFee + result.lawyerFee;

      document.getElementById('fees-subtotal')!.textContent =
        totalFees.toLocaleString('th-TH') + ' บาท';
      document.getElementById('service-fees')!.textContent =
        (totalServices + result.vat).toLocaleString('th-TH') + ' บาท';
      document.getElementById('total-fee')!.textContent =
        result.total.toLocaleString('th-TH') + ' บาท';

      const detailsSection = document.getElementById('details-section')!;
      detailsSection.innerHTML = `
        <div class="space-y-2">
          <div class="flex justify-between"><span>ประเภท:</span><strong>${result.transferTypeName}</strong></div>
          <div class="flex justify-between"><span>มูลค่าที่ดิน:</span><strong>${result.landValue.toLocaleString('th-TH')} บาท</strong></div>
          <div class="flex justify-between"><span>ค่าธรรมเนียม:</span><strong>${result.registrationFee.toLocaleString('th-TH')} บาท</strong></div>
          <div class="flex justify-between"><span>ค่าแสตมป์:</span><strong>${result.stampDutyFee.toLocaleString('th-TH')} บาท</strong></div>
          <div class="flex justify-between"><span>ภาษีที่ดิน:</span><strong>${result.landBuildingTax.toLocaleString('th-TH')} บาท</strong></div>
          <div class="flex justify-between"><span>ภาษีเงินได้:</span><strong>${result.capitalGainsTax.toLocaleString('th-TH')} บาท</strong></div>
          ${result.notaryFee > 0 ? `<div class="flex justify-between"><span>ค่าจดหมายเหตุ:</span><strong>${result.notaryFee.toLocaleString('th-TH')} บาท</strong></div>` : ''}
          ${result.lawyerFee > 0 ? `<div class="flex justify-between"><span>ค่าทนายความ:</span><strong>${result.lawyerFee.toLocaleString('th-TH')} บาท</strong></div>` : ''}
          ${result.vat > 0 ? `<div class="flex justify-between"><span>VAT 7%:</span><strong>${result.vat.toLocaleString('th-TH')} บาท</strong></div>` : ''}
        </div>
      `;

      if (result.notes.length > 0) {
        const notesSection = document.getElementById('notes-section')!;
        notesSection.classList.remove('hidden');
        notesSection.innerHTML = `
          <h3 class="font-semibold text-yellow-900 mb-2">⚠️ หมายเหตุ:</h3>
          <ul class="list-disc list-inside text-sm text-yellow-800 space-y-1">
            ${result.notes.map((note) => `<li>${note}</li>`).join('')}
          </ul>
        `;
      }
    }
  });
</script>
