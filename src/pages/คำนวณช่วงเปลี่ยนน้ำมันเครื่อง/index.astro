---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณรอบเปลี่ยนน้ำมันเครื่อง 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณรอบเปลี่ยนน้ำมันเครื่อง 2569 ฟรี — รู้ว่าควรเปลี่ยนทุกกี่กิโลหรือกี่เดือน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/calc/`;
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุน">
  <article><h1>คำนวณต้นทุน</h1>
    <div class="bg-white rounded-lg shadow-sm p-6 mb-8">
      <input type="number" id="amount" placeholder="0" value="100000" class="w-full px-3 py-2 border mb-4 rounded-md" />
      <button id="btn" class="w-full bg-orange-600 text-white py-2 rounded-md">คำนวณ</button>
    </div>
    <div id="results" class="hidden"><p id="result" class="text-2xl font-bold text-orange-600">ผล</p></div>
  </article>
  <script>
    document.getElementById('btn').addEventListener('click', () => {
      const v = parseFloat(document.getElementById('amount').value) || 100000;
      document.getElementById('result').textContent = Math.round(v * 1.2) + ' บาท';
      document.getElementById('results').classList.remove('hidden');
    });
  </script>
</BaseLayout>
