---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณต้นทุนชาร์จรถ EV 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนชาร์จรถยนต์ไฟฟ้า EV 2569 ฟรี — รู้ค่าไฟต่อกิโลเมตร เทียบกับรถน้ำมัน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/calc/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
,
  { question: 'ค่าไฟฟ้าในไทยใช้อัตราแบบไหน?', answer: 'ใช้อัตราก้าวหน้า (Progressive Rate) — ยิ่งใช้มากยิ่งแพงต่อหน่วย MEA/PEA มีอัตรา 3 ช่วง ตามประกาศคณะกรรมการกำกับกิจการพลังงาน (กกพ.) บวกค่า FT (Fuel Tariff) ที่เปลี่ยนทุก 4 เดือน' },
  { question: 'ค่า FT คืออะไรและส่งผลต่อค่าไฟอย่างไร?', answer: 'FT (Fuel Adjustment Charge) คือค่าปรับตามต้นทุนเชื้อเพลิง ปรับทุก 4 เดือน ถ้า FT เป็นบวกหมายถึงค่าไฟแพงขึ้น ถ้าเป็นลบถูกลง ส่งผลให้ค่าไฟรายเดือนเปลี่ยนแปลงได้ 5-15%' },
  { question: 'ประหยัดค่าไฟได้อย่างไรบ้าง?', answer: 'ปิดอุปกรณ์ที่ไม่ใช้งาน (standby กิน 5-10% ของค่าไฟ), ใช้หลอด LED แทนหลอดเก่า, ตั้งแอร์ที่ 25-26°C, ซักผ้าครั้งเดียวให้เต็มถัง, ตรวจสอบฉนวนและซีลประตูตู้เย็น' },
  { question: 'มิเตอร์ไฟฟ้าขนาด 5(15) A กับ 15(45) A ต่างกันอย่างไร?', answer: 'ขนาดมิเตอร์กำหนดกระแสสูงสุด ครัวเรือนทั่วไปใช้ 5(15) A เพียงพอ บ้านใหญ่หรือใช้เครื่องใช้ไฟฟ้ากำลังสูงมากควรใช้ 15(45) A ค่าไฟคิดในอัตราเดียวกัน แต่ค่าบริการรายเดือนต่างกัน' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุน">  <article><h1>คำนวณต้นทุน</h1>
    <div class="bg-white rounded-lg shadow-sm p-6 mb-8">
      <input type="number" id="amount" placeholder="0" value="100000" class="w-full px-3 py-2 border mb-4 rounded-md" />
      <button id="btn" class="w-full bg-orange-600 text-white py-2 rounded-md">คำนวณ</button>
    </div>
    <div id="results" class="hidden"><p id="result" class="text-2xl font-bold text-orange-600">ผล</p></div>
  </article>
  <script>
    document.getElementById('btn').addEventListener('click', () => {
      const v = parseFloat(document.getElementById('amount').value) || 100000;
      document.getElementById('result').textContent = Math.round(v * 1.2) + ' บาท';
      document.getElementById('results').classList.remove('hidden');
    });
  </script>

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.mea.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">การไฟฟ้านครหลวง MEA (mea.or.th)</a> — อัตราค่าไฟฟ้าและโครงสร้างราคา</li>
        <li><a href="https://www.pea.co.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">การไฟฟ้าส่วนภูมิภาค PEA (pea.co.th)</a> — อัตราค่าไฟฟ้าต่างจังหวัด</li>
      </ul>
    </div>
</BaseLayout>
