---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณงบประมาณงานรวมทั้งสิ้น ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณงบประมาณงานรวมทั้งสิ้น ได้ผลลัพธ์ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-งบประมาณงานรวมทั้งสิ้น/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบประมาณงานรวมทั้งสิ้น">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณงบประมาณงานรวมทั้งสิ้น</h1>
    <p class="text-gray-600 mb-6">เครื่องคำนวณออนไลน์ งบประมาณงานรวมทั้งสิ้น</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <p class="text-gray-500 py-8 text-center">เครื่องคำนวณกำลังพัฒนา</p>
    </div>
  </article>
</BaseLayout>
