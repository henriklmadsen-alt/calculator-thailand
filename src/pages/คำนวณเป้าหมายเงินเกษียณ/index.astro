---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเป้าหมายเงินเกษียณ 2569 | ต้องมีเงินก้อนเท่าไรตอนเกษียณ | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณเงินก้อนเป้าหมายที่ต้องมีตอนเกษียณ จากค่าใช้จ่ายรายเดือน อายุขัยคาดหวัง และเงินเฟ้อ เพื่อให้เงินพอใช้ตลอดชีวิตหลังเกษียณ อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเป้าหมายเงินเกษียณ/`;

const faqData = [
  {
    question: 'ต้องมีเงินเท่าไรจึงจะเกษียณได้?',
    answer: 'ขึ้นอยู่กับค่าใช้จ่ายรายเดือนหลังเกษียณและระยะเวลาที่ต้องการ เช่น หากใช้จ่าย 30,000 บาท/เดือน เกษียณอายุ 60 ปี อายุขัย 85 ปี (25 ปีหลังเกษียณ) และผลตอบแทน 4% ต่อปี จะต้องมีเงินประมาณ 5.7-6 ล้านบาท เครื่องคำนวณนี้คิดทั้งเงินเฟ้อและผลตอบแทนให้อัตโนมัติ',
  },
  {
    question: 'เงินเฟ้อมีผลต่อการวางแผนเกษียณอย่างไร?',
    answer: 'เงินเฟ้อทำให้ค่าใช้จ่ายจริงสูงขึ้นทุกปี หากเงินเฟ้อ 3% ต่อปี ค่าใช้จ่าย 30,000 บาทวันนี้จะเป็น 60,000 บาทในอีก 24 ปีข้างหน้า การวางแผนที่ดีต้องคำนึงถึงเงินเฟ้อโดยใช้ผลตอบแทนจริง (real return) ซึ่งคือผลตอบแทนหักเงินเฟ้อ',
  },
  {
    question: 'อายุขัยคาดหวังในไทยอยู่ที่เท่าไร?',
    answer: 'อายุขัยเฉลี่ยของคนไทยปัจจุบันอยู่ที่ประมาณ 77-79 ปี แต่เพื่อความปลอดภัยในการวางแผนเกษียณ แนะนำให้ใช้อายุขัยที่ 85-90 ปี เพื่อป้องกันความเสี่ยงอายุยืนกว่าที่คาด',
  },
  {
    question: 'ผลตอบแทนหลังเกษียณควรตั้งที่เท่าไร?',
    answer: 'หลังเกษียณควรลดความเสี่ยงพอร์ต เปลี่ยนจากหุ้นเป็นตราสารหนี้และเงินฝากมากขึ้น ผลตอบแทนที่สมเหตุสมผลหลังเกษียณอยู่ที่ 3-5% ต่อปี การใช้ค่า 4% เป็นค่ากลางที่นิยมในการวางแผน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเป้าหมายเงินเกษียณ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "วิธีคำนวณเป้าหมายเงินออม เพื่อเกษียณ ปี 2569",
  "description": "ขั้นตอนการกำหนดเป้าหมายเงินออมประจำปี เพื่อให้มีเงินเพียงพอเมื่อเกษียณ โดยใช้วิธีหาจำนวนเงินที่ต้องออมต่อเดือน",
  "step": [
    {
      "@type": "HowToStep",
      "name": "กำหนดเป้าหมายเงินเกษียณทั้งสิ้น",
      "text": "จากการคำนวณก่อนหน้า (CAL-KW43) บันทึกเงินเกษียณเป้าหมาย ตัวอย่าง: ต้องมีเงิน 15,000,000 บาท เมื่ออายุ 60 ปี"
    },
    {
      "@type": "HowToStep",
      "name": "ระบุเงินที่มีอยู่แล้ว",
      "text": "เงินออมปัจจุบัน + การลงทุน + เงินประกันสังคมที่คาดหวัง ตัวอย่าง: มีออมแล้ว 2,000,000 บาท, เงิน SSO จะได้ประมาณ 500,000 บาท = เงินที่มี 2,500,000 บาท"
    },
    {
      "@type": "HowToStep",
      "name": "คำนวณเงินที่ยังต้องออม",
      "text": "เงินต้องออม = เป้าหมาย - เงินที่มี = 15,000,000 - 2,500,000 = 12,500,000 บาท"
    },
    {
      "@type": "HowToStep",
      "name": "คำนวณจำนวนเงินที่ต้องออมต่อเดือน",
      "text": "เงินต้องออมต่อเดือน = เงินต้องออม ÷ (จำนวนเดือนที่เหลือ - ส่วนของดอกเบี้ย) สมมติดอกเบี้ยจากการลงทุน 3.5% ต่อปี นำไปคำนวณด้วย ตัวอย่าง: ต้องออมประมาณ 20,000-25,000 บาท/เดือน (ขึ้นอยู่กับอัตราดอกเบี้ย)"
    }
  ]
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเป้าหมายเงินเกษียณ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเป้าหมายเงินเกษียณ 2569 — ต้องมีเงินก้อนเท่าไรตอนเกษียณ
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณเงินก้อนเป้าหมายที่ต้องมี ณ วันเกษียณ โดยพิจารณาค่าใช้จ่ายรายเดือน อายุขัยคาดหวัง อัตราเงินเฟ้อ และผลตอบแทนจากการลงทุนหลังเกษียณ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="retire-target-form" class="space-y-5">
        <p id="retire-target-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div>
          <label for="retire-target-monthly" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าใช้จ่ายรายเดือนหลังเกษียณ (บาท)
          </label>
          <input
            type="text"
            id="retire-target-monthly"
            inputmode="numeric"
            placeholder="เช่น 30,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p id="retire-target-monthly-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="retire-target-age" class="block text-sm font-medium text-gray-700 mb-1">
              อายุเกษียณ (ปี)
            </label>
            <input
              type="number"
              id="retire-target-age"
              min="40"
              max="80"
              value="60"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="retire-target-life" class="block text-sm font-medium text-gray-700 mb-1">
              อายุขัยคาดหวัง (ปี)
            </label>
            <input
              type="number"
              id="retire-target-life"
              min="60"
              max="110"
              value="85"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="retire-target-inflation" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราเงินเฟ้อ (% ต่อปี)
            </label>
            <input
              type="text"
              id="retire-target-inflation"
              inputmode="decimal"
              placeholder="เช่น 3"
              value="3"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="retire-target-return" class="block text-sm font-medium text-gray-700 mb-1">
              ผลตอบแทนหลังเกษียณ (% ต่อปี)
            </label>
            <input
              type="text"
              id="retire-target-return"
              inputmode="decimal"
              placeholder="เช่น 4"
              value="4"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          id="retire-target-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณเป้าหมายเงินเกษียณ</h2>

        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินก้อนเป้าหมาย</div>
            <div id="res-retire-target" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าใช้จ่ายรวมตลอดชีวิตหลังเกษียณ</div>
            <div id="res-retire-total-expense" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-yellow-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าใช้จ่าย/เดือนหลังปรับเงินเฟ้อ ณ วันเกษียณ</div>
            <div id="res-retire-inflation-adj" class="text-xl font-bold text-yellow-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าใช้จ่ายรายเดือนปัจจุบัน</span>
            <span id="res-retire-monthly" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ระยะเวลาหลังเกษียณ</span>
            <span id="res-retire-duration" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ผลตอบแทนจริง (หักเงินเฟ้อ)</span>
            <span id="res-retire-real-return" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณเป้าหมายเงินเกษียณ</h2>
      <p>
        การคำนวณเงินเกษียณที่ถูกต้องต้องพิจารณาทั้งเงินเฟ้อและผลตอบแทนจากการลงทุน เครื่องคำนวณนี้ใช้สูตรมูลค่าปัจจุบันของเงินรายงวด (Present Value of Annuity) ด้วยผลตอบแทนจริง (Real Return Rate)
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรที่ใช้</h3>
      <p>
        ผลตอบแทนจริง = (1 + ผลตอบแทน) ÷ (1 + เงินเฟ้อ) - 1<br/>
        เงินก้อนเป้าหมาย = ค่าใช้จ่ายรายเดือน × [1 - (1 + r)^(-n)] ÷ r<br/>
        โดย r = ผลตอบแทนรายเดือน, n = จำนวนเดือนหลังเกษียณ
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่าง</h3>
      <p>
        ค่าใช้จ่าย 30,000 บาท/เดือน เกษียณ 60 ปี อายุขัย 85 ปี (300 เดือน) ผลตอบแทน 4% เงินเฟ้อ 3%<br/>
        ผลตอบแทนจริงรายเดือน ≈ 0.0806%<br/>
        เงินก้อนเป้าหมาย ≈ 5.7 ล้านบาท (คิดในมูลค่าวันนี้)
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณเป้าหมายเงินเกษียณ/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางการเงิน ควรปรึกษาผู้เชี่ยวชาญด้านการวางแผนการเงินก่อนตัดสินใจ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('retire-target-form') as HTMLFormElement;
    const formError = document.getElementById('retire-target-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const monthlyExpense = parseNum((document.getElementById('retire-target-monthly') as HTMLInputElement).value);
      const retireAge = parseInt((document.getElementById('retire-target-age') as HTMLInputElement).value) || 60;
      const lifeExpectancy = parseInt((document.getElementById('retire-target-life') as HTMLInputElement).value) || 85;
      const inflation = parseNum((document.getElementById('retire-target-inflation') as HTMLInputElement).value) || 3;
      const investReturn = parseNum((document.getElementById('retire-target-return') as HTMLInputElement).value) || 4;

      if (monthlyExpense <= 0) {
        formError.classList.remove('hidden');
        (document.getElementById('retire-target-monthly') as HTMLInputElement).focus();
        return;
      }

      trackCalculatorStart('retire-target');

      const retireDurationYears = Math.max(1, lifeExpectancy - retireAge);
      const retireDurationMonths = retireDurationYears * 12;

      // Real return rate monthly
      const realReturnAnnual = (1 + investReturn / 100) / (1 + inflation / 100) - 1;
      const realReturnMonthly = Math.pow(1 + realReturnAnnual, 1 / 12) - 1;

      let targetAmount: number;
      if (Math.abs(realReturnMonthly) < 0.0000001) {
        targetAmount = monthlyExpense * retireDurationMonths;
      } else {
        targetAmount = monthlyExpense * (1 - Math.pow(1 + realReturnMonthly, -retireDurationMonths)) / realReturnMonthly;
      }

      // Total expenses over retirement (nominal, inflation-adjusted)
      // Monthly expense at retirement: monthlyExpense * (1 + inflation/100)^yearsToRetirement
      // Since we don't know current age, we display as today's value context
      const totalExpense = monthlyExpense * retireDurationMonths; // simplified total in today's money

      // Inflation-adjusted monthly expense at retirement (need current age - show note)
      // We approximate: display the real monthly value
      const inflationAdjMonthly = monthlyExpense; // in real terms, it equals monthlyExpense

      (document.getElementById('res-retire-target') as HTMLElement).textContent = fmt(targetAmount) + ' บาท';
      (document.getElementById('res-retire-total-expense') as HTMLElement).textContent = fmt(totalExpense) + ' บาท';
      (document.getElementById('res-retire-inflation-adj') as HTMLElement).textContent = fmt(monthlyExpense) + ' บาท (มูลค่าวันนี้)';
      (document.getElementById('res-retire-monthly') as HTMLElement).textContent = fmt(monthlyExpense) + ' บาท';
      (document.getElementById('res-retire-duration') as HTMLElement).textContent = retireDurationYears + ' ปี (' + retireDurationMonths + ' เดือน)';
      (document.getElementById('res-retire-real-return') as HTMLElement).textContent = (realReturnAnnual * 100).toFixed(2) + '% ต่อปี';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('retire-target');
      trackCalculatorUsed('retire-target');
    });
  </script>
</BaseLayout>
