---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณมูลค่าธุรกิจ | Kamnuanlek';
const pageDescription = 'คำนวณมูลค่าธุรกิจ Business Valuation วิธี P/E Multiple EBITDA สำหรับ SME ไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0464-มูลค่าธุรกิจ/`;
const faqData = [
  { question: 'วิธีประเมินมูลค่าธุรกิจมีกี่วิธี?', answer: 'วิธีหลักได้แก่ Asset-based (ทรัพย์สิน) Income-based (รายได้/กำไร) Market-based (เปรียบเทียบตลาด) DCF (ปัจจุบันมูลค่าอนาคต) แต่ละวิธีให้ผลต่างกัน' },
  { question: 'SME ขายธุรกิจได้ราคาเท่าไหร่?', answer: 'SME ไทยมักขายที่ 2-5 เท่าของกำไรสุทธิต่อปี หรือ 0.5-2 เท่าของรายได้ ขึ้นอยู่กับอุตสาหกรรม การเติบโต และความเสี่ยง' },
  { question: 'EBITDA คืออะไร?', answer: 'EBITDA = กำไรก่อนดอกเบี้ย ภาษี ค่าเสื่อม เหมาะใช้เปรียบเทียบธุรกิจ มูลค่าธุรกิจมักอยู่ที่ 3-8x EBITDA ขึ้นอยู่กับอุตสาหกรรม' },
  { question: 'ปัจจัยอะไรเพิ่มมูลค่าธุรกิจ?', answer: 'ปัจจัยที่เพิ่มมูลค่า: กำไรที่เติบโตต่อเนื่อง ฐานลูกค้าแข็งแกร่ง แบรนด์ที่รู้จัก ระบบงานที่ดี ทีมงานมืออาชีพ ไม่พึ่งพาเจ้าของคนเดียว' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณมูลค่าธุรกิจ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณมูลค่าธุรกิจ</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">ประเมินมูลค่าธุรกิจด้วยวิธี Multiple กำไรและรายได้</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="annual_net_profit" class="block text-sm font-medium text-gray-700 mb-1">กำไรสุทธิต่อปี (บาท)</label><input type="text" id="annual_net_profit" inputmode="decimal" placeholder="เช่น 1000000" value="1000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="profit_multiple" class="block text-sm font-medium text-gray-700 mb-1">P/E Multiple (เท่า)</label><input type="number" id="profit_multiple" min="1" max="20" step="0.5" placeholder="เช่น 3" value="3" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="annual_revenue_val" class="block text-sm font-medium text-gray-700 mb-1">รายได้ต่อปี (บาท)</label><input type="text" id="annual_revenue_val" inputmode="decimal" placeholder="เช่น 5000000" value="5000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="revenue_multiple" class="block text-sm font-medium text-gray-700 mb-1">Revenue Multiple (เท่า)</label><input type="number" id="revenue_multiple" min="0.1" max="5" step="0.1" placeholder="เช่น 0.8" value="0.8" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">มูลค่าจากกำไร (P/E)</p><p id="pe_value" class="font-bold">-</p></div>
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">มูลค่าจากรายได้</p><p id="rev_value" class="font-bold">-</p></div>
          <div class="bg-indigo-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">มูลค่าเฉลี่ย</p><p id="avg_value" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const netProfit = parseFloat((document.getElementById('annual_net_profit') as HTMLInputElement).value) || 0;
      const peMultiple = parseFloat((document.getElementById('profit_multiple') as HTMLInputElement).value) || 3;
      const revenue = parseFloat((document.getElementById('annual_revenue_val') as HTMLInputElement).value) || 0;
      const revMultiple = parseFloat((document.getElementById('revenue_multiple') as HTMLInputElement).value) || 0.8;
      const peValue = netProfit * peMultiple;
      const revValue = revenue * revMultiple;
      const avgValue = (peValue + revValue) / 2;
      (document.getElementById('pe_value') as HTMLElement).textContent = peValue.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('rev_value') as HTMLElement).textContent = revValue.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('avg_value') as HTMLElement).textContent = avgValue.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('business-valuation');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
