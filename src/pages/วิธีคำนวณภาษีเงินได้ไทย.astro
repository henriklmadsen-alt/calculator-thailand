---
import BaseLayout from '../layouts/BaseLayout.astro';

const howtoSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Calculate Thai Income Tax',
  description: 'Step-by-step guide to calculating your Thai income tax with deductions and allowances.',
  image: 'https://www.kamnuanlek.com/img/tax-guide.jpg',
  estimatedCost: {
    '@type': 'PriceSpecification',
    priceCurrency: 'THB',
    price: '0',
  },
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Calculate Total Income',
      text: 'Add all income from salary, freelance work, investments, and other sources for the entire tax year.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Deduct Allowances',
      text: 'Subtract personal allowance (60,000 THB/year) and dependent allowances (20,000 THB each for dependents).',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Calculate Taxable Income',
      text: 'Subtract all allowances from your total income to get your taxable income.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Apply Tax Brackets',
      text: 'Calculate tax using the progressive tax rate: 5% on first 150,000, 10% on 150k-300k, 15% on 300k-500k, 20% on 500k-750k, 25% on 750k-1M, and 30-37% on over 1M.',
    },
    {
      '@type': 'HowToStep',
      position: 5,
      name: 'Verify with Calculator',
      text: 'Use our income tax calculator to verify your calculation and ensure accuracy.',
    },
  ],
};
---

<BaseLayout
  title="วิธีคำนวณภาษีเงินได้บุคคลธรรมดา ทีละขั้นตอน ปี 2569 | Kamnuanlek"
  description="คำแนะนำคำนวณภาษีเงินได้ไทยทีละขั้นตอน ทำความเข้าใจการหักลดหย่อน ค่าใช้จ่าย และใช้เครื่องคำนวณฟรีที่อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "วิธีคำนวณภาษีเงินได้บุคคลธรรมดา ทีละขั้นตอน ปี 2569", "item": "https://www.kamnuanlek.com/วิธีคำนวณภาษีเงินได้ไทย/"}
    ]
  }</script>
  <script type="application/ld+json" set:html={JSON.stringify(howtoSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-8">วิธีคำนวณภาษีเงินได้บุคคลธรรมดา ทีละขั้นตอน</h1>

    <div class="mb-12 p-6 bg-blue-50 border border-blue-200 rounded-lg">
      <p class="text-lg text-gray-800">
        อัตราภาษีเงินได้ไทยอยู่ระหว่าง 5% ถึง 37% ขึ้นอยู่กับระดับรายได้ คำนวณให้ถูกต้องเพื่อหลีกเลี่ยงการเสียภาษีเกิน
      </p>
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">คู่มือทีละขั้นตอน</h2>

        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">คำนวณรายได้รวม</h3>
              <p class="text-gray-700">รวมรายได้ทุกประเภท เงินเดือน งานฟรีแลนซ์ การลงทุน ฯลฯ</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">หักค่าลดหย่อน</h3>
              <p class="text-gray-700">ค่าลดหย่อนส่วนตัว: 60,000 บาท/ปี ผู้อยู่ในความดูแล: คนละ 20,000 บาท</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">คำนวณรายได้ที่ต้องเสียภาษี</h3>
              <p class="text-gray-700">รายได้รวม - ค่าลดหย่อน = รายได้ที่ต้องเสียภาษี</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">ใช้อัตราขั้นภาษี</h3>
              <p class="text-gray-700">5% สำหรับ 150,000 แรก, 10% สำหรับ 150k-300k, 15% สำหรับ 300k-500k เป็นต้น</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">คำนวณภาษีรวม</h3>
              <p class="text-gray-700">ใช้ <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="text-primary-600 hover:underline">เครื่องคำนวณของเรา</a> ตรวจสอบ</p>
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">อัตราขั้นภาษีปี 2569</h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-gray-300">
            <thead class="bg-primary-100">
              <tr>
                <th class="border border-gray-300 p-3 text-left">ช่วงรายได้</th>
                <th class="border border-gray-300 p-3 text-left">อัตราภาษี</th>
              </tr>
            </thead>
            <tbody>
              <tr><td class="border border-gray-300 p-3">0 - 150,000</td><td class="border border-gray-300 p-3">5%</td></tr>
              <tr><td class="border border-gray-300 p-3">150,001 - 300,000</td><td class="border border-gray-300 p-3">10%</td></tr>
              <tr><td class="border border-gray-300 p-3">300,001 - 500,000</td><td class="border border-gray-300 p-3">15%</td></tr>
              <tr><td class="border border-gray-300 p-3">500,001 - 750,000</td><td class="border border-gray-300 p-3">20%</td></tr>
              <tr><td class="border border-gray-300 p-3">750,001 - 1,000,000</td><td class="border border-gray-300 p-3">25%</td></tr>
              <tr><td class="border border-gray-300 p-3">1,000,001+</td><td class="border border-gray-300 p-3">30-37%</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="mt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">แหล่งข้อมูลที่เกี่ยวข้อง</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <a href="/เปรียบเทียบเครื่องคำนวณภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
            <span class="font-semibold text-gray-900">📊 เปรียบเทียบเครื่องคำนวณภาษี</span>
            <p class="text-gray-600 text-sm mt-2">เรียนรู้ว่าต้องใช้เครื่องคำนวณภาษีตัวไหน</p>
          </a>
          <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
            <span class="font-semibold text-gray-900">💳 ศูนย์รวมเครื่องคำนวณการเงิน</span>
            <p class="text-gray-600 text-sm mt-2">เครื่องมือคำนวณการเงินทุกประเภท</p>
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
