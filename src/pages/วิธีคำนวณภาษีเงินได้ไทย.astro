---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="How to Calculate Thai Income Tax — Step-by-Step Guide | Kamnuanlek"
  description="Learn how to calculate Thai income tax step by step. Understand deductions, exemptions, and use our free calculator."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-8">How to Calculate Thai Income Tax</h1>

    <div class="mb-12 p-6 bg-blue-50 border border-blue-200 rounded-lg">
      <p class="text-lg text-gray-800">
        Thai income tax rates range from 5% to 37% depending on your income level. Calculate yours correctly to avoid overpaying.
      </p>
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Step-by-Step Guide</h2>

        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Calculate Total Income</h3>
              <p class="text-gray-700">Add all income from salary, freelance work, investments, etc.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Deduct Allowances</h3>
              <p class="text-gray-700">Personal allowance: 60,000 THB/year, Dependent: 20,000 THB each</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Calculate Taxable Income</h3>
              <p class="text-gray-700">Total Income - Allowances = Taxable Income</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">4</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Apply Tax Brackets</h3>
              <p class="text-gray-700">5% on first 150,000, 10% on 150k-300k, 15% on 300k-500k, etc.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-primary-600 text-white rounded-full flex items-center justify-center font-bold">5</div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">Calculate Total Tax</h3>
              <p class="text-gray-700">Use <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="text-primary-600 hover:underline">our calculator</a> to verify</p>
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Tax Brackets 2026</h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-gray-300">
            <thead class="bg-primary-100">
              <tr>
                <th class="border border-gray-300 p-3 text-left">Income Range</th>
                <th class="border border-gray-300 p-3 text-left">Tax Rate</th>
              </tr>
            </thead>
            <tbody>
              <tr><td class="border border-gray-300 p-3">0 - 150,000</td><td class="border border-gray-300 p-3">5%</td></tr>
              <tr><td class="border border-gray-300 p-3">150,001 - 300,000</td><td class="border border-gray-300 p-3">10%</td></tr>
              <tr><td class="border border-gray-300 p-3">300,001 - 500,000</td><td class="border border-gray-300 p-3">15%</td></tr>
              <tr><td class="border border-gray-300 p-3">500,001 - 750,000</td><td class="border border-gray-300 p-3">20%</td></tr>
              <tr><td class="border border-gray-300 p-3">750,001 - 1,000,000</td><td class="border border-gray-300 p-3">25%</td></tr>
              <tr><td class="border border-gray-300 p-3">1,000,001+</td><td class="border border-gray-300 p-3">30-37%</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="mt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <a href="/เปรียบเทียบเครื่องคำนวณภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
            <span class="font-semibold text-gray-900">📊 Tax Calculator Comparison</span>
            <p class="text-gray-600 text-sm mt-2">Learn which tax calculator you need</p>
          </a>
          <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
            <span class="font-semibold text-gray-900">💳 Financial Calculators Hub</span>
            <p class="text-gray-600 text-sm mt-2">All your financial calculation tools</p>
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
