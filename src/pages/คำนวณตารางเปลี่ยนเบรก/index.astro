---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณตารางเปลี่ยนเบรกรถยนต์ ปี 2569 | ระยะเปลี่ยนผ้าเบรก | Calculator Thailand';
const pageDescription = 'คำนวณช่วงเวลาและระยะทางที่ต้องเปลี่ยนผ้าเบรกรถยนต์ พร้อมประมาณค่าใช้จ่าย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณตารางเปลี่ยนเบรก/`;

const faqData = [
  {
    question: 'ผ้าเบรกควรเปลี่ยนเมื่อความหนาเหลือเท่าไร?',
    answer: 'ผ้าเบรกที่มีความหนาต่ำกว่า 2 มม. ถือว่าถึงขีดจำกัดความปลอดภัยและต้องเปลี่ยนทันที โดยทั่วไปผ้าเบรกใหม่จะมีความหนาประมาณ 10–12 มม. ช่างผู้เชี่ยวชาญแนะนำให้เริ่มวางแผนเปลี่ยนเมื่อความหนาเหลือ 3–4 มม. เพื่อความปลอดภัยและหลีกเลี่ยงการเสียหายของจานเบรก',
  },
  {
    question: 'สัญญาณอะไรบ่งบอกว่าผ้าเบรกใกล้หมด?',
    answer: 'สัญญาณที่ควรสังเกต ได้แก่ เสียงดังแหลมหรือกรีดเมื่อเบรก (ตัวบ่งบอกโลหะสัมผัสจานเบรก) ระยะเบรกยาวขึ้น รถดึงออกข้างใดข้างหนึ่งเมื่อเบรก คันเร่งหรือพวงมาลัยสั่นเมื่อเบรก และไฟเตือนระบบเบรกติดบนแผงหน้าปัด ควรตรวจสอบทันทีหากพบสัญญาณเหล่านี้',
  },
  {
    question: 'ค่าเปลี่ยนผ้าเบรกรถยนต์ในไทยราคาเท่าไร?',
    answer: 'ค่าเปลี่ยนผ้าเบรกในประเทศไทยขึ้นอยู่กับยี่ห้อรถและคุณภาพผ้าเบรก โดยทั่วไปผ้าเบรกหน้าหนึ่งคู่ราคา 500–2,500 บาท ค่าแรง 300–800 บาทต่อเพลา รถยุโรปหรือรถหรูอาจมีราคาสูงกว่านี้หลายเท่า ควรเปรียบเทียบราคาและใช้ผ้าเบรกคุณภาพมาตรฐาน OEM หรือเทียบเท่า',
  },
  {
    question: 'เบรกหน้ากับเบรกหลังสึกหรอต่างกันอย่างไร?',
    answer: 'เบรกหน้าของรถยนต์ทั่วไปรับภาระมากกว่าเบรกหลัง 60–70% เนื่องจากน้ำหนักรถจะถ่ายไปด้านหน้าเมื่อเบรก ทำให้ผ้าเบรกหน้าสึกเร็วกว่าผ้าเบรกหลังประมาณ 2 เท่า ผ้าเบรกหน้าอาจต้องเปลี่ยนทุก 30,000–50,000 กม. ขณะที่ผ้าเบรกหลังอาจอยู่ได้ถึง 60,000–80,000 กม.',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณตารางเปลี่ยนเบรกรถยนต์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณตารางเปลี่ยนเบรกรถยนต์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณตารางเปลี่ยนเบรกรถยนต์
    </h1>
    <p class="text-gray-600 mb-6">
      คำนวณระยะทางและเวลาที่เหลือก่อนต้องเปลี่ยนผ้าเบรก พร้อมประมาณค่าใช้จ่ายและต้นทุนต่อกิโลเมตร
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="calculator-form" class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="current-thickness" class="block text-sm font-medium text-gray-700 mb-1">
              ความหนาผ้าเบรกปัจจุบัน (มม.)
            </label>
            <input
              type="text"
              id="current-thickness"
              inputmode="decimal"
              placeholder="เช่น 7"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="min-thickness" class="block text-sm font-medium text-gray-700 mb-1">
              ความหนาขั้นต่ำที่ปลอดภัย (มม.)
            </label>
            <input
              type="text"
              id="min-thickness"
              inputmode="decimal"
              placeholder="เช่น 2"
              value="2"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="wear-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราสึกหรอ (มม. ต่อ 10,000 กม.)
            </label>
            <input
              type="text"
              id="wear-rate"
              inputmode="decimal"
              placeholder="เช่น 2"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="monthly-km" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะทางเฉลี่ยต่อเดือน (กม.)
            </label>
            <input
              type="text"
              id="monthly-km"
              inputmode="decimal"
              placeholder="เช่น 2000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="pad-price" class="block text-sm font-medium text-gray-700 mb-1">
              ราคาผ้าเบรก (บาท)
            </label>
            <input
              type="text"
              id="pad-price"
              inputmode="decimal"
              placeholder="เช่น 1200"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="labor-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าแรง (บาท)
            </label>
            <input
              type="text"
              id="labor-cost"
              inputmode="decimal"
              placeholder="เช่น 500"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>
        <button
          type="button"
          id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ
        </button>
      </form>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-blue-700 font-medium mb-1">ระยะทางที่เหลือได้ใช้งาน</div>
            <div id="res-remaining-km" class="text-2xl font-bold text-blue-800">-</div>
            <div class="text-xs text-blue-600 mt-1">กิโลเมตร</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4">
            <div class="text-sm text-purple-700 font-medium mb-1">เวลาที่เหลือโดยประมาณ</div>
            <div id="res-remaining-months" class="text-2xl font-bold text-purple-800">-</div>
            <div class="text-xs text-purple-600 mt-1">เดือน</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4">
            <div class="text-sm text-green-700 font-medium mb-1">ค่าใช้จ่ายในการเปลี่ยน</div>
            <div id="res-replace-cost" class="text-2xl font-bold text-green-800">-</div>
            <div class="text-xs text-green-600 mt-1">บาท</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4">
            <div class="text-sm text-orange-700 font-medium mb-1">ต้นทุนเบรกต่อกิโลเมตร</div>
            <div id="res-cost-per-km" class="text-2xl font-bold text-orange-800">-</div>
            <div class="text-xs text-orange-600 mt-1">บาท/กม.</div>
          </div>
        </div>
        <div id="status-panel" class="rounded-lg p-4 border">
          <div id="status-label" class="text-sm font-medium mb-1">สถานะผ้าเบรก</div>
          <div id="status-message" class="text-base font-semibold">-</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">การเปลี่ยนผ้าเบรกรถยนต์และความสำคัญต่อความปลอดภัย</h2>
      <p>
        ผ้าเบรกเป็นชิ้นส่วนที่สึกหรอตามการใช้งานและต้องเปลี่ยนตามกำหนด
        การปล่อยให้ผ้าเบรกหมดจนถึงโลหะจะทำให้จานเบรกเสียหายและมีค่าซ่อมสูงกว่าการเปลี่ยนผ้าเบรกตามปกติหลายเท่า
        อัตราการสึกหรอของผ้าเบรกขึ้นอยู่กับพฤติกรรมการขับ สภาพถนน และน้ำหนักรถ
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณระยะทางที่เหลือ</h3>
      <div class="bg-gray-50 rounded-lg p-4 my-4 space-y-2">
        <p class="font-medium">ความหนาที่ใช้ได้อีก (มม.) = ความหนาปัจจุบัน − ความหนาขั้นต่ำ</p>
        <p class="font-medium">ระยะทางที่เหลือ (กม.) = (ความหนาที่ใช้ได้อีก ÷ อัตราสึกหรอ) × 10,000</p>
        <p class="font-semibold text-primary-700">เดือนที่เหลือ = ระยะทางที่เหลือ ÷ ระยะทางต่อเดือน</p>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ปัจจัยที่ทำให้ผ้าเบรกสึกเร็ว</h3>
      <p>
        การขับในเมืองที่มีการจราจรหนาแน่นและต้องเบรกบ่อยทำให้ผ้าเบรกสึกเร็วกว่าการขับทางหลวง
        การเบรกแรงกะทันหัน การขับบนทางลงเชิงเขา และการบรรทุกน้ำหนักมากล้วนเพิ่มอัตราสึกหรอ
        ในประเทศไทยที่มีการจราจรหนาแน่นในเมือง ผ้าเบรกอาจสึกเร็วกว่าค่าเฉลี่ย 20–30%
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณตารางเปลี่ยนเบรก/" />
    <RelatedCalculators currentHref="/คำนวณตารางเปลี่ยนเบรก/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการตามข้อมูลที่กรอก
      อัตราสึกหรอจริงขึ้นอยู่กับพฤติกรรมการขับ สภาพถนน และยี่ห้อผ้าเบรก
      ควรให้ช่างผู้เชี่ยวชาญตรวจสอบระบบเบรกโดยตรงเป็นประจำ อย่าละเลยสัญญาณเตือนจากระบบเบรก
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number, decimals = 2): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: decimals, maximumFractionDigits: decimals }).format(n);
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const currentThickness = parseNum((document.getElementById('current-thickness') as HTMLInputElement).value);
      const minThickness = parseNum((document.getElementById('min-thickness') as HTMLInputElement).value) || 2;
      const wearRate = parseNum((document.getElementById('wear-rate') as HTMLInputElement).value);
      const monthlyKm = parseNum((document.getElementById('monthly-km') as HTMLInputElement).value);
      const padPrice = parseNum((document.getElementById('pad-price') as HTMLInputElement).value);
      const laborCost = parseNum((document.getElementById('labor-cost') as HTMLInputElement).value);

      if (currentThickness <= 0 || wearRate <= 0 || monthlyKm <= 0) {
        alert('กรุณากรอกความหนาผ้าเบรก อัตราสึกหรอ และระยะทางต่อเดือน');
        return;
      }

      const usableThickness = Math.max(0, currentThickness - minThickness);
      const remainingKm = (usableThickness / wearRate) * 10000;
      const remainingMonths = monthlyKm > 0 ? remainingKm / monthlyKm : 0;
      const totalCost = padPrice + laborCost;
      const totalUsableKm = (Math.max(0, currentThickness - minThickness) + (currentThickness > minThickness ? 0 : 0)) > 0
        ? remainingKm
        : 0;
      // Cost per km based on full pad life from new (assume new pad ~10mm)
      const fullLifeKm = ((10 - minThickness) / wearRate) * 10000;
      const costPerKm = totalCost > 0 && fullLifeKm > 0 ? totalCost / fullLifeKm : 0;

      (document.getElementById('res-remaining-km') as HTMLElement).textContent = fmt(remainingKm, 0);
      (document.getElementById('res-remaining-months') as HTMLElement).textContent = fmt(remainingMonths, 1);
      (document.getElementById('res-replace-cost') as HTMLElement).textContent = totalCost > 0 ? fmt(totalCost, 0) : 'ไม่ระบุ';
      (document.getElementById('res-cost-per-km') as HTMLElement).textContent = costPerKm > 0 ? fmt(costPerKm, 4) : 'ไม่ระบุ';

      const panel = document.getElementById('status-panel') as HTMLElement;
      const label = document.getElementById('status-label') as HTMLElement;
      const message = document.getElementById('status-message') as HTMLElement;

      if (currentThickness <= minThickness) {
        panel.className = 'rounded-lg p-4 border border-red-300 bg-red-50';
        label.className = 'text-sm font-medium mb-1 text-red-700';
        label.textContent = 'สถานะผ้าเบรก — ต้องเปลี่ยนทันที!';
        message.className = 'text-base font-semibold text-red-800';
        message.textContent = 'ผ้าเบรกถึงขีดจำกัดความปลอดภัยแล้ว — ห้ามขับรถก่อนเปลี่ยน!';
      } else if (remainingMonths < 3) {
        panel.className = 'rounded-lg p-4 border border-orange-300 bg-orange-50';
        label.className = 'text-sm font-medium mb-1 text-orange-700';
        label.textContent = 'สถานะผ้าเบรก — ใกล้ถึงเวลาเปลี่ยน';
        message.className = 'text-base font-semibold text-orange-800';
        message.textContent = `อีกประมาณ ${fmt(remainingMonths, 1)} เดือน (${fmt(remainingKm, 0)} กม.) — ควรเริ่มนัดช่างได้แล้ว`;
      } else {
        panel.className = 'rounded-lg p-4 border border-green-300 bg-green-50';
        label.className = 'text-sm font-medium mb-1 text-green-700';
        label.textContent = 'สถานะผ้าเบรก — ยังอยู่ในเกณฑ์ดี';
        message.className = 'text-base font-semibold text-green-800';
        message.textContent = `ยังใช้งานได้อีกประมาณ ${fmt(remainingMonths, 1)} เดือน (${fmt(remainingKm, 0)} กม.)`;
      }

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
    });

    document.querySelectorAll('#calculator-form input').forEach(input => {
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
