---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculateElectricityBill } from '../../lib/klc-0577-electricity-bill-mea';

const pageTitle = 'คำนวณค่าไฟฟ้า MEA/PEA ปี 2569 | บิลไฟรายเดือน | Kamnuanlek';
const pageDescription = 'คำนวณค่าไฟฟ้าขั้นบันไดรายเดือนตามอัตรา MEA/PEA พร้อม VAT 7% ปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0577-ค่าไฟฟ้า-mea/`;

const faqData = [
  {
    question: 'MEA และ PEA ต่างกันอย่างไร?',
    answer: 'MEA = การไฟฟ้านครหลวง (จังหวัดกรุงเทพและปริมณฑล) | PEA = การไฟฟ้าส่วนภูมิภาค (ต่างจังหวัด) อัตราค่าไฟแตกต่างกัน',
  },
  {
    question: 'ท่านต้องเลือก MEA หรือ PEA อย่างไร?',
    answer: 'ตรวจสอบใบแจ้งหนี้ไฟฟ้า (ด้านบนแสดงผู้จัดจ่าย) หรือดูจังหวัดที่อยู่ของคุณ',
  },
  {
    question: 'VAT 7% คืออะไร?',
    answer: 'ภาษีมูลค่าเพิ่ม สำหรับค่าไฟบ้าน VAT คิดจากยอดรวมค่าไฟ + ค่าบริการ',
  },
  {
    question: 'ขั้นบันไดค่าไฟหมายความอย่างไร?',
    answer: 'ยิ่งใช้ไฟมาก ราคาต่อหน่วยยิ่งแพง เช่น 15 หน่วยแรก ราคา 2.35 บาท แต่หน่วยที่ 16-25 ราคา 2.99 บาท',
  },
  {
    question: 'ผลการคำนวณแตกต่างจากจริงได้หรือ?',
    answer: 'อาจแตกต่างบ้างเนื่องจากอัตราค่าไฟอาจมีการปรับปรุง ดูใบแจ้งหนี้ปัจจุบันเพื่อยืนยันอัตรา',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าไฟฟ้า MEA/PEA',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="klc0577-electricity">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-yellow-100 bg-yellow-50 p-4">
      <p class="text-sm font-semibold text-yellow-700">คำนวณค่าไฟฟ้า MEA/PEA</p>
      <p class="mt-1 text-sm text-slate-700">อัตราขั้นบันไดปี 2569 พร้อม VAT 7%</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าไฟฟ้าบ้าน MEA/PEA ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนจำนวนหน่วย (kWh) ที่ใช้ เลือกผู้จัดจ่าย และระบบจะคำนวณค่าไฟตามอัตราขั้นบันไดปัจจุบัน
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc_klc0577" class="space-y-5">
        <div>
          <label for="units" class="mb-1 block text-sm font-medium text-gray-700">จำนวนหน่วย (kWh) *</label>
          <input type="number" id="units" step="1" min="0" max="1000" placeholder="เช่น 80" required
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          <p class="mt-1 text-xs text-gray-500">ตรวจสอบใบแจ้งหนี้ของคุณ</p>
        </div>

        <div>
          <label for="provider" class="mb-1 block text-sm font-medium text-gray-700">ผู้จัดจ่าย *</label>
          <select id="provider" required
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
            <option value="">เลือก...</option>
            <option value="mea">MEA - การไฟฟ้านครหลวง (กรุงเทพและปริมณฑล)</option>
            <option value="pea">PEA - การไฟฟ้าส่วนภูมิภาค (ต่างจังหวัด)</option>
          </select>
        </div>

        <button type="submit" class="w-full rounded-md bg-yellow-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-yellow-700 focus:outline-none focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 sm:w-auto">
          คำนวณค่าไฟฟ้า
        </button>
      </form>
    </div>

    <div id="results_klc0577" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-6 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>

        <div class="space-y-3">
          <div class="flex justify-between border-b border-gray-200 pb-3">
            <span class="text-gray-600">ค่าไฟฟ้า (ขั้นบันไดเทียบ)</span>
            <span id="res_energy" class="font-semibold">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-200 pb-3">
            <span class="text-gray-600">ค่าบริการ</span>
            <span id="res_service" class="font-semibold">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-200 pb-3">
            <span class="text-gray-600">รวมก่อน VAT</span>
            <span id="res_subtotal" class="font-semibold">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-200 pb-3">
            <span class="text-gray-600">VAT 7%</span>
            <span id="res_vat" class="font-semibold">-</span>
          </div>
          <div class="flex justify-between rounded-lg bg-green-50 p-3">
            <span class="font-semibold text-gray-900">บิลทั้งหมด</span>
            <span id="res_total" class="text-xl font-bold text-green-700">-</span>
          </div>
        </div>

        <details class="mt-6 rounded-lg border border-gray-200 p-3">
          <summary class="cursor-pointer font-semibold text-gray-900">รายละเอียดขั้นบันไดค่าไฟ</summary>
          <div id="res_tiers" class="mt-3 space-y-2 text-sm"></div>
        </details>
      </div>
    </div>

    <div class="mb-8 rounded-lg border border-blue-100 bg-blue-50 p-4 sm:p-6">
      <h2 class="mb-4 text-lg font-semibold text-blue-900">ตัวอย่างการคำนวณ</h2>
      <div class="space-y-2 text-sm">
        <p><strong>บ้านถึกน้ิด (40 kWh):</strong> MEA ≈ 150 บาท | PEA ≈ 130 บาท</p>
        <p><strong>บ้านทั่วไป (80 kWh):</strong> MEA ≈ 300 บาท | PEA ≈ 260 บาท</p>
        <p><strong>บ้านใช้แอร์ (150 kWh):</strong> MEA ≈ 600 บาท | PEA ≈ 520 บาท</p>
      </div>
    </div>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-4 text-lg font-semibold text-gray-900">คำถามที่ถามบ่อย</h2>
      <div class="space-y-3">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 p-3">
            <summary class="cursor-pointer font-semibold text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <p class="mt-2 text-sm text-gray-600">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <div class="rounded-lg border border-yellow-100 bg-yellow-50 p-4 sm:p-6">
      <h3 class="font-semibold text-yellow-900">⚠️ สำคัญ</h3>
      <p class="mt-2 text-sm text-yellow-800">
        ผลการคำนวณนี้เป็นการประมาณเท่านั้น อัตราค่าไฟอาจเปลี่ยนแปลง ตรวจสอบใบแจ้งหนี้ปัจจุบันเพื่อยืนยันอัตรา
        สำหรับสูตรอัปเดตล่าสุด โปรดติดต่อ MEA (1129) หรือ PEA (1 023 ต่อจังหวัด) โดยตรง
      </p>
    </div>
  </article>

  <script define:vars={{calculateElectricityBill}} client:load>
    const form = document.getElementById('calc_klc0577');
    const resultsDiv = document.getElementById('results_klc0577');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();

      const units = parseFloat(document.getElementById('units').value);
      const provider = document.getElementById('provider').value;

      if (!units || !provider) return;

      const result = window.calculateElectricityBill({
        units,
        provider,
        customerType: 'residential',
      });

      document.getElementById('res_energy').textContent = `฿${result.energyCharge.toLocaleString('th-TH')}`;
      document.getElementById('res_service').textContent = `฿${result.serviceCharge.toLocaleString('th-TH')}`;
      document.getElementById('res_subtotal').textContent = `฿${result.subtotal.toLocaleString('th-TH')}`;
      document.getElementById('res_vat').textContent = `฿${result.vat.toLocaleString('th-TH')}`;
      document.getElementById('res_total').textContent = `฿${result.totalBill.toLocaleString('th-TH')}`;

      const tiersHtml = result.tiers.map(t =>
        `<div class="flex justify-between"><span>${t.label}</span><span>${t.units} × ฿${t.rate.toFixed(2)} = ฿${t.amount.toLocaleString('th-TH')}</span></div>`
      ).join('');
      document.getElementById('res_tiers').innerHTML = tiersHtml;

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth' });
    });
  </script>
</BaseLayout>
