---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ SSF RMF มูลค่าอนาคต 2569 | ลดหย่อนภาษี | Kamnuanlek';
const pageDescription = 'คำนวณมูลค่าอนาคตจากการลงทุน SSF และ RMF พร้อมสิทธิลดหย่อนภาษีสูงสุด 500,000 บาท';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณมูลค่าอนาคต-ssf-rmf/`;

const faqData = [
  {
    question: 'SSF และ RMF ต่างกันอย่างไร?',
    answer: 'SSF (Super Savings Fund) ลดหย่อนได้ไม่เกิน 30% ของรายได้ สูงสุด 200,000 บาท/ปี ถือครองขั้นต่ำ 10 ปี ส่วน RMF (Retirement Mutual Fund) ลดหย่อนได้ไม่เกิน 30% รวม PVD ไม่เกิน 500,000 บาท ถือจนอายุ 55 ปีและลงทุนต่อเนื่องไม่น้อยกว่า 5 ปี',
  },
  {
    question: 'ควรลงทุน SSF หรือ RMF ก่อน?',
    answer: 'ถ้าเป้าหมายหลักคือเกษียณ RMF เหมาะกว่าเพราะบังคับถือจนเกษียณ ถ้าต้องการความยืดหยุ่นมากกว่าและมีรายได้สูง SSF เหมาะกว่า ควรทำทั้งสองถ้ายังมีสิทธิ์ลดหย่อน',
  },
  {
    question: 'ลงทุน RMF/SSF แล้วประหยัดภาษีได้เท่าไหร่?',
    answer: 'ขึ้นอยู่กับฐานภาษีสูงสุดของแต่ละคน เช่น ถ้าอยู่ในฐาน 30% ลงทุน 100,000 บาท ประหยัดภาษีได้ 30,000 บาท ถ้าอยู่ในฐาน 20% ประหยัดได้ 20,000 บาท',
  },
  {
    question: 'ผลตอบแทน RMF/SSF โดยเฉลี่ยอยู่ที่เท่าไหร่?',
    answer: 'ขึ้นอยู่กับประเภทกองทุน กองทุนหุ้นระยะยาวเฉลี่ย 7–12%/ปี กองทุนผสม 5–8%/ปี กองทุนตราสารหนี้ 2–4%/ปี ควรเลือกตามความเสี่ยงและระยะเวลาลงทุน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณมูลค่าอนาคต SSF RMF',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณมูลค่าอนาคต-ssf-rmf">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-emerald-100 bg-emerald-50 p-4">
      <p class="text-sm font-semibold text-emerald-700">📈 คำนวณมูลค่าอนาคต SSF / RMF</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: FV = P(1+r)^n + PMT×[(1+r)^n−1]÷r | ภาษีประหยัด = ลงทุน × อัตราภาษี</p>
      <p class="mt-1 text-xs font-medium text-emerald-800">ลงทุนลดหย่อนภาษีพร้อมวางแผนเกษียณในกองทุนเดียว</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณมูลค่าอนาคต SSF / RMF ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกยอดลงทุน อัตราผลตอบแทน ระยะเวลา และฐานภาษี เพื่อดูมูลค่าในอนาคตและภาษีที่ประหยัดได้
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="ssf-form" class="space-y-5">
        <p id="ssf-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="mb-2">
          <label class="mb-1 block text-sm font-medium text-gray-700">ประเภทกองทุน</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 text-sm"><input type="radio" name="fund-type" value="ssf" checked class="text-primary-600" /> SSF (10 ปี)</label>
            <label class="flex items-center gap-2 text-sm"><input type="radio" name="fund-type" value="rmf" class="text-primary-600" /> RMF (จนอายุ 55)</label>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ssf-annual" class="mb-1 block text-sm font-medium text-gray-700">ลงทุนต่อปี (บาท)</label>
            <input type="text" id="ssf-annual" inputmode="numeric" placeholder="เช่น 100,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ssf-annual-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ssf-current" class="mb-1 block text-sm font-medium text-gray-700">ยอดกองทุนปัจจุบัน (บาท)</label>
            <input type="text" id="ssf-current" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="ssf-return" class="mb-1 block text-sm font-medium text-gray-700">ผลตอบแทน (% ต่อปี)</label>
            <input type="text" id="ssf-return" inputmode="numeric" placeholder="เช่น 8"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ssf-return-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ssf-years" class="mb-1 block text-sm font-medium text-gray-700">จำนวนปีลงทุน</label>
            <input type="text" id="ssf-years" inputmode="numeric" placeholder="เช่น 10"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ssf-years-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ssf-tax" class="mb-1 block text-sm font-medium text-gray-700">ฐานภาษีสูงสุด (%)</label>
            <select id="ssf-tax" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="5">5%</option>
              <option value="10">10%</option>
              <option value="15">15%</option>
              <option value="20" selected>20%</option>
              <option value="25">25%</option>
              <option value="30">30%</option>
              <option value="35">35%</option>
            </select>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณมูลค่า SSF/RMF
        </button>
      </form>
    </div>

    <div id="ssf-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-4">
          <div class="rounded-lg bg-emerald-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">มูลค่าในอนาคต</div>
            <div id="res-ssf-fv" class="text-xl font-bold text-emerald-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ลงทุนรวม</div>
            <div id="res-ssf-total-invest" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ผลตอบแทนสะสม</div>
            <div id="res-ssf-gain" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-purple-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ภาษีประหยัดรวม</div>
            <div id="res-ssf-tax-save" class="text-xl font-bold text-purple-700">-</div>
          </div>
        </div>
        <p id="ssf-status" class="rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สิทธิลดหย่อนภาษี</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>SSF: ลดหย่อนได้ 30% ของรายได้ สูงสุด 200,000 บาท/ปี ถือครองขั้นต่ำ 10 ปี</li>
        <li>RMF: ลดหย่อนได้ 30% ของรายได้ รวม PVD ไม่เกิน 500,000 บาท/ปี ถือจนอายุ 55 ปี</li>
        <li>ขาย SSF/RMF ก่อนกำหนดต้องคืนภาษีที่ได้ลดหย่อนไปทั้งหมด</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#ssf-results" />
    <RelatedArticles currentHref="/คำนวณมูลค่าอนาคต-ssf-rmf/" />
    <RelatedCalculators currentHref="/คำนวณมูลค่าอนาคต-ssf-rmf/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ ผลตอบแทนจริงอาจแตกต่าง กฎหมายภาษีอาจเปลี่ยนแปลง ควรปรึกษาผู้เชี่ยวชาญด้านภาษีก่อนลงทุน
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return 0;
      const n = Number(s);
      return Number.isFinite(n) && n >= 0 ? n : 0;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('ssf-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('ssf-error').classList.add('hidden');
      ['ssf-annual-error','ssf-return-error','ssf-years-error'].forEach(id => setErr(id, ''));

      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('ssf-rmf-future-value');
      const annual = parseNum(document.getElementById('ssf-annual').value);
      const current = parseNum(document.getElementById('ssf-current').value);
      const returnRate = parseNum(document.getElementById('ssf-return').value);
      const years = parseNum(document.getElementById('ssf-years').value);
      const taxRate = parseFloat(document.getElementById('ssf-tax').value);

      let hasError = false;
      if (!annual || annual <= 0) { setErr('ssf-annual-error', 'กรอกยอดลงทุนต่อปี'); hasError = true; }
      if (!returnRate || returnRate <= 0) { setErr('ssf-return-error', 'กรอกผลตอบแทน'); hasError = true; }
      if (!years || years <= 0) { setErr('ssf-years-error', 'กรอกจำนวนปี'); hasError = true; }
      if (hasError) { document.getElementById('ssf-error').classList.remove('hidden'); document.getElementById('ssf-results').classList.add('hidden'); return; }

      const r = returnRate / 100 / 12;
      const n = years * 12;
      const pmt = annual / 12;
      const fvPrincipal = current * Math.pow(1 + r, n);
      const fvPmt = pmt * (Math.pow(1 + r, n) - 1) / r;
      const fv = fvPrincipal + fvPmt;
      const totalInvest = current + annual * years;
      const gain = fv - totalInvest;
      const taxSave = annual * (taxRate / 100) * years;

      setText('res-ssf-fv', formatMoney(fv));
      setText('res-ssf-total-invest', formatMoney(totalInvest));
      setText('res-ssf-gain', formatMoney(gain));
      setText('res-ssf-tax-save', formatMoney(taxSave));

      const fundType = document.querySelector('input[name="fund-type"]:checked').value.toUpperCase();
      const statusEl = document.getElementById('ssf-status');
      statusEl.className = 'rounded-lg bg-emerald-50 p-3 text-sm font-medium text-emerald-800 border border-emerald-200';
      statusEl.textContent = `ลงทุน ${fundType} ปีละ ${formatMoney(annual)} ที่ผลตอบแทน ${returnRate}%/ปี ใน ${years} ปี จะได้ ${formatMoney(fv)} และประหยัดภาษีรวม ${formatMoney(taxSave)}`;

      document.getElementById('ssf-results').classList.remove('hidden');
      document.getElementById('ssf-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('ssf-rmf-future-value');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('ssf-rmf-future-value');
    });
  </script>
</BaseLayout>
