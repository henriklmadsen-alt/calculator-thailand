---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่า LINE Official Account ปี 2569 — ค่าใช้จ่าย LINE บิซิเนส';
const pageDescription = 'คำนวณค่าใช้จ่ายรายเดือน LINE Official Account และบอท ป้อนจำนวนข้อความและจำนวนผู้ติดตาม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่า-line-official-account/`;

const faqData = [
  {
    question: 'ค่า LINE Official Account คืออะไร?',
    answer: 'ค่าใช้จ่ายรายเดือนสำหรับการใช้งาน LINE Official Account เพื่อติดต่อกับลูกค้า ขึ้นอยู่กับจำนวนข้อความและฟีเจอร์',
  },
  {
    question: 'ค่าใช้จ่ายประกอบด้วยอะไรบ้าง?',
    answer: 'ค่าบริการพื้นฐาน (0–300 บาท) + ค่าข้อความ (บางแพลนฟรี บางแพลนคิดตามจำนวน) + ฟีเจอร์เพิ่มเติม',
  },
  {
    question: 'เลือกแพลนไหนดีสำหรับธุรกิจเล็ก?',
    answer: 'สำหรับธุรกิจเล็กเริ่มต้น ลองใช้ฟรี LINE Official Account ก่อน ส่วนใหญ่มี 200 ข้อความฟรีต่อเดือน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่า LINE Official Account',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-ค่า-line-official-account">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-green-100 bg-green-50 p-4">
      <p class="text-sm font-semibold text-green-700">คำนวณค่า LINE Official Account — ค่าใช้จ่ายบิซิเนส LINE</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: ค่าใช้จ่าย = ค่าแพลน + (ข้อความที่เกิน × อัตรา)</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่า LINE Official Account ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนจำนวนข้อความและจำนวนผู้ติดตาม เพื่อประมาณการค่าใช้จ่ายรายเดือน
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="line-form" class="space-y-5">
        <p id="line-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="messages" class="mb-1 block text-sm font-medium text-gray-700">จำนวนข้อความต่อเดือน</label>
            <input type="text" id="messages" inputmode="numeric" placeholder="เช่น 5000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">แพลน Basic: 0–200 ฟรี, Lite: 200–2000 ฟรี</p>
          </div>
          <div>
            <label for="followers" class="mb-1 block text-sm font-medium text-gray-700">จำนวนผู้ติดตาม</label>
            <input type="text" id="followers" inputmode="numeric" placeholder="เช่น 10000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div>
          <label for="plan" class="mb-1 block text-sm font-medium text-gray-700">เลือกแพลน</label>
          <select id="plan" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
            <option value="free">Free (ฟรี 200 ข้อความ)</option>
            <option value="light">Light (99 บาท)</option>
            <option value="standard">Standard (299 บาท)</option>
            <option value="pro">Pro (899 บาท)</option>
          </select>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณค่าใช้จ่าย
        </button>
      </form>
    </div>

    <!-- Results Section -->
    <div id="line-results" class="mb-8 hidden rounded-lg border border-green-200 bg-green-50 p-6">
      <h2 class="mb-4 text-lg font-bold text-gray-900">ผลการคำนวณ</h2>
      <div class="space-y-3">
        <div class="flex justify-between border-b border-green-200 pb-2">
          <span class="text-gray-700">จำนวนข้อความ</span>
          <span id="result-messages" class="font-semibold text-gray-900">0 ข้อความ</span>
        </div>
        <div class="flex justify-between border-b border-green-200 pb-2">
          <span class="text-gray-700">แพลน</span>
          <span id="result-plan" class="font-semibold text-gray-900">Free</span>
        </div>
        <div class="flex justify-between bg-blue-100 p-2 rounded font-bold">
          <span class="text-blue-700">ค่าแพลนพื้นฐาน</span>
          <span id="result-plan-cost" class="text-blue-700">0 บาท</span>
        </div>
        <div class="flex justify-between bg-green-100 p-2 rounded font-bold">
          <span class="text-green-700">ค่าใช้จ่ายรวม (รายเดือน)</span>
          <span id="result-total" class="text-green-700">0 บาท</span>
        </div>
      </div>
    </div>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="mb-4 text-lg font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="border-b border-gray-200 pb-4">
            <summary class="cursor-pointer font-semibold text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <p class="mt-2 text-sm text-gray-600">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </article>

  <GuardedAdSlot position="after-content" class="my-8" />
  <RelatedCalculators currentPath="/คำนวณ-ค่า-line-official-account/" limit={3} />
  <RelatedArticles limit={3} />
</BaseLayout>

<script>
  const form = document.getElementById('line-form') as HTMLFormElement;
  const resultsDiv = document.getElementById('line-results') as HTMLDivElement;
  const errorDiv = document.getElementById('line-error') as HTMLDivElement;

  const messagesInput = document.getElementById('messages') as HTMLInputElement;
  const followersInput = document.getElementById('followers') as HTMLInputElement;
  const planSelect = document.getElementById('plan') as HTMLSelectElement;

  const planCosts: Record<string, number> = {
    free: 0,
    light: 99,
    standard: 299,
    pro: 899,
  };

  const freeLimits: Record<string, number> = {
    free: 200,
    light: 2000,
    standard: 5000,
    pro: 10000,
  };

  const extraCosts: Record<string, number> = {
    free: 0.20,
    light: 0.15,
    standard: 0.10,
    pro: 0.08,
  };

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');

      const messages = parseInt(messagesInput.value.replace(/,/g, '').trim());
      const plan = planSelect.value;

      if (!messages || messages <= 0) {
        errorDiv.classList.remove('hidden');
        resultsDiv.classList.add('hidden');
        return;
      }

      const baseCost = planCosts[plan];
      const freeLimit = freeLimits[plan];
      const costPerExtra = extraCosts[plan];

      let totalCost = baseCost;
      if (messages > freeLimit) {
        const extraMessages = messages - freeLimit;
        totalCost += extraMessages * costPerExtra;
      }
      totalCost = Math.round(totalCost * 100) / 100;

      const planLabel = { free: 'Free', light: 'Light (99บ)', standard: 'Standard (299บ)', pro: 'Pro (899บ)' }[plan];

      document.getElementById('result-messages')!.textContent = messages.toLocaleString('th-TH') + ' ข้อความ';
      document.getElementById('result-plan')!.textContent = planLabel || '';
      document.getElementById('result-plan-cost')!.textContent = baseCost.toFixed(0) + ' บาท';
      document.getElementById('result-total')!.textContent = totalCost.toLocaleString('th-TH', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }) + ' บาท';

      resultsDiv.classList.remove('hidden');
    });
  }
</script>
