---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าห้องแรม โรงแรม 2569 | ค่าธรรมเนียม ค่าบริการ | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าห้องแรม ค่าบริการโรงแรม ค่าอากรประกอบการ ค่าคืนห้องก่อนเวลา ตามอัตรา 2569 ฟรีออนไลน์';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าห้องแรม/`;

const faqData = [
  {
    question: 'ค่าห้องแรมประกอบด้วยอะไรบ้าง?',
    answer: 'ค่าห้องแรมประกอบด้วย: (1) ค่าห้องพื้นฐาน (Room Rate) (2) ค่าบริการโรงแรม (Service Charge 10%) (3) ภาษี VAT 7% (4) ค่าเพิ่มเติมเช่น เตียงเสริม คืนห้องก่อนเวลา',
  },
  {
    question: 'ค่าบริการโรงแรมคิดเป็นเท่าไร?',
    answer: 'ค่าบริการโรงแรมมาตรฐานในไทยคิดเป็น 10% ของค่าห้องและค่าเพิ่มเติม บางโรงแรมอาจมีอัตราต่างกัน',
  },
  {
    question: 'ภาษี VAT คิดจากอะไร?',
    answer: 'ภาษี VAT 7% คิดจากยอดรวมของค่าห้องและค่าบริการโรงแรม (ไม่รวมค่าเพิ่มเติมอื่นๆ ที่ชำระแยก)',
  },
  {
    question: 'มีค่าคืนห้องก่อนเวลาหรือไม่?',
    answer: 'บางโรงแรมมีค่าปรับคืนห้องก่อนเวลาที่ระบุในนโยบาย โดยปกติประมาณ 50% ของค่าห้องหนึ่งคืน',
  },
  {
    question: 'ค่าเตียงเสริมคิดเป็นเท่าไร?',
    answer: 'ค่าเตียงเสริมโดยปกติคิดเป็น 30% ของค่าห้องต่อคืน แต่อาจแตกต่างตามโรงแรมแต่ละแห่ง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าห้องแรม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าห้องแรม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าห้องแรม
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2">
      <p class="text-xs font-semibold text-blue-800">[ปี 2569 — อัปเดต]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าห้องแรม ค่าบริการโรงแรม ภาษี VAT และค่าบริการเพิ่มเติม ฟรีออนไลน์
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="roomRate" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าห้องต่อคืน (บาท)
          </label>
          <input
            type="text"
            id="roomRate"
            inputmode="decimal"
            placeholder="เช่น 2500"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="nights" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนคืน
          </label>
          <input
            type="number"
            id="nights"
            min="1"
            max="30"
            value="1"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="rooms" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนห้อง
          </label>
          <input
            type="number"
            id="rooms"
            min="1"
            max="10"
            value="1"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="extraBeds" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนเตียงเสริม
          </label>
          <input
            type="number"
            id="extraBeds"
            min="0"
            max="5"
            value="0"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <div class="mb-6">
        <label class="flex items-center">
          <input
            type="checkbox"
            id="earlyCheckout"
            class="w-4 h-4 border-gray-300 rounded focus:ring-2 focus:ring-primary-500"
          />
          <span class="ml-2 text-sm text-gray-700">มีค่าปรับคืนห้องก่อนเวลา</span>
        </label>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณค่าห้อง
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6">
        <div class="mb-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
          <h3 class="font-semibold text-gray-900 mb-4">สรุปค่าห้อง</h3>

          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าห้องพื้นฐาน</span>
              <span id="fee-room" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าเตียงเสริม (ถ้ามี)</span>
              <span id="fee-bed" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">รวมก่อน Service Charge</span>
              <span id="subtotal" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าบริการโรงแรม 10%</span>
              <span id="fee-service" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ภาษี VAT 7%</span>
              <span id="vat-amount" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าปรับคืนห้องก่อนเวลา (ถ้ามี)</span>
              <span id="fee-checkout" class="font-medium text-gray-900">-</span>
            </div>
          </div>

          <div class="border-t-2 border-blue-400 my-3"></div>

          <div class="flex justify-between">
            <span class="text-base font-bold text-gray-900">รวมค่าห้องทั้งหมด</span>
            <span id="total" class="text-2xl font-bold text-primary-600">-</span>
          </div>
        </div>

        <!-- Note -->
        <div class="bg-yellow-50 rounded-lg p-4 border border-yellow-200">
          <p class="text-sm text-gray-700">
            <strong>หมายเหตุ:</strong> ค่าห้องข้างต้นเป็นการประมาณตามอัตราทั่วไป อาจแตกต่างตามโรงแรมแต่ละแห่ง
            โปรดตรวจสอบรายละเอียดค่าห้องกับโรงแรมเพื่อยืนยันราคาที่แน่นอน
          </p>
        </div>
      </div>
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ค่าห้องแรมประกอบด้วยอะไรบ้าง?</h2>
      <p>ค่าห้องแรม (Total Hotel Bill) ไม่ได้เป็นแค่ค่าห้องพื้นฐาน แต่ประกอบด้วยค่าต่างๆ เพิ่มเติม</p>

      <h3>1. ค่าห้องพื้นฐาน (Room Rate)</h3>
      <p>เป็นราคาห้องที่โรงแรมกำหนดต่อคืน ซึ่งแตกต่างกันตามประเภทห้อง (Standard, Deluxe, Suite) และช่วงเวลาการจอง</p>

      <h3>2. ค่าเตียงเสริม (Extra Bed)</h3>
      <p>หากมีผู้เข้าพักเพิ่มเติม โรงแรมอาจเรียกเก็บค่าเตียงเสริม ซึ่งโดยปกติคิดเป็น 30% ของค่าห้อง</p>

      <h3>3. ค่าบริการโรงแรม (Service Charge)</h3>
      <p>เป็นค่าบริการภาษหนึ่งซึ่งโรงแรมทั่วไปในไทยเรียกเก็บ 10% ของค่าห้องและค่าเพิ่มเติม</p>

      <h3>4. ภาษี VAT 7%</h3>
      <p>ภาษีมูลค่าเพิ่มที่รัฐบาลเรียกเก็บ ซึ่งคิดจากยอดรวมของค่าห้องและค่าบริการ</p>

      <h3>5. ค่าคืนห้องก่อนเวลา (Early Checkout Fee)</h3>
      <p>บางโรงแรมมีนโยบายคิดค่าปรับเมื่อผู้เข้าพักคืนห้องก่อนเวลาที่กำหนด โดยปกติประมาณ 50% ของค่าห้องหนึ่งคืน</p>
    </section>

    <!-- FAQ Section -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((item) => (
          <div class="border border-gray-200 rounded-lg p-4 hover:border-gray-300 transition-colors">
            <h3 class="font-semibold text-gray-900 mb-2">{item.question}</h3>
            <p class="text-gray-600 text-sm">{item.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Trust Panel -->
    <section class="bg-gray-50 rounded-lg p-4 sm:p-6 mb-8 border border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📌 แหล่งข้อมูลอ้างอิง</h2>
      <ul class="text-sm text-gray-700 space-y-2">
        <li>• สมาคมโรงแรมไทย (Thai Hotels Association)</li>
        <li>• ระทะการท่องเที่ยวแห่งประเทศไทย (TAT)</li>
        <li>• กรมสรรพากร — อัตราภาษี VAT และ Service Charge</li>
        <li>• ประกาศกรมสรรพสามิต — ค่าอากรประกอบการห้องพัก</li>
      </ul>
    </section>
  </article>
</BaseLayout>

<script>
  import { calculateHotelCost } from '../../lib/hotel-cost-calculator';

  const btnCalculate = document.getElementById('btn-calculate');
  const roomRateInput = document.getElementById('roomRate');
  const nightsInput = document.getElementById('nights');
  const roomsInput = document.getElementById('rooms');
  const extraBedsInput = document.getElementById('extraBeds');
  const earlyCheckoutCheckbox = document.getElementById('earlyCheckout');
  const resultDiv = document.getElementById('result');

  function formatCurrency(value: number): string {
    return new Intl.NumberFormat('th-TH', {
      style: 'currency',
      currency: 'THB',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(value);
  }

  function handleCalculate() {
    const roomRateStr = roomRateInput.value.replace(/,/g, '');
    const roomRate = parseFloat(roomRateStr);
    const nights = parseInt(nightsInput.value);
    const rooms = parseInt(roomsInput.value);
    const extraBeds = parseInt(extraBedsInput.value);

    if (!roomRate || roomRate <= 0 || isNaN(roomRate)) {
      alert('โปรดระบุค่าห้องที่ถูกต้อง');
      return;
    }

    if (!nights || nights < 1) {
      alert('โปรดระบุจำนวนคืนที่ถูกต้อง');
      return;
    }

    const result = calculateHotelCost({
      roomRate: roomRate,
      numberOfNights: nights,
      numberOfRooms: rooms,
      extraBeds: extraBeds,
      earlyCheckout: earlyCheckoutCheckbox.checked,
    });

    // Update UI
    document.getElementById('fee-room').textContent = formatCurrency(result.roomCost);
    document.getElementById('fee-bed').textContent = formatCurrency(result.extraBedFee);
    document.getElementById('subtotal').textContent = formatCurrency(result.subtotal);
    document.getElementById('fee-service').textContent = formatCurrency(result.serviceCharge);
    document.getElementById('vat-amount').textContent = formatCurrency(result.vat);
    document.getElementById('fee-checkout').textContent = formatCurrency(result.earlyCheckoutFee);
    document.getElementById('total').textContent = formatCurrency(result.total);

    resultDiv.classList.remove('hidden');
  }

  btnCalculate.addEventListener('click', handleCalculate);

  // Allow Enter key to calculate
  roomRateInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleCalculate();
  });
</script>
