---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเปรียบเทียบร้านแลกเงิน ปี 2569 — Exchange Kiosk Compare | Kamnuanlek';
const pageDescription = 'เปรียบเทียบร้านแลกเงินหลายร้านพร้อมกัน ป้อนยอดบาทและอัตราของแต่ละร้าน ทราบทันทีว่าร้านไหนให้เงินต่างประเทศมากที่สุด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเปรียบเทียบร้านแลกเงิน/`;

const faqData = [
  {
    question: 'ร้านแลกเงินไหนดีที่สุดในไทย?',
    answer: 'ร้านแลกเงินที่มักให้อัตราดี ได้แก่ SuperRich (สีส้มและสีเขียว), Vasu Exchange, และ Kasikorn Bank เพื่อสกุลยุโรป อัตราเปลี่ยนแปลงทุกวัน ควรเช็คแต่ละวัน',
  },
  {
    question: 'ส่วนต่างอัตราแลกเปลี่ยนมีผลมากไหม?',
    answer: 'มีผลมาก สำหรับยอด 50,000 บาท ส่วนต่าง 0.50 บาท/USD หมายถึงประมาณ 700 บาท หรือ ~1.4% ของยอดแลก ยิ่งยอดมากยิ่งควรเปรียบเทียบ',
  },
  {
    question: 'ร้านแลกเงินมีค่าธรรมเนียมไหม?',
    answer: 'ร้านแลกเงินส่วนใหญ่ไม่มีค่าธรรมเนียมแยกต่างหาก แต่รายได้มาจาก Spread ระหว่างอัตราซื้อและขาย ควรเปรียบเทียบอัตราที่แท้จริงที่จะได้รับ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเปรียบเทียบร้านแลกเงิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเปรียบเทียบร้านแลกเงิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-amber-100 bg-amber-50 p-4">
      <p class="text-sm font-semibold text-amber-700">เปรียบเทียบร้านแลกเงิน — ร้านไหนให้มากที่สุด</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: เงินต่างประเทศ = ยอดบาท ÷ อัตราแลก | ยิ่งอัตราต่ำ ยิ่งได้เงินต่างประเทศมาก</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      เปรียบเทียบร้านแลกเงิน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนยอดบาทที่ต้องการแลก และอัตราของแต่ละร้าน เพื่อดูว่าร้านไหนให้เงินต่างประเทศมากที่สุด
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <div>
        <label for="ek-amount" class="mb-1 block text-sm font-medium text-gray-700">ยอดบาทที่ต้องการแลก</label>
        <input type="text" id="ek-amount" inputmode="numeric" placeholder="เช่น 50,000"
          class="mb-4 w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        <p id="ek-amount-error" class="mb-2 hidden text-sm text-red-600"></p>
      </div>

      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-800">ร้านแลกเงิน</h2>
        <button type="button" id="ek-add" class="rounded-md bg-amber-100 px-3 py-1 text-sm font-medium text-amber-700 hover:bg-amber-200">
          + เพิ่มร้าน
        </button>
      </div>

      <div id="ek-shops" class="space-y-3 mb-4">
        <!-- rows injected by JS -->
      </div>

      <button type="button" id="ek-calc" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 sm:w-auto">
        เปรียบเทียบ
      </button>
    </div>

    <div id="ek-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการเปรียบเทียบ</h2>
        <div id="ek-result-list" class="space-y-3"></div>
        <p id="ek-verdict" class="mt-4 rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>เงินต่างประเทศ = ยอดบาท ÷ อัตราแลก</li>
        <li>ร้านที่ดีที่สุด = ร้านที่มีอัตราต่ำที่สุด (ได้เงินต่างประเทศมากที่สุด)</li>
        <li>ประหยัด = เงินต่างประเทศที่ดีที่สุด − เงินจากร้านที่เลือก</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณงบแลกเงินเดินทาง/">คำนวณงบแลกเงินเดินทาง</a></li>
        <li><a href="/คำนวณ-wire-transfer/">เปรียบเทียบ Wire Transfer</a></li>
        <li><a href="/คำนวณต้นทุนชำระเงินข้ามประเทศ/">คำนวณต้นทุนชำระเงินข้ามประเทศ</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#ek-results" />
    <RelatedArticles currentHref="/คำนวณเปรียบเทียบร้านแลกเงิน/" />
    <RelatedCalculators currentHref="/คำนวณเปรียบเทียบร้านแลกเงิน/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> อัตราแลกเปลี่ยนเปลี่ยนแปลงทุกวัน ควรตรวจสอบอัตราจริงก่อนเดินทางไปแลก
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n, d = 2) {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: d, maximumFractionDigits: d }).format(n);
    }

    const shopsDiv = document.getElementById('ek-shops');
    let shopCount = 0;

    function addShop(name = '', rate = '') {
      shopCount++;
      const id = shopCount;
      const row = document.createElement('div');
      row.id = `ek-row-${id}`;
      row.className = 'flex gap-2 items-start';
      row.innerHTML = `
        <div class="flex-1">
          <input type="text" placeholder="ชื่อร้าน" value="${name}"
            class="ek-name w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none" />
        </div>
        <div class="flex-1">
          <input type="text" inputmode="decimal" placeholder="อัตราแลก (บาท/1 หน่วย)" value="${rate}"
            class="ek-rate w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none" />
        </div>
        <button type="button" onclick="document.getElementById('ek-row-${id}').remove()" class="mt-1 text-red-400 hover:text-red-600 text-xl leading-none">×</button>
      `;
      shopsDiv.appendChild(row);
    }

    addShop('SuperRich', '');
    addShop('Vasu Exchange', '');
    addShop('ธนาคาร', '');

    document.getElementById('ek-add')?.addEventListener('click', () => addShop());

    document.getElementById('ek-calc')?.addEventListener('click', () => {
      const amount = parseNum(document.getElementById('ek-amount').value);
      const errEl = document.getElementById('ek-amount-error');

      if (!Number.isFinite(amount) || amount <= 0) {
        errEl.textContent = 'กรอกยอดบาทมากกว่า 0';
        errEl.classList.remove('hidden');
        return;
      }
      errEl.classList.add('hidden');

      const rows = shopsDiv.querySelectorAll('[id^="ek-row-"]');
      const shops = [];
      rows.forEach(row => {
        const name = row.querySelector('.ek-name').value.trim() || `ร้านที่ ${shops.length + 1}`;
        const rate = parseNum(row.querySelector('.ek-rate').value);
        if (Number.isFinite(rate) && rate > 0) shops.push({ name, rate, foreign: amount / rate });
      });

      if (shops.length < 2) { alert('กรุณาป้อนข้อมูลร้านอย่างน้อย 2 ร้าน'); return; }

      shops.sort((a, b) => b.foreign - a.foreign);
      const best = shops[0];

      const resultList = document.getElementById('ek-result-list');
      resultList.innerHTML = '';

      shops.forEach((shop, i) => {
        const diff = shop.foreign - best.foreign;
        const isFirst = i === 0;
        const div = document.createElement('div');
        div.className = `flex items-center justify-between rounded-lg p-3 ${isFirst ? 'bg-green-50 border-2 border-green-300' : 'bg-gray-50'}`;
        div.innerHTML = `
          <div>
            <span class="font-medium ${isFirst ? 'text-green-800' : 'text-gray-700'}">${isFirst ? '🥇 ' : ''}${shop.name}</span>
            <span class="ml-2 text-xs text-gray-500">อัตรา ${fmt(shop.rate, 4)}</span>
          </div>
          <div class="text-right">
            <div class="font-bold ${isFirst ? 'text-green-700' : 'text-gray-600'}">${fmt(shop.foreign, 2)} หน่วย</div>
            ${diff < 0 ? `<div class="text-xs text-red-500">น้อยกว่า ${fmt(Math.abs(diff), 2)} หน่วย</div>` : ''}
          </div>
        `;
        resultList.appendChild(div);
      });

      const verdict = document.getElementById('ek-verdict');
      verdict.className = 'mt-4 rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800 border border-green-200';
      verdict.textContent = `✅ ${best.name} ให้อัตราดีที่สุด ได้ ${fmt(best.foreign, 2)} หน่วย จาก ${fmt(amount, 0)} บาท`;

      document.getElementById('ek-results').classList.remove('hidden');
      document.getElementById('ek-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
