---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าลาครอบครัว | Kamnuanlek';
const pageDescription = 'คำนวณค่าเสียหายจากการลาครอบครัว การป่วย การลาดูแลเด็ก';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0602-ค่าลาครอบครัว/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าลาครอบครัว">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าลาครอบครัว</h1>
    <div class="mb-4 inline-block rounded-lg border border-pink-200 bg-pink-50 px-3 py-2"><p class="text-xs font-semibold text-pink-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณเงินเดือนเสียหายจากการลาครอบครัว คลอด ดูแลเด็ก สูตร SSO/OSCC</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="daily_wage" class="block text-sm font-medium text-gray-700 mb-1">เงินเดือนประจำปี (บาท)</label><input type="text" id="daily_wage" inputmode="decimal" placeholder="เช่น 180000" value="180000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="days_off" class="block text-sm font-medium text-gray-700 mb-1">จำนวนวันลา (วัน)</label><input type="number" id="days_off" min="1" max="30" placeholder="เช่น 7" value="7" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทการลา</label><select id="type" class="w-full px-3 py-2 border border-gray-300 rounded-md"><option value="maternity">คลอด (4 สัปดาห์)</option><option value="childcare">ดูแลเด็ก (สูงสุด 1 ปี)</option><option value="illness">ป่วย (ตามประกาศ)</option><option value="other">อื่นๆ (หักเดือน)</option></select></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-pink-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-pink-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าลาต่อวัน</p>
            <p id="per_day" class="font-bold">-</p>
          </div>
          <div class="bg-pink-50 rounded p-3">
            <p class="text-sm text-gray-600">จำนวนวันลา</p>
            <p id="days_text" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">เงินเสียหาย (หักโดยพลเมือง)</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">การลาครอบครัว มีกี่วันตามกฎหมายไทย?</h3>
            <p class="text-gray-600 text-sm">ตามพระราชกฤษณมูลนิติ จำหน่ายด่วน ของคนงาน พ.ศ. 2541: การลาคลอด 4 สัปดาห์ การลาดูแลเด็กป่วย ได้สูงสุด 1 ปี</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">เด็กเสียชีวิตแล้ว ยังได้ลาคลอดอีกหรือไม่?</h3>
            <p class="text-gray-600 text-sm">ตามกฎหมาย ไม่ได้รับสิทธิการลาคลอด หากเด็กเสียชีวิตก่อนหรือระหว่างการคลอด แต่อาจได้สิทธิลาป่วยแทน</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ถ้าลาข้าม 2 กำหนดปีงบประมาณ ต้องหักเงินทั้งหมดเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">หากเกินกำหนด จ่ายจากเงินเดือนปีใหม่ หรืออาจได้รับการหักหลาย ๆ เดือน ทั้งนี้ขึ้นอยู่กับนโยบายของบริษัท</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const annualWage = parseFloat((document.getElementById('daily_wage') as HTMLInputElement).value) || 0;
      const daysOff = parseInt((document.getElementById('days_off') as HTMLInputElement).value) || 0;
      const type = (document.getElementById('type') as HTMLSelectElement).value;

      const dailyWage = annualWage / 365;
      const totalLoss = dailyWage * daysOff;

      (document.getElementById('per_day') as HTMLElement).textContent = dailyWage.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('days_text') as HTMLElement).textContent = daysOff + ' วัน';
      (document.getElementById('total') as HTMLElement).textContent = totalLoss.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('maternity-leave');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
