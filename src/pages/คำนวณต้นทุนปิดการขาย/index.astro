---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';

const pageTitle = 'คำนวณต้นทุนปิดการขาย ปี 2569 | ค่าธรรมเนียม ภาษี | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณต้นทุนรวมทั้งหมดในวันปิดการขาย: ค่าธรรมเนียม ภาษี ค่าตรวจสอบ เครื่องคำนวณไทย ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนปิดการขาย/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนปิดการขาย">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณต้นทุนปิดการขาย ปี 2569</h1>
    <p class="text-gray-600 mb-6">รวมค่าใช้จ่ายทั้งหมดในวันปิดการขาย</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="closing-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="appraise-value" class="block text-sm font-medium text-gray-700 mb-1">ราคาประเมิน (บาท)</label>
            <input id="appraise-value" type="text" inputmode="numeric" placeholder="เช่น 5,800,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base" />
          </div>
          <div>
            <label for="mortgage-amt" class="block text-sm font-medium text-gray-700 mb-1">วงเงินจำนอง (บาท)</label>
            <input id="mortgage-amt" type="text" inputmode="numeric" placeholder="เช่น 4,500,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base" />
          </div>
        </div>

        <div>
          <label for="survey-cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าสำรวจ/ประกาศ/อื่นๆ (บาท)</label>
          <input id="survey-cost" type="text" inputmode="numeric" placeholder="เช่น 5,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base" value="5000" />
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณต้นทุน</h2>

        <div class="rounded-lg bg-primary-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">รวมต้นทุนทั้งหมด</div>
          <div id="res-total-cost" class="text-2xl font-bold text-primary-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าจดทะเบียนโอน (2%)</span>
            <span id="res-transfer" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าจดจำนอง (1%)</span>
            <span id="res-mortgage" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าสำรวจ/อื่นๆ</span>
            <span id="res-survey" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">รวมทั้งหมด</span>
            <span id="res-calc-total" class="font-bold text-primary-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <RelatedCalculators currentHref="/คำนวณต้นทุนปิดการขาย/" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#closing-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const appraiseValue = parseNumber(document.querySelector('#appraise-value')?.value || '');
    const mortgageAmt = parseNumber(document.querySelector('#mortgage-amt')?.value || '');
    const surveyCost = parseNumber(document.querySelector('#survey-cost')?.value || '');

    if (!(Number.isFinite(appraiseValue) && appraiseValue > 0 && Number.isFinite(mortgageAmt) && mortgageAmt > 0 && Number.isFinite(surveyCost) && surveyCost > 0)) {
      results?.classList.add('hidden');
      return;
    }

    const transferFee = appraiseValue * 0.02;
    const mortgageFee = Math.min(mortgageAmt * 0.01, 200000);
    const totalCost = transferFee + mortgageFee + surveyCost;

    document.querySelector('#res-total-cost').textContent = formatCurrency(totalCost);
    document.querySelector('#res-transfer').textContent = formatCurrency(transferFee);
    document.querySelector('#res-mortgage').textContent = formatCurrency(mortgageFee);
    document.querySelector('#res-survey').textContent = formatCurrency(surveyCost);
    document.querySelector('#res-calc-total').textContent = formatCurrency(totalCost);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
