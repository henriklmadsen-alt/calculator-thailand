---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณกองทุนมหาวิทยาลัยบุตร 2569 | วางแผนค่าเรียนมหาวิทยาลัย | Kamnuanlek';
const pageDescription = 'คำนวณเงินออมรายเดือนเพื่อกองทุนค่าเรียนมหาวิทยาลัยบุตร 4 ปี รวมค่าเล่าเรียน ค่าหอพัก ค่าใช้จ่าย และเงินเฟ้อค่าเล่าเรียนไทย อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณกองทุนมหาวิทยาลัยบุตร/`;

const faqData = [
  {
    question: 'ค่าใช้จ่ายมหาวิทยาลัยในไทย 4 ปีเฉลี่ยเท่าไร?',
    answer: 'มหาวิทยาลัยรัฐ: ค่าเล่าเรียน 30,000-80,000 บาท/ปี มหาวิทยาลัยเอกชน: 80,000-200,000 บาท/ปี รวมค่าหอพักและค่าใช้จ่ายครองชีพ ค่าใช้จ่ายรวมทั้งหมด 4 ปีอยู่ที่ประมาณ 600,000 - 1,500,000 บาท ขึ้นกับมหาวิทยาลัยและคณะที่เลือก',
  },
  {
    question: 'ค่าหอพักมหาวิทยาลัยไทยอยู่ที่เท่าไร?',
    answer: 'ค่าหอพักในหรือรอบมหาวิทยาลัยในไทยอยู่ที่ประมาณ 3,000-8,000 บาท/เดือน หรือ 36,000-96,000 บาท/ปี กรุงเทพฯ มักสูงกว่าต่างจังหวัด ค่าเฉลี่ยอยู่ที่ประมาณ 60,000 บาท/ปี',
  },
  {
    question: 'เงินเฟ้อค่าเล่าเรียนมหาวิทยาลัยอยู่ที่เท่าไร?',
    answer: 'ค่าเล่าเรียนมหาวิทยาลัยในไทยมีแนวโน้มเพิ่มขึ้น 4-7% ต่อปี ค่าเฉลี่ยอยู่ที่ประมาณ 5% ต่อปี การใช้ 5% เป็นค่ากลางในการวางแผนเป็นสิ่งที่เหมาะสม เพื่อรองรับการขึ้นราคาในอนาคต',
  },
  {
    question: 'ค่าใช้จ่ายแต่ละปีมหาวิทยาลัยต่างกันอย่างไร?',
    answer: 'ปี 1 มักสูงกว่าเพราะมีค่าลงทะเบียนแรกเข้า ค่าอุปกรณ์ และค่าชุดนักศึกษา ปี 2-3 ค่าใช้จ่ายค่อนข้างคงที่ ปี 4 อาจมีค่าทำวิทยานิพนธ์หรือโปรเจกต์เพิ่ม การวางแผนให้ครบทุกปีจึงสำคัญ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณกองทุนมหาวิทยาลัยบุตร',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณกองทุนมหาวิทยาลัยบุตร">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณกองทุนมหาวิทยาลัยบุตร 2569 — วางแผนค่าเรียนมหาวิทยาลัย 4 ปี
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณเงินออมรายเดือนเพื่อกองทุนค่าใช้จ่ายมหาวิทยาลัยบุตร 4 ปี ครอบคลุมค่าเล่าเรียน ค่าหอพัก และค่าใช้จ่ายอื่น รวมเงินเฟ้อค่าเล่าเรียนและผลตอบแทนการลงทุน
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="uni-fund-form" class="space-y-5">
        <p id="uni-fund-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="uni-tuition" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าเล่าเรียนต่อปี (บาท)
            </label>
            <input
              type="text"
              id="uni-tuition"
              inputmode="numeric"
              placeholder="เช่น 100,000"
              value="100000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="uni-accommodation" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าหอพักต่อปี (บาท)
            </label>
            <input
              type="text"
              id="uni-accommodation"
              inputmode="numeric"
              placeholder="เช่น 60,000"
              value="60000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="uni-expenses" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าใช้จ่ายอื่นต่อปี (บาท)
            </label>
            <input
              type="text"
              id="uni-expenses"
              inputmode="numeric"
              placeholder="เช่น 60,000"
              value="60000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="uni-study-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาศึกษา (ปี)
            </label>
            <input
              type="number"
              id="uni-study-years"
              min="2"
              max="8"
              value="4"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="uni-child-age" class="block text-sm font-medium text-gray-700 mb-1">
              อายุบุตรปัจจุบัน (ปี)
            </label>
            <input
              type="number"
              id="uni-child-age"
              min="0"
              max="17"
              placeholder="เช่น 5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="uni-child-age-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="uni-entry-age" class="block text-sm font-medium text-gray-700 mb-1">
              อายุที่เข้ามหาวิทยาลัย (ปี)
            </label>
            <input
              type="number"
              id="uni-entry-age"
              min="15"
              max="25"
              value="18"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="uni-inflation" class="block text-sm font-medium text-gray-700 mb-1">
              เงินเฟ้อค่าเล่าเรียน (% ต่อปี)
            </label>
            <input
              type="text"
              id="uni-inflation"
              inputmode="decimal"
              placeholder="เช่น 5"
              value="5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="uni-return" class="block text-sm font-medium text-gray-700 mb-1">
              ผลตอบแทนการลงทุน (% ต่อปี)
            </label>
            <input
              type="text"
              id="uni-return"
              inputmode="decimal"
              placeholder="เช่น 7"
              value="7"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="uni-existing-savings" class="block text-sm font-medium text-gray-700 mb-1">
            เงินออมที่มีอยู่แล้ว (บาท)
          </label>
          <input
            type="text"
            id="uni-existing-savings"
            inputmode="numeric"
            placeholder="เช่น 100,000"
            value="0"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          id="uni-fund-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณกองทุนมหาวิทยาลัย</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าใช้จ่ายรวม 4 ปีในอนาคต</div>
            <div id="res-uni-total-future" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ออมรายเดือนที่ต้องการ</div>
            <div id="res-uni-monthly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ระยะเวลาออม</div>
            <div id="res-uni-save-years" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-yellow-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าใช้จ่ายวันนี้ (ปัจจุบัน)</div>
            <div id="res-uni-today-total" class="text-xl font-bold text-yellow-700">-</div>
          </div>
        </div>

        <!-- Year-by-year breakdown -->
        <h3 class="text-base font-semibold text-gray-900 mb-3">รายละเอียดค่าใช้จ่ายแต่ละปีในอนาคต</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm mb-4">
            <thead>
              <tr class="text-left text-gray-500 border-b border-gray-200">
                <th class="py-2 pr-4">ปีที่เรียน</th>
                <th class="py-2 pr-4 text-right">ค่าเล่าเรียน</th>
                <th class="py-2 pr-4 text-right">ค่าหอพัก</th>
                <th class="py-2 pr-4 text-right">ค่าใช้จ่ายอื่น</th>
                <th class="py-2 text-right">รวมต่อปี</th>
              </tr>
            </thead>
            <tbody id="uni-year-breakdown"></tbody>
            <tfoot>
              <tr class="font-semibold border-t border-gray-200">
                <td class="py-2 pr-4">รวมทั้งหมด</td>
                <td class="py-2 pr-4 text-right" id="res-uni-total-tuition">-</td>
                <td class="py-2 pr-4 text-right" id="res-uni-total-accomm">-</td>
                <td class="py-2 pr-4 text-right" id="res-uni-total-other">-</td>
                <td class="py-2 text-right" id="res-uni-grand-total">-</td>
              </tr>
            </tfoot>
          </table>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">มูลค่าเงินออมที่มีอยู่ ณ วันเข้าเรียน</span>
            <span id="res-uni-existing-fv" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีวางแผนกองทุนมหาวิทยาลัยบุตร</h2>
      <p>
        การวางแผนกองทุนมหาวิทยาลัยต้องพิจารณาค่าใช้จ่ายทั้ง 4 ปี (หรือมากกว่า) ซึ่งแต่ละปีจะปรับขึ้นตามเงินเฟ้อค่าเล่าเรียน เครื่องคำนวณนี้คำนวณ NPV ของค่าใช้จ่ายรวมทุกปีและหาเงินออมรายเดือนที่เหมาะสม
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ค่าใช้จ่ายที่ควรนับรวม</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ค่าเล่าเรียน (Tuition): ค่าหน่วยกิต ค่าลงทะเบียน</li>
        <li>ค่าที่พัก (Accommodation): หอพักหรือค่าเช่าห้อง</li>
        <li>ค่าครองชีพ: อาหาร ค่าเดินทาง อุปกรณ์การเรียน</li>
        <li>ค่าใช้จ่ายส่วนตัวและกิจกรรม</li>
      </ul>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีการคำนวณ</h3>
      <p>
        คำนวณมูลค่าในอนาคตของค่าใช้จ่ายแต่ละปีโดยปรับเงินเฟ้อ แล้วคำนวณ PV ของค่าใช้จ่ายทั้งหมด ณ วันที่บุตรเข้ามหาวิทยาลัย จากนั้นหา PMT รายเดือนที่จำเป็น
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณกองทุนมหาวิทยาลัยบุตร/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ค่าใช้จ่ายจริงขึ้นอยู่กับมหาวิทยาลัยและคณะที่เลือก ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('uni-fund-form') as HTMLFormElement;
    const formError = document.getElementById('uni-fund-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const tuition = parseNum((document.getElementById('uni-tuition') as HTMLInputElement).value);
      const accommodation = parseNum((document.getElementById('uni-accommodation') as HTMLInputElement).value);
      const otherExpenses = parseNum((document.getElementById('uni-expenses') as HTMLInputElement).value);
      const studyYears = parseInt((document.getElementById('uni-study-years') as HTMLInputElement).value) || 4;
      const childAge = parseInt((document.getElementById('uni-child-age') as HTMLInputElement).value);
      const entryAge = parseInt((document.getElementById('uni-entry-age') as HTMLInputElement).value) || 18;
      const eduInflation = parseNum((document.getElementById('uni-inflation') as HTMLInputElement).value) || 5;
      const investReturn = parseNum((document.getElementById('uni-return') as HTMLInputElement).value) || 7;
      const existingSavings = parseNum((document.getElementById('uni-existing-savings') as HTMLInputElement).value);

      if (isNaN(childAge) || childAge < 0) {
        formError.classList.remove('hidden');
        (document.getElementById('uni-child-age') as HTMLInputElement).focus();
        return;
      }

      trackCalculatorStart('uni-fund');

      const yearsToEntry = Math.max(0, entryAge - childAge);
      const monthlyRate = investReturn / 100 / 12;
      const annualInflation = eduInflation / 100;

      const todayAnnualCost = tuition + accommodation + otherExpenses;

      // Calculate each year's cost in future value
      interface YearData { year: number; tuition: number; accommodation: number; other: number; total: number; }
      const yearData: YearData[] = [];
      let totalFutureCost = 0;
      let totalTuition = 0;
      let totalAccomm = 0;
      let totalOther = 0;

      // We need NPV of all year costs at the time of entry
      // Year i of university: yearsFromNow = yearsToEntry + (i-1)
      // Cost in that year = todayCost * (1+inflation)^yearsFromNow
      // PV at entry = cost_at_year_i / (1+investReturn)^(i-1)
      // Then total PV at entry is sum of above
      // Then PMT to accumulate that PV at entry

      let pvAtEntry = 0;
      for (let i = 1; i <= studyYears; i++) {
        const yearsFromNow = yearsToEntry + (i - 1);
        const futureTuition = tuition * Math.pow(1 + annualInflation, yearsFromNow);
        const futureAccomm = accommodation * Math.pow(1 + annualInflation, yearsFromNow);
        const futureOther = otherExpenses * Math.pow(1 + annualInflation, yearsFromNow);
        const yearTotal = futureTuition + futureAccomm + futureOther;

        yearData.push({
          year: i,
          tuition: futureTuition,
          accommodation: futureAccomm,
          other: futureOther,
          total: yearTotal,
        });

        totalFutureCost += yearTotal;
        totalTuition += futureTuition;
        totalAccomm += futureAccomm;
        totalOther += futureOther;

        // PV of this year's cost at entry date
        const discountYears = i - 1;
        pvAtEntry += yearTotal / Math.pow(1 + investReturn / 100, discountYears);
      }

      // FV of existing savings at entry
      const monthsToEntry = yearsToEntry * 12;
      const existingFV = existingSavings * Math.pow(1 + monthlyRate, monthsToEntry);

      // Required savings to accumulate pvAtEntry
      const needed = Math.max(0, pvAtEntry - existingFV);

      let monthlyNeeded: number;
      if (monthsToEntry <= 0) {
        monthlyNeeded = 0;
      } else if (Math.abs(monthlyRate) < 0.0000001) {
        monthlyNeeded = needed / monthsToEntry;
      } else {
        monthlyNeeded = needed * monthlyRate / (Math.pow(1 + monthlyRate, monthsToEntry) - 1);
      }

      (document.getElementById('res-uni-total-future') as HTMLElement).textContent = fmt(totalFutureCost) + ' บาท';
      (document.getElementById('res-uni-monthly') as HTMLElement).textContent = fmt(monthlyNeeded) + ' บาท';
      (document.getElementById('res-uni-save-years') as HTMLElement).textContent = yearsToEntry + ' ปี';
      (document.getElementById('res-uni-today-total') as HTMLElement).textContent = fmt(todayAnnualCost * studyYears) + ' บาท';
      (document.getElementById('res-uni-existing-fv') as HTMLElement).textContent = fmt(existingFV) + ' บาท';
      (document.getElementById('res-uni-total-tuition') as HTMLElement).textContent = fmt(totalTuition);
      (document.getElementById('res-uni-total-accomm') as HTMLElement).textContent = fmt(totalAccomm);
      (document.getElementById('res-uni-total-other') as HTMLElement).textContent = fmt(totalOther);
      (document.getElementById('res-uni-grand-total') as HTMLElement).textContent = fmt(totalFutureCost);

      const tbody = document.getElementById('uni-year-breakdown') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      yearData.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';
        tr.innerHTML = `
          <td class="py-2 pr-4 text-gray-600">ปีที่ ${row.year}</td>
          <td class="py-2 pr-4 text-right">${fmt(row.tuition)}</td>
          <td class="py-2 pr-4 text-right">${fmt(row.accommodation)}</td>
          <td class="py-2 pr-4 text-right">${fmt(row.other)}</td>
          <td class="py-2 text-right font-medium">${fmt(row.total)}</td>
        `;
        tbody.appendChild(tr);
      });

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('uni-fund');
      trackCalculatorUsed('uni-fund');
    });
  </script>
</BaseLayout>
