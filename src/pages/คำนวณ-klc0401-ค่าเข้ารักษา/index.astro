---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าเข้ารักษา | Kamnuanlek';
const pageDescription = 'คำนวณค่าเข้ารักษาโรงพยาบาล รวมค่าที่พัก ยา การรักษา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0401-ค่าเข้ารักษา/`;

const faqData = [
  { question: 'ค่ารักษาพยาบาลในไทยแตกต่างกันอย่างไรระหว่างโรงพยาบาลรัฐและเอกชน?', answer: 'โรงพยาบาลรัฐมีค่าใช้จ่ายต่ำกว่ามาก แต่ใช้เวลารอนาน โรงพยาบาลเอกชนสะดวกกว่าแต่ราคาสูงกว่า 3-10 เท่า ขึ้นอยู่กับประเภทการรักษา' },
  { question: 'สิทธิ์ประกันสังคมครอบคลุมค่ารักษาอะไรบ้าง?', answer: 'ผู้ประกันตนมาตรา 33 ได้รับการรักษาฟรีที่โรงพยาบาลตามบัตรรับรองสิทธิ์ ครอบคลุมการรักษาทั่วไป ผ่าตัด คลอดบุตร และยาตามบัญชียา' },
  { question: 'ควรทำประกันสุขภาพหรือสำรองเงินเอง?', answer: 'ประกันสุขภาพช่วยลดความเสี่ยงจากค่าใช้จ่ายสูงที่คาดไม่ถึง เหมาะกับคนที่ไม่มีเงินสำรองมาก ส่วนคนที่มีเงินออมสูงอาจสำรองเองได้' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกค่าห้อง ค่ายา ค่าหัตถการ และค่าตรวจวินิจฉัย กดคำนวณเพื่อดูค่าใช้จ่ายรวมทั้งหมด' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเข้ารักษา">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเข้ารักษา</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าเข้ารักษาโรงพยาบาล รวมค่าที่พัก ยา เวชกรรม ตามอัตรา รพ.</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="room_rate" class="block text-sm font-medium text-gray-700 mb-1">ค่าห้องต่อวัน (บาท)</label><input type="text" id="room_rate" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="days" class="block text-sm font-medium text-gray-700 mb-1">จำนวนวันนอน (วัน)</label><input type="number" id="days" min="1" max="365" placeholder="เช่น 5" value="5" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="medicine_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่ายาเภสัชกรรม (บาท)</label><input type="text" id="medicine_cost" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="treatment" class="block text-sm font-medium text-gray-700 mb-1">ค่าการรักษา/ผ่าตัด (บาท)</label><input type="text" id="treatment" inputmode="decimal" placeholder="เช่น 5000" value="5000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="tests" class="block text-sm font-medium text-gray-700 mb-1">ค่าตรวจวินิจฉัย/เลือด/CT (บาท)</label><input type="text" id="tests" inputmode="decimal" placeholder="เช่น 3000" value="3000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าห้องรวม</p>
            <p id="room_total" class="font-bold">-</p>
          </div>
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่ายา + การรักษา</p>
            <p id="treatment_total" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">รวมค่าเข้ารักษา</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">โรงพยาบาลรัฐวรรค่าเข้ารักษาเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">ค่าห้องโรงพยาบาลรัฐ: ป้ายแดง 1,000 บาท ป้ายเขียว 500 บาท ป้ายน้ำเงิน 100 บาท ขึ้นอยู่กับระดับบริการ</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่าผ่าตัดขึ้นกับอะไร?</h3>
            <p class="text-gray-600 text-sm">ผ่าตัดถูงขึ้นกับ: ประเภทผ่าตัด (จิ๋วเพื่อ) ระดับความยากง่าย หมอผ่าตัด โรงพยาบาล ประมาณ 10,000-200,000 บาท</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ประกันสุขภาพคลุมค่าทั้งหมดหรือไม่?</h3>
            <p class="text-gray-600 text-sm">ขึ้นอยู่กับประกาศ: อาจครอบ 50-100% ค่ารักษา ต้องเลือกแพลนให้เหมาะสม แนะนำการตรวจเช็ก co-pay</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const roomRate = parseFloat((document.getElementById('room_rate') as HTMLInputElement).value) || 0;
      const days = parseInt((document.getElementById('days') as HTMLInputElement).value) || 1;
      const medicineCost = parseFloat((document.getElementById('medicine_cost') as HTMLInputElement).value) || 0;
      const treatment = parseFloat((document.getElementById('treatment') as HTMLInputElement).value) || 0;
      const tests = parseFloat((document.getElementById('tests') as HTMLInputElement).value) || 0;

      const roomTotal = roomRate * days;
      const treatmentTotal = medicineCost + treatment + tests;
      const total = roomTotal + treatmentTotal;

      (document.getElementById('room_total') as HTMLElement).textContent = roomTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('treatment_total') as HTMLElement).textContent = treatmentTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('hospital-admission');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
