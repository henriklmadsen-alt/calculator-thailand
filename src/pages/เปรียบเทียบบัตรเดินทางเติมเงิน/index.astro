---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'เปรียบเทียบบัตรเดินทางเติมเงิน 2569 | บัตรท่องเที่ยวประหยัด FX | Kamnuanlek';
const pageDescription = 'เปรียบเทียบบัตรเดินทางเติมเงิน (Prepaid Travel Card) กับบัตรเดบิต/เครดิตปกติ เพื่อประหยัดค่า FX';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/เปรียบเทียบบัตรเดินทางเติมเงิน/`;

const faqData = [
  {
    question: 'บัตรเดินทางเติมเงิน (Prepaid Travel Card) คืออะไร?',
    answer: 'บัตรเดินทางเติมเงินคือบัตรที่เติมเงินล่วงหน้าในสกุลเงินต่างประเทศที่ต้องการใช้ ล็อคอัตราแลกเปลี่ยนไว้ก่อนเดินทาง โดยมี FX fee ต่ำกว่าบัตรเดบิตปกติ เหมาะสำหรับนักท่องเที่ยวที่เดินทางบ่อยหรืออยู่ต่างประเทศนาน',
  },
  {
    question: 'ข้อดีของบัตรเดินทางเติมเงินเมื่อเทียบกับบัตรเดบิตปกติ?',
    answer: 'บัตรเดินทางเติมเงินมีข้อดีคือ FX fee ต่ำกว่า (0-1% เทียบกับ 2.5-3.5%) ล็อคอัตราได้ บางใบไม่มีค่าธรรมเนียมถอน ATM ต่างประเทศ และปลอดภัยกว่าเพราะหายก็ไม่กระทบบัญชีหลัก',
  },
  {
    question: 'ประเทศใดที่ควรใช้บัตรเดินทางเติมเงินมากที่สุด?',
    answer: 'ญี่ปุ่นและยุโรปมักคุ้มค่าที่สุดเพราะค่าใช้จ่ายสูงและ FX spread ของเงินสดกว้าง ส่วนสิงคโปร์และออสเตรเลียก็ได้ประโยชน์มากจากบัตรเดินทาง อย่างไรก็ตาม ควรเปรียบเทียบอัตราจริงก่อนเดินทาง',
  },
];

const destinations = [
  { name: 'ญี่ปุ่น', cashSpread: 3.0 },
  { name: 'ยุโรป', cashSpread: 2.5 },
  { name: 'สหรัฐอเมริกา', cashSpread: 2.0 },
  { name: 'ออสเตรเลีย', cashSpread: 2.5 },
  { name: 'สิงคโปร์', cashSpread: 2.0 },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องเปรียบเทียบบัตรเดินทางเติมเงิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="เปรียบเทียบบัตรเดินทางเติมเงิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">เปรียบเทียบบัตรเดินทางเติมเงิน 2569</h1>
    <p class="mb-6 text-gray-600">เปรียบเทียบต้นทุน FX ระหว่างบัตรเดบิตปกติ บัตรเดินทางเติมเงิน และเงินสด</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc-form" class="space-y-4">
        <div>
          <label for="budget" class="mb-1 block text-sm font-medium text-gray-700">งบท่องเที่ยวทั้งหมด (บาท)</label>
          <input id="budget" type="text" inputmode="numeric" placeholder="เช่น 50000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="destination" class="mb-1 block text-sm font-medium text-gray-700">ประเทศปลายทาง</label>
          <select id="destination"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64">
            {destinations.map((d) => (
              <option value={d.cashSpread}>{d.name}</option>
            ))}
          </select>
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          เปรียบเทียบ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการเปรียบเทียบ</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm font-medium text-gray-700">บัตรเดบิตปกติ</div>
            <div class="mb-1 text-xs text-gray-500">FX fee 1.5% + CB 1%</div>
            <div id="res-debit" class="text-2xl font-bold text-red-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm font-medium text-gray-700">บัตรเดินทางเติมเงิน</div>
            <div class="mb-1 text-xs text-gray-500">FX fee 0.5%</div>
            <div id="res-travel" class="text-2xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-sm font-medium text-gray-700">เงินสด (แลกที่ไทย)</div>
            <div class="mb-1 text-xs text-gray-500" id="cash-spread-label">spread ตามประเทศ</div>
            <div id="res-cash" class="text-2xl font-bold text-orange-700">-</div>
          </div>
        </div>
        <div class="mt-4 rounded-lg bg-green-50 p-3">
          <p class="text-sm font-medium text-green-800">ประหยัดได้ด้วยบัตรเดินทางเทียบบัตรเดบิต: <span id="res-save" class="font-bold">-</span></p>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/เปรียบเทียบบัตรเดินทางเติมเงิน/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n > 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('calc-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const budget = parseNum((document.getElementById('budget') as HTMLInputElement).value);
    const cashSpread = parseNum((document.getElementById('destination') as HTMLSelectElement).value);
    if (!budget) return;

    const debitCost = budget * (0.015 + 0.01);
    const travelCost = budget * 0.005;
    const cashCost = budget * (cashSpread / 100);

    document.getElementById('res-debit')!.textContent = fmt(debitCost);
    document.getElementById('res-travel')!.textContent = fmt(travelCost);
    document.getElementById('res-cash')!.textContent = fmt(cashCost);
    document.getElementById('cash-spread-label')!.textContent = `spread ${cashSpread}%`;
    document.getElementById('res-save')!.textContent = fmt(debitCost - travelCost);
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
