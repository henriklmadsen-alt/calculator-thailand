---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'เปรียบเทียบเช่าที่ดิน vs ซื้อที่ดิน 2569 | คำนวณต้นทุน 20 ปี | Kamnuanlek';
const pageDescription = 'เปรียบเทียบค่าใช้จ่ายระยะยาว (20 ปี) ระหว่างเช่าที่ดินกับซื้อที่ดินตามอัตราจริง โลหิตงาน ดอกเบี้ยจำนอง ภาษีที่ดิน ค่าดูแลรักษา ออนไลน์ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเปรียบเทียบเช่าที่ดิน-vs-ซื้อที่ดิน/`;

const faqData = [
  {
    question: 'เช่าที่ดินกับซื้อที่ดิน อันไหนมีต้นทุนน้อยกว่า?',
    answer: 'ขึ้นอยู่กับระยะเวลาที่ต้องการ ประเมิณราคา และการปรับค่าเช่า เมื่อระยะเวลานาน (10+ ปี) การซื้อมักจะประหยัดกว่า เพราะค่าเช่าปรับขึ้นทุกปี และทรัพย์สินมีมูลค่าสูงขึ้น',
  },
  {
    question: 'ค่าใช้จ่ายที่ต้องพิจารณากับการซื้อมีอะไรบ้าง?',
    answer: 'ค่าธรรมเนียมโอน 2% + ดอกเบี้ยจำนอง + ภาษีที่ดินประจำปี + ค่าดูแลรักษา (ประมาณ 1-2% ต่อปี) + ค่าจดทะเบียน ส่วนเช่า คือ เงินมัดจำ + ค่าเช่ารายเดือน (ปรับขึ้นทุกปี)',
  },
  {
    question: 'ดอกเบี้ยจำนองในการคำนวณเท่าไหร่?',
    answer: 'ปกติแบงก์ในไทยให้ดอกเบี้ยประมาณ 2.5-4.5% ต่อปี ขึ้นอยู่กับอัตราเฉลี่ยและเงื่อนไขผู้กู้ คำนวณนี้ใช้อัตรา 3.5% เป็นค่าเฉลี่ย',
  },
  {
    question: 'ค่าเสื่อมราคาที่ดินคืออะไร?',
    answer: 'การซื้อที่ดิน คาดว่าราคาอาจปรับขึ้นหรือลงในอนาคต การคำนวณนี้ให้ผู้ใช้ป้อนอัตราการเปลี่ยนแปลงราคาต่อปี (เป็นเปอร์เซนต์) เพื่อประมาณราคาลงทุนในอนาคต',
  },
  {
    question: 'มูลค่าคงเหลือที่ท้ายสุด (residual value) คือ?',
    answer: 'มูลค่าของที่ดินที่เหลือในปลายสุดของระยะเวลาคำนวณ (20 ปี) หลังจากจ่ายดอกเบี้ยจำนองและค่าใช้จ่ายอื่น คำนวณจากราคาเริ่มต้น + อัตราการปรับขึ้นราคาต่อปี',
  },
,
  { question: 'ค่าโอนบ้านปี 2569 คิดอัตราเท่าไร?', answer: 'ค่าธรรมเนียมโอน 2% ของราคาประเมิน (ลดเหลือ 1% สำหรับที่อยู่อาศัยราคาไม่เกิน 3 ล้าน จนถึง 31 ธ.ค. 2568), ค่าจดจำนอง 1% ของวงเงิน (ลดเหลือ 0.01% สำหรับกู้ไม่เกิน 3 ล้าน)' },
  { question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ต่างกันอย่างไร?', answer: 'ภาษีธุรกิจเฉพาะ 3.3% (ถือครองน้อยกว่า 5 ปีหรือไม่ได้มีชื่อในทะเบียนบ้าน) | อากรแสตมป์ 0.5% (ถือครอง 5 ปีขึ้นไปและมีชื่อในทะเบียนบ้านครบ 1 ปี) เสียอย่างใดอย่างหนึ่ง' },
  { question: 'ราคาประเมินกรมที่ดินกับราคาตลาดต่างกันอย่างไร?', answer: 'ราคาประเมินคือราคาที่กรมที่ดินกำหนดเพื่อใช้คิดค่าธรรมเนียม อัปเดตทุก 4 ปี มักต่ำกว่าราคาตลาด 20-50% ภาษีและค่าธรรมเนียมใช้ราคาประเมินหรือราคาซื้อขาย แล้วแต่อย่างไหนสูงกว่า' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องเปรียบเทียบเช่าที่ดิน vs ซื้อที่ดิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="เปรียบเทียบเช่าที่ดิน vs ซื้อที่ดิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">วิเคราะห์ต้นทุน 20 ปี</p>
      <p class="mt-1 text-sm text-slate-700">เปรียบเทียบเช่าที่ดินกับซื้อที่ดิน เห็นความแตกต่างได้ชัด</p>
      <p class="mt-1 text-xs font-medium text-sky-800">ข้อมูลตามอัตราตลาดไทย 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      เปรียบเทียบเช่าที่ดินกับซื้อที่ดิน (20 ปี)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณและเปรียบเทียบต้นทุนรวมระยะยาวระหว่างการเช่าที่ดินกับการซื้อที่ดิน
      ดูส่วนต่างค่าใช้จ่าย ค่าเช่าปรับขึ้น ดอกเบี้ยจำนอง ภาษีที่ดิน และมูลค่าทรัพย์สินสุดท้าย
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ข้อมูลการเช่ากับการซื้อ</h2>

      <form id="lease-vs-buy-form" class="space-y-6">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="property-price" class="block text-sm font-medium text-gray-700 mb-1">
              ราคาที่ดิน (บาท)
            </label>
            <input
              type="text"
              id="property-price"
              inputmode="numeric"
              placeholder="เช่น 2,500,000"
              value="2500000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
          </div>
          <div>
            <label for="annual-rent" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าเช่ารายปี (บาท)
            </label>
            <input
              type="text"
              id="annual-rent"
              inputmode="numeric"
              placeholder="เช่น 120,000"
              value="120000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="rent-deposit" class="block text-sm font-medium text-gray-700 mb-1">
              เงินมัดจำ (บาท) - เช่า
            </label>
            <input
              type="text"
              id="rent-deposit"
              inputmode="numeric"
              placeholder="เช่น 60,000"
              value="60000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
            <p class="mt-1 text-xs text-gray-500">มัดจำคืนเมื่อหมดสัญญา</p>
          </div>
          <div>
            <label for="down-payment" class="block text-sm font-medium text-gray-700 mb-1">
              เงินดาวน์ (%) - ซื้อ
            </label>
            <input
              type="text"
              id="down-payment"
              inputmode="numeric"
              placeholder="เช่น 30"
              value="30"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
            <p class="mt-1 text-xs text-gray-500">เปอร์เซนต์ของราคาที่ดิน</p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="rent-increase" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราปรับค่าเช่า (%) ต่อปี
            </label>
            <input
              type="text"
              id="rent-increase"
              inputmode="numeric"
              placeholder="เช่น 3"
              value="3"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
          </div>
          <div>
            <label for="property-appreciation" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราปรับราคาที่ดิน (%) ต่อปี
            </label>
            <input
              type="text"
              id="property-appreciation"
              inputmode="numeric"
              placeholder="เช่น 2.5"
              value="2.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="mortgage-rate" class="block text-sm font-medium text-gray-700 mb-1">
              ดอกเบี้ยจำนอง (%) ต่อปี
            </label>
            <input
              type="text"
              id="mortgage-rate"
              inputmode="numeric"
              placeholder="เช่น 3.5"
              value="3.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
          </div>
          <div>
            <label for="property-tax-rate" class="block text-sm font-medium text-gray-700 mb-1">
              ภาษีที่ดิน (%) ต่อปี
            </label>
            <input
              type="text"
              id="property-tax-rate"
              inputmode="numeric"
              placeholder="เช่น 0.1"
              value="0.1"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="maintenance-rate" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าดูแลรักษา (%) ของราคาที่ดิน ต่อปี
          </label>
          <input
            type="text"
            id="maintenance-rate"
            inputmode="numeric"
            placeholder="เช่น 1.5"
            value="1.5"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          เปรียบเทียบตอนนี้
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการเปรียบเทียบ (20 ปี)</h2>

        <div class="grid gap-3 sm:grid-cols-2 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center border border-blue-100">
            <div class="text-sm text-gray-600 mb-1">ต้นทุนเช่าทั้งหมด</div>
            <div id="result-lease-total" class="text-2xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center border border-green-100">
            <div class="text-sm text-gray-600 mb-1">ต้นทุนซื้อทั้งหมด</div>
            <div id="result-buy-total" class="text-2xl font-bold text-green-700">-</div>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 mb-6">
          <div class="rounded-lg border border-blue-100 p-4">
            <h3 class="text-sm font-semibold text-blue-800 mb-3">ต้นทุนการเช่า</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600">เงินมัดจำเริ่มแรก</span>
                <span id="lease-deposit" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ค่าเช่า 20 ปี</span>
                <span id="lease-payments" class="font-medium">-</span>
              </div>
              <div class="flex justify-between border-t border-blue-100 pt-2 mt-2 font-semibold">
                <span>รวมเช่า</span>
                <span id="lease-subtotal" class="text-blue-700">-</span>
              </div>
            </div>
          </div>

          <div class="rounded-lg border border-green-100 p-4">
            <h3 class="text-sm font-semibold text-green-800 mb-3">ต้นทุนการซื้อ</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600">เงินดาวน์</span>
                <span id="buy-down" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ค่าธรรมเนียมโอน</span>
                <span id="buy-transfer-fee" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ดอกเบี้ยจำนอง 20 ปี</span>
                <span id="buy-interest" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ภาษีที่ดิน 20 ปี</span>
                <span id="buy-tax" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ค่าดูแลรักษา 20 ปี</span>
                <span id="buy-maintenance" class="font-medium">-</span>
              </div>
              <div class="flex justify-between border-t border-green-100 pt-2 mt-2 font-semibold">
                <span>รวมต้นทุนซื้อ</span>
                <span id="buy-subtotal" class="text-green-700">-</span>
              </div>
              <div class="flex justify-between text-green-800 bg-green-100 p-2 rounded mt-2">
                <span class="font-semibold">ลบมูลค่าทรัพย์สินสุดท้าย</span>
                <span id="buy-residual" class="font-bold">-</span>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-lg bg-yellow-50 border border-yellow-200 p-4">
          <div class="flex items-start gap-3">
            <span class="text-xl">📊</span>
            <div>
              <p class="font-semibold text-yellow-800 mb-1">สรุปผลการเปรียบเทียบ</p>
              <p id="comparison-summary" class="text-sm text-yellow-700">-</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.dol.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมที่ดิน (dol.go.th)</a> — อัตราค่าธรรมเนียมการโอนและจดทะเบียนสิทธิ์</li>
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยสินเชื่อบ้านอ้างอิง MRR/MLR</li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณเปรียบเทียบเช่าที่ดิน-vs-ซื้อที่ดิน/" />
    <RelatedCalculators currentHref="/คำนวณเปรียบเทียบเช่าที่ดิน-vs-ซื้อที่ดิน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการตามอัตราปกติเท่านั้น
      ผลจริงอาจแตกต่างตามสถานการณ์เฉพาะ อัตราดอกเบี้ย ราคาตลาด และสิทธิพิเศษส่วนบุคคล
    </div>
  </article>

  <script>
    function parseNumber(val: string): number {
      return Math.max(0, parseFloat(val.replace(/,/g, '')) || 0);
    }

    function formatThai(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(Math.round(num));
    }

    const form = document.getElementById('lease-vs-buy-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const propertyPrice = parseNumber((document.getElementById('property-price') as HTMLInputElement).value);
      const annualRent = parseNumber((document.getElementById('annual-rent') as HTMLInputElement).value);
      const rentDeposit = parseNumber((document.getElementById('rent-deposit') as HTMLInputElement).value);
      const downPaymentPercent = parseNumber((document.getElementById('down-payment') as HTMLInputElement).value);
      const rentIncreaseRate = parseNumber((document.getElementById('rent-increase') as HTMLInputElement).value) / 100;
      const propertyAppreciationRate = parseNumber((document.getElementById('property-appreciation') as HTMLInputElement).value) / 100;
      const mortgageRate = parseNumber((document.getElementById('mortgage-rate') as HTMLInputElement).value) / 100;
      const propertyTaxRate = parseNumber((document.getElementById('property-tax-rate') as HTMLInputElement).value) / 100;
      const maintenanceRate = parseNumber((document.getElementById('maintenance-rate') as HTMLInputElement).value) / 100;

      // LEASE COSTS
      let leasePayments = 0;
      let currentRent = annualRent;
      for (let year = 0; year < 20; year++) {
        leasePayments += currentRent;
        currentRent *= (1 + rentIncreaseRate);
      }
      const leaseTotal = rentDeposit + leasePayments;

      // BUY COSTS
      const downPayment = propertyPrice * (downPaymentPercent / 100);
      const loanAmount = propertyPrice - downPayment;
      const transferFee = propertyPrice * 0.02;

      // Mortgage calculation: principal + interest over 20 years (240 months)
      const monthlyRate = mortgageRate / 12;
      const numPayments = 240;
      const monthlyPayment = loanAmount * (monthlyRate * Math.pow(1 + monthlyRate, numPayments)) / (Math.pow(1 + monthlyRate, numPayments) - 1);
      const totalMortgagePayment = monthlyPayment * numPayments;
      const totalInterest = totalMortgagePayment - loanAmount;

      // Property tax and maintenance
      let propertyTax = 0;
      let maintenance = 0;
      let currentValue = propertyPrice;
      for (let year = 0; year < 20; year++) {
        propertyTax += currentValue * propertyTaxRate;
        maintenance += currentValue * maintenanceRate;
        currentValue *= (1 + propertyAppreciationRate);
      }

      const residualValue = propertyPrice * Math.pow(1 + propertyAppreciationRate, 20);
      const buySubtotal = downPayment + transferFee + totalInterest + propertyTax + maintenance;
      const buyTotal = buySubtotal - residualValue;

      // Update display
      (document.getElementById('lease-deposit') as HTMLElement).textContent = `${formatThai(rentDeposit)} บาท`;
      (document.getElementById('lease-payments') as HTMLElement).textContent = `${formatThai(leasePayments)} บาท`;
      (document.getElementById('lease-subtotal') as HTMLElement).textContent = `${formatThai(leaseTotal)} บาท`;

      (document.getElementById('buy-down') as HTMLElement).textContent = `${formatThai(downPayment)} บาท`;
      (document.getElementById('buy-transfer-fee') as HTMLElement).textContent = `${formatThai(transferFee)} บาท`;
      (document.getElementById('buy-interest') as HTMLElement).textContent = `${formatThai(totalInterest)} บาท`;
      (document.getElementById('buy-tax') as HTMLElement).textContent = `${formatThai(propertyTax)} บาท`;
      (document.getElementById('buy-maintenance') as HTMLElement).textContent = `${formatThai(maintenance)} บาท`;
      (document.getElementById('buy-subtotal') as HTMLElement).textContent = `${formatThai(buySubtotal)} บาท`;
      (document.getElementById('buy-residual') as HTMLElement).textContent = `${formatThai(residualValue)} บาท`;

      (document.getElementById('result-lease-total') as HTMLElement).textContent = `${formatThai(leaseTotal)} บาท`;
      (document.getElementById('result-buy-total') as HTMLElement).textContent = `${formatThai(buyTotal)} บาท`;

      const diff = leaseTotal - buyTotal;
      let summary = '';
      if (diff > 0) {
        summary = `การเช่าจ่ายมากกว่าการซื้อ ${formatThai(diff)} บาท (ประหยัด ${formatThai(Math.abs(diff))} บาท ถ้าซื้อ)`;
      } else {
        summary = `การซื้อจ่ายมากกว่าการเช่า ${formatThai(Math.abs(diff))} บาท (ประหยัด ${formatThai(diff)} บาท ถ้าเช่า)`;
      }
      (document.getElementById('comparison-summary') as HTMLElement).textContent = summary;

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('lease_vs_buy');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('lease_vs_buy');
    });

    form.addEventListener('input', () => {
      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('lease_vs_buy');
    }, { once: true });
  </script>
</BaseLayout>
