---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณงบประมาณสองรายได้ ปี 2569 คู่รัก 2 เงินเดือน สัดส่วนออกค่าใช้จ่าย | Kamnuanlek';
const pageDescription = 'คำนวณงบประมาณคู่รักหรือสามีภรรยาที่มี 2 รายได้ รายได้รวม ค่าใช้จ่ายร่วมและส่วนตัว สัดส่วนที่แต่ละคนควรออก ยอดเงินสดสุทธิ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบประมาณสองรายได้/`;

const faqData = [
  {
    question: 'สามีภรรยาควรหารค่าใช้จ่ายเท่ากันหรือตามสัดส่วนรายได้?',
    answer: 'ขึ้นอยู่กับข้อตกลงของคู่ แต่วิธีที่เป็นธรรมที่สุดคือหารตามสัดส่วนรายได้ เช่น ถ้าคนหนึ่งมีรายได้ 60% ของรายได้รวม ก็ออกค่าใช้จ่ายร่วม 60% วิธีนี้ทำให้ทั้งคู่มีเงินเหลือพอๆ กันหลังออกค่าใช้จ่าย',
  },
  {
    question: 'ค่าใช้จ่ายร่วมหมายถึงอะไร?',
    answer: 'ค่าใช้จ่ายร่วม (Shared Expenses) คือค่าใช้จ่ายที่ทั้งคู่ใช้ร่วมกัน เช่น ค่าเช่า/ผ่อนบ้าน ค่าไฟ/น้ำ ค่าอาหารในบ้าน ค่าเดินทางร่วม ต่างจากค่าใช้จ่ายส่วนตัว เช่น เสื้อผ้า งานสังสรรค์ของแต่ละคน',
  },
  {
    question: 'ควรมีบัญชีร่วมหรือแยกบัญชี?',
    answer: 'วิธีที่นิยมคือมีบัญชีร่วมสำหรับค่าใช้จ่ายร่วมและเงินออมครอบครัว และบัญชีส่วนตัวสำหรับใช้จ่ายส่วนตัว แต่ละเดือนทั้งคู่โอนสัดส่วนที่ตกลงไว้เข้าบัญชีร่วม',
  },
  {
    question: 'ถ้ารายได้ต่างกันมาก ควรจัดการงบอย่างไร?',
    answer: 'แนะนำให้ใช้สัดส่วนตามรายได้ และคนที่มีรายได้น้อยกว่าไม่ควรออกเกินความสามารถ สิ่งสำคัญคือต้องโปร่งใสเรื่องตัวเลขรายได้ และตกลงวิธีการล่วงหน้า',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบประมาณสองรายได้',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบประมาณสองรายได้">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-emerald-100 bg-emerald-50 p-4">
      <p class="text-sm font-semibold text-emerald-700">คำนวณงบประมาณคู่รัก 2 รายได้</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: รายได้รวม = รายได้ 1 + รายได้ 2 | สัดส่วน = รายได้แต่ละคน ÷ รายได้รวม × 100%</p>
      <p class="mt-1 text-xs font-medium text-emerald-800">คำนวณว่าแต่ละคนควรออกค่าใช้จ่ายร่วมเท่าไร</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณงบประมาณสองรายได้ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกรายได้ของทั้งสองคน ค่าใช้จ่ายร่วม และค่าใช้จ่ายส่วนตัว ระบบจะคำนวณสัดส่วนที่แต่ละคนควรออก
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="dual-form" class="space-y-5">
        <p id="dual-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <p class="text-sm font-semibold text-gray-700">รายได้แต่ละคน</p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="dual-inc1" class="mb-1 block text-sm font-medium text-gray-700">รายได้คนที่ 1 (บาท/เดือน)</label>
            <input type="text" id="dual-inc1" inputmode="numeric" placeholder="เช่น 45,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="dual-inc1-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="dual-inc2" class="mb-1 block text-sm font-medium text-gray-700">รายได้คนที่ 2 (บาท/เดือน)</label>
            <input type="text" id="dual-inc2" inputmode="numeric" placeholder="เช่น 35,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="dual-inc2-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <p class="text-sm font-semibold text-gray-700">ค่าใช้จ่ายร่วม (บาท/เดือน)</p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="dual-shared-housing" class="mb-1 block text-sm font-medium text-gray-700">ที่พัก / ผ่อนบ้าน</label>
            <input type="text" id="dual-shared-housing" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="dual-shared-food" class="mb-1 block text-sm font-medium text-gray-700">อาหารร่วม / ของใช้ในบ้าน</label>
            <input type="text" id="dual-shared-food" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="dual-shared-utilities" class="mb-1 block text-sm font-medium text-gray-700">สาธารณูปโภคร่วม</label>
            <input type="text" id="dual-shared-utilities" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="dual-shared-other" class="mb-1 block text-sm font-medium text-gray-700">ค่าใช้จ่ายร่วมอื่นๆ</label>
            <input type="text" id="dual-shared-other" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <p class="text-sm font-semibold text-gray-700">ค่าใช้จ่ายส่วนตัว (บาท/เดือน)</p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="dual-personal1" class="mb-1 block text-sm font-medium text-gray-700">ค่าใช้จ่ายส่วนตัวคนที่ 1</label>
            <input type="text" id="dual-personal1" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="dual-personal2" class="mb-1 block text-sm font-medium text-gray-700">ค่าใช้จ่ายส่วนตัวคนที่ 2</label>
            <input type="text" id="dual-personal2" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณงบประมาณสองรายได้
        </button>
      </form>
    </div>

    <div id="dual-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายได้รวม</div>
            <div id="res-dual-total-income" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายจ่ายรวม</div>
            <div id="res-dual-total-expense" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดคงเหลือรวม</div>
            <div id="res-dual-balance" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 text-left">
              <th class="px-3 py-2 font-medium text-gray-700">รายการ</th>
              <th class="px-3 py-2 text-right font-medium text-gray-700">คนที่ 1</th>
              <th class="px-3 py-2 text-right font-medium text-gray-700">คนที่ 2</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr>
              <td class="px-3 py-2 text-gray-700">รายได้</td>
              <td id="tbl-dual-inc1" class="px-3 py-2 text-right font-medium">-</td>
              <td id="tbl-dual-inc2" class="px-3 py-2 text-right font-medium">-</td>
            </tr>
            <tr>
              <td class="px-3 py-2 text-gray-700">สัดส่วนรายได้</td>
              <td id="tbl-dual-pct1" class="px-3 py-2 text-right text-blue-700 font-medium">-</td>
              <td id="tbl-dual-pct2" class="px-3 py-2 text-right text-blue-700 font-medium">-</td>
            </tr>
            <tr>
              <td class="px-3 py-2 text-gray-700">ส่วนแบ่งค่าใช้จ่ายร่วม (ตามสัดส่วน)</td>
              <td id="tbl-dual-shared1" class="px-3 py-2 text-right text-gray-600">-</td>
              <td id="tbl-dual-shared2" class="px-3 py-2 text-right text-gray-600">-</td>
            </tr>
            <tr>
              <td class="px-3 py-2 text-gray-700">ค่าใช้จ่ายส่วนตัว</td>
              <td id="tbl-dual-personal1" class="px-3 py-2 text-right text-gray-600">-</td>
              <td id="tbl-dual-personal2" class="px-3 py-2 text-right text-gray-600">-</td>
            </tr>
            <tr class="bg-gray-50 font-semibold">
              <td class="px-3 py-2 text-gray-900">เงินสดสุทธิแต่ละคน</td>
              <td id="tbl-dual-net1" class="px-3 py-2 text-right text-green-700">-</td>
              <td id="tbl-dual-net2" class="px-3 py-2 text-right text-green-700">-</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>รายได้รวม = รายได้ 1 + รายได้ 2</li>
        <li>สัดส่วนคนที่ 1 = รายได้ 1 ÷ รายได้รวม × 100%</li>
        <li>ส่วนแบ่งค่าใช้จ่ายร่วม = ค่าใช้จ่ายร่วมรวม × สัดส่วน</li>
        <li>เงินสดสุทธิ = รายได้ - ส่วนแบ่งค่าใช้จ่ายร่วม - ค่าใช้จ่ายส่วนตัว</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณงบประมาณครัวเรือน/">คำนวณงบประมาณครัวเรือน</a></li>
        <li><a href="/วางแผนงบประมาณครอบครัว/">วางแผนงบประมาณครอบครัว</a></li>
        <li><a href="/คำนวณงบประมาณ-zero-based/">คำนวณงบประมาณ Zero-Based</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#dual-results" />
    <RelatedArticles currentHref="/คำนวณงบประมาณสองรายได้/" />
    <RelatedCalculators currentHref="/คำนวณงบประมาณสองรายได้/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นแนวทางการวางแผน วิธีการแบ่งค่าใช้จ่ายที่เหมาะสมขึ้นอยู่กับข้อตกลงของแต่ละคู่
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return 0;
      const n = Number(s);
      return Number.isFinite(n) && n >= 0 ? n : 0;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('dual-form');
    const formError = document.getElementById('dual-error');
    const resultBox = document.getElementById('dual-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['dual-inc1-error','dual-inc2-error'].forEach(id => setErr(id, ''));

      const inc1 = parseNum(document.getElementById('dual-inc1').value);
      const inc2 = parseNum(document.getElementById('dual-inc2').value);
      let hasError = false;
      if (!inc1 || inc1 <= 0) { setErr('dual-inc1-error', 'กรอกรายได้คนที่ 1'); hasError = true; }
      if (!inc2 || inc2 <= 0) { setErr('dual-inc2-error', 'กรอกรายได้คนที่ 2'); hasError = true; }
      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const totalIncome = inc1 + inc2;
      const pct1 = inc1 / totalIncome;
      const pct2 = inc2 / totalIncome;

      const sharedHousing = parseNum(document.getElementById('dual-shared-housing').value);
      const sharedFood = parseNum(document.getElementById('dual-shared-food').value);
      const sharedUtils = parseNum(document.getElementById('dual-shared-utilities').value);
      const sharedOther = parseNum(document.getElementById('dual-shared-other').value);
      const totalShared = sharedHousing + sharedFood + sharedUtils + sharedOther;

      const personal1 = parseNum(document.getElementById('dual-personal1').value);
      const personal2 = parseNum(document.getElementById('dual-personal2').value);

      const share1 = totalShared * pct1;
      const share2 = totalShared * pct2;

      const net1 = inc1 - share1 - personal1;
      const net2 = inc2 - share2 - personal2;
      const totalExpense = totalShared + personal1 + personal2;
      const totalBalance = totalIncome - totalExpense;

      setText('res-dual-total-income', formatMoney(totalIncome));
      setText('res-dual-total-expense', formatMoney(totalExpense));
      setText('res-dual-balance', formatMoney(totalBalance));
      setText('tbl-dual-inc1', formatMoney(inc1));
      setText('tbl-dual-inc2', formatMoney(inc2));
      setText('tbl-dual-pct1', `${(pct1 * 100).toFixed(1)}%`);
      setText('tbl-dual-pct2', `${(pct2 * 100).toFixed(1)}%`);
      setText('tbl-dual-shared1', formatMoney(share1));
      setText('tbl-dual-shared2', formatMoney(share2));
      setText('tbl-dual-personal1', formatMoney(personal1));
      setText('tbl-dual-personal2', formatMoney(personal2));
      setText('tbl-dual-net1', formatMoney(net1));
      setText('tbl-dual-net2', formatMoney(net2));

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
