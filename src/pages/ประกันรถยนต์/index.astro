---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="ประกันรถยนต์ 2569 — เปรียบเทียบชั้น 1 2+ 3+ ราคา ครบจบ | Kamnuanlek"
  description="เปรียบเทียบประกันรถชั้น 1, 2+, 2, 3+, 3 ตัวอย่างเบี้ยรถ Toyota Camry Honda City Yaris 2569 เครื่องคำนวณประกัน 6 ตัว ข้อมูล OIC"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "ประกันรถยนต์", "item": "https://www.kamnuanlek.com/ประกันรถยนต์/"}
    ]
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "มีสินเชื่อรถต้องซื้อประกันชั้นไหน?",
        "acceptedAnswer": {"@type": "Answer", "text": "ธนาคารและบริษัทเช่าซื้อบังคับซื้อประกันชั้น 1 เสมอ เพื่อป้องกันความเสี่ยงกรณีรถเสียหายทั้งคัน"}
      },
      {
        "@type": "Question",
        "name": "ประกันชั้น 2+ กับ 3+ ต่างกันอย่างไร?",
        "acceptedAnswer": {"@type": "Answer", "text": "ชั้น 2+ คุ้มครองการชนและรถของเราด้วย ชั้น 3+ คุ้มครองเฉพาะกรณีชนกับยานพาหนะที่มีราคา ถ้าชนรถเก่าหรือสิ่งของ ชั้น 3+ ไม่คุ้มครองรถของเรา"}
      },
      {
        "@type": "Question",
        "name": "NCD คืออะไร?",
        "acceptedAnswer": {"@type": "Answer", "text": "NCD (No Claim Discount) คือส่วนลดไม่เรียกร้อง ปีที่ 2 ลด 10% ปีที่ 3-5 ลด 15-25% ถ้าเรียกประกัน NCD จะหายและเบี้ยเพิ่มขึ้นปีถัดไป"}
      },
      {
        "@type": "Question",
        "name": "Deductible คืออะไร?",
        "acceptedAnswer": {"@type": "Answer", "text": "Deductible คือส่วนที่คุณต้องจ่ายเองก่อนประกันจ่าย เช่น Deductible 5,000 บาท เกิดความเสียหาย 50,000 บาท คุณจ่าย 5,000 บาท ประกันจ่าย 45,000 บาท"}
      }
    ]
  }</script>

  <div class="max-w-5xl mx-auto px-4 py-12">
    <!-- Hero Section -->
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4">ประกันรถยนต์ 2569</h1>
      <p class="text-xl text-gray-600 mb-3">เปรียบเทียบชั้น 1 2+ 2 3+ 3 • ตัวอย่างเบี้ยจริง • คำนวณออนไลน์</p>
      <p class="text-sm text-gray-500">ข้อมูลตามอัตรา <a href="https://www.oic.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">คปภ. (OIC)</a> ประจำปี 2569</p>
    </div>

    <!-- Main CTA Section: Calculators -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องคำนวณประกันรถของเรา</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {[
          { href: '/คำนวณค่าประกันรถยนต์/', icon: '🚗', title: 'คำนวณค่าประกันรถยนต์', desc: 'เปรียบเทียบเบี้ยทุกชั้น' },
          { href: '/คำนวณเบี้ยประกันรถยนต์/', icon: '🧮', title: 'คำนวณเบี้ยประกัน', desc: 'ตามมูลค่ารถและชั้น' },
          { href: '/คำนวณ-deductible-ประกันรถ/', icon: '💰', title: 'คำนวณ Deductible', desc: 'เลือกส่วนหักประกัน' },
          { href: '/คำนวณเปรียบเทียบ-deductible-กับเบี้ย/', icon: '⚖️', title: 'เปรียบเทียบ Deductible', desc: 'ผลกระทบต่อเบี้ย' },
          { href: '/คำนวณส่วนลด-ncd/', icon: '🎯', title: 'คำนวณ NCD', desc: 'ส่วนลดไม่เรียกร้อง' },
          { href: '/คำนวณประกัน-top-up/', icon: '📊', title: 'คำนวณประกัน Top-up', desc: 'ความคุ้มครองพิเศษ' },
        ].map((calc) => (
          <a href={calc.href} class="p-5 bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 rounded-lg hover:border-primary-500 hover:shadow-md transition-all">
            <span class="text-3xl">{calc.icon}</span>
            <p class="font-semibold text-gray-900 mt-2">{calc.title}</p>
            <p class="text-gray-600 text-sm mt-1">{calc.desc}</p>
            <p class="text-primary-600 text-xs font-medium mt-2">ใช้ฟรี →</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">เปรียบเทียบความคุ้มครองทุกชั้น</h2>
      <div class="overflow-x-auto rounded-lg border border-gray-200">
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left px-4 py-3 font-semibold text-gray-900">ชั้น</th>
              <th class="text-center px-3 py-3 font-semibold text-gray-900">รถตัวเอง</th>
              <th class="text-center px-3 py-3 font-semibold text-gray-900">ไฟไหม้</th>
              <th class="text-center px-3 py-3 font-semibold text-gray-900">น้ำท่วม</th>
              <th class="text-center px-3 py-3 font-semibold text-gray-900">บุคคลภายนอก</th>
              <th class="text-left px-3 py-3 font-semibold text-gray-900">เบี้ยปี</th>
            </tr>
          </thead>
          <tbody>
            {[
              { cls: 'ชั้น 1', self: '✅ ครบ', fire: '✅', flood: '✅', third: '✅', price: '8,000–15,000', bg: 'bg-green-50' },
              { cls: 'ชั้น 2+', self: '✅ ชน', fire: '✅', flood: '❌', third: '✅', price: '4,500–7,500', bg: '' },
              { cls: 'ชั้น 2', self: '❌', fire: '✅', flood: '❌', third: '✅', price: '2,500–4,500', bg: 'bg-gray-50' },
              { cls: 'ชั้น 3+', self: '❌', fire: '❌', flood: '❌', third: '✅', price: '2,800–4,500', bg: '' },
              { cls: 'ชั้น 3', self: '❌', fire: '❌', flood: '❌', third: '✅', price: '1,200–2,000', bg: 'bg-gray-50' },
            ].map((row) => (
              <tr class={`border-t ${row.bg}`}>
                <td class="px-4 py-3 font-semibold text-gray-900">{row.cls}</td>
                <td class="px-3 py-3 text-center">{row.self}</td>
                <td class="px-3 py-3 text-center">{row.fire}</td>
                <td class="px-3 py-3 text-center">{row.flood}</td>
                <td class="px-3 py-3 text-center">{row.third}</td>
                <td class="px-3 py-3 text-gray-700 font-medium">{row.price}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-500 mt-2">* เบี้ยสำหรับรถเล็ก-กลาง อายุ 3-5 ปี ตามอัตรา OIC • เบี้ยจริงขึ้นอยู่กับบริษัท อายุผู้ขับ ประวัติอุบัติเหตุ</p>
    </section>

    <!-- Premium Examples -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">ตัวอย่างเบี้ยรถยนต์ยอดนิยม 2569</h2>
      <p class="text-gray-600 mb-6">คำนวณจากอัตราเบี้ย คปภ. ประจำปี 2569</p>

      <div class="space-y-6">
        {[
          {
            model: 'Toyota Camry', value: '~1,500,000 บาท', age: 'อายุ 3 ปี',
            rows: [
              { cls: 'ชั้น 1', price: '28,000–35,000', note: 'คุ้มครองครบถ้วน' },
              { cls: 'ชั้น 2+', price: '14,000–18,000', note: 'ชนรถ + บุคคลภายนอก' },
              { cls: 'ชั้น 3', price: '3,500–5,000', note: 'บุคคลภายนอกเท่านั้น' },
            ]
          },
          {
            model: 'Honda City', value: '~700,000 บาท', age: 'อายุ 2 ปี',
            rows: [
              { cls: 'ชั้น 1', price: '12,000–16,000', note: 'ครบถ้วนทั้งหมด' },
              { cls: 'ชั้น 2+', price: '6,500–8,500', note: 'สมดุล (ยอดนิยม)' },
              { cls: 'ชั้น 3', price: '1,800–2,500', note: 'ประหยัด' },
            ]
          },
          {
            model: 'Toyota Yaris', value: '~550,000 บาท', age: 'อายุ 2 ปี',
            rows: [
              { cls: 'ชั้น 1', price: '9,500–13,000', note: 'ครบถ้วนทั้งหมด' },
              { cls: 'ชั้น 2+', price: '5,000–6,500', note: 'ทำให้คุ้มสูง' },
              { cls: 'ชั้น 3', price: '1,200–1,800', note: 'ประหยัดสุด' },
            ]
          },
        ].map((car) => (
          <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
              <h3 class="font-bold text-gray-900">{car.model}</h3>
              <p class="text-sm text-gray-600">มูลค่า {car.value} • {car.age}</p>
            </div>
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-gray-100">
                  <th class="text-left px-4 py-2 font-semibold text-gray-700">ชั้น</th>
                  <th class="text-left px-4 py-2 font-semibold text-gray-700">เบี้ย/ปี</th>
                  <th class="text-left px-4 py-2 font-semibold text-gray-700 hidden sm:table-cell">หมายเหตุ</th>
                </tr>
              </thead>
              <tbody>
                {car.rows.map((r, i) => (
                  <tr class={`border-t ${i % 2 === 1 ? 'bg-gray-50' : ''}`}>
                    <td class="px-4 py-2 font-medium text-gray-900">{r.cls}</td>
                    <td class="px-4 py-2 text-gray-700">{r.price} บาท</td>
                    <td class="px-4 py-2 text-gray-600 hidden sm:table-cell">{r.note}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ))}
      </div>

      <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
        <p class="text-sm text-blue-800"><strong>💡 คำแนะนำ:</strong> ผู้ซื้อบ่อยเลือกชั้น 1 (รถแพง) หรือชั้น 2+ (สมดุล) • มีสินเชื่อต้องซื้อชั้น 1 • ต้องการประหยัด ลองชั้น 2 หรือ 3+</p>
      </div>
    </section>

    <!-- How to Choose -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">วิธีเลือกประกันให้ถูกชั้น</h2>
      <div class="space-y-4">
        {[
          {
            num: 1, title: 'ดูอายุและมูลค่ารถ',
            items: [
              'รถใหม่ (0–2 ปี) หรือมูลค่า > 1 ล้านบาท → ชั้น 1',
              'รถวัยกลาง (3–7 ปี) มูลค่า 500k–1M → ชั้น 2+ หรือ 2',
              'รถเก่า (> 7 ปี) มูลค่า < 500k → ชั้น 2 หรือ 3+',
            ]
          },
          {
            num: 2, title: 'ตรวจสัญญาสินเชื่อ',
            items: [
              'มีสินเชื่อรถ → ธนาคารบังคับซื้อชั้น 1',
              'ชำระเงินสดแล้ว → เลือกได้ตามต้องการ',
            ]
          },
          {
            num: 3, title: 'พิจารณาวิธีการขับ',
            items: [
              'ขับในเมืองเท่านั้น → ชั้น 2 หรือ 3+ เพียงพอ',
              'ขับหลายจังหวัด → ชั้น 2+',
              'ขับไกลบ่อย → ชั้น 1',
            ]
          },
          {
            num: 4, title: 'เปรียบเทียบเบี้ย',
            items: [
              'ขอใบเสนอราคาจาก 3 บริษัท เบี้ยต่างกันได้ 20-30%',
              'ลองใช้เครื่องคำนวณของเราเพื่อดูตัวเลขคร่าวๆ ก่อน',
            ]
          },
        ].map((step) => (
          <div class="flex gap-4 p-5 bg-white border border-gray-200 rounded-lg">
            <div class="flex-shrink-0 w-10 h-10 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center font-bold">{step.num}</div>
            <div>
              <h3 class="font-bold text-gray-900 mb-2">{step.title}</h3>
              <ul class="space-y-1">
                {step.items.map((item) => (
                  <li class="text-sm text-gray-700">• {item}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {[
          {
            q: 'มีสินเชื่อรถต้องซื้อชั้น 1 ไหม?',
            a: 'ใช่ ธนาคารและบริษัทเช่าซื้อบังคับซื้อชั้น 1 เสมอ เพราะรถเป็นหลักประกันของสินเชื่อ'
          },
          {
            q: 'ชั้น 2+ กับ 3+ ต่างกันอย่างไร?',
            a: 'ชั้น 2+ คุ้มครองรถของเราเมื่อเกิดการชน ชั้น 3+ คุ้มครองเฉพาะชนกับยานพาหนะที่มีราคา'
          },
          {
            q: 'NCD (No Claim Discount) คืออะไร?',
            a: 'ส่วนลดเมื่อไม่เรียกประกัน ปีที่ 2 ลด 10% ปีที่ 3-5 ลดได้ถึง 25% ถ้าเรียกประกัน NCD จะหาย'
          },
          {
            q: 'Deductible ส่งผลต่อเบี้ยอย่างไร?',
            a: 'Deductible สูง = เบี้ยถูกลง 10-20% เช่น Deductible 5k เกิดเสียหาย 50k คุณจ่าย 5k ประกันจ่าย 45k'
          },
          {
            q: 'ประกันชั้น 1 คุ้มครองน้ำท่วมไหม?',
            a: 'ชั้น 1 สามารถซื้อความคุ้มครองน้ำท่วมเพิ่มได้ ชั้น 2+ ถึง 3 ไม่มีในนโยบายมาตรฐาน'
          },
          {
            q: 'เรียกประกันแล้ว NCD หายไปคุ้มไหม?',
            a: 'ถ้าเสียหายต่ำกว่า 10-15k หลายคนจ่ายเองแทน เพราะ NCD ที่หายไปทำให้เบี้ยสูงขึ้น 1-2 ปีถัดไป'
          },
        ].map((faq, i) => (
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-2">{faq.q}</h3>
            <p class="text-gray-700 text-sm">{faq.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Data Source -->
    <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600">
      <strong>ที่มาข้อมูล:</strong> เบี้ยในหน้านี้อ้างอิงจาก <a href="https://www.oic.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">คปภ. (สำนักงานคณะกรรมการกำกับและส่งเสริมการประกอบธุรกิจประกันภัย)</a> ประจำปี 2569 เบี้ยเป็นตัวอย่างประมาณการ เบี้ยจริงขึ้นอยู่กับบริษัทประกันและปัจจัยรายบุคคล
    </div>

    <!-- Back to Guide -->
    <div class="mt-12 p-6 bg-blue-50 border border-blue-200 rounded-lg text-center">
      <p class="text-gray-700 mb-3">ต้องการเรียนรู้เพิ่มเติมเกี่ยวกับประกันรถ?</p>
      <a href="/คู่มือประกันรถ/" class="inline-block px-6 py-2 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition">อ่านคู่มือประกันรถฉบับเต็ม</a>
    </div>
  </div>
</BaseLayout>
