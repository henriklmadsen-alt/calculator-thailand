    // Car type multipliers (relative to eco car)
    const carMultipliers: Record<string, { parts: number; labor: number; label: string }> = {
      'eco':    { parts: 1.0, labor: 1.0, label: 'เก๋งเล็ก/อีโค่คาร์' },
      'sedan':  { parts: 1.25, labor: 1.1, label: 'เก๋งกลาง' },
      'suv':    { parts: 1.4, labor: 1.2, label: 'SUV / PPV' },
      'pickup': { parts: 1.15, labor: 1.1, label: 'กระบะ' },
      'euro':   { parts: 2.2, labor: 1.5, label: 'รถยุโรป' },
    };

    // Dealer markup factor (on top of garage price)
    const dealerMarkup = { parts: 1.5, labor: 1.6 };

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    function calculate() {
      const repairKey = (document.getElementById('repair-category') as HTMLSelectElement).value;
      const carType = (document.getElementById('car-type') as HTMLSelectElement).value;
      const serviceType = (document.getElementById('service-type') as HTMLSelectElement).value;

      const repair = repairs[repairKey];
      const carMul = carMultipliers[carType];
      if (!repair || !carMul) return;

      // Garage prices
      const garagePartsMin = Math.round(repair.partsMin * carMul.parts);
      const garagePartsMax = Math.round(repair.partsMax * carMul.parts);
      const garageLaborMin = Math.round(repair.laborMin * carMul.labor);
      const garageLaborMax = Math.round(repair.laborMax * carMul.labor);
      const garageTotalMin = garagePartsMin + garageLaborMin;
      const garageTotalMax = garagePartsMax + garageLaborMax;

      // Dealer prices
      const dealerPartsMin = Math.round(garagePartsMin * dealerMarkup.parts);
      const dealerPartsMax = Math.round(garagePartsMax * dealerMarkup.parts);
      const dealerLaborMin = Math.round(garageLaborMin * dealerMarkup.labor);
      const dealerLaborMax = Math.round(garageLaborMax * dealerMarkup.labor);
      const dealerTotalMin = dealerPartsMin + dealerLaborMin;
      const dealerTotalMax = dealerPartsMax + dealerLaborMax;

      // Which set to display as primary
      const isDealer = serviceType === 'dealer';
      const primaryPartsMin = isDealer ? dealerPartsMin : garagePartsMin;
      const primaryPartsMax = isDealer ? dealerPartsMax : garagePartsMax;
      const primaryLaborMin = isDealer ? dealerLaborMin : garageLaborMin;
      const primaryLaborMax = isDealer ? dealerLaborMax : garageLaborMax;
      const primaryTotalMin = isDealer ? dealerTotalMin : garageTotalMin;
      const primaryTotalMax = isDealer ? dealerTotalMax : garageTotalMax;

      // Show results
      const resultEl = document.getElementById('repair-result') as HTMLDivElement;
      resultEl.classList.remove('hidden');

      (document.getElementById('res-total') as HTMLElement).textContent = `${fmt(primaryTotalMin)} - ${fmt(primaryTotalMax)} บาท`;
      (document.getElementById('res-total-range') as HTMLElement).textContent =
        `ราคา${isDealer ? 'ศูนย์บริการ' : 'อู่ทั่วไป'} สำหรับ${carMul.label}`;

      (document.getElementById('res-parts') as HTMLElement).textContent =
        primaryPartsMin === 0 && primaryPartsMax === 0
          ? 'ไม่มีค่าอะไหล่'
          : `${fmt(primaryPartsMin)} - ${fmt(primaryPartsMax)} บาท`;

      (document.getElementById('res-labor') as HTMLElement).textContent =
        `${fmt(primaryLaborMin)} - ${fmt(primaryLaborMax)} บาท`;

      // Comparison
      (document.getElementById('res-garage-price') as HTMLElement).textContent =
        `${fmt(garageTotalMin)} - ${fmt(garageTotalMax)} บาท`;
      (document.getElementById('res-dealer-price') as HTMLElement).textContent =
        `${fmt(dealerTotalMin)} - ${fmt(dealerTotalMax)} บาท`;

      const diffMin = dealerTotalMin - garageTotalMin;
      const diffMax = dealerTotalMax - garageTotalMax;
      (document.getElementById('res-price-diff') as HTMLElement).textContent =
        `+${fmt(diffMin)} ถึง +${fmt(diffMax)} บาท`;

      // Detail
      (document.getElementById('res-description') as HTMLElement).textContent = repair.description;
      (document.getElementById('res-duration') as HTMLElement).textContent = repair.duration;
      (document.getElementById('res-tips') as HTMLElement).textContent = repair.tips;

      trackCalculatorUsed('car-repair-cost');
    }

    document.getElementById('btn-calculate')!.addEventListener('click', calculate);

    const repairResultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('car-repair-cost');
          repairResultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    repairResultObserver.observe(document.getElementById('repair-result')!);
  </script>
</BaseLayout>
