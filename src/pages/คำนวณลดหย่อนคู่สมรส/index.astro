---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณลดหย่อนคู่สมรส 2569 | 60,000 บาท ไม่มีรายได้ | kamnuanlek.com';
const pageDescription = 'คำนวณค่าลดหย่อนคู่สมรส 2569 ฟรี ลดหย่อนได้ 60,000 บาท หากคู่สมรสไม่มีรายได้ เช็กเงื่อนไขและภาษีที่ประหยัดได้ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณลดหย่อนคู่สมรส/`;

const faqData = [
  {
    question: 'ลดหย่อนคู่สมรสได้เท่าไร?',
    answer: 'ลดหย่อนได้ 60,000 บาท หากคู่สมรสไม่มีรายได้ในปีภาษีนั้น หรือมีรายได้แต่เลือกยื่นรวมกัน',
  },
  {
    question: 'คู่สมรสมีรายได้แต่น้อย ยังลดหย่อนได้ไหม?',
    answer: 'ไม่ได้ เงื่อนไขคือคู่สมรสต้องไม่มีรายได้เลยในปีภาษีนั้น หากคู่สมรสมีรายได้แม้แต่น้อยก็ไม่สามารถใช้ค่าลดหย่อนนี้ได้',
  },
  {
    question: 'ยื่นภาษีแยกหรือรวม ลดหย่อนคู่สมรสต่างกันไหม?',
    answer: 'กรณียื่นภาษีรวมกัน คู่สมรสที่มีรายได้ฝ่ายเดียวสามารถลดหย่อนคู่สมรส 60,000 บาทได้ กรณียื่นแยก ผู้มีรายได้ฝ่ายเดียวสามารถลดหย่อนได้เช่นกัน',
  },
  {
    question: 'ลดหย่อนคู่สมรสซ้ำกับค่าลดหย่อนส่วนตัวได้ไหม?',
    answer: 'ค่าลดหย่อนส่วนตัว 60,000 บาทเป็นของผู้มีเงินได้ ค่าลดหย่อนคู่สมรส 60,000 บาทเป็นของคู่สมรส สามารถใช้พร้อมกันได้รวม 120,000 บาท',
  },
  {
    question: 'สมรสกี่วันถึงจะใช้ลดหย่อนได้?',
    answer: 'ต้องสมรสถูกต้องตามกฎหมาย (จดทะเบียนสมรส) ณ วันที่ 31 ธันวาคมของปีภาษีนั้น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณลดหย่อนคู่สมรส 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณลดหย่อนคู่สมรส">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณลดหย่อนคู่สมรส ปี 2569 (2026)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าลดหย่อนคู่สมรสตามเกณฑ์กรมสรรพากร ลดหย่อนได้ 60,000 บาท
      เมื่อคู่สมรสจดทะเบียนสมรสถูกต้องตามกฎหมายและไม่มีรายได้
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">เช็กเงื่อนไขและคำนวณลดหย่อน</h2>

      <form id="spouse-form" class="space-y-6">
        <fieldset class="space-y-3">
          <legend class="text-sm font-semibold text-gray-900 mb-2">สถานะการสมรส</legend>
          <label class="flex items-center gap-3">
            <input type="radio" name="status" id="status-married" value="married" class="w-4 h-4 text-primary-600" />
            <span class="text-sm text-gray-700">จดทะเบียนสมรสถูกต้องตามกฎหมาย</span>
          </label>
          <label class="flex items-center gap-3">
            <input type="radio" name="status" id="status-not-married" value="not_married" class="w-4 h-4 text-primary-600" />
            <span class="text-sm text-gray-700">ยังไม่ได้จดทะเบียนสมรส</span>
          </label>
        </fieldset>

        <fieldset class="space-y-3" id="income-section">
          <legend class="text-sm font-semibold text-gray-900 mb-2">รายได้ของคู่สมรส</legend>
          <label class="flex items-center gap-3">
            <input type="radio" name="income" id="income-none" value="none" class="w-4 h-4 text-primary-600" />
            <span class="text-sm text-gray-700">ไม่มีรายได้</span>
          </label>
          <label class="flex items-center gap-3">
            <input type="radio" name="income" id="income-has" value="has" class="w-4 h-4 text-primary-600" />
            <span class="text-sm text-gray-700">มีรายได้</span>
          </label>
        </fieldset>

        <div>
          <label for="marginal-rate" class="block text-sm font-medium text-gray-700 mb-1">
            ฐานภาษีของคุณ (%) — สำหรับประมาณภาษีที่ประหยัดได้
          </label>
          <select
            id="marginal-rate"
            class="w-48 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
          >
            <option value="0.05">5%</option>
            <option value="0.10">10%</option>
            <option value="0.15">15%</option>
            <option value="0.20" selected>20%</option>
            <option value="0.25">25%</option>
            <option value="0.30">30%</option>
            <option value="0.35">35%</option>
          </select>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณลดหย่อนคู่สมรส</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">สิทธิ์ลดหย่อน</div>
            <div id="result-eligible" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าลดหย่อน</div>
            <div id="result-amount" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประหยัดภาษีโดยประมาณ</div>
            <div id="result-tax-saved" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <p id="result-message" class="text-sm text-gray-600 mt-2"></p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ค่าลดหย่อนคู่สมรส 2569 ใช้ยังไง?</h2>
      <p>
        หากจดทะเบียนสมรสถูกต้องตามกฎหมายและคู่สมรสไม่มีรายได้ ผู้มีเงินได้สามารถนำค่าลดหย่อน
        60,000 บาท มาใช้ได้ในการยื่นแบบ ภ.ง.ด.90 หรือ ภ.ง.ด.91
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เงื่อนไขสำคัญ</h3>
      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li>คู่สมรสต้องจดทะเบียนสมรสถูกต้องตามกฎหมายไทย</li>
        <li>คู่สมรสต้องไม่มีรายได้พึงประเมินในปีภาษีนั้น <strong>เลย</strong></li>
        <li>ใช้ร่วมกับค่าลดหย่อนส่วนตัว 60,000 บาทได้ รวมเป็น 120,000 บาท</li>
        <li>สามารถใช้ได้ทั้งกรณียื่นแยกและยื่นรวมกัน (กรณียื่นแยก ผู้มีรายได้เป็นผู้ใช้สิทธิ์)</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณลดหย่อนคู่สมรส/" />
    <RelatedCalculators currentHref="/คำนวณลดหย่อนคู่สมรส/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางภาษีหรือกฎหมาย กรุณาปรึกษาผู้เชี่ยวชาญด้านภาษีสำหรับกรณีเฉพาะ
    </div>
  </article>

  <script>
    function formatThai(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(num);
    }

    const form = document.getElementById('spouse-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const statusVal = (document.querySelector('input[name="status"]:checked') as HTMLInputElement | null)?.value;
      const incomeVal = (document.querySelector('input[name="income"]:checked') as HTMLInputElement | null)?.value;
      const rate = parseFloat((document.getElementById('marginal-rate') as HTMLSelectElement).value);

      const eligible = statusVal === 'married' && incomeVal === 'none';
      const amount = eligible ? 60_000 : 0;
      const taxSaved = amount * rate;

      (document.getElementById('result-eligible') as HTMLElement).textContent = eligible ? 'มีสิทธิ์' : 'ไม่มีสิทธิ์';
      (document.getElementById('result-eligible') as HTMLElement).className =
        `text-xl font-bold ${eligible ? 'text-green-700' : 'text-red-600'}`;
      (document.getElementById('result-amount') as HTMLElement).textContent = eligible ? `${formatThai(amount)} บาท` : '0 บาท';
      (document.getElementById('result-tax-saved') as HTMLElement).textContent = eligible ? `~${formatThai(taxSaved)} บาท` : '0 บาท';

      let message = '';
      if (!statusVal) {
        message = 'กรุณาเลือกสถานะการสมรส';
      } else if (!incomeVal) {
        message = 'กรุณาเลือกสถานะรายได้ของคู่สมรส';
      } else if (statusVal !== 'married') {
        message = 'ต้องจดทะเบียนสมรสถูกต้องตามกฎหมายจึงจะมีสิทธิ์ลดหย่อน';
      } else if (incomeVal === 'has') {
        message = 'คู่สมรสมีรายได้ ไม่สามารถใช้ค่าลดหย่อนนี้ได้ ทั้งสองฝ่ายยื่นภาษีแยกกันและใช้ค่าลดหย่อนส่วนตัวของตนเอง';
      } else {
        message = `มีสิทธิ์ลดหย่อนคู่สมรส 60,000 บาท ประหยัดภาษีโดยประมาณที่อัตรา ${(rate * 100).toFixed(0)}% ประมาณ ${formatThai(taxSaved)} บาท`;
      }
      (document.getElementById('result-message') as HTMLElement).textContent = message;

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('spouse_allowance');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('spouse_allowance');
    });

    form.addEventListener('input', () => {
      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('spouse_allowance');
    }, { once: true });
  </script>
</BaseLayout>
