---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เปรียบเทียบเครื่องคำนวณภาษี — ภาษีเงินได้ vs VAT vs ภาษีนิติบุคคล | Kamnuanlek"
  description="เปรียบเทียบเครื่องคำนวณภาษีไทยและเลือกใช้ให้ถูก ภาษีเงินได้บุคคลธรรมดา VAT ภาษีนิติบุคคล และภาษีหัก ณ ที่จ่าย อธิบายให้เข้าใจง่าย"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เปรียบเทียบเครื่องคำนวณภาษี — ภาษีเงินได้ vs VAT vs ภาษีนิติบุคคล", "item": "https://www.kamnuanlek.com/เปรียบเทียบเครื่องคำนวณภาษี/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-8">เปรียบเทียบเครื่องคำนวณภาษี</h1>

    <div class="mb-12 overflow-x-auto">
      <table class="w-full border-collapse border border-gray-300">
        <thead class="bg-primary-100">
          <tr>
            <th class="border border-gray-300 p-4 text-left font-semibold">ประเภทเครื่องคำนวณ</th>
            <th class="border border-gray-300 p-4 text-left font-semibold">ใครควรใช้</th>
            <th class="border border-gray-300 p-4 text-left font-semibold">ฟีเจอร์หลัก</th>
            <th class="border border-gray-300 p-4 text-left font-semibold">ลิงก์</th>
          </tr>
        </thead>
        <tbody>
          <tr class="hover:bg-gray-50">
            <td class="border border-gray-300 p-4 font-semibold">ภาษีเงินได้</td>
            <td class="border border-gray-300 p-4">บุคคลธรรมดา</td>
            <td class="border border-gray-300 p-4">คำนวณภาษีบุคคล ค่าลดหย่อน</td>
            <td class="border border-gray-300 p-4"><a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="text-primary-600 hover:underline">คำนวณ</a></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="border border-gray-300 p-4 font-semibold">VAT</td>
            <td class="border border-gray-300 p-4">ธุรกิจ</td>
            <td class="border border-gray-300 p-4">ภาษีมูลค่าเพิ่ม (7%)</td>
            <td class="border border-gray-300 p-4"><a href="/คำนวณมูลค่าเพิ่ม/" class="text-primary-600 hover:underline">คำนวณ</a></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="border border-gray-300 p-4 font-semibold">ภาษีหัก ณ ที่จ่าย</td>
            <td class="border border-gray-300 p-4">บริษัท</td>
            <td class="border border-gray-300 p-4">ภาษีที่หักไว้ ณ แหล่งจ่าย</td>
            <td class="border border-gray-300 p-4"><span class="text-gray-400">เร็วๆ นี้</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">ควรใช้เครื่องคำนวณใดในสถานการณ์ไหน</h2>
        <div class="space-y-4">
          <div class="p-4 bg-blue-50 rounded-lg border border-blue-200">
            <h3 class="font-semibold text-gray-900 mb-2">💰 ภาษีเงินได้บุคคลธรรมดา</h3>
            <p class="text-gray-700">ใช้หากคุณเป็นฟรีแลนซ์ ประกอบอาชีพอิสระ หรือมีรายได้เพิ่มเติม คำนวณก่อนสิ้นปีเพื่อวางแผนค่าลดหย่อน</p>
          </div>
          <div class="p-4 bg-green-50 rounded-lg border border-green-200">
            <h3 class="font-semibold text-gray-900 mb-2">📊 VAT (7%)</h3>
            <p class="text-gray-700">ใช้หากธุรกิจของคุณจดทะเบียนภาษีมูลค่าเพิ่ม คำนวณภาษีจากยอดขายและค่าใช้จ่าย</p>
          </div>
        </div>
      </section>

      <section class="mt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">แหล่งข้อมูลที่เกี่ยวข้อง</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
            <span class="font-semibold text-gray-900">💳 ศูนย์รวมเครื่องคำนวณการเงิน</span>
            <p class="text-gray-600 text-sm mt-2">เครื่องคำนวณภาษี สินเชื่อ และออมเงินครบชุด</p>
          </a>
          <a href="/เครื่องคำนวณการเงินชั้นยอด/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
            <span class="font-semibold text-gray-900">📊 เครื่องมือการเงิน 10 อันดับ</span>
            <p class="text-gray-600 text-sm mt-2">เครื่องคำนวณการเงินที่มีประโยชน์มากที่สุด เรียงตามความสำคัญ</p>
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
