---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เปรียบเทียบเครื่องคำนวณภาษี — ภาษีเงินได้ vs VAT vs ภาษีนิติบุคคล | Kamnuanlek"
  description="เปรียบเทียบเครื่องคำนวณภาษีไทยและเลือกใช้ให้ถูก ภาษีเงินได้บุคคลธรรมดา VAT ภาษีนิติบุคคล และภาษีหัก ณ ที่จ่าย อธิบายให้เข้าใจง่าย"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เปรียบเทียบเครื่องคำนวณภาษี — ภาษีเงินได้ vs VAT vs ภาษีนิติบุคคล", "item": "https://www.kamnuanlek.com/เปรียบเทียบเครื่องคำนวณภาษี/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-8">เปรียบเทียบเครื่องคำนวณภาษี</h1>

    <div class="mb-12 overflow-x-auto">
      <table class="w-full border-collapse border border-gray-300">
        <thead class="bg-primary-100">
          <tr>
            <th class="border border-gray-300 p-4 text-left font-semibold">Calculator Type</th>
            <th class="border border-gray-300 p-4 text-left font-semibold">Who Uses It</th>
            <th class="border border-gray-300 p-4 text-left font-semibold">Key Features</th>
            <th class="border border-gray-300 p-4 text-left font-semibold">Link</th>
          </tr>
        </thead>
        <tbody>
          <tr class="hover:bg-gray-50">
            <td class="border border-gray-300 p-4 font-semibold">Income Tax</td>
            <td class="border border-gray-300 p-4">Individuals</td>
            <td class="border border-gray-300 p-4">Calculate personal tax, deductions</td>
            <td class="border border-gray-300 p-4"><a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="text-primary-600 hover:underline">Calculate</a></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="border border-gray-300 p-4 font-semibold">VAT</td>
            <td class="border border-gray-300 p-4">Businesses</td>
            <td class="border border-gray-300 p-4">Value Added Tax (7%)</td>
            <td class="border border-gray-300 p-4"><a href="/คำนวณมูลค่าเพิ่ม/" class="text-primary-600 hover:underline">Calculate</a></td>
          </tr>
          <tr class="hover:bg-gray-50">
            <td class="border border-gray-300 p-4 font-semibold">Withholding Tax</td>
            <td class="border border-gray-300 p-4">Companies</td>
            <td class="border border-gray-300 p-4">Tax withheld at source</td>
            <td class="border border-gray-300 p-4"><span class="text-gray-400">Coming soon</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">When to Use Each Calculator</h2>
        <div class="space-y-4">
          <div class="p-4 bg-blue-50 rounded-lg border border-blue-200">
            <h3 class="font-semibold text-gray-900 mb-2">💰 Personal Income Tax</h3>
            <p class="text-gray-700">Use if you're self-employed, freelancer, or earning additional income. Calculate before year-end to plan deductions.</p>
          </div>
          <div class="p-4 bg-green-50 rounded-lg border border-green-200">
            <h3 class="font-semibold text-gray-900 mb-2">📊 VAT (7%)</h3>
            <p class="text-gray-700">Use if your business is VAT-registered. Calculate tax on sales and expenses.</p>
          </div>
        </div>
      </section>

      <section class="mt-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
            <span class="font-semibold text-gray-900">💳 Financial Calculators Hub</span>
            <p class="text-gray-600 text-sm mt-2">Complete collection of tax, loan, and savings calculators</p>
          </a>
          <a href="/เครื่องคำนวณการเงินชั้นยอด/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
            <span class="font-semibold text-gray-900">📊 Top 10 Financial Tools</span>
            <p class="text-gray-600 text-sm mt-2">Essential financial calculators ranked by usefulness</p>
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
