---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าแว่นตา | Kamnuanlek';
const pageDescription = 'คำนวณค่าแว่นตา ค่าเลนส์ กรอบแว่น ค่าตรวจสายตา ตามอัตราร้านแว่นตาไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0411-ค่าแว่นตา/`;

const faqData = [
  { question: 'แว่นตาทั่วไปราคาเท่าไหร่ในไทย?', answer: 'แว่นตาพื้นฐาน 500-2,000 บาท แว่นตาคุณภาพกลาง 2,000-5,000 บาท แว่นแบรนด์เนม 5,000-20,000 บาทขึ้นไป รวมเลนส์และกรอบ' },
  { question: 'เลนส์ Progressive ต่างจากเลนส์ธรรมดาอย่างไร?', answer: 'เลนส์ Progressive (multifocal) มองได้หลายระยะในเลนส์เดียว ราคา 3,000-15,000 บาท เหมาะผู้สูงอายุที่ต้องใช้ทั้งแว่นสายตาไกลและใกล้' },
  { question: 'ควรเปลี่ยนแว่นตาทุกกี่ปี?', answer: 'ควรตรวจสายตาทุก 1-2 ปี และเปลี่ยนเลนส์เมื่อค่าสายตาเปลี่ยนเกิน 0.25 หรือถ้ากรอบเสียหาย เลนส์มีรอยขีดข่วนมาก' },
  { question: 'ประกันสังคมคุ้มครองค่าแว่นตาไหม?', answer: 'ผู้ประกันตนมาตรา 33 ได้รับค่าแว่นตา 500 บาท ทุก 5 ปี เมื่อค่าสายตาเปลี่ยนเกิน 0.5 ไม่ครอบคลุมแว่นกันแดดหรือคอนแทคเลนส์' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าแว่นตา">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าแว่นตา</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าแว่นตารวม เลนส์ กรอบ และค่าตรวจสายตา</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div>
          <label for="lens_type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทเลนส์</label>
          <select id="lens_type" class="w-full px-3 py-2 border border-gray-300 rounded-md">
            <option value="500">เลนส์ธรรมดา (~500 บาท)</option>
            <option value="1500" selected>เลนส์มัลติโค้ท (~1,500 บาท)</option>
            <option value="3500">เลนส์ Blue Light (~3,500 บาท)</option>
            <option value="8000">เลนส์ Progressive (~8,000 บาท)</option>
          </select>
        </div>
        <div><label for="frame_cost" class="block text-sm font-medium text-gray-700 mb-1">ราคากรอบแว่น (บาท)</label><input type="text" id="frame_cost" inputmode="decimal" placeholder="เช่น 1500" value="1500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="eye_exam" class="block text-sm font-medium text-gray-700 mb-1">ค่าตรวจสายตา (บาท)</label><input type="text" id="eye_exam" inputmode="decimal" placeholder="เช่น 200" value="200" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="pairs" class="block text-sm font-medium text-gray-700 mb-1">จำนวนคู่</label><input type="number" id="pairs" min="1" max="5" placeholder="เช่น 1" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าแว่นต่อคู่</p>
            <p id="per_pair" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมค่าแว่นตาทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const lensType = parseFloat((document.getElementById('lens_type') as HTMLSelectElement).value) || 0;
      const frameCost = parseFloat((document.getElementById('frame_cost') as HTMLInputElement).value) || 0;
      const eyeExam = parseFloat((document.getElementById('eye_exam') as HTMLInputElement).value) || 0;
      const pairs = parseInt((document.getElementById('pairs') as HTMLInputElement).value) || 1;

      const perPair = (lensType * 2) + frameCost;
      const total = (perPair * pairs) + eyeExam;

      (document.getElementById('per_pair') as HTMLElement).textContent = perPair.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('eyeglasses-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
