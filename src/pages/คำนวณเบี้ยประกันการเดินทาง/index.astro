---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import AffiliateCard from '../../components/templates/AffiliateCard.astro';

const pageTitle = 'คำนวณเบี้ยประกันการเดินทาง 2569 | ในประเทศ+ต่างประเทศ | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณเบี้ยประกันการเดินทางในประเทศและต่างประเทศ ตามจุดหมาย จำนวนวัน ผู้เดินทาง และแผนคุ้มครอง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเบี้ยประกันการเดินทาง/`;

const faqData = [
  {
    question: 'ประกันการเดินทางครอบคลุมอะไรบ้าง?',
    answer: 'ประกันการเดินทางทั่วไปครอบคลุม: อุบัติเหตุและค่ารักษาพยาบาลต่างประเทศ, การยกเลิกหรือล่าช้าของเที่ยวบิน, สัมภาระสูญหายหรือล่าช้า, การส่งตัวกลับประเทศกรณีฉุกเฉิน บางแผนยังรวมการสูญเสียพาสปอร์ตและความรับผิดส่วนบุคคล',
  },
  {
    question: 'ควรซื้อประกันการเดินทางก่อนออกเดินทางนานแค่ไหน?',
    answer: 'ควรซื้อก่อนออกเดินทางอย่างน้อย 1-3 วัน เพื่อให้กรมธรรม์มีผลบังคับก่อนเดินทาง หากซื้อหลังจากเกิดเหตุ เช่น เที่ยวบินยกเลิกแล้ว จะไม่ได้รับความคุ้มครอง บางประเทศกำหนดให้ต้องมีประกันการเดินทางก่อนออกวีซ่า',
  },
  {
    question: 'เดินทางในประเทศต้องทำประกันการเดินทางไหม?',
    answer: 'ไม่บังคับ แต่แนะนำสำหรับการเดินทางที่มีมูลค่าสูงหรือเสี่ยง เช่น ทริปผจญภัย เดินป่า ดำน้ำ หรือเดินทางบ่อย ประกันในประเทศราคาถูกกว่าต่างประเทศมากและช่วยครอบคลุมค่าเที่ยวบินล่าช้าและอุบัติเหตุ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเบี้ยประกันการเดินทาง',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเบี้ยประกันการเดินทาง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณเบี้ยประกันการเดินทาง 2569</p>
      <p class="mt-1 text-sm text-slate-700">ตัวเลขเป็นการประมาณการ เพื่อใช้วางแผนเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเบี้ยประกันการเดินทาง 2569 — ในประเทศและต่างประเทศ
    </h1>

    <p class="text-gray-600 mb-6">
      ประมาณเบี้ยประกันการเดินทางตามจุดหมาย จำนวนวัน ผู้เดินทาง และแผนคุ้มครอง
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="ti-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ti-dest" class="block text-sm font-medium text-gray-700 mb-1">จุดหมายปลายทาง</label>
            <select id="ti-dest" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="domestic">ในประเทศไทย</option>
              <option value="asean">อาเซียน</option>
              <option value="asia">เอเชีย (ไม่รวมอาเซียน)</option>
              <option value="world">ทั่วโลก</option>
            </select>
          </div>
          <div>
            <label for="ti-plan" class="block text-sm font-medium text-gray-700 mb-1">แผนประกัน</label>
            <select id="ti-plan" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="basic">พื้นฐาน</option>
              <option value="standard" selected>มาตรฐาน</option>
              <option value="premium">พรีเมียม</option>
            </select>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ti-days" class="block text-sm font-medium text-gray-700 mb-1">จำนวนวันเดินทาง</label>
            <input type="text" id="ti-days" inputmode="numeric" placeholder="เช่น 7"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="ti-days-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ti-pax" class="block text-sm font-medium text-gray-700 mb-1">จำนวนผู้เดินทาง (คน)</label>
            <input type="text" id="ti-pax" inputmode="numeric" placeholder="เช่น 2" value="1"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <button type="submit" id="ti-submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ (ประมาณการ)</h2>
        <div class="grid gap-3 sm:grid-cols-2 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เบี้ยรวมทั้งหมด</div>
            <div id="res-total" class="text-2xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เบี้ยต่อคน</div>
            <div id="res-per-pax" class="text-2xl font-bold text-blue-700">-</div>
          </div>
        </div>
        <p id="res-summary" class="text-sm text-gray-600 mt-2">-</p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">อัตราเบี้ยประกันการเดินทาง (ประมาณการ)</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200">
          <thead><tr class="bg-gray-50"><th class="px-4 py-2 text-left border-b">จุดหมาย</th><th class="px-4 py-2 text-right border-b">พื้นฐาน (บาท/วัน)</th><th class="px-4 py-2 text-right border-b">มาตรฐาน</th><th class="px-4 py-2 text-right border-b">พรีเมียม</th></tr></thead>
          <tbody>
            <tr class="border-b"><td class="px-4 py-2">ในประเทศ</td><td class="px-4 py-2 text-right">30</td><td class="px-4 py-2 text-right">50</td><td class="px-4 py-2 text-right">80</td></tr>
            <tr class="border-b"><td class="px-4 py-2">อาเซียน</td><td class="px-4 py-2 text-right">50</td><td class="px-4 py-2 text-right">70</td><td class="px-4 py-2 text-right">110</td></tr>
            <tr class="border-b"><td class="px-4 py-2">เอเชีย</td><td class="px-4 py-2 text-right">70</td><td class="px-4 py-2 text-right">100</td><td class="px-4 py-2 text-right">150</td></tr>
            <tr><td class="px-4 py-2">ทั่วโลก</td><td class="px-4 py-2 text-right">90</td><td class="px-4 py-2 text-right">130</td><td class="px-4 py-2 text-right">200</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <AffiliateCard
      category="insurance"
      affiliateUrl="https://retail.easysunday.com/?sRefCode=SAF5401723"
      partnerName="EasySunday"
      ctaText="เปรียบเทียบประกันการเดินทาง"
      subtext="เปรียบเทียบประกันการเดินทางต่างประเทศและในประเทศจาก MSIG และอื่น ๆ"
    />
    <RelatedCalculators currentHref="/คำนวณเบี้ยประกันการเดินทาง/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงต้องสอบถามบริษัทประกันภัยโดยตรง
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n) + ' บาท'; }

    const RATES: Record<string, Record<string, number>> = {
      domestic: { basic: 30, standard: 50, premium: 80 },
      asean: { basic: 50, standard: 70, premium: 110 },
      asia: { basic: 70, standard: 100, premium: 150 },
      world: { basic: 90, standard: 130, premium: 200 },
    };

    const form = document.getElementById('ti-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    function setErr(id: string, msg: string) { const el = document.getElementById(id); if (el) { el.textContent = msg; el.classList.remove('hidden'); } }
    function clearErr(id: string) { const el = document.getElementById(id); if (el) { el.textContent = ''; el.classList.add('hidden'); } }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearErr('ti-days-error');

      const dest = (document.getElementById('ti-dest') as HTMLSelectElement).value;
      const plan = (document.getElementById('ti-plan') as HTMLSelectElement).value;
      const days = parseNum((document.getElementById('ti-days') as HTMLInputElement).value);
      const pax = Math.max(1, parseNum((document.getElementById('ti-pax') as HTMLInputElement).value));

      if (days < 1 || days > 180) { setErr('ti-days-error', 'กรุณากรอกจำนวนวัน 1-180 วัน'); return; }

      trackCalculatorStart('travel-insurance-premium');

      const rate = RATES[dest][plan] || 50;
      const perPax = rate * days;
      const total = perPax * pax;

      const destNames: Record<string, string> = { domestic: 'ในประเทศ', asean: 'อาเซียน', asia: 'เอเชีย', world: 'ทั่วโลก' };
      const planNames: Record<string, string> = { basic: 'พื้นฐาน', standard: 'มาตรฐาน', premium: 'พรีเมียม' };

      (document.getElementById('res-total') as HTMLElement).textContent = fmt(total);
      (document.getElementById('res-per-pax') as HTMLElement).textContent = fmt(perPax);
      (document.getElementById('res-summary') as HTMLElement).textContent = `${destNames[dest]} | แผน${planNames[plan]} | ${days} วัน × ${pax} คน = ${fmt(total)}`;

      resultsDiv.classList.remove('hidden');
      document.getElementById('affiliate-card')?.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('travel-insurance-premium');
      trackCalculatorUsed('travel-insurance-premium');
    });
  </script>
</BaseLayout>
