---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณค่าบำรุงรักษาเครื่องจักร ปี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณค่าบำรุงรักษาเครื่องจักร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าบำรุงรักษาเครื่องจักร/`;

const faqData = [
  {
    question: 'คำถามที่พบบ่อย 1',
    answer: 'คำตอบที่มีความหมาย',
  },
  {
    question: 'คำถามที่พบบ่อย 2',
    answer: 'คำตอบที่มีความหมาย',
  },
  {
    question: 'คำถามที่พบบ่อย 3',
    answer: 'คำตอบที่มีความหมาย',
  },
];

const jsonLdSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'คำนวณค่าบำรุงรักษาเครื่องจักร',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าบำรุงรักษาเครื่องจักร">
  <article>
    <h1 class="text-3xl font-bold mb-4">คำนวณค่าบำรุงรักษาเครื่องจักร</h1>
    <p class="text-gray-600 mb-6">คำนวณค่าบำรุงรักษาเครื่องจักร</p>

    <div class="bg-white rounded-lg shadow p-6 mb-8">
      <input type="number" placeholder="ป้อนค่า" class="w-full px-3 py-2 border rounded mb-4" />
      <button class="px-4 py-2 bg-blue-600 text-white rounded">คำนวณ</button>
    </div>

    <div class="grid gap-6 mb-8">
      <h2 class="text-2xl font-bold">คำถามที่พบบ่อย</h2>
      {faqData.map(faq => (
        <div class="border-l-4 border-blue-500 pl-4">
          <h3 class="font-bold">{faq.question}</h3>
          <p>{faq.answer}</p>
        </div>
      ))}
    </div>

    <RelatedCalculators />
    <RelatedArticles />
  </article>

  <script type="application/ld+json">
    {JSON.stringify(jsonLdSchema)}
  </script>
</BaseLayout>
