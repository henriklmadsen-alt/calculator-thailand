---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าจ้างพนักงาน 2569 | ต้นทุนรวมที่นายจ้างจ่ายจริง ประกันสังคม กองทุนสำรองเลี้ยงชีพ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนค่าจ้างพนักงานทั้งหมดที่นายจ้างต้องจ่าย เงินเดือน ประกันสังคมส่วนนายจ้าง กองทุนสำรองเลี้ยงชีพ ประกันกลุ่ม สวัสดิการ สำหรับ HR และเจ้าของธุรกิจ ปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าจ้างพนักงาน/`;

const faqData = [
  {
    question: 'ต้นทุนค่าจ้างพนักงานจริงๆ นายจ้างจ่ายเท่าไร?',
    answer: 'นายจ้างจ่ายมากกว่าเงินเดือนประมาณ 15-30% ขึ้นอยู่กับสวัสดิการ ประกอบด้วย เงินเดือนพื้นฐาน + ประกันสังคมส่วนนายจ้าง (5% สูงสุด 750 บาท) + กองทุนสำรองเลี้ยงชีพ (2-15%) + ประกันกลุ่ม + สวัสดิการอื่นๆ',
  },
  {
    question: 'นายจ้างต้องจ่ายประกันสังคมเท่าไร?',
    answer: 'นายจ้างจ่ายสมทบ 5% ของเงินเดือน เท่ากับลูกจ้าง โดยคิดจากฐานเงินเดือนขั้นต่ำ 1,650 บาท สูงสุด 15,000 บาท ดังนั้นจ่ายสูงสุด 750 บาท/เดือน/คน ตาม พ.ร.บ. ประกันสังคม พ.ศ. 2533',
  },
  {
    question: 'กองทุนสำรองเลี้ยงชีพ นายจ้างจ่ายกี่เปอร์เซ็นต์?',
    answer: 'นายจ้างสมทบ 2-15% ของเงินเดือน โดยต้องจ่ายไม่น้อยกว่าที่ลูกจ้างสมทบ ส่วนใหญ่บริษัทในไทยจ่ายสมทบ 3-5% เป็นสวัสดิการดึงดูดพนักงาน',
  },
  {
    question: 'ค่าประกันกลุ่มพนักงานเฉลี่ยเท่าไร?',
    answer: 'ค่าประกันสุขภาพกลุ่มเฉลี่ย 500-3,000 บาท/คน/เดือน ขึ้นอยู่กับวงเงินคุ้มครองและจำนวนพนักงาน ค่าประกันอุบัติเหตุกลุ่มเฉลี่ย 100-300 บาท/คน/เดือน',
  },
  {
    question: 'พนักงานเงินเดือน 25,000 บาท นายจ้างจ่ายจริงเท่าไร?',
    answer: 'ตัวอย่าง: เงินเดือน 25,000 + ประกันสังคม 750 + กองทุน 5% (1,250) + ประกันกลุ่ม 1,000 = ต้นทุนรวมประมาณ 28,000 บาท/เดือน หรือ 1.12 เท่าของเงินเดือน',
  },
  {
    question: 'สวัสดิการอื่นๆ ที่นายจ้างมักให้มีอะไรบ้าง?',
    answer: 'ค่าเดินทาง ค่าอาหาร ค่าโทรศัพท์ ค่ายูนิฟอร์ม เงินช่วยเหลืองานบุญ ของขวัญวันเกิด ตรวจสุขภาพประจำปี ค่าฝึกอบรม โบนัส (ไม่รวมในต้นทุนรายเดือนนี้)',
  },
,
  { question: 'ค่าแรงขั้นต่ำปี 2569 อยู่ที่เท่าไร?', answer: 'ค่าแรงขั้นต่ำปี 2568-2569 กรุงเทพและปริมณฑล 370-400 บาท/วัน ต่างจังหวัดอยู่ที่ 330-370 บาท/วัน ขึ้นอยู่กับจังหวัด ตรวจสอบอัตราล่าสุดได้จากกระทรวงแรงงาน mol.go.th' },
  { question: 'เงินเดือนสุทธิคำนวณจากอะไรบ้าง?', answer: 'เงินเดือนสุทธิ = เงินเดือนรวม - ภาษีหัก ณ ที่จ่าย - เงินสมทบประกันสังคม (5% สูงสุด 750 บาท) - กองทุนสำรองเลี้ยงชีพ (ถ้ามี) นายจ้างจ่ายประกันสังคมเพิ่มอีกฝ่าย 5%' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าจ้างพนักงาน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าจ้างพนักงาน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าจ้างพนักงาน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      คำนวณต้นทุนรวมที่นายจ้างต้องจ่ายต่อพนักงานหนึ่งคน
      รวมเงินเดือน ประกันสังคมส่วนนายจ้าง กองทุนสำรองเลี้ยงชีพ ประกันกลุ่ม และสวัสดิการ
      สำหรับ HR และเจ้าของธุรกิจ
    </p>

    <!-- Calculator Form -->
    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="ec-form" class="space-y-5">
        <p id="ec-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="monthly-salary" class="mb-1 block text-sm font-medium text-gray-700">
              เงินเดือนพนักงาน (บาท/เดือน)
            </label>
            <input
              type="text"
              id="monthly-salary"
              inputmode="decimal"
              placeholder="เช่น 25000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p id="monthly-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="working-days" class="mb-1 block text-sm font-medium text-gray-700">
              วันทำงานต่อเดือน (วัน)
            </label>
            <input
              type="text"
              id="working-days"
              inputmode="decimal"
              placeholder="เช่น 22"
              value="22"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p id="working-days-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <!-- Social Security Toggle -->
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
          <label class="flex cursor-pointer items-center gap-3">
            <input type="checkbox" id="include-sso" checked class="h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
            <span class="text-sm font-medium text-gray-700">ประกันสังคม ม.33 ส่วนนายจ้าง (5% สูงสุด 750 บาท)</span>
          </label>
        </div>

        <!-- Provident Fund Toggle -->
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
          <label class="flex cursor-pointer items-center gap-3">
            <input type="checkbox" id="include-pvd" class="h-4 w-4 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
            <span class="text-sm font-medium text-gray-700">กองทุนสำรองเลี้ยงชีพ ส่วนนายจ้างสมทบ</span>
          </label>

          <div id="pvd-fields" class="mt-4 hidden">
            <div class="max-w-xs">
              <label for="pvd-percent" class="mb-1 block text-sm font-medium text-gray-700">
                อัตราสมทบนายจ้าง (%)
              </label>
              <input
                type="text"
                id="pvd-percent"
                inputmode="decimal"
                placeholder="เช่น 5"
                value="5"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
              />
              <p id="pvd-percent-error" class="mt-1 hidden text-sm text-red-600"></p>
              <p class="mt-1 text-xs text-gray-500">ตามกฎหมาย 2-15% ส่วนใหญ่ 3-5%</p>
            </div>
          </div>
        </div>

        <!-- Benefits Section -->
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
          <p class="mb-3 text-sm font-medium text-gray-700">สวัสดิการอื่นๆ (บาท/เดือน/คน)</p>
          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <label for="health-insurance" class="mb-1 block text-sm font-medium text-gray-700">
                ประกันสุขภาพกลุ่ม
              </label>
              <input
                type="text"
                id="health-insurance"
                inputmode="decimal"
                placeholder="เช่น 1000"
                value="0"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
              />
              <p id="health-insurance-error" class="mt-1 hidden text-sm text-red-600"></p>
            </div>
            <div>
              <label for="accident-insurance" class="mb-1 block text-sm font-medium text-gray-700">
                ประกันอุบัติเหตุกลุ่ม
              </label>
              <input
                type="text"
                id="accident-insurance"
                inputmode="decimal"
                placeholder="เช่น 200"
                value="0"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
              />
              <p id="accident-insurance-error" class="mt-1 hidden text-sm text-red-600"></p>
            </div>
            <div>
              <label for="other-benefits" class="mb-1 block text-sm font-medium text-gray-700">
                สวัสดิการอื่นๆ
              </label>
              <input
                type="text"
                id="other-benefits"
                inputmode="decimal"
                placeholder="เช่น 500"
                value="0"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
              />
              <p id="other-benefits-error" class="mt-1 hidden text-sm text-red-600"></p>
            </div>
          </div>
        </div>

        <button
          type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          คำนวณต้นทุนค่าจ้าง
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="ec-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ — มุมมองนายจ้าง</h2>

        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนรวม/เดือน</div>
            <div id="res-total-monthly" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนรวม/ปี</div>
            <div id="res-total-annual" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุน/วัน</div>
            <div id="res-daily-cost" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="rounded-lg bg-purple-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ตัวคูณต้นทุน</div>
            <div id="res-multiplier" class="text-xl font-bold text-purple-700">-</div>
          </div>
        </div>

        <!-- Cost Breakdown -->
        <div>
          <h3 class="mb-3 text-sm font-semibold text-gray-700">รายละเอียดต้นทุนค่าจ้าง</h3>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">เงินเดือนพื้นฐาน</span>
              <span id="res-salary" class="font-medium">-</span>
            </div>
            <div id="sso-row" class="flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">ประกันสังคม ม.33 (ส่วนนายจ้าง)</span>
              <span id="res-sso" class="font-medium">-</span>
            </div>
            <div id="pvd-row" class="hidden flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">กองทุนสำรองเลี้ยงชีพ (ส่วนนายจ้าง)</span>
              <span id="res-pvd" class="font-medium">-</span>
            </div>
            <div id="health-row" class="hidden flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">ประกันสุขภาพกลุ่ม</span>
              <span id="res-health" class="font-medium">-</span>
            </div>
            <div id="accident-row" class="hidden flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">ประกันอุบัติเหตุกลุ่ม</span>
              <span id="res-accident" class="font-medium">-</span>
            </div>
            <div id="other-row" class="hidden flex justify-between border-b border-gray-100 py-1">
              <span class="text-gray-600">สวัสดิการอื่นๆ</span>
              <span id="res-other" class="font-medium">-</span>
            </div>
            <div class="flex justify-between border-b border-gray-100 py-1">
              <span class="font-medium text-gray-700">สวัสดิการรวม (ส่วนที่เพิ่มจากเงินเดือน)</span>
              <span id="res-total-benefits" class="font-bold text-blue-700">-</span>
            </div>
            <div class="flex justify-between border-t-2 border-gray-300 py-2">
              <span class="font-semibold text-gray-700">ต้นทุนค่าจ้างรวมต่อเดือน</span>
              <span id="res-total-bottom" class="font-bold text-green-700">-</span>
            </div>
          </div>
        </div>

        <!-- Rate Breakdown -->
        <div class="mt-4 rounded-lg bg-gray-50 p-4">
          <h3 class="mb-3 text-sm font-semibold text-gray-700">อัตราต้นทุนต่อหน่วย</h3>
          <div class="grid gap-3 sm:grid-cols-3 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-600">ต่อวัน</span>
              <span id="res-rate-daily" class="font-medium">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">ต่อชั่วโมง</span>
              <span id="res-rate-hourly" class="font-medium">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">ต่อปี</span>
              <span id="res-rate-annual" class="font-medium">-</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#ec-results" />

    <!-- Quick Reference Table -->
    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">ตารางต้นทุนค่าจ้างพนักงาน (ตัวอย่าง)</h2>
      <p class="mb-3 text-sm text-gray-600">ประมาณการ: ประกันสังคม + กองทุน 5% + ประกันกลุ่ม 1,000 บาท</p>
      <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="px-4 py-3 text-right font-semibold text-gray-700">เงินเดือน</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">ประกันสังคม</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">กองทุน 5%</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">ต้นทุนรวม/เดือน</th>
              <th class="px-4 py-3 text-right font-semibold text-gray-700">ตัวคูณ</th>
            </tr>
          </thead>
          <tbody>
            {[10000, 15000, 20000, 25000, 30000, 40000, 50000, 60000, 80000, 100000].map((salary) => {
              const ssoBase = Math.max(1650, Math.min(salary, 15000));
              const sso = Math.round(ssoBase * 0.05 * 100) / 100;
              const pvd = Math.round(salary * 0.05 * 100) / 100;
              const insurance = 1000;
              const total = salary + sso + pvd + insurance;
              const multiplier = total / salary;
              return (
                <tr class="border-b border-gray-100 hover:bg-gray-50">
                  <td class="px-4 py-3 text-right font-medium text-gray-900">
                    {new Intl.NumberFormat('th-TH').format(salary)}
                  </td>
                  <td class="px-4 py-3 text-right text-gray-700">
                    {new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(sso)}
                  </td>
                  <td class="px-4 py-3 text-right text-gray-700">
                    {new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(pvd)}
                  </td>
                  <td class="px-4 py-3 text-right font-medium text-green-700">
                    {new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(total)}
                  </td>
                  <td class="px-4 py-3 text-right text-gray-700">
                    ×{multiplier.toFixed(2)}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#ec-results" />

    <!-- Formula Section -->
    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่เครื่องมือนี้ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ต้นทุนค่าจ้างรวม = เงินเดือน + ประกันสังคม(นายจ้าง) + กองทุนสำรองฯ(นายจ้าง) + ประกันกลุ่ม + สวัสดิการอื่นๆ</li>
        <li>ประกันสังคม ม.33 (ส่วนนายจ้าง) = 5% ของเงินเดือน (ฐาน 1,650-15,000 บาท สูงสุด 750 บาท)</li>
        <li>กองทุนสำรองเลี้ยงชีพ (ส่วนนายจ้าง) = เงินเดือน × อัตราสมทบ% (2-15%)</li>
        <li>ตัวคูณต้นทุน = ต้นทุนรวม ÷ เงินเดือน</li>
        <li>ต้นทุนรายวัน = ต้นทุนรวม ÷ วันทำงานต่อเดือน</li>
        <li>ต้นทุนรายชั่วโมง = ต้นทุนรายวัน ÷ 8 ชั่วโมง</li>
        <li>ต้นทุนรายปี = ต้นทุนรวม × 12 เดือน</li>
      </ul>

      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ตัวอย่าง</h3>
      <p>
        พนักงานเงินเดือน 25,000 บาท นายจ้างจัดให้กองทุนสำรอง 5% ประกันกลุ่ม 1,000 บาท
      </p>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ประกันสังคม (นายจ้าง) = 15,000 × 5% = 750 บาท (เต็มเพดาน)</li>
        <li>กองทุนสำรอง (นายจ้าง) = 25,000 × 5% = 1,250 บาท</li>
        <li>ประกันกลุ่ม = 1,000 บาท</li>
        <li>ต้นทุนรวม = 25,000 + 750 + 1,250 + 1,000 = 28,000 บาท/เดือน</li>
        <li>ตัวคูณ = 28,000 ÷ 25,000 = ×1.12</li>
        <li>ต้นทุนรายปี = 28,000 × 12 = 336,000 บาท</li>
      </ul>

      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">แหล่งอ้างอิงทางการ</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="https://www.sso.go.th/wpr/main/privilege/%E0%B8%AA%E0%B8%B4%E0%B8%97%E0%B8%98%E0%B8%9B%E0%B8%A3%E0%B8%B0%E0%B9%82%E0%B8%A2%E0%B8%8A%E0%B8%99%E0%B9%8C_sub_category_1_1_1/info/436" target="_blank" rel="noopener noreferrer">สำนักงานประกันสังคม: อัตราเงินสมทบ มาตรา 33</a></li>
        <li><a href="https://www.thaipvd.com/" target="_blank" rel="noopener noreferrer">สมาคมกองทุนสำรองเลี้ยงชีพ: ข้อมูลกองทุนสำรองเลี้ยงชีพ</a></li>
      </ul>
    </section>

    <!-- Related Calculators -->
    <RelatedArticles currentHref="/คำนวณค่าจ้างพนักงาน/" />
    <RelatedCalculators currentHref="/คำนวณค่าจ้างพนักงาน/" />

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Disclaimer -->
    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการเบื้องต้น ต้นทุนจริงอาจแตกต่างตามนโยบายบริษัท
      อัตราประกันสังคมเป็นตาม พ.ร.บ. ประกันสังคม ม.33 ณ ปี 2569 กองทุนสำรองเลี้ยงชีพขึ้นอยู่กับข้อบังคับของแต่ละกองทุน
      กรุณาตรวจสอบกับฝ่ายบุคคลหรือที่ปรึกษาด้านแรงงาน
    </div>
  </article>

  <script type="module">
    import { calculateEmployeeCost } from '../../lib/employee-cost-calculator.ts';

    function parseNum(value) {
      const normalized = String(value).replace(/,/g, '').trim();
      if (normalized === '') return NaN;
      const num = Number(normalized);
      return Number.isFinite(num) ? num : NaN;
    }

    function formatMoney(num) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(num)} บาท`;
    }

    const form = document.getElementById('ec-form');
    const formError = document.getElementById('ec-form-error');
    const resultBox = document.getElementById('ec-results');
    const includePvdCheckbox = document.getElementById('include-pvd');
    const pvdFields = document.getElementById('pvd-fields');

    function clearFieldError(id) {
      const el = document.getElementById(id);
      if (!el) return;
      el.classList.add('hidden');
      el.textContent = '';
    }

    function setFieldError(id, message) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearErrors() {
      formError?.classList.add('hidden');
      clearFieldError('monthly-salary-error');
      clearFieldError('working-days-error');
      clearFieldError('pvd-percent-error');
      clearFieldError('health-insurance-error');
      clearFieldError('accident-insurance-error');
      clearFieldError('other-benefits-error');
    }

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    function showEl(id) {
      const el = document.getElementById(id);
      if (el) el.classList.remove('hidden');
    }

    function hideEl(id) {
      const el = document.getElementById(id);
      if (el) el.classList.add('hidden');
    }

    includePvdCheckbox?.addEventListener('change', () => {
      if (includePvdCheckbox.checked) {
        pvdFields?.classList.remove('hidden');
      } else {
        pvdFields?.classList.add('hidden');
      }
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      clearErrors();

      if (typeof window.trackCalculatorStart === 'function') {
        window.trackCalculatorStart('employee_cost');
      }

      const salary = parseNum(document.getElementById('monthly-salary')?.value || '');
      const workingDays = parseNum(document.getElementById('working-days')?.value || '');
      const includeSso = document.getElementById('include-sso')?.checked || false;
      const includePvd = includePvdCheckbox?.checked || false;
      const pvdPercent = parseNum(document.getElementById('pvd-percent')?.value || '5');
      const healthIns = parseNum(document.getElementById('health-insurance')?.value || '0');
      const accidentIns = parseNum(document.getElementById('accident-insurance')?.value || '0');
      const otherBen = parseNum(document.getElementById('other-benefits')?.value || '0');

      let hasError = false;

      if (!Number.isFinite(salary) || salary <= 0) {
        setFieldError('monthly-salary-error', 'กรุณากรอกเงินเดือนที่ถูกต้อง');
        hasError = true;
      }

      if (!Number.isFinite(workingDays) || workingDays <= 0 || workingDays > 31) {
        setFieldError('working-days-error', 'กรอกวันทำงานต่อเดือนระหว่าง 1 - 31 วัน');
        hasError = true;
      }

      if (includePvd) {
        if (!Number.isFinite(pvdPercent) || pvdPercent < 2 || pvdPercent > 15) {
          setFieldError('pvd-percent-error', 'กรอกอัตราสมทบระหว่าง 2-15%');
          hasError = true;
        }
      }

      if (!Number.isFinite(healthIns) || healthIns < 0) {
        setFieldError('health-insurance-error', 'กรอกจำนวนเงินที่ถูกต้อง');
        hasError = true;
      }

      if (!Number.isFinite(accidentIns) || accidentIns < 0) {
        setFieldError('accident-insurance-error', 'กรอกจำนวนเงินที่ถูกต้อง');
        hasError = true;
      }

      if (!Number.isFinite(otherBen) || otherBen < 0) {
        setFieldError('other-benefits-error', 'กรอกจำนวนเงินที่ถูกต้อง');
        hasError = true;
      }

      if (hasError) {
        formError?.classList.remove('hidden');
        resultBox?.classList.add('hidden');
        return;
      }

      try {
        const result = calculateEmployeeCost({
          monthlySalary: salary,
          workingDaysPerMonth: workingDays,
          includeSocialSecurity: includeSso,
          includeProvidentFund: includePvd,
          providentFundPercent: includePvd ? pvdPercent : 0,
          healthInsurance: healthIns,
          groupAccidentInsurance: accidentIns,
          otherBenefits: otherBen,
        });

        // Summary boxes
        setText('res-total-monthly', formatMoney(result.totalMonthlyCost));
        setText('res-total-annual', formatMoney(result.totalAnnualCost));
        const dailyCost = result.totalMonthlyCost / workingDays;
        setText('res-daily-cost', formatMoney(dailyCost));
        setText('res-multiplier', `×${result.costMultiplier.toFixed(2)}`);

        // Breakdown
        setText('res-salary', formatMoney(result.monthlySalary));

        if (includeSso) {
          setText('res-sso', `+${formatMoney(result.socialSecurityEmployer)}`);
          showEl('sso-row');
        } else {
          hideEl('sso-row');
        }

        if (includePvd && result.providentFundEmployer > 0) {
          setText('res-pvd', `+${formatMoney(result.providentFundEmployer)}`);
          showEl('pvd-row');
        } else {
          hideEl('pvd-row');
        }

        if (result.healthInsurance > 0) {
          setText('res-health', `+${formatMoney(result.healthInsurance)}`);
          showEl('health-row');
        } else {
          hideEl('health-row');
        }

        if (result.groupAccidentInsurance > 0) {
          setText('res-accident', `+${formatMoney(result.groupAccidentInsurance)}`);
          showEl('accident-row');
        } else {
          hideEl('accident-row');
        }

        if (result.otherBenefits > 0) {
          setText('res-other', `+${formatMoney(result.otherBenefits)}`);
          showEl('other-row');
        } else {
          hideEl('other-row');
        }

        setText('res-total-benefits', `+${formatMoney(result.totalBenefits)}`);
        setText('res-total-bottom', formatMoney(result.totalMonthlyCost));

        // Rate breakdown
        setText('res-rate-daily', formatMoney(dailyCost));
        const hourlyCost = dailyCost / 8;
        setText('res-rate-hourly', formatMoney(hourlyCost));
        setText('res-rate-annual', formatMoney(result.totalAnnualCost));

        resultBox?.classList.remove('hidden');
        resultBox?.scrollIntoView({ behavior: 'smooth', block: 'start' });

        if (typeof window.trackCalculatorComplete === 'function') {
          window.trackCalculatorComplete('employee_cost', result.totalMonthlyCost);
        }
      } catch (_error) {
        formError?.classList.remove('hidden');
        resultBox?.classList.add('hidden');
      }
    });
  </script>
</BaseLayout>
