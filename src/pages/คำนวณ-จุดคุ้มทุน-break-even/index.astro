---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณจุดคุ้มทุน Break-even ฟรี 2569 | Calculator Thailand';
const pageDescription = 'คำนวณจุดคุ้มทุน (Break-even Point) จำนวนหน่วยและรายได้ที่คุ้มทุน กำไรส่วนเพิ่ม (Contribution Margin) สำหรับธุรกิจและสตาร์ตอัป ฟรีทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-จุดคุ้มทุน-break-even/`;

const faqData = [
  {
    question: 'จุดคุ้มทุน (Break-even Point) คืออะไร?',
    answer: 'จุดคุ้มทุนคือระดับยอดขายที่รายได้รวมเท่ากับต้นทุนรวม (กำไร = 0) ถ้าขายได้มากกว่าจุดคุ้มทุน ธุรกิจจะมีกำไร ถ้าน้อยกว่าจะขาดทุน ใช้วางแผนการผลิต ตั้งราคา และประเมินความเป็นไปได้ทางธุรกิจ',
  },
  {
    question: 'ต้นทุนคงที่ (Fixed Cost) และต้นทุนแปรผัน (Variable Cost) คืออะไร?',
    answer: 'ต้นทุนคงที่ (Fixed Cost) คือต้นทุนที่ไม่เปลี่ยนแปลงตามปริมาณการผลิต เช่น ค่าเช่า เงินเดือน ค่าประกัน ต้นทุนแปรผัน (Variable Cost) คือต้นทุนที่เพิ่มขึ้นตามปริมาณการผลิต เช่น วัตถุดิบ ค่าแรงตรง ค่าบรรจุภัณฑ์',
  },
  {
    question: 'Contribution Margin คืออะไร?',
    answer: 'Contribution Margin (กำไรส่วนเพิ่ม) = ราคาขาย − ต้นทุนแปรผันต่อหน่วย คือส่วนที่ช่วยครอบคลุมต้นทุนคงที่หลังหักต้นทุนแปรผันแล้ว ยิ่ง CM สูง ยิ่งถึงจุดคุ้มทุนเร็ว CM Ratio = CM ÷ ราคาขาย × 100',
  },
  {
    question: 'จะลดจุดคุ้มทุนได้อย่างไร?',
    answer: 'ลดจุดคุ้มทุนได้โดย: (1) ลดต้นทุนคงที่ เช่น ย้ายออฟฟิศ ลดเงินเดือน (2) ลดต้นทุนแปรผันต่อหน่วย เช่น ต่อรองราคาวัตถุดิบ (3) ขึ้นราคาขาย เพิ่ม Contribution Margin (4) Outsource งานที่มีต้นทุนคงที่สูง',
  },
  {
    question: 'Margin of Safety คืออะไร?',
    answer: 'Margin of Safety คือส่วนต่างระหว่างยอดขายจริงกับยอดขายจุดคุ้มทุน แสดงว่าธุรกิจมีพื้นที่เหลือเท่าไรก่อนขาดทุน สูตร: MOS = (ยอดขายจริง − ยอดขายจุดคุ้มทุน) ÷ ยอดขายจริง × 100 ยิ่ง MOS สูง ธุรกิจยิ่งปลอดภัย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณจุดคุ้มทุน Break-even',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณจุดคุ้มทุน (Break-even Point)',
  description: 'ขั้นตอนการคำนวณจุดคุ้มทุนสำหรับธุรกิจหรือผลิตภัณฑ์',
  step: [
    {
      '@type': 'HowToStep',
      name: 'ระบุต้นทุนคงที่รวม',
      text: 'รวมต้นทุนคงที่ทั้งหมดต่อเดือนหรือต่อปี เช่น ค่าเช่า เงินเดือน ค่าประกัน ค่าเสื่อมราคา',
    },
    {
      '@type': 'HowToStep',
      name: 'ระบุต้นทุนแปรผันต่อหน่วย',
      text: 'คำนวณต้นทุนที่เพิ่มขึ้นต่อหน่วยที่ผลิต เช่น วัตถุดิบ ค่าแรงตรง ค่าบรรจุภัณฑ์',
    },
    {
      '@type': 'HowToStep',
      name: 'กำหนดราคาขายต่อหน่วย',
      text: 'ระบุราคาขายต่อหน่วย ต้องสูงกว่าต้นทุนแปรผันต่อหน่วย มิฉะนั้นไม่สามารถมี Contribution Margin บวก',
    },
    {
      '@type': 'HowToStep',
      name: 'อ่านผลจุดคุ้มทุน',
      text: 'ระบบแสดงจุดคุ้มทุนเป็นหน่วย รายได้ที่คุ้มทุน Contribution Margin และ CM Ratio',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-จุดคุ้มทุน-break-even">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณจุดคุ้มทุน — Break-even Analysis</p>
      <p class="mt-1 text-sm text-slate-700">หน่วยที่คุ้มทุน รายได้คุ้มทุน และ Contribution Margin</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณจุดคุ้มทุน (Break-even Analysis) สำหรับธุรกิจ 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณจุดคุ้มทุนเป็นหน่วยและรายได้ พร้อม Contribution Margin และ CM Ratio สำหรับวางแผนธุรกิจและประเมินความเป็นไปได้
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'กรมพัฒนาธุรกิจการค้า: คู่มือวิเคราะห์ความเป็นไปได้ทางธุรกิจ',
        'สำนักงานส่งเสริมวิสาหกิจขนาดกลางและขนาดย่อม (สสว.): การวางแผนธุรกิจ SME',
      ]}
      assumptions={[
        'จุดคุ้มทุนหน่วย = ต้นทุนคงที่ ÷ (ราคาขาย − ต้นทุนแปรผัน/หน่วย)',
        'จุดคุ้มทุนรายได้ = ต้นทุนคงที่ ÷ CM Ratio',
        'ราคาขายและต้นทุนคงที่ในช่วงที่ระบุ',
      ]}
      references={[
        { label: 'สสว.: คู่มือ SME', href: 'https://www.sme.go.th' },
        { label: 'กรมพัฒนาธุรกิจการค้า', href: 'https://www.dbd.go.th' },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="be-form" class="space-y-5">
        <p id="be-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="be-fixed" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนคงที่รวม (บาท/เดือน)</label>
            <input type="text" id="be-fixed" inputmode="numeric" placeholder="เช่น 50,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            <p class="mt-1 text-xs text-gray-500">ค่าเช่า + เงินเดือน + ค่าประกัน + อื่นๆ</p>
          </div>
          <div>
            <label for="be-variable" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนแปรผันต่อหน่วย (บาท)</label>
            <input type="text" id="be-variable" inputmode="numeric" placeholder="เช่น 80"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            <p class="mt-1 text-xs text-gray-500">วัตถุดิบ + ค่าแรงตรง + บรรจุภัณฑ์</p>
          </div>
          <div>
            <label for="be-price" class="block text-sm font-medium text-gray-700 mb-1">ราคาขายต่อหน่วย (บาท)</label>
            <input type="text" id="be-price" inputmode="numeric" placeholder="เช่น 150"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
        </div>

        <button type="submit" id="be-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณจุดคุ้มทุน
        </button>
      </form>
    </div>

    <div id="be-results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณจุดคุ้มทุน</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">จุดคุ้มทุน (หน่วย)</div>
            <div id="res-be-units" class="text-2xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รายได้คุ้มทุน</div>
            <div id="res-be-revenue" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Contribution Margin/หน่วย</div>
            <div id="res-be-cm" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">CM Ratio</div>
            <div id="res-be-cmr" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ต้นทุนคงที่รวม</span>
            <span id="res-be-fixed" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ต้นทุนแปรผันต่อหน่วย</span>
            <span id="res-be-vc" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ราคาขายต่อหน่วย</span>
            <span id="res-be-price" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#be-results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรและวิธีคำนวณจุดคุ้มทุน</h2>
      <div class="bg-gray-50 rounded-lg p-4 my-4">
        <p class="font-semibold mb-1">สูตรจุดคุ้มทุน:</p>
        <p class="text-sm">จุดคุ้มทุน (หน่วย) = ต้นทุนคงที่ ÷ (ราคาขาย − ต้นทุนแปรผัน/หน่วย)</p>
        <p class="text-sm mt-1">จุดคุ้มทุน (รายได้) = ต้นทุนคงที่ ÷ CM Ratio</p>
        <p class="text-sm mt-1">CM Ratio = (ราคาขาย − ต้นทุนแปรผัน) ÷ ราคาขาย</p>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่าง: ร้านกาแฟ ต้นทุนคงที่ 50,000 บาท ต้นทุนแปรผัน 80 บาท ราคา 150 บาท</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>CM = 150 − 80 = 70 บาท/แก้ว</li>
          <li>CM Ratio = 70 ÷ 150 = 46.67%</li>
          <li>จุดคุ้มทุน = 50,000 ÷ 70 = <strong>714.3 แก้ว/เดือน</strong></li>
          <li>รายได้คุ้มทุน = 50,000 ÷ 0.4667 = <strong>107,143 บาท/เดือน</strong></li>
        </ul>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        <strong>แหล่งอ้างอิง:</strong>
        <a href="https://www.sme.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">สำนักงานส่งเสริมวิสาหกิจขนาดกลางและขนาดย่อม (สสว.)</a>
      </p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณ-จุดคุ้มทุน-break-even/" />
    <RelatedCalculators currentHref="/คำนวณ-จุดคุ้มทุน-break-even/" slugs={['คำนวณ-npv-มูลค่าปัจจุบันสุทธิ', 'คำนวณ-roe-ผลตอบแทนผู้ถือหุ้น', 'คำนวณ-roa-ผลตอบแทนสินทรัพย์']} />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ ตัวเลขจริงอาจแตกต่างตามสภาวะตลาดและการดำเนินธุรกิจจริง
    </div>
  </article>
</BaseLayout>

<script>
  function parseNum(v: string): number {
    return parseFloat(String(v).replace(/,/g, '').trim()) || 0;
  }
  function fmt(n: number): string {
    return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
  }

  const form = document.getElementById('be-form') as HTMLFormElement;
  const formError = document.getElementById('be-form-error') as HTMLElement;
  const resultsDiv = document.getElementById('be-results') as HTMLElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    formError.classList.add('hidden');

    const fixed = parseNum((document.getElementById('be-fixed') as HTMLInputElement).value);
    const variable = parseNum((document.getElementById('be-variable') as HTMLInputElement).value);
    const price = parseNum((document.getElementById('be-price') as HTMLInputElement).value);

    if (fixed <= 0 || price <= 0) {
      formError.classList.remove('hidden');
      formError.textContent = 'กรุณากรอกต้นทุนคงที่และราคาขายให้ถูกต้อง';
      return;
    }
    if (price <= variable) {
      formError.classList.remove('hidden');
      formError.textContent = 'ราคาขายต้องสูงกว่าต้นทุนแปรผันต่อหน่วย มิฉะนั้นไม่มีจุดคุ้มทุน';
      return;
    }

    const cm = price - variable;
    const cmRatio = cm / price;
    const beUnits = fixed / cm;
    const beRevenue = fixed / cmRatio;

    (document.getElementById('res-be-units') as HTMLElement).textContent = Math.ceil(beUnits).toLocaleString('th-TH') + ' หน่วย';
    (document.getElementById('res-be-revenue') as HTMLElement).textContent = fmt(beRevenue) + ' บาท';
    (document.getElementById('res-be-cm') as HTMLElement).textContent = fmt(cm) + ' บาท';
    (document.getElementById('res-be-cmr') as HTMLElement).textContent = (cmRatio * 100).toFixed(2) + '%';
    (document.getElementById('res-be-fixed') as HTMLElement).textContent = fmt(fixed) + ' บาท';
    (document.getElementById('res-be-vc') as HTMLElement).textContent = fmt(variable) + ' บาท';
    (document.getElementById('res-be-price') as HTMLElement).textContent = fmt(price) + ' บาท';

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
