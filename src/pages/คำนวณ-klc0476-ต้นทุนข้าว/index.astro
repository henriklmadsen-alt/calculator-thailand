---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนการปลูกข้าว | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการปลูกข้าวต่อไร่ ค่าเมล็ดพันธุ์ ปุ๋ย ยา แรงงาน เครื่องจักร กำไรต่อฤดูกาล';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0476-ต้นทุนข้าว/`;
const faqData = [
  { question: 'ต้นทุนปลูกข้าวต่อไร่เฉลี่ยเท่าไหร่?', answer: 'ต้นทุนปลูกข้าวนาปีเฉลี่ย 3,500-5,000 บาท/ไร่ ข้าวนาปรัง 4,500-6,500 บาท/ไร่ ขึ้นอยู่กับพื้นที่ ระบบชลประทาน และวิธีการปลูก' },
  { question: 'ราคาข้าวเปลือกปัจจุบันเท่าไหร่?', answer: 'ราคาข้าวเปลือกเจ้าความชื้น 15% ประมาณ 8,000-10,000 บาท/ตัน หรือ 8-10 บาท/กก. ราคาจะผันผวนตามฤดูกาลและนโยบายรัฐ' },
  { question: 'ผลผลิตข้าวต่อไร่เฉลี่ยเท่าไหร่?', answer: 'ผลผลิตข้าวนาปีเฉลี่ย 400-500 กก./ไร่ ข้าวนาปรัง 600-800 กก./ไร่ พันธุ์ปรับปรุงในพื้นที่ชลประทานอาจได้ถึง 900-1,000 กก./ไร่' },
  { question: 'จะลดต้นทุนปลูกข้าวได้อย่างไร?', answer: 'ลดต้นทุนโดยใช้ปุ๋ยตามค่าวิเคราะห์ดิน ใช้เมล็ดพันธุ์ดีจาก กข. รวมกลุ่มเช่าเครื่องจักร ทำนาแปลงใหญ่ และใช้ระบบ GPS ในการพ่นยา' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนการปลูกข้าว">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนการปลูกข้าว</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนและกำไรการปลูกข้าวต่อไร่ต่อฤดูกาล</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="rice_area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่ปลูก (ไร่)</label><input type="number" id="rice_area" min="1" placeholder="เช่น 20" value="20" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="cost_per_rai" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนรวมต่อไร่ (บาท)</label><input type="text" id="cost_per_rai" inputmode="decimal" placeholder="เช่น 4500" value="4500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="yield_per_rai" class="block text-sm font-medium text-gray-700 mb-1">ผลผลิตต่อไร่ (กก.)</label><input type="number" id="yield_per_rai" min="1" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="rice_price_kg" class="block text-sm font-medium text-gray-700 mb-1">ราคาข้าวเปลือก (บาท/กก.)</label><input type="text" id="rice_price_kg" inputmode="decimal" placeholder="เช่น 8.5" value="8.5" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวมทั้งหมด</p><p id="total_cost_rice" class="font-bold">-</p></div>
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้รวม</p><p id="total_revenue_rice" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">กำไร/ขาดทุนฤดูกาล</p><p id="profit_rice" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const area = parseFloat((document.getElementById('rice_area') as HTMLInputElement).value) || 0;
      const costPerRai = parseFloat((document.getElementById('cost_per_rai') as HTMLInputElement).value) || 0;
      const yieldPerRai = parseFloat((document.getElementById('yield_per_rai') as HTMLInputElement).value) || 0;
      const priceKg = parseFloat((document.getElementById('rice_price_kg') as HTMLInputElement).value) || 0;
      const totalCost = area * costPerRai;
      const totalRevenue = area * yieldPerRai * priceKg;
      const profit = totalRevenue - totalCost;
      (document.getElementById('total_cost_rice') as HTMLElement).textContent = Math.round(totalCost).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total_revenue_rice') as HTMLElement).textContent = Math.round(totalRevenue).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('profit_rice') as HTMLElement).textContent = Math.round(profit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('rice-farming-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
