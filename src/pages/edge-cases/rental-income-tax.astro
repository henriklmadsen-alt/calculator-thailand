---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณภาษีค่าเช่า — บ้าน ที่ดิน คอนโด เสียภาษีเท่าไร?';
const pageDescription = 'วิธีคำนวณภาษีค่าเช่า หักค่าใช้จ่ายได้อะไรบ้าง กำไรสุทธิกับอัตราภาษี';
const canonical = `${siteUrl}/edge-cases/rental-income-tax/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: ให้เช่าคอนโดได้ 12,000 บาท/เดือน เสียภาษีเท่าไร?</h1>

    <h2>สถานการณ์</h2>
    <p>คุณมีคอนโด ให้เช่าได้ 12,000 บาท/เดือน (144,000 บาท/ปี) มีรายได้จากเงินเดือนอีก 50,000 บาท/เดือน ต้องจ่ายภาษีเท่าไร?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>ค่าเช่ารวมรายได้:</strong> รวมกับรายได้จากเงินเดือน ต้องคิดภาษีรวมกัน</li>
      <li><strong>หักค่าใช้จ่าย:</strong> ค่าเช่าสามารถหักค่าใช้จ่าย 20% โดยอัตโนมัติ</li>
      <li><strong>หมายเลขประเมิน:</strong> ต้องมีสัญญาเช่า และจดทะเบียนหากเกินเกณฑ์</li>
      <li><strong>ภาษีสิ่งปลูกสร้าง:</strong> หากเช่าคอนโดอาจมีการคำนวณอื่น</li>
    </ul>

    <h2>วิธีคำนวณ</h2>

    <h3>รายได้จากค่าเช่า</h3>

    <ul>
      <li>เช่า: 12,000 บาท × 12 เดือน = 144,000 บาท/ปี</li>
      <li>หักค่าใช้จ่าย 20% (อัตโนมัติ): 144,000 × 20% = 28,800 บาท</li>
      <li><strong>รายได้สุทธิจากค่าเช่า: 115,200 บาท</strong></li>
    </ul>

    <h3>รวมกับรายได้อื่น</h3>

    <ul>
      <li>เงินเดือน: 50,000 × 12 = 600,000 บาท</li>
      <li>ค่าเช่าสุทธิ: 115,200 บาท</li>
      <li><strong>รายได้รวม: 715,200 บาท</strong></li>
      <li>ลดหย่อนพื้นฐาน: 150,000 บาท</li>
      <li><strong>รายได้ที่เสียภาษี: 565,200 บาท</strong></li>
      <li>ภาษี (อัตรา): ประมาณ 60,000-70,000 บาท</li>
    </ul>

    <h2>ค่าใช้จ่ายที่หักได้</h2>

    <h3>วิธี 1: หักอัตโนมัติ 20% (ง่าย ไม่ต้องเก็บเอกสาร)</h3>
    <ul>
      <li>ทุกคนสามารถใช้ได้</li>
      <li>คำนวณโดยอัตโนมัติจาก ธ.ค.ท.</li>
      <li>ไม่ต้องมีใบเสร็จ</li>
    </ul>

    <h3>วิธี 2: หักค่าใช้จ่ายจริง (ต้องเก็บเอกสาร)</h3>
    <ul>
      <li>ค่าซ่อมแซม คอนโด</li>
      <li>ค่าประกันบ้าน</li>
      <li>ค่าภาษีสิ่งปลูกสร้าง</li>
      <li>ค่าสูตรธรรมชาติ (ประมาณ 30% ของค่าเช่า)</li>
      <li>ค่ากำจัดศัตรูพืช น้ำค่า ไฟค่า (ถ้ากำลังออก)</li>
    </ul>

    <h2>ตัวอย่างหักค่าใช้จ่ายจริง</h2>

    <ul>
      <li>เช่า: 144,000 บาท</li>
      <li>ค่าประกัน: 3,000 บาท</li>
      <li>ค่าซ่อมแซม: 5,000 บาท</li>
      <li>ค่าสูตรธรรมชาติ (30%): 43,200 บาท</li>
      <li>รวมค่าใช้จ่าย: 51,200 บาท</li>
      <li><strong>รายได้สุทธิ: 92,800 บาท</strong></li>
    </ul>

    <h2>เลือกวิธีไหน?</h2>

    <ul>
      <li>ถ้าค่าใช้จ่ายจริง &lt; 28,800 บาท → ใช้อัตโนมัติ 20% (ประหยัดกว่า)</li>
      <li>ถ้าค่าใช้จ่ายจริง &gt; 28,800 บาท → หักค่าจริง (ต้องมีใบเสร็จ)</li>
    </ul>

    <h2>สิ่งที่ต้องจำ</h2>

    <ul>
      <li>ต้องมีสัญญาเช่าเป็นหนังสือ</li>
      <li>ต้องยื่น PIT รวมรายได้ค่าเช่าเข้าไป</li>
      <li>หากรายได้เกิน 1,800,000 บาท ต้องจดทะเบียนเป็นธุรกิจ</li>
      <li>เก็บเอกสารค่าใช้จ่าย (ใบเสร็จ ใบเรียกเก็บ) เพื่อสำรอง</li>
    </ul>


    <h2>คำถามที่พบบ่อย (FAQ)</h2>

    <h3>ให้เช่าบ้าน หักค่าใช้จ่าย 20% ต้องเก็บเอกสารไหม?</h3>
    <p>ไม่ต้อง ใช้อัตโนมัติ</p>

  </article>
</BaseLayout>
