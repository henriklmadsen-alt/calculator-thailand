---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณลดหย่อนประกัน — ประกันชีวิต สุขภาพ เสียภาษีลดลงไหม?';
const pageDescription = 'วิธีคำนวณลดหย่อนประกันชีวิต ประกันสุขภาพ ประกันการเดินทาง ประกันอื่นๆ ประหยัดภาษีได้เท่าไร?';
const canonical = `${siteUrl}/edge-cases/insurance-deduction/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: ซื้อประกันชีวิต 60,000 บาท/ปี ประหยัดภาษีได้เท่าไร?</h1>

    <h2>สถานการณ์</h2>
    <p>คุณซื้อประกันชีวิต 60,000 บาท/ปี ประกันสุขภาพ 25,000 บาท/ปี ประกันจักรยานยนต์ 5,000 บาท/ปี ลดหย่อนภาษีได้เท่าไร?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>ลดหย่อนได้ไหม:</strong> ประกันบางประเภท ลดหย่อนได้ บางประเภท ไม่ได้</li>
      <li><strong>ขีดสุดลดหย่อน:</strong> ประกันชีวิต 100,000 บาท แต่ลดหย่อนเพียง 100,000 บาทต่อปี</li>
      <li><strong>ประกันสุขภาพ:</strong> 25,000 บาท/ปี แต่ลดหย่อนเพียง 25,000 บาท</li>
      <li><strong>ประกันอื่น:</strong> ประกันรถ บ้าน ไม่ลดหย่อนภาษี</li>
    </ul>

    <h2>ลดหย่อนได้อะไรบ้าง</h2>

    <h3>✓ ลดหย่อนได้:</h3>
    <ul>
      <li><strong>ประกันชีวิต:</strong> 100,000 บาท/ปี (ขีดสุด)</li>
      <li><strong>ประกันสุขภาพ:</strong> 25,000 บาท/ปี (ของตัวเอง เท่านั้น)</li>
      <li><strong>ประกันสุขภาพของคู่สมรส:</strong> 25,000 บาท/ปี</li>
      <li><strong>ประกันสุขภาพของบุตร:</strong> 25,000 บาท/ปี (ต่อคน)</li>
    </ul>

    <h3>✗ ไม่ลดหย่อน:</h3>
    <ul>
      <li>ประกันจักรยานยนต์</li>
      <li>ประกันบ้าน</li>
      <li>ประกันการเดินทาง</li>
      <li>ประกันวิจัยมะเร็ง (บางประเภท)</li>
    </ul>

    <h2>วิธีคำนวณ</h2>

    <h3>ตัวอย่าง: รายได้ 50,000 บาท/เดือน (600,000 บาท/ปี)</h3>

    <ul>
      <li><strong>เงินเดือน:</strong> 600,000 บาท/ปี</li>
      <li><strong>ประกันชีวิต:</strong> 60,000 บาท (ลดหย่อน 60,000 เพราะ &lt; 100,000)</li>
      <li><strong>ประกันสุขภาพ:</strong> 25,000 บาท (ลดหย่อน 25,000)</li>
      <li><strong>ประกันจักรยานยนต์:</strong> 5,000 บาท (ไม่ลดหย่อน)</li>
    </ul>

    <h3>คำนวณภาษี (ไม่รวมประกัน):</h3>

    <ul>
      <li>รายได้: 600,000 บาท</li>
      <li>ลดหย่อนพื้นฐาน: 150,000 บาท</li>
      <li><strong>รายได้ที่เสียภาษี: 450,000 บาท</strong></li>
      <li>ภาษี (อัตรา): ประมาณ 49,000-54,000 บาท</li>
    </ul>

    <h3>คำนวณภาษี (รวมประกัน):</h3>

    <ul>
      <li>รายได้: 600,000 บาท</li>
      <li>ลดหย่อนพื้นฐาน: 150,000 บาท</li>
      <li>ลดหย่อนประกัน: 85,000 บาท (60,000 + 25,000)</li>
      <li><strong>รายได้ที่เสียภาษี: 365,000 บาท</strong></li>
      <li>ภาษี (อัตรา): ประมาณ 39,000-43,000 บาท</li>
      <li><strong>ประหยัดภาษี: ~10,000 บาท/ปี</strong></li>
    </ul>

    <h2>ข้อสำคัญ</h2>

    <h3>การรักษาพยาบาล (Medical Insurance) ต้อง:</h3>
    <ul>
      <li>เป็นประกันที่ทำให้ได้ลดหย่อน (ตรวจสอบสัญญาประกัน)</li>
      <li>ของตัวเอง คู่สมรส บุตร ที่บุคคลดูแล</li>
      <li>ไม่เกิน 25,000 บาทต่อคน</li>
    </ul>

    <h3>ประกันชีวิต ต้อง:</h3>
    <ul>
      <li>เป็นประกันที่เน้นการคุ้มครอง (ไม่ใช่ลงทุน)</li>
      <li>ของตัวเอง คู่สมรส บุตรที่บุคคลดูแล</li>
      <li>ไม่เกิน 100,000 บาท (รวมทั้งหมด)</li>
    </ul>

    <h2>คำแนะนำ</h2>

    <ul>
      <li>เก็บเอกสาร: ใบเสร็จประกัน, หนังสือสัญญา</li>
      <li>ตรวจสอบ: ประกันนี้ลดหย่อนได้ไหม (อ่านจากสัญญา)</li>
      <li>คำนวณ: ซื้อประกันเท่าไร ลดหย่อนได้เท่าไร</li>
      <li>ยื่น PIT: ระบุจำนวนเบี้ยประกัน และลดหย่อน</li>
    </ul>

  </article>
</BaseLayout>
