---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณค่าจ้างเมื่อทำงานเสาร์-อาทิตย์และวันหยุด — กรณี Part-Time OT';
const pageDescription = 'วิธีคำนวณค่างวดและค่าโอที สำหรับคนทำงาน Part-Time ที่ทำงานวันหยุด เสาร์ อาทิตย์ กับความเสี่ยงภาษีและสัญญาจ้าง';
const canonical = `${siteUrl}/edge-cases/part-time-overtime/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: ทำงาน Part-Time เสาร์-อาทิตย์ โอทีสูง ภาษีเท่าไร?</h1>

    <h2>สถานการณ์</h2>
    <p>คุณทำงาน Part-Time และทำงานเพิ่มเติมเสาร์-อาทิตย์ โอที 2-3 เท่า เงินเดือน + โอทีรวมได้ 30,000 บาท/เดือน ต้องเสียภาษีเท่าไร?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>ภาษีจากทั้ง 2 งาน:</strong> ถ้าทำงาน 2 ที่ โอทีจากอีกที่อาจเป็นรายได้เพิ่มเติม ต้องรายงาน</li>
      <li><strong>ค่าโอทีจากเสาร์-อาทิตย์:</strong> คิดเป็น 1.5 เท่า ไม่ใช่ 2 เท่า หากไม่ใช่วันหยุด</li>
      <li><strong>ความสับสน:</strong> นายจ้างบางคน จ่ายค่าโอที 2-3 เท่า แม้กฎหมายบัญญัติไม่เกินนี้</li>
      <li><strong>หักภาษี ณ ที่จ่าย:</strong> แต่ละที่อาจหักไม่เท่ากัน ต้องคืนตอนยื่นภาษีประจำปี</li>
    </ul>

    <h2>วิธีแก้</h2>

    <h3>1. ตรวจสอบค่าโอทีที่ถูกต้อง</h3>
    <p>กฎหมายแรงงาน ค่าโอที:</p>
    <ul>
      <li>วันธรรมดา: 1.5 เท่าของค่าจ้างวันปกติ</li>
      <li>วันหยุด: 2 เท่า</li>
      <li>วันหยุดแล้วมาทำงาน + โอที: 3 เท่า</li>
    </ul>

    <p>ตรวจสอบว่า นายจ้างจ่ายตามกฎหมายจริง ถ้ามากกว่า อาจเป็นการจ่ายเกินที่บัญญัติ (ซึ่งดี สำหรับคุณ)</p>

    <h3>2. ประกาศรายได้จากทั้ง 2 ที่</h3>
    <p>เมื่อยื่นภาษีประจำปี ต้องระบุรายได้จากทั้ง 2 งาน ไม่ควรปิดบังหนึ่งในนั้น</p>

    <h3>3. คำนวณภาษี</h3>
    <p>สมมติ:</p>
    <ul>
      <li>งาน 1 (Part-Time): 15,000 บาท/เดือน → 180,000 บาท/ปี</li>
      <li>งาน 2 (โอท): 15,000 บาท/เดือน → 180,000 บาท/ปี</li>
      <li><strong>รายได้รวม: 360,000 บาท/ปี</strong></li>
      <li>ลดหย่อน: 150,000 บาท</li>
      <li>รายได้ที่เสียภาษี: 210,000 บาท</li>
      <li>ภาษี (อัตรา): ประมาณ 24,000-28,000 บาท</li>
    </ul>

    <h3>4. ขอคืนเงินภาษี</h3>
    <p>หากหักมากเกินไป (แต่ละที่หัก ไม่รู้ว่ามีรายได้อีกที่) สามารถขอคืนได้ เมื่อยื่นแบบ P.P.P. ประจำปี</p>

    <h2>คำแนะนำ</h2>

    <ul>
      <li>เก็บเอกสารจากทั้ง 2 ที่ (เช็ก ใบรับ)</li>
      <li>ยื่นภาษีตามปกติ ระบุรายได้จากทั้ง 2 แหล่ง</li>
      <li>ถ้ามีสงสัย ปรึกษาสำนักงานเก็บสรรพสามิต</li>
    </ul>

  </article>
</BaseLayout>