---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณภาษีเมื่อมีรายได้หลายแหล่ง — กรณี เงินเดือน + ค่าเช่า + อื่นๆ';
const pageDescription = 'วิธีคำนวณภาษี เมื่อมีรายได้จากเงินเดือน + ค่าเช่าบ้าน + ดอกเบี้ย + เงินปันผล ยืมลดหย่อนอย่างไร?';
const canonical = `${siteUrl}/edge-cases/multiple-income-tax/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: มีรายได้หลายแหล่ง ภาษีคำนวณอย่างไร?</h1>

    <h2>สถานการณ์</h2>
    <p>มีรายได้จาก: เงินเดือน 50,000 บาท + ค่าเช่าบ้าน 30,000 บาท + ดอกเบี้ยเงินฝาก 3,000 บาท ต้องเสียภาษีเท่าไร?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>รายได้แต่ละประเภท:</strong> มีการหักค่าใช้จ่ายต่างกัน</li>
      <li><strong>ลดหย่อนใช้ซ้ำได้ไหม?</strong> ใช่ แต่ต้องคำนวณถูกต้อง</li>
      <li><strong>ภาษีแต่ละแหล่ง:</strong> บ้าน รถ ดอกเบี้ยเงินฝาก มีการหักภาษี ณ ที่จ่ายต่างกัน</li>
      <li><strong>ตั้งแต่ง่ายผิดคำนวณ:</strong> ที่เช่าบ้านสามารถหักค่าใช้จ่าย 20% ได้โดยอัตโนมัติ</li>
    </ul>

    <h2>วิธีคำนวณ</h2>

    <h3>ขั้นตอน 1: รวมรายได้ทั้งหมด</h3>
    <ul>
      <li>เงินเดือน: 50,000 บาท</li>
      <li>ค่าเช่าบ้าน: 30,000 บาท</li>
      <li>ดอกเบี้ยเงินฝาก: 3,000 บาท</li>
      <li><strong>รวม: 83,000 บาท/เดือน → 996,000 บาท/ปี</strong></li>
    </ul>

    <h3>ขั้นตอน 2: หักค่าใช้จ่ายแต่ละรายได้</h3>
    <ul>
      <li><strong>เงินเดือน:</strong> ไม่หักค่าใช้จ่าย (นายจ้างหักภาษีแล้ว)</li>
      <li><strong>ค่าเช่าบ้าน:</strong> สามารถหัก 20% โดยอัตโนมัติ = 30,000 × 20% = 6,000 บาท</li>
      <li><strong>ดอกเบี้ยเงินฝาก:</strong> ไม่มีค่าใช้จ่าย</li>
    </ul>

    <h3>ขั้นตอน 3: คำนวณรายได้สุทธิ</h3>
    <ul>
      <li>600,000 (เงินเดือน ต่อปี) + 24,000 (เช่าสุทธิ) + 36,000 (ดอกเบี้ย ต่อปี) = 660,000 บาท</li>
    </ul>

    <h3>ขั้นตอน 4: หักลดหย่อน</h3>
    <ul>
      <li>ลดหย่อนพื้นฐาน: 150,000 บาท (ใช้ได้ครั้งเดียว ไม่ว่า รายได้กี่แหล่ง)</li>
      <li>ลดหย่อนพิเศษ: ประกันชีวิต 100,000 บาท เป็นต้น</li>
    </ul>

    <h3>ขั้นตอน 5: คำนวณภาษี</h3>
    <ul>
      <li>รายได้สุทธิ - ลดหย่อน = 660,000 - 250,000 = 410,000 บาท</li>
      <li>ตามตารางอัตรา ≈ 50,000-60,000 บาท</li>
    </ul>

    <h2>สิ่งที่ต้องจำ</h2>

    <ul>
      <li>ดอกเบี้ยเงินฝาก: มีการหักภาษี 15% โดยอัตโนมัติแล้ว</li>
      <li>ค่าเช่าบ้าน: ต้องมีสัญญา และสามารถหัก 20% โดยอัตโนมัติ</li>
      <li>ลดหย่อนพื้นฐาน: ใช้ได้เพียงครั้งเดียวต่อปี แม้มีรายได้หลายแหล่ง</li>
      <li>ยื่นภาษี: ต้องระบุรายได้จากทั้งหมด โดยไม่ปิดบังแหล่งใดแหล่งหนึ่ง</li>
    </ul>


    <h2>คำถามที่พบบ่อย (FAQ)</h2>

    <h3>มีรายได้หลายแหล่ง ต้องยื่น PIT กี่ครั้ง?</h3>
    <p>ยื่นครั้งเดียว รวมรายได้ทั้งหมด</p>

  </article>
</BaseLayout>