---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณภาษีจากการขายที่ดิน บ้าน หุ้น — มีภาษีหนึ่งครั้งหรือไม่?';
const pageDescription = 'วิธีคำนวณภาษีการขายที่ดิน บ้าน รถ หุ้น กำไรจากการขาย ต้องจ่ายภาษีเท่าไร?';
const canonical = `${siteUrl}/edge-cases/capital-gains-tax/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: ขายที่ดิน ได้กำไร 500,000 บาท ต้องจ่ายภาษีเท่าไร?</h1>

    <h2>สถานการณ์</h2>
    <p>คุณซื้อที่ดิน 1,000,000 บาท ขายไป 1,500,000 บาท ได้กำไร 500,000 บาท ต้องจ่ายภาษีกำไรทุนเท่าไร?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>ภาษีกำไรทุน:</strong> มีการคำนวณแตกต่างกันตามระยะเวลา</li>
      <li><strong>ระยะเวลากำหนด:</strong> ถ้าถืออยู่ &gt; 5 ปี อัตรา 20% (หรือไม่เสียเลย ในกรณีบ้าน)</li>
      <li><strong>ถ้าถือ &lt; 5 ปี:</strong> คิดเป็นรายได้ปกติ เสียภาษีตามตารา ก้าวหน้า</li>
      <li><strong>อุดหนุน:</strong> บ้านเด่นเมือง อาจไม่มีภาษีกำไรทุน</li>
    </ul>

    <h2>วิธีคำนวณ</h2>

    <h3>ขณะเวลา > 5 ปี (ที่ดิน/หุ้น)</h3>

    <ul>
      <li>กำไรจากการขาย: 500,000 บาท</li>
      <li>ภาษี: 20% = 100,000 บาท</li>
      <li><strong>ได้จริง: 400,000 บาท</strong></li>
    </ul>

    <h3>เมื่อ &lt; 5 ปี (อัตรา ก้าวหน้า)</h3>

    <ul>
      <li>กำไร: 500,000 บาท</li>
      <li>รวมกับรายได้ปกติ (เช่น เงินเดือน): 600,000 บาท</li>
      <li>รวมรายได้: 1,100,000 บาท</li>
      <li>ลดหย่อน: 150,000 บาท</li>
      <li>รายได้ที่เสียภาษี: 950,000 บาท</li>
      <li>ภาษี (อัตรา): ประมาณ 105,000-115,000 บาท</li>
    </ul>

    <h2>กรณีพิเศษ: บ้านเด่นเมือง</h2>

    <h3>บ้านแรกของครอบครัว (ไม่มีภาษีกำไรทุน):</h3>
    <ul>
      <li>ขายบ้านแรกของครอบครัว ไม่มีภาษีกำไรทุน</li>
      <li>แม้กำไรเท่าไรก็ตาม</li>
      <li>เงื่อนไข: เป็นบ้าน สถานที่อยู่อาศัยเท่านั้น</li>
    </ul>

    <h3>บ้านอื่น (มีภาษี):</h3>
    <ul>
      <li>ถูกนับเป็นบ้านอื่นของครอบครัว</li>
      <li>หรือเป็นที่ดิน สำหรับจำหน่าย</li>
      <li>เสียภาษีกำไรทุน</li>
    </ul>

    <h2>ค่าใช้จ่ายที่หักออกจากกำไร</h2>

    <h3>หักได้:</h3>
    <ul>
      <li>ราคาซื้อที่ดิน/บ้าน/หุ้น</li>
      <li>ค่าบัตรประเมิน ค่าจดทะเบียน (ตอนซื้อ)</li>
      <li>ค่าการแต่งสร้างที่เพิ่มมูลค่า (ตัวสร้าง หาก)</li>
    </ul>

    <h3>หักไม่ได้:</h3>
    <ul>
      <li>ค่าบัตรประเมิน ตอนขาย</li>
      <li>ค่า ธ.ก.ส. อยากสำเร็จ</li>
      <li>ค่าใช้จ่ายในการบ้าน (ไฟ น้ำ)</li>
    </ul>

    <h2>กำไรจริง vs กำไรตามกฎหมาย</h2>

    <h3>ตัวอย่าง:</h3>
    <ul>
      <li>ซื้อที่ดิน: 1,000,000 บาท</li>
      <li>ค่า เอกสาร: 5,000 บาท</li>
      <li>ค่า แตงสร้าง บ้าน: 200,000 บาท</li>
      <li><strong>ต้นทุนทั้งสิ้น: 1,205,000 บาท</strong></li>
      <li>ขายเป็น: 1,500,000 บาท</li>
      <li><strong>กำไรจริง: 295,000 บาท</strong></li>
      <li>ภาษี (20%, &gt; 5 ปี): 59,000 บาท</li>
      <li><strong>ได้จริง: 236,000 บาท</strong></li>
    </ul>

    <h2>คำแนะนำ</h2>

    <ul>
      <li>เก็บเอกสาร: ใบสำคัญ ใบแสดงสิทธิ์ ใบเสร็จ</li>
      <li>ตรวจสอบ: เป็นบ้านแรก หรือบ้านอื่น</li>
      <li>คำนวณ: ระยะเวลากำหนด &gt; 5 ปี หรือ &lt; 5 ปี</li>
      <li>ยื่นภาษี: รายงาน ธ.ค.ท. ภายใน 2 เดือนหลังการขาย</li>
    </ul>

  </article>
</BaseLayout>
