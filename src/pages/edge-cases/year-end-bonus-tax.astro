---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณภาษีโบนัส ปลายปี — เสียภาษีเท่าไร?';
const pageDescription = 'วิธีคำนวณภาษีจากโบนัสปลายปี วิธีเก็บเงินให้คุ้ม หักลดหย่อนอะไรได้บ้าง?';
const canonical = `${siteUrl}/edge-cases/year-end-bonus-tax/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: โบนัสปลายปี เสียภาษีเท่าไร? จ่ายหรือเก็บ?</h1>

    <h2>สถานการณ์</h2>
    <p>บริษัทให้โบนัสปลายปี 100,000 บาท เงินเดือนปกติปลายปี 50,000 บาท ต้องจ่ายภาษีเท่าไร? ควรจ่ายหรือเก็บ?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>โบนัสคำนวณไง:</strong> โบนัสเป็นรายได้เพิ่มเติม ถูกหักภาษี ณ ที่จ่ายตามตาราก้าวหน้า</li>
      <li><strong>อัตราหักสูง:</strong> โบนัสมักเสียภาษีสูงกว่าเงินเดือนปกติ (คิดแยก)</li>
      <li><strong>เก็บหรือจ่าย:</strong> ถ้าเก็บเงินสด อาจจ่ายภาษีเพิ่มเติมตอนยื่น PIT</li>
      <li><strong>การบ้านบ้านปลายปี:</strong> ต้องมีการคืนเงินภาษีหรือจ่ายเพิ่มเติม</li>
    </ul>

    <h2>วิธีคำนวณ</h2>

    <h3>ตัวอย่าง: เงินเดือน 50,000 + โบนัส 100,000</h3>

    <ul>
      <li><strong>เงินเดือนเดือนนี้:</strong> 50,000 บาท</li>
      <li>หักภาษี (ประมาณ 10%): 5,000 บาท</li>
      <li>หักประกันสังคม (5%): 2,500 บาท</li>
      <li>ได้จริง: 42,500 บาท</li>
    </ul>

    <h3>โบนัส 100,000 บาท</h3>

    <ul>
      <li><strong>หักภาษี ณ ที่จ่าย:</strong> ประมาณ 15-20% = 15,000-20,000 บาท</li>
      <li>หักประกันสังคม: 5,000 บาท</li>
      <li>ได้จริง: 75,000-80,000 บาท</li>
      <li><strong>รวมเดือนนี้: 117,500-122,500 บาท</strong></li>
    </ul>

    <h2>การคำนวณอัตราหัก</h2>

    <ul>
      <li>หากโบนัส 100,000 บาท หักแยก คิดเป็นรายได้เดือนเดียว</li>
      <li>ธนาคารอาจคิดตามตาราภาษี ก้าวหน้า = 20% (เพราะรวมรายได้เดือนนั้นสูง)</li>
      <li>รวมเดือนนี้: 150,000 บาท → อัตราสูง</li>
    </ul>

    <h2>เก็บเงินโบนัสหรือจ่าย?</h2>

    <h3>ควรจ่ายออกถ้า:</h3>
    <ul>
      <li>ต้องการลดรายได้เดือนนั้น (เพื่อลดอัตราหักภาษี)</li>
      <li>มีภาระหนี้สิน ต้องใช้เงินทำวิทยุ</li>
      <li>ต้องการเก็บเพื่อหมุนตัว ได้ดอกเบี้ย</li>
    </ul>

    <h3>ควรเก็บ ถ้า:</h3>
    <ul>
      <li>มีเงินในบัญชี เพียงพอหรือเกินพอใจแล้ว</li>
      <li>หัก ณ ที่จ่ายสม่ำเสมอ อยู่ในระดับต่ำ (อาจคืนเงินตอนยื่น PIT)</li>
      <li>ต้องการซื้อสิ่งของ ลงทุน ตอนปีหน้า</li>
    </ul>

    <h2>คืนเงินภาษีตอนยื่น PIT</h2>

    <h3>ถ้าหักมากเกินไป:</h3>
    <ul>
      <li>ตอนยื่น PPP ประจำปี ระบุรายได้ทั้งหมด</li>
      <li>ธ.ค.ท. จะคำนวณภาษีจริง แล้วเทียบกับที่หักไว้</li>
      <li>หากหักมากกว่า → คืนเงินเหลือ (ใช้เวลา 1-3 เดือน)</li>
      <li>หากหักน้อยกว่า → ต้องจ่ายเพิ่มเติม</li>
    </ul>

    <h2>คำแนะนำ</h2>

    <ul>
      <li>ประเมิน: ตอนรับโบนัส ต้องจ่ายภาษีเท่าไรแล้ว</li>
      <li>ถ้าหักมากแล้ว อาจเก็บเพื่อใช้ปีหน้า</li>
      <li>ถ้าหักน้อย อาจจ่ายออก เพื่อแบ่งรายได้หลายเดือน</li>
      <li>เก็บเอกสารอย่างนี้: ใบเดือนเงินเดือน + ใบรับโบนัส (สำคัญสำหรับยื่น PIT)</li>
    </ul>


    <h2>คำถามที่พบบ่อย (FAQ)</h2>

    <h3>โบนัสเสียภาษีแยกจากเงินเดือนไหม?</h3>
    <p>ใช่ หักภาษี ณ ที่จ่ายแยก</p>

  </article>
</BaseLayout>
