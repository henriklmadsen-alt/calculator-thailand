---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'กับดัก "ชำระขั้นต่ำ" บัตรเครดิต — ทำไมหนี้ไม่หด?';
const pageDescription = 'วิธีคำนวณว่าชำระขั้นต่ำบัตรเครดิต จะใช้เวลากี่ปีปลดหนี้? และแนวทางออกจากดอกเบี้ยสูง';
const canonical = `${siteUrl}/edge-cases/credit-card-minimum-trap/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: ชำระขั้นต่ำบัตรเครดิต ทำไมหนี้ไม่เคยหด?</h1>

    <h2>สถานการณ์</h2>
    <p>มีหนี้บัตรเครดิต 100,000 บาท อัตรา 15% ต่อปี ชำระขั้นต่ำ 10% (10,000 บาท/เดือน) จะปลดหนี้เมื่อไหร่?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>ดอกเบี้ยสูง:</strong> ดอกเบี้ยเดือนละ ≈ 1,250 บาท</li>
      <li><strong>ชำระขั้นต่ำ:</strong> 10,000 บาท แต่ 1,250 ไปจ่ายดอกเบี้ย เหลือ 8,750 บาท ลดหนี้จริง</li>
      <li><strong>หนี้เทพ:</strong> ยิ่งชำระยิ่งเสียดอกเบี้ย ดูเหมือนหนี้ไม่ลดเลย</li>
      <li><strong>วงจรหนี้:** ตั้งแต่ชำระขั้นต่ำ อาจจะต้องใช้ 10+ ปี ปลดหนี้</li>
    </ul>

    <h2>ตัวอย่างการคำนวณ</h2>

    <h3>หนี้ 100,000 บาท อัตรา 15% ต่อปี</h3>

    <ul>
      <li>เดือน 1: ดอกเบี้ย 1,250 บาท ชำระเพิ่มต้น 8,750 บาท → หนี้เหลือ 91,250 บาท</li>
      <li>เดือน 2: ดอกเบี้ย 1,141 บาท ชำระเพิ่มต้น 8,859 บาท → หนี้เหลือ 82,391 บาท</li>
      <li><strong>...</strong></li>
      <li><strong>เดือนที่ 132 (11 ปี):</strong> ปลดหนี้ - <strong>ชำระทั้งสิ้น ≈ 1,320,000 บาท!</strong></li>
    </ul>

    <h3>สารเปรียบเทียบ: ชำระ 15,000 บาท/เดือน</h3>

    <ul>
      <li>เดือน 1: ดอกเบี้ย 1,250 บาท ชำระต้น 13,750 บาท → หนี้เหลือ 86,250 บาท</li>
      <li><strong>...</strong></li>
      <li><strong>เดือนที่ 7.5 (กว่า 7 เดือน):</strong> ปลดหนี้ - <strong>ชำระทั้งสิ้น ≈ 112,500 บาท</strong></li>
    </ul>

    <h2>เหตุผลความแตกต่าง</h2>

    <ul>
      <li>ชำระ 10,000 บาท: ลดต้น 8,750 บาท/เดือน</li>
      <li>ชำระ 15,000 บาท: ลดต้น 13,750 บาท/เดือน</li>
      <li>ดอกเบี้ยลดลงเร็ว → เวลาปลดหนี้สั้นกว่า → ประหยัดดอกเบี้ยรวม 1.2 ล้านบาท!</li>
    </ul>

    <h2>แนวทางออกจากดอกเบี้ยสูง</h2>

    <h3>ตัวเลือก 1: เพิ่มจำนวนชำระ</h3>
    <ul>
      <li>ยอดใจ: ปลดหนี้เร็ว ประหยัดดอกเบี้ย</li>
      <li>ความยาก: ต้องมีเงินสดมาก</li>
    </ul>

    <h3>ตัวเลือก 2: ยา BFF (หรือสินเชื่อส่วนบุคคล)</h3>
    <ul>
      <li>อัตรา 6-10% ต่อปี (ต่ำกว่าบัตรเครดิต)</li>
      <li>ยอดใจ: ลดอัตรา สามารถปลดหนี้เร็ว</li>
      <li>ความยาก: ต้องขอสินเชื่อใหม่ ต้องผ่านการอนุมัติ</li>
    </ul>

    <h3>ตัวเลือก 3: โปรแกรมปรับหนี้บัตรเครดิต</h3>
    <ul>
      <li>ลดดอกเบี้ยบางส่วน (ธนาคารอาจให้หลาย 0-3% สำหรับลูกค้าเก่า)</li>
      <li>โปรโมชั่น 0% (2-6 เดือน) สำหรับการชำระเพิ่มเติม</li>
      <li>ยอดใจ: ไม่ต้องขอสินเชื่อ</li>
      <li>ความยาก: บางธนาคารไม่ให้ โปรแกรมมีข้อกำหนด</li>
    </ul>

    <h2>คำแนะนำ</h2>

    <ul>
      <li>อย่าพึ่งชำระขั้นต่ำ ถ้าเป็นไปได้</li>
      <li>ตั้งเป้าชำระให้เกินขั้นต่ำ 50% ขึ้นไป เพื่อลดเวลา</li>
      <li>เมื่อมีเงินพิเศษ จ่ายเพิ่มตรงไปที่เงินต้น ไม่ใช่เกิน 1 บาท</li>
      <li>หลีกเลี่ยงการใช้บัตรเครดิตเพิ่มเติม ขณะที่ยังมีหนี้</li>
    </ul>


    <h2>คำถามที่พบบ่อย (FAQ)</h2>

    <h3>ชำระขั้นต่ำแล้ว ทำไมหนี้ไม่ลดเลย?</h3>
    <p>เพราะดอกเบี้ยสูง ส่วนใหญ่ของการชำระไปจ่ายดอกเบี้ย</p>

  </article>
</BaseLayout>