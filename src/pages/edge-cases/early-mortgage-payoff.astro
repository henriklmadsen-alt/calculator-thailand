---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณการชำระเงินกู้ก่อนครบกำหนด — คุ้ม ไหม ใช่ไหม?';
const pageDescription = 'วิธีคำนวณว่าการชำระเงินกู้บ้านก่อนครบสัญญา ประหยัดดอกเบี้ยจริง หรือสูญเสีย?';
const canonical = `${siteUrl}/edge-cases/early-mortgage-payoff/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: จ่ายเงินกู้บ้านก่อนครบสัญญา ประหยัดหรือสูญเสีย?</h1>

    <h2>สถานการณ์</h2>
    <p>กู้บ้าน 2,000,000 บาท 20 ปี อัตรา 4% ต่อปี ได้เงินเพิ่ม 500,000 บาท ควรจ่ายเพิ่มเติมไหม?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>ดอกเบี้ยเหลือจริง:</strong> คำนวณดอกเบี้ยที่จะประหยัดต้องรู้ยอดค้างชำระที่ถูกต้อง</li>
      <li><strong>ค่าปรับทดแทน:</strong> ธนาคารบางแห่งเรียกค่านี้ เมื่อจ่ายเงินกู้ก่อนครบสัญญา</li>
      <li><strong>โอกาสต้นทุนเงิน:</strong> เงิน 500,000 นั้นสามารถนำไปลงทุนหรือใช้จ่ายอย่างอื่นได้</li>
      <li><strong>คิดในวาระยาว:</strong> ดอกเบี้ย 4% อาจต่ำกว่าอัตราเงินเฟ้อ ค่าเงินอาจเสื่อมลง</li>
    </ul>

    <h2>วิธีคำนวณ</h2>

    <h3>ตัวอย่าง: เงินกู้ 2,000,000 บาท</h3>
    <ul>
      <li>ระยะเวลา: 20 ปี (240 เดือน)</li>
      <li>อัตรา: 4% ต่อปี</li>
      <li>ค่างวดเดือนละ: ประมาณ 12,166 บาท</li>
      <li>รวมจ่ายทั้งสิ้น (20 ปี): ≈ 2,920,000 บาท</li>
      <li><strong>ดอกเบี้ยรวม: ≈ 920,000 บาท</strong></li>
    </ul>

    <h3>ถ้าจ่ายเพิ่ม 500,000 บาท ในปีที่ 5:</h3>
    <ul>
      <li>ยอดค้างชำระ: ประมาณ 1,650,000 บาท</li>
      <li>ยอดทั้งหมดจ่ายเพิ่ม: 500,000 บาท</li>
      <li>ดอกเบี้ยลดลง: ≈ 100,000-120,000 บาท (ตรวจสอบกับธนาคาร)</li>
      <li>ค่าปรับทดแทน: ≈ 10,000-20,000 บาท (ตรวจสอบสัญญา)</li>
      <li><strong>ประหยัดสุทธิ: 80,000-110,000 บาท</strong></li>
    </ul>

    <h2>ประเมินว่าคุ้มหรือไม่</h2>

    <h3>ควรจ่ายก่อนครบสัญญา ถ้า:</h3>
    <ul>
      <li>ไม่มีจำเป็นต้องใช้เงินสดในอนาคตอีก</li>
      <li>อัตราดอกเบี้ยสูง (> 5%)</li>
      <li>ธนาคารไม่เรียกค่าปรับทดแทน หรือเรียกน้อย</li>
      <li>ต้องการจิตใจสงบ ไม่ต้องกังวลหนี้สิน</li>
    </ul>

    <h3>ไม่ควรจ่ายก่อนครบสัญญา ถ้า:</h3>
    <ul>
      <li>อัตราดอกเบี้ยต่ำ (3-4%) เทียบกับผลตอบแทนลงทุน</li>
      <li>อาจต้องใช้เงินฉุกเฉิน ใจเย็นเก็บไว้</li>
      <li>สามารถลงทุนเงิน 500,000 ได้ผลตอบแทน > 4%</li>
      <li>ธนาคารเรียกค่าปรับทดแทนสูง</li>
    </ul>

    <h2>คำแนะนำ</h2>

    <ul>
      <li>ตรวจสอบสัญญาเงินกู้: อัตราดอกเบี้ยจริง ค่าปรับทดแทน</li>
      <li>คำนวณหรือขอธนาคารคำนวณดอกเบี้ยที่จะประหยัด</li>
      <li>เปรียบเทียบกับผลตอบแทนลงทุนอื่น</li>
    </ul>


    <h2>คำถามที่พบบ่อย (FAQ)</h2>

    <h3>ชำระเงินกู้ก่อนครบสัญญา ถูกปรับไหม?</h3>
    <p>อาจมี ขึ้นอยู่สัญญา บางธนาคารเรียก prepayment penalty</p>

  </article>
</BaseLayout>