---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณภาษีเมื่อเริ่มธุรกิจ — ต้องจ่ายภาษีทันทีไหม?';
const pageDescription = 'วิธีคำนวณภาษีเมื่อเริ่มธุรกิจ ปีแรก ต้องจดทะเบียน ต้องจ่ายภาษีเท่าไร?';
const canonical = `${siteUrl}/edge-cases/business-startup-tax/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: เริ่มธุรกิจปีแรก ต้องจ่ายภาษีเท่าไร? ต้องจดทะเบียนไหม?</h1>

    <h2>สถานการณ์</h2>
    <p>คุณเลิกงาน เริ่มธุรกิจขายสินค้าออนไลน์ ได้รายได้เดือนแรก 50,000 บาท ต้องจดทะเบียน? ต้องจ่ายภาษีไหม?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>ต้องจดทะเบียน?</strong> ขึ้นอยู่รายได้และประเภทธุรกิจ</li>
      <li><strong>ปีแรก:</strong> ใช้เวลา 6 เดือน ก่อนคิดภาษี (ในบางกรณี)</li>
      <li><strong>ไม่ได้ลาภ:</strong> ปีแรกอาจยังไม่ถึง ต้องจ่ายภาษี</li>
      <li><strong>การสูญเสีย:</strong> ปีแรก ถ้ายัง loss สามารถ carry forward ได้</li>
    </ul>

    <h2>เงื่อนไขจดทะเบียน</h2>

    <h3>ต้องจดทะเบียน ถ้า:</h3>
    <ul>
      <li>รายได้คาดว่า &gt; 1,800,000 บาท/ปี</li>
      <li>ทำธุรกิจประเภท: ร้านค้า ร้านอาหาร บริการ</li>
      <li>มีที่ตั้งสำนักงาน ประจำ</li>
    </ul>

    <h3>ไม่ต้องจดทะเบียน ถ้า:</h3>
    <ul>
      <li>รายได้คาดว่า &lt; 1,800,000 บาท/ปี</li>
      <li>ทำงานฟรีแลนซ์ ขายสินค้าออนไลน์เล็กน้อย</li>
      <li>อยู่บ้าน ไม่มีสำนักงานประจำ</li>
    </ul>

    <h2>วิธีคำนวณ</h2>

    <h3>ตัวอย่าง: ธุรกิจขายสินค้าออนไลน์</h3>

    <h3>ปีแรก (เดือน 1-12):</h3>
    <ul>
      <li>รายได้เดือน 1-3: 50,000 บาท/เดือน = 150,000 บาท</li>
      <li>รายได้เดือน 4-6: 80,000 บาท/เดือน = 240,000 บาท</li>
      <li>รายได้เดือน 7-12: 100,000 บาท/เดือน = 600,000 บาท</li>
      <li><strong>รายได้ปีแรก: 990,000 บาท</strong></li>
    </ul>

    <h3>ค่าใช้จ่าย:</h3>
    <ul>
      <li>ค่าซื้อสินค้า: 400,000 บาท</li>
      <li>ค่าบรรจุภัณฑ์: 50,000 บาท</li>
      <li>ค่าจัดส่ง: 80,000 บาท</li>
      <li>ค่ายื่นโฆษณา ออนไลน์: 60,000 บาท</li>
      <li>ค่าเบี้ยประกัน: 10,000 บาท</li>
      <li><strong>รวมค่าใช้จ่าย: 600,000 บาท</strong></li>
    </ul>

    <h3>กำไรสุทธิ:</h3>
    <ul>
      <li>รายได้: 990,000 บาท</li>
      <li>ค่าใช้จ่าย: 600,000 บาท</li>
      <li><strong>กำไรสุทธิ: 390,000 บาท</strong></li>
      <li>ลดหย่อนพื้นฐาน: 150,000 บาท</li>
      <li><strong>รายได้ที่เสียภาษี: 240,000 บาท</strong></li>
      <li>ภาษี (อัตรา): ประมาณ 27,000-31,000 บาท</li>
    </ul>

    <h2>กรณีพิเศษ: ปีแรก Loss (ขาดทุน)</h2>

    <h3>ถ้ากำไรติดลบ:</h3>
    <ul>
      <li>รายได้: 600,000 บาท</li>
      <li>ค่าใช้จ่าย: 700,000 บาท</li>
      <li><strong>ขาดทุน: 100,000 บาท</strong></li>
      <li>ยื่น PIT: ไม่เสียภาษี</li>
      <li><strong>สามารถหักไปจากกำไรปีถัดไป</strong></li>
    </ul>

    <h2>ช่วงเวลาสำคัญ</h2>

    <h3>ปีแรก (แอกคุณ):</h3>
    <ul>
      <li>เดือน 1-3: เริ่มธุรกิจ ไม่มีภาษีก่อน</li>
      <li>เดือน 4-12: ทำงานมาแล้ว 6+ เดือน คิดภาษี</li>
    </ul>

    <h3>ยื่นภาษี:</h3>
    <ul>
      <li>ส.ค. ของปีที่อนุมัติจดทะเบียน: ยื่นประกาศการณ์รายได้</li>
      <li>เดือน มีนาคม ปีถัดไป: ยื่น PIT/CIT</li>
    </ul>

    <h2>คำแนะนำ</h2>

    <ul>
      <li>เก็บเอกสาร: ใบเสร็จ ใบสั่ง ใบเดินทาง</li>
      <li>บัญชี: ชัดเจน ว่ามาจากไหน ไปไหน</li>
      <li>ต้อนรับสอบสวน: ธ.ค.ท. อาจตรวจสอบปีแรก</li>
      <li>ฝึกบัญชี: ถ้ารายได้มากขึ้น อาจต้องจดทะเบียน</li>
    </ul>


    <h2>คำถามที่พบบ่อย (FAQ)</h2>

    <h3>ปีแรกการทำธุรกิจ ต้องจ่ายภาษีไหม?</h3>
    <p>ขึ้นอยู่กับกำไร ถ้าขาดทุนไม่ต้องจ่าย</p>

  </article>
</BaseLayout>
