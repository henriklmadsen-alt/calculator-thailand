---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณลดหย่อนค่าเลี้ยงดูบุตร — เสียภาษีลดลงไหม?';
const pageDescription = 'วิธีคำนวณลดหย่อนค่าเลี้ยงดูบุตร ค่าอุปการะ บิดา มารดา ประหยัดภาษีได้เท่าไร?';
const canonical = `${siteUrl}/edge-cases/alimony-child-support/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: จ่ายค่าเลี้ยงดูบุตร 30,000 บาท/เดือน ลดหย่อนภาษีได้ไหม?</h1>

    <h2>สถานการณ์</h2>
    <p>คุณหย่าร้าง จ่ายค่าเลี้ยงดูบุตร 30,000 บาท/เดือน (360,000 บาท/ปี) ลดหย่อนภาษีได้ไหม? มีหลักเกณฑ์ไหม?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>ลดหย่อนได้ไหม:</strong> ค่าเลี้ยงดูบุตร สามารถลดหย่อนได้ เมื่อมีคำสั่งศาล</li>
      <li><strong>หลักฐาน:</strong> ต้องมีคำสั่งศาล หรือ สัญญา ที่ยอมรับจากทั้ง 2 ฝ่าย</li>
      <li><strong>จำนวน:</strong> ถ้าจ่ายมากกว่าคำสั่ง ลดหย่อนได้แค่ตามคำสั่ง</li>
      <li><strong>ไม่ต้องเสียภาษี:</strong> เงินที่จ่ายค่าเลี้ยง ไม่เป็นรายได้ของผู้รับ</li>
    </ul>

    <h2>เงื่อนไขลดหย่อน</h2>

    <h3>ต้องมี:</h3>
    <ul>
      <li><strong>คำสั่งศาล:</strong> ศาลอนุญาตให้จ่ายค่าเลี้ยง</li>
      <li><strong>หรือสัญญา:</strong> ทั้งสองฝ่ายตกลง เป็นลายลักษณ์อักษร</li>
      <li><strong>ประมาณการ:</strong> ระบุจำนวนเงินชัดเจน</li>
    </ul>

    <h3>ไม่เสียภาษี:</h3>
    <ul>
      <li>เงินที่จ่ายค่าเลี้ยงบุตร ไม่นับเป็นรายได้ของแม่/บิดา</li>
      <li>เงินดังกล่าว ลดหย่อนได้จากผู้จ่าย (บิดา/แม่อีกคน)</li>
    </ul>

    <h2>วิธีคำนวณ</h2>

    <h3>ตัวอย่าง 1: มีคำสั่งศาล 20,000 บาท/เดือน</h3>

    <ul>
      <li><strong>เงินเดือน:</strong> 50,000 บาท × 12 = 600,000 บาท/ปี</li>
      <li><strong>ค่าเลี้ยงดูบุตร (ตามคำสั่งศาล):</strong> 20,000 × 12 = 240,000 บาท/ปี</li>
      <li><strong>ลดหย่อนค่าเลี้ยง:</strong> 240,000 บาท</li>
      <li>ลดหย่อนพื้นฐาน: 150,000 บาท</li>
      <li><strong>รายได้ที่เสียภาษี: 600,000 - 240,000 - 150,000 = 210,000 บาท</strong></li>
      <li>ภาษี: ประมาณ 24,000 บาท</li>
    </ul>

    <h3>ตัวอย่าง 2: จ่ายจริง 30,000 แต่คำสั่งศาล 20,000</h3>

    <ul>
      <li>จ่ายจริง: 30,000 × 12 = 360,000 บาท</li>
      <li>ลดหย่อนได้เพียง: 240,000 บาท (ตามคำสั่งศาล)</li>
      <li>ส่วนเกิน 10,000 บาท: ไม่ลดหย่อน</li>
      <li><strong>ส่วนเกินนี้ ต้องจ่ายภาษี</strong></li>
    </ul>

    <h2>เงื่อนไขพิเศษ: ค่าอุปการะ บิดา มารดา</h3>

    <h3>ลดหย่อนได้:</h3>
    <ul>
      <li>บิดา มารดา ที่บุคคลดูแล สามารถลดหย่อนได้ 100,000 บาท/ปี</li>
      <li>เงื่อนไข: บิดา มารดา อายุ 60 ปีขึ้นไป หรือพิการ</li>
      <li>คุณต้องเป็นผู้บ้าน และมีหลักฐานการเลี้ยง</li>
    </ul>

    <h3>ตัวอย่าง: เลี้ยงแม่ 60 ปี เดือนละ 10,000 บาท</h3>

    <ul>
      <li><strong>เงินเดือน:</strong> 600,000 บาท/ปี</li>
      <li><strong>ค่าเลี้ยงแม่:</strong> 10,000 × 12 = 120,000 บาท/ปี</li>
      <li><strong>ลดหย่อนค่าเลี้ยง:</strong> 100,000 บาท (ขีดสุด)</li>
      <li>ลดหย่อนพื้นฐาน: 150,000 บาท</li>
      <li><strong>รายได้ที่เสียภาษี: 600,000 - 100,000 - 150,000 = 350,000 บาท</strong></li>
      <li>ภาษี: ประมาณ 39,000 บาท</li>
    </ul>

    <h2>หลักฐานที่จำเป็น</h2>

    <ul>
      <li>คำสั่งศาล (ต้องมีสำเร็จ)</li>
      <li>ใบเสร็จ หรือ ธนาคาร receipt (พิสูจน์การจ่าย)</li>
      <li>บัตรประชาชน บุตร (พิสูจน์เกี่ยว)</li>
      <li>สำเนา ใบสำคัญสิทธิ์บุตร</li>
    </ul>

    <h2>กรณี: ไม่มีคำสั่งศาล</h2>

    <h3>ถ้าไม่มีคำสั่งศาล:</h3>
    <ul>
      <li>ไม่สามารถลดหย่อนค่าเลี้ยงดูบุตร</li>
      <li>แม้จะจ่ายจริง ธ.ค.ท. จะไม่ยอมรับ</li>
      <li>ต้องไปศาล ขออนุมัติหรือบันทึก</li>
    </ul>

    <h2>คำแนะนำ</h2>

    <ul>
      <li>เก็บ: คำสั่งศาล ใบเสร็จ บัญชี ธนาคาร</li>
      <li>ยื่น PIT: ระบุจำนวนค่าเลี้ยงดูบุตร ตามคำสั่งศาล</li>
      <li>อย่างตรวจสอบ: ค่าเลี้ยงต้องไม่เกินคำสั่ง</li>
      <li>ถ้าเพิ่มจำนวน: ต้องเปลี่ยนคำสั่งศาล</li>
    </ul>

  </article>
</BaseLayout>
