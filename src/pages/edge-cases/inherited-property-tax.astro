---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'ภาษีที่ดินสืบทอด — ต้องจ่ายบ้าง? เมื่อไหร่?';
const pageDescription = 'วิธีคำนวณและจ่ายภาษีที่ดินสืบทอด ต้องจ่ายภาษีอากร ภาษีสิ่งปลูกสร้าง ภาษีที่ดินหรือไม่?';
const canonical = `${siteUrl}/edge-cases/inherited-property-tax/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: ได้รับมรดกที่ดินและบ้าน ต้องจ่ายภาษีเท่าไร?</h1>

    <h2>สถานการณ์</h2>
    <p>บิดามารดาเสียชีวิต เหลือที่ดินและบ้านสืบทอดมายังคุณ ต้องจ่ายภาษีอากรหรือภาษีที่ดินไหม?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>ความสับสน:</strong> มีการจ่ายภาษีอากร ภาษีสิ่งปลูกสร้าง ภาษีที่ดิน เวลาต่างกัน</li>
      <li><strong>อากรตราแบบอย่าง:</strong> จ่ายเมื่อจดทะเบียนสืบทอด</li>
      <li><strong>ภาษีสิ่งปลูกสร้าง:</strong> ชำระเมื่อย้ายสิ่งก่อสร้าง (อาจไม่มี ถ้าปล่อยเดิม)</li>
      <li><strong>ภาษีที่ดิน:</strong> จ่ายประจำปี (เช่นเดิม)</li>
    </ul>

    <h2>ส่วนประกอบภาษี</h2>

    <h3>1. อากรตราแบบอย่าง (เมื่อจดทะเบียน)</h3>

    <ul>
      <li>กรณีสืบทอด: 50 บาท + 0.1% ของราคาประเมิน (ในบางจังหวัด 0.5%)</li>
      <li>ตัวอย่าง: ที่ดิน 1,000,000 บาท</li>
      <li>อากร = 50 + 1,000,000 × 0.1% = 50 + 1,000 = <strong>1,050 บาท</strong></li>
    </ul>

    <h3>2. ภาษีสิ่งปลูกสร้าง (ถ้าย้ายสิ่งก่อสร้าง)</h3>

    <ul>
      <li>จ่ายเมื่อถมดิน ย้าย ซ่อมแซม สิ่งก่อสร้าง</li>
      <li>ไม่จ่าย ถ้าปล่อยสิ่งก่อสร้างเดิมไว้</li>
      <li>อัตรา: 3.3% ของมูลค่าสิ่งก่อสร้างที่เปลี่ยนแปลง</li>
    </ul>

    <h3>3. ภาษีที่ดิน (ประจำปี)</h3>

    <ul>
      <li>จ่ายปกติเช่นเดิม ทุกปี</li>
      <li>ไม่เปลี่ยนแปลงเพียงเพราะเป็นมรดก</li>
      <li>อัตรา: 0.02-0.1% ของราคาประเมิน</li>
    </ul>

    <h2>ขั้นตอน</h2>

    <h3>1. ยื่นจดทะเบียนสืบทอด</h3>
    <p>ไปสำนักงานที่ดิน ยื่นเอกสารสืบทอด (ใบสำคัญมรดก และเอกสารอื่นตามที่กำหนด)</p>

    <h3>2. ชำระอากรตราแบบอย่าง</h3>
    <p>ชำระที่สำนักงานที่ดิน ตามจำนวนที่คำนวณข้างต้น</p>

    <h3>3. จดทะเบียนเปลี่ยนชื่อ</h3>
    <p>ธุรการที่สำนักงานที่ดิน รับใบสำคัญสิทธิ์ชื่อใหม่</p>

    <h3>4. ชำระภาษีที่ดินประจำปี</h3>
    <p>ชำระตามปกติถัดจากปีที่จดทะเบียนสืบทอด</p>

    <h2>สิ่งที่ต้องจำ</h2>

    <ul>
      <li>อากรตราแบบอย่างต่ำสุด 50 บาท (แม้ราคาประเมินต่ำ)</li>
      <li>ต้องยื่นจดทะเบียนภายใน 1 ปี นับจากวันพิจารณาคดีหรือวันตายตัว</li>
      <li>สามารถขอผ่อนชำระได้ หากมีความเดือดร้อน</li>
    </ul>

  </article>
</BaseLayout>