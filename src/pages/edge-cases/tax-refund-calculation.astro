---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'คำนวณเงินคืนภาษี — ทำไมบางปีต้องจ่ายเพิ่ม บางปีได้คืน?';
const pageDescription = 'วิธีคำนวณเงินคืนภาษี ทำไมหักมากเกินไป ต้องจ่ายเพิ่ม การดำเนินการขอเงินคืน';
const canonical = `${siteUrl}/edge-cases/tax-refund-calculation/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <article class="prose prose-gray max-w-none">

    <h1>ปัญหา: ยื่น PIT ธ.ค.ท. เมื่อไรถึงคืนเงินให้? ต้องจ่ายเพิ่มเติมไหม?</h1>

    <h2>สถานการณ์</h2>
    <p>ยื่น PIT ปีที่แล้ว นายจ้างหักภาษี 72,000 บาท แต่ตอนคำนวณ พบว่าต้องจ่ายเพียง 60,000 บาท ได้คืน 12,000 บาท เมื่อไร?</p>

    <h2>ปัญหา</h2>

    <ul>
      <li><strong>หักมากเกิน:</strong> นายจ้างหักแบบประมาณ ไม่รู้รายได้อื่น</li>
      <li><strong>เงินคืน:</strong> ธ.ค.ท. ต้องการเวลา 1-3 เดือน ตัดสิน</li>
      <li><strong>ต้องจ่ายเพิ่ม:</strong> หากหักน้อยกว่า ต้องจ่ายส่วนต่าง</li>
      <li><strong>เงินเก็บ:</strong> ต้องรู้เกณฑ์ว่าจะต้องจ่ายหรือคืน</li>
    </ul>

    <h2>วิธีคำนวณ</h2>

    <h3>ตัวอย่าง: เงินเดือน + ค่าเช่า</h3>

    <ul>
      <li><strong>เงินเดือน:</strong> 50,000 × 12 = 600,000 บาท</li>
      <li><strong>ค่าเช่าบ้าน:</strong> 15,000 × 12 = 180,000 บาท (หัก 20% = 144,000 สุทธิ)</li>
      <li><strong>รายได้รวม: 744,000 บาท</strong></li>
      <li><strong>ลดหย่อน: 150,000 บาท</strong></li>
      <li><strong>รายได้ที่เสียภาษี: 594,000 บาท</strong></li>
      <li><strong>ภาษีจริง (อัตรา): ประมาณ 60,000 บาท</strong></li>
    </ul>

    <h3>นายจ้างหักไปเท่าไร:</h3>

    <ul>
      <li>หัก ณ ที่จ่าย เงินเดือน: 72,000 บาท (โดยไม่รู้เรื่องค่าเช่า)</li>
      <li><strong>หักมากเกิน: 72,000 - 60,000 = 12,000 บาท</strong></li>
    </ul>

    <h2>เมื่อไร ธ.ค.ท. จะคืนเงิน</h2>

    <h3>ในปกติ:</h3>
    <ul>
      <li><strong>เดือน มีนาคม:</strong> ยื่น PIT</li>
      <li><strong>เดือน เมษายน:</strong> ธ.ค.ท. คำนวณ ตัดสิน</li>
      <li><strong>เดือน พฤษภาคม-มิถุนายน:</strong> เงินอาจเข้าบัญชี (หรือดำเนิน appeal)</li>
    </ul>

    <h3>บางกรณี อาจช้ากว่า:</h3>
    <ul>
      <li>ธ.ค.ท. ตรวจสอบเอกสาร (ต้องมีหลักฐาน)</li>
      <li>รออนุมัติ (อาจตรวจสอบ 2-3 เดือน)</li>
      <li>โอนเงิน (เข้าบัญชีธนาคาร ในแบบ PIT)</li>
    </ul>

    <h2>กรณี: ต้องจ่ายเพิ่มเติม</h2>

    <h3>ตัวอย่าง: มีรายได้เพิ่มเติม</h3>

    <ul>
      <li><strong>เงินเดือน:</strong> 600,000 บาท</li>
      <li><strong>ค่าเช่าบ้าน:</strong> 144,000 บาท (สุทธิ)</li>
      <li><strong>ดอกเบี้ย:</strong> 20,000 บาท (หัก 15% = 17,000 สุทธิ)</li>
      <li><strong>รายได้รวม: 764,000 บาท</strong></li>
      <li><strong>ลดหย่อน: 150,000 บาท</strong></li>
      <li><strong>รายได้ที่เสียภาษี: 614,000 บาท</strong></li>
      <li><strong>ภาษีจริง: ประมาณ 63,000 บาท</strong></li>
      <li>นายจ้างหัก: 60,000 บาท</li>
      <li><strong>ต้องจ่ายเพิ่ม: 3,000 บาท</strong></li>
    </ul>

    <h2>การดำเนินการยื่นและรอคืนเงิน</h2>

    <h3>ขั้นตอน 1: เก็บเอกสาร</h3>
    <ul>
      <li>ใบเดือนเงินเดือน (ทั้ง 12 เดือน)</li>
      <li>สัญญาเช่า หรือใจเวียน เช่า</li>
      <li>ใบเสร็จค่าเบี้ยประกัน</li>
      <li>บัตรประชาชน หรือหนังสือเดินทาง</li>
    </ul>

    <h3>ขั้นตอน 2: ยื่น PIT</h3>
    <ul>
      <li>ยื่นแบบ PPP (ปกติยื่นที่ ธ.ค.ท.)</li>
      <li>ห้องเก็บสรรพสามิต ตามที่อยู่ หรือ online</li>
    </ul>

    <h3>ขั้นตอน 3: รอการคืนเงิน</h3>
    <ul>
      <li>ติดตามอยู่: สอบถาม ธ.ค.ท. เดือนที่ 2-3</li>
      <li>โอนเงิน: เข้าบัญชีธนาคาร ที่ระบุในแบบ PIT</li>
    </ul>

    <h2>คำแนะนำ</h2>

    <ul>
      <li>เก็บเอกสาร: ใบเดือน สัญญา ใบเสร็จ ทั้ง 5 ปี</li>
      <li>ยื่น PIT: อย่าลืม ต้องยื่นเองถ้านายจ้างไม่ยื่น</li>
      <li>ติดตาม: เช็ก ธ.ค.ท. เดือนที่ 2-3 หลังยื่น</li>
      <li>หากหักลบ: ต้องจ่ายตั้งแต่เดือนมีนาคม (อาจมีดอกเบี้ย)</li>
    </ul>

  </article>
</BaseLayout>
