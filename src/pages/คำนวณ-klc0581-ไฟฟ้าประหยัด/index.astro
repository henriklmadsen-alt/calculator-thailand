---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณ EV vs รถเบนซิน | Kamnuanlek';
const pageDescription = 'เปรียบเทียบต้นทุนซื้อ เชื้อเพลิง ซ่อมบำรุง ประกัน รถไฟฟ้า vs รถเบนซิน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0581-ev-vs-petrol/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ EV vs รถเบนซิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">เปรียบเทียบต้นทุน EV vs รถเบนซิน</h1>
    <div class="mb-4 inline-block rounded-lg border border-cyan-200 bg-cyan-50 px-3 py-2"><p class="text-xs font-semibold text-cyan-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">เปรียบเทียบต้นทุนการใช้ EV vs รถเบนซิน 5 ปี</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="ev_price" class="block text-sm font-medium text-gray-700 mb-1">ราคารถไฟฟ้า (บาท)</label><input type="text" id="ev_price" inputmode="decimal" placeholder="เช่น 1500000" value="1500000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="petrol_price" class="block text-sm font-medium text-gray-700 mb-1">ราคารถเบนซิน (บาท)</label><input type="text" id="petrol_price" inputmode="decimal" placeholder="เช่น 800000" value="800000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="km_per_month" class="block text-sm font-medium text-gray-700 mb-1">ระยะทาง/เดือน (กม.)</label><input type="text" id="km_per_month" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-cyan-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุน EV 5 ปี</p><p id="ev_total" class="font-bold">-</p></div><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนเบนซิน 5 ปี</p><p id="petrol_total" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ประหยัด EV</p><p id="savings" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const ev = parseFloat((document.getElementById('ev_price') as HTMLInputElement).value) || 0;
      const petrol = parseFloat((document.getElementById('petrol_price') as HTMLInputElement).value) || 0;
      const km = parseFloat((document.getElementById('km_per_month') as HTMLInputElement).value) || 0;
      const total_km = km * 12 * 5;
      const ev_fuel = total_km * 1.5, ev_maintain = total_km * 0.3, ev_insure = ev * 0.15 / 5;
      const petrol_fuel = total_km * 0.12 * 40, petrol_maintain = total_km * 0.8, petrol_insure = petrol * 0.15 / 5;
      const ev_total = ev + ev_fuel + ev_maintain + ev_insure;
      const petrol_total = petrol + petrol_fuel + petrol_maintain + petrol_insure;
      const savings = petrol_total - ev_total;
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('ev_total') as HTMLElement).textContent = fmt(ev_total);
      (document.getElementById('petrol_total') as HTMLElement).textContent = fmt(petrol_total);
      (document.getElementById('savings') as HTMLElement).textContent = fmt(Math.max(0, savings));
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('ev-vs-petrol');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
