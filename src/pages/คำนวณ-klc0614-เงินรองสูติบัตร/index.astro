---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณเงินรองสูติบัตร | Kamnuanlek';
const pageDescription = 'คำนวณค่ารองสูติบัตร ค่าจดทะเบียนเด็ก';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0614-เงินรองสูติบัตร/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินรองสูติบัตร">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณเงินรองสูติบัตร</h1>
    <div class="mb-4 inline-block rounded-lg border border-stone-200 bg-stone-50 px-3 py-2"><p class="text-xs font-semibold text-stone-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าจดทะเบียนเด็กแรกเกิด ค่าธรรมเนียมสูติบัตร</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="registration" class="block text-sm font-medium text-gray-700 mb-1">ค่าจดทะเบียนเด็ก (บาท)</label><input type="text" id="registration" inputmode="decimal" placeholder="เช่น 100" value="100" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="birth_cert" class="block text-sm font-medium text-gray-700 mb-1">ค่าสูติบัตร (บาท)</label><input type="text" id="birth_cert" inputmode="decimal" placeholder="เช่น 30" value="30" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="copies" class="block text-sm font-medium text-gray-700 mb-1">จำนวนฉบับที่ต้องการ (ฉบับ)</label><input type="number" id="copies" min="1" max="10" placeholder="เช่น 3" value="3" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="other" class="block text-sm font-medium text-gray-700 mb-1">ค่าอื่นๆ (ธรรมเนียม) (บาท)</label><input type="text" id="other" inputmode="decimal" placeholder="เช่น 50" value="50" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-stone-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-stone-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าสูติบัตรรวม</p>
            <p id="birth_total" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมค่าทั้งหมด</p>
            <p id="total" class="font-bold">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">จดทะเบียนเด็กในเวลากี่วัน?</h3>
            <p class="text-gray-600 text-sm">ตามกฎหมาย ต้องจดทะเบียนภายใน 15 วันนับแต่วันเกิด</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ไม่ทำสูติบัตรจะเกิดอะไรขึ้น?</h3>
            <p class="text-gray-600 text-sm">ได้รับปรับ 5,000-10,000 บาท ไม่สามารถสมัครเรียน ได้รับสิทธิ สำคัญ</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">จดทะเบียนเด็กที่อื่นได้หรือไม่?</h3>
            <p class="text-gray-600 text-sm">ได้ โดยแจ้งไว้กับสำนักทะเบียนที่อื่น แต่ควรแจ้งอำเภอแรกเกิดก่อน</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const registration = parseFloat((document.getElementById('registration') as HTMLInputElement).value) || 0;
      const birthCert = parseFloat((document.getElementById('birth_cert') as HTMLInputElement).value) || 0;
      const copies = parseInt((document.getElementById('copies') as HTMLInputElement).value) || 1;
      const other = parseFloat((document.getElementById('other') as HTMLInputElement).value) || 0;

      const birthTotal = birthCert * copies;
      const total = registration + birthTotal + other;

      (document.getElementById('birth_total') as HTMLElement).textContent = birthTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('birth-registration');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
