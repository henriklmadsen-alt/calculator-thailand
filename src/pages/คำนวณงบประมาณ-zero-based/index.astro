---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณงบประมาณ Zero-Based ปี 2569 ทุกบาทมีที่มาที่ไป รายได้ - รายจ่าย = 0 | Kamnuanlek';
const pageDescription = 'คำนวณงบประมาณแบบ Zero-based budgeting รายได้ลบรายจ่ายทุกหมวดต้องเท่ากับ 0 แสดงสัดส่วน % ต่อรายได้ ตรวจสอบยอดคงเหลือก่อนสิ้นเดือน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบประมาณ-zero-based/`;

const faqData = [
  {
    question: 'Zero-based budgeting คืออะไร?',
    answer: 'Zero-based budgeting คือการวางแผนงบประมาณที่ทุกบาทของรายได้ถูกจัดสรรให้มีจุดประสงค์ รายได้ทั้งหมด - รายจ่ายทุกหมวด (รวมเงินออม) = 0 ทำให้ไม่มีเงินลอยไปโดยไม่รู้จุดหมาย',
  },
  {
    question: 'Zero-based budgeting ต่างจาก 50/30/20 อย่างไร?',
    answer: 'สูตร 50/30/20 แบ่งงบกว้างๆ เป็น 3 กลุ่ม แต่ Zero-based budgeting กำหนดรายละเอียดทุกหมวดย่อย ทำให้มองเห็นว่าเงินไปไหนชัดเจนกว่า เหมาะกับคนที่ต้องการควบคุมค่าใช้จ่ายอย่างละเอียด',
  },
  {
    question: 'ยอดคงเหลือติดลบหมายความว่าอะไร?',
    answer: 'ยอดคงเหลือติดลบหมายความว่าคุณวางแผนใช้จ่ายเกินรายได้ในเดือนนั้น ต้องตัดรายจ่ายบางหมวดออกหรือหาทางเพิ่มรายได้ก่อนเดือนนั้นจะเริ่มต้น',
  },
  {
    question: 'ควรทำ Zero-based budgeting ทุกเดือนไหม?',
    answer: 'แนะนำให้ทำทุกเดือนเพราะค่าใช้จ่ายแต่ละเดือนไม่เท่ากัน เช่น เดือนที่มีวันหยุดยาว มีงานแต่งงาน หรือต้องชำระบิลรายปี ควรวางแผนล่วงหน้าอย่างน้อย 1 สัปดาห์ก่อนต้นเดือน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบประมาณ Zero-Based',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบประมาณ-zero-based">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-emerald-100 bg-emerald-50 p-4">
      <p class="text-sm font-semibold text-emerald-700">คำนวณงบประมาณแบบ Zero-Based — ทุกบาทมีจุดประสงค์</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: รายได้ - (ที่พัก + อาหาร + เดินทาง + สาธารณูปโภค + บันเทิง + ออม + อื่นๆ) = 0</p>
      <p class="mt-1 text-xs font-medium text-emerald-800">ยอดคงเหลือควรเท่ากับ 0 หรือมากกว่า</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณงบประมาณ Zero-Based ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกรายได้และค่าใช้จ่ายแต่ละหมวด ระบบจะแสดงยอดคงเหลือและสัดส่วนต่อรายได้ ปรับจนยอดคงเหลือ = 0
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="zbb-form" class="space-y-5">
        <p id="zbb-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div>
          <label for="zbb-income" class="mb-1 block text-sm font-medium text-gray-700">รายได้รวมต่อเดือน (บาท)</label>
          <input type="text" id="zbb-income" inputmode="numeric" placeholder="เช่น 40,000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:max-w-xs" />
          <p id="zbb-income-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <p class="text-sm font-semibold text-gray-700">รายจ่ายแต่ละหมวด (บาท/เดือน)</p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="zbb-housing" class="mb-1 block text-sm font-medium text-gray-700">ที่พัก / ค่าเช่า / ผ่อนบ้าน</label>
            <input type="text" id="zbb-housing" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="zbb-food" class="mb-1 block text-sm font-medium text-gray-700">อาหาร / เครื่องดื่ม</label>
            <input type="text" id="zbb-food" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="zbb-transport" class="mb-1 block text-sm font-medium text-gray-700">การเดินทาง / น้ำมัน</label>
            <input type="text" id="zbb-transport" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="zbb-utilities" class="mb-1 block text-sm font-medium text-gray-700">สาธารณูปโภค (ไฟ/น้ำ/อินเทอร์เน็ต)</label>
            <input type="text" id="zbb-utilities" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="zbb-entertainment" class="mb-1 block text-sm font-medium text-gray-700">บันเทิง / ช้อปปิ้ง / สังสรรค์</label>
            <input type="text" id="zbb-entertainment" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="zbb-savings" class="mb-1 block text-sm font-medium text-gray-700">เงินออม / ลงทุน / กองทุน</label>
            <input type="text" id="zbb-savings" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="zbb-other" class="mb-1 block text-sm font-medium text-gray-700">อื่นๆ (ประกัน / ค่าบำรุงรักษา)</label>
            <input type="text" id="zbb-other" inputmode="numeric" placeholder="0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณงบประมาณ Zero-Based
        </button>
      </form>
    </div>

    <div id="zbb-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายได้รวม</div>
            <div id="res-zbb-income" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายจ่ายรวม</div>
            <div id="res-zbb-expense" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div id="res-balance-box" class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดคงเหลือ</div>
            <div id="res-zbb-balance" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>

        <p id="res-zbb-status" class="mb-4 rounded-lg p-3 text-sm font-medium"></p>

        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 text-left">
              <th class="px-3 py-2 font-medium text-gray-700">หมวดรายจ่าย</th>
              <th class="px-3 py-2 text-right font-medium text-gray-700">จำนวนเงิน</th>
              <th class="px-3 py-2 text-right font-medium text-gray-700">% ของรายได้</th>
            </tr>
          </thead>
          <tbody id="zbb-table-body" class="divide-y divide-gray-100">
          </tbody>
        </table>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>รายจ่ายรวม = ผลรวมของรายจ่ายทุกหมวด</li>
        <li>ยอดคงเหลือ = รายได้รวม - รายจ่ายรวม</li>
        <li>สัดส่วน % = (รายจ่ายหมวดนั้น ÷ รายได้รวม) × 100</li>
        <li>เป้าหมาย: ยอดคงเหลือ = 0 (หรือจัดสรรส่วนเกินเข้าออม)</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณงบประมาณ-50-30-20/">คำนวณงบประมาณ 50/30/20</a></li>
        <li><a href="/คำนวณงบประมาณครัวเรือน/">คำนวณงบประมาณครัวเรือน</a></li>
        <li><a href="/คำนวณส่วนต่างรายได้รายจ่าย/">คำนวณส่วนต่างรายได้รายจ่าย</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#zbb-results" />
    <RelatedArticles currentHref="/คำนวณงบประมาณ-zero-based/" />
    <RelatedCalculators currentHref="/คำนวณงบประมาณ-zero-based/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการวางแผนงบประมาณเบื้องต้น ค่าใช้จ่ายจริงอาจแตกต่างจากแผน ควรติดตามและปรับแผนทุกเดือน
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '' || s === '0') return 0;
      const n = Number(s);
      return Number.isFinite(n) ? n : 0;
    }
    function parseRequired(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('zbb-form');
    const formError = document.getElementById('zbb-error');
    const resultBox = document.getElementById('zbb-results');

    const categories = [
      { id: 'housing', label: 'ที่พัก / ค่าเช่า / ผ่อนบ้าน' },
      { id: 'food', label: 'อาหาร / เครื่องดื่ม' },
      { id: 'transport', label: 'การเดินทาง / น้ำมัน' },
      { id: 'utilities', label: 'สาธารณูปโภค' },
      { id: 'entertainment', label: 'บันเทิง / ช้อปปิ้ง' },
      { id: 'savings', label: 'เงินออม / ลงทุน' },
      { id: 'other', label: 'อื่นๆ' },
    ];

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      setErr('zbb-income-error', '');

      const income = parseRequired(document.getElementById('zbb-income').value);
      let hasError = false;
      if (!Number.isFinite(income) || income <= 0) {
        setErr('zbb-income-error', 'กรอกรายได้มากกว่า 0');
        hasError = true;
      }
      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      let totalExpense = 0;
      const rows = [];
      for (const cat of categories) {
        const val = parseNum(document.getElementById(`zbb-${cat.id}`)?.value || '0');
        totalExpense += val;
        rows.push({ label: cat.label, amount: val, pct: income > 0 ? (val / income) * 100 : 0 });
      }

      const balance = income - totalExpense;

      setText('res-zbb-income', formatMoney(income));
      setText('res-zbb-expense', formatMoney(totalExpense));
      setText('res-zbb-balance', formatMoney(balance));

      const balanceBox = document.getElementById('res-balance-box');
      const balanceEl = document.getElementById('res-zbb-balance');
      const statusEl = document.getElementById('res-zbb-status');
      if (balance > 0) {
        balanceBox.className = 'rounded-lg bg-amber-50 p-4 text-center';
        balanceEl.className = 'text-xl font-bold text-amber-700';
        statusEl.className = 'mb-4 rounded-lg bg-amber-50 p-3 text-sm font-medium text-amber-800 border border-amber-200';
        statusEl.textContent = `มียอดคงเหลือ ${formatMoney(balance)} — จัดสรรส่วนเกินเข้าหมวดออมหรือกองทุนฉุกเฉินเพื่อให้ยอดเท่ากับ 0`;
      } else if (balance === 0) {
        balanceBox.className = 'rounded-lg bg-green-50 p-4 text-center';
        balanceEl.className = 'text-xl font-bold text-green-700';
        statusEl.className = 'mb-4 rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800 border border-green-200';
        statusEl.textContent = 'ยอดคงเหลือ = 0 สมบูรณ์แบบตามหลัก Zero-Based Budgeting';
      } else {
        balanceBox.className = 'rounded-lg bg-red-50 p-4 text-center';
        balanceEl.className = 'text-xl font-bold text-red-700';
        statusEl.className = 'mb-4 rounded-lg bg-red-50 p-3 text-sm font-medium text-red-800 border border-red-200';
        statusEl.textContent = `รายจ่ายเกินรายได้ ${formatMoney(Math.abs(balance))} — ต้องลดรายจ่ายบางหมวดก่อนสิ้นเดือน`;
      }

      const tbody = document.getElementById('zbb-table-body');
      tbody.innerHTML = rows.map(r => `
        <tr>
          <td class="px-3 py-2 text-gray-700">${r.label}</td>
          <td class="px-3 py-2 text-right font-medium">${formatMoney(r.amount)}</td>
          <td class="px-3 py-2 text-right text-gray-500">${r.pct.toFixed(1)}%</td>
        </tr>
      `).join('') + `
        <tr class="bg-gray-50 font-semibold">
          <td class="px-3 py-2 text-gray-900">รวมรายจ่าย</td>
          <td class="px-3 py-2 text-right text-gray-900">${formatMoney(totalExpense)}</td>
          <td class="px-3 py-2 text-right text-gray-500">${income > 0 ? ((totalExpense / income) * 100).toFixed(1) : 0}%</td>
        </tr>
      `;

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
