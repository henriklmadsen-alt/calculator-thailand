---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณค่าธรรมเนียมโอนเงิน 2569 | พร้อมเพย์ ATM เคาน์เตอร์ BAHTNET | Kamnuanlek';
const pageDescription = 'เปรียบเทียบค่าธรรมเนียมโอนเงินทุกช่องทาง พร้อมเพย์ โมบายแบงก์กิ้ง ATM เคาน์เตอร์ธนาคาร BAHTNET ดูค่าโอนและช่องทางที่ถูกที่สุด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าธรรมเนียมโอนเงิน/`;

const faqData = [
  {
    question: 'โอนเงินผ่านพร้อมเพย์เสียค่าธรรมเนียมไหม?',
    answer: 'ไม่เสียค่าธรรมเนียม ธนาคารแห่งประเทศไทย (ธปท.) กำหนดให้การโอนเงินผ่าน PromptPay ฟรีไม่จำกัดจำนวนเงินและจำนวนครั้ง',
  },
  {
    question: 'โอนเงินข้ามธนาคารผ่านแอปฯ เสียค่าธรรมเนียมหรือไม่?',
    answer: 'ไม่เสียค่าธรรมเนียม ตามนโยบาย ธปท. การโอนเงินข้ามธนาคารผ่านช่องทางดิจิทัล (โมบายแบงก์กิ้ง/อินเทอร์เน็ตแบงก์กิ้ง) เป็นบริการฟรี',
  },
  {
    question: 'โอนเงินผ่าน ATM ข้ามธนาคารค่าธรรมเนียมเท่าไร?',
    answer: 'ค่าธรรมเนียมโอนผ่าน ATM ข้ามธนาคารอยู่ที่ 25 บาท (ไม่เกิน 20,000 บาท) หรือ 35 บาท (20,001-50,000 บาท) ต่อรายการ โดยจำกัดโอนครั้งละไม่เกิน 50,000 บาท',
  },
  {
    question: 'BAHTNET คืออะไร เหมาะกับกรณีไหน?',
    answer: 'BAHTNET เป็นระบบโอนเงินรายใหญ่ของ ธปท. เหมาะสำหรับโอนเงินจำนวนมาก (ตั้งแต่ 2 ล้านบาทขึ้นไป) แบบ real-time โดยค่าธรรมเนียมอยู่ที่ 150-250 บาทต่อรายการ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียมโอนเงิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าธรรมเนียมโอนเงิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">อัปเดตค่าธรรมเนียมโอนเงิน 2569</p>
      <p class="mt-1 text-sm text-slate-700">เปรียบเทียบทุกช่องทาง: พร้อมเพย์ โมบายแบงก์กิ้ง ATM เคาน์เตอร์ BAHTNET</p>
      <p class="mt-1 text-xs font-medium text-sky-800">กรอกจำนวนเงินเพื่อดูค่าธรรมเนียมของแต่ละช่องทางพร้อมกัน</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณค่าธรรมเนียมโอนเงิน ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกจำนวนเงินที่ต้องการโอนเพื่อเปรียบเทียบค่าธรรมเนียมทุกช่องทาง หรือเลือกช่องทางที่ต้องการคำนวณ
    </p>

    <PublicTrustPanel
      lastUpdated="20 เม.ย. 2569"
      sources={[
        'ธนาคารแห่งประเทศไทย (ธปท.): นโยบายยกเว้นค่าธรรมเนียมโอนเงินดิจิทัล',
        'NITMX: อัตราค่าธรรมเนียม ATM ข้ามธนาคาร',
        'อัตราค่าธรรมเนียมเคาน์เตอร์และ BAHTNET อ้างอิงจากธนาคารพาณิชย์ไทยรายใหญ่',
      ]}
      assumptions={[
        'ค่าธรรมเนียมอาจแตกต่างกันตามธนาคารและประเภทบัญชี ผลลัพธ์เป็นอัตราทั่วไป',
        'PromptPay และโมบายแบงก์กิ้งข้ามธนาคาร ฟรีตามนโยบาย ธปท.',
      ]}
      references={[
        {
          label: 'ธปท.: นโยบายค่าธรรมเนียมบริการทางการเงิน',
          href: 'https://www.bot.or.th/th/financial-innovation/digital-finance/e-payment.html',
        },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="transfer-fee-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณากรอกจำนวนเงินที่ต้องการโอน
        </p>

        <div>
          <label for="transfer-amount" class="block text-sm font-medium text-gray-700 mb-1">จำนวนเงินที่ต้องการโอน (บาท)</label>
          <input id="transfer-amount" type="text" inputmode="numeric" placeholder="เช่น 50,000" class="w-full sm:max-w-md rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>

        <div>
          <label for="transfer-channel" class="block text-sm font-medium text-gray-700 mb-1">ช่องทางการโอน</label>
          <select id="transfer-channel" class="w-full sm:max-w-md rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
            <option value="all">เปรียบเทียบทุกช่องทาง</option>
            <option value="promptpay">พร้อมเพย์ (PromptPay)</option>
            <option value="mobile_same_bank">โมบายแบงก์กิ้ง (ภายในธนาคาร)</option>
            <option value="mobile_interbank">โมบายแบงก์กิ้ง (ข้ามธนาคาร)</option>
            <option value="atm_same_bank">ATM (ภายในธนาคาร)</option>
            <option value="atm_interbank">ATM (ข้ามธนาคาร)</option>
            <option value="counter_same_bank">เคาน์เตอร์ธนาคาร (ภายในธนาคาร)</option>
            <option value="counter_interbank">เคาน์เตอร์ธนาคาร (ข้ามธนาคาร)</option>
            <option value="bahtnet">BAHTNET (โอนเงินรายใหญ่)</option>
          </select>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          คำนวณค่าธรรมเนียม
        </button>
      </form>
    </div>

    <!-- Single channel result -->
    <div id="single-result" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณค่าธรรมเนียมโอนเงิน</h2>

        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">จำนวนเงินโอน</div>
            <div id="res-amount" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าธรรมเนียม</div>
            <div id="res-fee" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="rounded-lg bg-emerald-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดรวมทั้งหมด</div>
            <div id="res-total" class="text-xl font-bold text-emerald-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ช่องทาง</span>
            <span id="res-channel" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">หมายเหตุ</span>
            <span id="res-note" class="font-medium text-right max-w-[60%]">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Comparison result -->
    <div id="comparison-result" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">เปรียบเทียบค่าธรรมเนียมทุกช่องทาง</h2>

        <div class="rounded-lg bg-emerald-50 border border-emerald-200 p-3 mb-4">
          <p class="text-sm font-semibold text-emerald-800">ช่องทางที่ถูกที่สุด</p>
          <p id="res-cheapest" class="text-lg font-bold text-emerald-700 mt-1">-</p>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-2 pr-2 font-semibold text-gray-700">ช่องทาง</th>
                <th class="text-right py-2 px-2 font-semibold text-gray-700">ค่าธรรมเนียม</th>
                <th class="text-right py-2 pl-2 font-semibold text-gray-700">ยอดรวม</th>
              </tr>
            </thead>
            <tbody id="comparison-tbody"></tbody>
          </table>
        </div>

        <p class="mt-4 text-xs text-gray-500">
          หมายเหตุ: อัตราค่าธรรมเนียมเป็นอัตราทั่วไป อาจแตกต่างตามธนาคารและประเภทบัญชี
        </p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#comparison-result,#single-result" />

    <section class="mb-8 bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 prose prose-slate max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สรุปค่าธรรมเนียมโอนเงินแต่ละช่องทาง</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>พร้อมเพย์ (PromptPay)</strong> — ฟรีทุกจำนวนเงิน ไม่จำกัดครั้ง (นโยบาย ธปท.)</li>
        <li><strong>โมบายแบงก์กิ้ง (ภายในธนาคาร)</strong> — ฟรี</li>
        <li><strong>โมบายแบงก์กิ้ง (ข้ามธนาคาร)</strong> — ฟรี (นโยบาย ธปท.)</li>
        <li><strong>ATM (ภายในธนาคาร)</strong> — ฟรี</li>
        <li><strong>ATM (ข้ามธนาคาร)</strong> — 25-35 บาท/รายการ (จำกัดครั้งละ 50,000 บาท)</li>
        <li><strong>เคาน์เตอร์ธนาคาร (ภายในธนาคาร)</strong> — ฟรี</li>
        <li><strong>เคาน์เตอร์ธนาคาร (ข้ามธนาคาร)</strong> — 150-200 บาท/รายการ</li>
        <li><strong>BAHTNET</strong> — 150-250 บาท/รายการ (โอนเงินรายใหญ่ real-time)</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#comparison-result,#single-result" />

    <RelatedArticles currentHref="/คำนวณค่าธรรมเนียมโอนเงิน/" />
    <RelatedCalculators currentHref="/คำนวณค่าธรรมเนียมโอนเงิน/" />

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  import { calculateTransferFee, compareAllChannels } from '../../lib/transfer-fee-calculator';
  import type { TransferChannel } from '../../lib/transfer-fee-calculator';

  const form = document.querySelector('#transfer-fee-form');
  const formError = document.querySelector('#form-error');
  const singleResult = document.querySelector('#single-result');
  const comparisonResult = document.querySelector('#comparison-result');

  const amountInput = document.querySelector('#transfer-amount') as HTMLInputElement;
  const channelInput = document.querySelector('#transfer-channel') as HTMLSelectElement;

  function parseNumber(value: string): number {
    if (!value) return NaN;
    return Number(value.replace(/,/g, '').trim());
  }

  function formatCurrency(value: number): string {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(value)} บาท`;
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const amount = parseNumber(amountInput?.value || '');
    const channelValue = channelInput?.value || 'all';

    if (!Number.isFinite(amount) || amount <= 0) {
      formError?.classList.remove('hidden');
      singleResult?.classList.add('hidden');
      comparisonResult?.classList.add('hidden');
      return;
    }

    formError?.classList.add('hidden');

    if (channelValue === 'all') {
      singleResult?.classList.add('hidden');

      const comparison = compareAllChannels(amount);

      const cheapestEl = document.querySelector('#res-cheapest');
      if (cheapestEl) {
        cheapestEl.textContent = `${comparison.cheapest.channelNameTh} — ค่าธรรมเนียม ${formatCurrency(comparison.cheapest.fee)}`;
      }

      const tbody = document.querySelector('#comparison-tbody');
      if (tbody) {
        tbody.innerHTML = comparison.results
          .map((r) => {
            const isCheapest = r.fee === comparison.cheapest.fee;
            const rowClass = isCheapest ? 'bg-emerald-50' : '';
            const badge = isCheapest ? ' <span class="inline-block ml-1 px-1.5 py-0.5 text-xs rounded bg-emerald-100 text-emerald-700 font-semibold">ถูกสุด</span>' : '';
            return `<tr class="border-b border-gray-100 ${rowClass}">
              <td class="py-2 pr-2 text-gray-800">${r.channelNameTh}${badge}</td>
              <td class="py-2 px-2 text-right font-medium ${r.fee === 0 ? 'text-emerald-600' : 'text-gray-900'}">${r.fee === 0 ? 'ฟรี' : formatCurrency(r.fee)}</td>
              <td class="py-2 pl-2 text-right font-medium text-gray-900">${formatCurrency(r.total)}</td>
            </tr>`;
          })
          .join('');
      }

      comparisonResult?.classList.remove('hidden');
      comparisonResult?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
      comparisonResult?.classList.add('hidden');

      const result = calculateTransferFee({ amount, channel: channelValue as TransferChannel });

      const elAmount = document.querySelector('#res-amount');
      const elFee = document.querySelector('#res-fee');
      const elTotal = document.querySelector('#res-total');
      const elChannel = document.querySelector('#res-channel');
      const elNote = document.querySelector('#res-note');

      if (elAmount) elAmount.textContent = formatCurrency(result.amount);
      if (elFee) elFee.textContent = result.fee === 0 ? 'ฟรี' : formatCurrency(result.fee);
      if (elTotal) elTotal.textContent = formatCurrency(result.total);
      if (elChannel) elChannel.textContent = result.channelNameTh;
      if (elNote) elNote.textContent = result.note;

      singleResult?.classList.remove('hidden');
      singleResult?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
</script>
