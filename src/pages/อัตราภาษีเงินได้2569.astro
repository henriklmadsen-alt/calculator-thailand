---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="อัตราภาษีเงินได้บุคคลธรรมดาปี 2569 — ขั้นภาษี ลดหย่อน ค่าใช้จ่าย | Kamnuanlek"
  description="อัตราขั้นภาษีเงินได้บุคคลธรรมดาไทยปี 2569 ตั้งแต่ 0% ถึง 35% สิทธิลดหย่อนส่วนตัว ค่าใช้จ่าย และตัวอย่างการคำนวณภาษีจริง พร้อมเครื่องคำนวณฟรี"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">อัตราขั้นภาษีเงินได้บุคคลธรรมดาไทย ปี 2569</h1>

    <div class="mb-12 p-6 bg-primary-50 border border-primary-200 rounded-lg">
      <p class="text-lg text-gray-800">
        Thailand uses a progressive tax system. The more you earn, the higher the rate on the additional income. This page explains all current tax brackets and allowances.
      </p>
      <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block mt-4 px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-medium">
        Calculate My Income Tax →
      </a>
    </div>

    <div class="space-y-10">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Progressive Tax Rates 2026</h2>
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full">
            <thead class="bg-gradient-to-r from-primary-600 to-primary-700 text-white">
              <tr>
                <th class="text-left px-4 py-3 text-sm font-semibold">Taxable Income (THB)</th>
                <th class="text-left px-4 py-3 text-sm font-semibold">Rate</th>
                <th class="text-left px-4 py-3 text-sm font-semibold">Tax on This Bracket</th>
                <th class="text-left px-4 py-3 text-sm font-semibold">Cumulative Tax</th>
              </tr>
            </thead>
            <tbody>
              {[
                { range: '0 – 150,000', rate: '0%', bracket: '0', cumulative: '0' },
                { range: '150,001 – 300,000', rate: '5%', bracket: '7,500', cumulative: '7,500' },
                { range: '300,001 – 500,000', rate: '10%', bracket: '20,000', cumulative: '27,500' },
                { range: '500,001 – 750,000', rate: '15%', bracket: '37,500', cumulative: '65,000' },
                { range: '750,001 – 1,000,000', rate: '20%', bracket: '50,000', cumulative: '115,000' },
                { range: '1,000,001 – 2,000,000', rate: '25%', bracket: '250,000', cumulative: '365,000' },
                { range: '2,000,001 – 5,000,000', rate: '30%', bracket: '900,000', cumulative: '1,265,000' },
                { range: 'Over 5,000,000', rate: '35%', bracket: 'Variable', cumulative: 'Variable' },
              ].map((row, i) => (
                <tr class={`border-t ${i % 2 === 0 ? '' : 'bg-gray-50'}`}>
                  <td class="px-4 py-3 text-gray-900 font-medium">{row.range}</td>
                  <td class="px-4 py-3 font-bold text-primary-600">{row.rate}</td>
                  <td class="px-4 py-3 text-gray-700">{row.bracket}</td>
                  <td class="px-4 py-3 text-gray-700">{row.cumulative}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-gray-600 text-sm mt-2">* Tax is calculated on taxable income AFTER all allowances and deductions</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Standard Allowances & Deductions</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3">Personal Allowances</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex justify-between"><span>Personal allowance</span><span class="font-semibold">60,000 THB</span></li>
              <li class="flex justify-between"><span>Spouse allowance</span><span class="font-semibold">60,000 THB</span></li>
              <li class="flex justify-between"><span>Each child</span><span class="font-semibold">30,000 THB</span></li>
              <li class="flex justify-between"><span>Each parent (over 60)</span><span class="font-semibold">30,000 THB</span></li>
              <li class="flex justify-between"><span>Disability allowance</span><span class="font-semibold">60,000 THB</span></li>
            </ul>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3">Income Deductions</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex justify-between"><span>Employment income</span><span class="font-semibold">50% (max 100,000)</span></li>
              <li class="flex justify-between"><span>Freelance/service income</span><span class="font-semibold">60% flat rate</span></li>
              <li class="flex justify-between"><span>Rental income</span><span class="font-semibold">30% flat rate</span></li>
              <li class="flex justify-between"><span>Business income</span><span class="font-semibold">Actual or 60%</span></li>
            </ul>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3">Investment Deductions</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex justify-between"><span>RMF contribution</span><span class="font-semibold">Up to 500,000</span></li>
              <li class="flex justify-between"><span>SSF contribution</span><span class="font-semibold">Up to 200,000</span></li>
              <li class="flex justify-between"><span>Life insurance</span><span class="font-semibold">Up to 100,000</span></li>
              <li class="flex justify-between"><span>Health insurance</span><span class="font-semibold">Up to 25,000</span></li>
            </ul>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3">Property & Other Deductions</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex justify-between"><span>Home loan interest</span><span class="font-semibold">Up to 100,000</span></li>
              <li class="flex justify-between"><span>Social security (self)</span><span class="font-semibold">Actual amount</span></li>
              <li class="flex justify-between"><span>Charitable donations</span><span class="font-semibold">2x actual (max 10% income)</span></li>
            </ul>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Quick Tax Estimates</h2>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-white border-b">
                <tr>
                  <th class="text-left px-3 py-2 font-semibold">Annual Salary</th>
                  <th class="text-left px-3 py-2 font-semibold">Employee Deduction</th>
                  <th class="text-left px-3 py-2 font-semibold">Personal Allowance</th>
                  <th class="text-left px-3 py-2 font-semibold">Taxable Income</th>
                  <th class="text-left px-3 py-2 font-semibold">Est. Tax</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { salary: '300,000', deduct: '100,000', allow: '60,000', taxable: '140,000', tax: '0' },
                  { salary: '500,000', deduct: '100,000', allow: '60,000', taxable: '340,000', tax: '~8,500' },
                  { salary: '800,000', deduct: '100,000', allow: '60,000', taxable: '640,000', tax: '~56,500' },
                  { salary: '1,200,000', deduct: '100,000', allow: '60,000', taxable: '1,040,000', tax: '~130,000' },
                  { salary: '2,000,000', deduct: '100,000', allow: '60,000', taxable: '1,840,000', tax: '~340,000' },
                ].map((row, i) => (
                  <tr class={`border-t ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
                    <td class="px-3 py-2 font-semibold text-gray-900">{row.salary}</td>
                    <td class="px-3 py-2 text-gray-600">{row.deduct}</td>
                    <td class="px-3 py-2 text-gray-600">{row.allow}</td>
                    <td class="px-3 py-2 text-gray-700">{row.taxable}</td>
                    <td class="px-3 py-2 font-bold text-primary-600">{row.tax}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-gray-500 text-xs mt-2">Estimates for single employee with no additional deductions. Use calculator for exact amount.</p>
        </div>
      </section>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/วิธีคำนวณภาษีเงินได้ไทย/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📚 Tax Calculation Guide</span>
          <p class="text-gray-600 text-sm mt-2">Step-by-step instructions</p>
        </a>
        <a href="/ตรวจสอบหักลดหย่อนภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">✅ Deductions Checklist</span>
          <p class="text-gray-600 text-sm mt-2">All eligible write-offs</p>
        </a>
        <a href="/ผิดพลาดภาษีทั่วไป/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">❌ Common Mistakes</span>
          <p class="text-gray-600 text-sm mt-2">Avoid overpaying tax</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
