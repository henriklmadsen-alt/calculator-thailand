---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="อัตราภาษีเงินได้บุคคลธรรมดาปี 2569 — ขั้นภาษี ลดหย่อน ค่าใช้จ่าย | Kamnuanlek"
  description="อัตราขั้นภาษีเงินได้บุคคลธรรมดาไทยปี 2569 ตั้งแต่ 0% ถึง 35% สิทธิลดหย่อนส่วนตัว ค่าใช้จ่าย และตัวอย่างการคำนวณภาษีจริง พร้อมเครื่องคำนวณฟรี"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "อัตราภาษีเงินได้บุคคลธรรมดาปี 2569 — ขั้นภาษี ลดหย่อน ค่าใช้จ่าย", "item": "https://www.kamnuanlek.com/อัตราภาษีเงินได้2569/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">อัตราขั้นภาษีเงินได้บุคคลธรรมดาไทย ปี 2569</h1>

    <div class="mb-12 p-6 bg-primary-50 border border-primary-200 rounded-lg">
      <p class="text-lg text-gray-800">
        ไทยใช้ระบบภาษีอัตราก้าวหน้า ยิ่งมีรายได้มากยิ่งเสียภาษีในอัตราที่สูงขึ้นสำหรับรายได้ส่วนเพิ่ม หน้านี้อธิบายอัตราขั้นภาษีและค่าลดหย่อนทั้งหมดที่ใช้ในปัจจุบัน
      </p>
      <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="inline-block mt-4 px-5 py-2.5 bg-primary-600 text-white rounded-lg hover:bg-primary-700 font-medium">
        คำนวณภาษีเงินได้ของฉัน →
      </a>
    </div>

    <div class="space-y-10">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">อัตราภาษีก้าวหน้าปี 2569</h2>
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <table class="w-full">
            <thead class="bg-gradient-to-r from-primary-600 to-primary-700 text-white">
              <tr>
                <th class="text-left px-4 py-3 text-sm font-semibold">รายได้ที่ต้องเสียภาษี (บาท)</th>
                <th class="text-left px-4 py-3 text-sm font-semibold">อัตราภาษี</th>
                <th class="text-left px-4 py-3 text-sm font-semibold">ภาษีในขั้นนี้</th>
                <th class="text-left px-4 py-3 text-sm font-semibold">ภาษีสะสม</th>
              </tr>
            </thead>
            <tbody>
              {[
                { range: '0 – 150,000', rate: '0%', bracket: '0', cumulative: '0' },
                { range: '150,001 – 300,000', rate: '5%', bracket: '7,500', cumulative: '7,500' },
                { range: '300,001 – 500,000', rate: '10%', bracket: '20,000', cumulative: '27,500' },
                { range: '500,001 – 750,000', rate: '15%', bracket: '37,500', cumulative: '65,000' },
                { range: '750,001 – 1,000,000', rate: '20%', bracket: '50,000', cumulative: '115,000' },
                { range: '1,000,001 – 2,000,000', rate: '25%', bracket: '250,000', cumulative: '365,000' },
                { range: '2,000,001 – 5,000,000', rate: '30%', bracket: '900,000', cumulative: '1,265,000' },
                { range: 'เกิน 5,000,000', rate: '35%', bracket: 'ผันแปร', cumulative: 'ผันแปร' },
              ].map((row, i) => (
                <tr class={`border-t ${i % 2 === 0 ? '' : 'bg-gray-50'}`}>
                  <td class="px-4 py-3 text-gray-900 font-medium">{row.range}</td>
                  <td class="px-4 py-3 font-bold text-primary-600">{row.rate}</td>
                  <td class="px-4 py-3 text-gray-700">{row.bracket}</td>
                  <td class="px-4 py-3 text-gray-700">{row.cumulative}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-gray-600 text-sm mt-2">* ภาษีคำนวณจากรายได้ที่ต้องเสียภาษีหลังหักค่าลดหย่อนและค่าใช้จ่ายทั้งหมด</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">ค่าลดหย่อนและค่าใช้จ่ายมาตรฐาน</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3">ค่าลดหย่อนส่วนบุคคล</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex justify-between"><span>ค่าลดหย่อนส่วนตัว</span><span class="font-semibold">60,000 บาท</span></li>
              <li class="flex justify-between"><span>ค่าลดหย่อนคู่สมรส</span><span class="font-semibold">60,000 บาท</span></li>
              <li class="flex justify-between"><span>บุตรแต่ละคน</span><span class="font-semibold">30,000 บาท</span></li>
              <li class="flex justify-between"><span>บิดามารดา (อายุ 60+ ปี) ต่อคน</span><span class="font-semibold">30,000 บาท</span></li>
              <li class="flex justify-between"><span>ค่าลดหย่อนคนพิการ</span><span class="font-semibold">60,000 บาท</span></li>
            </ul>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3">ค่าใช้จ่ายจากรายได้</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex justify-between"><span>รายได้จากการจ้างงาน</span><span class="font-semibold">50% (สูงสุด 100,000)</span></li>
              <li class="flex justify-between"><span>รายได้ฟรีแลนซ์/บริการ</span><span class="font-semibold">60% อัตราคงที่</span></li>
              <li class="flex justify-between"><span>รายได้ค่าเช่า</span><span class="font-semibold">30% อัตราคงที่</span></li>
              <li class="flex justify-between"><span>รายได้ธุรกิจ</span><span class="font-semibold">ตามจริง หรือ 60%</span></li>
            </ul>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3">ค่าลดหย่อนการลงทุน</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex justify-between"><span>เงินสมทบ RMF</span><span class="font-semibold">ไม่เกิน 500,000</span></li>
              <li class="flex justify-between"><span>เงินสมทบ SSF</span><span class="font-semibold">ไม่เกิน 200,000</span></li>
              <li class="flex justify-between"><span>ประกันชีวิต</span><span class="font-semibold">ไม่เกิน 100,000</span></li>
              <li class="flex justify-between"><span>ประกันสุขภาพ</span><span class="font-semibold">ไม่เกิน 25,000</span></li>
            </ul>
          </div>
          <div class="p-5 bg-white border border-gray-200 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3">ค่าลดหย่อนอสังหาฯ และอื่นๆ</h3>
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex justify-between"><span>ดอกเบี้ยสินเชื่อบ้าน</span><span class="font-semibold">ไม่เกิน 100,000</span></li>
              <li class="flex justify-between"><span>ประกันสังคม (ตัวเอง)</span><span class="font-semibold">ตามจริง</span></li>
              <li class="flex justify-between"><span>เงินบริจาคการกุศล</span><span class="font-semibold">2 เท่า (สูงสุด 10% ของรายได้)</span></li>
            </ul>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">ประมาณการภาษีเบื้องต้น</h2>
        <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-white border-b">
                <tr>
                  <th class="text-left px-3 py-2 font-semibold">เงินเดือนต่อปี</th>
                  <th class="text-left px-3 py-2 font-semibold">หักค่าใช้จ่ายพนักงาน</th>
                  <th class="text-left px-3 py-2 font-semibold">ค่าลดหย่อนส่วนตัว</th>
                  <th class="text-left px-3 py-2 font-semibold">รายได้ที่ต้องเสียภาษี</th>
                  <th class="text-left px-3 py-2 font-semibold">ภาษีโดยประมาณ</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { salary: '300,000', deduct: '100,000', allow: '60,000', taxable: '140,000', tax: '0' },
                  { salary: '500,000', deduct: '100,000', allow: '60,000', taxable: '340,000', tax: '~8,500' },
                  { salary: '800,000', deduct: '100,000', allow: '60,000', taxable: '640,000', tax: '~56,500' },
                  { salary: '1,200,000', deduct: '100,000', allow: '60,000', taxable: '1,040,000', tax: '~130,000' },
                  { salary: '2,000,000', deduct: '100,000', allow: '60,000', taxable: '1,840,000', tax: '~340,000' },
                ].map((row, i) => (
                  <tr class={`border-t ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
                    <td class="px-3 py-2 font-semibold text-gray-900">{row.salary}</td>
                    <td class="px-3 py-2 text-gray-600">{row.deduct}</td>
                    <td class="px-3 py-2 text-gray-600">{row.allow}</td>
                    <td class="px-3 py-2 text-gray-700">{row.taxable}</td>
                    <td class="px-3 py-2 font-bold text-primary-600">{row.tax}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-gray-500 text-xs mt-2">ประมาณการสำหรับพนักงานโสดที่ไม่มีค่าลดหย่อนเพิ่มเติม ใช้เครื่องคำนวณสำหรับตัวเลขที่แน่นอน</p>
        </div>
      </section>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/วิธีคำนวณภาษีเงินได้ไทย/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📚 คู่มือคำนวณภาษี</span>
          <p class="text-gray-600 text-sm mt-2">คำแนะนำทีละขั้นตอน</p>
        </a>
        <a href="/ตรวจสอบหักลดหย่อนภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">✅ เช็กลิสต์ลดหย่อน</span>
          <p class="text-gray-600 text-sm mt-2">ค่าลดหย่อนที่มีสิทธิ์ทั้งหมด</p>
        </a>
        <a href="/ผิดพลาดภาษีทั่วไป/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">❌ ข้อผิดพลาดที่พบบ่อย</span>
          <p class="text-gray-600 text-sm mt-2">หลีกเลี่ยงการเสียภาษีเกิน</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
