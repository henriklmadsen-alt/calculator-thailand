---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณวางแผนภาษีปลายปี 2569 | ซื้อ SSF/RMF/ประกันเพิ่มเท่าไร | Kamnuanlek';
const pageDescription = 'คำนวณว่าต้องซื้อ SSF, RMF หรือประกันชีวิตเพิ่มเท่าไรก่อน 31 ธ.ค. เพื่อลดภาษีให้เหลือน้อยที่สุด พร้อมแสดงจำนวนเงินที่ประหยัดได้ ปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณวางแผนภาษีปลายปี/`;

const faqData = [
  {
    question: 'ควรซื้อ SSF หรือ RMF ดีกว่ากัน?',
    answer: 'SSF เหมาะสำหรับผู้ที่ต้องการความยืดหยุ่น (ถือขั้นต่ำ 10 ปีนับจากวันซื้อ) ส่วน RMF เหมาะสำหรับการออมเกษียณ (ถือจนอายุ 55 ปี และต้องซื้อต่อเนื่อง) ทั้งคู่ลดหย่อนได้ 30% ของรายได้',
  },
  {
    question: 'ซื้อ SSF ได้ถึงวันใด?',
    answer: 'ต้องซื้อและชำระเงินให้เสร็จสิ้นภายในวันที่ 31 ธันวาคมของปีภาษีนั้น เพื่อนำมาใช้ลดหย่อนในปีนั้น ไม่มีกำหนดขั้นต่ำต่อปี',
  },
  {
    question: 'ประกันชีวิตและ SSF ลดหย่อนรวมกันได้เท่าไร?',
    answer: 'ประกันชีวิตลดหย่อนได้สูงสุด 100,000 บาท SSF ลดหย่อนได้สูงสุด 200,000 บาท (30% ของรายได้) ทั้งสองประเภทลดหย่อนแยกกัน ไม่รวมเพดาน',
  },
  {
    question: 'ถ้าซื้อ SSF แล้วขาดทุน ยังลดหย่อนได้ไหม?',
    answer: 'ได้ เพราะสิทธิ์ลดหย่อนคำนวณจากจำนวนเงินที่ลงทุน ไม่ใช่มูลค่าตลาด แต่ถ้าขายก่อนครบกำหนดจะเสียสิทธิ์และต้องคืนภาษีส่วนที่ได้ลดหย่อนไป',
  },
  {
    question: 'หากรายได้ไม่ถึงเพดานภาษี ควรซื้อ SSF ไหม?',
    answer: 'ถ้ารายได้สุทธิหลังลดหย่อนแล้วอยู่ในขั้น 0% (ไม่เกิน 150,000 บาท) การซื้อ SSF เพิ่มจะไม่ช่วยลดภาษีแต่ยังเป็นการออมระยะยาวที่ดี',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณวางแผนภาษีปลายปี 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "วิธีวางแผนภาษีปลายปี (Year-End Tax Planning) ปี 2569",
  "description": "ขั้นตอนการวางแผนภาษีปลายปีอย่างถูกต้อง เพื่อลดอัตราการเสียภาษีด้วยวิธีการที่ถูกกฎหมาย ตามพระราชกฤษฎีกาของกรมสรรพากร",
  "step": [
    {"@type": "HowToStep", "name": "รวมรายได้ทั้งหมด", "text": "บันทึกรายได้ทั้งหมด: (1) เงินเดือนจากนายจ้าง, (2) รายได้ประเภทอื่น (ดอกเบี้ย, ปันผล, เช่า, ค่าจ้าง), (3) กำไรจากการขายสินทรัพย์"},
    {"@type": "HowToStep", "name": "ตรวจสอบสิทธิลดหย่อน", "text": "สิทธิลดหย่อน: ส่วนตัว 60,000, คู่สมรส 60,000, บุตร 30,000×จำนวน, ประกันสังคม 9,000, เบี้ยประกันชีวิต 100,000 (สูงสุด), กองทุนสำรองเลี้ยงชีพ 500,000 (สูงสุด), ดอกเบี้ยบ้าน 100,000 (สูงสุด)"},
    {"@type": "HowToStep", "name": "คำนวณรายได้ที่ต้องเสียภาษีชั่วคราว", "text": "รายได้ที่ต้องเสียภาษี = รายได้รวม - ลดหย่อนทั้งหมด คำนวณภาษีตามอัตราขั้นบันได เพื่อดูว่าต้องเสียเท่าไร"},
    {"@type": "HowToStep", "name": "พิจารณาการออมเงินเพิ่มก่อนสิ้นปี", "text": "ถ้า Taxable Income สูง พิจารณาออมใน: กองทุน SSF/RMF (ลดหย่อนได้ 30% ของรายได้), เบี้ยประกันชีวิต (สูงสุด 100,000 บาท)"},
    {"@type": "HowToStep", "name": "ตัดสินใจว่าจะออมเพิ่มหรือไม่", "text": "เปรียบเทียบ: ถ้าออมเพิ่ม ภาษีลดเท่าไร? ถ้า Taxable Income อยู่ในขั้น 20% ทุก 1,000 บาทที่ออมเพิ่ม ประหยัดภาษี 200 บาท"},
    {"@type": "HowToStep", "name": "วางแผนการยื่นแบบและชำระภาษี", "text": "ยื่นแบบ ภ.ง.ด.90/91 ภายใน 31 มีนาคม ปีถัดไป บันทึกใบเสร็จและใบรับรองต่างๆ ไว้ ชำระภาษีหรือขอรับเงินภาษีคืน"}
  ]
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณวางแผนภาษีปลายปี">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">วางแผนก่อน 31 ธันวาคม</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณว่าต้องซื้อ SSF/RMF/ประกันเพิ่มเท่าไรเพื่อลดภาษี</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณวางแผนภาษีปลายปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกรายได้และลดหย่อนที่มีอยู่ ระบบจะคำนวณว่าต้องซื้อ SSF, RMF หรือประกันเพิ่มเท่าไร
      ก่อนสิ้นปีเพื่อประหยัดภาษีได้มากที่สุด
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ข้อมูลรายได้และลดหย่อนปัจจุบัน</h2>
      <form id="yearend-form" class="space-y-5">
        <div>
          <label for="annual-income" class="block text-sm font-medium text-gray-700 mb-1">รายได้รวมทั้งปี (บาท)</label>
          <input type="text" id="annual-income" inputmode="numeric" placeholder="เช่น 600,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>

        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-3">ค่าลดหย่อนที่มีอยู่แล้ว (ยังไม่รวมส่วนที่จะซื้อเพิ่ม)</legend>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="d-base" class="block text-sm text-gray-700 mb-1">ลดหย่อนพื้นฐาน (ส่วนตัว+ประกันสังคม+อื่นๆ)</label>
              <input type="text" id="d-base" inputmode="numeric" placeholder="69,000" value="69000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            </div>
            <div>
              <label for="d-life-cur" class="block text-sm text-gray-700 mb-1">ประกันชีวิต/สุขภาพที่มีอยู่แล้ว</label>
              <input type="text" id="d-life-cur" inputmode="numeric" placeholder="0"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            </div>
            <div>
              <label for="d-ssf-cur" class="block text-sm text-gray-700 mb-1">SSF ที่ซื้อไปแล้วปีนี้</label>
              <input type="text" id="d-ssf-cur" inputmode="numeric" placeholder="0"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            </div>
            <div>
              <label for="d-rmf-cur" class="block text-sm text-gray-700 mb-1">RMF ที่ซื้อไปแล้วปีนี้</label>
              <input type="text" id="d-rmf-cur" inputmode="numeric" placeholder="0"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            </div>
          </div>
        </fieldset>

        <div>
          <label for="target-tax" class="block text-sm font-medium text-gray-700 mb-1">เป้าหมายภาษีที่ต้องการ (บาท) — ไม่บังคับ</label>
          <input type="text" id="target-tax" inputmode="numeric" placeholder="เช่น 0 หรือปล่อยว่างเพื่อลดสูงสุด"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>

        <button type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณแผนปลายปี
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">แผนการลดหย่อนปลายปี</h2>
        <div class="grid gap-3 sm:grid-cols-2 mb-6">
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ภาษีปัจจุบัน (ก่อนซื้อเพิ่ม)</div>
            <div id="r-before-tax" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ภาษีหลังซื้อเพิ่มตามแผน</div>
            <div id="r-after-tax" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>
        <div id="r-plan" class="space-y-3 mb-4"></div>
        <div class="flex justify-between py-2 border-t border-gray-200 font-bold text-base">
          <span>ประหยัดภาษีรวม</span>
          <span id="r-total-saving" class="text-green-700">-</span>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">กลยุทธ์วางแผนภาษีปลายปี</h2>
      <p>การวางแผนภาษีปลายปีคือการใช้สิทธิ์ลดหย่อนที่เหลืออยู่ให้ครบก่อน 31 ธันวาคม วิธีง่ายที่สุดคือการซื้อ SSF/RMF เพราะลดหย่อนสูงและไม่มีเงื่อนไขพิเศษ</p>
      <h3 class="text-lg font-semibold mt-4 mb-2">เพดานลดหย่อนกองทุนและประกัน ปี 2569</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-3 py-2 text-left border-b">ประเภท</th>
              <th class="px-3 py-2 text-right border-b">เพดานสูงสุด</th>
            </tr>
          </thead>
          <tbody>
            <tr><td class="px-3 py-2 border-b">SSF</td><td class="px-3 py-2 text-right border-b">30% ของรายได้ สูงสุด 200,000 บาท</td></tr>
            <tr><td class="px-3 py-2 border-b">RMF (รวมกองทุนอื่น)</td><td class="px-3 py-2 text-right border-b">30% ของรายได้ สูงสุด 500,000 บาท</td></tr>
            <tr><td class="px-3 py-2 border-b">ประกันชีวิต</td><td class="px-3 py-2 text-right border-b">100,000 บาท</td></tr>
            <tr><td class="px-3 py-2">ประกันสุขภาพ</td><td class="px-3 py-2 text-right">25,000 บาท</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.rd.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมสรรพากร (rd.go.th)</a> — อัตราภาษีเงินได้บุคคลธรรมดาและนิติบุคคล</li>
        <li><a href="https://www.rd.go.th/publish/20595.0.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ตารางภาษีเงินได้บุคคลธรรมดา — กรมสรรพากร 2567/2568</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณวางแผนภาษีปลายปี/" />
    <RelatedCalculators currentHref="/คำนวณวางแผนภาษีปลายปี/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ อ้างอิงอัตราภาษีปี 2569 จากกรมสรรพากร กรุณาปรึกษาผู้เชี่ยวชาญก่อนตัดสินใจลงทุน
    </div>
  </article>

  <script>
    const TAX_BRACKETS = [
      { min: 0, max: 150_000, rate: 0 },
      { min: 150_000, max: 300_000, rate: 0.05 },
      { min: 300_000, max: 500_000, rate: 0.10 },
      { min: 500_000, max: 750_000, rate: 0.15 },
      { min: 750_000, max: 1_000_000, rate: 0.20 },
      { min: 1_000_000, max: 2_000_000, rate: 0.25 },
      { min: 2_000_000, max: 5_000_000, rate: 0.30 },
      { min: 5_000_000, max: Infinity, rate: 0.35 },
    ];

    function parseNum(v: string) { return Math.max(0, parseFloat((v || '0').replace(/,/g, '')) || 0); }
    function fmt(n: number) { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' บาท'; }

    function calcTax(netIncome: number): number {
      let remaining = Math.max(0, netIncome);
      let tax = 0;
      for (const b of TAX_BRACKETS) {
        const w = b.max === Infinity ? Infinity : b.max - b.min;
        const taxable = Math.min(remaining, w);
        tax += taxable * b.rate;
        remaining -= taxable;
        if (remaining <= 0) break;
      }
      return tax;
    }

    function getInput(id: string) { return parseNum((document.getElementById(id) as HTMLInputElement).value); }

    const form = document.getElementById('yearend-form') as HTMLFormElement;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const annualIncome = getInput('annual-income');
      if (annualIncome <= 0) return;

      const expense = Math.min(annualIncome * 0.5, 100_000);
      const baseDeduct = getInput('d-base') + getInput('d-life-cur') + getInput('d-ssf-cur') + getInput('d-rmf-cur');
      const netBefore = Math.max(0, annualIncome - expense - baseDeduct);
      const taxBefore = calcTax(netBefore);

      // Available room for additional deductions
      const ssfUsed = getInput('d-ssf-cur');
      const rmfUsed = getInput('d-rmf-cur');
      const lifeUsed = getInput('d-life-cur');

      const ssfRoom = Math.max(0, Math.min(annualIncome * 0.3, 200_000) - ssfUsed);
      const rmfRoom = Math.max(0, Math.min(annualIncome * 0.3, 500_000) - rmfUsed);
      const lifeRoom = Math.max(0, 100_000 - lifeUsed);

      const targetTaxInput = (document.getElementById('target-tax') as HTMLInputElement).value.trim();
      const targetTax = targetTaxInput ? parseNum(targetTaxInput) : 0;

      interface PlanItem { label: string; amount: number; saving: number; }
      const plan: PlanItem[] = [];
      let remainingDeduct = netBefore - Math.max(0, netBefore);
      let runningDeduct = baseDeduct;

      // Greedily allocate SSF first, then RMF, then life insurance
      const rooms = [
        { label: 'SSF (แนะนำ)', room: ssfRoom },
        { label: 'RMF', room: rmfRoom },
        { label: 'ประกันชีวิต/สุขภาพ', room: lifeRoom },
      ];

      let currentNet = netBefore;
      let currentTax = taxBefore;

      for (const r of rooms) {
        if (r.room <= 0) continue;
        const newNet = Math.max(0, currentNet - r.room);
        const newTax = calcTax(newNet);
        const saving = currentTax - newTax;
        if (saving > 0 && currentTax > targetTax) {
          const neededDeduct = currentNet - Math.max(0, currentNet - r.room);
          plan.push({ label: r.label, amount: neededDeduct, saving });
          currentNet = newNet;
          currentTax = newTax;
          if (currentTax <= targetTax) break;
        }
      }

      const afterTax = currentTax;
      const totalSaving = taxBefore - afterTax;

      (document.getElementById('r-before-tax') as HTMLElement).textContent = fmt(taxBefore);
      (document.getElementById('r-after-tax') as HTMLElement).textContent = fmt(afterTax);
      (document.getElementById('r-total-saving') as HTMLElement).textContent = fmt(totalSaving);

      const planContainer = document.getElementById('r-plan') as HTMLElement;
      if (plan.length === 0) {
        planContainer.innerHTML = '<p class="text-sm text-gray-600 p-3 bg-gray-50 rounded-lg">ไม่มีช่องว่างลดหย่อนเพิ่มเติม หรือภาษีถึงเป้าหมายแล้ว</p>';
      } else {
        planContainer.innerHTML = plan.map(p => `
          <div class="flex items-center justify-between p-3 bg-primary-50 rounded-lg border border-primary-100">
            <div>
              <span class="text-sm font-semibold text-gray-900">ซื้อเพิ่ม: ${p.label}</span>
              <div class="text-base font-bold text-primary-700 mt-1">${fmt(p.amount)}</div>
            </div>
            <div class="text-right">
              <div class="text-xs text-gray-500">ประหยัดภาษีได้</div>
              <div class="text-lg font-bold text-green-700">${fmt(p.saving)}</div>
            </div>
          </div>
        `).join('');
      }

      const resultsDiv = document.getElementById('results') as HTMLElement;
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('year_end_tax_planning');
      trackCalculatorUsed('year_end_tax_planning');
    });

    form.addEventListener('input', () => { trackCalculatorStart('year_end_tax_planning'); }, { once: true });
  </script>
</BaseLayout>
