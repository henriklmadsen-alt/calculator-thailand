---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณการจัดสรรพอร์ตลงทุน 2569 | Asset Allocation ตามสัดส่วน | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณจัดสรรพอร์ตลงทุนตามสัดส่วนที่ต้องการ แบ่งเงินลงทุนระหว่างหุ้น กองทุน ตราสารหนี้ ทองคำ และสินทรัพย์อื่น พร้อมตรวจสอบสัดส่วนรวม อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณการจัดสรรพอร์ตลงทุน/`;

const faqData = [
  {
    question: 'Asset Allocation คืออะไร และสำคัญแค่ไหน?',
    answer: 'Asset Allocation คือการแบ่งสัดส่วนเงินลงทุนในสินทรัพย์ประเภทต่างๆ เช่น หุ้น ตราสารหนี้ ทองคำ การศึกษาพบว่า Asset Allocation มีผลต่อผลตอบแทนพอร์ตมากกว่า 90% ซึ่งสำคัญกว่าการเลือกหุ้นหรือจังหวะลงทุน',
  },
  {
    question: 'สัดส่วนพอร์ตลงทุนมาตรฐานสำหรับคนไทยควรเป็นอย่างไร?',
    answer: 'ไม่มีสัดส่วนที่ถูกต้องสำหรับทุกคน แต่หลักการทั่วไปคือ อายุน้อย-รับความเสี่ยงได้สูง: หุ้น 60-80%, ตราสารหนี้ 20-40%; อายุกลาง: หุ้น 50-60%, ตราสารหนี้ 30-40%, ทองคำ 10%; ใกล้เกษียณ: หุ้น 30-40%, ตราสารหนี้ 50-60%, เงินสด 10%',
  },
  {
    question: 'ควรรีบาลานซ์พอร์ตบ่อยแค่ไหน?',
    answer: 'ส่วนใหญ่แนะนำให้รีบาลานซ์ปีละ 1-2 ครั้ง หรือเมื่อสัดส่วนสินทรัพย์เบี่ยงเบนจากเป้าหมายเกิน 5-10% การรีบาลานซ์บ่อยเกินไปอาจทำให้เสียค่าธรรมเนียมและภาษีโดยไม่จำเป็น',
  },
  {
    question: 'ทองคำควรมีสัดส่วนกี่เปอร์เซ็นต์ในพอร์ต?',
    answer: 'นักลงทุนส่วนใหญ่แนะนำทองคำ 5-15% ของพอร์ต ทองคำทำหน้าที่เป็น hedge ในช่วงที่ตลาดหุ้นตกหรือเงินเฟ้อสูง แต่ไม่ให้ผลตอบแทนในรูปกระแสเงินสด (ไม่มีปันผล/ดอกเบี้ย) จึงไม่ควรถือมากเกินไป',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณการจัดสรรพอร์ตลงทุน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณการจัดสรรพอร์ตลงทุน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณการจัดสรรพอร์ตลงทุน 2569 — แบ่งเงินตาม Asset Allocation ที่ต้องการ
    </h1>

    <p class="text-gray-600 mb-6">
      ใส่เงินลงทุนรวมและสัดส่วนที่ต้องการ ระบบจะคำนวณจำนวนเงินที่ต้องลงทุนในแต่ละสินทรัพย์ พร้อมแจ้งเตือนหากสัดส่วนรวมไม่ครบ 100%
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="alloc-form" class="space-y-5">
        <p id="alloc-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>
        <p id="alloc-sum-warning" class="hidden rounded-lg border border-yellow-200 bg-yellow-50 px-3 py-2 text-sm font-medium text-yellow-700">
          ⚠️ สัดส่วนรวมต้องเท่ากับ 100% (ปัจจุบัน: <span id="alloc-current-sum">0</span>%)
        </p>

        <div>
          <label for="alloc-total" class="block text-sm font-medium text-gray-700 mb-1">
            เงินลงทุนทั้งหมด (บาท)
          </label>
          <input
            type="text"
            id="alloc-total"
            inputmode="numeric"
            placeholder="เช่น 1,000,000"
            class="w-full sm:w-64 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div>
          <div class="grid grid-cols-3 gap-2 text-xs text-gray-500 px-1 mb-1">
            <span class="col-span-2">ประเภทสินทรัพย์</span>
            <span>สัดส่วน (%)</span>
          </div>
          <div class="space-y-2" id="alloc-rows">
            <div class="alloc-row grid grid-cols-3 gap-2">
              <input type="text" value="หุ้นไทย" class="alloc-name col-span-2 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
              <input type="number" min="0" max="100" placeholder="%" class="alloc-pct px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            </div>
            <div class="alloc-row grid grid-cols-3 gap-2">
              <input type="text" value="หุ้นต่างประเทศ" class="alloc-name col-span-2 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
              <input type="number" min="0" max="100" placeholder="%" class="alloc-pct px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            </div>
            <div class="alloc-row grid grid-cols-3 gap-2">
              <input type="text" value="ตราสารหนี้" class="alloc-name col-span-2 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
              <input type="number" min="0" max="100" placeholder="%" class="alloc-pct px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            </div>
            <div class="alloc-row grid grid-cols-3 gap-2">
              <input type="text" value="ทองคำ" class="alloc-name col-span-2 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
              <input type="number" min="0" max="100" placeholder="%" class="alloc-pct px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            </div>
            <div class="alloc-row grid grid-cols-3 gap-2">
              <input type="text" value="เงินสด/อื่น" class="alloc-name col-span-2 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
              <input type="number" min="0" max="100" placeholder="%" class="alloc-pct px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
            </div>
          </div>
          <p class="mt-2 text-xs text-gray-500">สัดส่วนรวมต้องเท่ากับ 100%</p>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการจัดสรรพอร์ต</h2>

        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-gray-500 border-b border-gray-200">
                <th class="py-2 pr-4">ประเภทสินทรัพย์</th>
                <th class="py-2 pr-4 text-right">สัดส่วน (%)</th>
                <th class="py-2 text-right">จำนวนเงิน (บาท)</th>
              </tr>
            </thead>
            <tbody id="alloc-result-body"></tbody>
            <tfoot>
              <tr class="border-t-2 border-gray-300 font-bold">
                <td class="py-2 pr-4">รวมทั้งหมด</td>
                <td id="alloc-res-totalpct" class="py-2 pr-4 text-right">-</td>
                <td id="alloc-res-totalamt" class="py-2 text-right">-</td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีการจัดสรรพอร์ตลงทุน</h2>
      <p>
        การจัดสรรพอร์ตลงทุนที่ดีช่วยกระจายความเสี่ยงและเพิ่มโอกาสผลตอบแทนที่สอดคล้องกับเป้าหมายของคุณ สัดส่วนที่เหมาะสมขึ้นอยู่กับอายุ ระยะเวลาลงทุน และความสามารถรับความเสี่ยง
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการจัดสรรพอร์ตตามอายุ</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>อายุ 20-30 ปี:</strong> หุ้นไทย 40%, หุ้นต่างประเทศ 30%, ตราสารหนี้ 20%, ทองคำ 5%, เงินสด 5%</li>
        <li><strong>อายุ 40-50 ปี:</strong> หุ้นไทย 25%, หุ้นต่างประเทศ 20%, ตราสารหนี้ 40%, ทองคำ 10%, เงินสด 5%</li>
        <li><strong>อายุ 60+ ปี:</strong> หุ้นไทย 15%, หุ้นต่างประเทศ 10%, ตราสารหนี้ 55%, ทองคำ 10%, เงินสด 10%</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณการจัดสรรพอร์ตลงทุน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางการเงิน ควรปรึกษาที่ปรึกษาทางการเงินก่อนตัดสินใจลงทุน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('alloc-form') as HTMLFormElement;
    const formError = document.getElementById('alloc-form-error') as HTMLElement;
    const sumWarning = document.getElementById('alloc-sum-warning') as HTMLElement;
    const currentSumEl = document.getElementById('alloc-current-sum') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const allocRows = document.getElementById('alloc-rows') as HTMLElement;

    // Live sum display
    allocRows.addEventListener('input', () => {
      const pcts = allocRows.querySelectorAll('.alloc-pct') as NodeListOf<HTMLInputElement>;
      let sum = 0;
      pcts.forEach(p => sum += parseFloat(p.value) || 0);
      currentSumEl.textContent = sum.toFixed(1);
      if (Math.abs(sum - 100) > 0.01) {
        sumWarning.classList.remove('hidden');
      } else {
        sumWarning.classList.add('hidden');
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const total = parseNum((document.getElementById('alloc-total') as HTMLInputElement).value);
      const nameInputs = allocRows.querySelectorAll('.alloc-name') as NodeListOf<HTMLInputElement>;
      const pctInputs = allocRows.querySelectorAll('.alloc-pct') as NodeListOf<HTMLInputElement>;

      if (total <= 0) {
        formError.classList.remove('hidden');
        return;
      }

      let sumPct = 0;
      const rows: { name: string; pct: number; amount: number }[] = [];
      nameInputs.forEach((ni, i) => {
        const pct = parseFloat(pctInputs[i].value) || 0;
        sumPct += pct;
        if (pct > 0) {
          rows.push({ name: ni.value || `สินทรัพย์ ${i + 1}`, pct, amount: total * pct / 100 });
        }
      });

      if (Math.abs(sumPct - 100) > 0.01) {
        sumWarning.classList.remove('hidden');
        currentSumEl.textContent = sumPct.toFixed(1);
        return;
      }

      sumWarning.classList.add('hidden');
      trackCalculatorStart('portfolio-alloc');

      const tbody = document.getElementById('alloc-result-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      rows.forEach((row) => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';
        tr.innerHTML = `
          <td class="py-2 pr-4">${row.name}</td>
          <td class="py-2 pr-4 text-right">${row.pct.toFixed(1)}%</td>
          <td class="py-2 text-right font-medium">${fmt(row.amount)}</td>
        `;
        tbody.appendChild(tr);
      });

      (document.getElementById('alloc-res-totalpct') as HTMLElement).textContent = sumPct.toFixed(1) + '%';
      (document.getElementById('alloc-res-totalamt') as HTMLElement).textContent = fmt(total);

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('portfolio-alloc');
      trackCalculatorUsed('portfolio-alloc');
    });
  </script>
</BaseLayout>
