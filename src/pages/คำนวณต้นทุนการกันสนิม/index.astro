---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณต้นทุนการกันสนิมรถยนต์ ปี 2569 | Rustproofing | Calculator Thailand';
const pageDescription = 'คำนวณต้นทุนการกันสนิมรถยนต์ และประเมินความคุ้มค่าในการป้องกันสนิม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนการกันสนิม/`;

const faqData = [
  {
    question: 'รถยนต์ในไทยจำเป็นต้องกันสนิมไหม?',
    answer: 'ประเทศไทยมีอากาศร้อนชื้นและฝนตกชุก ทำให้รถยนต์เสี่ยงต่อการเกิดสนิมมากกว่าประเทศที่มีอากาศแห้ง โดยเฉพาะบริเวณใต้ท้องรถ ซุ้มล้อ และรอยต่อต่างๆ รถที่ใช้ในพื้นที่ชายทะเลหรือพื้นที่น้ำท่วมซ้ำซากควรได้รับการกันสนิมเป็นพิเศษ',
  },
  {
    question: 'การกันสนิมแบบไหนคุ้มค่าที่สุด?',
    answer: 'สำหรับรถใหม่ การกันสนิมแบบอิเล็กทรอนิกส์ (Electronic Rustproofing) เป็นการลงทุนครั้งเดียว 8,000 บาท อายุใช้งานตลอดชีพรถ คุ้มค่าสำหรับรถที่เก็บไว้นาน การพ่นกันสนิมใต้ท้องรถ (Spray Coating) เหมาะกับรถเก่าที่ต้องการป้องกันเพิ่มเติม ค่าใช้จ่าย 3,000 บาทต่อปี และ Full Underbody Treatment เป็นการรักษาครอบคลุมที่สุดสำหรับรถที่ใช้งานในสภาพแวดล้อมรุนแรง',
  },
  {
    question: 'สนิมในรถยนต์ทำให้เสียหายแค่ไหน?',
    answer: 'สนิมในรถยนต์นอกจากจะดูไม่สวยงามแล้ว ยังทำให้โครงสร้างรถอ่อนแอลง อาจส่งผลต่อความปลอดภัย ลดมูลค่ารถลง 2-8% ต่อปีหากปล่อยทิ้งไว้ งานซ่อมสนิมที่ลุกลามมากอาจมีค่าใช้จ่าย 10,000-50,000 บาทขึ้นไป การป้องกันตั้งแต่แรกจึงประหยัดกว่าการซ่อมแก้ไข',
  },
  {
    question: 'ใต้ท้องรถเกิดสนิมได้อย่างไร?',
    answer: 'ใต้ท้องรถสัมผัสกับน้ำ ดิน โคลน เกลือบนถนน และความชื้นตลอดเวลา บริเวณที่เสี่ยงที่สุดคือแชสซี เหล็กยึดช่วงล่าง ท่อไอเสีย และรอยต่อโลหะ การพ่นสารกันสนิมใต้ท้องรถช่วยสร้างชั้นกันน้ำและออกซิเจน ป้องกันการเกิดสนิมได้อย่างมีประสิทธิภาพ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนการกันสนิมรถยนต์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนการกันสนิม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณต้นทุนการกันสนิมรถยนต์
    </h1>
    <p class="text-gray-600 mb-6">
      คำนวณค่าใช้จ่ายการกันสนิมรถยนต์ใน 5 ปี พร้อมประเมินมูลค่าความเสียหายที่ป้องกันได้และผลตอบแทนสุทธิ
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-5">
        <div>
          <label for="rust-type" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทการกันสนิม
          </label>
          <select
            id="rust-type"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="electronic">กันสนิมระบบอิเล็กทรอนิกส์ (ครั้งเดียว)</option>
            <option value="spray" selected>พ่นกันสนิมใต้ท้องรถ (รายปี)</option>
            <option value="underbody">Full Underbody Treatment (ครั้งเดียว)</option>
          </select>
        </div>
        <div>
          <label for="treatment-cost" class="block text-sm font-medium text-gray-700 mb-1">
            ค่ากันสนิม (บาท)
          </label>
          <input
            type="text"
            id="treatment-cost"
            inputmode="decimal"
            value="3000"
            placeholder="เช่น 3000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="vehicle-age" class="block text-sm font-medium text-gray-700 mb-1">
            อายุรถยนต์ (ปี)
          </label>
          <input
            type="text"
            id="vehicle-age"
            inputmode="decimal"
            value="3"
            placeholder="เช่น 3"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="vehicle-value-rust" class="block text-sm font-medium text-gray-700 mb-1">
            มูลค่ารถยนต์ปัจจุบัน (บาท)
          </label>
          <input
            type="text"
            id="vehicle-value-rust"
            inputmode="decimal"
            value="600000"
            placeholder="เช่น 600000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div class="sm:col-span-2">
          <label for="annual-renewal" class="block text-sm font-medium text-gray-700 mb-1">
            ต่ออายุสารกันสนิมประจำปีหรือไม่? (สำหรับการพ่นแบบรายปี)
          </label>
          <select
            id="annual-renewal"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="yes" selected>ใช่ — ต่ออายุทุกปี</option>
            <option value="no">ไม่ — ทำครั้งแรกครั้งเดียว</option>
          </select>
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full px-6 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณความคุ้มค่าการกันสนิม
      </button>

      <!-- Results -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-blue-700 font-medium mb-1">ค่ากันสนิม 5 ปี</div>
            <div id="res-5yr-cost" class="text-2xl font-bold text-blue-800">-</div>
            <div id="res-cost-note" class="text-xs text-blue-600 mt-1">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4">
            <div class="text-sm text-red-700 font-medium mb-1">ความเสียหายจากสนิม (ถ้าไม่กัน)</div>
            <div id="res-rust-damage" class="text-2xl font-bold text-red-800">-</div>
            <div id="res-damage-note" class="text-xs text-red-600 mt-1">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4">
            <div class="text-sm text-green-700 font-medium mb-1">มูลค่าที่ป้องกันได้ (5 ปี)</div>
            <div id="res-prevention-value" class="text-2xl font-bold text-green-800">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4">
            <div class="text-sm text-primary-700 font-medium mb-1">ผลตอบแทนสุทธิ 5 ปี</div>
            <div id="res-net-5yr" class="text-2xl font-bold text-primary-800">-</div>
            <div id="res-roi-5yr" class="text-xs text-primary-600 mt-1">-</div>
          </div>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 text-sm">
          <div class="font-semibold text-gray-700 mb-2">สรุปและคำแนะนำ</div>
          <div id="res-recommendation" class="text-gray-600">-</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">การกันสนิมรถยนต์ในประเทศไทย</h2>
      <p>
        สภาพอากาศร้อนชื้นของไทยทำให้รถยนต์เสี่ยงต่อสนิมมากกว่าปกติ
        โดยเฉพาะบริเวณใต้ท้องรถที่สัมผัสกับน้ำและโคลนตลอดเวลา
        การลงทุนกันสนิมตั้งแต่รถใหม่หรือรถที่ยังสภาพดีเป็นการป้องกันที่คุ้มค่า
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประเภทการกันสนิมและราคา 2569</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b border-gray-200">
              <th class="py-2 pr-4">ประเภท</th>
              <th class="py-2 pr-4">ราคา (บาท)</th>
              <th class="py-2 pr-4">อายุใช้งาน</th>
              <th class="py-2">เหมาะกับ</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">กันสนิมอิเล็กทรอนิกส์</td>
              <td class="py-2 pr-4">8,000</td>
              <td class="py-2 pr-4">ตลอดชีพรถ</td>
              <td class="py-2">รถใหม่ทุกคัน</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">พ่นกันสนิมใต้ท้องรถ</td>
              <td class="py-2 pr-4">2,500-3,500/ปี</td>
              <td class="py-2 pr-4">1 ปี</td>
              <td class="py-2">รถเก่า/พื้นที่ชื้น</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">Full Underbody Treatment</td>
              <td class="py-2 pr-4">5,000-8,000</td>
              <td class="py-2 pr-4">3-5 ปี</td>
              <td class="py-2">รถที่ใช้งานหนัก</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ต้นทุนของสนิมที่ไม่รักษา</h3>
      <p>
        รถที่ปล่อยให้มีสนิมโดยไม่รักษาอาจเสียค่าซ่อมสนิมจุดเล็กๆ 2,000-5,000 บาท
        หากลุกลามถึงโครงสร้างหลัก ค่าซ่อมอาจสูง 20,000-100,000 บาท
        นอกจากนี้สนิมยังลดมูลค่ารถในการขายต่อ 10-30% อีกด้วย
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณความคุ้มค่าการกันสนิม</h3>
      <div class="bg-gray-50 rounded-lg p-4 my-4 space-y-2">
        <p class="font-medium">ความเสียหายจากสนิมต่อปี = มูลค่ารถ × 2-4% (ขึ้นอยู่กับสภาพแวดล้อม)</p>
        <p class="font-medium">มูลค่าที่ป้องกัน 5 ปี = ความเสียหายต่อปี × 5</p>
        <p class="font-semibold text-primary-700">ผลตอบแทนสุทธิ = มูลค่าที่ป้องกัน - ค่ากันสนิม 5 ปี</p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณต้นทุนการกันสนิม/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนการกันสนิม/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการโดยอิงจากข้อมูลทั่วไป
      ความเสียหายจากสนิมจริงขึ้นอยู่กับสภาพอากาศ วิธีการดูแลรถ และคุณภาพของผลิตภัณฑ์กันสนิม
      กรุณาปรึกษาช่างผู้เชี่ยวชาญก่อนตัดสินใจ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    // Default costs per type
    const defaultCosts: Record<string, number> = {
      'electronic': 8000,
      'spray': 3000,
      'underbody': 6500,
    };

    document.getElementById('rust-type')!.addEventListener('change', () => {
      const type = (document.getElementById('rust-type') as HTMLSelectElement).value;
      (document.getElementById('treatment-cost') as HTMLInputElement).value = defaultCosts[type].toString();
    });

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const rustType = (document.getElementById('rust-type') as HTMLSelectElement).value;
      const treatmentCost = parseNum((document.getElementById('treatment-cost') as HTMLInputElement).value) || defaultCosts[rustType];
      const vehicleAge = parseNum((document.getElementById('vehicle-age') as HTMLInputElement).value) || 3;
      const vehicleValue = parseNum((document.getElementById('vehicle-value-rust') as HTMLInputElement).value) || 600000;
      const annualRenewal = (document.getElementById('annual-renewal') as HTMLSelectElement).value;

      // 5-year treatment cost
      let cost5yr: number;
      let costNote: string;

      if (rustType === 'electronic') {
        cost5yr = treatmentCost; // one-time
        costNote = 'ลงทุนครั้งเดียว ใช้ได้ตลอดชีพรถ';
      } else if (rustType === 'spray') {
        if (annualRenewal === 'yes') {
          cost5yr = treatmentCost * 5;
          costNote = `${fmt(treatmentCost)} บาท × 5 ปี`;
        } else {
          cost5yr = treatmentCost; // once
          costNote = 'ทำครั้งเดียว อายุป้องกัน 1 ปี';
        }
      } else {
        // underbody: assume 1-2 treatments in 5 years
        cost5yr = treatmentCost * 1.5;
        costNote = `ประมาณ 1-2 ครั้งใน 5 ปี`;
      }

      // Rust damage rate: 2-3% per year based on vehicle age
      // Older cars lose more value to rust
      const rustPctPerYear = vehicleAge <= 3 ? 0.02 : vehicleAge <= 6 ? 0.03 : 0.04;
      const annualRustDamage = vehicleValue * rustPctPerYear;
      const damage5yr = annualRustDamage * 5;
      const damageNote = `${(rustPctPerYear * 100).toFixed(0)}%/ปี ของมูลค่ารถ สำหรับรถอายุ ${vehicleAge} ปี`;

      // Prevention value: treatment effectiveness varies by type
      const effectivenessMap: Record<string, number> = {
        'electronic': 0.9,  // 90% effective
        'spray': annualRenewal === 'yes' ? 0.85 : 0.6,
        'underbody': 0.8,
      };
      const effectiveness = effectivenessMap[rustType];
      const preventionValue = damage5yr * effectiveness;
      const net5yr = preventionValue - cost5yr;
      const roi = cost5yr > 0 ? (preventionValue / cost5yr) * 100 : 0;

      (document.getElementById('res-5yr-cost') as HTMLElement).textContent = `฿${fmt(Math.round(cost5yr))}`;
      (document.getElementById('res-cost-note') as HTMLElement).textContent = costNote;
      (document.getElementById('res-rust-damage') as HTMLElement).textContent = `฿${fmt(Math.round(damage5yr))}`;
      (document.getElementById('res-damage-note') as HTMLElement).textContent = damageNote;
      (document.getElementById('res-prevention-value') as HTMLElement).textContent = `฿${fmt(Math.round(preventionValue))}`;

      const netEl = document.getElementById('res-net-5yr') as HTMLElement;
      if (net5yr >= 0) {
        netEl.textContent = `+฿${fmt(Math.round(net5yr))}`;
        netEl.className = 'text-2xl font-bold text-green-700';
      } else {
        netEl.textContent = `-฿${fmt(Math.round(Math.abs(net5yr)))}`;
        netEl.className = 'text-2xl font-bold text-orange-700';
      }
      (document.getElementById('res-roi-5yr') as HTMLElement).textContent = `ROI: ${roi.toFixed(0)}% — ทุก ฿1 ลงทุน ได้คืน ฿${(roi / 100).toFixed(2)}`;

      const recEl = document.getElementById('res-recommendation') as HTMLElement;
      if (roi >= 150) {
        recEl.textContent = `การกันสนิมประเภทนี้คุ้มค่ามาก ได้ผลตอบแทน ${roi.toFixed(0)}% ในระยะ 5 ปี ควรดำเนินการโดยเร็ว`;
      } else if (roi >= 100) {
        recEl.textContent = `การกันสนิมคุ้มค่า สามารถป้องกันความเสียหายได้มากกว่าต้นทุนที่ลงทุน แนะนำดำเนินการ`;
      } else {
        recEl.textContent = `ค่ากันสนิมสูงกว่าความเสียหายที่ป้องกันได้เล็กน้อย แต่ยังคุ้มค่าในแง่การรักษาสภาพรถและมูลค่าขายต่อ`;
      }

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
    });
  </script>
</BaseLayout>
