---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณ ROI การลงทุนเกษตร | Kamnuanlek';
const pageDescription = 'คำนวณผลตอบแทนการลงทุนเกษตร ROI ระยะคืนทุน กำไรต่อปี ความคุ้มค่าการทำเกษตร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0482-roi-เกษตร/`;
const faqData = [
  { question: 'ROI การทำเกษตรที่ดีควรเป็นเท่าไหร่?', answer: 'ROI การเกษตรทั่วไป 10-30% ต่อปี พืชเศรษฐกิจอย่างทุเรียน มังคุด อาจได้ ROI 30-60% เมื่อต้นให้ผล แต่ต้องรอ 3-5 ปีก่อนได้รับผลตอบแทนเต็มที่' },
  { question: 'ระยะคืนทุนการทำสวนไม้ผลนานแค่ไหน?', answer: 'สวนทุเรียน: 5-7 ปี มังคุด: 8-10 ปี ลำไย: 3-4 ปี กล้วยหอม: 1 ปี ระยะคืนทุนขึ้นอยู่กับราคาตลาด ผลผลิต และต้นทุนการผลิต' },
  { question: 'การทำเกษตรอินทรีย์ ROI ดีกว่าไหม?', answer: 'เกษตรอินทรีย์ราคาขายสูงกว่า 20-50% แต่ผลผลิตอาจต่ำกว่าช่วงแรก ใช้เวลา 3 ปีเพื่อได้รับรอง Organic ระยะยาว ROI มักดีกว่าเกษตรทั่วไป' },
  { question: 'ปัจจัยที่ทำให้ ROI เกษตรลดลงมีอะไรบ้าง?', answer: 'ราคาตลาดตก ผลผลิตต่ำกว่าเป้า ภัยพิบัติ (น้ำท่วม/แล้ง) โรคพืชระบาด ต้นทุนพลังงานสูงขึ้น และการขาดตลาดรับซื้อที่แน่นอน' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ ROI การลงทุนเกษตร">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณ ROI การลงทุนเกษตร</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณผลตอบแทนและระยะคืนทุนของการลงทุนเกษตร</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="agri_invest" class="block text-sm font-medium text-gray-700 mb-1">เงินลงทุนเริ่มต้น (บาท)</label><input type="text" id="agri_invest" inputmode="decimal" placeholder="เช่น 200000" value="200000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="agri_annual_revenue" class="block text-sm font-medium text-gray-700 mb-1">รายได้ต่อปี (บาท)</label><input type="text" id="agri_annual_revenue" inputmode="decimal" placeholder="เช่น 150000" value="150000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="agri_annual_cost" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนดำเนินงานต่อปี (บาท)</label><input type="text" id="agri_annual_cost" inputmode="decimal" placeholder="เช่น 80000" value="80000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">กำไรสุทธิต่อปี</p><p id="agri_net_annual" class="font-bold">-</p></div>
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ROI ต่อปี</p><p id="agri_roi" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">ระยะคืนทุน</p><p id="agri_payback" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const invest = parseFloat((document.getElementById('agri_invest') as HTMLInputElement).value) || 0;
      const revenue = parseFloat((document.getElementById('agri_annual_revenue') as HTMLInputElement).value) || 0;
      const cost = parseFloat((document.getElementById('agri_annual_cost') as HTMLInputElement).value) || 0;
      const netAnnual = revenue - cost;
      const roi = invest > 0 ? (netAnnual / invest * 100) : 0;
      const payback = netAnnual > 0 ? invest / netAnnual : Infinity;
      (document.getElementById('agri_net_annual') as HTMLElement).textContent = Math.round(netAnnual).toLocaleString('th-TH') + ' บาท/ปี';
      (document.getElementById('agri_roi') as HTMLElement).textContent = roi.toFixed(1) + '%';
      (document.getElementById('agri_payback') as HTMLElement).textContent = isFinite(payback) ? payback.toFixed(1) + ' ปี' : 'ไม่คืนทุน';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('agricultural-roi');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
