---
import CreditCardInterestCalculatorPage from '../คำนวณดอกเบี้ยบัตรเครดิต/index.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const supportingInstallmentArticleHref = '/บทความ/ผ่อนบัตรเครดิต-2569-ค่างวด-ดอกเบี้ย/';

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---<CreditCardInterestCalculatorPage
  pageTitleOverride="คำนวณค่างวดบัตรเครดิต 2569 | ดอกเบี้ยและแผนปิดหนี้ | Kamnuanlek"
  pageDescriptionOverride="คำนวณค่างวดบัตรเครดิต 2569 จากยอดคงค้าง ยอดชำระ และจำนวนวันในรอบบิล เพื่อวางแผนจ่ายเกินขั้นต่ำและปิดหนี้เร็วขึ้น"
  canonicalPathOverride="/คำนวณค่างวดบัตรเครดิต/"
  pageNameOverride="คำนวณค่างวดบัตรเครดิต"
  headingOverride="คำนวณค่างวดบัตรเครดิต 2569 (ดอกเบี้ยรายวัน + แผนจ่ายจริง)"
  introOverride="กรอกยอดคงค้าง ยอดที่ต้องการจ่าย และจำนวนวันในรอบบิล เพื่อดูค่างวดขั้นต่ำ ดอกเบี้ยรวม และยอดคงเหลือรอบถัดไปในมุมผ่อนบัตรเครดิต"
  supportingArticleHrefOverride={supportingInstallmentArticleHref}
  supportingArticleLabelOverride="ผ่อนบัตรเครดิต 2569: ค่างวดและดอกเบี้ย ควรจ่ายเท่าไรไม่ให้หนี้ยืด"
  relatedHrefOverride="/คำนวณค่างวดบัตรเครดิต/"
/>
