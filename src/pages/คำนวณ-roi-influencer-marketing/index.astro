---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ ROI Influencer Marketing 2569 | Calculator Thailand';
const pageDescription = 'คำนวณ ROI จากการทำ Influencer Marketing ประเมินคุณค่าเทียบกับค่า Influencer Fee อย่างแม่นยำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-roi-influencer-marketing/`;

const faqData = [
  {
    question: 'Influencer Marketing ROI คำนวณอย่างไร?',
    answer: 'ROI = (ยอดขาย - ค่า Influencer) ÷ ค่า Influencer × 100 ตัวอย่าง: ค่าจ่าย 10,000 บาท ได้ยอดขาย 50,000 บาท = (50,000-10,000) ÷ 10,000 = 400% ROI (ลงทุน 1 บาทได้ 5 บาท)',
  },
  {
    question: 'ควรจ่าย Influencer เท่าไร?',
    answer: 'พึ่งจำนวนผู้ติดตาม: 1K-10K followers = 1,000-5,000 บาท, 10K-100K = 5,000-50,000 บาท, 100K+ = 50,000+ บาท Micro-influencer (10K-100K) มี Engagement ดี ราคาถูก ประสิทธิภาพสูงกว่า Mega-influencer',
  },
  {
    question: 'ปัจจัยไหนส่งผลต่อ Influencer ROI?',
    answer: 'Engagement Rate: ไลค์/ความเห็น สำคัญกว่า Follower Audience Match: หากผู้ติดตามตรงกับ Target Customer ยิ่งขาย Creative Content: ถ้า Influencer สร้างเนื้อหาที่ดี ลูกค้าเชื่อมากขึ้น CTA (Call-to-Action): ต้องชัดเจน ให้ลิงค์ รหัสลด',
  },
  {
    question: 'วิธีลดความเสี่ยง Influencer?',
    answer: 'ทำข้อตกลงล่วงหน้า: Deliverables, Timeline, Approval ชัดเจน Track Link/Code: ใช้ Unique Link รหัสลด Track ยอดขาย เก็บเป็นหลักฐาน Negotiate Terms: จ่าย Half ตอน Start, Half ตอน Delivery Pay by Performance: ตกลงจ่าย Commission จากยอดขายแทน Fixed Fee',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ ROI Influencer Marketing',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ ROI Influencer Marketing">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      👥 คำนวณ ROI Influencer Marketing
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณ ROI จากการทำ Influencer Marketing
      ประเมินคุณค่าเทียบกับค่า Influencer Fee อย่างแม่นยำ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="influencer-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="influencer-fee" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Influencer Fee (บาท)
            </label>
            <input
              type="text"
              id="influencer-fee"
              inputmode="numeric"
              placeholder="เช่น 10000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="expected-sales" class="block text-sm font-medium text-gray-700 mb-1">
              ยอดขายคาดหวัง (บาท)
            </label>
            <input
              type="text"
              id="expected-sales"
              inputmode="numeric"
              placeholder="เช่น 50000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="product-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ต้นทุนสินค้า/บริการ (บาท)
              <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
            </label>
            <input
              type="text"
              id="product-cost"
              inputmode="numeric"
              placeholder="เช่น 0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="impressions" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวน Impressions คาดหวัง
              <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
            </label>
            <input
              type="text"
              id="impressions"
              inputmode="numeric"
              placeholder="เช่น 10000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ ROI
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ ROI</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Gross Profit</div>
            <div id="res-gross-profit" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Net Profit</div>
            <div id="res-net-profit" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ROI %</div>
            <div id="res-roi-percent" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Cost per Impression</div>
            <div id="res-cpi" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่า Influencer</span>
            <span id="res-fee" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ยอดขายคาดหวัง</span>
            <span id="res-sales" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ต้นทุนสินค้า</span>
            <span id="res-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">Impressions</span>
            <span id="res-impr" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">Influencer Marketing: ลงทุนให้คุ้มค่า</h2>

      <p>
        Influencer Marketing เป็นช่องทางที่มีประสิทธิภาพ แต่ต้องคิดกำไรให้ดี
        บางแคมเปญขาดทุน บางแคมเปญทำกำไร 10 เท่า ความสำคัญคือการเลือก Influencer ที่เหมาะ
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประเภท Influencer และราคา</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>Nano-influencer (1K-10K)</strong> — 1,000-5,000 บาท Engagement ดีที่สุด</li>
        <li><strong>Micro-influencer (10K-100K)</strong> — 5,000-50,000 บาท ราคาดี Engagement ดี</li>
        <li><strong>Macro-influencer (100K-1M)</strong> — 50,000-500,000 บาท Reach กว้าง Engagement ต่ำกว่า</li>
        <li><strong>Mega-influencer (1M+)</strong> — 500,000+ บาท ชื่อเสียง แต่ ROI อาจต่ำ</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวชี้วัดสำคัญ</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>Engagement Rate</strong> — (ไลค์+ความเห็น) ÷ Followers × 100 มากกว่า 3-5% ดี</li>
        <li><strong>Cost per Engagement (CPE)</strong> — ค่า Influencer ÷ Engagement คนไหนต่ำกว่า ดีกว่า</li>
        <li><strong>Cost per Impression (CPI)</strong> — ค่า ÷ Impressions (Views) ประมาณ 0.05-0.5 บาท</li>
        <li><strong>Conversion Rate</strong> — % ของผู้ที่มา Track Link / Discount Code ซื้อ</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีเพิ่ม Influencer ROI</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>เลือก Micro-influencer: Engagement ดี ราคาถูก ROI สูง</li>
        <li>ให้ Creative Freedom: ปล่อยให้ Influencer สร้างเนื้อหา ลูกค้าเชื่อมากขึ้น</li>
        <li>ใช้ Unique Link/Code: Track ยอดขายที่ได้จาก Influencer ที่แต่ละคน</li>
        <li>Bundle Campaign: ร่วมหลาย Influencer เพื่อกระจายความเสี่ยง</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณ-roi-influencer-marketing/" />
    <RelatedCalculators currentHref="/คำนวณ-roi-influencer-marketing/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ
      ROI จริงขึ้นอยู่กับ Influencer Choice, Audience, Creative Quality
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('influencer-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const influencerFee = parseNum((document.getElementById('influencer-fee') as HTMLInputElement).value);
      const expectedSales = parseNum((document.getElementById('expected-sales') as HTMLInputElement).value);
      const productCost = parseNum((document.getElementById('product-cost') as HTMLInputElement).value);
      const impressions = parseNum((document.getElementById('impressions') as HTMLInputElement).value);

      if (influencerFee <= 0) { (document.getElementById('influencer-fee') as HTMLInputElement).focus(); return; }
      if (expectedSales <= 0) { (document.getElementById('expected-sales') as HTMLInputElement).focus(); return; }

      const grossProfit = expectedSales - productCost;
      const netProfit = grossProfit - influencerFee;
      const roiPercent = (netProfit / influencerFee) * 100;
      const cpi = impressions > 0 ? influencerFee / impressions : 0;

      (document.getElementById('res-gross-profit') as HTMLElement).textContent = fmt(grossProfit) + ' บาท';
      (document.getElementById('res-net-profit') as HTMLElement).textContent = fmt(netProfit) + ' บาท';
      (document.getElementById('res-roi-percent') as HTMLElement).textContent = roiPercent.toFixed(0) + '%';
      (document.getElementById('res-cpi') as HTMLElement).textContent = cpi.toFixed(2) + ' บาท/view';
      (document.getElementById('res-fee') as HTMLElement).textContent = fmt(influencerFee) + ' บาท';
      (document.getElementById('res-sales') as HTMLElement).textContent = fmt(expectedSales) + ' บาท';
      (document.getElementById('res-cost') as HTMLElement).textContent = fmt(productCost) + ' บาท';
      (document.getElementById('res-impr') as HTMLElement).textContent = impressions > 0 ? impressions.toFixed(0) : 'N/A';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('influencer-marketing-roi');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('influencer-marketing-roi');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
