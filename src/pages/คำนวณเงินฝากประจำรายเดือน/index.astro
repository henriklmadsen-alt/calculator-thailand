---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเงินฝากประจำรายเดือน 2569 | ดอกเบี้ยหักภาษี | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณผลตอบแทนจากการฝากประจำรายเดือนสม่ำเสมอ รวมดอกเบี้ย หักภาษี 15%';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินฝากประจำรายเดือน/`;

const faqData = [
  {
    question: 'เงินฝากประจำรายเดือนในไทยให้ดอกเบี้ยเท่าไหร่?',
    answer: 'เงินฝากประจำรายเดือน (Recurring Deposit) ในไทยปัจจุบันให้ดอกเบี้ยประมาณ 1–3% ต่อปี ขึ้นอยู่กับธนาคารและระยะเวลา บางธนาคารมีโปรโมชันพิเศษสูงถึง 3.5%',
  },
  {
    question: 'ต่างจากเงินฝากประจำแบบก้อนอย่างไร?',
    answer: 'เงินฝากประจำแบบก้อน (Fixed Deposit) ฝากครั้งเดียว ส่วน Recurring Deposit ฝากทุกเดือนในจำนวนที่กำหนด เหมาะสำหรับคนที่ต้องการออมอย่างมีวินัยโดยไม่ต้องมีเงินก้อนใหญ่ตั้งแต่ต้น',
  },
  {
    question: 'ควรเลือกฝากเดือนละเท่าไหร่?',
    answer: 'แนะนำให้ออมอย่างน้อย 10–20% ของรายได้ต่อเดือนในรูปแบบเงินฝากประจำ เลือกจำนวนที่ทำได้จริงสม่ำเสมอโดยไม่กระทบค่าใช้จ่ายจำเป็น',
  },
  {
    question: 'ถ้าขาดส่งเงินฝากประจำรายเดือนจะเกิดอะไร?',
    answer: 'ขึ้นอยู่กับเงื่อนไขธนาคาร บางแห่งอาจปรับลดดอกเบี้ยหรือยกเลิกสัญญา บางแห่งให้ยืดหยุ่นได้บ้าง ควรอ่านเงื่อนไขก่อนเปิดบัญชี',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินฝากประจำรายเดือน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินฝากประจำรายเดือน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-green-100 bg-green-50 p-4">
      <p class="text-sm font-semibold text-green-700">🏦 คำนวณเงินฝากประจำรายเดือน (Recurring Deposit)</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: FV = PMT × [(1+r)^n − 1] ÷ r | r = ดอกเบี้ยรายเดือน, n = จำนวนเดือน</p>
      <p class="mt-1 text-xs font-medium text-green-800">ออมทุกเดือนอย่างมีวินัย ดอกเบี้ยทบต้นช่วยให้เงินเติบโต</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณเงินฝากประจำรายเดือน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกจำนวนเงินฝากต่อเดือน อัตราดอกเบี้ย และระยะเวลา เพื่อดูเงินต้นรวมและดอกเบี้ยที่ได้รับ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="rd-form" class="space-y-5">
        <p id="rd-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="rd-monthly" class="mb-1 block text-sm font-medium text-gray-700">ฝากต่อเดือน (บาท)</label>
            <input type="text" id="rd-monthly" inputmode="numeric" placeholder="เช่น 5,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="rd-monthly-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="rd-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราดอกเบี้ย (% ต่อปี)</label>
            <input type="text" id="rd-rate" inputmode="numeric" placeholder="เช่น 2"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="rd-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="rd-months" class="mb-1 block text-sm font-medium text-gray-700">ระยะเวลา (เดือน)</label>
            <select id="rd-months" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="12">12 เดือน (1 ปี)</option>
              <option value="24" selected>24 เดือน (2 ปี)</option>
              <option value="36">36 เดือน (3 ปี)</option>
              <option value="48">48 เดือน (4 ปี)</option>
              <option value="60">60 เดือน (5 ปี)</option>
              <option value="120">120 เดือน (10 ปี)</option>
            </select>
          </div>
          <div>
            <label for="rd-tax" class="mb-1 block text-sm font-medium text-gray-700">หักภาษีดอกเบี้ย (%)</label>
            <select id="rd-tax" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="0">ไม่หักภาษี</option>
              <option value="15" selected>15% (มาตรฐาน)</option>
            </select>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณเงินฝากประจำ
        </button>
      </form>
    </div>

    <div id="rd-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-4">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">มูลค่าเมื่อครบกำหนด</div>
            <div id="res-rd-total" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินต้นรวม</div>
            <div id="res-rd-principal" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ดอกเบี้ยก่อนภาษี</div>
            <div id="res-rd-gross-int" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="rounded-lg bg-teal-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ดอกเบี้ยสุทธิ</div>
            <div id="res-rd-net-int" class="text-xl font-bold text-teal-700">-</div>
          </div>
        </div>
        <p id="rd-status" class="rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>FV = PMT × [(1+r)^n − 1] ÷ r</li>
        <li>โดย PMT = ฝากต่อเดือน, r = ดอกเบี้ยรายเดือน (% ÷ 12), n = จำนวนเดือน</li>
        <li>ดอกเบี้ยก่อนภาษี = FV − (PMT × n)</li>
        <li>ดอกเบี้ยสุทธิ = ดอกเบี้ยก่อนภาษี × (1 − อัตราภาษี)</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#rd-results" />
    <RelatedArticles currentHref="/คำนวณเงินฝากประจำรายเดือน/" />
    <RelatedCalculators currentHref="/คำนวณเงินฝากประจำรายเดือน/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ อัตราดอกเบี้ยจริงอาจแตกต่างตามธนาคารและช่วงเวลา
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return 0;
      const n = Number(s);
      return Number.isFinite(n) && n >= 0 ? n : 0;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('rd-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('rd-error').classList.add('hidden');
      ['rd-monthly-error','rd-rate-error'].forEach(id => setErr(id, ''));

      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('recurring-deposit');
      const pmt = parseNum(document.getElementById('rd-monthly').value);
      const annualRate = parseNum(document.getElementById('rd-rate').value);
      const n = parseInt(document.getElementById('rd-months').value, 10);
      const taxRate = parseFloat(document.getElementById('rd-tax').value);

      let hasError = false;
      if (!pmt || pmt <= 0) { setErr('rd-monthly-error', 'กรอกจำนวนเงินฝากต่อเดือน'); hasError = true; }
      if (!annualRate || annualRate <= 0) { setErr('rd-rate-error', 'กรอกอัตราดอกเบี้ย'); hasError = true; }
      if (hasError) { document.getElementById('rd-error').classList.remove('hidden'); document.getElementById('rd-results').classList.add('hidden'); return; }

      const r = annualRate / 100 / 12;
      const fv = pmt * (Math.pow(1 + r, n) - 1) / r;
      const principal = pmt * n;
      const grossInterest = fv - principal;
      const netInterest = grossInterest * (1 - taxRate / 100);
      const netTotal = principal + netInterest;

      setText('res-rd-total', formatMoney(netTotal));
      setText('res-rd-principal', formatMoney(principal));
      setText('res-rd-gross-int', formatMoney(grossInterest));
      setText('res-rd-net-int', formatMoney(netInterest));

      const statusEl = document.getElementById('rd-status');
      statusEl.className = 'rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800 border border-green-200';
      statusEl.textContent = `ฝากเดือนละ ${formatMoney(pmt)} ที่ดอกเบี้ย ${annualRate}%/ปี เป็นเวลา ${n} เดือน จะได้รับเงินรวม ${formatMoney(netTotal)} (ดอกเบี้ยสุทธิ ${formatMoney(netInterest)})`;

      document.getElementById('rd-results').classList.remove('hidden');
      document.getElementById('rd-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('recurring-deposit');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('recurring-deposit');
    });
  </script>
</BaseLayout>
