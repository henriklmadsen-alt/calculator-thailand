---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่าจดทะเบียนบริษัท | Kamnuanlek';
const pageDescription = 'คำนวณค่าจดทะเบียนบริษัท ค่าธรรมเนียม DBD ค่าอากรแสตมป์ ค่าทนายความ ปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0451-ค่าจดทะเบียน/`;

const faqData = [
  { question: 'ค่าจดทะเบียนบริษัทจำกัดเท่าไหร่?', answer: 'ค่าธรรมเนียมกรมพัฒนาธุรกิจการค้า (DBD) สำหรับทุนจดทะเบียน 1,000,000 บาท ประมาณ 5,500 บาท ทุนจดทะเบียนสูงขึ้นค่าธรรมเนียมก็เพิ่มขึ้น' },
  { question: 'ทุนจดทะเบียนขั้นต่ำเท่าไหร่?', answer: 'บริษัทจำกัดไม่มีทุนจดทะเบียนขั้นต่ำตามกฎหมาย แต่แนะนำ 1,000,000-3,000,000 บาท เพื่อความน่าเชื่อถือในการทำธุรกิจ' },
  { question: 'จดทะเบียนเองหรือใช้บริการนักบัญชีดีกว่า?', answer: 'จดทะเบียนเองผ่าน e-Registration ฟรีหรือถูกกว่า แต่ใช้เวลาเรียนรู้ ใช้บริการนักบัญชี/ทนายความ 3,000-10,000 บาท ประหยัดเวลาและลดความผิดพลาด' },
  { question: 'ค่าใช้จ่ายหลังจดทะเบียนมีอะไรบ้าง?', answer: 'หลังจดทะเบียน มีค่าทำบัญชี 2,000-5,000 บาท/เดือน ค่าประกันสังคมพนักงาน 5% ค่าจดทะเบียน VAT (ถ้าต้องการ) 500 บาท และค่าตรา 1,000-3,000 บาท' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าจดทะเบียนบริษัท">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าจดทะเบียนบริษัท</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าจดทะเบียนบริษัทจำกัด ค่าธรรมเนียม DBD และค่าบริการต่างๆ</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="capital" class="block text-sm font-medium text-gray-700 mb-1">ทุนจดทะเบียน (บาท)</label><input type="text" id="capital" inputmode="decimal" placeholder="เช่น 1000000" value="1000000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="legal_fee" class="block text-sm font-medium text-gray-700 mb-1">ค่าบริการทนายความ/นักบัญชี (บาท)</label><input type="text" id="legal_fee" inputmode="decimal" placeholder="เช่น 5000" value="5000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="stamp_duty" class="block text-sm font-medium text-gray-700 mb-1">ค่าอากรแสตมป์ (บาท)</label><input type="text" id="stamp_duty" inputmode="decimal" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="seal_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าตราประทับบริษัท (บาท)</label><input type="text" id="seal_cost" inputmode="decimal" placeholder="เช่น 1500" value="1500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าธรรมเนียม DBD</p>
            <p id="dbd_fee" class="font-bold">-</p>
          </div>
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าบริการและอื่นๆ</p>
            <p id="service_total" class="font-bold">-</p>
          </div>
          <div class="bg-indigo-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">รวมค่าจดทะเบียนบริษัท</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const capital = parseFloat((document.getElementById('capital') as HTMLInputElement).value) || 0;
      const legalFee = parseFloat((document.getElementById('legal_fee') as HTMLInputElement).value) || 0;
      const stampDuty = parseFloat((document.getElementById('stamp_duty') as HTMLInputElement).value) || 0;
      const sealCost = parseFloat((document.getElementById('seal_cost') as HTMLInputElement).value) || 0;

      // DBD fee calculation: 500 per 100,000 of capital, min 500
      const dbdFee = Math.max(500, Math.floor(capital / 100000) * 500);
      const serviceTotal = legalFee + stampDuty + sealCost;
      const total = dbdFee + serviceTotal;

      (document.getElementById('dbd_fee') as HTMLElement).textContent = dbdFee.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('service_total') as HTMLElement).textContent = serviceTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('company-registration-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
