---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');

const jsonLdOrganizationFull = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: 'Kamnuanlek',
  alternateName: ['คำนวณเลข', 'เครื่องคำนวณไทย', 'kamnuanlek.com'],
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/og-image.svg`,
    width: 1200,
    height: 630,
  },
  description: 'Kamnuanlek (คำนวณเลข) คือแพลตฟอร์มเครื่องคำนวณออนไลน์ฟรีสำหรับคนไทย ครอบคลุมการคำนวณภาษีเงินได้บุคคลธรรมดา สินเชื่อบ้านและรถยนต์ เงินเดือนสุทธิ ค่าไฟฟ้า ค่าน้ำ ประกันสังคม และอีกกว่า 800 รายการ ทุกอัตราอ้างอิงจากหน่วยงานราชการไทยและอัปเดตสำหรับปีพุทธศักราช 2569',
  foundingDate: '2024',
  inLanguage: 'th-TH',
  areaServed: { '@type': 'Country', name: 'Thailand' },
  knowsAbout: [
    'Thai personal income tax calculation',
    'Thai loan and mortgage calculators',
    'Thai salary and overtime calculation',
    'Thai social security contributions',
    'Thai electricity and water bill calculation',
    'Thai VAT calculation',
    'Thai property transfer fees',
    'เครื่องคำนวณภาษีไทย',
    'คำนวณสินเชื่อไทย',
    'คำนวณเงินเดือนสุทธิ',
  ],
  email: 'info@kamnuanlek.com',
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'info@kamnuanlek.com',
    contactType: 'customer support',
    availableLanguage: ['Thai', 'English'],
    url: 'https://www.kamnuanlek.com/ติดต่อเรา/',
  },
};

const jsonLdWebPage = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': `${siteUrl}/เกี่ยวกับ-kamnuanlek/#webpage`,
  url: `${siteUrl}/เกี่ยวกับ-kamnuanlek/`,
  name: 'เกี่ยวกับ Kamnuanlek — แพลตฟอร์มเครื่องคำนวณออนไลน์สำหรับคนไทย',
  description: 'Kamnuanlek (คำนวณเลข) คือเครื่องคำนวณออนไลน์ฟรีสำหรับคนไทย ครอบคลุมภาษี สินเชื่อ เงินเดือน ค่าสาธารณูปโภค และอีก 800+ รายการ อัปเดตอัตราราชการปี 2569',
  inLanguage: 'th-TH',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    name: 'Kamnuanlek — เครื่องคำนวณไทย',
    url: siteUrl,
  },
  about: { '@id': `${siteUrl}/#organization` },
  mainEntity: { '@id': `${siteUrl}/#organization` },
};
---

<BaseLayout
  title="เกี่ยวกับ Kamnuanlek — เครื่องคำนวณออนไลน์ฟรีสำหรับคนไทย"
  description="Kamnuanlek (คำนวณเลข) คือเครื่องคำนวณออนไลน์ฟรีสำหรับคนไทย ครอบคลุมภาษี สินเชื่อ เงินเดือน ค่าไฟ และอีก 800+ รายการ อัปเดตอัตราราชการปี 2569"
  canonical={`${siteUrl}/เกี่ยวกับ-kamnuanlek/`}
  pageName="เกี่ยวกับ Kamnuanlek"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrganizationFull)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebPage)} />

  <article class="max-w-3xl mx-auto px-4 py-8">

    <h1 class="text-3xl font-extrabold text-gray-900 mb-4">
      เกี่ยวกับ Kamnuanlek (คำนวณเลข)
    </h1>
    <p class="text-lg text-gray-600 mb-8 leading-relaxed">
      Kamnuanlek คือแพลตฟอร์มเครื่องคำนวณออนไลน์<strong>ฟรี 100%</strong>สำหรับคนไทย
      ออกแบบมาเพื่อช่วยให้คนไทยคำนวณตัวเลขสำคัญในชีวิตประจำวันได้อย่างถูกต้องและรวดเร็ว
      โดยไม่ต้องสมัครสมาชิกหรือเสียค่าใช้จ่ายใดๆ
    </p>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">เราคือใคร</h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        Kamnuanlek (คำนวณเลข) ก่อตั้งขึ้นเพื่อแก้ปัญหาที่คนไทยทั่วไปพบเจอ:
        การคำนวณภาษี สินเชื่อ เงินเดือน และค่าใช้จ่ายต่างๆ มักซับซ้อน ต้องอาศัยความเข้าใจกฎหมายและอัตราราชการที่เปลี่ยนแปลงอยู่เสมอ
      </p>
      <p class="text-gray-700 leading-relaxed mb-4">
        เราสร้างเครื่องคำนวณที่ใช้อัตราและสูตรที่ถูกต้องตามกฎหมายไทย
        อ้างอิงจากหน่วยงานราชการโดยตรง และอัปเดตทุกครั้งที่มีการเปลี่ยนแปลงอัตราทางการ
      </p>
      <p class="text-gray-700 leading-relaxed">
        ปัจจุบัน Kamnuanlek มีเครื่องคำนวณกว่า <strong>800 รายการ</strong>
        ครอบคลุมหมวดภาษี สินเชื่อ เงินเดือน ค่าสาธารณูปโภค สุขภาพ ยานยนต์ อสังหาริมทรัพย์ ธุรกิจ และอีกมากมาย
        ทั้งหมดเป็นภาษาไทย และใช้งานได้ทันทีบนมือถือ
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">หมวดเครื่องคำนวณหลัก</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="bg-blue-50 rounded-xl p-4">
          <h3 class="font-semibold text-blue-900 mb-2">ภาษีและการเงิน</h3>
          <ul class="text-sm text-blue-800 space-y-1">
            <li>• ภาษีเงินได้บุคคลธรรมดา</li>
            <li>• ภาษีมูลค่าเพิ่ม (VAT 7%)</li>
            <li>• ภาษีที่ดินและสิ่งปลูกสร้าง</li>
            <li>• ประกันสังคมมาตรา 33, 39, 40</li>
          </ul>
        </div>
        <div class="bg-green-50 rounded-xl p-4">
          <h3 class="font-semibold text-green-900 mb-2">สินเชื่อและการออม</h3>
          <ul class="text-sm text-green-800 space-y-1">
            <li>• ผ่อนบ้าน (สินเชื่อที่อยู่อาศัย)</li>
            <li>• ผ่อนรถยนต์</li>
            <li>• ดอกเบี้ยเงินฝาก</li>
            <li>• วางแผนเกษียณ</li>
          </ul>
        </div>
        <div class="bg-purple-50 rounded-xl p-4">
          <h3 class="font-semibold text-purple-900 mb-2">เงินเดือนและแรงงาน</h3>
          <ul class="text-sm text-purple-800 space-y-1">
            <li>• เงินเดือนสุทธิ (หักภาษีและประกันสังคม)</li>
            <li>• ค่าโอที (OT) ตาม พ.ร.บ. คุ้มครองแรงงาน</li>
            <li>• ค่าแรงขั้นต่ำ 77 จังหวัด</li>
            <li>• เงินชดเชยเลิกจ้าง</li>
          </ul>
        </div>
        <div class="bg-orange-50 rounded-xl p-4">
          <h3 class="font-semibold text-orange-900 mb-2">ค่าสาธารณูปโภค</h3>
          <ul class="text-sm text-orange-800 space-y-1">
            <li>• ค่าไฟฟ้า MEA/PEA อัตราก้าวหน้า</li>
            <li>• ค่าน้ำประปา MWA/PWA</li>
            <li>• ค่าโอนบ้านและอสังหาฯ</li>
            <li>• ค่าคอนโดรายเดือน</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">แหล่งข้อมูลที่เราอ้างอิง</h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        ทุกอัตราและสูตรที่ใช้ใน Kamnuanlek อ้างอิงจากหน่วยงานราชการไทย:
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="text-left p-3 font-semibold text-gray-800 border border-gray-200">หน่วยงาน</th>
              <th class="text-left p-3 font-semibold text-gray-800 border border-gray-200">ข้อมูลที่ใช้</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="p-3 border border-gray-200 font-medium">กรมสรรพากร (rd.go.th)</td>
              <td class="p-3 border border-gray-200 text-gray-600">อัตราภาษีเงินได้บุคคลธรรมดา, VAT, ค่าลดหย่อน</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="p-3 border border-gray-200 font-medium">สำนักงานประกันสังคม (sso.go.th)</td>
              <td class="p-3 border border-gray-200 text-gray-600">อัตราประกันสังคมมาตรา 33, 39, 40</td>
            </tr>
            <tr>
              <td class="p-3 border border-gray-200 font-medium">การไฟฟ้านครหลวง MEA (mea.or.th)</td>
              <td class="p-3 border border-gray-200 text-gray-600">อัตราค่าไฟฟ้าตามช่วงหน่วย + Ft + VAT</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="p-3 border border-gray-200 font-medium">การไฟฟ้าส่วนภูมิภาค PEA (pea.co.th)</td>
              <td class="p-3 border border-gray-200 text-gray-600">อัตราค่าไฟฟ้าภูมิภาค</td>
            </tr>
            <tr>
              <td class="p-3 border border-gray-200 font-medium">การประปานครหลวง MWA</td>
              <td class="p-3 border border-gray-200 text-gray-600">อัตราค่าน้ำประปานครหลวง</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="p-3 border border-gray-200 font-medium">ธนาคารแห่งประเทศไทย BOT (bot.or.th)</td>
              <td class="p-3 border border-gray-200 text-gray-600">อัตราดอกเบี้ย MRR/MLR, อัตราแลกเปลี่ยน</td>
            </tr>
            <tr>
              <td class="p-3 border border-gray-200 font-medium">กรมที่ดิน</td>
              <td class="p-3 border border-gray-200 text-gray-600">ค่าธรรมเนียมโอนอสังหาริมทรัพย์</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="p-3 border border-gray-200 font-medium">กระทรวงแรงงาน</td>
              <td class="p-3 border border-gray-200 text-gray-600">ค่าแรงขั้นต่ำรายจังหวัด, กฎหมายคุ้มครองแรงงาน</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-gray-500 mt-3">
        อัปเดตล่าสุดสำหรับปีพุทธศักราช 2569 (ค.ศ. 2026)
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">หลักการของเรา</h2>
      <div class="space-y-4">
        <div class="flex gap-3">
          <span class="text-2xl">🎯</span>
          <div>
            <h3 class="font-semibold text-gray-900">ความถูกต้อง</h3>
            <p class="text-gray-600 text-sm">สูตรและอัตราทุกตัวได้รับการตรวจสอบเทียบกับกฎหมายและประกาศราชการปัจจุบัน</p>
          </div>
        </div>
        <div class="flex gap-3">
          <span class="text-2xl">📱</span>
          <div>
            <h3 class="font-semibold text-gray-900">ใช้งานง่ายบนมือถือ</h3>
            <p class="text-gray-600 text-sm">ออกแบบสำหรับมือถือเป็นหลัก ทุกเครื่องคำนวณใช้งานได้ทันทีโดยไม่ต้องติดตั้งแอป</p>
          </div>
        </div>
        <div class="flex gap-3">
          <span class="text-2xl">🔓</span>
          <div>
            <h3 class="font-semibold text-gray-900">ฟรีตลอดกาล</h3>
            <p class="text-gray-600 text-sm">ไม่มีค่าสมาชิก ไม่ต้องลงทะเบียน ทุกเครื่องคำนวณใช้ได้ฟรี 100% รายได้มาจากโฆษณาเท่านั้น</p>
          </div>
        </div>
        <div class="flex gap-3">
          <span class="text-2xl">🇹🇭</span>
          <div>
            <h3 class="font-semibold text-gray-900">สร้างสำหรับคนไทย</h3>
            <p class="text-gray-600 text-sm">ทุกอย่างเป็นภาษาไทย รองรับระบบปีพุทธศักราช และใช้อัตราที่ถูกต้องสำหรับประเทศไทยโดยเฉพาะ</p>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">ข้อจำกัดความรับผิดชอบ</h2>
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-sm text-yellow-900">
        <p class="mb-2">
          <strong>ข้อมูลบน Kamnuanlek มีไว้เพื่อการคำนวณเบื้องต้นเท่านั้น</strong>
          ไม่ใช่คำแนะนำทางกฎหมาย ภาษี หรือการเงินอย่างเป็นทางการ
        </p>
        <p>
          สำหรับการตัดสินใจทางภาษีหรือการเงินที่สำคัญ ควรปรึกษานักบัญชี นักกฎหมาย หรือผู้เชี่ยวชาญที่ได้รับใบอนุญาต
          อัตราที่แสดงอ้างอิงจากประกาศราชการ แต่อาจมีการเปลี่ยนแปลงโดยไม่แจ้งล่วงหน้า
        </p>
      </div>
    </section>

    <section>
      <h2 class="text-xl font-bold text-gray-900 mb-4">ลิงก์ที่เกี่ยวข้อง</h2>
      <ul class="space-y-2 text-blue-700">
        <li>
          <a href="/" class="hover:underline">← หน้าแรก — เครื่องคำนวณทั้งหมด</a>
        </li>
        <li>
          <a href="/บทความ/" class="hover:underline">บทความและคู่มือการคำนวณ</a>
        </li>
        <li>
          <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="hover:underline">เครื่องคำนวณภาษีเงินได้บุคคลธรรมดา</a>
        </li>
        <li>
          <a href="/คำนวณเงินเดือนสุทธิ/" class="hover:underline">เครื่องคำนวณเงินเดือนสุทธิ</a>
        </li>
        <li>
          <a href="/คำนวณผ่อนบ้าน/" class="hover:underline">เครื่องคำนวณผ่อนบ้าน</a>
        </li>
      </ul>
    </section>

  </article>
</BaseLayout>
