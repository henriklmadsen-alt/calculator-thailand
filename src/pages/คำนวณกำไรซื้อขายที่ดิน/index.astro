---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณกำไรซื้อขายที่ดิน อสังหาฯ 2569 | Kamnuanlek';
const pageDescription = 'คำนวณกำไรสุทธิจากการขายที่ดินและอสังหาฯ 2569 ฟรี — หักค่าโอน ภาษี ค่าซ่อม ดอกเบี้ย รู้ว่าได้กำไรจริงเท่าไร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณกำไรซื้อขายที่ดิน/`;

const faqData = [
  {
    question: 'Property Flip คืออะไร?',
    answer: 'Property Flip คือการซื้อที่ดิน ปรับปรุง และขายไปในระยะเวลาสั้น (โดยปกติ 1-3 ปี) เพื่อหากำไรจากความแตกต่างราคา',
  },
  {
    question: 'ต้นทุนที่ต้องพิจารณาคืออะไร?',
    answer: 'ค่าจัดหาเงิน (ดอกเบี้ยกู้ยืม) + ค่าซ่อมแซมปรับปรุง + ค่าธรรมเนียมโอนซื้อ 2% + ค่าธรรมเนียมโอนขาย 2% + ภาษีธุรกิจเฉพาะหรือแสตมป์ (ผู้ขาย) + ค่าจดทะเบียน + ค่าตัวจริง/ค่าสำรวจ',
  },
  {
    question: 'ดอกเบี้ยกู้ยืมคิดอย่างไร?',
    answer: 'คิดจากจำนวนเงินกู้และระยะเวลาถือครอง ถ้าซื้อ 2.5 ล้านบาท กู้ 80% (2 ล้าน) ดอกเบี้ย 5% ต่อปี เวลา 2 ปี ดอกเบี้ยประมาณ 200,000 บาท',
  },
  {
    question: 'ค่าปรับปรุงอย่างไร?',
    answer: 'ค่าปรับปรุง คืออาคาร ระบบวัสดุ แต่ที่ดินไม่ได้ปรับปรุง ใส่ค่าปรับปรุงตามประเมิน หรือตามค่าจ้างช่างและวัสดุ',
  },
  {
    question: 'ขายได้ราคาเท่าไหร่ถึงจะคุ้ม?',
    answer: 'กำไรสุทธิ = ราคาขาย - (ต้นทุนจัดหา + ดอกเบี้ย + ค่าปรับปรุง + ค่าธรรมเนียมโอนซื้อ/ขาย) ต้องขายให้สูงกว่าต้นทุนรวมถึงค่าใช้จ่ายตรง',
  },
,
  { question: 'ค่าโอนบ้านปี 2569 คิดอัตราเท่าไร?', answer: 'ค่าธรรมเนียมโอน 2% ของราคาประเมิน (ลดเหลือ 1% สำหรับที่อยู่อาศัยราคาไม่เกิน 3 ล้าน จนถึง 31 ธ.ค. 2568), ค่าจดจำนอง 1% ของวงเงิน (ลดเหลือ 0.01% สำหรับกู้ไม่เกิน 3 ล้าน)' },
  { question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ต่างกันอย่างไร?', answer: 'ภาษีธุรกิจเฉพาะ 3.3% (ถือครองน้อยกว่า 5 ปีหรือไม่ได้มีชื่อในทะเบียนบ้าน) | อากรแสตมป์ 0.5% (ถือครอง 5 ปีขึ้นไปและมีชื่อในทะเบียนบ้านครบ 1 ปี) เสียอย่างใดอย่างหนึ่ง' },
  { question: 'ราคาประเมินกรมที่ดินกับราคาตลาดต่างกันอย่างไร?', answer: 'ราคาประเมินคือราคาที่กรมที่ดินกำหนดเพื่อใช้คิดค่าธรรมเนียม อัปเดตทุก 4 ปี มักต่ำกว่าราคาตลาด 20-50% ภาษีและค่าธรรมเนียมใช้ราคาประเมินหรือราคาซื้อขาย แล้วแต่อย่างไหนสูงกว่า' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณกำไรซื้อขายที่ดิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณกำไรซื้อขายที่ดิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คิดกำไรก่อนลงทุน</p>
      <p class="mt-1 text-sm text-slate-700">ตัดค่าใช้จ่ายทั้งหมด ดูกำไรสุทธิที่แท้จริง</p>
      <p class="mt-1 text-xs font-medium text-sky-800">ตามอัตราตลาดไทย 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณกำไร Property Flip (ซื้อขายที่ดิน)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณกำไรสุทธิจากการซื้อและขายที่ดิน
      ตัดค่าธรรมเนียมโอน ดอกเบี้ยกู้ยืม ค่าปรับปรุง ภาษี และค่าใช้จ่ายอื่น
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ข้อมูลการซื้อขาย</h2>

      <form id="property-flip-form" class="space-y-6">
        <div class="bg-blue-50 border border-blue-100 rounded-lg p-4 mb-4">
          <h3 class="font-semibold text-blue-900 mb-2">ราคาซื้อและราคาขาย</h3>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="purchase-price" class="block text-sm font-medium text-gray-700 mb-1">
                ราคาซื้อ (บาท)
              </label>
              <input
                type="text"
                id="purchase-price"
                inputmode="numeric"
                placeholder="เช่น 2,000,000"
                value="2000000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
            <div>
              <label for="sale-price" class="block text-sm font-medium text-gray-700 mb-1">
                ราคาขาย (บาท)
              </label>
              <input
                type="text"
                id="sale-price"
                inputmode="numeric"
                placeholder="เช่น 2,500,000"
                value="2500000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
          </div>
        </div>

        <div class="bg-green-50 border border-green-100 rounded-lg p-4 mb-4">
          <h3 class="font-semibold text-green-900 mb-2">การจัดหาเงิน</h3>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="loan-percent" class="block text-sm font-medium text-gray-700 mb-1">
                ร้อยละเงินกู้ (%)
              </label>
              <input
                type="text"
                id="loan-percent"
                inputmode="numeric"
                placeholder="เช่น 80"
                value="80"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
              <p class="mt-1 text-xs text-gray-500">เช่น 80% = ดาวน์ 20%</p>
            </div>
            <div>
              <label for="loan-rate" class="block text-sm font-medium text-gray-700 mb-1">
                ดอกเบี้ย (%) ต่อปี
              </label>
              <input
                type="text"
                id="loan-rate"
                inputmode="numeric"
                placeholder="เช่น 5"
                value="5"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
          </div>
        </div>

        <div class="bg-orange-50 border border-orange-100 rounded-lg p-4 mb-4">
          <h3 class="font-semibold text-orange-900 mb-2">ค่าปรับปรุงและค่าใช้จ่าย</h3>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="renovation-cost" class="block text-sm font-medium text-gray-700 mb-1">
                ค่าปรับปรุง (บาท)
              </label>
              <input
                type="text"
                id="renovation-cost"
                inputmode="numeric"
                placeholder="เช่น 200,000"
                value="200000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
            <div>
              <label for="holding-period" class="block text-sm font-medium text-gray-700 mb-1">
                ระยะเวลาถือครอง (เดือน)
              </label>
              <input
                type="text"
                id="holding-period"
                inputmode="numeric"
                placeholder="เช่น 18"
                value="18"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
          </div>
        </div>

        <div class="bg-purple-50 border border-purple-100 rounded-lg p-4">
          <h3 class="font-semibold text-purple-900 mb-2">ค่าธรรมเนียมและภาษี</h3>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="registration-cost" class="block text-sm font-medium text-gray-700 mb-1">
                ค่าจดทะเบียน/สำรวจ (บาท)
              </label>
              <input
                type="text"
                id="registration-cost"
                inputmode="numeric"
                placeholder="เช่น 5,000"
                value="5000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
            <div>
              <label for="other-cost" class="block text-sm font-medium text-gray-700 mb-1">
                ค่าอื่น (บาท)
              </label>
              <input
                type="text"
                id="other-cost"
                inputmode="numeric"
                placeholder="เช่น 10,000"
                value="10000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
              />
            </div>
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณกำไร
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณกำไร</h2>

        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center border border-blue-100">
            <div class="text-sm text-gray-600 mb-1">ราคาซื้อ</div>
            <div id="result-purchase" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center border border-green-100">
            <div class="text-sm text-gray-600 mb-1">ราคาขาย</div>
            <div id="result-sale" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center border border-red-100">
            <div class="text-sm text-gray-600 mb-1">ส่วนต่างราคา</div>
            <div id="result-price-diff" class="text-xl font-bold text-red-700">-</div>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 mb-6">
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">ต้นทุนทั้งหมด</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600">ราคาซื้อ</span>
                <span id="cost-purchase" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ค่าธรรมเนียมโอนซื้อ (2%)</span>
                <span id="cost-buy-transfer" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ดอกเบี้ยกู้ยืม</span>
                <span id="cost-interest" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ค่าปรับปรุง</span>
                <span id="cost-renovation" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ค่าจดทะเบียน/สำรวจ</span>
                <span id="cost-registration" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ค่าอื่น</span>
                <span id="cost-other" class="font-medium">-</span>
              </div>
              <div class="flex justify-between border-t border-gray-200 pt-2 mt-2 font-semibold">
                <span>รวมต้นทุน</span>
                <span id="total-cost" class="text-gray-900">-</span>
              </div>
            </div>
          </div>

          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">ค่าใช้จ่ายการขาย</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600">ค่าธรรมเนียมโอนขาย (2%)</span>
                <span id="cost-sell-transfer" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ภาษีธุรกิจเฉพาะ (3.3%)</span>
                <span id="cost-sbt" class="font-medium">-</span>
              </div>
              <div class="flex justify-between border-t border-gray-200 pt-2 mt-2 font-semibold">
                <span>รวมค่าขาย</span>
                <span id="total-sell-cost" class="text-gray-900">-</span>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-lg bg-green-50 border border-green-200 p-6">
          <div class="text-center">
            <p class="text-sm text-gray-600 mb-2">กำไรสุทธิ</p>
            <p id="net-profit" class="text-4xl font-bold text-green-700 mb-2">-</p>
            <p id="roi-percent" class="text-sm text-green-600 font-semibold">-</p>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณกำไรซื้อขายที่ดิน/" />
    <RelatedCalculators currentHref="/คำนวณกำไรซื้อขายที่ดิน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการเท่านั้น อาจไม่คำนึงถึงความเสี่ยง สภาวะตลาด และการเปลี่ยนแปลงอัตราดอกเบี้ย
    </div>
  </article>

  <script>
    function parseNumber(val: string): number {
      return Math.max(0, parseFloat(val.replace(/,/g, '')) || 0);
    }

    function formatThai(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(Math.round(num));
    }

    const form = document.getElementById('property-flip-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const purchasePrice = parseNumber((document.getElementById('purchase-price') as HTMLInputElement).value);
      const salePrice = parseNumber((document.getElementById('sale-price') as HTMLInputElement).value);
      const loanPercent = parseNumber((document.getElementById('loan-percent') as HTMLInputElement).value) / 100;
      const loanRate = parseNumber((document.getElementById('loan-rate') as HTMLInputElement).value) / 100;
      const renovationCost = parseNumber((document.getElementById('renovation-cost') as HTMLInputElement).value);
      const holdingMonths = parseNumber((document.getElementById('holding-period') as HTMLInputElement).value);
      const registrationCost = parseNumber((document.getElementById('registration-cost') as HTMLInputElement).value);
      const otherCost = parseNumber((document.getElementById('other-cost') as HTMLInputElement).value);

      // Calculate loan and interest
      const loanAmount = purchasePrice * loanPercent;
      const holdingYears = holdingMonths / 12;
      const interest = loanAmount * loanRate * holdingYears;

      // Calculate transfer fees
      const buyTransferFee = purchasePrice * 0.02;
      const sellTransferFee = salePrice * 0.02;
      const sbtTax = salePrice * 0.033;

      // Calculate total costs
      const totalCost = purchasePrice + buyTransferFee + interest + renovationCost + registrationCost + otherCost;
      const totalSellCost = sellTransferFee + sbtTax;
      const totalExpenses = totalCost + totalSellCost;

      const netProfit = salePrice - totalExpenses;
      const roiPercent = (netProfit / totalCost) * 100;

      // Update display
      (document.getElementById('result-purchase') as HTMLElement).textContent = `${formatThai(purchasePrice)} บาท`;
      (document.getElementById('result-sale') as HTMLElement).textContent = `${formatThai(salePrice)} บาท`;
      (document.getElementById('result-price-diff') as HTMLElement).textContent = `${formatThai(salePrice - purchasePrice)} บาท`;

      (document.getElementById('cost-purchase') as HTMLElement).textContent = `${formatThai(purchasePrice)} บาท`;
      (document.getElementById('cost-buy-transfer') as HTMLElement).textContent = `${formatThai(buyTransferFee)} บาท`;
      (document.getElementById('cost-interest') as HTMLElement).textContent = `${formatThai(interest)} บาท`;
      (document.getElementById('cost-renovation') as HTMLElement).textContent = `${formatThai(renovationCost)} บาท`;
      (document.getElementById('cost-registration') as HTMLElement).textContent = `${formatThai(registrationCost)} บาท`;
      (document.getElementById('cost-other') as HTMLElement).textContent = `${formatThai(otherCost)} บาท`;
      (document.getElementById('total-cost') as HTMLElement).textContent = `${formatThai(totalCost)} บาท`;

      (document.getElementById('cost-sell-transfer') as HTMLElement).textContent = `${formatThai(sellTransferFee)} บาท`;
      (document.getElementById('cost-sbt') as HTMLElement).textContent = `${formatThai(sbtTax)} บาท`;
      (document.getElementById('total-sell-cost') as HTMLElement).textContent = `${formatThai(totalSellCost)} บาท`;

      (document.getElementById('net-profit') as HTMLElement).textContent = `${formatThai(netProfit)} บาท`;
      (document.getElementById('roi-percent') as HTMLElement).textContent = `ROI: ${roiPercent.toFixed(2)}% (${holdingMonths} เดือน)`;

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('property_flip');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('property_flip');
    });

    form.addEventListener('input', () => {
      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('property_flip');
    }, { once: true });
  </script>
</BaseLayout>
