---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณผ่อนกู้ — เครื่องคำนวณสินเชื่อออนไลน์ฟรี';
const pageDescription = 'คำนวณค่าผ่อนสินเชื่อ ดอกเบี้ยบ้าน สินเชื่อรถ สินเชื่อส่วนบุคคล ทั้งแบบลดต้นลดดอก (reducing balance) และแบบคงที่ (flat rate) พร้อมตารางผ่อนชำระ';
const siteUrl = 'https://calculator-thailand.up.railway.app';
const canonical = `${siteUrl}/คำนวณผ่อนกู้/`;

const faqData = [
  {
    question: 'ดอกเบี้ยแบบลดต้นลดดอก (reducing balance) คืออะไร?',
    answer: 'ดอกเบี้ยแบบลดต้นลดดอกคำนวณจากยอดเงินต้นคงเหลือในแต่ละงวด เมื่อผ่อนไปเรื่อยๆ เงินต้นลดลง ดอกเบี้ยก็ลดลงด้วย ทำให้จ่ายดอกเบี้ยรวมน้อยกว่าแบบคงที่ สินเชื่อบ้านมักใช้วิธีนี้',
  },
  {
    question: 'ดอกเบี้ยแบบคงที่ (flat rate) คืออะไร?',
    answer: 'ดอกเบี้ยแบบคงที่คำนวณจากเงินต้นทั้งก้อนตลอดระยะเวลากู้ ค่างวดเท่ากันทุกเดือน แต่ดอกเบี้ยรวมจะสูงกว่าแบบลดต้นลดดอก มักใช้กับสินเชื่อรถและสินเชื่อส่วนบุคคล',
  },
  {
    question: 'สินเชื่อบ้านดอกเบี้ยกี่เปอร์เซ็นต์?',
    answer: 'ดอกเบี้ยสินเชื่อบ้านในไทยปี 2567 อยู่ที่ประมาณ 5-7% ต่อปี ขึ้นอยู่กับธนาคารและเงื่อนไข ดอกเบี้ยปีแรกมักเป็นอัตราพิเศษ (เช่น 3%) แล้วปรับเป็นอัตราลอยตัวในปีถัดไป',
  },
  {
    question: 'ผ่อนกี่ปีดีที่สุด?',
    answer: 'ระยะเวลาผ่อนที่เหมาะสมขึ้นอยู่กับความสามารถในการผ่อน ผ่อนสั้นจ่ายดอกเบี้ยน้อยแต่ค่างวดสูง ผ่อนยาวค่างวดต่ำแต่ดอกเบี้ยรวมมาก สินเชื่อบ้านมักผ่อนได้สูงสุด 30 ปี สินเชื่อรถ 5-7 ปี',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผ่อนกู้',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณผ่อนกู้ — สินเชื่อบ้าน สินเชื่อรถ สินเชื่อส่วนบุคคล
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าผ่อนชำระรายเดือน ดอกเบี้ยรวม และตารางผ่อนชำระ ทั้งแบบลดต้นลดดอกและแบบคงที่
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="loan-form" class="space-y-5">
        <div>
          <label for="principal" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนเงินกู้ (บาท)
          </label>
          <input
            type="text"
            id="principal"
            inputmode="numeric"
            placeholder="เช่น 3,000,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="interest-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราดอกเบี้ยต่อปี (%)
            </label>
            <input
              type="text"
              id="interest-rate"
              inputmode="decimal"
              placeholder="เช่น 6.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="term-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาผ่อน (ปี)
            </label>
            <input
              type="text"
              id="term-years"
              inputmode="numeric"
              placeholder="เช่น 20"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <!-- Method Toggle -->
        <fieldset>
          <legend class="text-sm font-semibold text-gray-900 mb-2">วิธีคำนวณดอกเบี้ย</legend>
          <div class="flex gap-4">
            <label class="flex items-center gap-2">
              <input type="radio" name="method" value="reducing" checked class="w-4 h-4 text-primary-600" />
              <span class="text-sm text-gray-700">ลดต้นลดดอก (สินเชื่อบ้าน)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="radio" name="method" value="flat" class="w-4 h-4 text-primary-600" />
              <span class="text-sm text-gray-700">แบบคงที่ (สินเชื่อรถ)</span>
            </label>
          </div>
        </fieldset>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <!-- Summary Cards -->
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่างวดต่อเดือน</div>
            <div id="res-monthly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยรวม</div>
            <div id="res-interest" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดชำระรวม</div>
            <div id="res-total" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">วิธีคำนวณ</div>
            <div id="res-method" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>

        <!-- Summary Details -->
        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินกู้</span>
            <span id="res-principal" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">อัตราดอกเบี้ยต่อปี</span>
            <span id="res-rate" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนงวด</span>
            <span id="res-term" class="font-medium">-</span>
          </div>
        </div>

        <!-- Amortization Schedule -->
        <details class="mt-4">
          <summary class="cursor-pointer font-semibold text-gray-900 hover:text-primary-600 mb-2">
            ตารางผ่อนชำระ (คลิกเพื่อดู)
          </summary>
          <div class="overflow-x-auto mt-2">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-gray-500 border-b border-gray-200">
                  <th class="py-2 pr-2">งวดที่</th>
                  <th class="py-2 pr-2 text-right">ค่างวด</th>
                  <th class="py-2 pr-2 text-right">เงินต้น</th>
                  <th class="py-2 pr-2 text-right">ดอกเบี้ย</th>
                  <th class="py-2 text-right">ยอมคงเหลือ</th>
                </tr>
              </thead>
              <tbody id="schedule-body"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณค่าผ่อนสินเชื่อ</h2>

      <p>
        การคำนวณค่าผ่อนสินเชื่อเป็นขั้นตอนสำคัญก่อนตัดสินใจกู้เงิน
        ไม่ว่าจะเป็นสินเชื่อบ้าน สินเชื่อรถยนต์ หรือสินเชื่อส่วนบุคคล
        เครื่องคำนวณนี้ช่วยให้คุณเปรียบเทียบค่าผ่อนและดอกเบี้ยรวมได้ง่าย
        รองรับทั้งวิธีลดต้นลดดอกและวิธีคงที่
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ดอกเบี้ยแบบลดต้นลดดอก (Reducing Balance)</h3>

      <p>
        ดอกเบี้ยคำนวณจากยอดเงินต้นคงเหลือในแต่ละงวด ค่างวดเท่ากันทุกเดือน
        แต่สัดส่วนเงินต้นและดอกเบี้ยเปลี่ยนไป เดือนแรกๆ จ่ายดอกเบี้ยมาก
        เดือนหลังๆ จ่ายเงินต้นมาก วิธีนี้ดอกเบี้ยรวมจะน้อยกว่าแบบคงที่
        ใช้กับสินเชื่อบ้านเป็นหลัก
      </p>

      <p>
        สูตร: ค่างวด = P × [r(1+r)ⁿ] / [(1+r)ⁿ - 1]
        โดย P = เงินต้น, r = อัตราดอกเบี้ยต่อเดือน, n = จำนวนงวด
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ดอกเบี้ยแบบคงที่ (Flat Rate)</h3>

      <p>
        ดอกเบี้ยคำนวณจากเงินต้นเต็มจำนวนตลอดระยะเวลากู้ ค่างวดและดอกเบี้ยต่อเดือนเท่ากันทุกงวด
        วิธีนี้คำนวณง่ายแต่ดอกเบี้ยรวมสูงกว่าแบบลดต้นลดดอก
        มักใช้กับสินเชื่อรถยนต์และสินเชื่อส่วนบุคคล
      </p>

      <p>สูตร: ค่างวด = (เงินต้น + ดอกเบี้ยรวม) ÷ จำนวนงวด</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการคำนวณ</h3>

      <p>
        กู้เงิน 3,000,000 บาท ดอกเบี้ย 6.5% ต่อปี ผ่อน 20 ปี:
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>ลดต้นลดดอก:</strong> ค่างวดประมาณ 22,362 บาท/เดือน ดอกเบี้ยรวม 2,366,843 บาท</li>
        <li><strong>แบบคงที่:</strong> ค่างวดประมาณ 28,750 บาท/เดือน ดอกเบี้ยรวม 3,900,000 บาท</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เคล็ดลับการกู้เงิน</h3>

      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ค่างวดไม่ควรเกิน 30-40% ของรายได้ต่อเดือน</li>
        <li>เปรียบเทียบข้อเสนอจากหลายสถาบันการเงิน</li>
        <li>ตรวจสอบค่าธรรมเนียมและประกันที่ต้องจ่ายเพิ่ม</li>
        <li>พิจารณาการผ่อนเพิ่มเพื่อลดระยะเวลาและดอกเบี้ยรวม</li>
        <li>สินเชื่อบ้านมักใช้ลดต้นลดดอก — ดอกเบี้ยรวมน้อยกว่า</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">เครื่องคำนวณที่เกี่ยวข้อง</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="block p-4 bg-white rounded-lg shadow-sm border border-gray-200 hover:border-primary-500 transition-colors">
          <span class="text-primary-600 font-medium">คำนวณภาษีเงินได้บุคคลธรรมดา</span>
          <span class="text-gray-400 text-sm block">ภาษีเงินได้ตามขั้นบันได 2567</span>
        </a>
        <a href="/คำนวณภาษีมูลค่าเพิ่ม/" class="block p-4 bg-white rounded-lg shadow-sm border border-gray-200 hover:border-primary-500 transition-colors">
          <span class="text-primary-600 font-medium">คำนวณ VAT 7%</span>
          <span class="text-gray-400 text-sm block">บวก/แยก VAT จากราคา</span>
        </a>
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ค่างวดจริงอาจแตกต่างตามเงื่อนไขของสถาบันการเงิน ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('loan-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const principal = parseNum((document.getElementById('principal') as HTMLInputElement).value);
      const annualRate = parseFloat((document.getElementById('interest-rate') as HTMLInputElement).value.replace(/,/g, '')) || 0;
      const termYears = parseNum((document.getElementById('term-years') as HTMLInputElement).value);
      const method = (document.querySelector('input[name="method"]:checked') as HTMLInputElement).value as 'reducing' | 'flat';

      if (principal <= 0) { (document.getElementById('principal') as HTMLInputElement).focus(); return; }
      if (termYears <= 0) { (document.getElementById('term-years') as HTMLInputElement).focus(); return; }

      const termMonths = Math.round(termYears * 12);
      const monthlyRate = annualRate / 100 / 12;

      let monthlyPayment: number;
      let schedule: { payment: number; principalPart: number; interestPart: number; remaining: number }[] = [];

      if (method === 'reducing') {
        if (monthlyRate === 0) {
          monthlyPayment = principal / termMonths;
        } else {
          monthlyPayment = principal * (monthlyRate * Math.pow(1 + monthlyRate, termMonths)) /
            (Math.pow(1 + monthlyRate, termMonths) - 1);
        }
        let balance = principal;
        for (let m = 0; m < termMonths; m++) {
          const interestPart = balance * monthlyRate;
          const principalPart = monthlyPayment - interestPart;
          balance = Math.max(0, balance - principalPart);
          schedule.push({ payment: monthlyPayment, principalPart, interestPart, remaining: balance });
        }
      } else {
        const totalInterest = principal * (annualRate / 100) * (termMonths / 12);
        monthlyPayment = (principal + totalInterest) / termMonths;
        const monthlyPrincipal = principal / termMonths;
        const monthlyInterest = totalInterest / termMonths;
        let balance = principal;
        for (let m = 0; m < termMonths; m++) {
          balance = Math.max(0, balance - monthlyPrincipal);
          schedule.push({ payment: monthlyPayment, principalPart: monthlyPrincipal, interestPart: monthlyInterest, remaining: balance });
        }
      }

      const totalPaid = schedule.reduce((s, r) => s + r.payment, 0);
      const totalInterest = totalPaid - principal;

      // Update summary
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthlyPayment) + ' บาท';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(totalPaid) + ' บาท';
      (document.getElementById('res-method') as HTMLElement).textContent = method === 'reducing' ? 'ลดต้นลดดอก' : 'แบบคงที่';
      (document.getElementById('res-principal') as HTMLElement).textContent = fmt(principal) + ' บาท';
      (document.getElementById('res-rate') as HTMLElement).textContent = annualRate.toFixed(2) + '%';
      (document.getElementById('res-term') as HTMLElement).textContent = termMonths + ' งวด (' + termYears + ' ปี)';

      // Amortization table — show first 24 months + every 12th month after
      const tbody = document.getElementById('schedule-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';

      schedule.forEach((row, i) => {
        const monthNum = i + 1;
        const show = monthNum <= 24 || monthNum % 12 === 0 || monthNum === termMonths;
        if (!show) return;

        // Add separator if gap
        if (monthNum > 25 && (monthNum - 1) % 12 !== 0) {
          const sep = document.createElement('tr');
          sep.innerHTML = '<td colspan="5" class="py-1 text-center text-gray-400 text-xs">⋮</td>';
          tbody.appendChild(sep);
        }

        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';
        tr.innerHTML = `
          <td class="py-2 pr-2 text-gray-600">${monthNum}</td>
          <td class="py-2 pr-2 text-right">${fmt(row.payment)}</td>
          <td class="py-2 pr-2 text-right">${fmt(row.principalPart)}</td>
          <td class="py-2 pr-2 text-right">${fmt(row.interestPart)}</td>
          <td class="py-2 text-right">${fmt(row.remaining)}</td>
        `;
        tbody.appendChild(tr);
      });

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
