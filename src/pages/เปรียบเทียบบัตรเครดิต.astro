---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เปรียบเทียบบัตรเครดิต — ดอกเบี้ย ค่าธรรมเนียม ปิดหนี้เร็ว | Kamnuanlek"
  description="เครื่องคำนวณบัตรเครดิตฟรี คำนวณดอกเบี้ย กับดักจ่ายขั้นต่ำ ระยะเวลาปิดหนี้ และเปรียบเทียบค่าธรรมเนียมรายปี บริหารหนี้บัตรเครดิตได้ฉลาดขึ้น"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เปรียบเทียบบัตรเครดิต — ดอกเบี้ย ค่าธรรมเนียม ปิดหนี้เร็ว", "item": "https://www.kamnuanlek.com/เปรียบเทียบบัตรเครดิต/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณและคู่มือบัตรเครดิต</h1>
    <p class="text-xl text-gray-600 mb-12">
      ทำความเข้าใจค่าใช้จ่ายบัตรเครดิตและบริหารหนี้อย่างชาญฉลาด คำนวณดอกเบี้ย ระยะเวลาปิดหนี้ และความคุ้มค่าของค่าธรรมเนียมรายปี
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณดอกเบี้ยบัตรเครดิต/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">💳</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณดอกเบี้ยบัตรเครดิต</h3>
        <p class="text-gray-600 mb-3">คำนวณดอกเบี้ยที่ต้องจ่ายจากยอดค้างชำระ ที่อัตราสูงสุด 18% ต่อปี (1.5%/เดือน) ตามกฎ ธปท.</p>
        <span class="text-primary-600 font-medium">คำนวณดอกเบี้ย →</span>
      </a>

      <a href="/คำนวณจ่ายขั้นต่ำบัตรเครดิต/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">⏳</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">เครื่องคำนวณการจ่ายขั้นต่ำ</h3>
        <p class="text-gray-600 mb-3">ดูว่าต้องใช้เวลานานเท่าไรกว่าจะปิดหนี้ หากจ่ายแค่ขั้นต่ำทุกเดือน (เฉลยก่อน: มักเกิน 10 ปี)</p>
        <span class="text-primary-600 font-medium">คำนวณ →</span>
      </a>
    </div>

    <div class="p-6 bg-red-50 border border-red-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">⚠️ กับดักการจ่ายขั้นต่ำ</h2>
      <p class="text-gray-700 mb-4">ตัวอย่าง: หนี้บัตรเครดิต 50,000 บาท ดอกเบี้ย 18%/ปี (1.5%/เดือน) จ่ายขั้นต่ำ 2%:</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="p-4 bg-white rounded-lg border border-red-100 text-center">
          <p class="text-2xl font-bold text-red-700">กว่า 27 ปี</p>
          <p class="text-gray-700 font-medium mt-1">ระยะเวลาปิดหนี้</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-red-100 text-center">
          <p class="text-2xl font-bold text-red-700">127,000 บาท</p>
          <p class="text-gray-700 font-medium mt-1">ดอกเบี้ยรวมที่ต้องจ่าย</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-red-100 text-center">
          <p class="text-2xl font-bold text-green-700">3.5 ปี</p>
          <p class="text-gray-700 font-medium mt-1">หากจ่าย 2,000 บาท/เดือน</p>
        </div>
      </div>
    </div>

    <div class="p-6 bg-green-50 border border-green-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">เคล็ดลับใช้บัตรเครดิตอย่างฉลาด</h2>
      <ul class="space-y-3 text-gray-700">
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">✓</span>
          <span><strong>ชำระเต็มจำนวนทุกเดือน</strong> — หลีกเลี่ยงดอกเบี้ยได้ทั้งหมด บัตรส่วนใหญ่มีระยะปลอดดอกเบี้ย 30-55 วัน</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">✓</span>
          <span><strong>อัตราสูงสุด 18%/ปี</strong> — เพดานของ ธปท. ไม่ควรจ่ายเกิน 1.5%/เดือน</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">✓</span>
          <span><strong>โอนยอดหนี้</strong> — บางธนาคารเสนอ 0% สำหรับ 3-6 เดือนเมื่อโอนยอดหนี้</span>
        </li>
        <li class="flex gap-3">
          <span class="text-green-600 font-bold">✓</span>
          <span><strong>เงินคืน vs แต้มสะสม</strong> — สำหรับคนส่วนใหญ่ บัตร Cashback ให้ประโยชน์คุ้มค่ากว่า</span>
        </li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/เปรียบเทียบสินเชื่อ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏦 คู่มือเปรียบเทียบสินเชื่อ</span>
          <p class="text-gray-600 text-sm mt-2">สินเชื่อบุคคล vs บัตรเครดิต อันไหนดีกว่า?</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 ศูนย์รวมเครื่องคำนวณการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">เครื่องมือการเงินทุกประเภทในที่เดียว</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
