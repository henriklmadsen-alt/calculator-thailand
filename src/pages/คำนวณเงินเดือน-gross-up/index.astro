---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเงินเดือน Gross-up ปี 2569 ต้องรับ Gross เท่าไรให้ได้ Net ที่ต้องการ | Kamnuanlek';
const pageDescription = 'คำนวณ Gross-up เงินเดือน หาเงินเดือน Gross ที่ต้องได้รับเพื่อให้ได้ยอด Net หลังหักภาษีและประกันสังคมตามที่ต้องการ อัปเดตอัตราภาษีปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินเดือน-gross-up/`;

const faqData = [
  {
    question: 'Gross-up เงินเดือนคืออะไร?',
    answer: 'Gross-up คือการคำนวณหาเงินเดือน Gross (ก่อนหัก) ที่ต้องได้รับ เพื่อให้เหลือเงินสุทธิ (Net) ตามที่ต้องการหลังจากหักภาษีเงินได้และเงินสมทบประกันสังคมแล้ว',
  },
  {
    question: 'ทำไมต้องคำนวณ Gross-up?',
    answer: 'ใช้เมื่อนายจ้างต้องการให้พนักงานได้รับเงินสุทธิตามจำนวนที่ตกลงกัน หรือเมื่อพนักงานต้องการทราบว่าควรขอเงินเดือน Gross เท่าไรให้ Net ที่ได้เป็นตามที่ต้องการ',
  },
  {
    question: 'การคำนวณ Gross-up ใช้วิธีอะไร?',
    answer: 'ใช้วิธีวนซ้ำ (iteration) เพราะภาษีคำนวณจาก Gross ซึ่งเป็นตัวแปรที่ต้องหา ระบบจะปรับ Gross ทีละน้อยจนได้ Net ตรงกับที่ต้องการภายใน 0.01 บาท',
  },
  {
    question: 'SSC มาตรา 33 คิดอย่างไร?',
    answer: 'ประกันสังคมมาตรา 33 คิด 5% ของค่าจ้างจริง แต่ฐานขั้นต่ำ 1,650 บาท และสูงสุด 15,000 บาท ดังนั้นเงินสมทบสูงสุดคือ 750 บาท/เดือน',
  },
,
  { question: 'ค่าแรงขั้นต่ำปี 2569 อยู่ที่เท่าไร?', answer: 'ค่าแรงขั้นต่ำปี 2568-2569 กรุงเทพและปริมณฑล 370-400 บาท/วัน ต่างจังหวัดอยู่ที่ 330-370 บาท/วัน ขึ้นอยู่กับจังหวัด ตรวจสอบอัตราล่าสุดได้จากกระทรวงแรงงาน mol.go.th' },
  { question: 'เงินเดือนสุทธิคำนวณจากอะไรบ้าง?', answer: 'เงินเดือนสุทธิ = เงินเดือนรวม - ภาษีหัก ณ ที่จ่าย - เงินสมทบประกันสังคม (5% สูงสุด 750 บาท) - กองทุนสำรองเลี้ยงชีพ (ถ้ามี) นายจ้างจ่ายประกันสังคมเพิ่มอีกฝ่าย 5%' },
  { question: 'OT คำนวณอย่างไร?', answer: 'วันธรรมดา: 1.5 เท่าของค่าจ้างปกติต่อชั่วโมง | วันหยุด: 2 เท่า (ชั่วโมงปกติ) และ 3 เท่า (เกินเวลาปกติ) | ตามพระราชบัญญัติคุ้มครองแรงงาน พ.ศ. 2541' },
  { question: 'กองทุนสำรองเลี้ยงชีพมีประโยชน์อย่างไร?', answer: 'เป็นเงินออมระยะยาวที่นายจ้างสมทบ (1-15% ของค่าจ้าง) + ลดหย่อนภาษีได้สูงสุด 15% ของรายได้หรือ 500,000 บาท + ผลตอบแทนจากการลงทุน ดึงออกได้เมื่อออกจากงานหรือเกษียณ' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินเดือน Gross-up',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินเดือน Gross-up">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">อัปเดตเกณฑ์ปี 2569</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณตามอัตราภาษีเงินได้บุคคลธรรมดาขั้นบันได 0-35% และประกันสังคมมาตรา 33 สูงสุด 750 บาท/เดือน</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับ HR นายจ้าง และพนักงานที่ต้องการเจรจาเงินเดือน Net</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณเงินเดือน Gross-up ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกยอดเงินเดือนสุทธิ (Net) ที่ต้องการ และตัวเลือกเพิ่มเติม ระบบจะคำนวณหาเงินเดือน Gross ที่ต้องได้รับก่อนหักภาษีและประกันสังคม
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="grossup-form" class="space-y-5">
        <p id="grossup-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="desired-net" class="mb-1 block text-sm font-medium text-gray-700">
              เงินเดือนสุทธิที่ต้องการ (บาท/เดือน)
            </label>
            <input
              type="text"
              id="desired-net"
              inputmode="numeric"
              placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p id="desired-net-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="personal-allowance" class="mb-1 block text-sm font-medium text-gray-700">
              ค่าลดหย่อนส่วนตัวเพิ่มเติม (บาท/ปี)
            </label>
            <input
              type="text"
              id="personal-allowance"
              inputmode="numeric"
              placeholder="เช่น 0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ค่าลดหย่อนส่วนตัว 60,000 บาท/ปี รวมอยู่แล้ว</p>
          </div>
        </div>

        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">รวมประกันสังคม มาตรา 33?</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 text-sm">
              <input type="radio" name="include-ssc" value="yes" checked class="accent-primary-600" /> รวม (5% สูงสุด 750 บาท)
            </label>
            <label class="flex items-center gap-2 text-sm">
              <input type="radio" name="include-ssc" value="no" class="accent-primary-600" /> ไม่รวม
            </label>
          </div>
        </div>

        <button
          type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          คำนวณ Gross-up
        </button>
      </form>
    </div>

    <div id="grossup-results" class="mb-8 hidden border-2 border-primary-600 bg-primary-50 rounded-lg p-6 shadow-sm">
      <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ Gross-up</h2>

      <div class="mb-6 grid gap-3 sm:grid-cols-3">
        <div class="rounded-lg bg-white p-4 text-center border border-gray-200">
          <div class="mb-1 text-sm text-gray-600">เงินเดือน Gross ที่ต้องการ</div>
          <div id="res-gross" class="text-lg sm:text-2xl lg:text-3xl font-bold text-green-700">-</div>
        </div>
        <div class="rounded-lg bg-white p-4 text-center border border-gray-200">
          <div class="mb-1 text-sm text-gray-600">เงินเดือนสุทธิ (Net)</div>
          <div id="res-net" class="text-lg sm:text-2xl lg:text-3xl font-bold text-primary-700">-</div>
        </div>
        <div class="rounded-lg bg-white p-4 text-center border border-gray-200">
          <div class="mb-1 text-sm text-gray-600">ยอดหักรวม</div>
          <div id="res-total-deduction" class="text-lg sm:text-2xl lg:text-3xl font-bold text-amber-700">-</div>
        </div>
      </div>

      <div class="space-y-2 text-sm">
        <div class="flex justify-between border-b border-gray-100 py-1">
          <span class="text-gray-600">เงินเดือน Gross</span>
          <span id="res-gross2" class="font-medium">-</span>
        </div>
        <div class="flex justify-between border-b border-gray-100 py-1">
          <span class="text-gray-600">ประกันสังคม (5% สูงสุด 750 บาท)</span>
          <span id="res-ssc" class="font-medium text-red-600">-</span>
        </div>
        <div class="flex justify-between border-b border-gray-100 py-1">
          <span class="text-gray-600">ภาษีเงินได้หัก ณ ที่จ่าย (ต่อเดือน)</span>
          <span id="res-tax" class="font-medium text-red-600">-</span>
        </div>
        <div class="flex justify-between border-b border-gray-100 py-1 font-semibold">
          <span class="text-gray-800">เงินเดือนสุทธิ</span>
          <span id="res-net2" class="text-green-700">-</span>
        </div>
      </div>

      <details class="mt-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4">
        <summary class="font-semibold text-yellow-900 cursor-pointer select-none hover:text-yellow-800 transition-colors">
          ⚠️ สำคัญ: หมายเหตุเกี่ยวกับการคำนวณ
        </summary>
        <div class="mt-3 text-sm text-yellow-800 space-y-2">
          <p>• ผลการคำนวณนี้เป็นการประมาณการเพื่อวางแผนเบื้องต้น ตัวเลขจริงอาจต่างตามค่าลดหย่อนส่วนบุคคลและรายได้อื่น</p>
          <p>• ระบบคำนวณตามอัตราภาษีเงินได้บุคคลธรรมดาปี 2569 และประกันสังคมมาตรา 33</p>
          <p>• หากมีค่าลดหย่อนพิเศษเพิ่มเติม (ประกันชีวิต SSF/RMF บุตร) ผลลัพธ์อาจเปลี่ยนแปลง</p>
          <p>• สำหรับการวางแผนเงินเดือนที่แม่นยำ ปรึกษาผู้เชี่ยวชาญด้านภาษีหรือบัญชี</p>
        </div>
      </details>
    </div>

    <div class="my-8 border-t-2 border-gray-200"></div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">วิธีคำนวณ Gross-up</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าลดหย่อนค่าใช้จ่าย = Gross × 12 × 50% แต่ไม่เกิน 100,000 บาท/ปี</li>
        <li>ค่าลดหย่อนส่วนตัว = 60,000 บาท/ปี + ค่าลดหย่อนอื่นๆ ที่ระบุ</li>
        <li>SSC = min(Gross × 5%, 750) บาท/เดือน (ถ้าเลือกรวม)</li>
        <li>รายได้สุทธิต่อปี = Gross × 12 − ค่าลดหย่อนทั้งหมด − SSC × 12</li>
        <li>ภาษี/ปี คำนวณตามขั้นบันได 0%/5%/10%/15%/20%/25%/30%/35%</li>
        <li>Net = Gross − SSC − ภาษี/เดือน</li>
        <li>ระบบวนหา Gross ที่ทำให้ Net ตรงกับที่ต้องการ</li>
      </ul>

      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">อัตราภาษีเงินได้ปี 2569</h3>
      <table class="w-full text-sm">
        <thead><tr class="bg-gray-50"><th class="p-2 text-left">รายได้สุทธิต่อปี</th><th class="p-2 text-right">อัตราภาษี</th></tr></thead>
        <tbody>
          <tr><td class="p-2">0 - 150,000</td><td class="p-2 text-right">ยกเว้น</td></tr>
          <tr class="bg-gray-50"><td class="p-2">150,001 - 300,000</td><td class="p-2 text-right">5%</td></tr>
          <tr><td class="p-2">300,001 - 500,000</td><td class="p-2 text-right">10%</td></tr>
          <tr class="bg-gray-50"><td class="p-2">500,001 - 750,000</td><td class="p-2 text-right">15%</td></tr>
          <tr><td class="p-2">750,001 - 1,000,000</td><td class="p-2 text-right">20%</td></tr>
          <tr class="bg-gray-50"><td class="p-2">1,000,001 - 2,000,000</td><td class="p-2 text-right">25%</td></tr>
          <tr><td class="p-2">2,000,001 - 5,000,000</td><td class="p-2 text-right">30%</td></tr>
          <tr class="bg-gray-50"><td class="p-2">มากกว่า 5,000,000</td><td class="p-2 text-right">35%</td></tr>
        </tbody>
      </table>

      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a> — คำนวณ Net จาก Gross</li>
        <li><a href="/คำนวณประกันสังคม/">คำนวณประกันสังคม</a> — รายละเอียดเงินสมทบ SSC</li>
        <li><a href="/คำนวณขึ้นเงินเดือน/">คำนวณขึ้นเงินเดือน</a> — ผลของการปรับเงินเดือน</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#grossup-results" />
    <RelatedArticles currentHref="/คำนวณเงินเดือน-gross-up/" />
    <RelatedCalculators currentHref="/คำนวณเงินเดือน-gross-up/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการเพื่อวางแผนเบื้องต้น ตัวเลขจริงอาจต่างกันตามค่าลดหย่อนส่วนบุคคลและรายได้อื่น ควรปรึกษาผู้เชี่ยวชาญด้านภาษีเพื่อการวางแผนที่แม่นยำ
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }

    function calcAnnualTax(netIncome) {
      if (netIncome <= 0) return 0;
      const brackets = [
        [150000, 0.00],
        [150000, 0.05],
        [200000, 0.10],
        [250000, 0.15],
        [250000, 0.20],
        [1000000, 0.25],
        [3000000, 0.30],
        [Infinity, 0.35],
      ];
      let tax = 0;
      let remaining = netIncome;
      for (const [size, rate] of brackets) {
        if (remaining <= 0) break;
        const chunk = Math.min(remaining, size);
        tax += chunk * rate;
        remaining -= chunk;
      }
      return tax;
    }

    function calcSSC(gross) {
      return Math.min(Math.max(gross, 1650), 15000) * 0.05;
    }

    function calcNet(gross, extraAllowance, includeSsc) {
      const ssc = includeSsc ? calcSSC(gross) : 0;
      const annualGross = gross * 12;
      const expenseDeduction = Math.min(annualGross * 0.5, 100000);
      const personalAllowance = 60000 + (extraAllowance || 0);
      const annualSSC = ssc * 12;
      const netIncome = Math.max(annualGross - expenseDeduction - personalAllowance - annualSSC, 0);
      const annualTax = calcAnnualTax(netIncome);
      const monthlyTax = annualTax / 12;
      return { net: gross - ssc - monthlyTax, ssc, tax: monthlyTax };
    }

    function grossUp(desiredNet, extraAllowance, includeSsc) {
      let gross = desiredNet * 1.3;
      for (let i = 0; i < 1000; i++) {
        const { net } = calcNet(gross, extraAllowance, includeSsc);
        const diff = desiredNet - net;
        if (Math.abs(diff) < 0.01) break;
        gross += diff * 0.5;
        if (gross < desiredNet) gross = desiredNet;
      }
      return gross;
    }

    function setText(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }

    const form = document.getElementById('grossup-form');
    const formError = document.getElementById('grossup-form-error');
    const resultBox = document.getElementById('grossup-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      document.getElementById('desired-net-error').classList.add('hidden');

      const desiredNet = parseNum(document.getElementById('desired-net').value);
      const extraAllowance = parseNum(document.getElementById('personal-allowance').value) || 0;
      const includeSsc = document.querySelector('input[name="include-ssc"]:checked').value === 'yes';

      if (!Number.isFinite(desiredNet) || desiredNet <= 0) {
        document.getElementById('desired-net-error').textContent = 'กรอกเงินเดือนสุทธิที่ต้องการ (มากกว่า 0)';
        document.getElementById('desired-net-error').classList.remove('hidden');
        formError.classList.remove('hidden');
        resultBox.classList.add('hidden');
        return;
      }

      const gross = grossUp(desiredNet, extraAllowance, includeSsc);
      const { net, ssc, tax } = calcNet(gross, extraAllowance, includeSsc);
      const totalDeduction = ssc + tax;

      setText('res-gross', formatMoney(gross));
      setText('res-net', formatMoney(net));
      setText('res-total-deduction', formatMoney(totalDeduction));
      setText('res-gross2', formatMoney(gross));
      setText('res-ssc', `−${formatMoney(ssc)}`);
      setText('res-tax', `−${formatMoney(tax)}`);
      setText('res-net2', formatMoney(net));

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
