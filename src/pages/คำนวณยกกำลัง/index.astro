---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณยกกำลัง aⁿ และเลขชี้กำลัง ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณยกกำลัง aⁿ เลขชี้กำลัง กำลังสอง กำลังสาม และค่า e^x ฟรี พร้อมตัวอย่าง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณยกกำลัง/`;

const faqData = [
  {
    question: 'การยกกำลังศูนย์คืออะไร? a⁰ เท่ากับเท่าไหร่?',
    answer: 'ทุกจำนวน (ยกเว้น 0) ที่ยกกำลัง 0 จะได้ผลเท่ากับ 1 เสมอ เช่น 5⁰ = 1, 100⁰ = 1 เป็นนิยามทางคณิตศาสตร์ที่ช่วยให้กฎเลขชี้กำลังสอดคล้องกัน ส่วน 0⁰ นั้นยังเป็นประเด็นที่ถกเถียงกันในแวดวงคณิตศาสตร์',
  },
  {
    question: 'เลขชี้กำลังติดลบหมายความว่าอะไร?',
    answer: 'a⁻ⁿ = 1/aⁿ เช่น 2⁻³ = 1/2³ = 1/8 = 0.125 เลขชี้กำลังติดลบหมายถึงส่วนกลับ (reciprocal) ของค่าที่ยกกำลังบวก ใช้บ่อยในสัญกรณ์วิทยาศาสตร์และสูตรดอกเบี้ยทบต้น',
  },
  {
    question: 'e คืออะไร ทำไมถึงสำคัญในคณิตศาสตร์?',
    answer: 'e (จำนวน Euler) มีค่าประมาณ 2.71828 เป็นฐานของลอการิทึมธรรมชาติ (ln) ใช้ในสูตรการเติบโตแบบเอ็กซ์โพเนนเชียล ดอกเบี้ยทบต้นต่อเนื่อง (continuous compounding) และสมการเชิงอนุพันธ์ เป็นค่าคงที่สำคัญในแคลคูลัสและฟิสิกส์',
  },
  {
    question: '10^x ต่างจาก e^x อย่างไร?',
    answer: '10^x ใช้ฐาน 10 เหมาะสำหรับสัญกรณ์วิทยาศาสตร์และการวัดระดับ เช่น pH ระดับเดซิเบล ส่วน e^x ใช้ฐาน e ≈ 2.71828 เหมาะสำหรับอธิบายการเติบโต/ลดลงตามธรรมชาติ เช่น การสลายตัวของสารกัมมันตรังสี การเพิ่มจำนวนของแบคทีเรีย',
  },
  {
    question: 'เลขชี้กำลังเป็นเศษส่วนได้ไหม?',
    answer: 'ได้ เลขชี้กำลังเป็นเศษส่วน เช่น a^(1/2) = √a และ a^(2/3) = (∛a)² ใช้ในการคำนวณรากและในสูตรต่างๆ ทางวิทยาศาสตร์ เครื่องคำนวณนี้รองรับเลขชี้กำลังทุกรูปแบบ ทั้งจำนวนเต็ม เศษส่วน และทศนิยม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณยกกำลังและเลขชี้กำลัง',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'EducationApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณยกกำลัง aⁿ',
  description: 'ขั้นตอนการคำนวณยกกำลัง เลขชี้กำลัง และฟังก์ชันเอ็กซ์โพเนนเชียล',
  step: [
    {
      '@type': 'HowToStep',
      name: 'เลือกโหมดการคำนวณ',
      text: 'เลือกระหว่าง aⁿ (ยกกำลังทั่วไป), e^x (ฟังก์ชันเอ็กซ์โพเนนเชียลธรรมชาติ) หรือ 10^x (ยกกำลัง 10)',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกค่าฐาน (base)',
      text: 'สำหรับ aⁿ ให้กรอกค่าฐาน a เช่น 2, 3, 10 หรือจำนวนทศนิยมใดก็ได้',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกเลขชี้กำลัง',
      text: 'กรอกค่าเลขชี้กำลัง n เช่น 3 สำหรับกำลังสาม หรือ -1 สำหรับส่วนกลับ ค่าเป็นบวก ลบ หรือทศนิยมได้',
    },
    {
      '@type': 'HowToStep',
      name: 'กดคำนวณและอ่านผลลัพธ์',
      text: 'กดปุ่ม "คำนวณ" ผลลัพธ์จะแสดงทั้งในรูปทศนิยมและสัญกรณ์วิทยาศาสตร์หากค่ามีขนาดใหญ่มากหรือเล็กมาก',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณยกกำลัง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณยกกำลัง aⁿ, e^x และ 10^x ในหน้าเดียว</p>
      <p class="mt-1 text-sm text-slate-700">รองรับเลขชี้กำลังติดลบ เศษส่วน และทศนิยม พร้อมแสดงสัญกรณ์วิทยาศาสตร์</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณยกกำลัง aⁿ และเลขชี้กำลัง ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณการยกกำลังทุกรูปแบบ ทั้ง aⁿ แบบทั่วไป ฟังก์ชัน e^x สำหรับการเติบโตแบบธรรมชาติ
      และ 10^x สำหรับสัญกรณ์วิทยาศาสตร์ เหมาะสำหรับงานคณิตศาสตร์ วิทยาศาสตร์ และวิศวกรรม
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'สสวท. (SciMath): เลขชี้กำลังและลอการิทึม',
        'ECMAScript specification: Math.pow, Math.exp',
      ]}
      assumptions={[
        'ผลลัพธ์คำนวณจากข้อมูลที่ผู้ใช้กรอกเท่านั้น',
        'ตัวเลขที่ใหญ่มากอาจแสดงในรูปสัญกรณ์วิทยาศาสตร์โดยอัตโนมัติ',
      ]}
      references={[
        {
          label: 'SciMath: เลขยกกำลังและกฎการคำนวณ',
          href: 'https://www.scimath.org/article-mathematics/item/11474-3',
        },
      ]}
    />

    <!-- Mode 1: a^n -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">1) ยกกำลัง aⁿ</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: 2³ = 8, 5⁻² = 0.04, 3^0.5 ≈ 1.732051</p>
      <div class="grid gap-3 sm:grid-cols-3">
        <div>
          <label for="pow-base" class="block text-sm font-medium text-gray-700 mb-1">ฐาน a</label>
          <input id="pow-base" type="text" inputmode="decimal" placeholder="เช่น 2" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label for="pow-exp" class="block text-sm font-medium text-gray-700 mb-1">เลขชี้กำลัง n</label>
          <input id="pow-exp" type="text" inputmode="decimal" placeholder="เช่น 3" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div class="flex items-end">
          <button id="btn-pow" type="button" class="w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700">คำนวณ</button>
        </div>
      </div>
      <p id="pow-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="pow-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="pow-result-value" class="text-xl font-bold text-primary-700">-</p>
        <p id="pow-result-sci" class="text-sm text-gray-500 mt-1"></p>
      </div>
    </div>

    <!-- Mode 2: e^x -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">2) e^x (ฟังก์ชันเอ็กซ์โพเนนเชียล)</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: e¹ ≈ 2.718282, e² ≈ 7.389056, e⁻¹ ≈ 0.367879</p>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="sm:col-span-2">
          <label for="exp-x" class="block text-sm font-medium text-gray-700 mb-1">ค่า x</label>
          <input id="exp-x" type="text" inputmode="decimal" placeholder="เช่น 1" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div class="flex items-end">
          <button id="btn-exp" type="button" class="w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700">คำนวณ</button>
        </div>
      </div>
      <p id="exp-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="exp-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="exp-result-value" class="text-xl font-bold text-primary-700">-</p>
        <p id="exp-result-sci" class="text-sm text-gray-500 mt-1"></p>
      </div>
    </div>

    <!-- Mode 3: 10^x -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">3) 10^x (ยกกำลัง 10)</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: 10² = 100, 10³ = 1,000, 10⁻³ = 0.001</p>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="sm:col-span-2">
          <label for="ten-x" class="block text-sm font-medium text-gray-700 mb-1">ค่า x</label>
          <input id="ten-x" type="text" inputmode="decimal" placeholder="เช่น 3" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div class="flex items-end">
          <button id="btn-ten" type="button" class="w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700">คำนวณ</button>
        </div>
      </div>
      <p id="ten-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="ten-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="ten-result-value" class="text-xl font-bold text-primary-700">-</p>
        <p id="ten-result-sci" class="text-sm text-gray-500 mt-1"></p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#ten-result" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">กฎการยกกำลังที่ควรรู้</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>aᵐ × aⁿ = aᵐ⁺ⁿ (คูณฐานเดียวกัน บวกเลขชี้กำลัง)</li>
        <li>aᵐ ÷ aⁿ = aᵐ⁻ⁿ (หารฐานเดียวกัน ลบเลขชี้กำลัง)</li>
        <li>(aᵐ)ⁿ = aᵐⁿ (ยกกำลังซ้อน คูณเลขชี้กำลัง)</li>
        <li>a⁰ = 1 (ทุกจำนวนยกกำลัง 0 ได้ 1)</li>
        <li>a⁻ⁿ = 1/aⁿ (เลขชี้กำลังติดลบ = ส่วนกลับ)</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณยกกำลัง/" />
    <RelatedCalculators currentHref="/คำนวณยกกำลัง/" />
  </article>
</BaseLayout>

<script>
  const parseNum = (v) => parseFloat(String(v).replace(/,/g, '').trim());

  const setError = (id, msg) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg || '';
    msg ? el.classList.remove('hidden') : el.classList.add('hidden');
  };

  const formatResult = (val) => {
    if (!Number.isFinite(val)) return { main: 'ไม่สามารถคำนวณได้', sci: '' };
    const abs = Math.abs(val);
    const main = val.toPrecision(10).replace(/\.?0+$/, '');
    const sci = (abs >= 1e6 || (abs < 1e-4 && abs > 0)) ? `(≈ ${val.toExponential(6)})` : '';
    return { main, sci };
  };

  const showResult = (containerId, valueId, sciId, val) => {
    const c = document.getElementById(containerId);
    const v = document.getElementById(valueId);
    const s = document.getElementById(sciId);
    if (!c || !v) return;
    const { main, sci } = formatResult(val);
    v.textContent = main;
    if (s) s.textContent = sci;
    c.classList.remove('hidden');
  };

  document.getElementById('btn-pow')?.addEventListener('click', () => {
    setError('pow-error', '');
    const a = parseNum(document.getElementById('pow-base')?.value);
    const n = parseNum(document.getElementById('pow-exp')?.value);
    if (!Number.isFinite(a) || !Number.isFinite(n)) { setError('pow-error', 'กรุณากรอกตัวเลขให้ครบ'); return; }
    const result = Math.pow(a, n);
    showResult('pow-result', 'pow-result-value', 'pow-result-sci', result);
  });

  document.getElementById('btn-exp')?.addEventListener('click', () => {
    setError('exp-error', '');
    const x = parseNum(document.getElementById('exp-x')?.value);
    if (!Number.isFinite(x)) { setError('exp-error', 'กรุณากรอกตัวเลขที่ถูกต้อง'); return; }
    const result = Math.exp(x);
    showResult('exp-result', 'exp-result-value', 'exp-result-sci', result);
  });

  document.getElementById('btn-ten')?.addEventListener('click', () => {
    setError('ten-error', '');
    const x = parseNum(document.getElementById('ten-x')?.value);
    if (!Number.isFinite(x)) { setError('ten-error', 'กรุณากรอกตัวเลขที่ถูกต้อง'); return; }
    const result = Math.pow(10, x);
    showResult('ten-result', 'ten-result-value', 'ten-result-sci', result);
  });
</script>
