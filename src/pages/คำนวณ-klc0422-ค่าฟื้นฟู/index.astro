---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าฟื้นฟูร่างกาย | Kamnuanlek';
const pageDescription = 'คำนวณค่าฟื้นฟูร่างกาย Rehabilitation ค่ากายภาพ กิจกรรมบำบัด ศูนย์ฟื้นฟู';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0422-ค่าฟื้นฟู/`;

const faqData = [
  { question: 'ค่าศูนย์ฟื้นฟูผู้ป่วยนอกเดือนละเท่าไหร่?', answer: 'ศูนย์ฟื้นฟูผู้ป่วยนอก 5,000-20,000 บาทต่อเดือน ขึ้นอยู่กับความเข้มข้นของโปรแกรม โรงพยาบาลรัฐถูกกว่าเอกชน 3-5 เท่า' },
  { question: 'กิจกรรมบำบัดราคาเท่าไหร่?', answer: 'กิจกรรมบำบัด (Occupational Therapy) 600-1,500 บาทต่อครั้ง เหมาะสำหรับผู้ป่วยอัมพฤกษ์ อุบัติเหตุ หรือผู้ที่ต้องเรียนรู้ทักษะชีวิตใหม่' },
  { question: 'Stroke ผู้ป่วยโรคหลอดเลือดสมองต้องฟื้นฟูนานแค่ไหน?', answer: 'การฟื้นฟูหลัง Stroke ขึ้นอยู่กับความรุนแรง ระยะเฉียบพลัน 2-4 สัปดาห์ในโรงพยาบาล ฟื้นฟูต่อเนื่อง 3-12 เดือน หรือตลอดชีวิตสำหรับบางราย' },
  { question: 'ประกันสุขภาพคลุมค่าฟื้นฟูไหม?', answer: 'บางประกันครอบคลุมการฟื้นฟูที่ถูกสั่งโดยแพทย์ มักมีเพดานจำนวนครั้งหรือวงเงิน ควรตรวจสอบเงื่อนไขก่อนรับการรักษา' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าฟื้นฟูร่างกาย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าฟื้นฟูร่างกาย</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าใช้จ่ายการฟื้นฟูสมรรถภาพร่างกาย Rehabilitation</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="pt_rehab" class="block text-sm font-medium text-gray-700 mb-1">ค่ากายภาพบำบัดต่อครั้ง (บาท)</label><input type="text" id="pt_rehab" inputmode="decimal" placeholder="เช่น 800" value="800" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="ot_rehab" class="block text-sm font-medium text-gray-700 mb-1">ค่ากิจกรรมบำบัดต่อครั้ง (บาท)</label><input type="text" id="ot_rehab" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="speech_rehab" class="block text-sm font-medium text-gray-700 mb-1">ค่าบำบัดการพูดต่อครั้ง (บาท)</label><input type="text" id="speech_rehab" inputmode="decimal" placeholder="เช่น 0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="sessions_week_rehab" class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้งรวมต่อสัปดาห์</label><input type="number" id="sessions_week_rehab" min="1" max="21" placeholder="เช่น 5" value="5" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="rehab_months" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลาฟื้นฟู (เดือน)</label><input type="number" id="rehab_months" min="1" max="24" placeholder="เช่น 6" value="6" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าฟื้นฟูต่อเดือน</p>
            <p id="monthly_rehab" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมค่าฟื้นฟูทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const ptRehab = parseFloat((document.getElementById('pt_rehab') as HTMLInputElement).value) || 0;
      const otRehab = parseFloat((document.getElementById('ot_rehab') as HTMLInputElement).value) || 0;
      const speechRehab = parseFloat((document.getElementById('speech_rehab') as HTMLInputElement).value) || 0;
      const sessionsWeek = parseInt((document.getElementById('sessions_week_rehab') as HTMLInputElement).value) || 1;
      const months = parseInt((document.getElementById('rehab_months') as HTMLInputElement).value) || 1;

      const avgSessionCost = (ptRehab + otRehab + speechRehab) / 3 || ptRehab;
      const monthlyRehab = avgSessionCost * sessionsWeek * 4.3;
      const total = monthlyRehab * months;

      (document.getElementById('monthly_rehab') as HTMLElement).textContent = Math.round(monthlyRehab).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = Math.round(total).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('rehabilitation-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
