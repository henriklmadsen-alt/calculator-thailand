---
import BaseLayout from '../layouts/BaseLayout.astro';

const mathCalcs = [
  { title: 'Mean Calculator', slug: '/คำนวณ-mean/', desc: 'Calculate average values' },
  { title: 'Median Calculator', slug: '/คำนวณ-median/', desc: 'Find the middle value' },
  { title: 'Standard Deviation', slug: '/คำนวณ-standard-deviation/', desc: 'Measure data spread' },
  { title: 'Correlation Calculator', slug: '/คำนวณ-correlation/', desc: 'Analyze relationships' },
  { title: 'Probability Calculator', slug: '/คำนวณ-probability/', desc: 'Calculate odds' },
  { title: 'Z-Score Calculator', slug: '/คำนวณ-z-score/', desc: 'Standardize values' },
];
---

<BaseLayout
  title="เครื่องคำนวณคณิตศาสตร์และสถิติ — เฉลี่ย มัธยฐาน เปอร์เซ็นต์ | Kamnuanlek"
  description="เครื่องคำนวณคณิตศาสตร์และสถิติฟรี ค่าเฉลี่ย มัธยฐาน ส่วนเบี่ยงเบนมาตรฐาน ความน่าจะเป็น เปอร์เซ็นต์ และอื่นๆ สำหรับนักเรียนและมืออาชีพ"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เครื่องคำนวณคณิตศาสตร์และสถิติ — เฉลี่ย มัธยฐาน เปอร์เซ็นต์", "item": "https://www.kamnuanlek.com/เครื่องคำนวณคณิตศาสตร์/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณคณิตศาสตร์และสถิติ</h1>
    <p class="text-xl text-gray-600 mb-12">
      Essential math and statistical calculators for students, researchers, and professionals. Accurate, fast, free.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {mathCalcs.map((calc) => (
        <a
          href={calc.slug}
          class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all"
        >
          <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-600">{calc.title}</h3>
          <p class="text-gray-600 text-sm mb-4">{calc.desc}</p>
          <span class="text-primary-600 text-sm font-medium">Calculate →</span>
        </a>
      ))}
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Calculators</span>
          <p class="text-gray-600 text-sm mt-2">Tax, loans, and savings calculators</p>
        </a>
        <a href="/เครื่องคำนวณธุรกิจ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 Business Tools</span>
          <p class="text-gray-600 text-sm mt-2">ROE, ROA, break-even analysis, and more</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
