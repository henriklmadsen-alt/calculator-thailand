---
import BaseLayout from '../layouts/BaseLayout.astro';

const mathCalcs = [
  { title: 'เครื่องคำนวณค่าเฉลี่ย', slug: '/คำนวณ-mean/', desc: 'คำนวณค่าเฉลี่ยของข้อมูล' },
  { title: 'เครื่องคำนวณมัธยฐาน', slug: '/คำนวณ-median/', desc: 'หาค่ากลางของข้อมูล' },
  { title: 'ส่วนเบี่ยงเบนมาตรฐาน', slug: '/คำนวณ-standard-deviation/', desc: 'วัดการกระจายตัวของข้อมูล' },
  { title: 'เครื่องคำนวณสหสัมพันธ์', slug: '/คำนวณ-correlation/', desc: 'วิเคราะห์ความสัมพันธ์ระหว่างตัวแปร' },
  { title: 'เครื่องคำนวณความน่าจะเป็น', slug: '/คำนวณ-probability/', desc: 'คำนวณโอกาสเกิดเหตุการณ์' },
  { title: 'เครื่องคำนวณ Z-Score', slug: '/คำนวณ-z-score/', desc: 'แปลงค่าเป็นมาตรฐาน' },
];
---

<BaseLayout
  title="เครื่องคำนวณคณิตศาสตร์และสถิติ — เฉลี่ย มัธยฐาน เปอร์เซ็นต์ | Kamnuanlek"
  description="เครื่องคำนวณคณิตศาสตร์และสถิติฟรี ค่าเฉลี่ย มัธยฐาน ส่วนเบี่ยงเบนมาตรฐาน ความน่าจะเป็น เปอร์เซ็นต์ และอื่นๆ สำหรับนักเรียนและมืออาชีพ"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เครื่องคำนวณคณิตศาสตร์และสถิติ — เฉลี่ย มัธยฐาน เปอร์เซ็นต์", "item": "https://www.kamnuanlek.com/เครื่องคำนวณคณิตศาสตร์/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณคณิตศาสตร์และสถิติ</h1>
    <p class="text-xl text-gray-600 mb-12">
      เครื่องคำนวณคณิตศาสตร์และสถิติที่จำเป็นสำหรับนักเรียน นักวิจัย และมืออาชีพ แม่นยำ รวดเร็ว ฟรี
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {mathCalcs.map((calc) => (
        <a
          href={calc.slug}
          class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all"
        >
          <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-600">{calc.title}</h3>
          <p class="text-gray-600 text-sm mb-4">{calc.desc}</p>
          <span class="text-primary-600 text-sm font-medium">คำนวณ →</span>
        </a>
      ))}
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">เครื่องมือที่เกี่ยวข้อง</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 เครื่องคำนวณการเงิน</span>
          <p class="text-gray-600 text-sm mt-2">ภาษี สินเชื่อ และเครื่องคำนวณออมเงิน</p>
        </a>
        <a href="/เครื่องคำนวณธุรกิจ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 เครื่องมือธุรกิจ</span>
          <p class="text-gray-600 text-sm mt-2">ROE ROA วิเคราะห์จุดคุ้มทุน และอื่นๆ</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
