---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่าธรรมเนียม QR Payment ปี 2569 — สแกนจ่าย PromptPay | Kamnuanlek';
const pageDescription = 'คำนวณค่าธรรมเนียม QR Payment หรือ PromptPay สำหรับร้านค้า ป้อนยอดชำระและอัตราค่าธรรมเนียม ทราบยอดหักและยอดรับจริงทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-QR-payment/`;

const faqData = [
  {
    question: 'ค่าธรรมเนียม QR Payment สำหรับร้านค้าเท่าไหร่?',
    answer: 'ค่าธรรมเนียม QR Payment (PromptPay) สำหรับร้านค้าทั่วไปอยู่ที่ประมาณ 0.55–1.20% ต่อธุรกรรม ขึ้นอยู่กับธนาคารและประเภทธุรกิจ',
  },
  {
    question: 'QR Payment กับบัตรเครดิตต่างกันอย่างไร?',
    answer: 'QR Payment มักมีค่าธรรมเนียมต่ำกว่าบัตรเครดิต (MDR) โดย QR Payment อยู่ที่ ~0.55–1.2% ส่วนบัตรเครดิตอยู่ที่ 1.5–3%',
  },
  {
    question: 'PromptPay มีค่าธรรมเนียมไหม?',
    answer: 'PromptPay บุคคลต่อบุคคลฟรี แต่สำหรับร้านค้าที่รับผ่าน QR Code ธนาคารอาจเก็บค่าธรรมเนียม Settlement ประมาณ 0.55–1.2%',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียม QR Payment',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-QR-payment">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-purple-100 bg-purple-50 p-4">
      <p class="text-sm font-semibold text-purple-700">คำนวณค่าธรรมเนียม QR Payment — Settlement Fee สำหรับร้านค้า</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: ค่าธรรมเนียม = ยอดชำระ × อัตรา% | ยอดรับจริง = ยอดชำระ − ค่าธรรมเนียม</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าธรรมเนียม QR Payment ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกยอดชำระและอัตราค่าธรรมเนียม QR Payment ของธนาคาร เพื่อดูค่าธรรมเนียมและยอดที่ร้านได้รับ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="qr-form" class="space-y-5">
        <p id="qr-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="qr-amount" class="mb-1 block text-sm font-medium text-gray-700">ยอดชำระ (บาท)</label>
            <input type="text" id="qr-amount" inputmode="numeric" placeholder="เช่น 500"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="qr-amount-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="qr-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราค่าธรรมเนียม (%)</label>
            <input type="text" id="qr-rate" inputmode="decimal" placeholder="เช่น 0.55"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="qr-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
            <p class="mt-1 text-xs text-gray-500">ทั่วไป 0.55–1.20%</p>
          </div>
        </div>

        <div>
          <label for="qr-txns" class="mb-1 block text-sm font-medium text-gray-700">จำนวนธุรกรรมต่อเดือน (ครั้ง) — ไม่บังคับ</label>
          <input type="text" id="qr-txns" inputmode="numeric" placeholder="เช่น 300"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณค่าธรรมเนียม
        </button>
      </form>
    </div>

    <div id="qr-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าธรรมเนียม/ครั้ง</div>
            <div id="res-qr-fee" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดรับจริง/ครั้ง</div>
            <div id="res-qr-net" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดชำระ</div>
            <div id="res-qr-gross" class="text-xl font-bold text-blue-700">-</div>
          </div>
        </div>
        <div id="qr-monthly-section" class="hidden space-y-2 text-sm">
          <h3 class="font-medium text-gray-800">สรุปรายเดือน</h3>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ยอดขายรวม/เดือน</span>
            <span id="res-qr-m-gross" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ค่าธรรมเนียมรวม/เดือน</span>
            <span id="res-qr-m-fee" class="font-medium text-red-600">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ยอดรับจริงรวม/เดือน</span>
            <span id="res-qr-m-net" class="font-medium text-green-600">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าธรรมเนียม = ยอดชำระ × (อัตรา% ÷ 100)</li>
        <li>ยอดรับจริง = ยอดชำระ − ค่าธรรมเนียม</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณ-MDR-ค่าธรรมเนียมร้านค้า/">คำนวณ MDR ค่าธรรมเนียมร้านค้า</a></li>
        <li><a href="/คำนวณ-POS-fee/">คำนวณค่าธรรมเนียม POS</a></li>
        <li><a href="/คำนวณ-e-wallet/">คำนวณค่าธรรมเนียม E-Wallet</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#qr-results" />
    <RelatedArticles currentHref="/คำนวณ-QR-payment/" />
    <RelatedCalculators currentHref="/คำนวณ-QR-payment/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> อัตราค่าธรรมเนียมขึ้นอยู่กับธนาคารและประเภทบัญชี ควรยืนยันกับธนาคารก่อนตัดสินใจ
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('qr-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('qr-error').classList.add('hidden');
      ['qr-amount-error','qr-rate-error'].forEach(id => setErr(id, ''));

      const amount = parseNum(document.getElementById('qr-amount').value);
      const rate = parseNum(document.getElementById('qr-rate').value);
      const txns = parseNum(document.getElementById('qr-txns').value);
      let hasError = false;
      if (!Number.isFinite(amount) || amount <= 0) { setErr('qr-amount-error', 'กรอกยอดชำระมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(rate) || rate <= 0 || rate >= 100) { setErr('qr-rate-error', 'กรอกอัตราค่าธรรมเนียม 0.01–99.99%'); hasError = true; }
      if (hasError) { document.getElementById('qr-error').classList.remove('hidden'); document.getElementById('qr-results').classList.add('hidden'); return; }

      const fee = amount * rate / 100;
      const net = amount - fee;

      setText('res-qr-fee', fmt(fee));
      setText('res-qr-net', fmt(net));
      setText('res-qr-gross', fmt(amount));

      const monthlySection = document.getElementById('qr-monthly-section');
      if (Number.isFinite(txns) && txns > 0) {
        setText('res-qr-m-gross', fmt(amount * txns));
        setText('res-qr-m-fee', fmt(fee * txns));
        setText('res-qr-m-net', fmt(net * txns));
        monthlySection.classList.remove('hidden');
      } else {
        monthlySection.classList.add('hidden');
      }

      document.getElementById('qr-results').classList.remove('hidden');
      document.getElementById('qr-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
