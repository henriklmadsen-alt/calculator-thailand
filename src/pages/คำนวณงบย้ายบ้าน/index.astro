---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณงบย้ายบ้าน 2569 | ค่ารถขนของ ค่าแรง ค่าบรรจุภัณฑ์ | Kamnuanlek';
const pageDescription = 'คำนวณค่าใช้จ่ายย้ายบ้าน รถขนของ ค่าแรงงาน ค่าบรรจุภัณฑ์ ตามระยะทางและจำนวนห้อง เพื่อวางแผนงบย้ายบ้านอย่างแม่นยำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบย้ายบ้าน/`;

const faqData = [
  {
    question: 'ค่าย้ายบ้านเฉลี่ยเท่าไร?',
    answer: 'ค่าย้ายบ้านในกรุงเทพฯ ระยะทางใกล้สำหรับ 2 ห้องนอน อยู่ที่ประมาณ 3,000-8,000 บาท หากจ้างทีมครบวงจร (รวมแรงงานและบรรจุภัณฑ์) อาจอยู่ที่ 8,000-20,000 บาทขึ้นไป',
  },
  {
    question: 'ควรเช่ารถขนของเองหรือจ้างบริษัทย้ายบ้าน?',
    answer: 'การเช่ารถขนเองถูกกว่าแต่ต้องใช้แรงงานและเวลาเอง เหมาะสำหรับของน้อยหรือระยะสั้น การจ้างบริษัทย้ายบ้านสะดวกกว่า มีประกันสินค้า แต่ค่าใช้จ่ายสูงกว่า 2-3 เท่า',
  },
  {
    question: 'ควรวางแผนย้ายบ้านล่วงหน้าแค่ไหน?',
    answer: 'แนะนำให้วางแผนย้ายบ้านล่วงหน้าอย่างน้อย 2-4 สัปดาห์ เพื่อมีเวลาคัดแยกของ จองรถหรือบริษัทย้ายบ้าน และแจ้งเปลี่ยนที่อยู่กับหน่วยงานที่เกี่ยวข้อง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบย้ายบ้าน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบย้ายบ้าน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณงบย้ายบ้าน 2569</h1>
    <p class="mb-6 text-gray-600">คำนวณค่าใช้จ่ายย้ายบ้าน รถขนของ ค่าแรงงาน และค่าบรรจุภัณฑ์</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="move-form" class="space-y-4">
        <div>
          <label for="move-distance" class="mb-1 block text-sm font-medium text-gray-700">ระยะทาง (กม.)</label>
          <input id="move-distance" type="text" inputmode="numeric" placeholder="เช่น 20"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="rooms" class="mb-1 block text-sm font-medium text-gray-700">จำนวนห้อง / Studio/1BR/2BR/3BR</label>
          <select id="rooms" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-auto">
            <option value="1">Studio / 1 ห้องนอน</option>
            <option value="2" selected>2 ห้องนอน</option>
            <option value="3">3 ห้องนอน</option>
            <option value="4">4 ห้องนอน+</option>
          </select>
        </div>
        <fieldset>
          <legend class="mb-2 text-sm font-medium text-gray-700">บริการที่ต้องการ</legend>
          <div class="flex flex-wrap gap-2">
            <label class="service-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors">
              <input type="radio" name="service" value="self" class="sr-only" /> เช่ารถเอง
            </label>
            <label class="service-pill cursor-pointer rounded-full border-2 border-primary-500 bg-primary-50 px-4 py-2 text-sm font-medium text-primary-700 transition-colors">
              <input type="radio" name="service" value="labor" class="sr-only" checked /> จ้างทีมย้าย
            </label>
            <label class="service-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors">
              <input type="radio" name="service" value="full" class="sr-only" /> บริการครบวงจร
            </label>
          </div>
        </fieldset>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ค่าใช้จ่ายย้ายบ้าน</h2>
        <div class="mb-6 rounded-lg bg-primary-50 p-4 text-center">
          <div class="mb-1 text-sm text-gray-600">ค่าใช้จ่ายรวม</div>
          <div id="res-total" class="text-4xl font-bold text-primary-700 sm:text-5xl">-</div>
          <div class="mt-1 text-sm text-gray-500">บาท</div>
        </div>
        <div class="space-y-0">
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🚚 ค่ารถขนของ</span>
            <span id="res-truck" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">💪 ค่าแรงงาน</span>
            <span id="res-labor" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-700">📦 ค่าบรรจุภัณฑ์</span>
            <span id="res-pack" class="text-sm font-medium text-gray-900">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedCalculators currentHref="/คำนวณงบย้ายบ้าน/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  // base truck cost + per km, labor base per room, packing per room
  const SERVICE: Record<string, { truckBase: number; truckPerKm: number; laborMult: number; packMult: number }> = {
    self:  { truckBase: 800, truckPerKm: 15, laborMult: 0, packMult: 0.3 },
    labor: { truckBase: 1500, truckPerKm: 20, laborMult: 1.0, packMult: 0.5 },
    full:  { truckBase: 2500, truckPerKm: 25, laborMult: 1.5, packMult: 1.0 },
  };
  const ROOM_BASE_LABOR: Record<string, number> = { '1': 1500, '2': 2500, '3': 3500, '4': 5000 };
  const ROOM_BASE_PACK: Record<string, number>  = { '1': 500,  '2': 800,  '3': 1200, '4': 1800 };

  document.querySelectorAll<HTMLLabelElement>('.service-pill').forEach((pill) => {
    pill.querySelector('input')?.addEventListener('change', () => {
      document.querySelectorAll<HTMLLabelElement>('.service-pill').forEach((p) => {
        p.classList.remove('border-primary-500', 'bg-primary-50', 'text-primary-700');
        p.classList.add('border-gray-200', 'text-gray-700');
      });
      pill.classList.remove('border-gray-200', 'text-gray-700');
      pill.classList.add('border-primary-500', 'bg-primary-50', 'text-primary-700');
    });
  });

  document.getElementById('move-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const distance = parseNum((document.getElementById('move-distance') as HTMLInputElement).value) || 10;
    const rooms = (document.getElementById('rooms') as HTMLSelectElement).value;
    const service = (document.querySelector('input[name="service"]:checked') as HTMLInputElement)?.value ?? 'labor';

    const s = SERVICE[service];
    const truck = s.truckBase + s.truckPerKm * distance;
    const labor = ROOM_BASE_LABOR[rooms] * s.laborMult;
    const pack = ROOM_BASE_PACK[rooms] * s.packMult;
    const total = truck + labor + pack;

    document.getElementById('res-total')!.textContent = fmt(total);
    document.getElementById('res-truck')!.textContent = fmt(truck);
    document.getElementById('res-labor')!.textContent = labor > 0 ? fmt(labor) : '— (ทำเอง)';
    document.getElementById('res-pack')!.textContent = fmt(pack);
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
