---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าเชื้อเพลิง | เบนซิน ดีเซล | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าเชื้อเพลิง ค่าน้ำมันเบนซิน ดีเซล ตามอัตรา 2569 ฟรีออนไลน์';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าเชื้อเพลิง/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเชื้อเพลิง">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเชื้อเพลิง</h1>

    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2">
      <p class="text-xs font-semibold text-blue-800">[ปี 2569 — อัปเดต]</p>
    </div>

    <p class="text-gray-600 mb-6">คำนวณค่าเชื้อเพลิงตามระยะทางและอัตราการบริโภค</p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-3 mb-6">
        <div>
          <label for="distance" class="block text-sm font-medium text-gray-700 mb-1">ระยะทาง (กม.)</label>
          <input type="number" id="distance" placeholder="100" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label for="fuelPrice" class="block text-sm font-medium text-gray-700 mb-1">ราคาน้ำมัน (บาท/ลิตร)</label>
          <input type="number" id="fuelPrice" placeholder="36" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label for="consumption" class="block text-sm font-medium text-gray-700 mb-1">การบริโภค (กม./ลิตร)</label>
          <input type="number" id="consumption" placeholder="6" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
      </div>

      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700">คำนวณ</button>

      <!-- Result -->
      <div id="result" class="hidden mt-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
        <div class="space-y-2">
          <div class="flex justify-between"><span class="text-sm text-gray-700">น้ำมันที่ต้องใช้</span><span id="liters" class="font-semibold">-</span></div>
          <div class="flex justify-between"><span class="text-sm text-gray-700">ค่าเชื้อเพลิงรวม</span><span id="total" class="font-semibold text-lg text-primary-600">-</span></div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  import { calculateFuelCost } from '../../lib/fuel-cost-calculator';

  document.getElementById('btn-calculate').addEventListener('click', () => {
    const distance = parseFloat(document.getElementById('distance').value);
    const fuelPrice = parseFloat(document.getElementById('fuelPrice').value);
    const consumption = parseFloat(document.getElementById('consumption').value);

    if (!distance || !fuelPrice || !consumption) {
      alert('โปรดระบุข้อมูลให้ครบถ้วน');
      return;
    }

    const result = calculateFuelCost({ distance, fuelPrice, fuelConsumption: consumption });
    document.getElementById('liters').textContent = result.litersNeeded.toFixed(2) + ' ลิตร';
    document.getElementById('total').textContent = result.totalCost.toLocaleString('th-TH') + ' บาท';
    document.getElementById('result').classList.remove('hidden');
  });
</script>
