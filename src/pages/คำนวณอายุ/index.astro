---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณอายุ — เครื่องคำนวณอายุจากวันเกิดออนไลน์ฟรี';
const pageDescription = 'คำนวณอายุจากวันเกิด แสดงผลเป็นปี เดือน วัน รองรับปฏิทินไทย (พ.ศ.) พร้อมนับถอยหลังวันเกิดถัดไป ราศี และรุ่น Generation';
const siteUrl = 'https://calculator-thailand-production.up.railway.app';
const canonical = `${siteUrl}/คำนวณอายุ/`;

const currentBEYear = new Date().getFullYear() + 543;

const thaiMonths = [
  'มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน',
  'พฤษภาคม', 'มิถุนายน', 'กรกฎาคม', 'สิงหาคม',
  'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม',
];

const faqData = [
  {
    question: 'พ.ศ. กับ ค.ศ. ต่างกันอย่างไร?',
    answer: 'พ.ศ. (พุทธศักราช) เป็นปฏิทินที่ใช้ในไทย มากกว่า ค.ศ. (คริสต์ศักราช) 543 ปี เช่น ค.ศ. 2024 = พ.ศ. 2567 เครื่องคำนวณนี้ใช้ พ.ศ. เป็นค่าตั้งต้น',
  },
  {
    question: 'คำนวณอายุนับอย่างไร?',
    answer: 'อายุนับจากวันเกิดถึงวันปัจจุบัน นับปีเต็มก่อน แล้วนับเดือนเต็ม สุดท้ายนับวันที่เหลือ เช่น เกิด 15 มกราคม 2530 ถึงวันที่ 20 มีนาคม 2567 = 37 ปี 2 เดือน 5 วัน',
  },
  {
    question: 'Generation (เจเนอเรชัน) แบ่งตามปีเกิดอย่างไร?',
    answer: 'Baby Boomer: 2489-2507 (ค.ศ. 1946-1964), Gen X: 2508-2523 (1965-1980), Gen Y/Millennials: 2524-2539 (1981-1996), Gen Z: 2540-2555 (1997-2012), Gen Alpha: 2556 เป็นต้นไป (2013+)',
  },
  {
    question: 'ราศีคำนวณจากอะไร?',
    answer: 'ราศีคำนวณจากเดือนและวันเกิดตามจักรราศีสากล (Western Zodiac) เช่น เกิด 21 มีนาคม - 19 เมษายน = ราศีเมษ (Aries)',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณอายุ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณอายุ — คำนวณอายุจากวันเกิด ปฏิทิน พ.ศ.
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณอายุจากวันเกิด แสดงผลเป็นปี เดือน วัน พร้อมวันเกิดถัดไป ราศี และรุ่น Generation รองรับปีพุทธศักราช (พ.ศ.)
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="age-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="birth-day" class="block text-sm font-medium text-gray-700 mb-1">
              วันที่เกิด
            </label>
            <select
              id="birth-day"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              {Array.from({ length: 31 }, (_, i) => i + 1).map((d) => (
                <option value={d}>{d}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="birth-month" class="block text-sm font-medium text-gray-700 mb-1">
              เดือนเกิด
            </label>
            <select
              id="birth-month"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              {thaiMonths.map((m, i) => (
                <option value={i + 1}>{m}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="birth-year" class="block text-sm font-medium text-gray-700 mb-1">
              ปีเกิด (พ.ศ.)
            </label>
            <input
              type="text"
              id="birth-year"
              inputmode="numeric"
              placeholder={`เช่น ${currentBEYear - 30}`}
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณอายุ
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <!-- Age Display -->
        <div class="text-center mb-6 p-6 bg-primary-50 rounded-lg">
          <div class="text-sm text-gray-600 mb-2">อายุของคุณ</div>
          <div class="flex items-center justify-center gap-4 flex-wrap">
            <div>
              <span id="res-years" class="text-4xl font-extrabold text-primary-700">-</span>
              <span class="text-lg text-gray-600 ml-1">ปี</span>
            </div>
            <div>
              <span id="res-months" class="text-4xl font-extrabold text-primary-600">-</span>
              <span class="text-lg text-gray-600 ml-1">เดือน</span>
            </div>
            <div>
              <span id="res-days" class="text-4xl font-extrabold text-primary-500">-</span>
              <span class="text-lg text-gray-600 ml-1">วัน</span>
            </div>
          </div>
        </div>

        <!-- Summary Cards -->
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">อายุรวม (วัน)</div>
            <div id="res-total-days" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">อายุรวม (สัปดาห์)</div>
            <div id="res-total-weeks" class="text-xl font-bold text-gray-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">วันเกิดถัดไป</div>
            <div id="res-next-birthday" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-accent-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ราศี</div>
            <div id="res-zodiac" class="text-xl font-bold text-accent-600">-</div>
          </div>
        </div>

        <!-- Detail Info -->
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">วันเกิด (พ.ศ.)</span>
            <span id="res-birth-be" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">วันเกิด (ค.ศ.)</span>
            <span id="res-birth-ce" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">อายุรวม (เดือน)</span>
            <span id="res-total-months" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">รุ่น (Generation)</span>
            <span id="res-generation" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณอายุจากวันเกิด</h2>

      <p>
        เครื่องคำนวณอายุนี้ออกแบบมาสำหรับคนไทยโดยเฉพาะ รองรับปีพุทธศักราช (พ.ศ.)
        ซึ่งเป็นระบบปฏิทินที่ใช้ในไทย คำนวณอายุได้แม่นยำถึงระดับวัน
        พร้อมข้อมูลเสริมที่น่าสนใจอย่างราศีและรุ่น Generation
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">การแปลง พ.ศ. เป็น ค.ศ.</h3>

      <p>
        ปี ค.ศ. = ปี พ.ศ. − 543 เช่น พ.ศ. 2540 = ค.ศ. 1997
        เครื่องคำนวณนี้รับค่าเป็น พ.ศ. และแปลงเป็น ค.ศ. อัตโนมัติ
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ราศีตามวันเกิด</h3>

      <p>ราศี 12 ราศีตามจักรราศีสากล แบ่งตามวันเกิด:</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>ราศีมังกร:</strong> 22 ธ.ค. - 19 ม.ค.</li>
        <li><strong>ราศีกุมภ์:</strong> 20 ม.ค. - 18 ก.พ.</li>
        <li><strong>ราศีมีน:</strong> 19 ก.พ. - 20 มี.ค.</li>
        <li><strong>ราศีเมษ:</strong> 21 มี.ค. - 19 เม.ย.</li>
        <li><strong>ราศีพฤษภ:</strong> 20 เม.ย. - 20 พ.ค.</li>
        <li><strong>ราศีเมถุน:</strong> 21 พ.ค. - 20 มิ.ย.</li>
        <li><strong>ราศีกรกฎ:</strong> 21 มิ.ย. - 22 ก.ค.</li>
        <li><strong>ราศีสิงห์:</strong> 23 ก.ค. - 22 ส.ค.</li>
        <li><strong>ราศีกันย์:</strong> 23 ส.ค. - 22 ก.ย.</li>
        <li><strong>ราศีตุลย์:</strong> 23 ก.ย. - 22 ต.ค.</li>
        <li><strong>ราศีพิจิก:</strong> 23 ต.ค. - 21 พ.ย.</li>
        <li><strong>ราศีธนู:</strong> 22 พ.ย. - 21 ธ.ค.</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">รุ่น Generation ตามปีเกิด</h3>

      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>Baby Boomer:</strong> พ.ศ. 2489-2507 (ค.ศ. 1946-1964)</li>
        <li><strong>Gen X:</strong> พ.ศ. 2508-2523 (ค.ศ. 1965-1980)</li>
        <li><strong>Gen Y / Millennials:</strong> พ.ศ. 2524-2539 (ค.ศ. 1981-1996)</li>
        <li><strong>Gen Z:</strong> พ.ศ. 2540-2555 (ค.ศ. 1997-2012)</li>
        <li><strong>Gen Alpha:</strong> พ.ศ. 2556 เป็นต้นไป (ค.ศ. 2013+)</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">เครื่องคำนวณที่เกี่ยวข้อง</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        <a href="/คำนวณ-bmi/" class="block p-4 bg-white rounded-lg shadow-sm border border-gray-200 hover:border-primary-500 transition-colors">
          <span class="text-primary-600 font-medium">คำนวณ BMI</span>
          <span class="text-gray-400 text-sm block">ดัชนีมวลกาย เกณฑ์เอเชีย</span>
        </a>
        <a href="/คำนวณภาษีเงินได้บุคคลธรรมดา/" class="block p-4 bg-white rounded-lg shadow-sm border border-gray-200 hover:border-primary-500 transition-colors">
          <span class="text-primary-600 font-medium">คำนวณภาษีเงินได้</span>
          <span class="text-gray-400 text-sm block">ภาษีเงินได้ตามขั้นบันได 2567</span>
        </a>
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>หมายเหตุ:</strong> ผลการคำนวณอ้างอิงจากวันที่ปัจจุบันของเครื่องผู้ใช้ ราศีคำนวณตามจักรราศีสากล (Western Zodiac)
    </div>
  </article>

  <script>
    const THAI_MONTHS = [
      'มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน',
      'พฤษภาคม', 'มิถุนายน', 'กรกฎาคม', 'สิงหาคม',
      'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม',
    ];

    const ZODIAC_DATES: [number, number][] = [
      [1, 20], [2, 19], [3, 21], [4, 20], [5, 21], [6, 21],
      [7, 23], [8, 23], [9, 23], [10, 23], [11, 22], [12, 22],
    ];

    const ZODIAC_NAMES = [
      'มังกร (Capricorn)', 'กุมภ์ (Aquarius)', 'มีน (Pisces)',
      'เมษ (Aries)', 'พฤษภ (Taurus)', 'เมถุน (Gemini)',
      'กรกฎ (Cancer)', 'สิงห์ (Leo)', 'กันย์ (Virgo)',
      'ตุลย์ (Libra)', 'พิจิก (Scorpio)', 'ธนู (Sagittarius)',
    ];

    function getZodiac(month: number, day: number): string {
      for (let i = ZODIAC_DATES.length - 1; i >= 0; i--) {
        const [m, d] = ZODIAC_DATES[i];
        if (month > m || (month === m && day >= d)) {
          return ZODIAC_NAMES[(i + 1) % 12];
        }
      }
      return ZODIAC_NAMES[0];
    }

    function getGeneration(ceYear: number): string {
      if (ceYear >= 2013) return 'Gen Alpha (เจนอัลฟา)';
      if (ceYear >= 1997) return 'Gen Z (เจนซี)';
      if (ceYear >= 1981) return 'Gen Y / Millennials (เจนวาย)';
      if (ceYear >= 1965) return 'Gen X (เจนเอ็กซ์)';
      if (ceYear >= 1946) return 'Baby Boomer (เบบี้บูมเมอร์)';
      return 'Silent Generation';
    }

    function fmtNum(n: number): string {
      return new Intl.NumberFormat('th-TH').format(n);
    }

    const form = document.getElementById('age-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const birthDay = parseInt((document.getElementById('birth-day') as HTMLSelectElement).value);
      const birthMonth = parseInt((document.getElementById('birth-month') as HTMLSelectElement).value);
      const birthYearBE = parseInt((document.getElementById('birth-year') as HTMLInputElement).value);

      if (!birthYearBE || birthYearBE < 2443 || birthYearBE > new Date().getFullYear() + 543) {
        (document.getElementById('birth-year') as HTMLInputElement).focus();
        return;
      }

      const ceYear = birthYearBE - 543;
      const birthDate = new Date(ceYear, birthMonth - 1, birthDay);

      // Validate date
      if (birthDate.getDate() !== birthDay || birthDate.getMonth() !== birthMonth - 1) {
        alert('วันที่ไม่ถูกต้อง กรุณาตรวจสอบอีกครั้ง');
        return;
      }

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      if (birthDate > today) {
        alert('วันเกิดต้องไม่เกินวันปัจจุบัน');
        return;
      }

      // Calculate age
      let years = today.getFullYear() - birthDate.getFullYear();
      let months = today.getMonth() - birthDate.getMonth();
      let days = today.getDate() - birthDate.getDate();

      if (days < 0) {
        months--;
        const prevMonth = new Date(today.getFullYear(), today.getMonth(), 0);
        days += prevMonth.getDate();
      }
      if (months < 0) {
        years--;
        months += 12;
      }

      const diffMs = today.getTime() - birthDate.getTime();
      const totalDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
      const totalWeeks = Math.floor(totalDays / 7);
      const totalMonths = years * 12 + months;

      // Next birthday
      let nextBirthday = new Date(today.getFullYear(), birthMonth - 1, birthDay);
      if (nextBirthday <= today) {
        nextBirthday = new Date(today.getFullYear() + 1, birthMonth - 1, birthDay);
      }
      const nextBirthdayDays = Math.ceil((nextBirthday.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));

      // Update UI
      (document.getElementById('res-years') as HTMLElement).textContent = String(years);
      (document.getElementById('res-months') as HTMLElement).textContent = String(months);
      (document.getElementById('res-days') as HTMLElement).textContent = String(days);
      (document.getElementById('res-total-days') as HTMLElement).textContent = fmtNum(totalDays) + ' วัน';
      (document.getElementById('res-total-weeks') as HTMLElement).textContent = fmtNum(totalWeeks) + ' สัปดาห์';
      (document.getElementById('res-next-birthday') as HTMLElement).textContent = nextBirthdayDays === 0 ? 'วันนี้! 🎂' : 'อีก ' + fmtNum(nextBirthdayDays) + ' วัน';
      (document.getElementById('res-zodiac') as HTMLElement).textContent = getZodiac(birthMonth, birthDay);
      (document.getElementById('res-birth-be') as HTMLElement).textContent = birthDay + ' ' + THAI_MONTHS[birthMonth - 1] + ' ' + birthYearBE;
      (document.getElementById('res-birth-ce') as HTMLElement).textContent = birthDay + ' ' + THAI_MONTHS[birthMonth - 1] + ' ' + ceYear;
      (document.getElementById('res-total-months') as HTMLElement).textContent = fmtNum(totalMonths) + ' เดือน';
      (document.getElementById('res-generation') as HTMLElement).textContent = getGeneration(ceYear);

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('age');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('age');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
