---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---
<BaseLayout pageName="คำนวณค่าน้ำหนักกระเป๋าเสริม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <h1 class="text-2xl font-bold mb-4">คำนวณค่าน้ำหนักกระเป๋าเสริม</h1>
  <div class="bg-white p-6 rounded-lg border">
    <input type="number" id="weight" placeholder="น้ำหนัก (กก.)" class="w-full p-2 border rounded mb-2" />
    <select id="airline" class="w-full p-2 border rounded mb-4">
      <option value="fullservice">สายการบินเต็มบริการ</option>
      <option value="budget">สายการบินต้นทุนต่ำ</option>
    </select>
    <button onclick="calculate()" class="bg-primary-600 text-white px-4 py-2 rounded">คำนวณ</button>
    <div id="result" class="hidden mt-4 p-4 bg-blue-50 rounded">
      <div class="flex justify-between"><span>ค่าเพิ่มเติม</span><span id="total" class="font-bold">-</span></div>
    </div>
  </div>
  <script>
    import { calculateLuggageExcess } from '../../lib/luggage-excess-calculator';
    function calculate() {
      const result = calculateLuggageExcess({ weightKg: parseInt(document.getElementById('weight').value), airlineType: document.getElementById('airline').value as any });
      document.getElementById('total').textContent = result.excessFee.toLocaleString('th-TH') + ' บาท';
      document.getElementById('result').classList.remove('hidden');
    }
  </script>

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.anamai.moph.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมอนามัย (anamai.moph.go.th)</a> — เกณฑ์สุขภาพและตัวชี้วัดสำหรับคนไทย</li>
        <li><a href="https://www.moph.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">กระทรวงสาธารณสุข (moph.go.th)</a> — นโยบายและข้อมูลสุขภาพแห่งชาติ</li>
      </ul>
    </div>
</BaseLayout>
