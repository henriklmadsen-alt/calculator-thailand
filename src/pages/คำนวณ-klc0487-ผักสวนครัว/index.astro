---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนปลูกผักสวนครัวเชิงพาณิชย์ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนและกำไรการปลูกผักสวนครัว ผักอินทรีย์ ต้นทุนต่อตารางเมตร ต่อรอบการปลูก';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0487-ผักสวนครัว/`;
const faqData = [
  { question: 'ผักชนิดไหนให้ผลตอบแทนดีที่สุด?', answer: 'ผักสลัด คะน้า ผักบุ้ง ปลูกง่าย รอบสั้น 30-45 วัน กำไรดี ผักออร์แกนิกได้ราคาสูงกว่า 30-50% ผักสมุนไพร เช่น โหระพา กระชาย มีมูลค่าสูง' },
  { question: 'ปลูกผักในโรงเรือนคุ้มค่าไหม?', answer: 'โรงเรือนลงทุน 150,000-500,000 บาท/ไร่ ลดความเสียหายจากแมลงและฝน ผลผลิตสูงกว่า 30-50% เหมาะผักสลัด ผักออร์แกนิก คืนทุนในระยะ 2-4 ปี' },
  { question: 'ระบบไฮโดรโปนิกส์เหมาะกับผักไหน?', answer: 'ไฮโดรโปนิกส์เหมาะผักสลัดทุกชนิด คะน้า ผักชี โหระพา ประหยัดน้ำ 90% ปลอดสารพิษ แต่ต้นทุนตั้งต้นสูง 500-1,500 บาท/ตร.ม.' },
  { question: 'ช่องทางขายผักสดออนไลน์ทำได้อย่างไร?', answer: 'ขายผ่าน Line Official LINE Shop Facebook Shop หรือ GrabMart Foodpanda ตัดสด-ส่งถึงบ้านได้ราคาสูงกว่าตลาดกลาง 50-100% สร้างฐานลูกค้าประจำ' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนปลูกผักสวนครัวเชิงพาณิชย์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนปลูกผักสวนครัว</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนและกำไรการปลูกผักต่อรอบการผลิต</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="veg_area_sqm" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่ปลูก (ตร.ม.)</label><input type="number" id="veg_area_sqm" min="1" placeholder="เช่น 200" value="200" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="veg_cost_sqm" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนต่อตร.ม.ต่อรอบ (บาท)</label><input type="text" id="veg_cost_sqm" inputmode="decimal" placeholder="เช่น 25" value="25" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="veg_yield_sqm" class="block text-sm font-medium text-gray-700 mb-1">ผลผลิตต่อตร.ม. (กก.)</label><input type="text" id="veg_yield_sqm" inputmode="decimal" placeholder="เช่น 3" value="3" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="veg_price_kg" class="block text-sm font-medium text-gray-700 mb-1">ราคาขาย (บาท/กก.)</label><input type="text" id="veg_price_kg" inputmode="decimal" placeholder="เช่น 40" value="40" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวม/รอบ</p><p id="veg_total_cost" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">กำไร/รอบ</p><p id="veg_profit" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const area = parseFloat((document.getElementById('veg_area_sqm') as HTMLInputElement).value) || 0;
      const costSqm = parseFloat((document.getElementById('veg_cost_sqm') as HTMLInputElement).value) || 0;
      const yieldSqm = parseFloat((document.getElementById('veg_yield_sqm') as HTMLInputElement).value) || 0;
      const price = parseFloat((document.getElementById('veg_price_kg') as HTMLInputElement).value) || 0;
      const totalCost = area * costSqm;
      const revenue = area * yieldSqm * price;
      const profit = revenue - totalCost;
      (document.getElementById('veg_total_cost') as HTMLElement).textContent = Math.round(totalCost).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('veg_profit') as HTMLElement).textContent = Math.round(profit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('vegetable-garden-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
