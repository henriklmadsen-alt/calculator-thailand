              <td class="px-4 py-2 text-center text-green-600 font-bold">&#10003;</td>
              <td class="px-4 py-2 text-center text-red-400">&#10007;</td>
              <td class="px-4 py-2 text-center text-red-400">&#10007;</td>
            </tr>
            <tr class="border-b">
              <td class="px-4 py-2">โจรกรรม</td>
              <td class="px-4 py-2 text-center text-green-600 font-bold">&#10003;</td>
              <td class="px-4 py-2 text-center text-green-600 font-bold">&#10003;</td>
