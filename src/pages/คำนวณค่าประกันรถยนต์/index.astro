    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Related Calculators -->
    <RelatedArticles currentHref="/คำนวณค่าประกันรถยนต์/" />
    <RelatedCalculators currentHref="/คำนวณค่าประกันรถยนต์/" />

    <!-- Disclaimer -->
    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.oic.or.th/th/consumer/insurance/non-life/motor" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">สำนักงาน คปภ. — ประกันภัยรถยนต์</a> — โครงสร้างชั้นความคุ้มครองและอัตราเบี้ยประกันรถยนต์</li>
        <li><a href="https://www.oic.or.th/th/consumer/insurance/non-life/motor/motor-voluntary" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ประกันภัยรถยนต์ภาคสมัครใจ — คปภ.</a></li>
        <li><a href="https://www.oic.or.th/th/consumer/knowledge/car_insurance" target="_blank" rel="noopener noreferrer" class="font-medium text-primary-600 hover:underline">ข้อมูลประกันรถยนต์จากสำนักงาน คปภ.</a> — ความรู้ประกันรถยนต์สำหรับผู้บริโภค</li>
        <li><a href="https://www.oic.or.th/th/consumer/knowledge/vehicle_act" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">พรบ. รถยนต์ภาคบังคับ — ข้อมูลจาก คปภ.</a> — ข้อมูล พ.ร.บ. ประกันภัยรถยนต์ภาคบังคับ</li>
      </ul>
    </div>

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      เบี้ยประกันจริงขึ้นอยู่กับบริษัทประกันภัย เงื่อนไขกรมธรรม์ ประวัติการเคลม
      และส่วนลดไม่มีเรียกร้อง (NCD) อ้างอิงโครงสร้างเบี้ยจาก <a href="https://www.oic.or.th" target="_blank" rel="noopener noreferrer" class="underline font-medium">คปภ.</a>
      กรุณาสอบถามบริษัทประกันภัยโดยตรงเพื่อเบี้ยที่แม่นยำ
    </div>
  </article>

  <script>
    import { calculateAllTypes } from '../../lib/car-insurance-calculator';
    import type { CarGroup } from '../../lib/car-insurance-calculator';

    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    let currentGroup: CarGroup = 3;

    const groupButtons = document.querySelectorAll('.car-group-btn') as NodeListOf<HTMLButtonElement>;
    const carValueInput = document.getElementById('car-value') as HTMLInputElement;
    const carAgeInput = document.getElementById('car-age') as HTMLInputElement;
    const driverAgeInput = document.getElementById('driver-age') as HTMLInputElement;
    const formError = document.getElementById('form-error') as HTMLParagraphElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const comparisonCards = document.getElementById('comparison-cards') as HTMLDivElement;
    const coverageTbody = document.getElementById('coverage-tbody') as HTMLTableSectionElement;

    function setGroup(group: CarGroup) {
      currentGroup = group;
      groupButtons.forEach(btn => {
        const g = parseInt(btn.dataset.group || '3', 10);
        if (g === group) {
          btn.className = 'car-group-btn py-2 px-3 rounded-md text-sm font-medium transition-colors border border-primary-500 bg-primary-50 text-primary-700';
          const span = btn.querySelector('span');
          if (span) span.className = 'block text-xs text-primary-400 mb-0.5';
        } else {
          btn.className = 'car-group-btn py-2 px-3 rounded-md text-sm font-medium transition-colors border border-gray-300 text-gray-600 hover:border-primary-400';
          const span = btn.querySelector('span');
          if (span) span.className = 'block text-xs text-gray-400 mb-0.5';
        }
      });
    }

    groupButtons.forEach(btn => {
      btn.addEventListener('click', () => setGroup(parseInt(btn.dataset.group || '3', 10) as CarGroup));
    });

    const groupNames: Record<number, string> = {
      1: 'กลุ่ม 1 (รถเล็ก)',
      2: 'กลุ่ม 2 (ซีดานกลาง)',
      3: 'กลุ่ม 3 (กระบะ/SUV)',
      4: 'กลุ่ม 4 (หรู)',
      5: 'กลุ่ม 5 (สปอร์ต)',
    };

    const typeColors: Record<string, { bg: string; border: string; text: string; badge: string }> = {
      type1: { bg: 'bg-primary-50', border: 'border-primary-200', text: 'text-primary-700', badge: 'bg-primary-600' },
      type2plus: { bg: 'bg-blue-50', border: 'border-blue-200', text: 'text-blue-700', badge: 'bg-blue-600' },
      type2: { bg: 'bg-teal-50', border: 'border-teal-200', text: 'text-teal-700', badge: 'bg-teal-600' },
      type3plus: { bg: 'bg-amber-50', border: 'border-amber-200', text: 'text-amber-700', badge: 'bg-amber-600' },
      type3: { bg: 'bg-gray-50', border: 'border-gray-200', text: 'text-gray-700', badge: 'bg-gray-600' },
    };

    function doCalculate() {
      formError.classList.add('hidden');

      const carValue = parseNum(carValueInput.value);
      const carAge = Math.max(0, Math.floor(parseNum(carAgeInput.value)));
      const driverAge = Math.max(18, Math.floor(parseNum(driverAgeInput.value)));

      if (carValue <= 0) {
        formError.textContent = 'กรุณากรอกมูลค่ารถ';
        formError.classList.remove('hidden');
        carValueInput.focus();
        return;
      }
      if (driverAge < 18 || parseNum(driverAgeInput.value) <= 0) {
        formError.textContent = 'กรุณากรอกอายุผู้ขับขี่ (18 ปีขึ้นไป)';
        formError.classList.remove('hidden');
        driverAgeInput.focus();
        return;
      }

      trackCalculatorStart('car_insurance');

      const results = calculateAllTypes(carValue, currentGroup, carAge, driverAge);

      // Render comparison cards
      comparisonCards.innerHTML = results.map((r) => {
        const c = typeColors[r.insuranceType];
        const isRecommended = r.insuranceType === 'type1' || r.insuranceType === 'type2plus';
        return `
          <div class="${c.bg} rounded-lg p-4 border ${c.border} ${isRecommended ? 'ring-2 ring-primary-300' : ''}">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs font-semibold text-white px-2 py-0.5 rounded ${c.badge}">${r.insuranceTypeName}</span>
              ${isRecommended ? '<span class="text-xs text-primary-600 font-medium">แนะนำ</span>' : ''}
            </div>
            <div class="text-2xl font-bold ${c.text} mb-1">${fmt(r.estimatedPremium)} <span class="text-sm font-normal">บาท/ปี</span></div>
            ${r.coverageAmount > 0 ? `<div class="text-xs text-gray-500">ทุนประกัน ${fmt(r.coverageAmount)} บาท</div>` : '<div class="text-xs text-gray-500">ไม่มีทุนประกัน</div>'}
            <div class="mt-3 space-y-1 text-xs text-gray-600">
              <div>${r.ownDamage ? '<span class="text-green-600">&#10003;</span> รถตัวเอง' : '<span class="text-gray-300">&#10007;</span> <span class="text-gray-400">รถตัวเอง</span>'}</div>
              <div>${r.fireTheft ? '<span class="text-green-600">&#10003;</span> ไฟไหม้/โจรกรรม' : '<span class="text-gray-300">&#10007;</span> <span class="text-gray-400">ไฟไหม้/โจรกรรม</span>'}</div>
              <div><span class="text-green-600">&#10003;</span> บุคคลภายนอก ${fmt(r.thirdPartyProperty)} บาท</div>
            </div>
          </div>
        `;
      }).join('');

      // Render coverage comparison table
      const coverageRows = [
        { label: 'เบี้ยประกันโดยประมาณ', values: results.map(r => `<strong>${fmt(r.estimatedPremium)}</strong> บาท`) },
        { label: 'ทุนประกัน', values: results.map(r => r.coverageAmount > 0 ? `${fmt(r.coverageAmount)} บาท` : '-') },
        { label: 'รถตัวเองเสียหาย (ชนเอง)', values: results.map(r => r.ownDamage ? '<span class="text-green-600 font-bold">&#10003;</span>' : '<span class="text-red-400">&#10007;</span>') },
        { label: 'ชนกับยานพาหนะอื่น', values: results.map(r => r.insuranceType === 'type1' || r.insuranceType === 'type2plus' || r.insuranceType === 'type3plus' ? '<span class="text-green-600 font-bold">&#10003;</span>' : '<span class="text-red-400">&#10007;</span>') },
        { label: 'ไฟไหม้', values: results.map(r => r.fireTheft ? '<span class="text-green-600 font-bold">&#10003;</span>' : '<span class="text-red-400">&#10007;</span>') },
        { label: 'โจรกรรม', values: results.map(r => r.fireTheft ? '<span class="text-green-600 font-bold">&#10003;</span>' : '<span class="text-red-400">&#10007;</span>') },
        { label: 'น้ำท่วม/ภัยธรรมชาติ', values: results.map(r => r.floodCoverage ? '<span class="text-green-600 font-bold">&#10003;</span>' : '<span class="text-red-400">&#10007;</span>') },
        { label: 'ทรัพย์สินบุคคลภายนอก', values: results.map(r => `${fmt(r.thirdPartyProperty)} บาท`) },
        { label: 'บาดเจ็บ/เสียชีวิตบุคคลภายนอก', values: results.map(r => `${fmt(r.thirdPartyBodily)} บาท`) },
        { label: 'ประกันอุบัติเหตุส่วนบุคคล', values: results.map(r => r.personalAccident > 0 ? `${fmt(r.personalAccident)} บาท` : '-') },
        { label: 'ค่ารักษาพยาบาล', values: results.map(r => r.medicalExpense > 0 ? `${fmt(r.medicalExpense)} บาท` : '-') },
        { label: 'ประกันตัวผู้ขับขี่', values: results.map(r => `${fmt(r.bailBond)} บาท`) },
      ];

      coverageTbody.innerHTML = coverageRows.map((row, i) => `
        <tr class="${i < coverageRows.length - 1 ? 'border-b border-gray-100' : ''} ${i === 0 ? 'bg-green-50' : ''}">
          <td class="px-3 py-2 text-gray-600 whitespace-nowrap">${row.label}</td>
          ${row.values.map(v => `<td class="px-3 py-2 text-center text-gray-900 text-xs">${v}</td>`).join('')}
        </tr>
      `).join('');

      // Input summary
      (document.getElementById('sum-car-value') as HTMLElement).textContent = fmt(carValue) + ' บาท';
      (document.getElementById('sum-car-group') as HTMLElement).textContent = groupNames[currentGroup];
      (document.getElementById('sum-car-age') as HTMLElement).textContent = carAge + ' ปี';
      (document.getElementById('sum-driver-age') as HTMLElement).textContent = driverAge + ' ปี';
      (document.getElementById('sum-car-adj') as HTMLElement).textContent = `x${results[0].carAgeAdjustment.toFixed(2)}`;
      (document.getElementById('sum-driver-adj') as HTMLElement).textContent = `x${results[0].driverAgeAdjustment.toFixed(2)}`;

      resultsDiv.classList.remove('hidden');
      document.getElementById('affiliate-card')?.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      trackCalculatorUsed('car_insurance');
      trackCalculatorComplete('car_insurance', results[0].estimatedPremium);
    }

    document.getElementById('btn-calculate')!.addEventListener('click', doCalculate);

    // Enter key support
    [carValueInput, carAgeInput, driverAgeInput].forEach(input => {
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); doCalculate(); }
      });
    });

    // Track result viewed
    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('car_insurance');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
