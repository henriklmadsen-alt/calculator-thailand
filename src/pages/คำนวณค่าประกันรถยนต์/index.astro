---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import AffiliateCard from '../../components/templates/AffiliateCard.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าประกันรถยนต์ ชั้น 1-3 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันรถยนต์ 2569 ฟรี — เปรียบเทียบชั้น 1, 2+, 2, 3+, 3 ตามมูลค่ารถและอายุ รู้ค่าประกันโดยประมาณก่อนตัดสินใจ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าประกันรถยนต์/`;

const faqData = [
  {
    question: 'ประกันรถยนต์ชั้น 1, 2+, 2, 3+, 3 ต่างกันอย่างไร?',
    answer: 'ชั้น 1 คุ้มครองรอบด้านสุด ทั้งรถตัวเอง ไฟไหม้ โจรกรรม น้ำท่วม และบุคคลภายนอก ชั้น 2+ คุ้มครองชนกับยานพาหนะ+ไฟไหม้+โจรกรรม+บุคคลภายนอก ชั้น 2 คุ้มครองไฟไหม้+โจรกรรม+บุคคลภายนอก ชั้น 3+ คุ้มครองชนกับยานพาหนะ+บุคคลภายนอก ชั้น 3 คุ้มครองบุคคลภายนอกอย่างเดียว เบี้ยถูกที่สุด',
  },
  {
    question: 'กลุ่มรถ 1-5 คืออะไร?',
    answer: 'บริษัทประกันจัดกลุ่มรถตามความเสี่ยง กลุ่ม 1 คือรถเล็กเศรษฐกิจ (City, Vios) เบี้ยต่ำสุด กลุ่ม 2 คือรถซีดานกลาง (Civic, Corolla) กลุ่ม 3 คือกระบะ/SUV (Hilux, Fortuner) กลุ่ม 4 คือรถหรู (Benz C, BMW 3) กลุ่ม 5 คือรถสปอร์ต/พรีเมียม เบี้ยสูงสุด',
  },
  {
    question: 'อายุรถมีผลกับเบี้ยประกันอย่างไร?',
    answer: 'รถใหม่จะมีเบี้ยสูงกว่าเพราะทุนประกัน (มูลค่ารถ) สูง เมื่อรถเก่าลง ทุนประกันลดลงตามค่าเสื่อม เบี้ยจึงลดตาม แต่รถเก่ามากอาจมีข้อจำกัดในการทำประกันชั้น 1 บางบริษัทรับรถอายุไม่เกิน 7-10 ปี',
  },
  {
    question: 'ผู้ขับอายุน้อยเสียเบี้ยแพงกว่าจริงไหม?',
    answer: 'ใช่ ผู้ขับอายุต่ำกว่า 25 ปี มักถูกคิดเบี้ยเพิ่ม 10-20% เพราะสถิติอุบัติเหตุสูงกว่า ส่วนผู้ขับอายุ 35-50 ปี อาจได้ส่วนลดเล็กน้อย',
  },
  {
    question: 'ทุนประกันคืออะไร ต่างจากมูลค่ารถอย่างไร?',
    answer: 'ทุนประกัน คือวงเงินสูงสุดที่บริษัทจะจ่ายเมื่อรถเสียหายทั้งคัน โดยปกติจะลดลงตามค่าเสื่อมของรถ เช่น รถราคา 1,000,000 บาท อายุ 3 ปี ทุนประกันอาจอยู่ที่ 760,000 บาท มูลค่ารถเป็นราคาตลาดปัจจุบัน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าประกันรถยนต์ 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณเบี้ยประกันรถยนต์',
  description: 'ขั้นตอนการประมาณเบี้ยประกันรถยนต์ ชั้น 1 ชั้น 2+ และชั้น 3 ตามประเภทรถและความครอบคลุม',
  step: [
    { '@type': 'HowToStep', name: 'เลือกประเภทประกันรถยนต์', text: 'เลือกชั้นประกันที่ต้องการ: ชั้น 1 (คุ้มครองครบถ้วน รวมกรณีไม่มีคู่กรณี), ชั้น 2+ (คุ้มครองบางส่วน), ชั้น 3 (คุ้มครองเฉพาะคู่กรณี) ประกันชั้น 1 เบี้ยสูงสุด แต่คุ้มครองมากที่สุด' },
    { '@type': 'HowToStep', name: 'ระบุข้อมูลรถยนต์', text: 'กรอกข้อมูล: ยี่ห้อ รุ่น ปีรถ และมูลค่ารถ เบี้ยประกันคำนวณจากมูลค่ารถ (ประมาณ 3-5% ของราคารถสำหรับชั้น 1) รถใหม่มีเบี้ยสูงกว่ารถเก่า' },
    { '@type': 'HowToStep', name: 'กรอกข้อมูลผู้ขับขี่', text: 'ระบุอายุผู้ขับขี่หลัก (อายุน้อยกว่า 25 ปี = เบี้ยสูงกว่า) ประวัติอุบัติเหตุ (ไม่มีประวัติ = ส่วนลด) และจำนวนผู้ขับขี่ที่ต้องการคุ้มครอง' },
    { '@type': 'HowToStep', name: 'เปรียบเทียบราคาจากหลายบริษัท', text: 'เบี้ยประกันต่างกันตามบริษัทประกัน ควรเปรียบเทียบอย่างน้อย 3 บริษัท (เช่น AXA, MSIG, Chubb, Cigna) และตรวจสอบความครอบคลุมที่แตกต่างกันก่อนตัดสินใจ' },
    { '@type': 'HowToStep', name: 'ตรวจสอบความครอบคลุมและเงื่อนไข', text: 'ก่อนซื้อตรวจสอบ: วงเงินคุ้มครองต่อเหตุการณ์, ค่าเบี้ยขั้นต่ำ (Deductible), บริการช่วยเหลือฉุกเฉิน 24 ชั่วโมง, และเครือข่ายอู่ซ่อมรถที่ครอบคลุม' },
  ],
};

---

<BaseLayout noGenericHowTo={true} title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าประกันรถยนต์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">เปรียบเทียบทุกชั้นความคุ้มครองในหน้าเดียว</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการประมาณการเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อ้างอิงโครงสร้างเบี้ย <a href="https://www.oic.or.th/th/consumer/insurance/non-life/motor" target="_blank" rel="noopener noreferrer" class="underline hover:text-sky-900">คปภ.</a> ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณค่าประกันรถยนต์ 2569 (2026)
    </h1>

    <p class="text-gray-600 mb-6">
      เปรียบเทียบเบี้ยประกันรถยนต์ ชั้น 1, 2+, 2, 3+, 3 ตามมูลค่ารถ กลุ่มรถ อายุรถ
      และอายุผู้ขับขี่ ดูความคุ้มครองแต่ละชั้น ผลลัพธ์ทันที ใช้งานฟรี
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูลรถยนต์</h2>

      <form id="insurance-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณากรอกข้อมูลให้ครบถ้วน
        </p>

        <!-- Car Value -->
        <div>
          <label for="car-value" class="block text-sm font-medium text-gray-700 mb-1">
            มูลค่ารถ (บาท)
          </label>
          <input
            type="text"
            id="car-value"
            inputmode="numeric"
            placeholder="เช่น 800,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p class="mt-1 text-xs text-gray-500">ราคาตลาดปัจจุบันหรือราคาซื้อ</p>
        </div>

        <!-- Car Group -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">กลุ่มรถ</label>
          <div class="grid grid-cols-2 sm:grid-cols-5 gap-2">
            <button type="button" data-group="1" class="car-group-btn py-2 px-3 rounded-md text-sm font-medium transition-colors border border-gray-300 text-gray-600 hover:border-primary-400">
              <span class="block text-xs text-gray-400 mb-0.5">กลุ่ม 1</span>
              รถเล็ก
            </button>
            <button type="button" data-group="2" class="car-group-btn py-2 px-3 rounded-md text-sm font-medium transition-colors border border-gray-300 text-gray-600 hover:border-primary-400">
              <span class="block text-xs text-gray-400 mb-0.5">กลุ่ม 2</span>
              ซีดานกลาง
            </button>
            <button type="button" data-group="3" class="car-group-btn py-2 px-3 rounded-md text-sm font-medium transition-colors border border-primary-500 bg-primary-50 text-primary-700">
              <span class="block text-xs text-primary-400 mb-0.5">กลุ่ม 3</span>
              กระบะ/SUV
            </button>
            <button type="button" data-group="4" class="car-group-btn py-2 px-3 rounded-md text-sm font-medium transition-colors border border-gray-300 text-gray-600 hover:border-primary-400">
              <span class="block text-xs text-gray-400 mb-0.5">กลุ่ม 4</span>
              หรู
            </button>
            <button type="button" data-group="5" class="car-group-btn py-2 px-3 rounded-md text-sm font-medium transition-colors border border-gray-300 text-gray-600 hover:border-primary-400">
              <span class="block text-xs text-gray-400 mb-0.5">กลุ่ม 5</span>
              สปอร์ต
            </button>
          </div>
          <p class="mt-1 text-xs text-gray-500">กลุ่ม 1: City, Vios | กลุ่ม 2: Civic, Corolla | กลุ่ม 3: Hilux, Fortuner | กลุ่ม 4: Benz C, BMW 3 | กลุ่ม 5: Benz S, Porsche</p>
        </div>

        <!-- Car Age -->
        <div>
          <label for="car-age" class="block text-sm font-medium text-gray-700 mb-1">
            อายุรถ (ปี)
          </label>
          <input
            type="text"
            id="car-age"
            inputmode="numeric"
            placeholder="เช่น 3"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p class="mt-1 text-xs text-gray-500">0 = รถป้ายแดง, นับจากปีจดทะเบียนครั้งแรก</p>
        </div>

        <!-- Driver Age -->
        <div>
          <label for="driver-age" class="block text-sm font-medium text-gray-700 mb-1">
            อายุผู้ขับขี่หลัก (ปี)
          </label>
          <input
            type="text"
            id="driver-age"
            inputmode="numeric"
            placeholder="เช่น 35"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p class="mt-1 text-xs text-gray-500">อายุต่ำกว่า 25 ปีอาจมีเบี้ยเพิ่ม</p>
        </div>

        <button
          type="button"
          id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          เปรียบเทียบเบี้ยประกัน
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการเปรียบเทียบ</h2>

      <!-- Comparison Cards -->
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-6" id="comparison-cards"></div>

      <!-- Coverage Comparison Table -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden mb-6">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b border-gray-200">เปรียบเทียบความคุ้มครอง</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm" id="coverage-table">
            <thead>
              <tr class="bg-gray-50 border-b">
                <th class="px-3 py-2 text-left text-gray-600 font-medium">ความคุ้มครอง</th>
                <th class="px-3 py-2 text-center text-gray-600 font-medium">ชั้น 1</th>
                <th class="px-3 py-2 text-center text-gray-600 font-medium">ชั้น 2+</th>
                <th class="px-3 py-2 text-center text-gray-600 font-medium">ชั้น 2</th>
                <th class="px-3 py-2 text-center text-gray-600 font-medium">ชั้น 3+</th>
                <th class="px-3 py-2 text-center text-gray-600 font-medium">ชั้น 3</th>
              </tr>
            </thead>
            <tbody id="coverage-tbody"></tbody>
          </table>
        </div>
      </div>

      <!-- Input Summary -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden mb-6">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b border-gray-200">ข้อมูลที่ใช้คำนวณ</h3>
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 text-gray-600">มูลค่ารถ</td>
              <td id="sum-car-value" class="px-4 py-3 text-right font-medium text-gray-900">-</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 text-gray-600">กลุ่มรถ</td>
              <td id="sum-car-group" class="px-4 py-3 text-right font-medium text-gray-900">-</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 text-gray-600">อายุรถ</td>
              <td id="sum-car-age" class="px-4 py-3 text-right font-medium text-gray-900">-</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 text-gray-600">อายุผู้ขับขี่</td>
              <td id="sum-driver-age" class="px-4 py-3 text-right font-medium text-gray-900">-</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3 text-gray-600">ปรับตามอายุรถ</td>
              <td id="sum-car-adj" class="px-4 py-3 text-right font-medium text-gray-900">-</td>
            </tr>
            <tr>
              <td class="px-4 py-3 text-gray-600">ปรับตามอายุผู้ขับ</td>
              <td id="sum-driver-adj" class="px-4 py-3 text-right font-medium text-gray-900">-</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <AffiliateCard
      category="insurance"
      affiliateUrl="/go/tipinsure/?sub_id=คำนวณค่าประกันรถยนต์"
      partnerName="TIPINSURE"
      ctaText="เปรียบเทียบประกันรถผ่าน TIPINSURE"
      subtext="เปรียบเทียบแผนประกันรถจากหลายบริษัท"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ประกันรถยนต์คืออะไร?</h2>

      <p>
        ประกันรถยนต์ (ประกันภัยภาคสมัครใจ) คือประกันภัยที่เจ้าของรถเลือกทำเพิ่มเติม
        นอกเหนือจาก พ.ร.บ. (ประกันภัยภาคบังคับ) เพื่อคุ้มครองความเสียหายต่อรถตัวเอง
        ทรัพย์สินบุคคลภายนอก และค่ารักษาพยาบาล โดยแบ่งเป็น 5 ชั้นตามระดับความคุ้มครอง
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประกันชั้น 1 — คุ้มครองสูงสุด</h3>

      <p>คุ้มครองครอบคลุมที่สุด เหมาะกับรถใหม่หรือรถที่มีมูลค่าสูง:</p>

      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ความเสียหายต่อรถตัวเอง (ชนเอง ถูกชน)</li>
        <li>ไฟไหม้และภัยธรรมชาติ (รวมน้ำท่วม)</li>
        <li>รถถูกโจรกรรม</li>
        <li>ความรับผิดต่อทรัพย์สินบุคคลภายนอก</li>
        <li>ความรับผิดต่อชีวิตและร่างกายบุคคลภายนอก</li>
        <li>ค่ารักษาพยาบาลผู้ขับขี่และผู้โดยสาร</li>
        <li>ประกันตัวผู้ขับขี่ (กรณีคดีอาญา)</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประกันชั้น 2+ — คุ้มครองชนกับยานพาหนะ</h3>

      <p>
        เพิ่มความคุ้มครองจากชั้น 2 โดยครอบคลุมความเสียหายกรณีชนกับยานพาหนะอื่น
        เหมาะกับผู้ที่ต้องการความคุ้มครองรถตัวเองในราคาย่อมเยา
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประกันชั้น 2 — ไฟไหม้ โจรกรรม บุคคลภายนอก</h3>

      <p>คุ้มครอง 3 ส่วนหลัก: ไฟไหม้ โจรกรรม และความรับผิดต่อบุคคลภายนอก ไม่คุ้มครองรถชน</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประกันชั้น 3+ และชั้น 3 — เบี้ยต่ำสุด</h3>

      <p>
        ชั้น 3 คุ้มครองเฉพาะความรับผิดต่อบุคคลภายนอก เบี้ยต่ำที่สุด เหมาะกับรถเก่า
        ส่วนชั้น 3+ เพิ่มความคุ้มครองกรณีชนกับยานพาหนะอื่น
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ปัจจัยที่ส่งผลต่อเบี้ยประกัน</h3>

