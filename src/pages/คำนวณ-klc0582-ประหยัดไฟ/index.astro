---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณการประหยัดไฟ LED | Kamnuanlek';
const pageDescription = 'คำนวณประหยัดไฟเมื่อเปลี่ยนเป็นไฟ LED ค่าไฟและค่าจำหน่ายต่อปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0582-led-savings/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประหยัดไฟ LED">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณประหยัดไฟเปลี่ยน LED</h1>
    <div class="mb-4 inline-block rounded-lg border border-yellow-200 bg-yellow-50 px-3 py-2"><p class="text-xs font-semibold text-yellow-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณประหยัดไฟเมื่อเปลี่ยนจากหลอดธรรมดาเป็น LED</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="bulbs" class="block text-sm font-medium text-gray-700 mb-1">จำนวนหลอด</label><input type="text" id="bulbs" inputmode="numeric" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="hours" class="block text-sm font-medium text-gray-700 mb-1">ชั่วโมง/วัน</label><input type="text" id="hours" inputmode="decimal" placeholder="เช่น 8" value="8" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-yellow-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-red-50 rounded p-3"><p class="text-sm text-gray-600">ค่าไฟดั้งเดิมต่อปี</p><p id="old" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ค่าไฟ LED ต่อปี</p><p id="new" class="font-bold">-</p></div><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ประหยัดต่อปี</p><p id="savings" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const bulbs = parseFloat((document.getElementById('bulbs') as HTMLInputElement).value) || 0;
      const hours = parseFloat((document.getElementById('hours') as HTMLInputElement).value) || 0;
      if (bulbs <= 0) return;
      const old_kw = bulbs * 0.06 * hours * 365, new_kw = bulbs * 0.01 * hours * 365;
      const old_bill = old_kw * 5.5, new_bill = new_kw * 5.5, savings = old_bill - new_bill;
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('old') as HTMLElement).textContent = fmt(old_bill);
      (document.getElementById('new') as HTMLElement).textContent = fmt(new_bill);
      (document.getElementById('savings') as HTMLElement).textContent = fmt(savings);
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('led-savings');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
