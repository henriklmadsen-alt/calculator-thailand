---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณลดหย่อนเงินบริจาค 2569 | ลดหย่อน 2 เท่า การศึกษา | Calculator Thailand';
const pageDescription = 'คำนวณค่าลดหย่อนเงินบริจาคเพื่อการศึกษา (2 เท่า) และบริจาคการกุศลทั่วไป (1 เท่า สูงสุด 10%) ตามกฎหมายภาษีไทยปี 2569 ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณลดหย่อนเงินบริจาค/`;

const faqData = [
  {
    question: 'บริจาคเพื่อการศึกษาลดหย่อนได้กี่เท่า?',
    answer: 'เงินบริจาคให้แก่สถานศึกษาและโครงการที่กรมสรรพากรกำหนด ลดหย่อนได้ 2 เท่าของเงินบริจาคจริง แต่รวมกับการบริจาคอื่นต้องไม่เกิน 10% ของรายได้หลังหักค่าใช้จ่ายและค่าลดหย่อนอื่นๆ',
  },
  {
    question: 'บริจาคให้มูลนิธิการกุศลลดหย่อนได้เท่าไร?',
    answer: 'บริจาคให้มูลนิธิ สมาคม หรือหน่วยงานการกุศลที่กรมสรรพากรรับรอง ลดหย่อนได้ 1 เท่าของเงินบริจาคจริง สูงสุดไม่เกิน 10% ของรายได้หลังหักค่าใช้จ่ายและค่าลดหย่อนอื่นๆ',
  },
  {
    question: 'เงินบริจาคพรรคการเมืองลดหย่อนได้ไหม?',
    answer: 'บริจาคให้พรรคการเมืองลดหย่อนได้สูงสุด 10,000 บาทต่อปี (ต่างจากการบริจาคการกุศล) โดยต้องเป็นพรรคที่จดทะเบียนถูกต้องตามกฎหมาย',
  },
  {
    question: 'ต้องมีหลักฐานอะไรบ้างสำหรับการลดหย่อนเงินบริจาค?',
    answer: 'ต้องมีใบเสร็จรับเงินหรือหนังสือรับรองการบริจาคจากองค์กรที่ได้รับรอง ระบุชื่อ-นามสกุลผู้บริจาค จำนวนเงิน และวัตถุประสงค์การบริจาค เก็บไว้อย่างน้อย 5 ปี',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณลดหย่อนเงินบริจาค 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณลดหย่อนเงินบริจาค">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">บริจาคเพื่อการศึกษา ลดหย่อนได้ 2 เท่า</p>
      <p class="mt-1 text-sm text-slate-700">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณลดหย่อนเงินบริจาค 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าลดหย่อนจากเงินบริจาค ทั้งแบบลดหย่อน 2 เท่า (การศึกษา) และ 1 เท่า (การกุศลทั่วไป)
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูล</h2>
      <div class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="don-income" class="block text-sm font-medium text-gray-700 mb-1">
              รายได้ต่อปี (บาท)
            </label>
            <input type="text" id="don-income" inputmode="numeric" placeholder="เช่น 600,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="don-other-deductions" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าลดหย่อนอื่นๆ (บาท) <span class="text-gray-400 font-normal">ยกเว้นเงินบริจาค</span>
            </label>
            <input type="text" id="don-other-deductions" inputmode="numeric" placeholder="เช่น 60,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="don-edu" class="block text-sm font-medium text-gray-700 mb-1">
              บริจาคเพื่อการศึกษา (บาท) — ลดหย่อน 2 เท่า
            </label>
            <input type="text" id="don-edu" inputmode="numeric" placeholder="เช่น 10,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="don-charity" class="block text-sm font-medium text-gray-700 mb-1">
              บริจาคการกุศลทั่วไป (บาท) — ลดหย่อน 1 เท่า
            </label>
            <input type="text" id="don-charity" inputmode="numeric" placeholder="เช่น 5,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
        </div>

        <button type="button" id="btn-don-calc"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 transition-colors text-base">
          คำนวณทันที
        </button>
      </div>

      <div id="don-result" class="hidden mt-6">
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-4">
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">บริจาคจริงรวม</div>
            <div id="dr-actual" class="text-lg font-bold text-gray-900">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ลดหย่อนที่คำนวณได้</div>
            <div id="dr-calc" class="text-lg font-bold text-primary-700">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เพดาน 10% ของรายได้</div>
            <div id="dr-cap" class="text-lg font-bold text-amber-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ลดหย่อนที่ใช้ได้จริง</div>
            <div id="dr-final" class="text-lg font-bold text-green-700">-</div>
          </div>
        </div>
        <div class="space-y-1 text-sm bg-gray-50 rounded-lg p-3">
          <div class="flex justify-between"><span class="text-gray-500">บริจาคการศึกษา × 2</span><span id="dr-edu-calc" class="font-medium"></span></div>
          <div class="flex justify-between"><span class="text-gray-500">บริจาคการกุศล × 1</span><span id="dr-charity-calc" class="font-medium"></span></div>
          <div class="flex justify-between border-t border-gray-200 pt-1"><span class="font-semibold">ลดหย่อนก่อนเพดาน</span><span id="dr-before-cap" class="font-bold"></span></div>
        </div>
        <p id="dr-warning" class="hidden mt-3 text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded p-2"></p>
      </div>
    </div>

    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">[โฆษณา — AdSense]</div>

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ลดหย่อนเงินบริจาคในประเทศไทย</h2>
      <p>กรมสรรพากรอนุญาตให้นำเงินบริจาคมาหักลดหย่อนภาษีได้ โดยแบ่งเป็น 2 ประเภทหลัก:</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>บริจาคเพื่อการศึกษา:</strong> ลดหย่อนได้ 2 เท่าของเงินบริจาคจริง (เช่น บริจาค 10,000 บาท ลดหย่อนได้ 20,000 บาท)</li>
        <li><strong>บริจาคการกุศลทั่วไป:</strong> ลดหย่อนได้ 1 เท่าของเงินบริจาคจริง</li>
      </ul>
      <p class="mt-3">เพดานรวมการบริจาคทุกประเภท: ต้องไม่เกิน 10% ของรายได้หลังหักค่าใช้จ่ายและค่าลดหย่อนอื่นๆ (ก่อนหักเงินบริจาค)</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณลดหย่อนเงินบริจาค/" />
    <RelatedCalculators currentHref="/คำนวณลดหย่อนเงินบริจาค/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางภาษีหรือกฎหมาย กรุณาปรึกษาผู้เชี่ยวชาญด้านภาษีสำหรับกรณีเฉพาะ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' บาท';
    }

    document.getElementById('btn-don-calc')!.addEventListener('click', () => {
      const income = parseNum((document.getElementById('don-income') as HTMLInputElement).value);
      const otherDeductions = parseNum((document.getElementById('don-other-deductions') as HTMLInputElement).value);
      const edu = parseNum((document.getElementById('don-edu') as HTMLInputElement).value);
      const charity = parseNum((document.getElementById('don-charity') as HTMLInputElement).value);
      if (income <= 0) return;

      const expense = Math.min(income * 0.5, 100000);
      // Base income after expense and other deductions (before donation)
      const baseAfterDeductions = Math.max(0, income - expense - otherDeductions);
      // 10% cap applies to income after expense and other deductions
      const cap = baseAfterDeductions * 0.10;

      const eduCalc = edu * 2;
      const charityCalc = charity * 1;
      const totalCalc = eduCalc + charityCalc;
      const finalDeduction = Math.min(totalCalc, cap);
      const actualTotal = edu + charity;

      (document.getElementById('dr-actual') as HTMLElement).textContent = fmt(actualTotal);
      (document.getElementById('dr-calc') as HTMLElement).textContent = fmt(totalCalc);
      (document.getElementById('dr-cap') as HTMLElement).textContent = fmt(cap);
      (document.getElementById('dr-final') as HTMLElement).textContent = fmt(finalDeduction);
      (document.getElementById('dr-edu-calc') as HTMLElement).textContent = fmt(eduCalc);
      (document.getElementById('dr-charity-calc') as HTMLElement).textContent = fmt(charityCalc);
      (document.getElementById('dr-before-cap') as HTMLElement).textContent = fmt(totalCalc);

      const warn = document.getElementById('dr-warning') as HTMLElement;
      if (totalCalc > cap) {
        warn.textContent = `⚠️ ลดหย่อนที่คำนวณได้ (${new Intl.NumberFormat('th-TH').format(Math.round(totalCalc))} บาท) เกินเพดาน 10% จึงใช้ได้เพียง ${new Intl.NumberFormat('th-TH').format(Math.round(finalDeduction))} บาท`;
        warn.classList.remove('hidden');
      } else {
        warn.classList.add('hidden');
      }

      (document.getElementById('don-result') as HTMLDivElement).classList.remove('hidden');
      trackCalculatorUsed('donation-deduction');
    });
  </script>
</BaseLayout>
