---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าถุงทารก | Kamnuanlek';
const pageDescription = 'คำนวณค่าเตรียมทารก ค่าครรภ์คลอด ค่าแทะวัตถุดิบ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0615-ค่าถุงทารก/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าถุงทารก">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าถุงทารก</h1>
    <div class="mb-4 inline-block rounded-lg border border-fuchsia-200 bg-fuchsia-50 px-3 py-2"><p class="text-xs font-semibold text-fuchsia-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าเตรียมที่อยู่อาศัย เตียง ตู้ อาหาร รายปีสำหรับทารก</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="furniture" class="block text-sm font-medium text-gray-700 mb-1">ค่าเฟอร์นิเจอร์เตียง ตู้ (บาท)</label><input type="text" id="furniture" inputmode="decimal" placeholder="เช่น 5000" value="5000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="clothes" class="block text-sm font-medium text-gray-700 mb-1">ค่าเสื้อผ้า ผ้าอ้อม อุปกรณ์ (บาท)</label><input type="text" id="clothes" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="feeding" class="block text-sm font-medium text-gray-700 mb-1">ค่าอุปกรณ์เลี้ยง ขวดนม (บาท)</label><input type="text" id="feeding" inputmode="decimal" placeholder="เช่น 1500" value="1500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="health" class="block text-sm font-medium text-gray-700 mb-1">ค่าประกันทารก วัคซีน (บาท/ปี)</label><input type="text" id="health" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-fuchsia-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-fuchsia-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าเตรียมครั้งแรก</p>
            <p id="initial" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมตลอดปีแรก</p>
            <p id="total" class="font-bold">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่าเตรียมทารกประมาณเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">ค่าเตรียมพื้นฐาน 10,000-15,000 บาท บ้านโรงพยาบาล 20,000-50,000 บาท</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ขวดนมช่วยได้จริงหรือ?</h3>
            <p class="text-gray-600 text-sm">ใช่ หากแม่ไม่สามารถให้นมได้ ขวดนมเป็นทางเลือก ควรเลือกแบบดี</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">อาหารเสริมทารกต้องรอกี่เดือน?</h3>
            <p class="text-gray-600 text-sm">ตามสมาคมทันตแพทย์เด็ก เริ่มให้อาหารเสริมตั้งแต่ 6 เดือน</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const furniture = parseFloat((document.getElementById('furniture') as HTMLInputElement).value) || 0;
      const clothes = parseFloat((document.getElementById('clothes') as HTMLInputElement).value) || 0;
      const feeding = parseFloat((document.getElementById('feeding') as HTMLInputElement).value) || 0;
      const health = parseFloat((document.getElementById('health') as HTMLInputElement).value) || 0;

      const initial = furniture + clothes + feeding;
      const total = initial + health;

      (document.getElementById('initial') as HTMLElement).textContent = initial.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('baby-preparation');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
