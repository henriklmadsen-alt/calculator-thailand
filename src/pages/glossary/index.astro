---
import BaseLayout from '../../layouts/BaseLayout.astro';

const glossaryTerms = [
  { term: 'APR', thai: 'อัตราเงินกู้ประจำปี', slug: 'apr' },
  { term: 'Interest Rate', thai: 'อัตราดอกเบี้ย', slug: 'interest-rate' },
  { term: 'Principal', thai: 'เงินต้น', slug: 'principal' },
  { term: 'Amortization', thai: 'การชำระคืนแบบผ่อนส่วน', slug: 'amortization' },
  { term: 'Tax Deduction', thai: 'ลดหย่อนภาษี', slug: 'tax-deduction' },
  { term: 'Gross Income', thai: 'รายได้รวม', slug: 'gross-income' },
  { term: 'Net Income', thai: 'รายได้สุทธิ', slug: 'net-income' },
  { term: 'Tax Bracket', thai: 'ชั้นภาษีเงินได้', slug: 'tax-bracket' },
  { term: 'VAT (Value Added Tax)', thai: 'ภาษีมูลค่าเพิ่ม', slug: 'vat' },
  { term: 'Social Security', thai: 'ประกันสังคม', slug: 'social-security' },
  { term: 'Loan-to-Value (LTV)', thai: 'สัดส่วนเงินกู้ต่อมูลค่าทรัพย์', slug: 'ltv' },
  { term: 'Mortgage', thai: 'สินเชื่อที่อยู่อาศัย', slug: 'mortgage' },
  { term: 'Refinance', thai: 'รีไฟแนนซ์', slug: 'refinance' },
  { term: 'BMI (Body Mass Index)', thai: 'ดัชนีมวลกาย', slug: 'bmi' },
  { term: 'Cost of Living', thai: 'ค่าครองชีพ', slug: 'cost-of-living' },
  { term: 'Compound Interest', thai: 'ดอกเบี้ยทบต้น', slug: 'compound-interest' },
  { term: 'Depreciation', thai: 'ค่าเสื่อมราคา', slug: 'depreciation' },
  { term: 'Asset', thai: 'สินทรัพย์', slug: 'asset' },
  { term: 'Liability', thai: 'หนี้สิน', slug: 'liability' },
  { term: 'Equity', thai: 'ส่วนทุน', slug: 'equity' },
];

const pageTitle = 'คำศัพท์ด้านการเงิน — พจนานุกรมเครื่องคำนวณ';
const pageDescription = 'พจนานุกรมคำศัพท์ด้านการเงิน ภาษี สินเชื่อ และสุขภาพ ที่ใช้ในเครื่องคำนวณของคำนวณเลข เขียนเป็นภาษาไทยง่ายๆ พร้อมตัวอย่าง';
---

<BaseLayout title={pageTitle} description={pageDescription} pageName="คำศัพท์ด้านการเงิน">
  <main class="min-h-screen bg-gradient-to-b from-slate-50 to-white">
    <div class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-4">
          พจนานุกรมคำศัพท์ด้านการเงิน
        </h1>
        <p class="text-lg text-slate-600 mb-4">
          เข้าใจคำศัพท์ที่ใช้ในเครื่องคำนวณของเรา เขียนเป็นภาษาไทยง่ายๆ พร้อมตัวอย่างและหมายเหตุ
        </p>
        <div class="inline-block bg-blue-100 text-blue-900 px-3 py-1 rounded-full text-sm font-medium">
          🏦 20 คำศัพท์สำคัญด้านการเงิน
        </div>
      </div>

      <!-- Quick Answer Box (for LLM) -->
      <div class="ai-quick-answer bg-amber-50 border-l-4 border-amber-500 p-6 mb-12 rounded">
        <p class="text-sm text-amber-900 font-semibold mb-2">📖 คำตอบสั้นๆ</p>
        <p class="text-slate-700">
          คำศัพท์ด้านการเงินคือศัพท์เฉพาะที่ใช้ในการคำนวณเงินกู้ ภาษี เงินฝาก และการวางแผนทางการเงิน หากคุณต้องการเข้าใจค่าดอกเบี้ย อัตราภาษี หรือการชำระเงินผ่อน เราได้รวบรวมคำศัพท์ 20 คำสำคัญเอาไว้
        </p>
      </div>

      <!-- Terms Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        {glossaryTerms.map((item) => (
          <a
            href={`/glossary/${item.slug}/`}
            class="block p-6 bg-white border border-slate-200 rounded-lg hover:shadow-lg hover:border-blue-300 transition-all"
          >
            <h3 class="text-lg font-semibold text-blue-600 mb-2">{item.term}</h3>
            <p class="text-slate-600 text-sm">{item.thai}</p>
            <div class="mt-4 text-blue-500 text-sm font-medium flex items-center">
              อ่านเพิ่มเติม →
            </div>
          </a>
        ))}
      </div>

      <!-- Footer -->
      <div class="bg-slate-100 rounded-lg p-8 text-center">
        <p class="text-slate-700 mb-4">
          ไม่พบคำศัพท์ที่ค้นหา?
        </p>
        <a href="/ติดต่อเรา/" class="inline-block bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 transition">
          ติดต่อเราเพื่อเพิ่มคำศัพท์
        </a>
      </div>
    </div>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Financial Glossary — Kamnuanlek.com',
    url: 'https://www.kamnuanlek.com/glossary/',
    description: 'Comprehensive Thai glossary of financial terms used in calculators',
    hasPart: glossaryTerms.map(term => ({
      '@type': 'DefinitionSet',
      name: term.term,
      description: term.thai,
    })),
  })} />
</BaseLayout>

<style>
  h1, h3 {
    font-family: 'Noto Sans Thai', sans-serif;
  }
</style>
