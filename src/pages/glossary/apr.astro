---
import BaseLayout from '../../layouts/BaseLayout.astro';

const term = 'APR';
const thai = 'อัตราเงินกู้ประจำปี';
const definition = `อัตราเงินกู้ประจำปี (Annual Percentage Rate) คือ "ต้นทุนที่แท้จริง" ของการกู้เงินในหนึ่งปี
โดยนับรวมดอกเบี้ยบวกกับค่าธรรมเนียมและค่าใช้สอยอื่นๆ ทั้งหมด`;

const relatedCalculators = [
  { name: 'APR Calculator', url: '/คำนวณ-apr/' },
  { name: 'Mortgage Calculator', url: '/คำนวณผ่อนบ้าน/' },
  { name: 'Loan Comparison', url: '/คำนวณเปรียบเทียบสินเชื่อ/' },
];
---

<BaseLayout
  title={`${term} (${thai}) — คำศัพท์ด้านการเงิน`}
  description={`${term} คือ ${definition}`}
  pageName={`${term} — ${thai}`}
  categoryId="finance"
  categoryName="การเงิน"
  categorySlug="การเงิน"
>
  <main class="min-h-screen bg-white">
    <div class="max-w-3xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8">
        <a href="/glossary/" class="text-blue-600 hover:text-blue-700 font-medium mb-4 inline-block">
          ← กลับไปพจนานุกรม
        </a>
        <h1 class="text-4xl font-bold text-slate-900 mb-2">{term}</h1>
        <p class="text-2xl text-slate-600 font-semibold">{thai}</p>
      </div>

      <!-- Quick Answer Box (for LLM) -->
      <div class="ai-quick-answer bg-amber-50 border-l-4 border-amber-500 p-6 mb-8 rounded">
        <p class="text-sm text-amber-900 font-semibold mb-2">📖 คำตอบสั้นๆ</p>
        <p class="text-slate-700 whitespace-pre-line">{definition}</p>
      </div>

      <!-- Full Definition -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">คำจำกัดความแบบละเอียด</h2>
        <div class="prose prose-slate max-w-none text-slate-700 space-y-4">
          <p>
            APR (Annual Percentage Rate) เป็นตัวแทนที่ดีกว่า "ดอกเบี้ย" ธรรมดา เพราะมันรวมเอา:
          </p>
          <ul class="list-disc pl-6 space-y-2">
            <li><strong>ดอกเบี้ยรายปี</strong> — เศษส่วนของเงินต้นที่ธนาคารเรียกเก็บ</li>
            <li><strong>ค่าธรรมเนียมการจัดเงินกู้</strong> — ค่าจัดการเอกสาร ค่าประเมิน</li>
            <li><strong>ค่าประกันภัย</strong> — ประกันเงินกู้ (บังคับในบางเงินกู้)</li>
            <li><strong>ค่าใช้อื่นๆ</strong> — ค่าบันทึกจำนอง ค่าแสตมป์</li>
          </ul>

          <p class="mt-4">
            <strong>ตัวอย่าง:</strong> ถ้าธนาคารบอกว่า "ดอกเบี้ย 3% ต่อปี" แต่มี "ค่าธรรมเนียม 5,000 บาท"
            APR อาจจะกลายเป็น 3.5% ต่อปี เพราะรวมค่าธรรมเนียมเข้ามา
          </p>

          <p class="mt-4">
            <strong>ทำไมสำคัญ?</strong> เมื่อเปรียบเทียบเงินกู้จากธนาคารหลายแห่ง คุณต้องดู APR ไม่ใช่แค่ดอกเบี้ย
            เพราะค่าธรรมเนียมที่ต่างกันจะทำให้ต้นทุนรวมแตกต่างกันมาก
          </p>
        </div>
      </section>

      <!-- Related Information -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">คำศัพท์ที่เกี่ยวข้อง</h2>
        <div class="space-y-3">
          <div class="p-4 bg-slate-50 rounded">
            <h3 class="font-semibold text-slate-900">Interest Rate (อัตราดอกเบี้ย)</h3>
            <p class="text-slate-600 text-sm">เพียงเศษส่วนของเงินต้นที่ธนาคารเรียก ไม่รวมค่าธรรมเนียม</p>
          </div>
          <div class="p-4 bg-slate-50 rounded">
            <h3 class="font-semibold text-slate-900">Principal (เงินต้น)</h3>
            <p class="text-slate-600 text-sm">จำนวนเงินที่คุณยืมจากธนาคาร ก่อนคิดดอกเบี้ยและค่าธรรมเนียม</p>
          </div>
          <div class="p-4 bg-slate-50 rounded">
            <h3 class="font-semibold text-slate-900">Amortization (ผ่อนส่วน)</h3>
            <p class="text-slate-600 text-sm">วิธีชำระเงินกู้เป็นงวดเท่า ๆ กัน ตามสูตรที่คิดดอกเบี้ยลดหลั่น</p>
          </div>
        </div>
      </section>

      <!-- Related Calculators -->
      <section class="mb-10 bg-blue-50 p-8 rounded-lg">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">🧮 ใช้เครื่องคำนวณที่เกี่ยวข้อง</h2>
        <div class="space-y-3">
          {relatedCalculators.map((calc) => (
            <a
              href={calc.url}
              class="block p-4 bg-white border border-blue-200 rounded hover:shadow-md hover:border-blue-400 transition"
            >
              <p class="font-semibold text-blue-600">{calc.name}</p>
              <p class="text-sm text-slate-600">คำนวณอัตราเงินกู้และเปรียบเทียบตัวเลือกต่างๆ</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Source -->
      <section class="border-t border-slate-200 pt-6">
        <p class="text-sm text-slate-600">
          📚 <strong>แหล่งข้อมูล:</strong> Bank of Thailand (ธนาคารแห่งประเทศไทย), Thai Banking Association
        </p>
        <p class="text-sm text-slate-600 mt-2">
          ⏰ <strong>อัปเดตล่าสุด:</strong> <time dateTime="2026-04-24">เมษายน 2026</time>
        </p>
      </section>
    </div>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'DefinitionSet',
    name: term,
    description: thai,
    author: {
      '@type': 'Organization',
      name: 'Kamnuanlek.com',
      url: 'https://www.kamnuanlek.com',
    },
    datePublished: '2026-04-24',
    dateModified: '2026-04-24',
    inLanguage: 'th-TH',
  })} />
</BaseLayout>

<style>
  h1, h2, h3 {
    font-family: 'Noto Sans Thai', sans-serif;
  }
</style>
