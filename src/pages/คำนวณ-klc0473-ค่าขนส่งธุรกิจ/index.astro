---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าขนส่งและกระจายสินค้า | Kamnuanlek';
const pageDescription = 'คำนวณค่าขนส่งสินค้า Distribution Cost ต้นทุนโลจิสติกส์ต่อหน่วย ค่าส่งพัสดุ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0473-ค่าขนส่งธุรกิจ/`;
const faqData = [
  { question: 'ค่าขนส่งพัสดุไปรษณีย์ไทยราคาเท่าไหร่?', answer: 'ไปรษณีย์ไทย 1 กก. ในจังหวัด 20-40 บาท ต่างจังหวัด 40-60 บาท EMS 1 กก. 70-150 บาท Kerry/Flash Express 1 กก. 30-70 บาท' },
  { question: 'ค่าขนส่งควรเป็นกี่เปอร์เซ็นต์ของราคาสินค้า?', answer: 'ค่าขนส่งควรไม่เกิน 5-15% ของมูลค่าสินค้า สินค้าหนักหรือใหญ่อาจสูงกว่า แต่ถ้าสูงเกินนี้ควรพิจารณาผู้ให้บริการรายอื่นหรือเจรจาราคา' },
  { question: '3PL Logistics คืออะไร?', answer: '3PL (Third-Party Logistics) คือการจ้างบริษัทภายนอกจัดการคลังสินค้า หยิบ แพ็ก และส่งสินค้า เหมาะธุรกิจที่ต้องการลด CapEx คลังและให้ผู้เชี่ยวชาญจัดการ' },
  { question: 'จะลดค่าขนส่งได้อย่างไร?', answer: 'ลดค่าขนส่งโดย เจรจาต่อรองกับ courier เมื่อปริมาณสูง ส่งแบบ Bulk ลดน้ำหนัก/ขนาดแพ็กเกจ ใช้บริการ 3PL ตั้ง drop point หรือ fulfillment center กระจาย' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าขนส่งและกระจายสินค้า">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าขนส่งและกระจายสินค้า</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนโลจิสติกส์รวมต่อเดือนและต่อหน่วยส่ง</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="parcels_month" class="block text-sm font-medium text-gray-700 mb-1">จำนวนพัสดุต่อเดือน (ชิ้น)</label><input type="number" id="parcels_month" min="1" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="cost_per_parcel" class="block text-sm font-medium text-gray-700 mb-1">ค่าขนส่งเฉลี่ยต่อชิ้น (บาท)</label><input type="text" id="cost_per_parcel" inputmode="decimal" placeholder="เช่น 50" value="50" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="warehouse_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าคลังสินค้า/เดือน (บาท)</label><input type="text" id="warehouse_cost" inputmode="decimal" placeholder="เช่น 10000" value="10000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="packing_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าบรรจุภัณฑ์ต่อชิ้น (บาท)</label><input type="text" id="packing_cost" inputmode="decimal" placeholder="เช่น 15" value="15" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนโลจิสติกส์/เดือน</p><p id="monthly_logistics" class="font-bold">-</p></div>
          <div class="bg-indigo-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนต่อหน่วยส่ง</p><p id="per_unit_logistics" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const parcels = parseInt((document.getElementById('parcels_month') as HTMLInputElement).value) || 1;
      const costPerParcel = parseFloat((document.getElementById('cost_per_parcel') as HTMLInputElement).value) || 0;
      const warehouse = parseFloat((document.getElementById('warehouse_cost') as HTMLInputElement).value) || 0;
      const packing = parseFloat((document.getElementById('packing_cost') as HTMLInputElement).value) || 0;
      const monthlyLogistics = (costPerParcel * parcels) + warehouse + (packing * parcels);
      const perUnit = parcels > 0 ? monthlyLogistics / parcels : 0;
      (document.getElementById('monthly_logistics') as HTMLElement).textContent = Math.round(monthlyLogistics).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('per_unit_logistics') as HTMLElement).textContent = perUnit.toLocaleString('th-TH', {maximumFractionDigits: 2}) + ' บาท/ชิ้น';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('distribution-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
