---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณ ROI การทำให้บ้านเป็นอัตโนมัติ | Home Automation ROI | Calculator Thailand';
const pageDescription = 'คำนวณผลตอบแทนจากการลงทุนสมาร์ทโฮม ประหยัดค่าไฟ เวลา และความสุขสำหรับครอบครัว';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-roi-อัตโนมัติบ้าน/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ ROI อัตโนมัติบ้าน">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณผลตอบแทน (ROI) อัตโนมัติบ้าน</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2">
      <p class="text-xs font-semibold text-green-800">[อัปเดต 2569]</p>
    </div>
    <p class="text-gray-600 mb-6">คำนวณผลตอบแทน (ROI) และระยะเวลาคืนทุนจากการลงทุนสมาร์ทโฮม</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="initialCost" class="block text-sm font-medium text-gray-700 mb-1">ต้นทุนลงทุนเริ่มแรม (บาท)</label>
          <input type="number" id="initialCost" placeholder="100000" value="100000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-green-500 text-base" />
        </div>
        <div>
          <label for="monthlySavings" class="block text-sm font-medium text-gray-700 mb-1">ประหยัดรายเดือน (บาท)</label>
          <input type="number" id="monthlySavings" placeholder="2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-green-500 text-base" />
        </div>
      </div>

      <button id="calculateBtn" class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-md">
        คำนวณ ROI
      </button>
    </div>

    <div id="results" class="bg-green-50 rounded-lg border border-green-200 p-6 mb-8 hidden">
      <h2 class="text-xl font-bold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="bg-white rounded-lg p-4 mb-4">
        <p class="text-sm text-gray-600 mb-1">ระยะเวลาคืนทุน</p>
        <p id="paybackPeriod" class="text-3xl font-bold text-green-600">0 เดือน</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="bg-white rounded-lg p-4">
          <p class="text-xs text-gray-600">ROI ต่อปี</p>
          <p id="roi" class="text-xl font-bold">0%</p>
        </div>
        <div class="bg-white rounded-lg p-4">
          <p class="text-xs text-gray-600">ประหยัดต่อปี</p>
          <p id="yearlySavings" class="text-xl font-bold">0 บาท</p>
        </div>
      </div>
    </div>
  </article>

  <script>
    document.getElementById('calculateBtn').addEventListener('click', () => {
      const initialCost = parseFloat(document.getElementById('initialCost').value) || 100000;
      const monthlySavings = parseFloat(document.getElementById('monthlySavings').value) || 2000;

      const paybackMonths = initialCost / monthlySavings;
      const yearlySavings = monthlySavings * 12;
      const roi = (yearlySavings / initialCost * 100).toFixed(1);

      document.getElementById('paybackPeriod').textContent = paybackMonths.toFixed(1) + ' เดือน';
      document.getElementById('roi').textContent = roi + '%';
      document.getElementById('yearlySavings').textContent = new Intl.NumberFormat('th-TH').format(Math.round(yearlySavings)) + ' บาท';
      document.getElementById('results').classList.remove('hidden');
    });
  </script>
</BaseLayout>
