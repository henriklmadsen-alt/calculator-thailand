              {[
                { budget: '< 2,000 บาท', cls: 'ชั้น 3', who: 'รถเก่า ยอมรับความเสี่ยงรถตัวเองเสียหาย', bg: '' },
                { budget: '2,000–4,000 บาท', cls: 'ชั้น 3+ หรือ 2', who: 'อยากประหยัดแต่มีความคุ้มครองพื้นฐาน', bg: 'bg-gray-50' },
                { budget: '4,000–8,000 บาท', cls: 'ชั้น 2+', who: 'สมดุลระหว่างเบี้ยและความคุ้มครอง', bg: '' },
                { budget: '> 8,000 บาท', cls: 'ชั้น 1', who: 'รถใหม่หรือแพง อยากคุ้มครองรอบด้าน', bg: 'bg-gray-50' },
