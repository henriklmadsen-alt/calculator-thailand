                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- FAQ -->
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-6">คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {[
