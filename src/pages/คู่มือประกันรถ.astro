---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout noGenericHowTo={true} title="ประกันรถยนต์ชั้น 1 2+ 3+ ต่างกันอย่างไร 2569 — คู่มือเลือกประกันรถ | Kamnuanlek"
  description="เปรียบเทียบประกันรถยนต์ชั้น 1, 2+, 2, 3+, 3 ครบถ้วน พร้อมตัวอย่างเบี้ยจริงสำหรับ Toyota Camry, Honda City, Yaris ปี 2569 ตามอัตรา คปภ."
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "คู่มือประกันรถยนต์ 2569", "item": "https://www.kamnuanlek.com/คู่มือประกันรถ/"}
    ]
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "วิธีเลือกประกันรถยนต์ให้เหมาะสม",
    "description": "4 ขั้นตอนเลือกประกันรถยนต์ตามอายุรถ มูลค่า สินเชื่อ และรูปแบบการขับ",
    "step": [
      {"@type": "HowToStep", "position": 1, "name": "ดูอายุและมูลค่ารถ", "text": "รถใหม่หรือมูลค่า > 1 ล้านบาท เลือกชั้น 1 รถวัยกลาง 500,000–1,000,000 บาท เลือกชั้น 2+ หรือ 2 รถเก่ามูลค่า < 500,000 บาท เลือกชั้น 2 หรือ 3+"},
      {"@type": "HowToStep", "position": 2, "name": "ตรวจสอบสัญญาสินเชื่อ", "text": "มีสินเชื่อรถยนต์หรือเช่าซื้อ ธนาคารบังคับซื้อชั้น 1 ชำระเงินสดจบแล้วเลือกได้ตามต้องการ"},
      {"@type": "HowToStep", "position": 3, "name": "พิจารณาวิธีการขับ", "text": "ขับในเมืองเท่านั้น ชั้น 2 หรือ 3+ เพียงพอ ขับหลายจังหวัดหรือมีผู้โดยสารประจำ เลือก 2+ ขับไกลบ่อยหรืออยากคุ้มครองรอบด้าน ชั้น 1"},
      {"@type": "HowToStep", "position": 4, "name": "เปรียบเทียบเบี้ยจากหลายบริษัท", "text": "ขอใบเสนอราคาจาก 3 บริษัทขึ้นไป เบี้ยต่างกันได้ถึง 20-30% สำหรับชั้นเดียวกัน ใช้เครื่องคำนวณประกันรถยนต์เพื่อดูตัวเลขคร่าวๆ ก่อน"}
    ]
  }</script>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "มีสินเชื่อรถต้องซื้อประกันชั้นไหน?",
        "acceptedAnswer": {"@type": "Answer", "text": "ธนาคารและบริษัทเช่าซื้อบังคับซื้อประกันชั้น 1 เสมอ เพื่อป้องกันความเสี่ยงกรณีรถเสียหายทั้งคัน"}
      },
      {
        "@type": "Question",
        "name": "ประกันชั้น 2+ กับ 3+ ต่างกันอย่างไร?",
        "acceptedAnswer": {"@type": "Answer", "text": "ชั้น 2+ คุ้มครองการชนและรถของเราด้วย ชั้น 3+ คุ้มครองเฉพาะกรณีชนกับยานพาหนะที่มีราคา ถ้าชนรถเก่าหรือสิ่งของ ชั้น 3+ ไม่คุ้มครองรถของเรา"}
      },
      {
        "@type": "Question",
        "name": "NCD คืออะไร ลดเบี้ยได้เท่าไร?",
        "acceptedAnswer": {"@type": "Answer", "text": "NCD (No Claim Discount) คือส่วนลดไม่เรียกร้อง ปีที่ 2 ลด 10% ปีที่ 3-5 ลด 15-25% ถ้าเรียกประกัน NCD จะหายและเบี้ยเพิ่มขึ้นปีถัดไป"}
      },
      {
        "@type": "Question",
        "name": "ประกันชั้น 1 คุ้มครองน้ำท่วมไหม?",
        "acceptedAnswer": {"@type": "Answer", "text": "ชั้น 1 สามารถเพิ่มความคุ้มครองน้ำท่วมได้ ชั้น 2+, 2, 3+, 3 ไม่มีการคุ้มครองน้ำท่วมในนโยบายมาตรฐาน ต้องปรึกษาบริษัทประกันโดยตรง"}
      }
    ]
  }</script>

  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">ประกันรถยนต์ชั้น 1 2+ 2 3+ 3 ต่างกันอย่างไร 2569</h1>
    <p class="text-lg text-gray-600 mb-2">คู่มือเลือกประกันรถให้ถูกชั้น ถูกราคา ตรงความต้องการ</p>
    <p class="text-sm text-gray-400 mb-8">อัปเดตล่าสุด: 2569 · ข้อมูลตามอัตรา <a href="https://www.oic.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">คปภ. (OIC)</a></p>

    <div class="mb-10 p-6 bg-blue-50 border border-blue-200 rounded-lg">
      <p class="text-gray-800">
        สำหรับคนไทยส่วนใหญ่ การซื้อประกันรถเป็นเรื่องที่งง เพราะมีชั้นความคุ้มครองหลายแบบและเบี้ยต่างกันมาก หน้านี้อธิบายชั้นประกันแต่ละตัว พร้อมตัวอย่างเบี้ยจริง เพื่อให้คุณเลือกได้ตรงกับความต้องการ
      </p>
    </div>

    <div class="space-y-12">

      <!-- Comparison Table -->
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">เปรียบเทียบความคุ้มครองทุกชั้น</h2>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ประกันชั้น</th>
                <th class="text-center px-3 py-3 font-semibold text-gray-900">คุ้มครองรถตัวเอง</th>
                <th class="text-center px-3 py-3 font-semibold text-gray-900">ไฟไหม้/โจรกรรม</th>
                <th class="text-center px-3 py-3 font-semibold text-gray-900">น้ำท่วม</th>
                <th class="text-center px-3 py-3 font-semibold text-gray-900">ชนยานพาหนะ</th>
                <th class="text-center px-3 py-3 font-semibold text-gray-900">บุคคลภายนอก</th>
                <th class="text-left px-3 py-3 font-semibold text-gray-900">เบี้ยประมาณ/ปี</th>
              </tr>
            </thead>
            <tbody>
              {[
                { cls: 'ชั้น 1', self: '✅ ครบ', fire: '✅', flood: '✅', crash: '✅', third: '✅', price: '8,000–15,000', bg: 'bg-green-50' },
                { cls: 'ชั้น 2+', self: '✅ เฉพาะชน', fire: '✅', flood: '❌', crash: '✅', third: '✅', price: '4,500–7,500', bg: '' },
                { cls: 'ชั้น 2', self: '❌', fire: '✅', flood: '❌', crash: '❌', third: '✅', price: '2,500–4,500', bg: 'bg-gray-50' },
                { cls: 'ชั้น 3+', self: '❌', fire: '❌', flood: '❌', crash: '✅', third: '✅', price: '2,800–4,500', bg: '' },
                { cls: 'ชั้น 3', self: '❌', fire: '❌', flood: '❌', crash: '❌', third: '✅', price: '1,200–2,000', bg: 'bg-gray-50' },
              ].map((row) => (
                <tr class={`border-t ${row.bg}`}>
                  <td class="px-4 py-3 font-semibold text-gray-900">{row.cls}</td>
                  <td class="px-3 py-3 text-center">{row.self}</td>
                  <td class="px-3 py-3 text-center">{row.fire}</td>
                  <td class="px-3 py-3 text-center">{row.flood}</td>
                  <td class="px-3 py-3 text-center">{row.crash}</td>
                  <td class="px-3 py-3 text-center">{row.third}</td>
                  <td class="px-3 py-3 text-gray-700">{row.price} บาท</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-500 mt-2">* เบี้ยสำหรับรถเล็ก-กลาง อายุ 3-5 ปี มูลค่า 500,000–1,000,000 บาท เบี้ยจริงขึ้นอยู่กับบริษัท สถานที่จดทะเบียน อายุผู้ขับ และประวัติอุบัติเหตุ</p>
      </section>

      <!-- Premium Examples -->
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">ตัวอย่างเบี้ยรถยนต์รุ่นยอดนิยม 2569</h2>
        <p class="text-gray-600 mb-6">คำนวณจากอัตราเบี้ย คปภ. ประจำปี 2569</p>

        <div class="space-y-6">
          {[
            {
              model: 'Toyota Camry', value: '~1,500,000 บาท', age: 'อายุ 3 ปี',
              rows: [
                { cls: 'ชั้น 1', price: '28,000–35,000', note: 'คุ้มครองทั้งรถ บุคคลภายนอก ไฟไหม้ น้ำท่วม' },
                { cls: 'ชั้น 2+', price: '14,000–18,000', note: 'ชนรถ บุคคลภายนอก ไฟไหม้' },
                { cls: 'ชั้น 2', price: '8,500–11,000', note: 'ไฟไหม้ บุคคลภายนอก' },
                { cls: 'ชั้น 3+', price: '10,500–13,000', note: 'ชนรถ บุคคลภายนอก' },
                { cls: 'ชั้น 3', price: '3,500–5,000', note: 'บุคคลภายนอกเท่านั้น' },
              ],
              tip: 'รถราคาแพง ส่วนใหญ่เลือกชั้น 1–2+ ถ้าชำระเงินสดจบแล้ว บางคนลดลงเป็นชั้น 2 หรือ 3+ เพื่อประหยัดเบี้ย'
            },
            {
              model: 'Honda City', value: '~700,000 บาท', age: 'อายุ 2 ปี',
              rows: [
                { cls: 'ชั้น 1', price: '12,000–16,000', note: 'ครบถ้วนทั้งหมด' },
                { cls: 'ชั้น 2+', price: '6,500–8,500', note: 'ชนรถ บุคคลภายนอก ไฟไหม้' },
                { cls: 'ชั้น 2', price: '4,000–5,500', note: 'ไฟไหม้ บุคคลภายนอก' },
                { cls: 'ชั้น 3+', price: '4,500–6,000', note: 'ชนรถ บุคคลภายนอก' },
                { cls: 'ชั้น 3', price: '1,800–2,500', note: 'บุคคลภายนอกเท่านั้น' },
              ],
              tip: 'ผู้ซื้อบ่อยเลือกชั้น 2+ (ความสมดุลระหว่างความคุ้มครองและเบี้ย) หรือชั้น 1 หากต้องการความคุ้มครองเต็มที่'
            },
            {
              model: 'Toyota Yaris', value: '~550,000 บาท', age: 'อายุ 2 ปี',
              rows: [
                { cls: 'ชั้น 1', price: '9,500–13,000', note: 'ครบถ้วนทั้งหมด' },
                { cls: 'ชั้น 2+', price: '5,000–6,500', note: 'ชนรถ บุคคลภายนอก ไฟไหม้' },
                { cls: 'ชั้น 2', price: '3,000–4,000', note: 'ไฟไหม้ บุคคลภายนอก' },
                { cls: 'ชั้น 3+', price: '3,500–4,500', note: 'ชนรถ บุคคลภายนอก' },
                { cls: 'ชั้น 3', price: '1,200–1,800', note: 'บุคคลภายนอกเท่านั้น' },
              ],
              tip: 'รถเล็ก ราคาไม่สูง ผู้ขับบ่อยเลือกชั้น 2 หรือ 3+ เพื่อประหยัด ถ้ามีสินเชื่อต้องซื้อชั้น 1'
            }
          ].map((car) => (
            <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
              <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
                <h3 class="font-bold text-gray-900">{car.model}</h3>
                <p class="text-sm text-gray-600">มูลค่า {car.value} · {car.age}</p>
              </div>
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-100">
                    <th class="text-left px-4 py-2 font-semibold text-gray-700">ชั้นประกัน</th>
                    <th class="text-left px-4 py-2 font-semibold text-gray-700">เบี้ย/ปี (บาท)</th>
                    <th class="text-left px-4 py-2 font-semibold text-gray-700 hidden sm:table-cell">ครอบคลุม</th>
                  </tr>
                </thead>
                <tbody>
                  {car.rows.map((r, i) => (
                    <tr class={`border-t ${i % 2 === 1 ? 'bg-gray-50' : ''}`}>
                      <td class="px-4 py-2 font-medium text-gray-900">{r.cls}</td>
                      <td class="px-4 py-2 text-gray-700">{r.price}</td>
                      <td class="px-4 py-2 text-gray-600 hidden sm:table-cell">{r.note}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
              <div class="px-4 py-3 bg-blue-50 border-t border-blue-100">
                <p class="text-sm text-blue-800"><strong>คำแนะนำ:</strong> {car.tip}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- How to Choose -->
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-6">4 ขั้นตอนเลือกประกันรถให้เหมาะสม</h2>
        <div class="space-y-4">
          {[
            {
              num: 1, title: 'ดูอายุและมูลค่ารถ',
              items: [
                'รถใหม่ (0–2 ปี) หรือมูลค่า > 1 ล้านบาท → ชั้น 1',
                'รถวัยกลาง (3–7 ปี) มูลค่า 500,000–1,000,000 บาท → ชั้น 2+ หรือ 2',
                'รถเก่า (> 7 ปี) มูลค่า < 500,000 บาท → ชั้น 2 หรือ 3+',
              ]
            },
            {
              num: 2, title: 'ตรวจสอบสัญญาสินเชื่อ',
              items: [
                'มีสินเชื่อรถยนต์หรือเช่าซื้อ → ธนาคารบังคับซื้อชั้น 1',
                'ชำระเงินสดจบแล้ว → เลือกได้ตามต้องการ',
              ]
            },
            {
              num: 3, title: 'พิจารณาวิธีการขับและสถานที่',
              items: [
                'ขับในเมืองเท่านั้น → ชั้น 2 หรือ 3+ เพียงพอ',
                'ขับหลายจังหวัดหรือมีผู้โดยสารประจำ → ชั้น 2+',
                'ขับไกลบ่อยหรืออยากคุ้มครองรอบด้าน → ชั้น 1',
              ]
            },
            {
              num: 4, title: 'เปรียบเทียบเบี้ยจากหลายบริษัท',
              items: [
                'ขอใบเสนอราคาจาก 3 บริษัทขึ้นไป เบี้ยต่างกันได้ถึง 20-30%',
                'ตรวจสอบ Deductible (ส่วนหักประกัน) Deductible สูง = เบี้ยถูกลง',
                'ใช้เครื่องคำนวณของเราเพื่อดูตัวเลขคร่าวๆ ก่อน',
              ]
            },
          ].map((step) => (
            <div class="flex gap-4 p-5 bg-white border border-gray-200 rounded-lg">
              <div class="flex-shrink-0 w-10 h-10 bg-primary-100 text-primary-700 rounded-full flex items-center justify-center font-bold">{step.num}</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-2">{step.title}</h3>
                <ul class="space-y-1">
                  {step.items.map((item) => (
                    <li class="text-sm text-gray-700">• {item}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Budget Guide -->
