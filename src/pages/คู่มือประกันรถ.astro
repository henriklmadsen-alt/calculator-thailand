        <h2 class="text-2xl font-bold text-gray-900 mb-4">เลือกประกันตามงบประมาณ</h2>
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">งบประมาณ/ปี</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900">ชั้นแนะนำ</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-900 hidden sm:table-cell">เหมาะกับใคร</th>
              </tr>
            </thead>
