---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณตารางเปลี่ยนหัวเทียนรถยนต์ ปี 2569 | Spark Plug | Kamnuanlek';
const pageDescription = 'คำนวณช่วงเปลี่ยนหัวเทียนตามประเภทและระยะทาง พร้อมประมาณค่าใช้จ่าย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณตารางเปลี่ยนหัวเทียน/`;

const faqData = [
  {
    question: 'หัวเทียนอิริเดียมดีกว่าหัวเทียนทองแดงอย่างไร?',
    answer: 'หัวเทียนอิริเดียม (Iridium) มีอายุการใช้งานยาวที่สุดประมาณ 100,000 กม. เนื่องจากอิริเดียมเป็นโลหะที่แข็งและทนความร้อนสูงมาก ช่วยให้การจุดระเบิดแม่นยำและสม่ำเสมอตลอดอายุการใช้งาน หัวเทียนทองแดง (Copper) อายุสั้นที่สุด 20,000 กม. แต่ราคาถูกที่สุด ส่วนแพลทินัม (Platinum) อยู่ตรงกลางที่ 60,000 กม.',
  },
  {
    question: 'อาการอะไรบ่งบอกว่าหัวเทียนเสื่อมสภาพ?',
    answer: 'อาการที่ควรระวัง ได้แก่ เครื่องยนต์สั่นหรือกระตุกขณะเดินเบา การตอบสนองของคันเร่งช้าลง น้ำมันเชื้อเพลิงสิ้นเปลืองผิดปกติ เครื่องยนต์สตาร์ทยาก มีควันดำจากท่อไอเสีย และเสียงเครื่องยนต์ผิดปกติ สัญญาณเหล่านี้อาจเกิดจากหัวเทียนสึกหรอหรือสกปรก',
  },
  {
    question: 'หัวเทียนหนึ่งหัวรองรับกระบอกสูบกี่กระบอก?',
    answer: 'รถยนต์ส่วนใหญ่มีหัวเทียนหนึ่งหัวต่อหนึ่งกระบอกสูบ รถ 4 สูบจะใช้หัวเทียน 4 หัว รถ 6 สูบใช้ 6 หัว และรถ 8 สูบใช้ 8 หัว อย่างไรก็ตาม รถบางรุ่นมีระบบ Twin Spark ที่ใช้หัวเทียน 2 หัวต่อกระบอกสูบ ควรตรวจสอบจำนวนที่แน่นอนจากคู่มือรถหรือสอบถามช่างก่อนซื้อ',
  },
  {
    question: 'ควรเปลี่ยนหัวเทียนทีละหัวหรือทั้งชุด?',
    answer: 'แนะนำให้เปลี่ยนหัวเทียนทั้งชุดพร้อมกันทุกครั้ง เนื่องจากหัวเทียนทุกหัวมีอายุการใช้งานใกล้เคียงกัน การเปลี่ยนพร้อมกันช่วยประหยัดค่าแรงและให้การทำงานของเครื่องยนต์สม่ำเสมอกันทุกกระบอก นอกจากนี้ควรตรวจสอบสายหัวเทียนหรือคอยล์จุดระเบิดพร้อมกันด้วย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณตารางเปลี่ยนหัวเทียนรถยนต์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณตารางเปลี่ยนหัวเทียนรถยนต์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณตารางเปลี่ยนหัวเทียนรถยนต์
    </h1>
    <p class="text-gray-600 mb-6">
      คำนวณกำหนดการเปลี่ยนหัวเทียนตามประเภทและระยะทาง พร้อมประมาณค่าใช้จ่ายทั้งหมด
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="calculator-form" class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="plug-type" class="block text-sm font-medium text-gray-700 mb-1">
              ประเภทหัวเทียน
            </label>
            <select
              id="plug-type"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              <option value="copper">ทองแดง / Copper (20,000 กม.)</option>
              <option value="platinum">แพลทินัม / Platinum (60,000 กม.)</option>
              <option value="iridium">อิริเดียม / Iridium (100,000 กม.)</option>
            </select>
          </div>
          <div>
            <label for="cylinders" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนกระบอกสูบ (หัว)
            </label>
            <select
              id="cylinders"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              <option value="3">3 สูบ</option>
              <option value="4" selected>4 สูบ</option>
              <option value="6">6 สูบ</option>
              <option value="8">8 สูบ</option>
            </select>
          </div>
          <div>
            <label for="last-replace-year" class="block text-sm font-medium text-gray-700 mb-1">
              ปีที่เปลี่ยนครั้งล่าสุด (พ.ศ.)
            </label>
            <input
              type="text"
              id="last-replace-year"
              inputmode="numeric"
              placeholder="เช่น 2566"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="last-replace-month" class="block text-sm font-medium text-gray-700 mb-1">
              เดือนที่เปลี่ยนครั้งล่าสุด
            </label>
            <select
              id="last-replace-month"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              <option value="1">มกราคม</option>
              <option value="2">กุมภาพันธ์</option>
              <option value="3">มีนาคม</option>
              <option value="4" selected>เมษายน</option>
              <option value="5">พฤษภาคม</option>
              <option value="6">มิถุนายน</option>
              <option value="7">กรกฎาคม</option>
              <option value="8">สิงหาคม</option>
              <option value="9">กันยายน</option>
              <option value="10">ตุลาคม</option>
              <option value="11">พฤศจิกายน</option>
              <option value="12">ธันวาคม</option>
            </select>
          </div>
          <div>
            <label for="last-mileage" class="block text-sm font-medium text-gray-700 mb-1">
              เลขไมล์ตอนที่เปลี่ยนครั้งล่าสุด (กม.)
            </label>
            <input
              type="text"
              id="last-mileage"
              inputmode="decimal"
              placeholder="เช่น 40000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="monthly-km" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะทางเฉลี่ยต่อเดือน (กม.)
            </label>
            <input
              type="text"
              id="monthly-km"
              inputmode="decimal"
              placeholder="เช่น 2000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="plug-price" class="block text-sm font-medium text-gray-700 mb-1">
              ราคาหัวเทียนต่อหัว (บาท)
            </label>
            <input
              type="text"
              id="plug-price"
              inputmode="decimal"
              placeholder="เช่น 350"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="labor-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าแรง (บาท)
            </label>
            <input
              type="text"
              id="labor-cost"
              inputmode="decimal"
              placeholder="เช่น 600"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>
        <button
          type="button"
          id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ
        </button>
      </form>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-blue-700 font-medium mb-1">กำหนดเปลี่ยนครั้งถัดไป</div>
            <div id="res-next-km" class="text-2xl font-bold text-blue-800">-</div>
            <div class="text-xs text-blue-600 mt-1">กิโลเมตร</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4">
            <div class="text-sm text-purple-700 font-medium mb-1">ระยะทางที่เหลือ</div>
            <div id="res-remaining-km" class="text-2xl font-bold text-purple-800">-</div>
            <div class="text-xs text-purple-600 mt-1">กิโลเมตร</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4">
            <div class="text-sm text-green-700 font-medium mb-1">ค่าหัวเทียนทั้งชุด</div>
            <div id="res-parts-cost" class="text-2xl font-bold text-green-800">-</div>
            <div id="res-parts-detail" class="text-xs text-green-600 mt-1">-</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4">
            <div class="text-sm text-orange-700 font-medium mb-1">ค่าใช้จ่ายรวม (ค่าหัวเทียน + ค่าแรง)</div>
            <div id="res-total-cost" class="text-2xl font-bold text-orange-800">-</div>
            <div class="text-xs text-orange-600 mt-1">บาท</div>
          </div>
        </div>
        <div id="status-panel" class="rounded-lg p-4 border">
          <div id="status-label" class="text-sm font-medium mb-1">สถานะหัวเทียน</div>
          <div id="status-message" class="text-base font-semibold">-</div>
          <div id="status-due-date" class="text-sm mt-1">-</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">หัวเทียนรถยนต์และผลต่อสมรรถนะเครื่องยนต์</h2>
      <p>
        หัวเทียนทำหน้าที่จุดระเบิดส่วนผสมของน้ำมันและอากาศในกระบอกสูบ
        หัวเทียนที่เสื่อมสภาพทำให้การเผาไหม้ไม่สมบูรณ์ เครื่องยนต์สูญเสียกำลัง
        สิ้นเปลืองน้ำมันมากขึ้น และอาจก่อให้เกิดมลพิษทางอากาศสูงขึ้น
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ระยะเปลี่ยนหัวเทียนตามประเภท</h3>
      <div class="bg-gray-50 rounded-lg p-4 my-4 space-y-2">
        <p class="font-medium">ทองแดง (Copper): ทุก 20,000 กม. — ราคาประหยัดที่สุด</p>
        <p class="font-medium">แพลทินัม (Platinum): ทุก 60,000 กม. — คุณภาพปานกลาง</p>
        <p class="font-semibold text-primary-700">อิริเดียม (Iridium): ทุก 100,000 กม. — อายุยาว ประสิทธิภาพสูงสุด</p>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">การเลือกหัวเทียนที่เหมาะสม</h3>
      <p>
        การเลือกหัวเทียนควรอ้างอิงตามคำแนะนำของผู้ผลิตรถยนต์เป็นหลัก
        ไม่ควรใช้หัวเทียนที่มีค่าความร้อน (Heat Range) ผิดจากที่กำหนด
        เพราะอาจทำให้เครื่องยนต์เสียหายได้ แม้ว่าหัวเทียนอิริเดียมจะมีราคาสูงกว่า
        แต่เมื่อคำนวณต้นทุนต่อกิโลเมตรอาจคุ้มค่ากว่าเมื่อรวมค่าแรงที่ประหยัดได้
      </p>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณตารางเปลี่ยนหัวเทียน/" />
    <RelatedCalculators currentHref="/คำนวณตารางเปลี่ยนหัวเทียน/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการทั่วไป
      ระยะเปลี่ยนหัวเทียนที่แน่นอนควรอ้างอิงตามคู่มือรถยนต์ของผู้ผลิต
      ควรให้ช่างผู้เชี่ยวชาญตรวจสอบสภาพหัวเทียนและระบบจุดระเบิดเป็นประจำ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number, decimals = 2): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: decimals, maximumFractionDigits: decimals }).format(n);
    }

    const THAI_MONTHS = [
      'มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน',
      'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม',
    ];

    const PLUG_INTERVAL: Record<string, number> = {
      copper: 20000,
      platinum: 60000,
      iridium: 100000,
    };

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const plugType = (document.getElementById('plug-type') as HTMLSelectElement).value;
      const cylinders = parseInt((document.getElementById('cylinders') as HTMLSelectElement).value, 10);
      const lastYear = parseNum((document.getElementById('last-replace-year') as HTMLInputElement).value);
      const lastMonth = parseInt((document.getElementById('last-replace-month') as HTMLSelectElement).value, 10);
      const lastMileage = parseNum((document.getElementById('last-mileage') as HTMLInputElement).value);
      const monthlyKm = parseNum((document.getElementById('monthly-km') as HTMLInputElement).value);
      const plugPrice = parseNum((document.getElementById('plug-price') as HTMLInputElement).value);
      const laborCost = parseNum((document.getElementById('labor-cost') as HTMLInputElement).value);

      if (lastYear <= 0 || lastMileage <= 0 || monthlyKm <= 0) {
        alert('กรุณากรอกปีที่เปลี่ยน เลขไมล์ตอนเปลี่ยน และระยะทางต่อเดือน');
        return;
      }

      const interval = PLUG_INTERVAL[plugType] ?? 20000;
      const nextDueKm = lastMileage + interval;

      // Current date in BE
      const now = new Date();
      const currentYear = now.getFullYear() + 543;
      const currentMonth = now.getMonth() + 1;
      const currentTotalMonths = currentYear * 12 + (currentMonth - 1);
      const lastTotalMonths = lastYear * 12 + (lastMonth - 1);
      const monthsElapsed = currentTotalMonths - lastTotalMonths;

      const currentMileageEst = lastMileage + monthsElapsed * monthlyKm;
      const remainingKm = Math.max(0, nextDueKm - currentMileageEst);
      const remainingMonths = monthlyKm > 0 ? remainingKm / monthlyKm : 0;

      // Due date
      const dueTotalMonths = lastTotalMonths + Math.round(interval / monthlyKm);
      const dueYear = Math.floor(dueTotalMonths / 12);
      const dueMonth = (dueTotalMonths % 12) + 1;

      // Costs
      const partsCost = plugPrice * cylinders;
      const totalCost = partsCost + laborCost;

      (document.getElementById('res-next-km') as HTMLElement).textContent = fmt(nextDueKm, 0);
      (document.getElementById('res-remaining-km') as HTMLElement).textContent = fmt(remainingKm, 0);
      (document.getElementById('res-parts-cost') as HTMLElement).textContent =
        partsCost > 0 ? fmt(partsCost, 0) : 'ไม่ระบุ';
      (document.getElementById('res-parts-detail') as HTMLElement).textContent =
        plugPrice > 0 ? `${fmt(plugPrice, 0)} บาท × ${cylinders} หัว` : '';
      (document.getElementById('res-total-cost') as HTMLElement).textContent =
        totalCost > 0 ? fmt(totalCost, 0) : 'ไม่ระบุ';

      const panel = document.getElementById('status-panel') as HTMLElement;
      const label = document.getElementById('status-label') as HTMLElement;
      const message = document.getElementById('status-message') as HTMLElement;
      const dueDateEl = document.getElementById('status-due-date') as HTMLElement;

      const dueDateStr = `กำหนดเปลี่ยนครั้งถัดไป: ${THAI_MONTHS[dueMonth - 1]} ${dueYear}`;

      if (remainingKm <= 0) {
        panel.className = 'rounded-lg p-4 border border-red-300 bg-red-50';
        label.className = 'text-sm font-medium mb-1 text-red-700';
        label.textContent = 'สถานะหัวเทียน — เกินกำหนดแล้ว!';
        message.className = 'text-base font-semibold text-red-800';
        message.textContent = `เกินกำหนดมาแล้วประมาณ ${fmt(currentMileageEst - nextDueKm, 0)} กม. — ควรนัดเปลี่ยนหัวเทียนโดยเร็ว`;
        dueDateEl.className = 'text-sm mt-1 text-red-600';
        dueDateEl.textContent = dueDateStr;
      } else if (remainingMonths < 3) {
        panel.className = 'rounded-lg p-4 border border-orange-300 bg-orange-50';
        label.className = 'text-sm font-medium mb-1 text-orange-700';
        label.textContent = 'สถานะหัวเทียน — ใกล้ถึงกำหนด';
        message.className = 'text-base font-semibold text-orange-800';
        message.textContent = `อีกประมาณ ${fmt(remainingMonths, 1)} เดือน (${fmt(remainingKm, 0)} กม.) ถึงกำหนด`;
        dueDateEl.className = 'text-sm mt-1 text-orange-600';
        dueDateEl.textContent = dueDateStr;
      } else {
        panel.className = 'rounded-lg p-4 border border-green-300 bg-green-50';
        label.className = 'text-sm font-medium mb-1 text-green-700';
        label.textContent = 'สถานะหัวเทียน — ยังอยู่ในเกณฑ์ดี';
        message.className = 'text-base font-semibold text-green-800';
        message.textContent = `ยังใช้งานได้อีกประมาณ ${fmt(remainingMonths, 1)} เดือน (${fmt(remainingKm, 0)} กม.)`;
        dueDateEl.className = 'text-sm mt-1 text-green-600';
        dueDateEl.textContent = dueDateStr;
      }

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
    });

    document.querySelectorAll('#calculator-form input').forEach(input => {
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
