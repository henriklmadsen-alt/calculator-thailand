---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');

const financialCalcs = [
  { title: 'เครื่องคำนวณภาษีเงินได้', slug: '/คำนวณภาษีเงินได้บุคคลธรรมดา/', desc: 'คำนวณภาษีเงินได้บุคคลธรรมดาอย่างรวดเร็ว' },
  { title: 'เครื่องคำนวณเงินเดือน', slug: '/คำนวณเงินเดือนสุทธิ/', desc: 'คำนวณเงินเดือนสุทธิหลังหักภาษีและประกันสังคม' },
  { title: 'เครื่องคำนวณผ่อนกู้', slug: '/คำนวณผ่อนกู้/', desc: 'คำนวณค่างวดสินเชื่อรายเดือน' },
  { title: 'เครื่องคำนวณผ่อนบ้าน', slug: '/คำนวณผ่อนบ้าน/', desc: 'คำนวณค่างวดสินเชื่อบ้าน' },
  { title: 'เครื่องคำนวณผ่อนรถ', slug: '/คำนวณผ่อนรถ/', desc: 'คำนวณค่างวดสินเชื่อรถยนต์' },
  { title: 'เครื่องคำนวณดอกเบี้ยเงินฝาก', slug: '/คำนวณดอกเบี้ยเงินฝาก/', desc: 'คำนวณผลตอบแทนเงินออม' },
  { title: 'ดอกเบี้ยบัตรเครดิต', slug: '/คำนวณดอกเบี้ยบัตรเครดิต/', desc: 'คำนวณดอกเบี้ยบัตรเครดิต' },
  { title: 'เครื่องคำนวณ VAT', slug: '/คำนวณมูลค่าเพิ่ม/', desc: 'คำนวณภาษีมูลค่าเพิ่ม' },
  { title: 'เครื่องคำนวณ NPV', slug: '/คำนวณ-npv/', desc: 'เครื่องมือวิเคราะห์การลงทุน' },
  { title: 'เครื่องคำนวณ IRR', slug: '/คำนวณ-irr/', desc: 'คำนวณอัตราผลตอบแทนภายใน' },
];
---

<BaseLayout
  title="เครื่องคำนวณการเงินไทย — ภาษี สินเชื่อ เงินออม ครบทุกเรื่อง | Kamnuanlek"
  description="เครื่องคำนวณการเงินไทยฟรีครบชุด ภาษีเงินได้ เงินเดือนสุทธิ ผ่อนบ้าน ผ่อนรถ ดอกเบี้ยออม VAT NPV IRR คำนวณได้ทันที อัปเดตปี 2569"
>
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "หน้าหลัก", "item": "https://www.kamnuanlek.com/"},
      {"@type": "ListItem", "position": 2, "name": "เครื่องคำนวณการเงินไทย — ภาษี สินเชื่อ เงินออม ครบทุกเรื่อง", "item": "https://www.kamnuanlek.com/ตัวช่วยคำนวณการเงิน/"}
    ]
  }</script>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณการเงินไทยครบชุด</h1>
    <p class="text-xl text-gray-600 mb-12">
      เครื่องมือการเงินที่จำเป็นสำหรับการวางแผนส่วนตัว คำนวณภาษี และวิเคราะห์การลงทุน ฟรีทั้งหมด ไม่ต้องสมัครสมาชิก
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {financialCalcs.map((calc) => (
        <a
          href={calc.slug}
          class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all"
        >
          <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-600">{calc.title}</h3>
          <p class="text-gray-600 text-sm mb-4">{calc.desc}</p>
          <span class="text-primary-600 text-sm font-medium">ใช้เครื่องคำนวณ →</span>
        </a>
      ))}
    </div>

    <div class="mt-12 p-8 bg-gradient-to-r from-primary-50 to-blue-50 rounded-2xl border border-primary-200">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">ทำไมต้องใช้เครื่องคำนวณเหล่านี้?</h2>
      <ul class="space-y-3 text-gray-700">
        <li>✓ สูตรคำนวณที่แม่นยำตามกฎหมายภาษีและการเงินไทย</li>
        <li>✓ ผลลัพธ์ทันที ไม่ต้องรอ ไม่ต้องสมัครสมาชิก</li>
        <li>✓ วางแผนล่วงหน้า เห็นผลกระทบทางภาษีก่อนสิ้นปี</li>
        <li>✓ เปรียบเทียบตัวเลือก ประเมินสถานการณ์สินเชื่อ/ออมเงินต่างๆ</li>
      </ul>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">สำรวจเครื่องมือเพิ่มเติม</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/เครื่องคำนวณการเงินชั้นยอด/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 เครื่องมือการเงิน 10 อันดับแรก</span>
          <p class="text-gray-600 text-sm mt-2">เครื่องคำนวณการเงินที่ควรรู้จัก</p>
        </a>
        <a href="/เปรียบเทียบเครื่องคำนวณภาษี/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💼 เปรียบเทียบเครื่องคำนวณภาษี</span>
          <p class="text-gray-600 text-sm mt-2">ภาษีเงินได้ VAT ภาษีนิติบุคคล — คุณต้องใช้ตัวไหน?</p>
        </a>
        <a href="/เปรียบเทียบสินเชื่อ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏦 คู่มือเปรียบเทียบสินเชื่อ</span>
          <p class="text-gray-600 text-sm mt-2">บ้าน รถ หรือสินเชื่อบุคคล — เปรียบเทียบตัวเลือก</p>
        </a>
        <a href="/วิธีคำนวณภาษีเงินได้ไทย/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📚 วิธีคำนวณภาษี</span>
          <p class="text-gray-600 text-sm mt-2">คู่มือคำนวณภาษีเงินได้ทีละขั้นตอน</p>
        </a>
        <a href="/ผิดพลาดภาษีทั่วไป/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">❌ ข้อผิดพลาดภาษีที่พบบ่อย</span>
          <p class="text-gray-600 text-sm mt-2">หลีกเลี่ยง 8 ข้อผิดพลาดนี้และประหยัดเงิน</p>
        </a>
        <a href="/เครื่องคำนวณคณิตศาสตร์/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📐 เครื่องมือคณิตศาสตร์และสถิติ</span>
          <p class="text-gray-600 text-sm mt-2">ค่าเฉลี่ย มัธยฐาน ส่วนเบี่ยงเบนมาตรฐาน และอื่นๆ</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
