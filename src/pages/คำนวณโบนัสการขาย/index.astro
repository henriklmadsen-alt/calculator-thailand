---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณโบนัสการขาย ปี 2569 ตามยอดขายจริงเทียบกับเป้าหมาย | Kamnuanlek';
const pageDescription = 'คำนวณโบนัสการขาย Sales Incentive ตามเปอร์เซ็นต์ทำได้เทียบกับเป้าหมาย ถึง 100% รับเต็ม 80-99% รับสัดส่วน ต่ำกว่า 80% ไม่ได้โบนัส';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณโบนัสการขาย/`;

const faqData = [
  {
    question: 'ถ้าทำยอดได้ 90% ของเป้าได้โบนัสเท่าไร?',
    answer: 'ตามสูตรที่ใช้: ถ้าทำได้ 80-99% ของเป้าหมาย โบนัสจะคิดสัดส่วน เช่น ทำได้ 90% โบนัสฐาน = 90÷100 × โบนัสเต็ม',
  },
  {
    question: 'ถ้าทำยอดเกิน 100% จะได้โบนัสพิเศษไหม?',
    answer: 'ขึ้นอยู่กับนโยบายบริษัท บางองค์กรกำหนดโบนัสพิเศษสำหรับยอดเกินเป้า เช่น 110% ของเป้า = โบนัส 120% หรือคิดคอมมิชชั่นเพิ่มในส่วนที่เกิน',
  },
  {
    question: 'เกณฑ์ขั้นต่ำ 80% มาจากไหน?',
    answer: 'เป็นเกณฑ์ที่นิยมใช้ในหลายองค์กร บริษัทอาจกำหนดต่างกัน เช่น 70%, 75%, หรือ 85% ขึ้นอยู่กับนโยบายการจ่ายโบนัส',
  },
  {
    question: 'โบนัสการขายต่างจากค่าคอมมิชชั่นอย่างไร?',
    answer: 'คอมมิชชั่นมักจ่ายตามยอดขายทุกบาท ส่วนโบนัสการขายมักมีเป้าหมายและเงื่อนไขขั้นต่ำ และจ่ายครั้งเดียวหรือรายไตรมาส',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณโบนัสการขาย',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณโบนัสการขาย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">Sales Incentive — ยอดจริง vs เป้าหมาย</p>
      <p class="mt-1 text-sm text-slate-700">≥100% = โบนัสเต็ม | 80-99% = โบนัสสัดส่วน | &lt;80% = ไม่ได้โบนัส</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับพนักงานขายที่ต้องการตรวจสอบโบนัสตามเป้าหมาย</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณโบนัสการขาย ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเป้าหมายยอดขาย ยอดขายจริง และโบนัสเต็มจำนวน ระบบจะคำนวณโบนัสที่พึงได้รับตามเปอร์เซ็นต์ทำได้
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="sales-bonus-form" class="space-y-5">
        <p id="sales-bonus-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="sb-target" class="mb-1 block text-sm font-medium text-gray-700">เป้าหมายยอดขาย (บาท)</label>
            <input type="text" id="sb-target" inputmode="numeric" placeholder="เช่น 1,000,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="sb-target-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="sb-actual" class="mb-1 block text-sm font-medium text-gray-700">ยอดขายจริง (บาท)</label>
            <input type="text" id="sb-actual" inputmode="numeric" placeholder="เช่น 920,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="sb-actual-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="sb-full-bonus" class="mb-1 block text-sm font-medium text-gray-700">โบนัสเต็มจำนวน (บาท)</label>
            <input type="text" id="sb-full-bonus" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="sb-full-bonus-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="sb-min-threshold" class="mb-1 block text-sm font-medium text-gray-700">เกณฑ์ขั้นต่ำ (%)</label>
            <input type="text" id="sb-min-threshold" inputmode="decimal" placeholder="เช่น 80"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">ต่ำกว่าเกณฑ์นี้ไม่ได้รับโบนัส (ค่าเริ่มต้น 80%)</p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณโบนัสการขาย
        </button>
      </form>
    </div>

    <div id="sales-bonus-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">โบนัสที่ได้รับ</div>
            <div id="res-sb-bonus" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ทำได้เปอร์เซ็นต์</div>
            <div id="res-sb-pct" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">สถานะโบนัส</div>
            <div id="res-sb-status" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ยอดขายจริง</span>
            <span id="res-sb-actual" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">เป้าหมาย</span>
            <span id="res-sb-target" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ยอดขายส่วนเกิน/ขาด</span>
            <span id="res-sb-diff" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>% ทำได้ = ยอดขายจริง ÷ เป้าหมาย × 100</li>
        <li>ถ้า % ทำได้ ≥ 100%: โบนัส = โบนัสเต็มจำนวน</li>
        <li>ถ้า % ทำได้ อยู่ในช่วงเกณฑ์ขั้นต่ำ – 99%: โบนัส = โบนัสเต็ม × (% ทำได้ ÷ 100)</li>
        <li>ถ้า % ทำได้ &lt; เกณฑ์ขั้นต่ำ: โบนัส = 0</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณค่าคอมมิชชั่น/">คำนวณค่าคอมมิชชั่น</a></li>
        <li><a href="/คำนวณโบนัสประจำปี/">คำนวณโบนัสประจำปี</a></li>
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#sales-bonus-results" />
    <RelatedArticles currentHref="/คำนวณโบนัสการขาย/" />
    <RelatedCalculators currentHref="/คำนวณโบนัสการขาย/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการตามสูตรที่ระบุ โบนัสจริงขึ้นอยู่กับนโยบายและเงื่อนไขของบริษัท
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('sales-bonus-form');
    const formError = document.getElementById('sales-bonus-form-error');
    const resultBox = document.getElementById('sales-bonus-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['sb-target-error','sb-actual-error','sb-full-bonus-error'].forEach((id) => setErr(id, ''));

      const target = parseNum(document.getElementById('sb-target').value);
      const actual = parseNum(document.getElementById('sb-actual').value);
      const fullBonus = parseNum(document.getElementById('sb-full-bonus').value);
      const minThreshold = parseNum(document.getElementById('sb-min-threshold').value) || 80;

      let hasError = false;
      if (!Number.isFinite(target) || target <= 0) { setErr('sb-target-error', 'กรอกเป้าหมายมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(actual) || actual < 0) { setErr('sb-actual-error', 'กรอกยอดขายจริงมากกว่าหรือเท่ากับ 0'); hasError = true; }
      if (!Number.isFinite(fullBonus) || fullBonus <= 0) { setErr('sb-full-bonus-error', 'กรอกโบนัสเต็มจำนวนมากกว่า 0'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const achievePct = (actual / target) * 100;
      let bonus = 0;
      let status = '';

      if (achievePct >= 100) {
        bonus = fullBonus;
        status = 'ครบเป้า 🎉';
      } else if (achievePct >= minThreshold) {
        bonus = fullBonus * (achievePct / 100);
        status = 'บางส่วน';
      } else {
        bonus = 0;
        status = 'ไม่ถึงเกณฑ์';
      }

      const diff = actual - target;
      setText('res-sb-bonus', formatMoney(bonus));
      setText('res-sb-pct', `${achievePct.toFixed(2)}%`);
      setText('res-sb-status', status);
      setText('res-sb-actual', formatMoney(actual));
      setText('res-sb-target', formatMoney(target));
      setText('res-sb-diff', diff >= 0 ? `+${formatMoney(diff)}` : `−${formatMoney(Math.abs(diff))}`);

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
