---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณปฏิทินชำระรายเดือน ปี 2569 — Recurring Payment Calendar | เครื่องคำนวณไทย';
const pageDescription = 'สร้างปฏิทินชำระรายเดือน ป้อนวันที่ชำระครั้งแรก จำนวนงวด และยอดต่องวด ดูตารางวันชำระและยอดทั้งหมดล่วงหน้า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณปฏิทินชำระรายเดือน/`;

const faqData = [
  {
    question: 'ปฏิทินชำระรายเดือนช่วยอะไรได้บ้าง?',
    answer: 'ช่วยวางแผนกระแสเงินสด ทราบล่วงหน้าว่าต้องจ่ายเมื่อไหร่เท่าไหร่ ลดความเสี่ยงผิดนัดชำระ และจัดการงบประมาณรายเดือนได้ดีขึ้น',
  },
  {
    question: 'ถ้าวันชำระตรงกับวันหยุดทำอย่างไร?',
    answer: 'ควรชำระล่วงหน้า 1–2 วันทำการ เพราะระบบธนาคารอาจประมวลผลล่าช้าในวันหยุดนักขัตฤกษ์ บางสัญญาระบุให้ชำระในวันทำการถัดไป',
  },
  {
    question: 'ผ่อนรายเดือนกับผ่อนรายปักษ์ต่างกันอย่างไร?',
    answer: 'ผ่อนรายปักษ์ (ทุก 2 สัปดาห์) ช่วยลดดอกเบี้ยสะสมได้มากกว่า เพราะชำระบ่อยกว่า แต่ต้องแน่ใจว่ากระแสเงินสดพอเพียงทุก 2 สัปดาห์',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณปฏิทินชำระรายเดือน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณปฏิทินชำระรายเดือน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-indigo-100 bg-indigo-50 p-4">
      <p class="text-sm font-semibold text-indigo-700">คำนวณปฏิทินชำระรายเดือน — Recurring Payment Calendar</p>
      <p class="mt-1 text-sm text-slate-700">สร้างตารางวันชำระล่วงหน้าทุกงวด พร้อมยอดสะสม</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณปฏิทินชำระรายเดือน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนวันที่ชำระครั้งแรก จำนวนงวด และยอดต่องวด เพื่อดูตารางวันชำระทั้งหมด
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="cal-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="cal-start" class="mb-1 block text-sm font-medium text-gray-700">วันที่ชำระงวดแรก</label>
            <input type="date" id="cal-start"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="cal-start-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="cal-installment" class="mb-1 block text-sm font-medium text-gray-700">ยอดชำระต่องวด (บาท)</label>
            <input type="text" id="cal-installment" inputmode="numeric" placeholder="เช่น 5,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="cal-installment-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="cal-terms" class="mb-1 block text-sm font-medium text-gray-700">จำนวนงวด</label>
            <input type="number" id="cal-terms" min="1" max="120" placeholder="เช่น 12"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="cal-terms-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="cal-freq" class="mb-1 block text-sm font-medium text-gray-700">ความถี่</label>
            <select id="cal-freq" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="monthly" selected>รายเดือน</option>
              <option value="biweekly">ราย 2 สัปดาห์</option>
              <option value="weekly">รายสัปดาห์</option>
              <option value="quarterly">รายไตรมาส</option>
            </select>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          สร้างปฏิทินชำระ
        </button>
      </form>
    </div>

    <div id="cal-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ปฏิทินชำระ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-2">
          <div class="rounded-lg bg-indigo-50 p-3 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดรวมทั้งหมด</div>
            <div id="res-cal-total" class="text-xl font-bold text-indigo-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-3 text-center">
            <div class="mb-1 text-sm text-gray-600">งวดสุดท้าย</div>
            <div id="res-cal-last" class="text-xl font-bold text-blue-700">-</div>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 text-left">
                <th class="px-3 py-2 font-medium text-gray-700">งวด</th>
                <th class="px-3 py-2 font-medium text-gray-700">วันที่ชำระ</th>
                <th class="px-3 py-2 font-medium text-gray-700 text-right">ยอดชำระ</th>
                <th class="px-3 py-2 font-medium text-gray-700 text-right">ยอดสะสม</th>
              </tr>
            </thead>
            <tbody id="cal-table-body" class="divide-y divide-gray-100"></tbody>
          </table>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณวันครบกำหนด-invoice/">คำนวณวันครบกำหนดชำระ Invoice</a></li>
        <li><a href="/คำนวณแบ่งชำระ/">คำนวณแบ่งชำระ</a></li>
        <li><a href="/ตารางผ่อนชำระเงินกู้/">ตารางผ่อนชำระเงินกู้</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#cal-results" />
    <RelatedArticles currentHref="/คำนวณปฏิทินชำระรายเดือน/" />
    <RelatedCalculators currentHref="/คำนวณปฏิทินชำระรายเดือน/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>
  </article>

  <script type="module">
    const today = new Date();
    const dateInput = document.getElementById('cal-start');
    if (dateInput) dateInput.value = today.toISOString().split('T')[0];

    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }
    function fmtDate(d) {
      return d.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' });
    }
    function addPeriod(date, freq) {
      const d = new Date(date);
      if (freq === 'monthly') d.setMonth(d.getMonth() + 1);
      else if (freq === 'biweekly') d.setDate(d.getDate() + 14);
      else if (freq === 'weekly') d.setDate(d.getDate() + 7);
      else if (freq === 'quarterly') d.setMonth(d.getMonth() + 3);
      return d;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }

    document.getElementById('cal-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const startVal = document.getElementById('cal-start').value;
      const installment = parseNum(document.getElementById('cal-installment').value);
      const terms = parseInt(document.getElementById('cal-terms').value);
      const freq = document.getElementById('cal-freq').value;

      let hasError = false;
      if (!startVal) { document.getElementById('cal-start-error').textContent = 'กรุณาเลือกวันที่'; document.getElementById('cal-start-error').classList.remove('hidden'); hasError = true; }
      if (!Number.isFinite(installment) || installment <= 0) { document.getElementById('cal-installment-error').textContent = 'กรอกยอดชำระมากกว่า 0'; document.getElementById('cal-installment-error').classList.remove('hidden'); hasError = true; }
      if (!terms || terms <= 0) { document.getElementById('cal-terms-error').textContent = 'กรอกจำนวนงวดมากกว่า 0'; document.getElementById('cal-terms-error').classList.remove('hidden'); hasError = true; }
      if (hasError) { document.getElementById('cal-results').classList.add('hidden'); return; }

      ['cal-start-error','cal-installment-error','cal-terms-error'].forEach(id => { const el = document.getElementById(id); if (el) { el.textContent = ''; el.classList.add('hidden'); } });

      let currentDate = new Date(startVal);
      let cumulative = 0;
      const tbody = document.getElementById('cal-table-body');
      tbody.innerHTML = '';
      let lastDate = null;

      for (let i = 1; i <= terms; i++) {
        cumulative += installment;
        const row = document.createElement('tr');
        row.className = i % 2 === 0 ? 'bg-gray-50' : '';
        row.innerHTML = `
          <td class="px-3 py-2 text-gray-700">${i}</td>
          <td class="px-3 py-2 text-gray-700">${fmtDate(currentDate)}</td>
          <td class="px-3 py-2 text-right text-gray-700">${fmt(installment)} บาท</td>
          <td class="px-3 py-2 text-right font-medium text-indigo-700">${fmt(cumulative)} บาท</td>
        `;
        tbody.appendChild(row);
        lastDate = fmtDate(currentDate);
        if (i < terms) currentDate = addPeriod(currentDate, freq);
      }

      setText('res-cal-total', `${fmt(installment * terms)} บาท`);
      setText('res-cal-last', lastDate || '-');

      document.getElementById('cal-results').classList.remove('hidden');
      document.getElementById('cal-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
