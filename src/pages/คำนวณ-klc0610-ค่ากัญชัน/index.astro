---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณค่ากัญชัน | Kamnuanlek';
const pageDescription = 'คำนวณค่ากัญชันลูก ค่าเลี้ยงลูกหลังแยกกัน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0610-ค่ากัญชัน/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่ากัญชัน">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่ากัญชัน</h1>
    <div class="mb-4 inline-block rounded-lg border border-purple-200 bg-purple-50 px-3 py-2"><p class="text-xs font-semibold text-purple-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่ากัญชันลูก ค่าเลี้ยงลูกหลังหลุดพ้น ตามกฎหมายครอบครัว</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="child_age" class="block text-sm font-medium text-gray-700 mb-1">อายุลูก (ปี)</label><input type="number" id="child_age" min="0" max="25" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="base_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าเลี้ยงพื้นฐานต่อเดือน (บาท)</label><input type="text" id="base_cost" inputmode="decimal" placeholder="เช่น 5000" value="5000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="age_factor" class="block text-sm font-medium text-gray-700 mb-1">พิเศษเพราะอายุ (0-1 = 0%)</label><input type="text" id="age_factor" inputmode="decimal" placeholder="เช่น 0.2" value="0.2" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-purple-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-purple-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่ากัญชันต่อเดือน</p>
            <p id="monthly" class="font-bold">-</p>
          </div>
          <div class="bg-purple-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าต่อปี</p>
            <p id="yearly" class="font-bold">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่ากัญชันคำนวณอย่างไร?</h3>
            <p class="text-gray-600 text-sm">ตามคดีศาลครอบครัว ค่ากัญชั่นคำนวณจากรายได้ผู้พึ่งพา หลักประมาณ 20-30% ของรายได้</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ยื่นค่ากัญชันต่อศาลต้องเตรียมอะไร?</h3>
            <p class="text-gray-600 text-sm">ต้องเตรียม: สูติบัตรลูก หลักฐานรายได้ ใบประกาศบ้าน สำเนาประกาศหนังสือสัญญา</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่ากัญชันจ่ายจนปีกี่?</h3>
            <p class="text-gray-600 text-sm">จนกว่าลูกจะบรรลุนิติภาวะ (20 ปี) หรือเมื่อแต่งงาน ลูกเสร็จสิ้นการศึกษาและมีรายได้</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const baseCost = parseFloat((document.getElementById('base_cost') as HTMLInputElement).value) || 0;
      const ageFactor = parseFloat((document.getElementById('age_factor') as HTMLInputElement).value) || 0;

      const totalAdjustment = 1 + ageFactor;
      const monthlyTotal = baseCost * totalAdjustment;
      const yearlyTotal = monthlyTotal * 12;

      (document.getElementById('monthly') as HTMLElement).textContent = monthlyTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('yearly') as HTMLElement).textContent = yearlyTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('alimony');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
