---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');

/* ── Category taxonomy ─────────────────────────────────────────── */
const categories = [
  { id: 'tax',         name: 'ภาษี',              icon: '💰', slug: 'ภาษี' },
  { id: 'loan',        name: 'สินเชื่อ/ผ่อน',     icon: '🏠', slug: 'สินเชื่อ-ผ่อน' },
  { id: 'bills',       name: 'ค่าใช้จ่าย',         icon: '⚡', slug: 'ค่าใช้จ่าย' },
  { id: 'salary',      name: 'เงินเดือน/แรงงาน',   icon: '👷', slug: 'เงินเดือน-แรงงาน' },
  { id: 'realestate',  name: 'อสังหาฯ',            icon: '🏘️', slug: 'อสังหาริมทรัพย์' },
  { id: 'health',      name: 'สุขภาพ/ชีวิต',       icon: '❤️', slug: 'สุขภาพ-ชีวิต' },
  { id: 'creditcard',  name: 'บัตรเครดิต',          icon: '💳', slug: 'บัตรเครดิต' },
  { id: 'general',     name: 'แปลง/ทั่วไป',        icon: '📏', slug: 'แปลง-ทั่วไป' },
