---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณผลตอบแทน Hedge สกุลเงิน ปี 2569 ป้องกันความเสี่ยงอัตราแลกเปลี่ยน | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณผลตอบแทนจริงของการลงทุนต่างประเทศหลัง Hedge ค่าเงิน รวมผลตอบแทนการลงทุนและกำไร/ขาดทุนจากอัตราแลกเปลี่ยน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณผลตอบแทน-hedge-สกุลเงิน/`;

const faqData = [
  {
    question: 'Currency Hedge คืออะไร?',
    answer: 'Currency Hedge คือกลยุทธ์ป้องกันความเสี่ยงจากการเปลี่ยนแปลงอัตราแลกเปลี่ยน สำหรับนักลงทุนไทยที่ลงทุนในสินทรัพย์ต่างประเทศ เพื่อลดผลกระทบของค่าเงินบาทที่แข็งหรืออ่อนค่า',
  },
  {
    question: 'กองทุนรวม Hedged vs Unhedged ต่างกันอย่างไร?',
    answer: 'กองทุน Hedged ป้องกันความเสี่ยงค่าเงินด้วยสัญญา Forward/Swap มักมีต้นทุน Hedge 1–3% ต่อปี กองทุน Unhedged รับผลตอบแทนรวมความเสี่ยงค่าเงินเต็มๆ อาจได้กำไรหรือขาดทุนเพิ่มเติมจากค่าเงิน',
  },
  {
    question: 'ค่า Hedge Cost ในไทยอยู่ที่เท่าไหร่?',
    answer: 'ค่า Hedge Cost ขึ้นอยู่กับส่วนต่างอัตราดอกเบี้ยระหว่างประเทศ เช่น ถ้าดอกเบี้ยไทยต่ำกว่าสหรัฐฯ ค่า Hedge USD กลับมา THB จะมีต้นทุน ปัจจุบันอยู่ที่ประมาณ 1–3% ต่อปีสำหรับ USD/THB',
  },
  {
    question: 'ควร Hedge หรือไม่ Hedge?',
    answer: 'ขึ้นอยู่กับระยะเวลาลงทุนและมุมมองค่าเงิน การ Hedge เหมาะกับระยะสั้นหรือผู้ที่ไม่ต้องการความเสี่ยงค่าเงิน ส่วนการไม่ Hedge เหมาะกับระยะยาวที่ค่าเงินอาจหักล้างกัน และประหยัดต้นทุน Hedge',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผลตอบแทน Hedge สกุลเงิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผลตอบแทน-hedge-สกุลเงิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-blue-100 bg-blue-50 p-4">
      <p class="text-sm font-semibold text-blue-700">💱 คำนวณผลตอบแทนการลงทุนต่างประเทศหลัง Hedge</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: ผลตอบแทน Hedged = ผลตอบแทนลงทุน + กำไร/ขาดทุนค่าเงิน − ต้นทุน Hedge</p>
      <p class="mt-1 text-xs font-medium text-blue-800">เปรียบเทียบผลตอบแทนแบบ Hedge และ Unhedge</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณผลตอบแทน Hedge สกุลเงิน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกข้อมูลการลงทุนต่างประเทศ อัตราแลกเปลี่ยน และต้นทุน Hedge เพื่อเปรียบเทียบผลตอบแทน
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="hedge-form" class="space-y-5">
        <p id="hedge-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="hedge-invest" class="mb-1 block text-sm font-medium text-gray-700">เงินลงทุน (บาท)</label>
            <input type="text" id="hedge-invest" inputmode="numeric" placeholder="เช่น 1,000,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hedge-invest-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="hedge-return" class="mb-1 block text-sm font-medium text-gray-700">ผลตอบแทนการลงทุน (% ต่อปี)</label>
            <input type="text" id="hedge-return" inputmode="numeric" placeholder="เช่น 8"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hedge-return-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="hedge-fx-start" class="mb-1 block text-sm font-medium text-gray-700">อัตราแลกเปลี่ยนเริ่มต้น (บาท/USD)</label>
            <input type="text" id="hedge-fx-start" inputmode="numeric" placeholder="เช่น 35"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hedge-fx-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="hedge-fx-end" class="mb-1 block text-sm font-medium text-gray-700">อัตราแลกเปลี่ยงสิ้นสุด (บาท/USD)</label>
            <input type="text" id="hedge-fx-end" inputmode="numeric" placeholder="เช่น 33"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="hedge-cost" class="mb-1 block text-sm font-medium text-gray-700">ต้นทุน Hedge (% ต่อปี)</label>
            <input type="text" id="hedge-cost" inputmode="numeric" placeholder="เช่น 2"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">ค่า Hedge USD→THB ปัจจุบัน ~1–3%</p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณผลตอบแทน
        </button>
      </form>
    </div>

    <div id="hedge-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-lg bg-blue-50 p-4">
            <div class="mb-2 text-sm font-semibold text-blue-800">แบบ Hedged (ป้องกันค่าเงิน)</div>
            <div class="text-sm text-gray-600">ผลตอบแทนสุทธิ: <span id="res-hedge-hedged" class="font-bold text-blue-700">-</span></div>
            <div class="mt-1 text-sm text-gray-600">มูลค่าสุทธิ: <span id="res-hedge-hedged-val" class="font-bold text-blue-700">-</span></div>
          </div>
          <div class="rounded-lg bg-green-50 p-4">
            <div class="mb-2 text-sm font-semibold text-green-800">แบบ Unhedged (ไม่ป้องกันค่าเงิน)</div>
            <div class="text-sm text-gray-600">ผลตอบแทนสุทธิ: <span id="res-hedge-unhedged" class="font-bold text-green-700">-</span></div>
            <div class="mt-1 text-sm text-gray-600">มูลค่าสุทธิ: <span id="res-hedge-unhedged-val" class="font-bold text-green-700">-</span></div>
          </div>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <div class="rounded-lg bg-purple-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ผลกระทบค่าเงิน</div>
            <div id="res-hedge-fx-impact" class="text-xl font-bold text-purple-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าเงิน THB/USD เปลี่ยนแปลง</div>
            <div id="res-hedge-fx-change" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <p id="hedge-status" class="mt-4 rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ผลกระทบค่าเงิน = (อัตราสิ้นสุด − อัตราเริ่มต้น) ÷ อัตราเริ่มต้น × 100%</li>
        <li>ผลตอบแทน Unhedged = ผลตอบแทนลงทุน + ผลกระทบค่าเงิน</li>
        <li>ผลตอบแทน Hedged = ผลตอบแทนลงทุน − ต้นทุน Hedge</li>
        <li>ค่าเงินแข็ง (THB) = ผู้ลงทุนไทยขาดทุนค่าเงิน (Unhedged)</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#hedge-results" />
    <RelatedArticles currentHref="/คำนวณผลตอบแทน-hedge-สกุลเงิน/" />
    <RelatedCalculators currentHref="/คำนวณผลตอบแทน-hedge-สกุลเงิน/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ อัตราแลกเปลี่ยนและต้นทุน Hedge จริงอาจแตกต่าง ควรปรึกษาผู้จัดการกองทุนก่อนลงทุน
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      return Number(s);
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('hedge-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('hedge-error').classList.add('hidden');
      ['hedge-invest-error','hedge-return-error','hedge-fx-error'].forEach(id => setErr(id, ''));

      const invest = parseNum(document.getElementById('hedge-invest').value);
      const returnRate = parseNum(document.getElementById('hedge-return').value);
      const fxStart = parseNum(document.getElementById('hedge-fx-start').value);
      const fxEnd = parseNum(document.getElementById('hedge-fx-end').value);
      const hedgeCost = parseNum(document.getElementById('hedge-cost').value) || 0;

      let hasError = false;
      if (isNaN(invest) || invest <= 0) { setErr('hedge-invest-error', 'กรอกเงินลงทุน'); hasError = true; }
      if (isNaN(returnRate)) { setErr('hedge-return-error', 'กรอกผลตอบแทน'); hasError = true; }
      if (isNaN(fxStart) || fxStart <= 0) { setErr('hedge-fx-error', 'กรอกอัตราแลกเปลี่ยนเริ่มต้น'); hasError = true; }
      if (hasError) { document.getElementById('hedge-error').classList.remove('hidden'); document.getElementById('hedge-results').classList.add('hidden'); return; }

      const fxEndVal = isNaN(fxEnd) || fxEnd <= 0 ? fxStart : fxEnd;
      const fxChange = (fxEndVal - fxStart) / fxStart * 100;
      const unhedgedReturn = returnRate + fxChange;
      const hedgedReturn = returnRate - hedgeCost;
      const unhedgedVal = invest * (1 + unhedgedReturn / 100);
      const hedgedVal = invest * (1 + hedgedReturn / 100);

      setText('res-hedge-hedged', `${hedgedReturn.toFixed(2)}%`);
      setText('res-hedge-hedged-val', formatMoney(hedgedVal));
      setText('res-hedge-unhedged', `${unhedgedReturn.toFixed(2)}%`);
      setText('res-hedge-unhedged-val', formatMoney(unhedgedVal));
      setText('res-hedge-fx-impact', `${fxChange >= 0 ? '+' : ''}${fxChange.toFixed(2)}%`);
      setText('res-hedge-fx-change', `${fxStart} → ${fxEndVal} THB/USD`);

      const statusEl = document.getElementById('hedge-status');
      const better = hedgedReturn > unhedgedReturn ? 'Hedged' : 'Unhedged';
      statusEl.className = 'rounded-lg bg-blue-50 p-3 text-sm font-medium text-blue-800 border border-blue-200';
      statusEl.textContent = `กลยุทธ์ที่ดีกว่าในสถานการณ์นี้คือ ${better} (ผลตอบแทน ${better === 'Hedged' ? hedgedReturn.toFixed(2) : unhedgedReturn.toFixed(2)}%/ปี)`;

      document.getElementById('hedge-results').classList.remove('hidden');
      document.getElementById('hedge-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
