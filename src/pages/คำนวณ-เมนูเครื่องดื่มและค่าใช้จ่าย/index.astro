---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณเมนูเครื่องดื่มและค่าใช้จ่าย ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเมนูเครื่องดื่มและค่าใช้จ่าย ได้ผลลัพธ์ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-เมนูเครื่องดื่มและค่าใช้จ่าย/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเมนูเครื่องดื่มและค่าใช้จ่าย">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณเมนูเครื่องดื่มและค่าใช้จ่าย</h1>
    <p class="text-gray-600 mb-6">เครื่องคำนวณออนไลน์ เมนูเครื่องดื่มและค่าใช้จ่าย</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <p class="text-gray-500 py-8 text-center">เครื่องคำนวณกำลังพัฒนา</p>
    </div>
  </article>
</BaseLayout>
