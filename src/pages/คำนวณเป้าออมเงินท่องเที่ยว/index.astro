---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเป้าหมายออมเงินท่องเที่ยว 2569 | วางแผนเที่ยว | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณเงินออมรายเดือนสำหรับทริปท่องเที่ยว จากงบประมาณเดินทาง ระยะเวลา และอัตราดอกเบี้ย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเป้าออมเงินท่องเที่ยว/`;

const faqData = [
  {
    question: 'ควรวางแผนออมเงินท่องเที่ยวไว้ล่วงหน้าแค่ไหน?',
    answer: 'แนะนำวางแผนล่วงหน้าอย่างน้อย 3-6 เดือนสำหรับทริปในประเทศ และ 6-12 เดือนสำหรับทริปต่างประเทศ การจองตั๋วล่วงหน้านานกว่า 2 เดือนมักได้ราคาที่ถูกกว่า ประหยัดงบได้ 20-40%',
  },
  {
    question: 'งบท่องเที่ยวต่างประเทศเฉลี่ยเป็นเท่าไหร่?',
    answer: 'งบท่องเที่ยวขึ้นอยู่กับปลายทาง ทริปในเอเชียตะวันออกเฉียงใต้ (เวียดนาม กัมพูชา) ประมาณ 20,000-40,000 บาท/คน ญี่ปุ่น-เกาหลี 50,000-80,000 บาท/คน ยุโรปหรืออเมริกา 100,000-200,000 บาท/คน รวมตั๋ว ที่พัก อาหาร และกิจกรรม',
  },
  {
    question: 'เงินออมท่องเที่ยวควรเก็บในบัญชีอะไร?',
    answer: 'แนะนำเปิดบัญชีออมทรัพย์แยกต่างหากสำหรับการท่องเที่ยวโดยเฉพาะ เพื่อไม่สับสนกับเงินใช้จ่ายประจำวัน บัญชีออมทรัพย์พิเศษหรือกองทุนตลาดเงินให้ดอกเบี้ยสูงกว่าและเข้าถึงได้ง่าย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเป้าหมายออมเงินท่องเที่ยว',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเป้าออมเงินท่องเที่ยว">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเป้าหมายออมเงินท่องเที่ยว 2569 — วางแผนทริปในฝัน
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณเงินออมรายเดือนสำหรับทริปท่องเที่ยว จากงบประมาณเดินทาง ระยะเวลา และอัตราดอกเบี้ย
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="travel-savings-form" class="space-y-5">
        <p id="travel-savings-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="tv-budget" class="block text-sm font-medium text-gray-700 mb-1">งบประมาณท่องเที่ยว (บาท)</label>
            <input type="text" id="tv-budget" inputmode="numeric" placeholder="เช่น 80,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="tv-budget-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="tv-current" class="block text-sm font-medium text-gray-700 mb-1">เงินออมปัจจุบัน (บาท)</label>
            <input type="text" id="tv-current" inputmode="numeric" placeholder="เช่น 10,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="tv-months" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (เดือน)</label>
            <select id="tv-months" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="3">3 เดือน</option>
              <option value="6" selected>6 เดือน</option>
              <option value="12">12 เดือน</option>
              <option value="18">18 เดือน</option>
              <option value="24">24 เดือน</option>
              <option value="36">36 เดือน</option>
            </select>
          </div>
          <div>
            <label for="tv-rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราดอกเบี้ย (%/ปี)</label>
            <input type="text" id="tv-rate" inputmode="decimal" placeholder="เช่น 1.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <button type="submit" id="travel-savings-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินออมรายเดือน</div>
            <div id="res-monthly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยที่ได้</div>
            <div id="res-interest" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดรวม</div>
            <div id="res-total" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีวางแผนออมเงินท่องเที่ยว</h2>
      <p>การออมเงินเพื่อการท่องเที่ยวทำให้คุณสามารถเดินทางในฝันได้โดยไม่เป็นหนี้ เครื่องคำนวณนี้ช่วยหาเงินออมรายเดือนที่เหมาะสมตามงบประมาณและระยะเวลาที่กำหนด</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เคล็ดลับออมเงินท่องเที่ยว</h3>
      <p>ตั้งบัญชีออมทรัพย์แยกสำหรับการท่องเที่ยวโดยเฉพาะ ตั้ง auto-transfer รายเดือน และหาโปรโมชั่นตั๋วและที่พักล่วงหน้าเพื่อประหยัดงบได้มากขึ้น</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">งบท่องเที่ยวประกอบด้วยอะไรบ้าง</h3>
      <p>ค่าตั๋วเครื่องบิน ที่พัก อาหาร ค่าเข้าชมสถานที่ การเดินทางในประเทศ ของฝาก และค่าใช้จ่ายสำรองฉุกเฉิน 10-15% ของงบรวม</p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณเป้าออมเงินท่องเที่ยว/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น อัตราดอกเบี้ยจริงอาจแตกต่างตามเงื่อนไขของธนาคาร ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }
    const form = document.getElementById('travel-savings-form') as HTMLFormElement;
    const submitBtn = document.getElementById('travel-savings-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('travel-savings-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const budgetInput = document.getElementById('tv-budget') as HTMLInputElement;
    const currentInput = document.getElementById('tv-current') as HTMLInputElement;
    const rateInput = document.getElementById('tv-rate') as HTMLInputElement;
    function setFieldError(id: string, msg: string) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.remove('hidden'); }
    function clearFieldError(id: string) { const el = document.getElementById(id); if (!el) return; el.textContent = ''; el.classList.add('hidden'); }
    function clearValidation() { formError.classList.add('hidden'); ['tv-budget-error'].forEach(clearFieldError); }
    [budgetInput, currentInput, rateInput].forEach(input => { input.addEventListener('input', clearValidation); });
    form.addEventListener('submit', (e) => {
      e.preventDefault(); clearValidation();
      const target = parseNum(budgetInput.value);
      const current = parseNum(currentInput.value);
      const months = parseInt((document.getElementById('tv-months') as HTMLSelectElement).value) || 6;
      const annualRate = parseFloat(rateInput.value.replace(/,/g, '')) || 0;
      if (target <= 0) { setFieldError('tv-budget-error', 'กรุณากรอกงบประมาณท่องเที่ยว'); formError.classList.remove('hidden'); return; }
      submitBtn.disabled = true; submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('vacation-savings-goal');
      const r = annualRate / 100;
      let monthlyPmt: number;
      if (r === 0) {
        const needed = target - current;
        monthlyPmt = needed > 0 ? needed / months : 0;
      } else {
        const rm = r / 12;
        const factor = Math.pow(1 + rm, months);
        const currentFV = current * factor;
        const needed = target - currentFV;
        monthlyPmt = needed <= 0 ? 0 : needed / ((factor - 1) / rm);
      }
      monthlyPmt = Math.max(0, monthlyPmt);
      const totalContributions = current + monthlyPmt * months;
      const totalInterest = Math.max(0, target - totalContributions);
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthlyPmt) + ' บาท/เดือน';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(target) + ' บาท';
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false; submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('vacation-savings-goal');
      trackCalculatorUsed('vacation-savings-goal');
    });
  </script>
</BaseLayout>
