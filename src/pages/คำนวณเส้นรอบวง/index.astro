---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเส้นรอบวง พื้นที่วงกลม และเส้นผ่านศูนย์กลาง ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเส้นรอบวง พื้นที่วงกลม เส้นผ่านศูนย์กลาง และรัศมี จากข้อมูลที่มี ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเส้นรอบวง/`;

const faqData = [
  {
    question: 'เส้นรอบวงคำนวณยังไง?',
    answer: 'เส้นรอบวง (circumference) คำนวณจากสูตร C = 2πr (จากรัศมี) หรือ C = πd (จากเส้นผ่านศูนย์กลาง) โดย π ≈ 3.14159265 ตัวอย่าง: วงกลมรัศมี 5 ซม. มีเส้นรอบวง = 2 × π × 5 ≈ 31.4159 ซม.',
  },
  {
    question: 'พื้นที่วงกลมคำนวณยังไง?',
    answer: 'พื้นที่วงกลม (area) คำนวณจากสูตร A = πr² โดย r คือรัศมี ตัวอย่าง: วงกลมรัศมี 7 ซม. มีพื้นที่ = π × 7² = π × 49 ≈ 153.94 ซม.²',
  },
  {
    question: 'ค่า π (pi) มาจากไหน?',
    answer: 'π (pi) คืออัตราส่วนระหว่างเส้นรอบวงและเส้นผ่านศูนย์กลางของวงกลมทุกวง มีค่าประมาณ 3.14159265358979... เป็นจำนวนอตรรกยะที่ทศนิยมไม่รู้จบและไม่มีรูปแบบซ้ำ',
  },
  {
    question: 'รัศมีและเส้นผ่านศูนย์กลางต่างกันอย่างไร?',
    answer: 'รัศมี (radius, r) คือระยะจากจุดศูนย์กลางถึงขอบวงกลม ส่วนเส้นผ่านศูนย์กลาง (diameter, d) คือเส้นตรงที่ผ่านจุดศูนย์กลางจากขอบหนึ่งถึงอีกขอบหนึ่ง ดังนั้น d = 2r หรือ r = d/2',
  },
  {
    question: 'วงกลมใช้ในชีวิตจริงอย่างไร?',
    answer: 'วงกลมพบได้ทั่วไป เช่น คำนวณความยาวยางรถยนต์จากเส้นผ่านศูนย์กลาง หาปริมาณวัสดุทำแผ่นกลม คำนวณพื้นที่บ่อน้ำทรงกลม ออกแบบพิซซ่า และในงานวิศวกรรมสำหรับท่อและถัง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเส้นรอบวงและพื้นที่วงกลม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'EducationApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณเส้นรอบวงและพื้นที่วงกลม',
  description: 'ขั้นตอนการคำนวณคุณสมบัติต่างๆ ของวงกลม จากรัศมีหรือเส้นผ่านศูนย์กลาง',
  step: [
    {
      '@type': 'HowToStep',
      name: 'เลือกข้อมูลที่ทราบ',
      text: 'เลือกว่ามีรัศมี (r) หรือเส้นผ่านศูนย์กลาง (d) แล้วกรอกข้อมูลในช่องที่เหมาะสม',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกตัวเลข',
      text: 'ใส่ค่ารัศมีหรือเส้นผ่านศูนย์กลางเป็นตัวเลขบวก ไม่ต้องระบุหน่วย ผลลัพธ์จะใช้หน่วยเดียวกัน',
    },
    {
      '@type': 'HowToStep',
      name: 'กดคำนวณ',
      text: 'กดปุ่ม "คำนวณ" เครื่องจะคำนวณเส้นรอบวง พื้นที่ และค่าที่เหลือให้ครบ',
    },
    {
      '@type': 'HowToStep',
      name: 'อ่านผลลัพธ์',
      text: 'ผลลัพธ์แสดงทศนิยม 4 ตำแหน่ง ได้แก่ เส้นรอบวง พื้นที่ รัศมี และเส้นผ่านศูนย์กลาง',
    },
  ],
};
---

<BaseLayout noGenericHowTo={true} title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเส้นรอบวง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณเส้นรอบวง พื้นที่ และขนาดวงกลมในหน้าเดียว</p>
      <p class="mt-1 text-sm text-slate-700">ใช้ค่า π ที่แม่นยำ แสดงผลลัพธ์ทศนิยม 4 ตำแหน่ง</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเส้นรอบวง พื้นที่วงกลม และขนาดวงกลม ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณคุณสมบัติวงกลมครบทุกอย่างในคลิกเดียว ทั้งเส้นรอบวง (C = 2πr) พื้นที่ (A = πr²)
      เส้นผ่านศูนย์กลาง และรัศมี ใช้ในงานคณิตศาสตร์ วิศวกรรม และการออกแบบ
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'สสวท. (SciMath): วงกลมและค่า π',
        'ECMAScript: Math.PI = 3.141592653589793',
      ]}
      assumptions={[
        'ใช้ Math.PI ของ JavaScript ซึ่งมีความแม่นยำ 15-16 หลัก',
        'ผลลัพธ์แสดงทศนิยม 4 ตำแหน่ง',
      ]}
      references={[
        {
          label: 'SciMath: วงกลมและสูตรพื้นที่',
          href: 'https://www.scimath.org/article-mathematics/item/11474-3',
        },
      ]}
    />

    <!-- Mode 1: From radius -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">1) คำนวณจากรัศมี (r)</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: r = 5 → เส้นรอบวง ≈ 31.4159, พื้นที่ ≈ 78.5398</p>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="sm:col-span-2">
          <label for="circ-r" class="block text-sm font-medium text-gray-700 mb-1">รัศมี r</label>
          <input id="circ-r" type="text" inputmode="decimal" placeholder="เช่น 5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div class="flex items-end">
          <button id="btn-circ-r" type="button" class="w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700">คำนวณ</button>
        </div>
      </div>
      <p id="circ-r-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="circ-r-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4 space-y-1">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="circ-r-circumference" class="text-base font-semibold text-primary-700">-</p>
        <p id="circ-r-area" class="text-base font-semibold text-primary-700">-</p>
        <p id="circ-r-diameter" class="text-base text-gray-600">-</p>
      </div>
    </div>

    <!-- Mode 2: From diameter -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">2) คำนวณจากเส้นผ่านศูนย์กลาง (d)</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: d = 10 → เส้นรอบวง ≈ 31.4159, พื้นที่ ≈ 78.5398</p>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="sm:col-span-2">
          <label for="circ-d" class="block text-sm font-medium text-gray-700 mb-1">เส้นผ่านศูนย์กลาง d</label>
          <input id="circ-d" type="text" inputmode="decimal" placeholder="เช่น 10" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div class="flex items-end">
          <button id="btn-circ-d" type="button" class="w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700">คำนวณ</button>
        </div>
      </div>
      <p id="circ-d-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="circ-d-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4 space-y-1">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="circ-d-circumference" class="text-base font-semibold text-primary-700">-</p>
        <p id="circ-d-area" class="text-base font-semibold text-primary-700">-</p>
        <p id="circ-d-radius" class="text-base text-gray-600">-</p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#circ-d-result" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรวงกลมที่ควรจำ</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>เส้นรอบวง: C = 2πr = πd</li>
        <li>พื้นที่: A = πr² = π(d/2)²</li>
        <li>เส้นผ่านศูนย์กลาง: d = 2r = C/π</li>
        <li>รัศมี: r = d/2 = C/(2π) = √(A/π)</li>
        <li>π ≈ 3.14159265358979</li>
      </ul>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณเส้นรอบวง/" />
    <RelatedCalculators currentHref="/คำนวณเส้นรอบวง/" />
  </article>
</BaseLayout>

<script>
  const parseNum = (v) => parseFloat(String(v).replace(/,/g, '').trim());

  const setError = (id, msg) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg || '';
    msg ? el.classList.remove('hidden') : el.classList.add('hidden');
  };

  const setText = (id, text) => {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  };

  document.getElementById('btn-circ-r')?.addEventListener('click', () => {
    setError('circ-r-error', '');
    const r = parseNum(document.getElementById('circ-r')?.value);
    if (!Number.isFinite(r)) { setError('circ-r-error', 'กรุณากรอกตัวเลขที่ถูกต้อง'); return; }
    if (r <= 0) { setError('circ-r-error', 'รัศมีต้องมากกว่า 0'); return; }
    const C = 2 * Math.PI * r;
    const A = Math.PI * r * r;
    const d = 2 * r;
    setText('circ-r-circumference', `เส้นรอบวง C = 2π × ${r} = ${C.toFixed(4)}`);
    setText('circ-r-area', `พื้นที่ A = π × ${r}² = ${A.toFixed(4)}`);
    setText('circ-r-diameter', `เส้นผ่านศูนย์กลาง d = 2 × ${r} = ${d.toFixed(4)}`);
    document.getElementById('circ-r-result')?.classList.remove('hidden');
  });

  document.getElementById('btn-circ-d')?.addEventListener('click', () => {
    setError('circ-d-error', '');
    const d = parseNum(document.getElementById('circ-d')?.value);
    if (!Number.isFinite(d)) { setError('circ-d-error', 'กรุณากรอกตัวเลขที่ถูกต้อง'); return; }
    if (d <= 0) { setError('circ-d-error', 'เส้นผ่านศูนย์กลางต้องมากกว่า 0'); return; }
    const r = d / 2;
    const C = Math.PI * d;
    const A = Math.PI * r * r;
    setText('circ-d-circumference', `เส้นรอบวง C = π × ${d} = ${C.toFixed(4)}`);
    setText('circ-d-area', `พื้นที่ A = π × (${d}/2)² = ${A.toFixed(4)}`);
    setText('circ-d-radius', `รัศมี r = ${d}/2 = ${r.toFixed(4)}`);
    document.getElementById('circ-d-result')?.classList.remove('hidden');
  });
</script>
