---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าเรียนโรงเรียนนานาชาติ ปี 2569 | IB, AP, Cambridge | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนเรียนโรงเรียนนานาชาติ: IB, AP, Cambridge, สัญญาสัมปทาน รวมค่าเรียน ค่าอื่นๆ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าเรียนโรงเรียนนานาชาติ/`;

const faqData = [
  {
    question: 'ค่าเรียนโรงเรียนนานาชาติในไทยเท่าไหร่?',
    answer: 'โรงเรียนนานาชาติทั่วไป: 150,000–300,000 บาท/ปี โรงเรียนเน้น IB/AP ระดับสูง: 250,000–500,000+ บาท/ปี ขึ้นอยู่กับแหล่งที่ตั้ง หลักสูตร และสิ่งอำนวยความสะดวก',
  },
  {
    question: 'IB กับ AP ต่างกันอย่างไร?',
    answer: 'IB (International Baccalaureate) เน้นการศึกษาทั้งตัว 2 ปี AP (Advanced Placement) เป็นวิชาเลือกอาจเรียนหลายวิชา IB โดยทั่วไปแพงกว่าและต้องมุ่งสาย',
  },
  {
    question: 'ค่าสัมปทาน (Tuition) เท่านั้นหรือมีค่าอื่น?',
    answer: 'นอกจากค่าเรียนแล้วมี: ค่าสมัครสมาชิก, ค่าสอบ IB/AP, ค่าหนังสือ, ค่ากิจกรรม, ค่าเที่ยว, ประกัน โดยค่าเพิ่มเติมอาจ 30,000–50,000 บาท/ปี',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าเรียนโรงเรียนนานาชาติ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเรียนโรงเรียนนานาชาติ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณค่าเรียนโรงเรียนนานาชาติ ปี 2569</h1>

    <p class="text-gray-600 mb-6">
      คำนวณต้นทุนการศึกษานานาชาติทั้งหมด (IB, AP, Cambridge) รวมค่าเรียน ค่าสอบ ค่าอื่นๆ วางแผนการศึกษาระดับสูง
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="intl-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="tuition" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าเรียน/ปี (บาท)
            </label>
            <input
              type="text"
              id="tuition"
              inputmode="numeric"
              placeholder="เช่น 250,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="exam-fees" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าสอบ IB/AP (บาท) — ไม่บังคับ
            </label>
            <input
              type="text"
              id="exam-fees"
              inputmode="numeric"
              placeholder="เช่น 50,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="other" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าใช้จ่ายอื่น/ปี (บาท) — ไม่บังคับ
          </label>
          <input
            type="text"
            id="other"
            inputmode="numeric"
            placeholder="เช่น 40,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          />
        </div>

        <div>
          <label for="years" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนปีศึกษา
          </label>
          <input
            type="text"
            id="years"
            inputmode="numeric"
            placeholder="เช่น 2 (for IB) or 4 (for High School)"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          />
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-blue-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-700">
          คำนวณต้นทุนรวม
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="rounded-lg bg-blue-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ต้นทุนรวมทั้งหมด</div>
          <div id="res-total" class="text-3xl font-bold text-blue-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าเรียน/ปี</span>
            <span id="res-tuition" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าสอบ (รวม)</span>
            <span id="res-exam" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าใช้จ่ายอื่น</span>
            <span id="res-other" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">รวมทั้งหมด</span>
            <span id="res-calc-total" class="font-bold text-lg text-blue-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <RelatedCalculators currentHref="/คำนวณค่าเรียนโรงเรียนนานาชาติ/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return 0;
    return Number(String(value).replace(/,/g, '').trim()) || 0;
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#intl-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const tuition = parseNumber(document.querySelector('#tuition')?.value || '');
    const examFees = parseNumber(document.querySelector('#exam-fees')?.value || '');
    const other = parseNumber(document.querySelector('#other')?.value || '');
    const years = parseNumber(document.querySelector('#years')?.value || '');

    if (!(tuition > 0 && years > 0)) {
      results?.classList.add('hidden');
      return;
    }

    const yearlyOther = other * years;
    const total = (tuition * years) + examFees + yearlyOther;

    document.querySelector('#res-tuition').textContent = formatCurrency(tuition * years);
    document.querySelector('#res-exam').textContent = formatCurrency(examFees);
    document.querySelector('#res-other').textContent = formatCurrency(yearlyOther);
    document.querySelector('#res-total').textContent = formatCurrency(total);
    document.querySelector('#res-calc-total').textContent = formatCurrency(total);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
