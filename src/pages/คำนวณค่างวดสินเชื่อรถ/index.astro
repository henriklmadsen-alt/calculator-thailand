---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import AffiliateCard from '../../components/templates/AffiliateCard.astro';

const pageTitle = 'คำนวณค่างวดสินเชื่อรถ 2569 | Kamnuanlek';
const pageDescription = 'คำนวณค่างวดรถ ดอกเบี้ย flat rate และ effective rate ค่างวดรายเดือน ดอกเบี้ยรวม 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่างวดสินเชื่อรถ/`;

const faqData = [
  {
    question: 'สินเชื่อรถยนต์ในไทยปี 2569 ดอกเบี้ยกี่เปอร์เซ็นต์?',
    answer: 'สินเชื่อรถยนต์ใหม่ในไทยปี 2569 มีอัตราดอกเบี้ยแบบ flat rate ประมาณ 2.5-4% ต่อปี สำหรับรถใหม่ และ 4-7% สำหรับรถมือสอง ขึ้นอยู่กับธนาคาร ยี่ห้ารถ และเครดิตของผู้กู้ ให้สอบถามสัตว์แนวทางปัจจุบัน',
  },
  {
    question: 'ดอกเบี้ย flat rate กับ effective rate ต่างกันยังไง?',
    answer: 'Flat rate คำนวณจากเงินต้นเต็มจำนวนตลอดสัญญา ส่วน effective rate คือดอกเบี้ยแท้จริงจากยอดหนี้คงเหลือ ตัวอย่าง: ดอกเบี้ย flat rate 3% เทียบเท่า effective rate ประมาณ 5.5-6% ปกติสินเชื่อรถใช้ flat rate เป็นหลัก',
  },
  {
    question: 'เงินดาวน์รถควรจ่ายกี่เปอร์เซ็นต์?',
    answer: 'เงินดาวน์ขั้นต่ำโดยปกติ 10-20% แต่แนะนำ 20-25% เพื่อลดภาระค่างวดและดอกเบี้ยรวม ดาวน์มากยิ่งจ่ายดอกเบี้ยน้อย แต่ต้องดูการเงินส่วนตัวสมดุล',
  },
  {
    question: 'ผ่อนรถกี่ปีดีที่สุด?',
    answer: 'สินเชื่อรถผ่อนได้ 4-7 ปี (48-84 งวด) ผ่อนสั้น 4 ปี ค่างวดสูงแต่ดอกเบี้ยน้อย ผ่อนยาว 6-7 ปี ค่างวดต่ำแต่ดอกเบี้ยรวมสูง แนะนำค่างวดไม่เกิน 15-20% ของรายได้',
  },
  {
    question: 'ข้อผิดพลาดทั่วไปที่ต้องหลีกเลี่ยงคืออะไร?',
    answer: 'ข้อผิดพลาด ได้แก่ (1) ลืมบวกค่าประกันภัชระบบ (2) ไม่ตรวจสอบอัตราดอกเบี้ยจริง (3) ใช้ effective rate มาคิด flat rate (4) ไม่คิดค่าอื่น (5) ไม่ตรวจการคำนวณผ่อนก่อนลงนาม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่างวดสินเชื่อรถ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'THB',
  },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณค่างวดสินเชื่อรถ',
  description: 'ขั้นตอนการใช้เครื่องคำนวณสินเชื่อรถเพื่อทราบค่างวดรายเดือน และดอกเบี้ยรวม',
  step: [
    {
      '@type': 'HowToStep',
      name: 'กรอกราคารถ',
      text: 'ป้อนราคารถยนต์ที่ต้องการซื้อ เช่น 500,000 บาท',
    },
    {
      '@type': 'HowToStep',
      name: 'ระบุเงินดาวน์',
      text: 'ป้อนเปอร์เซ็นต์เงินดาวน์ เช่น 20% หรือจำนวนเงินที่ต้องการชำระล่วงหน้า',
    },
    {
      '@type': 'HowToStep',
      name: 'ระบุอัตราดอกเบี้ยและประเภท',
      text: 'ป้อนอัตราดอกเบี้ยต่อปี และเลือกประเภท flat rate หรือ effective rate',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกระยะเวลาผ่อน',
      text: 'เลือกจำนวนเดือนที่ต้องการผ่อน (12, 24, 36, 48, 60, 72, หรือ 84 เดือน)',
    },
    {
      '@type': 'HowToStep',
      name: 'ดูผลลัพธ์',
      text: 'ระบบจะแสดงค่างวดรายเดือน ดอกเบี้ยรวม ยอดชำระรวม เงินดาวน์ และวงเงินกู้อัตโนมัติ',
    },
  ],
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่างวดสินเชื่อรถ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณค่างวดสินเชื่อรถ 2569 (2026) - flat rate และ effective rate
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่างวดรถแบบลดต้นลดดอก พร้อมเลือกประเภทดอกเบี้ยแบบ flat rate หรือ effective rate
      เพื่อดูค่างวดรายเดือน ดอกเบี้ยรวม เงินดาวน์ และวงเงินกู้ชัดเจน
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="car-loan-form" class="space-y-6">
        <p id="car-loan-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div>
          <label for="vehicle-price" class="block text-sm font-medium text-gray-700 mb-1">
            ราคารถ (บาท)
          </label>
          <input
            type="text"
            id="vehicle-price"
            inputmode="numeric"
            value="500000"
            placeholder="เช่น 500,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p id="vehicle-price-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="down-payment-percent" class="block text-sm font-medium text-gray-700 mb-1">
              เงินดาวน์ (%)
            </label>
            <input
              type="text"
              id="down-payment-percent"
              inputmode="decimal"
              value="20"
              placeholder="เช่น 20"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="down-payment-percent-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="annual-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราดอกเบี้ย (% ต่อปี)
            </label>
            <input
              type="text"
              id="annual-rate"
              inputmode="decimal"
              value="3.5"
              placeholder="เช่น 3.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="annual-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="loan-term-months" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาผ่อน (เดือน)
            </label>
            <select
              id="loan-term-months"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            >
              <option value="12">12 เดือน (1 ปี)</option>
              <option value="24">24 เดือน (2 ปี)</option>
              <option value="36">36 เดือน (3 ปี)</option>
              <option value="48" selected>48 เดือน (4 ปี)</option>
              <option value="60">60 เดือน (5 ปี)</option>
              <option value="72">72 เดือน (6 ปี)</option>
              <option value="84">84 เดือน (7 ปี)</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              ประเภทดอกเบี้ย
            </label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2">
                <input
                  type="radio"
                  name="interest-type"
                  value="flat"
                  checked
                  class="w-4 h-4 text-primary-600"
                />
                <span class="text-sm text-gray-700">Flat rate</span>
              </label>
              <label class="flex items-center gap-2">
                <input
                  type="radio"
                  name="interest-type"
                  value="effective"
                  class="w-4 h-4 text-primary-600"
                />
                <span class="text-sm text-gray-700">Effective rate</span>
              </label>
            </div>
          </div>
        </div>

        <div class="pt-2">
          <button
            type="button"
            id="calculate-btn"
            class="w-full bg-orange-600 hover:bg-orange-700 text-white font-medium py-3 px-4 rounded-lg transition-colors"
          >
            คำนวณค่างวด
          </button>
        </div>
      </form>
    </div>

    <div id="results-section" class="hidden space-y-6">
      <div class="bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-lg p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
          <div>
            <p class="text-xs font-medium text-gray-600 uppercase tracking-wide mb-1">เงินดาวน์</p>
            <p id="result-down-payment" class="text-2xl font-bold text-gray-900">0</p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-600 uppercase tracking-wide mb-1">วงเงินกู้</p>
            <p id="result-loan-amount" class="text-2xl font-bold text-gray-900">0</p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-600 uppercase tracking-wide mb-1">ค่างวดรายเดือน</p>
            <p id="result-monthly-payment" class="text-2xl font-bold text-orange-600">0</p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-600 uppercase tracking-wide mb-1">ดอกเบี้ยรวม</p>
            <p id="result-total-interest" class="text-2xl font-bold text-gray-900">0</p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-600 uppercase tracking-wide mb-1">ยอดชำระรวม</p>
            <p id="result-total-payment" class="text-2xl font-bold text-gray-900">0</p>
          </div>
        </div>
      </div>
    </div>

    <div class="my-12 bg-blue-50 border border-blue-200 rounded-lg p-6">
      <h2 class="font-bold text-gray-900 mb-3">ตัวอย่างการคำนวณ</h2>
      <p class="text-gray-700 text-sm mb-3">
        <strong>นายสมชาย</strong> ต้องการซื้อรถราคา 500,000 บาท ชำระเงินดาวน์ 20% (100,000 บาท)
        ผ่อน 48 เดือน ดอกเบี้ย 3.5% ต่อปี แบบ flat rate
      </p>
      <ul class="text-sm text-gray-700 space-y-2">
        <li>• <strong>วงเงินกู้:</strong> 400,000 บาท</li>
        <li>• <strong>ค่างวดรายเดือน:</strong> 9,500 บาท</li>
        <li>• <strong>ดอกเบี้ยรวม:</strong> 56,000 บาท</li>
        <li>• <strong>ยอดชำระรวม:</strong> 456,000 บาท</li>
      </ul>
    </div>

    <RelatedCalculators currentHref="/คำนวณค่างวดสินเชื่อรถ/" />

    <AffiliateCard
      category="car-loan"
      affiliateUrl="PLACEHOLDER_URL"
      partnerName="Rabbit Finance"
      ctaText="เปรียบเทียบสินเชื่อรถจริง"
      subtext="รวมข้อเสนอจากกว่า 10 ธนาคาร — ไม่มีค่าธรรมเนียม"
    />

    <GuardedAdSlot />

    <div class="my-12 space-y-6">
      <h2 class="text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      {faqData.map((faq) => (
        <details class="group border border-gray-200 rounded-lg p-4">
          <summary class="flex cursor-pointer items-center justify-between font-medium text-gray-900">
            {faq.question}
            <span class="transition group-open:rotate-180">▼</span>
          </summary>
          <p class="mt-3 text-sm text-gray-600">{faq.answer}</p>
        </details>
      ))}
    </div>


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณค่างวดสินเชื่อรถ/" />
  </article>

  <script>
    // Calculator logic
    document.getElementById('calculate-btn')?.addEventListener('click', () => {
      const vehiclePrice = parseFloat(document.getElementById('vehicle-price').value.replace(/,/g, '')) || 0;
      const downPaymentPercent = parseFloat(document.getElementById('down-payment-percent').value) || 0;
      const annualRate = parseFloat(document.getElementById('annual-rate').value) || 0;
      const loanTermMonths = parseInt(document.getElementById('loan-term-months').value) || 0;
      const interestType = document.querySelector('input[name="interest-type"]:checked')?.value || 'flat';

      // Validation
      const errorEl = document.getElementById('car-loan-form-error');
      if (vehiclePrice <= 0 || downPaymentPercent < 0 || annualRate <= 0 || loanTermMonths <= 0) {
        errorEl?.classList.remove('hidden');
        return;
      }
      errorEl?.classList.add('hidden');

      // Calculations
      const downPaymentAmount = (vehiclePrice * downPaymentPercent) / 100;
      const loanAmount = vehiclePrice - downPaymentAmount;

      let monthlyPayment = 0;
      let totalInterest = 0;

      if (interestType === 'flat') {
        // Flat rate: totalInterest = principal × (annualRate/100) × years
        //            monthlyPayment = (principal + totalInterest) / months
        const years = loanTermMonths / 12;
        totalInterest = loanAmount * (annualRate / 100) * years;
        monthlyPayment = (loanAmount + totalInterest) / loanTermMonths;
      } else {
        // Effective rate (reducing balance) formula
        const monthlyRate = annualRate / 100 / 12;
        if (monthlyRate === 0) {
          monthlyPayment = loanAmount / loanTermMonths;
        } else {
          monthlyPayment = (loanAmount * monthlyRate * Math.pow(1 + monthlyRate, loanTermMonths)) /
                          (Math.pow(1 + monthlyRate, loanTermMonths) - 1);
        }
        totalInterest = monthlyPayment * loanTermMonths - loanAmount;
      }

      const totalPayment = loanAmount + totalInterest;

      // Display results
      document.getElementById('result-down-payment').textContent = downPaymentAmount.toLocaleString('th-TH', { maximumFractionDigits: 0 }) + ' บาท';
      document.getElementById('result-loan-amount').textContent = loanAmount.toLocaleString('th-TH', { maximumFractionDigits: 0 }) + ' บาท';
      document.getElementById('result-monthly-payment').textContent = monthlyPayment.toLocaleString('th-TH', { maximumFractionDigits: 0 }) + ' บาท';
      document.getElementById('result-total-interest').textContent = totalInterest.toLocaleString('th-TH', { maximumFractionDigits: 0 }) + ' บาท';
      document.getElementById('result-total-payment').textContent = totalPayment.toLocaleString('th-TH', { maximumFractionDigits: 0 }) + ' บาท';

      document.getElementById('results-section')?.classList.remove('hidden');
      document.getElementById('affiliate-card')?.classList.remove('hidden');
      document.getElementById('results-section')?.scrollIntoView({ behavior: 'smooth' });
    });

    // Format input on blur
    ['vehicle-price', 'down-payment-percent', 'annual-rate'].forEach(id => {
      const el = document.getElementById(id);
      el?.addEventListener('blur', (e) => {
        const num = parseFloat(e.target.value.replace(/,/g, ''));
        if (!isNaN(num)) {
          e.target.value = num.toLocaleString('th-TH');
        }
      });
      el?.addEventListener('focus', (e) => {
        e.target.value = e.target.value.replace(/,/g, '');
      });
    });

    // Auto-calculate on input change (optional)
    document.getElementById('car-loan-form')?.addEventListener('change', () => {
      document.getElementById('calculate-btn')?.click();
    });
  </script>
</BaseLayout>
