---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="เครื่องคำนวณรถยนต์ — ผ่อนรถ ภาษีรถ ประกันภัย ต้นทุนจริง | Kamnuanlek"
  description="เครื่องคำนวณรถยนต์ฟรีครบชุด คำนวณค่างวดผ่อนรถ ภาษีรถประจำปี พ.ร.บ. ประกันภัยชั้น 1-3 ค่าน้ำมัน และต้นทุนการเป็นเจ้าของรถจริง อัปเดตปี 2569"
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">เครื่องคำนวณรถยนต์</h1>
    <p class="text-xl text-gray-600 mb-12">
      Plan your vehicle purchase and ownership costs. Car loans, road tax, fuel costs, and insurance — all in one place.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณผ่อนรถ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🚗</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Car Loan Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate monthly car payments, total cost, and interest paid over the loan term.</p>
        <span class="text-primary-600 font-medium">Calculate Payment →</span>
      </a>

      <a href="/คำนวณภาษีรถยนต์/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">📋</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Road Tax Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate annual road tax based on engine size (CC) and vehicle type.</p>
        <span class="text-primary-600 font-medium">Calculate Tax →</span>
      </a>

      <a href="/คำนวณค่าน้ำมัน/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">⛽</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Fuel Cost Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate monthly fuel costs based on your driving distance and fuel efficiency.</p>
        <span class="text-primary-600 font-medium">Calculate Fuel Cost →</span>
      </a>

      <a href="/คำนวณค่าประกันรถ/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🛡️</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Car Insurance Calculator</h3>
        <p class="text-gray-600 mb-3">Estimate comprehensive car insurance premiums based on vehicle value and driver profile.</p>
        <span class="text-primary-600 font-medium">Estimate Premium →</span>
      </a>
    </div>

    <div class="p-6 bg-blue-50 border border-blue-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Total Cost of Car Ownership</h2>
      <p class="text-gray-700 mb-4">Monthly ownership costs for a typical 1 million THB car (60-month loan at 4% interest):</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-4 bg-white rounded-lg text-center border border-blue-100">
          <p class="font-bold text-gray-900 text-lg">~18,400</p>
          <p class="text-gray-600 text-sm">THB/month loan</p>
        </div>
        <div class="p-4 bg-white rounded-lg text-center border border-blue-100">
          <p class="font-bold text-gray-900 text-lg">~1,500</p>
          <p class="text-gray-600 text-sm">THB/month insurance</p>
        </div>
        <div class="p-4 bg-white rounded-lg text-center border border-blue-100">
          <p class="font-bold text-gray-900 text-lg">~3,000</p>
          <p class="text-gray-600 text-sm">THB/month fuel</p>
        </div>
        <div class="p-4 bg-white rounded-lg text-center border border-blue-100">
          <p class="font-bold text-gray-900 text-lg">~500</p>
          <p class="text-gray-600 text-sm">THB/month road tax</p>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/เปรียบเทียบสินเชื่อ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">🏦 Loan Comparison Guide</span>
          <p class="text-gray-600 text-sm mt-2">Compare car loans vs personal loans</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Financial Calculators Hub</span>
          <p class="text-gray-600 text-sm mt-2">All financial tools in one place</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
