---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณค่าดนตรีและความบันเทิง ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าดนตรีและความบันเทิง ได้ผลลัพธ์ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าดนตรีและความบันเทิง/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าดนตรีและความบันเทิง">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าดนตรีและความบันเทิง</h1>
    <p class="text-gray-600 mb-6">เครื่องคำนวณออนไลน์ ค่าดนตรีและความบันเทิง</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <p class="text-gray-500 py-8 text-center">เครื่องคำนวณกำลังพัฒนา</p>
    </div>
  </article>
</BaseLayout>
