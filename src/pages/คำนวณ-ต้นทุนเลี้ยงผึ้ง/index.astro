---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนการเลี้ยงผึ้ง | Calculator Thailand';
const pageDescription = 'คำนวณต้นทุนการเลี้ยงผึ้งโดยการดำเนิน อาหาร บำรุงรักษา ผลผลิตน้ำแข็ง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุนเลี้ยงผึ้ง/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนเลี้ยงผึ้ง">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนการเลี้ยงผึ้ง</h1>
    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2"><p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนการเลี้ยงผึ้ง อาหาร บำรุงรักษา ผลผลิตน้ำแข็ง</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="hives" class="block text-sm font-medium text-gray-700 mb-1">จำนวนผึ้งรัง</label><input type="text" id="hives" inputmode="numeric" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="months" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (เดือน)</label><input type="text" id="months" inputmode="numeric" placeholder="เช่น 12" value="12" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-primary-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวม</p><p id="cost" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ผลผลิตน้ำแข็ง</p><p id="yield" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้</p><p id="income" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">กำไร</p><p id="profit" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const hives = parseFloat((document.getElementById('hives') as HTMLInputElement).value) || 0;
      const months = parseFloat((document.getElementById('months') as HTMLInputElement).value) || 0;
      if (hives <= 0) return;
      const feedCost = hives * 500 * months, maintenanceCost = hives * 300 * months, healthCost = hives * 200 * months;
      const totalCost = feedCost + maintenanceCost + healthCost;
      const honeyPerHive = 15, honeyYield = hives * honeyPerHive, pricePerKg = 200, income = honeyYield * pricePerKg, profit = income - totalCost;
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('cost') as HTMLElement).textContent = fmt(totalCost);
      (document.getElementById('yield') as HTMLElement).textContent = Math.round(honeyYield) + ' กก.';
      (document.getElementById('income') as HTMLElement).textContent = fmt(income);
      (document.getElementById('profit') as HTMLElement).textContent = fmt(profit);
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('beekeeping-farming');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
