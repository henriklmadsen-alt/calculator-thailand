---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

interface Props {
  pageTitleOverride?: string;
  pageDescriptionOverride?: string;
  canonicalPathOverride?: string;
  pageNameOverride?: string;
  headingOverride?: string;
  introOverride?: string;
  supportingArticleHrefOverride?: string;
  supportingArticleLabelOverride?: string;
  relatedHrefOverride?: string;
}

const {
  pageTitleOverride,
  pageDescriptionOverride,
  canonicalPathOverride,
  pageNameOverride,
  headingOverride,
  introOverride,
  supportingArticleHrefOverride,
  supportingArticleLabelOverride,
  relatedHrefOverride,
} = Astro.props;

const pageTitle = pageTitleOverride || 'คำนวณ ดอกเบี้ยบัตรเครดิต ปี 2569 | รู้ดอกเบี้ยและยอดคงค้างก่อนจ่ายจริง | เครื่องคำนวณไทย';
const pageDescription = pageDescriptionOverride || 'คำนวณดอกเบี้ยบัตรเครดิตปี 2569 ตามเกณฑ์ ธปท. แบบรายวัน เห็นดอกเบี้ยก่อนครบกำหนด หลังชำระ และยอดคงค้างรอบถัดไป พร้อมยอดชำระขั้นต่ำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = canonicalPathOverride ? `${siteUrl}${canonicalPathOverride}` : `${siteUrl}/คำนวณดอกเบี้ยบัตรเครดิต/`;
const pageName = pageNameOverride || 'คำนวณดอกเบี้ยบัตรเครดิต';
const heading = headingOverride || 'คำนวณดอกเบี้ยบัตรเครดิต ปี 2569';
const intro = introOverride || 'กรอกยอดค้างชำระ ยอดที่จ่ายจริง และจำนวนวันในแต่ละช่วง เพื่อดูดอกเบี้ยรวมรอบถัดไป ยอดคงค้างใหม่ และยอดชำระขั้นต่ำที่ควรจ่าย';
const supportingArticleHref = supportingArticleHrefOverride || '/บทความ/ดอกเบี้ยบัตรเครดิต-คิดยังไง-จ่ายขั้นต่ำ-2569/';
const supportingArticleLabel = supportingArticleLabelOverride || 'บทความ: ดอกเบี้ยบัตรเครดิตคิดยังไง ปี 2569';
const relatedHref = relatedHrefOverride || '/คำนวณดอกเบี้ยบัตรเครดิต/';

const faqData = [
  {
    question: 'ดอกเบี้ยบัตรเครดิตคิดสูงสุดได้เท่าไรในปี 2569?',
    answer: 'ตามเกณฑ์ ธปท. ผู้ออกบัตรเครดิตเรียกเก็บดอกเบี้ย ค่าปรับ ค่าบริการ และค่าธรรมเนียมรวมกันได้ไม่เกิน 16% ต่อปี (effective rate)',
  },
  {
    question: 'ถ้าจ่ายไม่เต็มจำนวน ดอกเบี้ยคิดอย่างไร?',
    answer: 'ปกติจะคิดเป็นรายวัน 2 ช่วง คือช่วงก่อนวันครบกำหนดจากยอดใช้จ่าย และช่วงหลังชำระจากยอดคงค้างที่เหลือจนถึงวันตัดรอบถัดไป',
  },
  {
    question: 'ขั้นต่ำบัตรเครดิตปี 2569 ต้องจ่ายกี่เปอร์เซ็นต์?',
    answer: 'ธปท. ขยายมาตรการชั่วคราวให้ขั้นต่ำอยู่ที่ 8% ของยอดคงค้างจนถึงสิ้นปี 2569 (อาจมีการเปลี่ยนแปลงตามประกาศใหม่)',
  },
  {
    question: 'เบิกเงินสดจากบัตรเครดิตมีค่าใช้จ่ายอะไรเพิ่ม?',
    answer: 'มีค่าธรรมเนียมเบิกเงินสดไม่เกิน 3% ของยอดเบิก และมี VAT 7% บนค่าธรรมเนียมดังกล่าว รวมถึงดอกเบี้ยที่เริ่มคิดตั้งแต่วันเบิกเงินสด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: pageName,
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageName}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">อัปเดตเกณฑ์ล่าสุดปี 2569</p>
      <p class="mt-1 text-sm text-slate-700">คำนวณตามอัตราดอกเบี้ยบัตรเครดิตที่ ธปท. กำกับ (ไม่เกิน 16% ต่อปี)</p>
      <p class="mt-1 text-xs font-medium text-sky-800">ใช้เพื่อประเมินก่อนตัดรอบบิลจริง</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      {heading}
    </h1>

    <p class="text-gray-600 mb-6">
      {intro}
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="cc-interest-form" class="space-y-5">
        <p id="cc-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="statement-balance" class="block text-sm font-medium text-gray-700 mb-1">
              ยอดค้างชำระรอบบิลนี้ (บาท)
            </label>
            <input
              type="text"
              id="statement-balance"
              inputmode="numeric"
              placeholder="เช่น 35,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="statement-balance-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="payment-amount" class="block text-sm font-medium text-gray-700 mb-1">
              ยอดที่ชำระในวันครบกำหนด (บาท)
            </label>
            <input
              type="text"
              id="payment-amount"
              inputmode="numeric"
              placeholder="เช่น 8,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="payment-amount-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="annual-interest-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราดอกเบี้ยรวม (% ต่อปี)
            </label>
            <input
              type="text"
              id="annual-interest-rate"
              inputmode="decimal"
              placeholder="เช่น 16"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p class="mt-1 text-xs text-gray-500">ตามเกณฑ์ ธปท. เรียกเก็บรวมกันได้ไม่เกิน 16% ต่อปี</p>
            <p id="annual-interest-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="min-payment-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราชำระขั้นต่ำ (% ของยอดคงค้าง)
            </label>
            <input
              type="text"
              id="min-payment-rate"
              inputmode="decimal"
              placeholder="เช่น 8"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p class="mt-1 text-xs text-gray-500">มาตรการชั่วคราวปี 2569 อยู่ที่ 8% ตามประกาศ ธปท.</p>
            <p id="min-payment-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="days-before-due" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนวันก่อนครบกำหนดชำระ (วัน)
            </label>
            <input
              type="text"
              id="days-before-due"
              inputmode="numeric"
              placeholder="เช่น 20"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="days-before-due-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="days-after-payment" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนวันหลังชำระถึงรอบถัดไป (วัน)
            </label>
            <input
              type="text"
              id="days-after-payment"
              inputmode="numeric"
              placeholder="เช่น 25"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="days-after-payment-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <details class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
          <summary class="cursor-pointer text-sm font-semibold text-gray-800">กรณีมีการเบิกเงินสด (ไม่บังคับ)</summary>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <div>
              <label for="cash-advance-amount" class="block text-sm font-medium text-gray-700 mb-1">
                ยอดเบิกเงินสด (บาท)
              </label>
              <input
                type="text"
                id="cash-advance-amount"
                inputmode="numeric"
                placeholder="เช่น 5,000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
              <p id="cash-advance-amount-error" class="mt-1 hidden text-sm text-red-600"></p>
            </div>
            <div>
              <label for="cash-advance-days" class="block text-sm font-medium text-gray-700 mb-1">
                จำนวนวันคิดดอกเบี้ยเบิกเงินสด (วัน)
              </label>
              <input
                type="text"
                id="cash-advance-days"
                inputmode="numeric"
                placeholder="เช่น 30"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
              <p id="cash-advance-days-error" class="mt-1 hidden text-sm text-red-600"></p>
            </div>
          </div>
          <p class="mt-3 text-xs text-gray-500">ค่าธรรมเนียมเบิกเงินสดคิดไม่เกิน 3% และมี VAT 7% บนค่าธรรมเนียม</p>
        </details>

        <button
          type="submit"
          id="cc-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณดอกเบี้ย
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยรวมรอบถัดไป</div>
            <div id="res-total-interest" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดคงค้างประมาณการ</div>
            <div id="res-next-balance" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดชำระขั้นต่ำ</div>
            <div id="res-min-payment" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินต้นคงเหลือหลังชำระ</div>
            <div id="res-remaining-principal" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ยอดค้างชำระรอบนี้</span>
            <span id="res-statement-balance" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ยอดที่ชำระ</span>
            <span id="res-payment-amount" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยช่วงก่อนครบกำหนด</span>
            <span id="res-interest-before-due" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยช่วงหลังชำระ</span>
            <span id="res-interest-after-payment" class="font-medium">-</span>
          </div>
          <div id="cash-interest-row" class="hidden flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยเบิกเงินสด</span>
            <span id="res-cash-interest" class="font-medium">-</span>
          </div>
          <div id="cash-fee-row" class="hidden flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าธรรมเนียมเบิกเงินสด + VAT</span>
            <span id="res-cash-fees" class="font-medium">-</span>
          </div>
        </div>

        <p class="text-xs text-gray-500">
          หมายเหตุ: ผลลัพธ์เป็นการประมาณจากข้อมูลที่กรอกจริง และนโยบายผู้ออกบัตรอาจแตกต่างกันเล็กน้อยตามเงื่อนไขสัญญา
        </p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="mb-8 bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 prose prose-slate max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณดอกเบี้ยบัตรเครดิต</h2>
      <p>
        เครื่องมือนี้ใช้แนวคิดการคิดดอกเบี้ยรายวันตามหลักเกณฑ์ ธปท. สำหรับกรณีจ่ายไม่เต็มจำนวน โดยแบ่งเป็น 2 ช่วงหลัก และเพิ่มส่วนเบิกเงินสดถ้ามี
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ดอกเบี้ยช่วงก่อนครบกำหนด = ยอดค้างชำระ × (อัตราดอกเบี้ยต่อปี ÷ 365) × จำนวนวันก่อนครบกำหนด</li>
        <li>ดอกเบี้ยช่วงหลังชำระ = ยอดคงเหลือหลังจ่าย × (อัตราดอกเบี้ยต่อปี ÷ 365) × จำนวนวันหลังชำระถึงรอบถัดไป</li>
        <li>ดอกเบี้ยรวม = ดอกเบี้ยทั้ง 2 ช่วง + ดอกเบี้ยจากเบิกเงินสด (ถ้ามี)</li>
      </ul>
      <p>
        ถ้ามีการเบิกเงินสด จะบวกค่าธรรมเนียมเบิกเงินสด (ไม่เกิน 3%) และ VAT 7% บนค่าธรรมเนียม ตามเกณฑ์ของ ธปท.
      </p>
      <p>
        แหล่งอ้างอิงอย่างเป็นทางการ:
        <a href="https://www.bot.or.th/th/satang-story/digital-fin-lit/creditcard.html" target="_blank" rel="noopener noreferrer">ธปท. ความรู้เรื่องบัตรเครดิต (การคิดดอกเบี้ยและค่าธรรมเนียม)</a>
        ,
        <a href="https://www.bot.or.th/th/news-and-media/news/news-20251204-2.html" target="_blank" rel="noopener noreferrer">ข่าว ธปท. 47/2568 (ขั้นต่ำบัตรเครดิต 8% ถึงสิ้นปี 2569)</a>
      </p>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <RelatedArticles currentHref={relatedHref} />
    <RelatedCalculators currentHref={relatedHref} />

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลคำนวณนี้เป็นค่าประมาณเพื่อวางแผนการเงินเท่านั้น เงื่อนไขจริงอาจต่างกันตามผู้ออกบัตรและรายการใช้จ่ายของแต่ละคน
    </div>
  </article>

  <script type="module">
    import { calculateCreditCardInterest, MAX_CREDIT_CARD_ANNUAL_RATE } from '../../lib/credit-card-interest';

    function parseNum(v) {
      const normalized = String(v).replace(/,/g, '').trim();
      if (normalized === '') return 0;
      const n = Number(normalized);
      return Number.isFinite(n) ? Math.max(0, n) : NaN;
    }

    function hasInvalidNumber(v) {
      const normalized = String(v).replace(/,/g, '').trim();
      return normalized !== '' && Number.isNaN(Number(normalized));
    }

    function fmtMoney(n) {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('cc-interest-form');
    const submitBtn = document.getElementById('cc-submit-btn');
    const formError = document.getElementById('cc-form-error');
    const resultsDiv = document.getElementById('results');

    const fields = {
      statementBalance: document.getElementById('statement-balance'),
      paymentAmount: document.getElementById('payment-amount'),
      annualInterestRate: document.getElementById('annual-interest-rate'),
      minPaymentRate: document.getElementById('min-payment-rate'),
      daysBeforeDue: document.getElementById('days-before-due'),
      daysAfterPayment: document.getElementById('days-after-payment'),
      cashAdvanceAmount: document.getElementById('cash-advance-amount'),
      cashAdvanceDays: document.getElementById('cash-advance-days'),
    };

    function setFieldError(elementId, message) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearFieldError(elementId) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      clearFieldError('statement-balance-error');
      clearFieldError('payment-amount-error');
      clearFieldError('annual-interest-rate-error');
      clearFieldError('min-payment-rate-error');
      clearFieldError('days-before-due-error');
      clearFieldError('days-after-payment-error');
      clearFieldError('cash-advance-amount-error');
      clearFieldError('cash-advance-days-error');
    }

    function updateSubmitState() {
      const requiredFilled = [
        fields.statementBalance.value,
        fields.paymentAmount.value,
        fields.annualInterestRate.value,
        fields.minPaymentRate.value,
        fields.daysBeforeDue.value,
        fields.daysAfterPayment.value,
      ].every((value) => String(value).trim() !== '');

      const hasInvalid = Object.values(fields).some((input) => hasInvalidNumber(input.value));

      const ready = requiredFilled && !hasInvalid;
      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณดอกเบี้ย' : 'กรอกข้อมูลให้ครบ';
      submitBtn.classList.toggle('opacity-70', !ready);
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
    }

    Object.values(fields).forEach((input) => {
      input.addEventListener('input', () => {
        clearValidation();
        updateSubmitState();
      });
    });
    updateSubmitState();

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      clearValidation();

      const statementBalance = parseNum(fields.statementBalance.value);
      const paymentAmount = parseNum(fields.paymentAmount.value);
      const annualInterestRate = parseNum(fields.annualInterestRate.value);
      const minPaymentRate = parseNum(fields.minPaymentRate.value);
      const daysBeforeDue = parseNum(fields.daysBeforeDue.value);
      const daysAfterPayment = parseNum(fields.daysAfterPayment.value);
      const cashAdvanceAmount = parseNum(fields.cashAdvanceAmount.value);
      const cashAdvanceDays = parseNum(fields.cashAdvanceDays.value);

      const inputValidity = {
        statementBalance: !hasInvalidNumber(fields.statementBalance.value) && statementBalance > 0,
        paymentAmount: !hasInvalidNumber(fields.paymentAmount.value) && paymentAmount >= 0,
        annualInterestRate:
          !hasInvalidNumber(fields.annualInterestRate.value) &&
          annualInterestRate > 0 &&
          annualInterestRate <= MAX_CREDIT_CARD_ANNUAL_RATE,
        minPaymentRate: !hasInvalidNumber(fields.minPaymentRate.value) && minPaymentRate > 0 && minPaymentRate <= 100,
        daysBeforeDue: !hasInvalidNumber(fields.daysBeforeDue.value) && daysBeforeDue > 0,
        daysAfterPayment: !hasInvalidNumber(fields.daysAfterPayment.value) && daysAfterPayment > 0,
        cashAdvanceAmount: !hasInvalidNumber(fields.cashAdvanceAmount.value) && cashAdvanceAmount >= 0,
        cashAdvanceDays: !hasInvalidNumber(fields.cashAdvanceDays.value) && cashAdvanceDays >= 0,
      };

      if (!inputValidity.statementBalance) {
        setFieldError('statement-balance-error', 'กรอกยอดค้างชำระมากกว่า 0');
      }
      if (!inputValidity.paymentAmount) {
        setFieldError('payment-amount-error', 'ยอดชำระต้องไม่ติดลบ');
      }
      if (!inputValidity.annualInterestRate) {
        setFieldError('annual-interest-rate-error', `กรอกอัตราดอกเบี้ยระหว่าง 0 ถึง ${MAX_CREDIT_CARD_ANNUAL_RATE}`);
      }
      if (!inputValidity.minPaymentRate) {
        setFieldError('min-payment-rate-error', 'กรอกอัตราขั้นต่ำระหว่าง 0 ถึง 100');
      }
      if (!inputValidity.daysBeforeDue) {
        setFieldError('days-before-due-error', 'กรอกจำนวนวันมากกว่า 0');
      }
      if (!inputValidity.daysAfterPayment) {
        setFieldError('days-after-payment-error', 'กรอกจำนวนวันมากกว่า 0');
      }
      if (!inputValidity.cashAdvanceAmount) {
        setFieldError('cash-advance-amount-error', 'ยอดเบิกเงินสดต้องไม่ติดลบ');
      }
      if (!inputValidity.cashAdvanceDays) {
        setFieldError('cash-advance-days-error', 'จำนวนวันเบิกเงินสดต้องไม่ติดลบ');
      }

      if (!Object.values(inputValidity).every(Boolean)) {
        formError.classList.remove('hidden');
        updateSubmitState();
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('credit_card_interest');

      const result = calculateCreditCardInterest({
        statementBalance,
        paymentAmount,
        annualInterestRate,
        minPaymentRate,
        daysBeforeDue,
        daysAfterPayment,
        cashAdvanceAmount,
        cashAdvanceDays,
      });

      document.getElementById('res-total-interest').textContent = `${fmtMoney(result.totalInterest)} บาท`;
      document.getElementById('res-next-balance').textContent = `${fmtMoney(result.nextStatementBalance)} บาท`;
      document.getElementById('res-min-payment').textContent = `${fmtMoney(result.minimumPayment)} บาท`;
      document.getElementById('res-remaining-principal').textContent = `${fmtMoney(result.remainingPrincipal)} บาท`;
      document.getElementById('res-statement-balance').textContent = `${fmtMoney(statementBalance)} บาท`;
      document.getElementById('res-payment-amount').textContent = `${fmtMoney(paymentAmount)} บาท`;
      document.getElementById('res-interest-before-due').textContent = `${fmtMoney(result.purchaseInterestBeforeDue)} บาท`;
      document.getElementById('res-interest-after-payment').textContent = `${fmtMoney(result.purchaseInterestAfterPayment)} บาท`;

      const cashInterestRow = document.getElementById('cash-interest-row');
      const cashFeeRow = document.getElementById('cash-fee-row');
      if (result.cashAdvanceInterest > 0 || result.totalFees > 0) {
        document.getElementById('res-cash-interest').textContent = `${fmtMoney(result.cashAdvanceInterest)} บาท`;
        document.getElementById('res-cash-fees').textContent = `${fmtMoney(result.totalFees)} บาท`;
        cashInterestRow.classList.remove('hidden');
        cashFeeRow.classList.remove('hidden');
      } else {
        cashInterestRow.classList.add('hidden');
        cashFeeRow.classList.add('hidden');
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณดอกเบี้ย';
      trackCalculatorComplete('credit_card_interest');
      trackCalculatorUsed('credit_card_interest');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          trackResultViewed('credit_card_interest');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
