---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณประหยัดรีไฟแนนซ์บ้าน 2569 | เปรียบดอกเบี้ยเดิม-ใหม่ | Kamnuanlek';
const pageDescription = 'คำนวณประหยัดรีไฟแนนซ์บ้านปี 2569 ฟรี เปรียบค่างวดเดิมกับค่างวดใหม่ ดูดอกเบี้ยรวมที่ประหยัดได้ จุดคุ้มทุน และประหยัดสุทธิหักค่าธรรมเนียม ผลทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประหยัดรีไฟแนนซ์บ้าน/`;

const faqData = [
  {
    question: 'รีไฟแนนซ์บ้านคุ้มเมื่อดอกเบี้ยต่างกันเท่าไร?',
    answer: 'โดยทั่วไปควรมีส่วนต่างดอกเบี้ยอย่างน้อย 0.5–1% ต่อปี และประหยัดดอกเบี้ยรวมมากกว่าค่าธรรมเนียมรีไฟแนนซ์ทั้งหมด ขึ้นอยู่กับยอดหนี้คงเหลือและระยะเวลาที่เหลือด้วย',
  },
  {
    question: 'ค่าธรรมเนียมรีไฟแนนซ์บ้านมีอะไรบ้าง?',
    answer: 'ค่าธรรมเนียมหลักได้แก่ ค่าประเมินหลักทรัพย์ ค่าจดจำนอง (0.1% ของวงเงิน) ค่าปรับปิดบัญชีก่อนกำหนด (ถ้ามี) และค่าธรรมเนียมอื่นของธนาคาร รวมกันอาจอยู่ที่ 20,000–80,000 บาทขึ้นไป',
  },
  {
    question: 'จุดคุ้มทุนรีไฟแนนซ์คำนวณอย่างไร?',
    answer: 'จุดคุ้มทุน = ค่าธรรมเนียมรีไฟแนนซ์รวม ÷ ส่วนต่างค่างวดต่อเดือน เช่น ค่าธรรมเนียม 50,000 บาท ประหยัดต่อเดือน 2,000 บาท จุดคุ้มทุนอยู่ที่ 25 เดือน หากยังถือหนี้ต่อเกิน 25 เดือนถือว่าคุ้ม',
  },
  {
    question: 'ระยะเวลาสัญญาใหม่ควรเลือกเท่าไร?',
    answer: 'ถ้าต้องการลดดอกเบี้ยรวมให้เลือกระยะเวลาใกล้เคียงหรือสั้นกว่างวดคงเหลือ แต่ถ้าต้องการลดค่างวดรายเดือนอาจยืดได้ โดยยอมรับว่าดอกเบี้ยรวมอาจเพิ่มขึ้น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณประหยัดรีไฟแนนซ์บ้าน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประหยัดรีไฟแนนซ์บ้าน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">🔄 รู้ผลทันที — ไม่บันทึกข้อมูล</p>
      <p class="mt-1 text-sm text-slate-700">เปรียบเทียบดอกเบี้ยเดิมกับดอกเบี้ยใหม่ พร้อมจุดคุ้มทุนก่อนตัดสินใจรีไฟแนนซ์</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณประหยัดรีไฟแนนซ์บ้าน 2569
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกยอดหนี้คงเหลือ ดอกเบี้ยเดิม ดอกเบี้ยใหม่ และค่าธรรมเนียม เครื่องมือนี้จะคำนวณ
      ค่างวดเดิม ค่างวดใหม่ ดอกเบี้ยที่ประหยัดได้ จุดคุ้มทุน และประหยัดสุทธิให้ทันที
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="refi-form" class="space-y-5">
        <p id="refi-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="refi-balance" class="block text-sm font-medium text-gray-700 mb-1">
              ยอดหนี้คงเหลือ (บาท)
            </label>
            <input
              type="text"
              id="refi-balance"
              inputmode="numeric"
              value="2000000"
              placeholder="เช่น 2,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="refi-old-rate" class="block text-sm font-medium text-gray-700 mb-1">
              ดอกเบี้ยเดิม (% ต่อปี)
            </label>
            <input
              type="text"
              id="refi-old-rate"
              inputmode="decimal"
              value="6.5"
              placeholder="เช่น 6.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="refi-new-rate" class="block text-sm font-medium text-gray-700 mb-1">
              ดอกเบี้ยใหม่ (% ต่อปี)
            </label>
            <input
              type="text"
              id="refi-new-rate"
              inputmode="decimal"
              value="4.5"
              placeholder="เช่น 4.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="refi-remaining-months" class="block text-sm font-medium text-gray-700 mb-1">
              งวดคงเหลือ (เดือน)
            </label>
            <input
              type="text"
              id="refi-remaining-months"
              inputmode="numeric"
              value="240"
              placeholder="เช่น 240"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="refi-new-term-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาสัญญาใหม่ (ปี)
            </label>
            <input
              type="text"
              id="refi-new-term-years"
              inputmode="numeric"
              value="20"
              placeholder="เช่น 20"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="refi-fee" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าธรรมเนียมรีไฟแนนซ์รวม (บาท)
            </label>
            <input
              type="text"
              id="refi-fee"
              inputmode="numeric"
              value="50000"
              placeholder="เช่น 50,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="refi-results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณรีไฟแนนซ์</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่างวดเดิม</div>
            <div id="res-old-payment" class="text-xl font-bold text-gray-800">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่างวดใหม่</div>
            <div id="res-new-payment" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประหยัดต่อเดือน</div>
            <div id="res-monthly-saving" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">จุดคุ้มทุน</div>
            <div id="res-break-even" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยรวมเดิมที่เหลือ</span>
            <span id="res-old-total-interest" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยรวมใหม่</span>
            <span id="res-new-total-interest" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าธรรมเนียมรีไฟแนนซ์</span>
            <span id="res-fee-display" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ประหยัดสุทธิ (หักค่าธรรมเนียม)</span>
            <span id="res-net-saving" class="font-semibold text-green-700">-</span>
          </div>
        </div>

        <div id="res-summary" class="p-3 rounded-lg text-sm bg-primary-50 border border-primary-200 text-primary-900">-</div>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#refi-results"
    />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีใช้เครื่องคำนวณประหยัดรีไฟแนนซ์บ้าน</h2>
      <ol class="list-decimal pl-6 space-y-1 text-gray-700">
        <li>กรอก <strong>ยอดหนี้คงเหลือ</strong> จากใบแจ้งยอดธนาคารปัจจุบัน</li>
        <li>ระบุ <strong>ดอกเบี้ยเดิม</strong> และ <strong>ดอกเบี้ยใหม่</strong> ที่ธนาคารใหม่เสนอ</li>
        <li>กรอก <strong>งวดคงเหลือ</strong> และ <strong>ระยะเวลาสัญญาใหม่</strong></li>
        <li>ใส่ <strong>ค่าธรรมเนียมรีไฟแนนซ์</strong> รวมทุกรายการ กดคำนวณเพื่อดูผล</li>
      </ol>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรที่ใช้คำนวณ</h3>
      <p class="text-gray-700">
        ค่างวดคำนวณด้วยสูตรลดต้นลดดอก (PMT): <strong>PMT = P × [r(1+r)^n] / [(1+r)^n − 1]</strong>
        โดย P = เงินต้น, r = ดอกเบี้ยต่อเดือน, n = จำนวนงวด
        ดอกเบี้ยรวมคือผลรวมดอกเบี้ยทุกงวด ประหยัดสุทธิ = ดอกเบี้ยเดิมรวม − ดอกเบี้ยใหม่รวม − ค่าธรรมเนียม
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ข้อควรระวังก่อนรีไฟแนนซ์</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ตรวจสอบค่าปรับปิดบัญชีก่อนกำหนดของสัญญาเดิม</li>
        <li>เปรียบเทียบดอกเบี้ยหลังหมดโปรโมชัน 2–3 ปีแรกด้วย</li>
        <li>รวมค่าใช้จ่ายทุกรายการ: ประเมินหลักทรัพย์ จดจำนอง ค่าอากรแสตมป์</li>
        <li>ถ้าจุดคุ้มทุนนานกว่าที่คุณตั้งใจถือหนี้ อาจไม่คุ้มที่จะรีไฟแนนซ์</li>
      </ul>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณประหยัดรีไฟแนนซ์บ้าน/" />
    <RelatedCalculators currentHref="/คำนวณประหยัดรีไฟแนนซ์บ้าน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลคำนวณเป็นการประมาณการเพื่อวางแผนเท่านั้น ไม่ใช่คำแนะนำการเงินหรือข้อเสนอจากธนาคาร
      โปรดตรวจสอบเงื่อนไขจริงกับสถาบันการเงินก่อนตัดสินใจ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    function calcPMT(principal: number, annualRate: number, months: number): number {
      if (months <= 0 || principal <= 0) return 0;
      const r = annualRate / 100 / 12;
      if (r === 0) return principal / months;
      const factor = Math.pow(1 + r, months);
      return principal * (r * factor) / (factor - 1);
    }

    function calcTotalInterest(principal: number, annualRate: number, months: number): number {
      const pmt = calcPMT(principal, annualRate, months);
      return Math.max(0, pmt * months - principal);
    }

    function monthLabel(months: number): string {
      const years = Math.floor(months / 12);
      const rem = months % 12;
      if (years <= 0) return `${months} เดือน`;
      if (rem === 0) return `${years} ปี`;
      return `${years} ปี ${rem} เดือน`;
    }

    const form = document.getElementById('refi-form') as HTMLFormElement;
    const formError = document.getElementById('refi-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('refi-results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const balance = parseNum((document.getElementById('refi-balance') as HTMLInputElement).value);
      const oldRate = parseNum((document.getElementById('refi-old-rate') as HTMLInputElement).value);
      const newRate = parseNum((document.getElementById('refi-new-rate') as HTMLInputElement).value);
      const remainingMonths = parseNum((document.getElementById('refi-remaining-months') as HTMLInputElement).value);
      const newTermYears = parseNum((document.getElementById('refi-new-term-years') as HTMLInputElement).value);
      const fee = parseNum((document.getElementById('refi-fee') as HTMLInputElement).value);

      if (balance <= 0 || remainingMonths <= 0 || newTermYears <= 0) {
        formError.classList.remove('hidden');
        return;
      }

      trackCalculatorUsed('refi-savings');

      const newTermMonths = Math.round(newTermYears * 12);
      const oldPayment = calcPMT(balance, oldRate, remainingMonths);
      const newPayment = calcPMT(balance, newRate, newTermMonths);
      const oldTotalInterest = calcTotalInterest(balance, oldRate, remainingMonths);
      const newTotalInterest = calcTotalInterest(balance, newRate, newTermMonths);
      const monthlySaving = oldPayment - newPayment;
      const breakEvenMonths = monthlySaving > 0 ? Math.ceil(fee / monthlySaving) : 0;
      const netSaving = oldTotalInterest - newTotalInterest - fee;

      (document.getElementById('res-old-payment') as HTMLElement).textContent = fmt(oldPayment) + ' บาท';
      (document.getElementById('res-new-payment') as HTMLElement).textContent = fmt(newPayment) + ' บาท';
      (document.getElementById('res-monthly-saving') as HTMLElement).textContent =
        (monthlySaving >= 0 ? '' : '-') + fmt(Math.abs(monthlySaving)) + ' บาท';
      (document.getElementById('res-break-even') as HTMLElement).textContent =
        breakEvenMonths > 0 ? monthLabel(breakEvenMonths) : (monthlySaving <= 0 ? 'ค่างวดไม่ลด' : 'ทันที');
      (document.getElementById('res-old-total-interest') as HTMLElement).textContent = fmt(oldTotalInterest) + ' บาท';
      (document.getElementById('res-new-total-interest') as HTMLElement).textContent = fmt(newTotalInterest) + ' บาท';
      (document.getElementById('res-fee-display') as HTMLElement).textContent = fmt(fee) + ' บาท';
      (document.getElementById('res-net-saving') as HTMLElement).textContent =
        (netSaving >= 0 ? '+' : '') + fmt(netSaving) + ' บาท';

      const summary = document.getElementById('res-summary') as HTMLElement;
      if (netSaving > 0) {
        summary.className = 'p-3 rounded-lg text-sm bg-green-50 border border-green-200 text-green-900';
        summary.textContent = `รีไฟแนนซ์คาดว่าคุ้ม ประหยัดสุทธิประมาณ ${fmt(netSaving)} บาท` +
          (breakEvenMonths > 0 ? ` โดยถึงจุดคุ้มทุนภายใน ${monthLabel(breakEvenMonths)}` : '');
      } else {
        summary.className = 'p-3 rounded-lg text-sm bg-amber-50 border border-amber-200 text-amber-900';
        summary.textContent = `ตัวเลขปัจจุบันยังไม่คุ้มรีไฟแนนซ์ (ขาดทุนประมาณ ${fmt(Math.abs(netSaving))} บาท) ลองเจรจาลดค่าธรรมเนียมหรือขอดอกเบี้ยที่ต่ำกว่านี้`;
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackResultViewed('refi-savings');
    });
  </script>
</BaseLayout>
