---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');

const newCalculators = [
  // Corporate Finance (10)
  { slug: '/คำนวณ-npv/', title: 'เครื่องคำนวณ NPV', desc: 'มูลค่าปัจจุบันสุทธิสำหรับวิเคราะห์การลงทุน' },
  { slug: '/คำนวณ-irr/', title: 'เครื่องคำนวณ IRR', desc: 'อัตราผลตอบแทนภายในสำหรับโครงการ' },
  { slug: '/คำนวณ-wacc/', title: 'เครื่องคำนวณ WACC', desc: 'ต้นทุนถัวเฉลี่ยถ่วงน้ำหนักของเงินทุน' },
  { slug: '/คำนวณ-roe/', title: 'เครื่องคำนวณ ROE', desc: 'ผลตอบแทนต่อส่วนของผู้ถือหุ้น' },
  { slug: '/คำนวณ-roa/', title: 'เครื่องคำนวณ ROA', desc: 'วิเคราะห์ผลตอบแทนต่อสินทรัพย์รวม' },
  { slug: '/คำนวณ-cagr/', title: 'เครื่องคำนวณ CAGR', desc: 'อัตราการเติบโตต่อปีแบบทบต้น' },
  { slug: '/คำนวณ-break-even/', title: 'เครื่องคำนวณจุดคุ้มทุน', desc: 'วิเคราะห์จุดคุ้มทุน' },
  { slug: '/คำนวณ-debt-to-equity/', title: 'เครื่องคำนวณอัตราส่วน D/E', desc: 'วิเคราะห์อัตราส่วนหนี้สินต่อทุน' },
  { slug: '/คำนวณ-ebitda/', title: 'เครื่องคำนวณ EBITDA', desc: 'กำไรก่อนหักดอกเบี้ยและภาษี' },
  { slug: '/คำนวณ-cash-flow/', title: 'การประมาณการกระแสเงินสด', desc: 'คาดการณ์กระแสเงินสดในอนาคต' },

  // Math & Statistics (11)
  { slug: '/คำนวณ-mean/', title: 'เครื่องคำนวณค่าเฉลี่ย', desc: 'คำนวณค่าเฉลี่ยของข้อมูล' },
  { slug: '/คำนวณ-median/', title: 'เครื่องคำนวณมัธยฐาน', desc: 'หาค่ากลางของข้อมูล' },
  { slug: '/คำนวณ-mode/', title: 'เครื่องคำนวณฐานนิยม', desc: 'หาค่าที่ปรากฏบ่อยที่สุด' },
  { slug: '/คำนวณ-standard-deviation/', title: 'เครื่องคำนวณส่วนเบี่ยงเบนมาตรฐาน', desc: 'วิเคราะห์ส่วนเบี่ยงเบนมาตรฐาน' },
  { slug: '/คำนวณ-variance/', title: 'เครื่องคำนวณความแปรปรวน', desc: 'คำนวณความแปรปรวนของข้อมูล' },
  { slug: '/คำนวณ-correlation/', title: 'เครื่องคำนวณสหสัมพันธ์', desc: 'วิเคราะห์ความสัมพันธ์ระหว่างตัวแปร' },
  { slug: '/คำนวณ-regression/', title: 'เครื่องคำนวณการถดถอย', desc: 'วิเคราะห์การถดถอยเชิงเส้น' },
  { slug: '/คำนวณ-probability/', title: 'เครื่องคำนวณความน่าจะเป็น', desc: 'คำนวณโอกาสเกิดเหตุการณ์' },
  { slug: '/คำนวณ-z-score/', title: 'เครื่องคำนวณ Z-Score', desc: 'คำนวณคะแนนมาตรฐาน' },
  { slug: '/คำนวณ-confidence-interval/', title: 'เครื่องคำนวณช่วงความเชื่อมั่น', desc: 'ช่วงความเชื่อมั่นทางสถิติ' },
  { slug: '/คำนวณ-hypothesis-test/', title: 'การทดสอบสมมติฐาน', desc: 'ทดสอบสมมติฐานทางสถิติ' },
];

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'New Calculators',
      item: `${siteUrl}/เครื่องคำนวณใหม่/`,
    },
  ],
};

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What are these new calculators?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A collection of 21 new calculators for finance, business, and statistics — all free and available in Thai.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are they free to use?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, all calculators are 100% free. No signup required.',
      },
    },
  ],
};
---

<BaseLayout
  title="เครื่องคำนวณใหม่ล่าสุด — ธุรกิจ การเงิน สถิติ | Kamnuanlek"
  description="เครื่องคำนวณใหม่ล่าสุดฟรี NPV IRR WACC ROE ROA CAGR จุดคุ้มทุน สถิติ และอื่นๆ สำหรับธุรกิจและการเงินไทย อัปเดตปี 2569"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} />

  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-100 text-primary-700 rounded-full text-xs font-bold mb-4">
        ⭐ ใหม่
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 mb-4">
        เครื่องคำนวณใหม่
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl">
        เครื่องคำนวณใหม่ 21 ตัว สำหรับวิเคราะห์ธุรกิจ ประเมินการลงทุน และการคำนวณทางสถิติ ฟรีทุกตัวสำหรับทุกคน
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {newCalculators.map((calc) => (
        <a
          href={calc.slug}
          class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all"
        >
          <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-600">
            {calc.title}
          </h3>
          <p class="text-gray-600 text-sm">{calc.desc}</p>
          <div class="mt-4 flex items-center text-primary-600 text-sm font-medium group-hover:translate-x-1 transition">
            ใช้เครื่องคำนวณ →
          </div>
        </a>
      ))}
    </div>

    <div class="bg-gradient-to-r from-primary-50 to-blue-50 p-8 rounded-2xl border border-primary-200 mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">ทำไมต้องใช้เครื่องคำนวณเหล่านี้?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">📊 วิเคราะห์การเงิน</h3>
          <p class="text-gray-700">เครื่องมือ NPV IRR WACC และการวิเคราะห์อัตราส่วน เพื่อประเมินการลงทุนและผลการดำเนินงานทางธุรกิจ</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">📈 เครื่องมือทางสถิติ</h3>
          <p class="text-gray-700">ค่าเฉลี่ย มัธยฐาน ส่วนเบี่ยงเบนมาตรฐาน สหสัมพันธ์ และการทดสอบสมมติฐาน สำหรับวิเคราะห์ข้อมูล</p>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-200 pt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">คำถามที่พบบ่อย</h2>
      <div class="space-y-6">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">เครื่องคำนวณเหล่านี้แม่นยำแค่ไหน?</h3>
          <p class="text-gray-600">เครื่องคำนวณทุกตัวสร้างขึ้นจากสูตรการเงินและสถิติมาตรฐาน ผลลัพธ์มีความแม่นยำเหมาะสำหรับการวางแผนและวิเคราะห์</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">ต้องสมัครสมาชิกหรือไม่?</h3>
          <p class="text-gray-600">ไม่ต้อง ใช้เครื่องคำนวณได้ทันทีโดยไม่ต้องสมัครสมาชิก ลงทะเบียน หรือเข้าสู่ระบบ</p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">นำผลลัพธ์ไปใช้ทำอะไรได้บ้าง?</h3>
          <p class="text-gray-600">ใช้ผลลัพธ์สำหรับวางแผนส่วนตัว วิเคราะห์ธุรกิจ ตัดสินใจลงทุน และอื่นๆ แชร์ผลลัพธ์กับเพื่อนร่วมงาน ที่ปรึกษา หรือหุ้นส่วนได้เลย</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
