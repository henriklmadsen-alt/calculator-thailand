---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณต้นทุนเก็บสินค้าเกษตร | Kamnuanlek';
const pageDescription = 'คำนวณค่าเก็บรักษา ค่าเช่าห้องเก็บ ค่อนเดือน ตันทึก สินค้า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุนเก็บสินค้า/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนเก็บสินค้า">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนเก็บรักษาสินค้า</h1>
    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2"><p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าเก็บรักษาสินค้าเกษตร ค่าเช่าห้องเก็บ</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="kg" class="block text-sm font-medium text-gray-700 mb-1">จำนวนสินค้า (กก.)</label><input type="text" id="kg" inputmode="decimal" placeholder="เช่น 5000" value="5000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="months" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (เดือน)</label><input type="text" id="months" inputmode="numeric" placeholder="เช่น 6" value="6" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-primary-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ค่าต่อเดือน</p><p id="monthly" class="font-bold">-</p></div><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวม</p><p id="total" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ค่าต่อกก.</p><p id="perkg" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const kg = parseFloat((document.getElementById('kg') as HTMLInputElement).value) || 0;
      const months = parseFloat((document.getElementById('months') as HTMLInputElement).value) || 0;
      if (kg <= 0) return;
      const costPerKgMonth = 2, monthlyCost = kg * costPerKgMonth, totalCost = monthlyCost * months, costPerKg = totalCost / kg;
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('monthly') as HTMLElement).textContent = fmt(monthlyCost);
      (document.getElementById('total') as HTMLElement).textContent = fmt(totalCost);
      (document.getElementById('perkg') as HTMLElement).textContent = fmt(costPerKg);
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('storage-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
