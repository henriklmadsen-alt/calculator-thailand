---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
const pageTitle = 'คำนวณค่าเหมาจัดงาน 2569 | Calculator Thailand';
const pageDescription = 'คำนวณค่าเหมาจัดงาน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าเหมาจัดงาน/`;
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเหมาจัดงาน">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเหมาจัดงาน</h1>
    <p class="text-gray-600 mb-6">คำนวณค่าเหมา</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="budget" class="block text-sm font-medium text-gray-700 mb-1">งบประมาณทั้งหมด (บาท)</label>
          <input type="text" id="budget" inputmode="decimal" placeholder="0" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-orange-500 text-base" />
        </div>
        <div>
          <label for="percent" class="block text-sm font-medium text-gray-700 mb-1">ค่าเหมา (%)</label>
          <input type="text" id="percent" inputmode="decimal" placeholder="10" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-orange-500 text-base" />
        </div>
      </div>
      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-orange-600 text-white font-semibold rounded-md hover:bg-orange-700 transition-colors text-base">คำนวณ</button>
      <div id="result" class="hidden mt-8">
        <div class="bg-orange-50 rounded-lg p-6 text-center">
          <div class="text-sm text-gray-600 mb-2">ค่าเหมา</div>
          <div class="text-5xl font-bold text-orange-700"><span id="total">-</span></div>
          <div class="text-sm text-gray-600">บาท</div>
        </div>
      </div>
    </div>
    <RelatedCalculators />
    <RelatedArticles />
  </article>
</BaseLayout>
<script>
  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const budget = parseFloat(document.getElementById('budget')?.value || 0);
    const percent = parseFloat(document.getElementById('percent')?.value || 10);
    const total = budget * (percent / 100);
    if (total === 0) { alert('กรุณาป้อนค่า'); return; }
    document.getElementById('total').textContent = total.toLocaleString('th-TH');
    document.getElementById('result').classList.remove('hidden');
  });
</script>
