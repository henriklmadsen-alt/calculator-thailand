---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ ค่าบริการ SEO 2569 | Calculator Thailand';
const pageDescription = 'คำนวณค่าบริการ SEO ประเมินค่า Keywords, Backlinks, On-page Optimization และ ROI อย่างแม่นยำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่า-seo/`;

const faqData = [
  {
    question: 'ค่า SEO ถูกคิดเป็นอย่างไร?',
    answer: 'SEO บ่อยครั้งเป็นรายเดือน 5,000-100,000+ บาท ขึ้นอยู่กับ Keywords, Competition ความสำนัก เล็ก Agencies 5,000-20,000/เดือน ใหญ่ 50,000+ บ้านค่าตามผล (บางค่า Fixed บางค่าตามการจัดลำดับ)',
  },
  {
    question: 'โดยทั่วไป SEO ใช้เวลาผลเท่าไร?',
    answer: '3-6 เดือนถึง 1 ปี ดูคว่ากรรมวิธีตัวเลขคีย์เวิร์ด ความแข่งขัน High SEO ต้องใช้เวลาสูงกว่า (6-12 เดือน) Low SEO เร็วกว่า (3-6 เดือน)',
  },
  {
    question: 'SEO ROI ประมาณเท่าไร?',
    answer: '1 ปีหลัง ประมาณ 300-500% ROI ไม่มีค่า Ads ต่อเนื่อง Organic Traffic ใช้ได้ไปยาวนาน ยิ่ง Organic ช่วยลดค่า Ads ส่วนยาว',
  },
  {
    question: 'ควรลงทุน In-house SEO หรือ Agency?',
    answer: 'In-house ต้นทุนสูง แต่ Control ดี เหมาะอย่างต่อเนื่อง Agency ต้นทุนจำกัด รวดเร็ว ไม่ต้อง Manage ต่อง์เสี่ยง: เลือก Agency ที่ดีสำคัญมาก',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าบริการ SEO',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่า SEO">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🔍 คำนวณค่าบริการ SEO
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าบริการ SEO ประเมินค่า Keywords, Backlinks, On-page Optimization และ ROI
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="seo-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="monthly-fee" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า SEO ต่อเดือน (บาท)
            </label>
            <input
              type="text"
              id="monthly-fee"
              inputmode="numeric"
              placeholder="เช่น 15000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="months" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลา (เดือน)
            </label>
            <input
              type="text"
              id="months"
              inputmode="numeric"
              placeholder="เช่น 6"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="expected-traffic" class="block text-sm font-medium text-gray-700 mb-1">
              Traffic คาดหวัง (ต่อเดือน หลัง completion)
            </label>
            <input
              type="text"
              id="expected-traffic"
              inputmode="numeric"
              placeholder="เช่น 1000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="conversion-rate" class="block text-sm font-medium text-gray-700 mb-1">
              Conversion Rate (%)
            </label>
            <input
              type="text"
              id="conversion-rate"
              inputmode="numeric"
              placeholder="เช่น 3"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="avg-value" class="block text-sm font-medium text-gray-700 mb-1">
            ค่า Conversion เฉลี่ย (บาท)
          </label>
          <input
            type="text"
            id="avg-value"
            inputmode="numeric"
            placeholder="เช่น 5000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณค่า SEO
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณค่า SEO</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่า SEO รวม</div>
            <div id="res-total-cost" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดขายคาดหวัง</div>
            <div id="res-revenue" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ROI %</div>
            <div id="res-roi" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Cost per Conversion</div>
            <div id="res-cpc" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าต่อเดือน</span>
            <span id="res-monthly" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนเดือน</span>
            <span id="res-months" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">Traffic Conversions</span>
            <span id="res-conversions" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">Payback Period</span>
            <span id="res-payback" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">SEO: ลงทุนยาวคือกุญแจ</h2>

      <p>
        SEO ต่างจาก Ads ที่ให้ผล ทันที SEO ต้องใช้เวลา แต่ Traffic ที่ได้จะอยู่ยาวนาน
        ลดค่า Ads คูณ ทำให้ ROI สูงที่สุดในระยะยาว
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ค่า SEO ตามระดับ</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>Freelancer/Beginner</strong> — 3,000-5,000 บาท/เดือน</li>
        <li><strong>Small Agency</strong> — 5,000-20,000 บาท/เดือน</li>
        <li><strong>Medium Agency</strong> — 20,000-50,000 บาท/เดือน</li>
        <li><strong>Enterprise</strong> — 50,000+ บาท/เดือน</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณ-ค่า-seo/" />
    <RelatedCalculators currentHref="/คำนวณ-ค่า-seo/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ SEO Result ขึ้นอยู่กับหลายปัจจัย
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('seo-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const monthlyFee = parseNum((document.getElementById('monthly-fee') as HTMLInputElement).value);
      const months = parseNum((document.getElementById('months') as HTMLInputElement).value);
      const expectedTraffic = parseNum((document.getElementById('expected-traffic') as HTMLInputElement).value);
      const conversionRate = parseNum((document.getElementById('conversion-rate') as HTMLInputElement).value);
      const avgValue = parseNum((document.getElementById('avg-value') as HTMLInputElement).value);

      if (monthlyFee <= 0) { (document.getElementById('monthly-fee') as HTMLInputElement).focus(); return; }
      if (months <= 0) { (document.getElementById('months') as HTMLInputElement).focus(); return; }
      if (expectedTraffic <= 0) { (document.getElementById('expected-traffic') as HTMLInputElement).focus(); return; }
      if (conversionRate <= 0) { (document.getElementById('conversion-rate') as HTMLInputElement).focus(); return; }
      if (avgValue <= 0) { (document.getElementById('avg-value') as HTMLInputElement).focus(); return; }

      const totalCost = monthlyFee * months;
      const conversions = (expectedTraffic * conversionRate) / 100;
      const monthlyRevenue = conversions * avgValue;
      const totalRevenue = monthlyRevenue * 12;
      const roi = ((totalRevenue - totalCost) / totalCost) * 100;
      const cpc = conversions > 0 ? totalCost / conversions : 0;
      const payback = monthlyFee > 0 ? totalCost / monthlyRevenue : 0;

      (document.getElementById('res-total-cost') as HTMLElement).textContent = fmt(totalCost) + ' บาท';
      (document.getElementById('res-revenue') as HTMLElement).textContent = fmt(totalRevenue) + ' บาท';
      (document.getElementById('res-roi') as HTMLElement).textContent = roi.toFixed(0) + '%';
      (document.getElementById('res-cpc') as HTMLElement).textContent = fmt(cpc) + ' บาท';
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthlyFee) + ' บาท';
      (document.getElementById('res-months') as HTMLElement).textContent = months.toFixed(0);
      (document.getElementById('res-conversions') as HTMLElement).textContent = conversions.toFixed(0);
      (document.getElementById('res-payback') as HTMLElement).textContent = payback.toFixed(1) + ' เดือน';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('seo-service-cost');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('seo-service-cost');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
