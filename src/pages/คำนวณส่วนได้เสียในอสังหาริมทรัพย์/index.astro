---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณส่วนได้เสียในอสังหาริมทรัพย์ 2569 | Equity | Kamnuanlek';
const pageDescription = 'คำนวณส่วนได้เสียบ้าน (Home Equity) เทียบราคาปัจจุบันกับยอดกู้คงเหลือ ออนไลน์ฟรี ตามราคาตลาดไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณส่วนได้เสียในอสังหาริมทรัพย์/`;

const faqData = [
  {
    question: 'ส่วนได้เสีย (Equity) ในอสังหาริมทรัพย์คืออะไร?',
    answer: 'ส่วนได้เสีย = ราคาปัจจุบันของอสังหาริมทรัพย์ - ยอดกู้คงเหลือ หรือ ส่วนได้เสียนั่นเป็นสินทรัพย์ที่คุณมี ส่วนที่ไม่ใช่หนี้',
  },
  {
    question: 'ใช้ส่วนได้เสียได้อย่างไร?',
    answer: 'สามารถใช้ส่วนได้เสียเป็นหลักประกันกู้ยืม (Home Equity Loan หรือ HELOC) ในอัตราดอกเบี้ยต่ำกว่าสินเชื่อส่วนบุคคล หรือใช้ลงทุนจบการศึกษาลูก ฯลฯ',
  },
  {
    question: 'ราคาปัจจุบันคำนวณอย่างไร?',
    answer: 'ราคาปัจจุบันควรอยู่ตามมูลค่า ตลาด อาจใช้เกณฑ์จากการประเมินอสังหาริมทรัพย์ ราคาจำหน่ายของบ้านใกล้เคียง หรือประเมินตามการปรับขึ้นราคา',
  },
  {
    question: 'ยอดกู้คงเหลือหมายถึง?',
    answer: 'ยอดกู้คงเหลือ คือเงินที่ยังต้องชำระให้ธนาคารหรือสถาบันการเงินในปัจจุบัน คุณสามารถขอจากธนาคารได้',
  },
,
  { question: 'ค่าโอนบ้านปี 2569 คิดอัตราเท่าไร?', answer: 'ค่าธรรมเนียมโอน 2% ของราคาประเมิน (ลดเหลือ 1% สำหรับที่อยู่อาศัยราคาไม่เกิน 3 ล้าน จนถึง 31 ธ.ค. 2568), ค่าจดจำนอง 1% ของวงเงิน (ลดเหลือ 0.01% สำหรับกู้ไม่เกิน 3 ล้าน)' },
  { question: 'ภาษีธุรกิจเฉพาะกับอากรแสตมป์ต่างกันอย่างไร?', answer: 'ภาษีธุรกิจเฉพาะ 3.3% (ถือครองน้อยกว่า 5 ปีหรือไม่ได้มีชื่อในทะเบียนบ้าน) | อากรแสตมป์ 0.5% (ถือครอง 5 ปีขึ้นไปและมีชื่อในทะเบียนบ้านครบ 1 ปี) เสียอย่างใดอย่างหนึ่ง' },
  { question: 'ราคาประเมินกรมที่ดินกับราคาตลาดต่างกันอย่างไร?', answer: 'ราคาประเมินคือราคาที่กรมที่ดินกำหนดเพื่อใช้คิดค่าธรรมเนียม อัปเดตทุก 4 ปี มักต่ำกว่าราคาตลาด 20-50% ภาษีและค่าธรรมเนียมใช้ราคาประเมินหรือราคาซื้อขาย แล้วแต่อย่างไหนสูงกว่า' },
  { question: 'ซื้อบ้านมือสองต้องระวังค่าใช้จ่ายอะไร?', answer: 'ค่าธรรมเนียมโอน ค่าภาษีธุรกิจเฉพาะหรืออากรแสตมป์ ค่าจดจำนอง ค่าตรวจสอบภาระผูกพัน ค่าประเมินราคา ค่าซ่อมแซม และค่าประกันภัย รวมกันอาจสูงถึง 5-10% ของราคาซื้อ' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณส่วนได้เสียในอสังหาริมทรัพย์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณส่วนได้เสียในอสังหาริมทรัพย์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ตรวจสอบความมั่นคง</p>
      <p class="mt-1 text-sm text-slate-700">ส่วนได้เสียของคุณในบ้านสูงแค่ไหน?</p>
      <p class="mt-1 text-xs font-medium text-sky-800">ตามราคาตลาดไทย 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณส่วนได้เสียในอสังหาริมทรัพย์
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณส่วนได้เสีย (Home Equity) ของคุณ
      โดยเปรียบเทียบราคาปัจจุบันของบ้านกับยอดกู้ที่คงเหลือ
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ข้อมูลอสังหาริมทรัพย์</h2>

      <form id="equity-form" class="space-y-6">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="current-value" class="block text-sm font-medium text-gray-700 mb-1">
              ราคาปัจจุบันของบ้าน (บาท)
            </label>
            <input
              type="text"
              id="current-value"
              inputmode="numeric"
              placeholder="เช่น 3,500,000"
              value="3500000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
            <p class="mt-1 text-xs text-gray-500">ตามประเมินหรือราคาตลาดปัจจุบัน</p>
          </div>
          <div>
            <label for="remaining-loan" class="block text-sm font-medium text-gray-700 mb-1">
              ยอดกู้คงเหลือ (บาท)
            </label>
            <input
              type="text"
              id="remaining-loan"
              inputmode="numeric"
              placeholder="เช่น 2,000,000"
              value="2000000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base"
            />
            <p class="mt-1 text-xs text-gray-500">ยอดเงินกู้ที่ยังต้องชำระ</p>
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณส่วนได้เสีย
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center border border-blue-100">
            <div class="text-sm text-gray-600 mb-1">ราคาปัจจุบัน</div>
            <div id="result-value" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center border border-red-100">
            <div class="text-sm text-gray-600 mb-1">ยอดกู้คงเหลือ</div>
            <div id="result-loan" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center border border-green-100">
            <div class="text-sm text-gray-600 mb-1">ส่วนได้เสีย</div>
            <div id="result-equity" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>

        <div class="rounded-lg bg-white border border-gray-200 p-6 mb-6">
          <h3 class="text-sm font-semibold text-gray-900 mb-4">สัดส่วนมูลค่า</h3>
          <div class="space-y-3">
            <div>
              <div class="flex justify-between mb-1">
                <span class="text-sm text-gray-600">ส่วนได้เสีย</span>
                <span id="equity-percent" class="text-sm font-semibold text-gray-900">-</span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div id="equity-bar" class="bg-green-500 h-2 rounded-full" style="width: 0%"></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between mb-1">
                <span class="text-sm text-gray-600">ยอดกู้คงเหลือ</span>
                <span id="debt-percent" class="text-sm font-semibold text-gray-900">-</span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div id="debt-bar" class="bg-red-500 h-2 rounded-full" style="width: 0%"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">รายละเอียด</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600">ราคาปัจจุบัน</span>
                <span id="detail-value" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">ยอดกู้คงเหลือ</span>
                <span id="detail-loan" class="font-medium">-</span>
              </div>
              <div class="flex justify-between border-t border-gray-200 pt-2 mt-2 font-semibold">
                <span>ส่วนได้เสีย</span>
                <span id="detail-equity" class="text-green-700">-</span>
              </div>
            </div>
          </div>

          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">อัตราส่วน</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-600">ส่วนได้เสีย (%)</span>
                <span id="detail-equity-pct" class="font-medium">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-600">อัตราส่วนกู้ต่อค่า (LTV)</span>
                <span id="detail-ltv" class="font-medium">-</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.dol.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมที่ดิน (dol.go.th)</a> — อัตราค่าธรรมเนียมการโอนและจดทะเบียนสิทธิ์</li>
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยสินเชื่อบ้านอ้างอิง MRR/MLR</li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณส่วนได้เสียในอสังหาริมทรัพย์/" />
    <RelatedCalculators currentHref="/คำนวณส่วนได้เสียในอสังหาริมทรัพย์/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณใช้เพื่อการประมาณการเท่านั้น ราคาปัจจุบันและยอดกู้ควรตรวจสอบจากเอกสารรับรอง
    </div>
  </article>

  <script>
    function parseNumber(val: string): number {
      return Math.max(0, parseFloat(val.replace(/,/g, '')) || 0);
    }

    function formatThai(num: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(Math.round(num));
    }

    const form = document.getElementById('equity-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const currentValue = parseNumber((document.getElementById('current-value') as HTMLInputElement).value);
      const remainingLoan = parseNumber((document.getElementById('remaining-loan') as HTMLInputElement).value);

      const equity = currentValue - remainingLoan;
      const equityPercent = currentValue > 0 ? (equity / currentValue) * 100 : 0;
      const loanPercent = currentValue > 0 ? (remainingLoan / currentValue) * 100 : 0;
      const ltv = currentValue > 0 ? (remainingLoan / currentValue) * 100 : 0;

      // Update display
      (document.getElementById('result-value') as HTMLElement).textContent = `${formatThai(currentValue)} บาท`;
      (document.getElementById('result-loan') as HTMLElement).textContent = `${formatThai(remainingLoan)} บาท`;
      (document.getElementById('result-equity') as HTMLElement).textContent = `${formatThai(equity)} บาท`;

      (document.getElementById('equity-percent') as HTMLElement).textContent = `${equityPercent.toFixed(1)}%`;
      (document.getElementById('debt-percent') as HTMLElement).textContent = `${loanPercent.toFixed(1)}%`;
      (document.getElementById('equity-bar') as HTMLElement).style.width = `${Math.min(equityPercent, 100)}%`;
      (document.getElementById('debt-bar') as HTMLElement).style.width = `${Math.min(loanPercent, 100)}%`;

      (document.getElementById('detail-value') as HTMLElement).textContent = `${formatThai(currentValue)} บาท`;
      (document.getElementById('detail-loan') as HTMLElement).textContent = `${formatThai(remainingLoan)} บาท`;
      (document.getElementById('detail-equity') as HTMLElement).textContent = `${formatThai(equity)} บาท`;
      (document.getElementById('detail-equity-pct') as HTMLElement).textContent = `${equityPercent.toFixed(2)}%`;
      (document.getElementById('detail-ltv') as HTMLElement).textContent = `${ltv.toFixed(2)}%`;

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('property_equity');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('property_equity');
    });

    form.addEventListener('input', () => {
      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('property_equity');
    }, { once: true });
  </script>
</BaseLayout>
