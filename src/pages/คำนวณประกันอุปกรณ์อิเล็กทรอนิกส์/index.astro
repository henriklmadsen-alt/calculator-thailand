---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณประกันอุปกรณ์อิเล็กทรอนิกส์ (Gadget Insurance) 2569 | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันอุปกรณ์อิเล็กทรอนิกส์ 2569 แล็ปท็อป แท็บเล็ต กล้อง ชุดเกม ประกันทุกอุปกรณ์ในกรมธรรม์เดียว ป้องกันความเสียหายและการสูญหาย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประกันอุปกรณ์อิเล็กทรอนิกส์/`;

const faqData = [
  { question: 'Gadget Insurance ครอบคลุมอุปกรณ์อะไรบ้าง?', answer: 'โดยทั่วไปครอบคลุม: สมาร์ทโฟน แล็ปท็อป แท็บเล็ต กล้องถ่ายภาพ หูฟัง สมาร์ทวอทช์ เกมคอนโซล และอุปกรณ์อิเล็กทรอนิกส์พกพาต่างๆ บางแผนรวมทุกอุปกรณ์ในบ้านเดียว' },
  { question: 'เบี้ยประกันหลายอุปกรณ์ในกรมธรรม์เดียวถูกกว่าไหม?', answer: 'ใช่ การซื้อ Gadget Insurance แบบ multi-device (หลายอุปกรณ์) มักถูกกว่าซื้อแยกแต่ละชิ้น ส่วนลดมักอยู่ที่ 15-30% เมื่อเพิ่มอุปกรณ์ที่ 2 และ 3' },
  { question: 'ประกันอุปกรณ์ครอบคลุมการสูญหายไหม?', answer: 'ขึ้นกับแผน แผนพื้นฐานมักไม่ครอบคลุมการสูญหาย แต่แผนครอบคลุมหรือ All-risks จะรวมการสูญหายและถูกขโมยด้วย ควรอ่านเงื่อนไขให้ชัดก่อนซื้อ' },
  { question: 'อุปกรณ์เก่าซื้อประกันได้ไหม?', answer: 'ได้ แต่มักมีข้อจำกัด เช่น อุปกรณ์ต้องไม่เกิน 2-3 ปี ต้องตรวจสอบสภาพก่อนรับประกัน และมูลค่าเครื่องที่คุ้มครองอาจลดลงตามอายุการใช้งาน' },
];

const jsonLdWebApp = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'เครื่องคำนวณประกันอุปกรณ์อิเล็กทรอนิกส์ 2569', description: pageDescription, url: canonical, applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' }, inLanguage: 'th' };
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประกันอุปกรณ์อิเล็กทรอนิกส์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณการเบี้ย Gadget Insurance</p>
      <p class="mt-1 text-sm text-slate-700">ประกันหลายอุปกรณ์ในกรมธรรม์เดียว</p>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณประกันอุปกรณ์อิเล็กทรอนิกส์ 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">ประมาณเบี้ย Gadget Insurance สำหรับอุปกรณ์อิเล็กทรอนิกส์หลายชิ้น</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกมูลค่าอุปกรณ์</h2>
      <form id="calc-form" class="space-y-4">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกมูลค่าอุปกรณ์อย่างน้อย 1 รายการ</p>

        <div class="grid sm:grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-gray-700 mb-1">📱 สมาร์ทโฟน (บาท)</label><input type="text" id="val-phone" inputmode="numeric" placeholder="เช่น 35,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">💻 แล็ปท็อป (บาท)</label><input type="text" id="val-laptop" inputmode="numeric" placeholder="เช่น 50,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">📷 กล้อง (บาท)</label><input type="text" id="val-camera" inputmode="numeric" placeholder="เช่น 25,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" /></div>
          <div><label class="block text-sm font-medium text-gray-700 mb-1">🎮 อื่นๆ (บาท)</label><input type="text" id="val-other" inputmode="numeric" placeholder="เช่น 15,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" /></div>
        </div>

        <div>
          <label for="coverage-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทความคุ้มครอง</label>
          <select id="coverage-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="0.06">อุบัติเหตุ/เสียหาย (6%/ปี)</option>
            <option value="0.09" selected>อุบัติเหตุ + น้ำเข้า (9%/ปี)</option>
            <option value="0.13">All-risks รวมสูญหาย (13%/ปี)</option>
          </select>
        </div>

        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">คำนวณเบี้ยรวม</button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 mb-4 text-center">
        <p class="text-sm text-primary-700 mb-1">เบี้ยประกันประมาณการรายปี (หลังส่วนลด multi-device)</p>
        <p class="text-4xl font-bold text-primary-700" id="total-premium">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ทำไมควรรวมอุปกรณ์ในกรมธรรม์เดียว?</h2>
      <p>การประกันหลายอุปกรณ์ในกรมธรรม์เดียวมีข้อดีหลายอย่าง: เบี้ยต่อชิ้นถูกกว่า จัดการง่ายกว่า และส่วนใหญ่มีวงเงินรวมที่เพียงพอสำหรับทุกอุปกรณ์</p>
    </section>
    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (<details class="bg-white rounded-lg shadow-sm border border-gray-200"><summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary><div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div></details>))}
      </div>
    </section>
    <RelatedCalculators currentHref="/คำนวณประกันอุปกรณ์อิเล็กทรอนิกส์/" />
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800"><strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงขึ้นกับผู้ให้บริการประกัน</div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const phone = parseNum((document.getElementById('val-phone') as HTMLInputElement).value);
      const laptop = parseNum((document.getElementById('val-laptop') as HTMLInputElement).value);
      const camera = parseNum((document.getElementById('val-camera') as HTMLInputElement).value);
      const other = parseNum((document.getElementById('val-other') as HTMLInputElement).value);
      const rate = parseFloat((document.getElementById('coverage-type') as HTMLSelectElement).value);
      const err = document.getElementById('form-error')!;
      const totalValue = phone + laptop + camera + other;
      if (totalValue < 5000) { err.textContent = 'กรุณากรอกมูลค่าอุปกรณ์อย่างน้อย 1 รายการ'; err.classList.remove('hidden'); return; }
      err.classList.add('hidden');

      const numDevices = [phone, laptop, camera, other].filter(v => v > 0).length;
      const discount = numDevices >= 3 ? 0.25 : numDevices >= 2 ? 0.15 : 0;
      const basePremium = totalValue * rate;
      const total = basePremium * (1 - discount);

      const rows = [
        phone > 0 ? ['สมาร์ทโฟน', '', `${fmt(phone)} บาท`] : null,
        laptop > 0 ? ['แล็ปท็อป', '', `${fmt(laptop)} บาท`] : null,
        camera > 0 ? ['กล้อง', '', `${fmt(camera)} บาท`] : null,
        other > 0 ? ['อุปกรณ์อื่นๆ', '', `${fmt(other)} บาท`] : null,
        ['มูลค่ารวมทั้งหมด', '', `${fmt(totalValue)} บาท`],
        ['เบี้ยก่อนส่วนลด', `${(rate*100).toFixed(0)}%`, `${fmt(basePremium)} บาท`],
        ['ส่วนลด multi-device', `${(discount*100).toFixed(0)}% (${numDevices} อุปกรณ์)`, `-${fmt(basePremium * discount)} บาท`],
        ['เบี้ยรวม/ปี', '', `<strong>${fmt(total)} บาท</strong>`],
      ].filter(Boolean) as string[][];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td><td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td></tr>`).join('');

      (document.getElementById('total-premium') as HTMLElement).textContent = fmt(total) + ' บาท/ปี';
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
