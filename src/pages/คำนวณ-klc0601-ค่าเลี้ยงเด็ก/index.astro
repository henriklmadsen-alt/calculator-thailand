---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าเลี้ยงเด็ก | Kamnuanlek';
const pageDescription = 'คำนวณค่าใจ ค่าหลักสูตร ค่ากิจกรรม รายปีสำหรับเด็ก';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0601-ค่าเลี้ยงเด็ก/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเลี้ยงเด็ก">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเลี้ยงเด็ก</h1>
    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2"><p class="text-xs font-semibold text-blue-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าเลี้ยงเด็กรายปี: ค่าเล่นกีฬา ค่าหนังสือ ค่ากิจกรรม ค่าอาหาร เสื้อผ้า</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="num_children" class="block text-sm font-medium text-gray-700 mb-1">จำนวนลูก (คน)</label><input type="number" id="num_children" min="1" max="10" placeholder="เช่น 2" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="child_age" class="block text-sm font-medium text-gray-700 mb-1">อายุลูก (ปี)</label><input type="number" id="child_age" min="1" max="25" placeholder="เช่น 5" value="5" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="monthly_tuition" class="block text-sm font-medium text-gray-700 mb-1">ค่าเล่นต่อเดือน (บาท)</label><input type="text" id="monthly_tuition" inputmode="decimal" placeholder="เช่น 5000" value="5000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="monthly_food" class="block text-sm font-medium text-gray-700 mb-1">ค่าอาหารต่อเดือน (บาท)</label><input type="text" id="monthly_food" inputmode="decimal" placeholder="เช่น 3000" value="3000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="monthly_clothes" class="block text-sm font-medium text-gray-700 mb-1">ค่าเสื้อผ้า/เครื่องแบบต่อเดือน (บาท)</label><input type="text" id="monthly_clothes" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="activities" class="block text-sm font-medium text-gray-700 mb-1">ค่ากิจกรรมต่อเดือน (บาท)</label><input type="text" id="activities" inputmode="decimal" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-blue-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าเลี้ยงต่อเดือน</p>
            <p id="monthly" class="font-bold">-</p>
          </div>
          <div class="bg-blue-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าเลี้ยงต่อปี</p>
            <p id="yearly" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">รวมค่าเลี้ยงเด็กทั้งหมด (ทั้งปี)</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่าเลี้ยงเด็ก ต่างจากค่าใจ อย่างไร?</h3>
            <p class="text-gray-600 text-sm">ค่าเลี้ยงเด็ก (childcare) หมายถึงค่าใจ ค่าเล่นกีฬา ค่าหนังสือ ค่ากิจกรรม ค่าอาหาร เสื้อผ้า ส่วนค่าใจโดยเฉพาะ คือค่าสถานที่เล่นเท่านั้น</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ควรประมาณค่าเลี้ยงเด็กเท่าไหร่ต่อเดือน?</h3>
            <p class="text-gray-600 text-sm">ตามสถิติของประเทศไทย เด็กอายุ 0-5 ปี ต้องใช้งบประมาณประมาณ 2,000-5,000 บาทต่อเดือน เด็ก 6-12 ปี ประมาณ 4,000-8,000 บาทต่อเดือน ขึ้นอยู่กับคุณภาพเล่นและสถานที่</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ควรเก็บเงินเลี้ยงเด็กไว้อย่างไร?</h3>
            <p class="text-gray-600 text-sm">ควรเก็บเงินในบัญชีออมสินหรือกองทุนที่มีอัตราผลตอบแทนที่เหมาะสม เพื่อให้เงินเก็บเพิ่มขึ้นเมื่อถึงเวลาใช้</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const numChildren = parseInt((document.getElementById('num_children') as HTMLInputElement).value) || 1;
      const monthlyTuition = parseFloat((document.getElementById('monthly_tuition') as HTMLInputElement).value) || 0;
      const monthlyFood = parseFloat((document.getElementById('monthly_food') as HTMLInputElement).value) || 0;
      const monthlyClothes = parseFloat((document.getElementById('monthly_clothes') as HTMLInputElement).value) || 0;
      const activities = parseFloat((document.getElementById('activities') as HTMLInputElement).value) || 0;

      const monthlyPerChild = monthlyTuition + monthlyFood + monthlyClothes + activities;
      const monthlyTotal = monthlyPerChild * numChildren;
      const yearlyTotal = monthlyTotal * 12;

      (document.getElementById('monthly') as HTMLElement).textContent = monthlyTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('yearly') as HTMLElement).textContent = (monthlyTotal * 12).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = yearlyTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('childcare-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
