---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณต้นทุนระบบ Telematics | วิเคราะห์ประโยชน์ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนประโยชน์จากระบบ Telematics สำหรับยานพาหนะ โดยวิเคราะห์การประหยัดน้ำมัน ลดอุบัติเหตุ และปรับปรุงประสิทธิภาพการขับขี่';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนระบบ-telematics/`;

const faqData = [
  {
    question: 'ระบบ Telematics คืออะไร?',
    answer: 'Telematics เป็นระบบที่รวมการสื่อสารระยะไกล (Tele) และคณิตศาสตร์ (Matics) เพื่อติดตามและวิเคราะห์ข้อมูลยานพาหนะ รวมถึงตำแหน่ง พฤติกรรมการขับขี่ สภาพเครื่องยนต์ ประสิทธิภาพเชื้อเพลิง',
  },
  {
    question: 'ประโยชน์ของระบบ Telematics คืออะไร?',
    answer: 'ประโยชน์หลัก: (1) ลดการใช้น้ำมัน 5-15% โดยการวิเคราะห์พฤติกรรมการขับขี่ (2) ลดอุบัติเหตุ 20-30% โดยการเตือนการขับอันตราย (3) ลดค่าซ่อมบำรุง 10-15% โดยการตรวจสอบสภาพรถ (4) ประหยัดค่าประกัน 10-20% (5) ปรับปรุงการตัดสินใจจัดการสำรองรถ',
  },
  {
    question: 'Telematics กับ GPS ต่างกันอย่างไร?',
    answer: 'GPS ติดตามตำแหน่งของรถเท่านั้น ในขณะที่ Telematics ติดตามข้อมูลมากมายรวมถึง ตำแหน่ง ความเร็ว พฤติกรรมการขับขี่ ประสิทธิภาพเครื่องยนต์ ระดับน้ำมัน อุณหภูมิเครื่องยนต์ และสามารถเตือนและให้คำแนะนำการขับขี่ได้',
  },
  {
    question: 'Telematics เหมาะกับธุรกิจใดบ้าง?',
    answer: 'Telematics เหมาะกับบริษัทที่มีรถหลายคัน เช่น บริษัทลอจิสติก ชุมชนบริการ ระบบขนส่งสาธารณะ และบริษัทปันส่วนโดยทั่วไป',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนระบบ Telematics',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนระบบ Telematics">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณต้นทุนระบบ Telematics
    </h1>

    <p class="text-gray-600 mb-6">
      วิเคราะห์ประโยชน์และต้นทุนของการลงทุนในระบบ Telematics สำหรับจัดการรถบริษัท
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="calculator-form" class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="num-vehicles" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนรถ (คัน)
            </label>
            <input type="text" id="num-vehicles" inputmode="decimal" placeholder="เช่น 50" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="installation-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าติดตั้งต่อรถ (บาท)
            </label>
            <input type="text" id="installation-cost" inputmode="decimal" placeholder="เช่น 5000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="monthly-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าสมัครต่อเดือน/รถ (บาท)
            </label>
            <input type="text" id="monthly-cost" inputmode="decimal" placeholder="เช่น 500" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="fuel-saving" class="block text-sm font-medium text-gray-700 mb-1">
              ลดการใช้น้ำมัน (%)
            </label>
            <input type="text" id="fuel-saving" inputmode="decimal" placeholder="เช่น 10" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="monthly-fuel-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าน้ำมันต่อเดือน/รถ (บาท)
            </label>
            <input type="text" id="monthly-fuel-cost" inputmode="decimal" placeholder="เช่น 6000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="accident-reduction" class="block text-sm font-medium text-gray-700 mb-1">
              ลดต้นทุนอุบัติเหตุต่อปี (บาท)
            </label>
            <input type="text" id="accident-reduction" inputmode="decimal" placeholder="เช่น 15000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="maintenance-reduction" class="block text-sm font-medium text-gray-700 mb-1">
              ลดค่าซ่อมบำรุงต่อปี (บาท)
            </label>
            <input type="text" id="maintenance-reduction" inputmode="decimal" placeholder="เช่น 20000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>

          <div>
            <label for="analysis-period" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาวิเคราะห์ (ปี)
            </label>
            <input type="text" id="analysis-period" inputmode="decimal" placeholder="เช่น 3" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          วิเคราะห์ต้นทุน
        </button>
      </form>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ผลตอบแทนเฉลี่ยต่อปี</div>
          <div id="roi-percent" class="text-4xl font-bold mb-2 text-primary-600">0%</div>
        </div>

        <div class="bg-blue-50 rounded-lg p-4">
          <div class="text-sm text-gray-600">ต้นทุนเริ่มแรก</div>
          <div id="total-investment" class="text-2xl font-bold text-blue-700">0</div>
        </div>

        <div class="bg-green-50 rounded-lg p-4">
          <div class="text-sm text-gray-600">การออมต่อปี</div>
          <div id="annual-saving" class="text-2xl font-bold text-green-700">0</div>
        </div>

        <div class="bg-orange-50 rounded-lg p-4">
          <div class="text-sm text-gray-600">ระยะเวลาคืนทุน</div>
          <div id="payback-months" class="text-2xl font-bold text-orange-700">0</div>
          <div class="text-sm text-gray-600">เดือน</div>
        </div>

        <div class="bg-purple-50 rounded-lg p-4">
          <div class="text-sm text-gray-600">ผลตอบแทนสุทธิ (ตามระยะเวลาวิเคราะห์)</div>
          <div id="net-benefit" class="text-2xl font-bold text-purple-700">0</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ระบบ Telematics สำหรับจัดการรถบริษัท</h2>

      <p>
        ระบบ Telematics เป็นโซลูชันการจัดการรถยนต์ที่ทันสมัย ซึ่งรวมเทคโนโลยี GPS, IoT, และ Big Data Analytics
        เพื่อติดตามและวิเคราะห์ข้อมูลยานพาหนะแบบเรียลไทม์ ช่วยให้บริษัทสามารถเพิ่มประสิทธิภาพ ลดต้นทุน และปรับปรุงความปลอดภัย
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ส่วนประกอบของระบบ Telematics</h3>

      <ol class="list-decimal list-inside space-y-2 text-gray-700">
        <li><strong>อุปกรณ์ติดตั้งรถ:</strong> กล่องเล็กติดไว้ในรถ เก็บรวบรวมข้อมูลต่างๆ</li>
        <li><strong>ระบบสื่อสาร:</strong> ส่งข้อมูลจากรถไปยังเซิร์ฟเวอร์กลางผ่านอินเทอร์เน็ต</li>
        <li><strong>แพลตฟอร์มวิเคราะห์ข้อมูล:</strong> ประมวลผลข้อมูลและสร้างรายงานต่างๆ</li>
        <li><strong>แอปพลิเคชันสำหรับผู้ใช้:</strong> อนุญาตให้ผู้จัดการและคนขับดูข้อมูลและรับการแจ้งเตือน</li>
      </ol>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีการประเมินมูลค่าระบบ Telematics</h3>

      <p>
        ในการประเมินมูลค่าของระบบ Telematics จำเป็นต้องพิจารณา:
      </p>

      <ul class="list-disc list-inside space-y-2 text-gray-700">
        <li><strong>ต้นทุนการลงทุน:</strong> ค่าติดตั้ง ค่าอุปกรณ์ ค่าคำฝึกสอน</li>
        <li><strong>ต้นทุนปกติ:</strong> ค่าสมัครรายเดือน ค่าบำรุงรักษา</li>
        <li><strong>ประโยชน์:</strong> การประหยัดน้ำมัน ลดอุบัติเหตุ ลดค่าซ่อม</li>
        <li><strong>ระยะเวลากู้คืนทุน:</strong> Payback Period</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณต้นทุนระบบ-telematics/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนระบบ-telematics/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น ผลจริงอาจแตกต่างตามสภาพการใช้งาน
    </div>
  </article>

  <script>
    function formatNumber(num: number): string {
      return new Intl.NumberFormat('th-TH', {
        minimumFractionDigits: 0,
        maximumFractionDigits: 2,
      }).format(num);
    }

    function calculateTelematics() {
      const numVehicles = parseFloat(document.getElementById('num-vehicles')?.value || '1') || 1;
      const installationCost = parseFloat(document.getElementById('installation-cost')?.value || '0') || 0;
      const monthlyCost = parseFloat(document.getElementById('monthly-cost')?.value || '0') || 0;
      const fuelSaving = parseFloat(document.getElementById('fuel-saving')?.value || '0') || 0;
      const monthlyFuelCost = parseFloat(document.getElementById('monthly-fuel-cost')?.value || '0') || 0;
      const accidentReduction = parseFloat(document.getElementById('accident-reduction')?.value || '0') || 0;
      const maintenanceReduction = parseFloat(document.getElementById('maintenance-reduction')?.value || '0') || 0;
      const analysisPeriod = parseFloat(document.getElementById('analysis-period')?.value || '1') || 1;

      // Calculate costs
      const totalInvestment = installationCost * numVehicles;
      const annualSubscriptionCost = monthlyCost * numVehicles * 12;

      // Calculate benefits
      const monthlyFuelSavingAmount = (monthlyFuelCost * fuelSaving / 100) * numVehicles;
      const annualFuelSavingAmount = monthlyFuelSavingAmount * 12;
      const annualAccidentSaving = accidentReduction * numVehicles;
      const annualMaintenanceSaving = maintenanceReduction * numVehicles;

      const totalAnnualBenefit = annualFuelSavingAmount + annualAccidentSaving + annualMaintenanceSaving;
      const netAnnualBenefit = totalAnnualBenefit - annualSubscriptionCost;
      const roi = (netAnnualBenefit / totalInvestment) * 100;
      const paybackMonths = (totalInvestment / (netAnnualBenefit || 1)) * 12;
      const netBenefit = (netAnnualBenefit * analysisPeriod) - totalInvestment;

      // Update display
      document.getElementById('roi-percent')!.textContent = formatNumber(Math.max(roi, 0)) + '%';
      document.getElementById('total-investment')!.textContent = formatNumber(totalInvestment) + ' บาท';
      document.getElementById('annual-saving')!.textContent = formatNumber(netAnnualBenefit) + ' บาท';
      document.getElementById('payback-months')!.textContent = formatNumber(Math.max(paybackMonths, 0));
      document.getElementById('net-benefit')!.textContent = formatNumber(netBenefit) + ' บาท';

      document.getElementById('result')?.classList.remove('hidden');
    }

    document.getElementById('btn-calculate')?.addEventListener('click', calculateTelematics);
  </script>
</BaseLayout>
