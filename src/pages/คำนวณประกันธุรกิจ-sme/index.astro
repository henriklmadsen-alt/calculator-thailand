---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณประกันธุรกิจ SME 2569 | ประมาณเบี้ยประกันธุรกิจขนาดย่อม ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันธุรกิจ SME 2569 ครอบคลุมทรัพย์สิน สต็อกสินค้า ความรับผิด และธุรกิจหยุดชะงัก ประมาณการเบี้ยรายปีสำหรับร้านค้า โรงงาน สำนักงาน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประกันธุรกิจ-sme/`;

const faqData = [
  {
    question: 'ประกันธุรกิจ SME ครอบคลุมอะไรบ้าง?',
    answer: 'ประกันธุรกิจ SME มักครอบคลุม: (1) ทรัพย์สินและอาคาร เช่น ไฟไหม้ น้ำท่วม ภัยธรรมชาติ (2) สต็อกสินค้าในคลังหรือร้าน (3) ความรับผิดต่อบุคคลภายนอก (Public Liability) (4) ธุรกิจหยุดชะงัก (Business Interruption) เมื่อเกิดเหตุไม่คาดฝัน',
  },
  {
    question: 'ธุรกิจ SME ควรทำประกันทุนเท่าไร?',
    answer: 'ควรประเมินมูลค่าทรัพย์สินทั้งหมดได้แก่ อาคาร เครื่องจักร สต็อกสินค้า รวมกัน เพื่อเป็นทุนประกันทรัพย์สิน ส่วนความรับผิดควรอยู่ที่ 1-5 ล้านบาทขึ้นไปขึ้นกับลักษณะธุรกิจ',
  },
  {
    question: 'เบี้ยประกันธุรกิจ SME คำนวณอย่างไร?',
    answer: 'เบี้ยคำนวณจากมูลค่าทรัพย์สินที่เอาประกัน × อัตราเบี้ย (ปกติ 0.15-0.5% ต่อปี ขึ้นกับประเภทธุรกิจและความเสี่ยง) บวกเบี้ยความรับผิดและธุรกิจหยุดชะงักตามเลือก',
  },
  {
    question: 'ประกันธุรกิจ SME ลดหย่อนภาษีได้ไหม?',
    answer: 'ได้ เบี้ยประกันธุรกิจสามารถนำไปหักเป็นค่าใช้จ่ายของกิจการได้ทั้งจำนวน ทำให้ลดกำไรสุทธิที่ต้องเสียภาษีนิติบุคคลหรือภาษีเงินได้จากธุรกิจ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณประกันธุรกิจ SME 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประกันธุรกิจ SME">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณการเบี้ยประกันธุรกิจ SME</p>
      <p class="mt-1 text-sm text-slate-700">ผลลัพธ์เป็นการประมาณการเท่านั้น อัตราจริงขึ้นกับบริษัทประกันและลักษณะธุรกิจ</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณประกันธุรกิจ SME 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">ประมาณเบี้ยประกันธุรกิจขนาดย่อมและขนาดกลาง ครอบคลุมทรัพย์สิน สต็อก ความรับผิด และธุรกิจหยุดชะงัก</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูลธุรกิจ</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>

        <div>
          <label for="asset-value" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าทรัพย์สิน/อาคาร (บาท)</label>
          <input type="text" id="asset-value" inputmode="numeric" placeholder="เช่น 2,000,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">อาคาร เครื่องจักร อุปกรณ์สำนักงาน</p>
        </div>

        <div>
          <label for="stock-value" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าสต็อกสินค้า (บาท)</label>
          <input type="text" id="stock-value" inputmode="numeric" placeholder="เช่น 500,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">สินค้าคงคลัง วัตถุดิบ</p>
        </div>

        <div>
          <label for="business-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทธุรกิจ</label>
          <select id="business-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="0.0015">ร้านค้าปลีก/สำนักงาน (0.15%)</option>
            <option value="0.002">ร้านอาหาร/บริการ (0.20%)</option>
            <option value="0.003">โกดัง/คลังสินค้า (0.30%)</option>
            <option value="0.004">โรงงานเบา (0.40%)</option>
            <option value="0.005">โรงงานหนัก/เคมี (0.50%)</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">ความคุ้มครองเพิ่มเติม</label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-sm text-gray-700">
              <input type="checkbox" id="chk-liability" class="rounded" checked />
              ความรับผิดต่อบุคคลภายนอก (1,000,000 บาท / ~3,500 บาท/ปี)
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700">
              <input type="checkbox" id="chk-bi" class="rounded" />
              ธุรกิจหยุดชะงัก Business Interruption (~5,000 บาท/ปี)
            </label>
          </div>
        </div>

        <button type="button" id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">
          คำนวณเบี้ยประกัน
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 mb-4 text-center">
        <p class="text-sm text-primary-700 mb-1">เบี้ยประกันประมาณการรายปี</p>
        <p class="text-4xl font-bold text-primary-700" id="total-premium">-</p>
        <p class="text-sm text-primary-600 mt-1" id="monthly-premium">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b border-gray-200">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm">
          <tbody id="breakdown-body"></tbody>
        </table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ประกันธุรกิจ SME คืออะไร?</h2>
      <p>ประกันธุรกิจ SME คือแพ็กเกจประกันภัยที่ออกแบบมาสำหรับธุรกิจขนาดเล็กและกลาง ให้ความคุ้มครองครอบคลุมในกรมธรรม์เดียว ช่วยให้เจ้าของกิจการไม่ต้องซื้อประกันหลายฉบับแยกกัน</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ความคุ้มครองหลัก</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ไฟไหม้ ฟ้าผ่า ระเบิด ภัยธรรมชาติ</li>
        <li>การโจรกรรมและการลักทรัพย์</li>
        <li>ความเสียหายของสต็อกสินค้า</li>
        <li>ความรับผิดต่อลูกค้าและบุคคลภายนอก</li>
        <li>ธุรกิจหยุดชะงักจากเหตุที่คุ้มครอง</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณประกันธุรกิจ-sme/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ อัตราจริงขึ้นกับบริษัทประกัน ประเภทธุรกิจ และประวัติการเคลม
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const assetVal = parseNum((document.getElementById('asset-value') as HTMLInputElement).value);
      const stockVal = parseNum((document.getElementById('stock-value') as HTMLInputElement).value);
      const rate = parseFloat((document.getElementById('business-type') as HTMLSelectElement).value);
      const hasLiability = (document.getElementById('chk-liability') as HTMLInputElement).checked;
      const hasBI = (document.getElementById('chk-bi') as HTMLInputElement).checked;
      const err = document.getElementById('form-error')!;

      if (assetVal < 100000) {
        err.textContent = 'กรุณากรอกมูลค่าทรัพย์สินอย่างน้อย 100,000 บาท';
        err.classList.remove('hidden'); return;
      }
      err.classList.add('hidden');

      const assetPremium = assetVal * rate;
      const stockPremium = stockVal * rate;
      const liabilityPremium = hasLiability ? 3500 : 0;
      const biPremium = hasBI ? 5000 : 0;
      const total = assetPremium + stockPremium + liabilityPremium + biPremium;

      const rows = [
        ['เบี้ยทรัพย์สิน/อาคาร', `${fmt(assetVal)} × ${(rate*100).toFixed(2)}%`, `${fmt(assetPremium)} บาท`],
        ['เบี้ยสต็อกสินค้า', `${fmt(stockVal)} × ${(rate*100).toFixed(2)}%`, `${fmt(stockPremium)} บาท`],
        ['ความรับผิดบุคคลภายนอก', hasLiability ? 'คุ้มครอง 1,000,000 บาท' : 'ไม่เลือก', hasLiability ? '3,500 บาท' : '-'],
        ['ธุรกิจหยุดชะงัก', hasBI ? 'เลือก' : 'ไม่เลือก', hasBI ? '5,000 บาท' : '-'],
        ['เบี้ยรวมประมาณการ/ปี', '', `<strong>${fmt(total)} บาท</strong>`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td>
          <td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td>
        </tr>`).join('');

      (document.getElementById('total-premium') as HTMLElement).textContent = fmt(total) + ' บาท/ปี';
      (document.getElementById('monthly-premium') as HTMLElement).textContent = `≈ ${fmt(total/12)} บาท/เดือน`;
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
