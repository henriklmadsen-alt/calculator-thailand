---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเปรียบเทียบ Wire Transfer ปี 2569 — SWIFT vs FinTech | เครื่องคำนวณไทย';
const pageDescription = 'เปรียบเทียบต้นทุน Wire Transfer ระหว่างธนาคาร SWIFT กับ FinTech เช่น Wise ป้อนยอดโอน อัตราและค่าธรรมเนียม ดูว่าแบบไหนคุ้มกว่า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-wire-transfer/`;

const faqData = [
  {
    question: 'Wire Transfer กับ FinTech ต่างกันอย่างไร?',
    answer: 'Wire Transfer ผ่านธนาคารใช้ระบบ SWIFT มีค่าธรรมเนียมสูงกว่า (500–1,500 บาท) แต่น่าเชื่อถือ ส่วน FinTech เช่น Wise ใช้อัตราตลาดจริงและค่าธรรมเนียมต่ำกว่า',
  },
  {
    question: 'Wise ดีกว่าธนาคารจริงไหม?',
    answer: 'สำหรับการโอนเงินส่วนตัวขนาดเล็กถึงกลาง Wise มักถูกกว่า เพราะใช้อัตราตลาด Mid-Market Rate และค่าธรรมเนียมต่ำ แต่สำหรับธุรกรรมขนาดใหญ่ควรเปรียบเทียบด้วยตัวเอง',
  },
  {
    question: 'Wire Transfer ใช้เวลานานแค่ไหน?',
    answer: 'SWIFT Wire Transfer ใช้เวลา 1–5 วันทำการ ขึ้นอยู่กับประเทศและธนาคาร ส่วน FinTech มักเร็วกว่า บางรายโอนถึงวันเดียวกัน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเปรียบเทียบ Wire Transfer',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-wire-transfer">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-blue-100 bg-blue-50 p-4">
      <p class="text-sm font-semibold text-blue-700">เปรียบเทียบ Wire Transfer — ธนาคาร SWIFT vs FinTech</p>
      <p class="mt-1 text-sm text-slate-700">ต้นทุนรวม = ค่าธรรมเนียม + ค่า FX Spread | เลือกแบบที่ผู้รับได้มากที่สุด</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      เปรียบเทียบ Wire Transfer ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      เปรียบเทียบต้นทุนการโอนเงินระหว่างประเทศผ่าน 2 ช่องทาง
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="wt-form" class="space-y-5">
        <p id="wt-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div>
          <label for="wt-amount" class="mb-1 block text-sm font-medium text-gray-700">ยอดโอน (บาท)</label>
          <input type="text" id="wt-amount" inputmode="numeric" placeholder="เช่น 100,000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          <p id="wt-amount-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-gray-100 bg-gray-50 p-4">
            <h3 class="mb-3 text-sm font-semibold text-gray-700">ช่องทางที่ 1 (เช่น ธนาคาร SWIFT)</h3>
            <div class="space-y-3">
              <div>
                <label class="mb-1 block text-xs font-medium text-gray-600">ค่าธรรมเนียมคงที่ (บาท)</label>
                <input type="text" id="wt-a-fee" inputmode="numeric" placeholder="เช่น 700"
                  class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-xs font-medium text-gray-600">FX Spread (%)</label>
                <input type="text" id="wt-a-spread" inputmode="decimal" placeholder="เช่น 2.0"
                  class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none" />
              </div>
            </div>
          </div>
          <div class="rounded-lg border border-blue-100 bg-blue-50 p-4">
            <h3 class="mb-3 text-sm font-semibold text-blue-700">ช่องทางที่ 2 (เช่น Wise)</h3>
            <div class="space-y-3">
              <div>
                <label class="mb-1 block text-xs font-medium text-gray-600">ค่าธรรมเนียมคงที่ (บาท)</label>
                <input type="text" id="wt-b-fee" inputmode="numeric" placeholder="เช่น 150"
                  class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none" />
              </div>
              <div>
                <label class="mb-1 block text-xs font-medium text-gray-600">FX Spread (%)</label>
                <input type="text" id="wt-b-spread" inputmode="decimal" placeholder="เช่น 0.5"
                  class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-primary-500 focus:outline-none" />
              </div>
            </div>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          เปรียบเทียบ Wire Transfer
        </button>
      </form>
    </div>

    <div id="wt-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการเปรียบเทียบ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-2">
          <div id="wt-a-box" class="rounded-lg p-4">
            <div class="mb-1 text-sm font-semibold text-gray-700">ช่องทางที่ 1</div>
            <div class="text-xs text-gray-500 mb-2">ต้นทุนรวม</div>
            <div id="res-wt-a-cost" class="text-2xl font-bold">-</div>
            <div class="mt-1 text-xs text-gray-500">ผู้รับได้ <span id="res-wt-a-net"></span></div>
          </div>
          <div id="wt-b-box" class="rounded-lg p-4">
            <div class="mb-1 text-sm font-semibold text-blue-700">ช่องทางที่ 2</div>
            <div class="text-xs text-gray-500 mb-2">ต้นทุนรวม</div>
            <div id="res-wt-b-cost" class="text-2xl font-bold">-</div>
            <div class="mt-1 text-xs text-gray-500">ผู้รับได้ <span id="res-wt-b-net"></span></div>
          </div>
        </div>
        <p id="wt-verdict" class="rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ต้นทุน FX = ยอดโอน × Spread%</li>
        <li>ต้นทุนรวม = ค่าธรรมเนียมคงที่ + ต้นทุน FX</li>
        <li>ยอดผู้รับ = ยอดโอน − ต้นทุนรวม</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณต้นทุนชำระเงินข้ามประเทศ/">คำนวณต้นทุนชำระเงินข้ามประเทศ</a></li>
        <li><a href="/คำนวณยอดรับเงินโอนต่างประเทศ/">คำนวณยอดรับเงินโอนต่างประเทศ</a></li>
        <li><a href="/คำนวณเปรียบเทียบร้านแลกเงิน/">เปรียบเทียบร้านแลกเงิน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#wt-results" />
    <RelatedArticles currentHref="/คำนวณ-wire-transfer/" />
    <RelatedCalculators currentHref="/คำนวณ-wire-transfer/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> อัตราแลกเปลี่ยนและค่าธรรมเนียมเปลี่ยนแปลงได้ ควรยืนยันอัตราจริงก่อนทำรายการ
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('wt-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      setErr('wt-amount-error', '');

      const amount = parseNum(document.getElementById('wt-amount').value);
      const aFee = parseNum(document.getElementById('wt-a-fee').value) || 0;
      const aSpread = parseNum(document.getElementById('wt-a-spread').value) || 0;
      const bFee = parseNum(document.getElementById('wt-b-fee').value) || 0;
      const bSpread = parseNum(document.getElementById('wt-b-spread').value) || 0;

      if (!Number.isFinite(amount) || amount <= 0) { setErr('wt-amount-error', 'กรอกยอดโอนมากกว่า 0'); document.getElementById('wt-error').classList.remove('hidden'); document.getElementById('wt-results').classList.add('hidden'); return; }
      document.getElementById('wt-error').classList.add('hidden');

      const aCost = aFee + amount * aSpread / 100;
      const bCost = bFee + amount * bSpread / 100;
      const aNet = amount - aCost;
      const bNet = amount - bCost;

      setText('res-wt-a-cost', fmt(aCost));
      setText('res-wt-a-net', fmt(aNet));
      setText('res-wt-b-cost', fmt(bCost));
      setText('res-wt-b-net', fmt(bNet));

      const aBox = document.getElementById('wt-a-box');
      const bBox = document.getElementById('wt-b-box');
      const verdict = document.getElementById('wt-verdict');
      const aCostEl = document.getElementById('res-wt-a-cost');
      const bCostEl = document.getElementById('res-wt-b-cost');

      if (aCost < bCost) {
        aBox.className = 'rounded-lg bg-green-50 border-2 border-green-300 p-4';
        aCostEl.className = 'text-2xl font-bold text-green-700';
        bBox.className = 'rounded-lg bg-gray-50 p-4';
        bCostEl.className = 'text-2xl font-bold text-gray-500';
        verdict.className = 'rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800 border border-green-200';
        verdict.textContent = `✅ ช่องทางที่ 1 ประหยัดกว่า ${fmt(bCost - aCost)} ต่อการโอน`;
      } else if (bCost < aCost) {
        bBox.className = 'rounded-lg bg-blue-50 border-2 border-blue-300 p-4';
        bCostEl.className = 'text-2xl font-bold text-blue-700';
        aBox.className = 'rounded-lg bg-gray-50 p-4';
        aCostEl.className = 'text-2xl font-bold text-gray-500';
        verdict.className = 'rounded-lg bg-blue-50 p-3 text-sm font-medium text-blue-800 border border-blue-200';
        verdict.textContent = `✅ ช่องทางที่ 2 ประหยัดกว่า ${fmt(aCost - bCost)} ต่อการโอน`;
      } else {
        verdict.className = 'rounded-lg bg-gray-50 p-3 text-sm font-medium text-gray-700 border border-gray-200';
        verdict.textContent = 'ต้นทุนเท่ากัน — เลือกได้ตามความสะดวก';
      }

      document.getElementById('wt-results').classList.remove('hidden');
      document.getElementById('wt-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
