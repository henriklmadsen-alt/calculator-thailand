---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Savings & Investment Calculators Thailand — Compound Interest, ROI, CAGR | Kamnuanlek"
  description="Free savings and investment calculators: compound interest, ROI, CAGR, NPV, IRR, and more. Plan your financial future with accurate Thai investment tools."
>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Savings & Investment Calculators</h1>
    <p class="text-xl text-gray-600 mb-12">
      Plan your financial future with powerful savings and investment tools. From simple interest to complex investment analysis — all free.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <a href="/คำนวณดอกเบี้ยทบต้น/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">📈</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Compound Interest Calculator</h3>
        <p class="text-gray-600 mb-3">See how compound interest grows your money exponentially over time. The 8th wonder of the world.</p>
        <span class="text-primary-600 font-medium">Calculate Growth →</span>
      </a>

      <a href="/คำนวณดอกเบี้ยเงินฝาก/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🏛️</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">Savings Interest Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate interest earned on savings accounts, fixed deposits, and government bonds.</p>
        <span class="text-primary-600 font-medium">Calculate Interest →</span>
      </a>

      <a href="/คำนวณ-roi/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">💹</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">ROI Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate Return on Investment (ROI) to compare different investment opportunities.</p>
        <span class="text-primary-600 font-medium">Calculate ROI →</span>
      </a>

      <a href="/คำนวณ-cagr/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">📊</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">CAGR Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate Compound Annual Growth Rate (CAGR) to measure investment performance.</p>
        <span class="text-primary-600 font-medium">Calculate CAGR →</span>
      </a>

      <a href="/คำนวณ-npv/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">🔮</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">NPV Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate Net Present Value of future cash flows to determine if an investment is worthwhile.</p>
        <span class="text-primary-600 font-medium">Calculate NPV →</span>
      </a>

      <a href="/คำนวณ-irr/" class="group p-6 bg-white border border-gray-200 rounded-lg hover:border-primary-500 hover:shadow-lg transition-all">
        <div class="text-3xl mb-3">📉</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary-600">IRR Calculator</h3>
        <p class="text-gray-600 mb-3">Calculate Internal Rate of Return (IRR) to evaluate investment profitability.</p>
        <span class="text-primary-600 font-medium">Calculate IRR →</span>
      </a>
    </div>

    <div class="p-6 bg-indigo-50 border border-indigo-200 rounded-lg mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Investment Concepts</h2>
      <div class="space-y-3">
        <div class="p-4 bg-white rounded-lg border border-indigo-100">
          <h3 class="font-semibold text-gray-900">Compound Interest</h3>
          <p class="text-gray-700 text-sm mt-1">Interest calculated on both principal AND previously earned interest. Even small amounts grow dramatically over long periods.</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-indigo-100">
          <h3 class="font-semibold text-gray-900">Rule of 72</h3>
          <p class="text-gray-700 text-sm mt-1">Divide 72 by your annual return rate to find how long to double your money. At 6% return: 72÷6 = 12 years.</p>
        </div>
        <div class="p-4 bg-white rounded-lg border border-indigo-100">
          <h3 class="font-semibold text-gray-900">Real Return</h3>
          <p class="text-gray-700 text-sm mt-1">Nominal return minus inflation rate = real return. Thailand's average inflation: ~2-3%/year.</p>
        </div>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Tools</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/เครื่องคำนวณธุรกิจ/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">📊 Business Analysis Tools</span>
          <p class="text-gray-600 text-sm mt-2">Break-even, ROE, ROA, WACC</p>
        </a>
        <a href="/ตัวช่วยคำนวณการเงิน/" class="p-4 bg-white border border-gray-200 rounded-lg hover:border-primary-500 transition-colors">
          <span class="font-semibold text-gray-900">💳 Full Financial Hub</span>
          <p class="text-gray-600 text-sm mt-2">All financial calculators in one place</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
