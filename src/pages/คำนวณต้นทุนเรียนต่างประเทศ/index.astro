---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณต้นทุนเรียนต่างประเทศ ปี 2569 | ค่าเรียน ที่พัก | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการเรียนต่างประเทศ: ค่าเรียน ค่าที่พัก อาหาร ตั๋วเครื่องบิน ประกัน วางแผนทั้งหมด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนเรียนต่างประเทศ/`;

const faqData = [
  {
    question: 'ต้นทุนเรียนต่างประเทศประมาณเท่าไหร่?',
    answer: 'ขึ้นอยู่กับประเทศ: มหาวิทยาลัย UK: 15,000–30,000 ปอนด์/ปี, USA: 25,000–50,000 ดอลลาร์/ปี, ประเทศเอเชีย: 10,000–20,000 ดอลลาร์/ปี รวมค่าเรียน ที่พัก อาหาร ค่าเดินทาง',
  },
  {
    question: 'ต้นทุนต่อเดือนจริงๆ คืออะไร?',
    answer: 'เฉลี่ย: ค่าเรียนประมาณ 40% ค่าที่พัก/อาหาร 40% การเดินทาง 10% อื่นๆ 10% ควรมีเงินสำรองพิเศษสำหรับค่าใช้จ่ายจำนวนมากที่ไม่คาดคิด',
  },
  {
    question: 'มีทุนหรือการช่วยเหลือการเงินหรือไม่?',
    answer: 'มี: ทุน Fulbright (USA), British Council (UK), ทุนเอเชีย, สินเชื่อศึกษา ขอมหาวิทยาลัยโดยตรง ควรเริ่มค้นหาตั้งแต่เร็ว (1–2 ปีก่อนเข้า)',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนเรียนต่างประเทศ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนเรียนต่างประเทศ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณต้นทุนเรียนต่างประเทศ ปี 2569</h1>

    <p class="text-gray-600 mb-6">
      คำนวณต้นทุนการเรียนต่างประเทศทั้งหมด: ค่าเรียน ที่พัก อาหาร ตั๋วเครื่องบิน ประกัน วางแผนการศึกษาต่างประเทศ
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="abroad-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="tuition" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าเรียน/ปี (บาท หรือสกุลอื่น)
            </label>
            <input
              type="text"
              id="tuition"
              inputmode="numeric"
              placeholder="เช่น 1,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="accommodation" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าที่พัก/เดือน (บาท)
            </label>
            <input
              type="text"
              id="accommodation"
              inputmode="numeric"
              placeholder="เช่น 15,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="food" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าอาหาร/เดือน (บาท)
            </label>
            <input
              type="text"
              id="food"
              inputmode="numeric"
              placeholder="เช่น 8,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="flights" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าตั๋วเครื่องบิน (ไป-กลับ) (บาท) — ไม่บังคับ
            </label>
            <input
              type="text"
              id="flights"
              inputmode="numeric"
              placeholder="เช่น 50,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="insurance" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าประกันสุขภาพ/ปี (บาท) — ไม่บังคับ
            </label>
            <input
              type="text"
              id="insurance"
              inputmode="numeric"
              placeholder="เช่น 30,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="other" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าใช้จ่ายอื่น/เดือน (บาท) — ไม่บังคับ
            </label>
            <input
              type="text"
              id="other"
              inputmode="numeric"
              placeholder="เช่น 5,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <div>
          <label for="duration" class="block text-sm font-medium text-gray-700 mb-1">
            ระยะเวลาศึกษา (ปี)
          </label>
          <input
            type="text"
            id="duration"
            inputmode="numeric"
            placeholder="เช่น 4"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          />
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-blue-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-700">
          คำนวณต้นทุนรวม
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="rounded-lg bg-blue-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ต้นทุนรวมทั้งหมด</div>
          <div id="res-total" class="text-3xl font-bold text-blue-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าเรียน</span>
            <span id="res-tuition" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าที่พัก</span>
            <span id="res-accom" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าอาหาร</span>
            <span id="res-food-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าตั๋วเครื่องบิน</span>
            <span id="res-flights-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าประกัน</span>
            <span id="res-insurance-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าใช้จ่ายอื่น</span>
            <span id="res-other-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">รวมทั้งหมด</span>
            <span id="res-calc-total" class="font-bold text-lg text-blue-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนเรียนต่างประเทศ/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return 0;
    return Number(String(value).replace(/,/g, '').trim()) || 0;
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#abroad-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const tuition = parseNumber(document.querySelector('#tuition')?.value || '');
    const accommodation = parseNumber(document.querySelector('#accommodation')?.value || '');
    const food = parseNumber(document.querySelector('#food')?.value || '');
    const flights = parseNumber(document.querySelector('#flights')?.value || '');
    const insurance = parseNumber(document.querySelector('#insurance')?.value || '');
    const other = parseNumber(document.querySelector('#other')?.value || '');
    const duration = parseNumber(document.querySelector('#duration')?.value || '');

    if (!(tuition > 0 && duration > 0 && (accommodation > 0 || food > 0))) {
      results?.classList.add('hidden');
      return;
    }

    const yearlyAccom = accommodation * 12;
    const yearlyFood = food * 12;
    const yearlyOther = other * 12;
    const totalYearly = tuition + yearlyAccom + yearlyFood + insurance + yearlyOther;
    const total = totalYearly * duration + flights;

    document.querySelector('#res-tuition').textContent = formatCurrency(tuition * duration);
    document.querySelector('#res-accom').textContent = formatCurrency(yearlyAccom * duration);
    document.querySelector('#res-food-cost').textContent = formatCurrency(yearlyFood * duration);
    document.querySelector('#res-flights-cost').textContent = formatCurrency(flights);
    document.querySelector('#res-insurance-cost').textContent = formatCurrency(insurance * duration);
    document.querySelector('#res-other-cost').textContent = formatCurrency(yearlyOther * duration);
    document.querySelector('#res-total').textContent = formatCurrency(total);
    document.querySelector('#res-calc-total').textContent = formatCurrency(total);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
