---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณสัดส่วนค่าเช่าต่อรายได้ 2569 | ค่าเช่าที่อยู่อาศัยเหมาะสมแค่ไหน | Kamnuanlek';
const pageDescription = 'ตรวจสอบว่าค่าเช่าที่อยู่อาศัยเหมาะสมกับรายได้หรือไม่ คำนวณสัดส่วนค่าเช่าต่อรายได้ และดูค่าเช่าแนะนำตามรายได้';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณสัดส่วนค่าเช่าต่อรายได้/`;

const faqData = [
  {
    question: 'ค่าเช่าควรเป็นกี่เปอร์เซ็นต์ของรายได้?',
    answer: 'หลักการทั่วไปคือค่าเช่าไม่ควรเกิน 30% ของรายได้สุทธิต่อเดือน หากค่าเช่าเกิน 40% ถือว่าเป็นภาระหนักมาก และควรพิจารณาหาที่พักที่ถูกกว่าหรือเพิ่มรายได้',
  },
  {
    question: 'กฎ 30% สำหรับค่าเช่ามีที่มาจากไหน?',
    answer: 'กฎ 30% มีต้นกำเนิดจากโครงการที่อยู่อาศัยของรัฐบาลสหรัฐอเมริกาในช่วง 1960s-70s ที่กำหนดให้ผู้อยู่อาศัยจ่ายไม่เกิน 25-30% ของรายได้เป็นค่าที่อยู่อาศัย ปัจจุบันยังคงใช้เป็นแนวทางทั่วไป',
  },
  {
    question: 'ถ้าค่าเช่าสูงกว่า 30% ควรทำอย่างไร?',
    answer: 'พิจารณาหาห้องหรืออพาร์ตเมนต์ที่ถูกกว่าในทำเลเดียวกัน หรือเลือกทำเลที่ไกลออกไปแต่ใกล้รถไฟฟ้า แชร์ห้องกับเพื่อน หรือตั้งเป้าเพิ่มรายได้เพื่อให้สัดส่วนค่าเช่าลดลง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณสัดส่วนค่าเช่าต่อรายได้',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "วิธีคำนวณสัดส่วนค่าเช่าต่อรายได้ (30% Rule) ปี 2569",
  "description": "ขั้นตอนการคำนวณเพื่อตรวจสอบว่าค่าเช่าที่จ่ายเหมาะสมหรือมากเกินไป โดยใช้หลักกฎ 30% (ค่าเช่าไม่ควรเกิน 30% ของรายได้สุทธิ)",
  "step": [
    {
      "@type": "HowToStep",
      "name": "บันทึกรายได้สุทธิรายเดือน",
      "text": "รายได้ = เงินเดือนหรือรายได้จ้างหลัก หลังหักภาษีและประกันสังคม ตัวอย่าง: เงินเดือน 50,000 บาท (เต็มจำนวน) หรือสุทธิ 45,000 บาท (หลังหัก SSO)"
    },
    {
      "@type": "HowToStep",
      "name": "คำนวณค่าเช่า 30% ของรายได้",
      "text": "ค่าเช่าเหมาะสม = รายได้สุทธิ × 30% ตัวอย่าง: 45,000 × 30% = 13,500 บาท/เดือน (ค่าเช่าที่เหมาะสม)"
    },
    {
      "@type": "HowToStep",
      "name": "ตรวจสอบสัดส่วนค่าเช่าปัจจุบัน",
      "text": "สัดส่วน = ค่าเช่าปัจจุบัน ÷ รายได้สุทธิ × 100% ถ้า < 30% = ดี, 30-35% = โอเค, > 35% = เกินไป ตัวอย่าง: ค่าเช่า 15,000 ÷ 45,000 × 100% = 33.3% (เกินเล็กน้อย)"
    }
  ]
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณสัดส่วนค่าเช่าต่อรายได้">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณสัดส่วนค่าเช่าต่อรายได้ 2569</h1>
    <p class="mb-6 text-gray-600">ตรวจสอบว่าค่าเช่าที่อยู่อาศัยเหมาะสมกับรายได้หรือไม่ และดูค่าเช่าแนะนำตามรายได้ของคุณ</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="rent-form" class="space-y-4">
        <div>
          <label for="net-income" class="mb-1 block text-sm font-medium text-gray-700">รายได้สุทธิต่อเดือน (บาท)</label>
          <input id="net-income" type="text" inputmode="numeric" placeholder="เช่น 25,000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="rent-amount" class="mb-1 block text-sm font-medium text-gray-700">ค่าเช่าต่อเดือน (บาท)</label>
          <input id="rent-amount" type="text" inputmode="numeric" placeholder="เช่น 6,000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 rounded-lg p-4 text-center" id="status-box">
          <div class="mb-1 text-sm text-gray-600">สัดส่วนค่าเช่าต่อรายได้</div>
          <div id="res-ratio" class="text-4xl font-bold sm:text-5xl">-</div>
          <div id="res-status" class="mt-2 text-base font-semibold">-</div>
        </div>
        <div class="space-y-0">
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">ค่าเช่าแนะนำ (ไม่เกิน 30%)</span>
            <span id="res-recommended" class="text-sm font-medium text-green-700">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">ค่าเช่าสูงสุดที่ยอมรับได้ (40%)</span>
            <span id="res-max" class="text-sm font-medium text-yellow-700">-</span>
          </div>
          <div class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-700">รายได้คงเหลือหลังหักค่าเช่า</span>
            <span id="res-remaining" class="text-sm font-medium text-gray-900">-</span>
          </div>
        </div>
      </div>
    </div>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณสัดส่วนค่าเช่าต่อรายได้/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n > 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('rent-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const income = parseNum((document.getElementById('net-income') as HTMLInputElement).value);
    const rent = parseNum((document.getElementById('rent-amount') as HTMLInputElement).value);
    if (!income) return;

    const ratio = (rent / income) * 100;
    const recommended = income * 0.30;
    const max = income * 0.40;
    const remaining = income - rent;

    document.getElementById('res-ratio')!.textContent = ratio.toFixed(1) + '%';
    document.getElementById('res-recommended')!.textContent = fmt(recommended) + '/เดือน';
    document.getElementById('res-max')!.textContent = fmt(max) + '/เดือน';
    document.getElementById('res-remaining')!.textContent = fmt(remaining) + '/เดือน';

    const box = document.getElementById('status-box')!;
    const status = document.getElementById('res-status')!;
    const ratioEl = document.getElementById('res-ratio')!;

    box.className = 'mb-6 rounded-lg p-4 text-center';
    if (ratio <= 30) {
      box.classList.add('bg-green-50');
      ratioEl.classList.add('text-green-700');
      status.textContent = '✅ เหมาะสม — ค่าเช่าอยู่ในเกณฑ์ที่แนะนำ';
      status.className = 'mt-2 text-base font-semibold text-green-700';
    } else if (ratio <= 40) {
      box.classList.add('bg-yellow-50');
      ratioEl.classList.add('text-yellow-700');
      status.textContent = '⚠️ สูงพอรับได้ — ควรพยายามลดลงให้ต่ำกว่า 30%';
      status.className = 'mt-2 text-base font-semibold text-yellow-700';
    } else {
      box.classList.add('bg-red-50');
      ratioEl.classList.add('text-red-700');
      status.textContent = '🚨 สูงมาก — ค่าเช่าเป็นภาระหนัก ควรพิจารณาปรับลด';
      status.className = 'mt-2 text-base font-semibold text-red-700';
    }

    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
