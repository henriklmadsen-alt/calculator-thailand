---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเบี้ยประกันชีวิตตลอดชีพ 2569 | Whole Life | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันชีวิตแบบตลอดชีพ (Whole Life) ตามอายุ เพศ วงเงินคุ้มครอง และระยะชำระเบี้ย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเบี้ยประกันชีวิตตลอดชีพ/`;

const faqData = [
  {
    question: 'ประกันชีวิตแบบตลอดชีพต่างจากแบบชั่วระยะเวลาอย่างไร?',
    answer: 'ประกันชีวิตแบบตลอดชีพ (Whole Life) คุ้มครองตลอดชีวิต เบี้ยสูงกว่าแต่มีมูลค่าเงินสด (Cash Value) สะสมเพิ่มขึ้นตามเวลา ส่วนแบบชั่วระยะเวลา (Term) เบี้ยถูกกว่า คุ้มครองเฉพาะช่วงเวลาที่กำหนด ไม่มีมูลค่าเงินสด',
  },
  {
    question: 'ระยะชำระเบี้ย 10 ปีกับ 20 ปีต่างกันอย่างไร?',
    answer: 'ระยะชำระเบี้ยสั้นกว่า เบี้ยรายปีสูงกว่า แต่จ่ายเบี้ยรวมน้อยกว่า การเลือกขึ้นอยู่กับกระแสเงินสดในปัจจุบัน หากรายได้สูงและต้องการจ่ายเบี้ยให้เสร็จเร็ว เลือกระยะสั้น หากต้องการลดภาระรายปี เลือกระยะยาว',
  },
  {
    question: 'ประกันชีวิตตลอดชีพลดหย่อนภาษีได้ไหม?',
    answer: 'เบี้ยประกันชีวิตตลอดชีพสามารถนำไปลดหย่อนภาษีเงินได้บุคคลธรรมดาได้สูงสุด 100,000 บาทต่อปี โดยกรมธรรม์ต้องมีระยะเวลาคุ้มครอง 10 ปีขึ้นไป ตามหลักเกณฑ์กรมสรรพากร',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเบี้ยประกันชีวิตตลอดชีพ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเบี้ยประกันชีวิตตลอดชีพ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณเบี้ยประกันชีวิตตลอดชีพ ปี 2569</p>
      <p class="mt-1 text-sm text-slate-700">ตัวเลขเป็นการประมาณการ เพื่อใช้วางแผนเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเบี้ยประกันชีวิตแบบตลอดชีพ (Whole Life) 2569
    </h1>

    <p class="text-gray-600 mb-6">
      ประมาณเบี้ยประกันชีวิตแบบตลอดชีพตามอายุ เพศ ทุนประกัน และระยะชำระเบี้ย พร้อมสิทธิลดหย่อนภาษี
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="wl-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="wl-age" class="block text-sm font-medium text-gray-700 mb-1">อายุ (ปี)</label>
            <input type="text" id="wl-age" inputmode="numeric" placeholder="เช่น 30"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="wl-age-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="wl-gender" class="block text-sm font-medium text-gray-700 mb-1">เพศ</label>
            <select id="wl-gender" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="male">ชาย</option>
              <option value="female">หญิง</option>
            </select>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="wl-sum" class="block text-sm font-medium text-gray-700 mb-1">ทุนประกัน (บาท)</label>
            <input type="text" id="wl-sum" inputmode="numeric" placeholder="เช่น 1,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="wl-sum-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="wl-period" class="block text-sm font-medium text-gray-700 mb-1">ระยะชำระเบี้ย</label>
            <select id="wl-period" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              <option value="10">10 ปี</option>
              <option value="15">15 ปี</option>
              <option value="20" selected>20 ปี</option>
              <option value="99">ตลอดชีพ</option>
            </select>
          </div>
        </div>

        <button type="submit" id="wl-submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ (ประมาณการ)</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เบี้ยรายปี (ประมาณ)</div>
            <div id="res-annual" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เบี้ยรายเดือน (ประมาณ)</div>
            <div id="res-monthly" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">สิทธิลดหย่อนภาษีสูงสุด</div>
            <div id="res-tax" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-2">* เบี้ยจริงอาจแตกต่างตามบริษัทประกัน โปรดติดต่อตัวแทนเพื่อใบเสนอราคาที่แน่นอน</p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ประกันชีวิตแบบตลอดชีพคืออะไร?</h2>
      <p>ประกันชีวิตแบบตลอดชีพให้ความคุ้มครองตลอดชีวิตผู้เอาประกัน มีมูลค่าเงินสดสะสม เหมาะสำหรับการส่งต่อมรดกและวางแผนทางการเงินระยะยาว</p>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณเบี้ยประกันชีวิตตลอดชีพ/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงต้องสอบถามบริษัทประกันชีวิตโดยตรง
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n) + ' บาท'; }

    const form = document.getElementById('wl-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    function setErr(id: string, msg: string) { const el = document.getElementById(id); if (el) { el.textContent = msg; el.classList.remove('hidden'); } }
    function clearErr(id: string) { const el = document.getElementById(id); if (el) { el.textContent = ''; el.classList.add('hidden'); } }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      ['wl-age-error', 'wl-sum-error'].forEach(clearErr);

      const age = parseNum((document.getElementById('wl-age') as HTMLInputElement).value);
      const gender = (document.getElementById('wl-gender') as HTMLSelectElement).value;
      const sumInsured = parseNum((document.getElementById('wl-sum') as HTMLInputElement).value);
      const period = parseInt((document.getElementById('wl-period') as HTMLSelectElement).value);

      let hasError = false;
      if (age < 1 || age > 70) { setErr('wl-age-error', 'กรุณากรอกอายุระหว่าง 1-70 ปี'); hasError = true; }
      if (sumInsured <= 0) { setErr('wl-sum-error', 'กรุณากรอกทุนประกัน'); hasError = true; }
      if (hasError) return;

      trackCalculatorStart('whole-life-premium');

      // Approximate rate per 1000 sum insured per year
      const baseRatePer1000 = gender === 'male'
        ? 8.5 + age * 0.15
        : 7.2 + age * 0.12;
      const periodMultiplier = period === 10 ? 2.5 : period === 15 ? 1.8 : period === 20 ? 1.4 : 1.0;
      const annualPremium = (sumInsured / 1000) * baseRatePer1000 * periodMultiplier;
      const monthlyPremium = annualPremium / 12;
      const taxBenefit = Math.min(annualPremium, 100000);

      (document.getElementById('res-annual') as HTMLElement).textContent = fmt(annualPremium);
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthlyPremium);
      (document.getElementById('res-tax') as HTMLElement).textContent = fmt(taxBenefit);

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('whole-life-premium');
      trackCalculatorUsed('whole-life-premium');
    });
  </script>
</BaseLayout>
