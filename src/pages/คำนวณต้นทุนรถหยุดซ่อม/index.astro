---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณต้นทุนรถหยุดซ่อม ปี 2569 | ต้นทุนวันหยุดทำงาน | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนทางธุรกิจจากรถหยุดซ่อม รวมรายได้ที่เสียไป ค่าจ้างคนขับ ค่าเช่ารถทดแทน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนรถหยุดซ่อม/`;

const faqData = [
  {
    question: 'ต้นทุนรถหยุดซ่อม (Downtime Cost) มีอะไรบ้าง?',
    answer: 'ต้นทุนรถหยุดซ่อมประกอบด้วย รายได้ที่เสียไปจากการไม่สามารถใช้งานรถเพื่อสร้างรายได้ ค่าจ้างพนักงานขับรถที่ยังต้องจ่ายแม้รถจะซ่อม ค่าเช่ารถทดแทน และค่าซ่อมแซมตัวรถเอง',
  },
  {
    question: 'ธุรกิจขนส่งควรวางแผนรับมือกับ Downtime อย่างไร?',
    answer: 'ธุรกิจขนส่งควรมีรถสำรอง (Spare Vehicle) สำหรับทดแทนระหว่างซ่อม ทำสัญญากับอู่ซ่อมที่มีบริการด่วน วางแผนการบำรุงรักษาเชิงป้องกัน (Preventive Maintenance) และทำประกันรถพาณิชย์ที่ครอบคลุมค่าใช้จ่ายระหว่างหยุดซ่อม',
  },
  {
    question: 'ค่าเช่ารถพาณิชย์ทดแทนในไทยอยู่ที่เท่าไร?',
    answer: 'ค่าเช่ารถพาณิชย์ทดแทนในไทยขึ้นอยู่กับประเภทรถ รถกระบะทั่วไป 600–1,200 บาท/วัน รถตู้ 1,200–2,000 บาท/วัน รถบรรทุกขนาดเล็ก 2,000–5,000 บาท/วัน และรถบรรทุกขนาดใหญ่ 5,000–15,000 บาท/วัน โดยราคาขึ้นอยู่กับภูมิภาคและผู้ให้บริการ',
  },
  {
    question: 'การทำ Preventive Maintenance ช่วยลด Downtime ได้อย่างไร?',
    answer: 'การบำรุงรักษาเชิงป้องกันตามระยะเวลาที่กำหนด เช่น เปลี่ยนถ่ายน้ำมันเครื่อง ตรวจสอบยาง เบรก และระบบไฟฟ้า ช่วยลดโอกาสเกิดความเสียหายฉับพลันได้ 30–60% งานวิจัยระบุว่า 1 บาทที่ลงทุนใน Preventive Maintenance ประหยัดค่าซ่อมฉุกเฉินได้ 3–5 บาท',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนรถหยุดซ่อม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนรถหยุดซ่อม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณต้นทุนรถหยุดซ่อม
    </h1>
    <p class="text-gray-600 mb-6">
      วิเคราะห์ต้นทุนทางธุรกิจทั้งหมดเมื่อรถต้องหยุดซ่อม รวมรายได้ที่เสียไป ค่าจ้างคนขับ
      ค่าเช่ารถทดแทน และค่าซ่อม เพื่อช่วยตัดสินใจด้านบริหารยานพาหนะ
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="calculator-form" class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="revenue-per-day" class="block text-sm font-medium text-gray-700 mb-1">
              รายได้จากรถต่อวัน (บาท)
            </label>
            <input
              type="text"
              id="revenue-per-day"
              inputmode="decimal"
              placeholder="เช่น 3000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="driver-salary" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าจ้างคนขับต่อวัน (บาท)
            </label>
            <input
              type="text"
              id="driver-salary"
              inputmode="decimal"
              placeholder="เช่น 600"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="rental-cost-day" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าเช่ารถทดแทนต่อวัน (บาท)
            </label>
            <input
              type="text"
              id="rental-cost-day"
              inputmode="decimal"
              placeholder="เช่น 1200"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="downtime-days" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนวันหยุดซ่อม (วัน)
            </label>
            <input
              type="text"
              id="downtime-days"
              inputmode="decimal"
              placeholder="เช่น 7"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="repair-cost" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าซ่อมรถ (บาท)
            </label>
            <input
              type="text"
              id="repair-cost"
              inputmode="decimal"
              placeholder="เช่น 25000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>
        <button
          type="button"
          id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ
        </button>
      </form>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-blue-700 font-medium mb-1">รายได้ที่เสียไป</div>
            <div id="res-lost-revenue" class="text-xl font-bold text-blue-800">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-blue-700 font-medium mb-1">ค่าจ้างคนขับระหว่างหยุดซ่อม</div>
            <div id="res-driver-cost" class="text-xl font-bold text-blue-800">-</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4">
            <div class="text-sm text-orange-700 font-medium mb-1">ค่าเช่ารถทดแทน</div>
            <div id="res-rental-cost" class="text-xl font-bold text-orange-800">-</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4">
            <div class="text-sm text-orange-700 font-medium mb-1">ค่าซ่อมรถ</div>
            <div id="res-repair-cost" class="text-xl font-bold text-orange-800">-</div>
          </div>
        </div>
        <div class="bg-red-50 rounded-lg p-4 border border-red-200">
          <div class="text-sm text-red-700 font-medium mb-1">ต้นทุนรวมจากรถหยุดซ่อม</div>
          <div id="res-total-cost" class="text-3xl font-bold text-red-800">-</div>
          <div id="res-cost-per-hour" class="text-sm text-red-600 mt-1">-</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ต้นทุนที่มองไม่เห็นของรถหยุดซ่อม</h2>
      <p>
        เมื่อรถพาณิชย์หรือรถใช้งานในธุรกิจต้องเข้าอู่ซ่อม ต้นทุนที่แท้จริงมักสูงกว่าค่าซ่อมรถที่เห็นบนใบเสร็จ
        ธุรกิจขนส่ง บริการส่งสินค้า และงานที่ต้องพึ่งพาพาหนะล้วนได้รับผลกระทบจากรายได้ที่หายไปในทุกวันที่รถยังอยู่ในอู่
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณต้นทุนรวม</h3>
      <div class="bg-gray-50 rounded-lg p-4 my-4 space-y-2">
        <p class="font-medium">รายได้ที่เสีย = รายได้ต่อวัน × จำนวนวันหยุดซ่อม</p>
        <p class="font-medium">ค่าจ้างคนขับ = ค่าจ้างต่อวัน × จำนวนวัน</p>
        <p class="font-medium">ค่าเช่ารถทดแทน = ค่าเช่าต่อวัน × จำนวนวัน</p>
        <p class="font-semibold text-primary-700">ต้นทุนรวม = รายได้ที่เสีย + ค่าจ้าง + ค่าเช่า + ค่าซ่อม</p>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">กลยุทธ์ลดต้นทุน Downtime</h3>
      <p>
        ธุรกิจที่ใช้รถยนต์อย่างหนักควรวางแผนบำรุงรักษาเชิงป้องกัน (Preventive Maintenance) อย่างสม่ำเสมอ
        ประกันรถพาณิชย์ที่ดีควรรวมความคุ้มครองสำหรับรถทดแทน (Substitute Vehicle) หรือค่าเช่าระหว่างซ่อม
        นอกจากนี้ควรมีสัญญากับอู่ซ่อมที่รับประกันระยะเวลาซ่อมเพื่อลดวันหยุดให้สั้นที่สุด
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณต้นทุนรถหยุดซ่อม/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนรถหยุดซ่อม/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเพื่อช่วยวางแผนธุรกิจ
      ต้นทุนจริงอาจแตกต่างตามประเภทธุรกิจ ประเภทยานพาหนะ และสภาพการณ์จริง
      ควรปรึกษาผู้เชี่ยวชาญด้านการขนส่งและประกันภัยเพื่อวางแผนที่เหมาะสม
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const revenuePerDay = parseNum((document.getElementById('revenue-per-day') as HTMLInputElement).value);
      const driverSalary = parseNum((document.getElementById('driver-salary') as HTMLInputElement).value);
      const rentalCostDay = parseNum((document.getElementById('rental-cost-day') as HTMLInputElement).value);
      const downtimeDays = parseNum((document.getElementById('downtime-days') as HTMLInputElement).value);
      const repairCost = parseNum((document.getElementById('repair-cost') as HTMLInputElement).value);

      if (downtimeDays <= 0) {
        (document.getElementById('downtime-days') as HTMLInputElement).focus();
        return;
      }

      const lostRevenue = revenuePerDay * downtimeDays;
      const driverCost = driverSalary * downtimeDays;
      const rentalCost = rentalCostDay * downtimeDays;
      const totalCost = lostRevenue + driverCost + rentalCost + repairCost;
      const totalHours = downtimeDays * 24;
      const costPerHour = totalHours > 0 ? totalCost / totalHours : 0;

      (document.getElementById('res-lost-revenue') as HTMLElement).textContent = `฿${fmt(lostRevenue)}`;
      (document.getElementById('res-driver-cost') as HTMLElement).textContent = `฿${fmt(driverCost)}`;
      (document.getElementById('res-rental-cost') as HTMLElement).textContent = `฿${fmt(rentalCost)}`;
      (document.getElementById('res-repair-cost') as HTMLElement).textContent = `฿${fmt(repairCost)}`;
      (document.getElementById('res-total-cost') as HTMLElement).textContent = `฿${fmt(totalCost)}`;
      (document.getElementById('res-cost-per-hour') as HTMLElement).textContent =
        `เฉลี่ย ฿${fmt(costPerHour)} ต่อชั่วโมง (${downtimeDays} วัน × 24 ชั่วโมง)`;

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
    });

    document.querySelectorAll('#calculator-form input').forEach(input => {
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
