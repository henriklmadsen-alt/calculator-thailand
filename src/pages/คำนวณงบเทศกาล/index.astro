---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณงบเทศกาล 2569 | วางแผนงบสงกรานต์ ปีใหม่ ตรุษจีน | เครื่องคำนวณไทย';
const pageDescription = 'วางแผนงบช่วงเทศกาล สงกรานต์ ปีใหม่ ตรุษจีน วาเลนไทน์ คำนวณค่าของขวัญ ของกินดื่ม เดินทาง กิจกรรม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบเทศกาล/`;

const faqData = [
  {
    question: 'ควรตั้งงบเทศกาลเท่าไร?',
    answer: 'แนะนำให้ตั้งงบเทศกาลไม่เกิน 5-10% ของรายได้ต่อเดือน หรือเก็บออมเดือนละเล็กน้อยตลอดทั้งปีเพื่อรองรับค่าใช้จ่ายช่วงเทศกาลที่มาถี่ ไม่ควรใช้เงินก้อนหรือรูดบัตรเครดิตสำหรับค่าใช้จ่ายเทศกาล',
  },
  {
    question: 'เทศกาลสงกรานต์ใช้เงินเท่าไร?',
    answer: 'งบเทศกาลสงกรานต์โดยทั่วไปอยู่ที่ 2,000-10,000 บาทต่อคน ขึ้นอยู่กับว่าเดินทางกลับบ้านต่างจังหวัด ซื้อของขวัญ หรือไปเที่ยวเล่นน้ำ ค่าเดินทางมักเป็นค่าใช้จ่ายหลัก',
  },
  {
    question: 'วิธีประหยัดค่าใช้จ่ายช่วงเทศกาลทำอย่างไร?',
    answer: 'จองตั๋วเดินทางล่วงหน้า 1-3 เดือน กำหนดงบของขวัญล่วงหน้าและแจ้งให้ผู้รับทราบ ทำอาหารเองแทนกินนอกบ้าน และรวมกลุ่มซื้อของขวัญเป็น group gift เพื่อแบ่งค่าใช้จ่าย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบเทศกาล',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบเทศกาล">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณงบเทศกาล 2569</h1>
    <p class="mb-6 text-gray-600">วางแผนงบช่วงเทศกาล สงกรานต์ ปีใหม่ ตรุษจีน วาเลนไทน์ เพื่อควบคุมค่าใช้จ่าย</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="festival-form" class="space-y-4">
        <div>
          <label for="festival" class="mb-1 block text-sm font-medium text-gray-700">เทศกาล</label>
          <select id="festival" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-auto">
            <option value="songkran">สงกรานต์</option>
            <option value="newyear">ปีใหม่ไทย/สากล</option>
            <option value="chinese">ตรุษจีน</option>
            <option value="valentine">วาเลนไทน์</option>
            <option value="other">อื่นๆ</option>
          </select>
        </div>
        <div>
          <label for="people" class="mb-1 block text-sm font-medium text-gray-700">จำนวนคนในกลุ่ม</label>
          <input id="people" type="text" inputmode="numeric" placeholder="เช่น 5"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-32" />
        </div>
        <div>
          <label for="gift-per-person" class="mb-1 block text-sm font-medium text-gray-700">งบของขวัญต่อคน (บาท)</label>
          <input id="gift-per-person" type="text" inputmode="numeric" placeholder="เช่น 300"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">งบเทศกาลโดยประมาณ</h2>
        <div class="mb-6 rounded-lg bg-primary-50 p-4 text-center">
          <div class="mb-1 text-sm text-gray-600">งบรวมทั้งหมด</div>
          <div id="res-total" class="text-4xl font-bold text-primary-700 sm:text-5xl">-</div>
          <div class="mt-1 text-sm text-gray-500">บาท</div>
        </div>
        <div class="space-y-0">
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🎁 ของขวัญ</span>
            <span id="res-gift" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🍱 ของกินดื่ม</span>
            <span id="res-food" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🚌 ค่าเดินทาง</span>
            <span id="res-travel" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-700">🎉 ค่ากิจกรรม</span>
            <span id="res-activity" class="text-sm font-medium text-gray-900">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณงบเทศกาล/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  // [food_per_person, travel_per_person, activity_per_person]
  const FESTIVAL_BASE: Record<string, number[]> = {
    songkran: [400, 1500, 600],
    newyear:  [600, 1000, 800],
    chinese:  [500, 500, 200],
    valentine:[300, 400, 500],
    other:    [400, 800, 400],
  };

  document.getElementById('festival-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const festival = (document.getElementById('festival') as HTMLSelectElement).value;
    const people = parseNum((document.getElementById('people') as HTMLInputElement).value) || 1;
    const giftPerPerson = parseNum((document.getElementById('gift-per-person') as HTMLInputElement).value);

    const [foodPP, travelPP, activityPP] = FESTIVAL_BASE[festival];
    const gift = giftPerPerson * people;
    const food = foodPP * people;
    const travel = travelPP * people;
    const activity = activityPP * people;
    const total = gift + food + travel + activity;

    document.getElementById('res-total')!.textContent = fmt(total);
    document.getElementById('res-gift')!.textContent = fmt(gift);
    document.getElementById('res-food')!.textContent = fmt(food);
    document.getElementById('res-travel')!.textContent = fmt(travel);
    document.getElementById('res-activity')!.textContent = fmt(activity);
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
