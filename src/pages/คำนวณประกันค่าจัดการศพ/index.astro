---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณประกันค่าจัดการศพ (Funeral Expense) 2569 | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณเบี้ยประกันค่าจัดการศพ 2569 และประมาณค่าใช้จ่ายงานศพในไทย เตรียมทุนสำรองค่าจัดการศพให้ครอบครัวไม่ต้องแบกภาระ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประกันค่าจัดการศพ/`;

const faqData = [
  { question: 'ค่าจัดการศพในไทยเฉลี่ยเท่าไร?', answer: 'ค่าจัดการศพในไทยปัจจุบันอยู่ที่ 50,000-300,000 บาท ขึ้นกับระดับงาน: งานประหยัด 50,000-80,000 บาท, งานปานกลาง 100,000-150,000 บาท, งานใหญ่ 200,000-400,000 บาทขึ้นไป ไม่รวมค่าที่ดินฌาปนสถาน' },
  { question: 'ประกันค่าจัดการศพแตกต่างจากประกันชีวิตอย่างไร?', answer: 'ประกันค่าจัดการศพเน้นคุ้มครองเฉพาะค่าใช้จ่ายงานศพ วงเงินน้อยกว่า เบี้ยถูกกว่า เหมาะสำหรับผู้ที่ต้องการให้ครอบครัวมีเงินจัดงานศพโดยไม่ต้องกู้ยืม ส่วนประกันชีวิตครอบคลุมกว้างกว่าทั้งรายได้และหนี้สิน' },
  { question: 'ควรมีทุนประกันค่าจัดการศพเท่าไร?', answer: 'แนะนำ 100,000-200,000 บาท ซึ่งครอบคลุมค่าจัดงานศพในระดับปานกลาง รวมค่าโลง ค่าสวดอภิธรรม ค่าฌาปนกิจ ดอกไม้ อาหาร และของชำร่วย' },
  { question: 'ผู้สูงอายุซื้อประกันค่าจัดการศพได้ไหม?', answer: 'ได้ บางบริษัทออกแบบผลิตภัณฑ์เฉพาะสำหรับผู้สูงอายุ อายุ 60-80 ปี เบี้ยอาจสูงขึ้นตามอายุ แต่บางแผนไม่ต้องตรวจสุขภาพ เหมาะสำหรับผู้สูงอายุที่ต้องการวางแผนล่วงหน้า' },
];

const jsonLdWebApp = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'เครื่องคำนวณประกันค่าจัดการศพ 2569', description: pageDescription, url: canonical, applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' }, inLanguage: 'th' };
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประกันค่าจัดการศพ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">วางแผนค่าจัดการศพล่วงหน้า</p>
      <p class="mt-1 text-sm text-slate-700">ให้ครอบครัวไม่ต้องแบกภาระค่าใช้จ่ายงานศพ</p>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณประกันค่าจัดการศพ 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">ประมาณค่าจัดการศพที่ต้องการและเบี้ยประกันเพื่อเตรียมทุนไว้ล่วงหน้า</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ประมาณค่าจัดการศพ</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>
        <div>
          <label for="funeral-level" class="block text-sm font-medium text-gray-700 mb-1">ระดับงานศพที่ต้องการ</label>
          <select id="funeral-level" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="70000">ประหยัด — 50,000-80,000 บาท (ค่าเฉลี่ย 70,000)</option>
            <option value="120000" selected>ปานกลาง — 100,000-150,000 บาท (ค่าเฉลี่ย 120,000)</option>
            <option value="220000">ใหญ่ — 180,000-250,000 บาท (ค่าเฉลี่ย 220,000)</option>
            <option value="400000">พิเศษ — 300,000-500,000 บาท (ค่าเฉลี่ย 400,000)</option>
          </select>
        </div>
        <div>
          <label for="age" class="block text-sm font-medium text-gray-700 mb-1">อายุปัจจุบัน (ปี)</label>
          <input type="text" id="age" inputmode="numeric" placeholder="เช่น 50" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="coverage-type" class="block text-sm font-medium text-gray-700 mb-1">แผนความคุ้มครอง</label>
          <select id="coverage-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="funeral">ค่าจัดการศพอย่างเดียว</option>
            <option value="funeral+income" selected>ค่าจัดการศพ + เงินก้อนให้ครอบครัว (×2)</option>
          </select>
        </div>
        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">คำนวณ</button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="grid gap-4 sm:grid-cols-2 mb-4">
        <div class="bg-primary-50 border border-primary-200 rounded-lg p-4 text-center"><p class="text-xs text-primary-700 mb-1">ทุนประกันที่แนะนำ</p><p class="text-2xl font-bold text-primary-700" id="coverage">-</p></div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center"><p class="text-xs text-green-700 mb-1">เบี้ยประมาณการ/ปี</p><p class="text-2xl font-bold text-green-700" id="premium">-</p></div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">องค์ประกอบค่าจัดการศพในไทย</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ค่าโลงศพ: 5,000-50,000+ บาท</li>
        <li>ค่าสถานที่สวดอภิธรรม: 5,000-30,000 บาท/คืน</li>
        <li>ค่าฌาปนกิจ: 3,000-10,000 บาท</li>
        <li>ค่าอาหารและเครื่องดื่ม: 20,000-100,000 บาท</li>
        <li>ค่าดอกไม้และพิธีกรรม: 10,000-50,000 บาท</li>
        <li>ค่าของชำร่วย: 10,000-30,000 บาท</li>
      </ul>
    </section>
    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (<details class="bg-white rounded-lg shadow-sm border border-gray-200"><summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary><div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div></details>))}
      </div>
    </section>
    <RelatedCalculators currentHref="/คำนวณประกันค่าจัดการศพ/" />
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800"><strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ ค่าใช้จ่ายจริงขึ้นกับพื้นที่และผู้ให้บริการ</div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const funeralCost = parseFloat((document.getElementById('funeral-level') as HTMLSelectElement).value);
      const age = parseNum((document.getElementById('age') as HTMLInputElement).value);
      const coverageType = (document.getElementById('coverage-type') as HTMLSelectElement).value;
      const err = document.getElementById('form-error')!;
      if (age < 18 || age > 80) { err.textContent = 'กรุณากรอกอายุ 18-80 ปี'; err.classList.remove('hidden'); return; }
      err.classList.add('hidden');

      const coverageAmount = coverageType === 'funeral+income' ? funeralCost * 2 : funeralCost;
      const ageRate = age < 40 ? 0.015 : age < 50 ? 0.025 : age < 60 ? 0.04 : 0.065;
      const premium = coverageAmount * ageRate;

      const rows = [
        ['ค่าจัดการศพประมาณ', '', `${fmt(funeralCost)} บาท`],
        ['แผนความคุ้มครอง', coverageType === 'funeral+income' ? 'ค่าจัดการ + เงินก้อน × 2' : 'ค่าจัดการศพอย่างเดียว', ''],
        ['ทุนประกันที่แนะนำ', '', `${fmt(coverageAmount)} บาท`],
        ['อัตราเบี้ยตามอายุ', `อายุ ${age} ปี, ${(ageRate*100).toFixed(1)}%/ปี`, ''],
        ['เบี้ยประมาณการ/ปี', '', `<strong>${fmt(premium)} บาท</strong>`],
        ['เบี้ยต่อเดือน', '', `≈ ${fmt(premium/12)} บาท`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td><td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td></tr>`).join('');

      (document.getElementById('coverage') as HTMLElement).textContent = fmt(coverageAmount) + ' บาท';
      (document.getElementById('premium') as HTMLElement).textContent = fmt(premium) + ' บาท';
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
