---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณสินเชื่อเกษตร ธ.ก.ส. | Kamnuanlek';
const pageDescription = 'คำนวณสินเชื่อเกษตรกรจาก ธ.ก.ส. ดอกเบี้ย ค่างวด ภาระหนี้ สินเชื่อ ธกส. ฤดูกาล';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0497-กู้ธกส/`;
const faqData = [
  { question: 'ธ.ก.ส. ให้สินเชื่อเกษตรกรอัตราดอกเบี้ยเท่าไหร่?', answer: 'ธ.ก.ส. ให้สินเชื่อเกษตรกร MRR+0% ถึง MRR+3% ปัจจุบัน MRR ประมาณ 6.5-7% ต่อปี สินเชื่อพิเศษโครงการรัฐ เช่น ชะลอการขายข้าว อัตราดอกเบี้ยอาจต่ำกว่า 3% ต่อปี' },
  { question: 'วงเงินสินเชื่อ ธ.ก.ส. สูงสุดเท่าไหร่?', answer: 'สินเชื่อเพื่อการเกษตร วงเงินขึ้นกับแผนการผลิตและหลักประกัน ที่ดิน สปก. หรือโฉนดค้ำประกันได้ วงเงินทั่วไป 50,000-500,000 บาท/ราย โครงการพิเศษอาจสูงกว่า' },
  { question: 'เกษตรกรพักหนี้ ธ.ก.ส. ได้ไหม?', answer: 'มีโครงการพักชำระหนี้เกษตรกรตามนโยบายรัฐบาล เช่น พักชำระต้นเงิน 3 ปี แต่ดอกเบี้ยยังคิดปกติ ควรติดตามประกาศจาก ธ.ก.ส. สาขาใกล้บ้าน' },
  { question: 'เกษตรกรรุ่นใหม่กู้ ธ.ก.ส. ได้ไหม?', answer: 'Young Smart Farmer วงเงินสูงสุด 500,000 บาท อัตราดอกเบี้ยพิเศษ ต้องผ่านการอบรมและมีแผนธุรกิจการเกษตร อายุ 20-45 ปี มีประสบการณ์การเกษตร' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณสินเชื่อเกษตร ธ.ก.ส.">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณสินเชื่อเกษตร ธ.ก.ส.</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่างวดและดอกเบี้ยสินเชื่อ ธ.ก.ส.</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="baac_loan" class="block text-sm font-medium text-gray-700 mb-1">วงเงินกู้ (บาท)</label><input type="text" id="baac_loan" inputmode="decimal" placeholder="เช่น 200000" value="200000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="baac_rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราดอกเบี้ยต่อปี (%)</label><input type="text" id="baac_rate" inputmode="decimal" placeholder="เช่น 7" value="7" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="baac_years" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลากู้ (ปี)</label><input type="number" id="baac_years" min="1" placeholder="เช่น 5" value="5" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ค่างวดต่อเดือน</p><p id="baac_monthly" class="font-bold">-</p></div>
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ดอกเบี้ยรวมทั้งหมด</p><p id="baac_interest" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3 col-span-2"><p class="text-sm text-gray-600">ภาระหนี้รวม</p><p id="baac_total" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const loan = parseFloat((document.getElementById('baac_loan') as HTMLInputElement).value) || 0;
      const annualRate = parseFloat((document.getElementById('baac_rate') as HTMLInputElement).value) || 0;
      const years = parseFloat((document.getElementById('baac_years') as HTMLInputElement).value) || 1;
      const r = annualRate / 100 / 12;
      const n = years * 12;
      const monthly = r > 0 ? loan * r * Math.pow(1+r,n) / (Math.pow(1+r,n)-1) : loan/n;
      const totalPay = monthly * n;
      const totalInterest = totalPay - loan;
      (document.getElementById('baac_monthly') as HTMLElement).textContent = Math.round(monthly).toLocaleString('th-TH') + ' บาท/เดือน';
      (document.getElementById('baac_interest') as HTMLElement).textContent = Math.round(totalInterest).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('baac_total') as HTMLElement).textContent = Math.round(totalPay).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('baac-agricultural-loan');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
