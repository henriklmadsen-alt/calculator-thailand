---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'วิธีคำนวณค่าธรรมเนียมโอนบ้าน — คำแนะนำฉบับสมบูรณ์';
const pageDescription = 'เรียนรู้วิธีคำนวณค่าธรรมเนียมโอน ค่าจดจำนอง ภาษี และค่าใช้จ่ายอื่นๆ เมื่อซื้อขายทรัพย์สิน';
const canonical = `${siteUrl}/how-to/property-transfer-fee/`;
const authorDate = '2026-05-01';

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDescription,
  image: {
    '@type': 'ImageObject',
    url: `${siteUrl}/og-image.jpg`,
    width: 1200,
    height: 630,
  },
  datePublished: authorDate,
  author: {
    '@type': 'Organization',
    name: 'Kamnuanlek',
  },
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: pageTitle,
  description: pageDescription,
  step: [
    {
      '@type': 'HowToStep',
      name: 'ทราบราคาซื้อขายและราคาประเมิน',
      text: 'ค่าธรรมเนียมคิดจากราคาที่สูงกว่า ระหว่างราคาซื้อขายกับราคาประเมินของกรมที่ดิน',
    },
    {
      '@type': 'HowToStep',
      name: 'คำนวณค่าธรรมเนียมโอน',
      text: 'ราคา × 2% (ปกติ) หรือ 1% (หากเข้าเงื่อนไขอื่นๆ)',
    },
    {
      '@type': 'HowToStep',
      name: 'คำนวณค่าจดจำนอง (ถ้ามี)',
      text: 'วงเงินกู้ × 1% (ปกติ) หรือ 0.01% (ถ้าเข้าโครงการพิเศษ)',
    },
    {
      '@type': 'HowToStep',
      name: 'คำนวณภาษีธุรกิจเฉพาะหรืออากรแสตมป์',
      text: 'ถือครองน้อยกว่า 5 ปี: ภาษีธุรกิจเฉพาะ 3.3% | ถือครอง 5 ปีขึ้นไป: อากรแสตมป์ 0.5%',
    },
    {
      '@type': 'HowToStep',
      name: 'รวมค่าใช้จ่ายทั้งหมด',
      text: 'ค่าธรรมเนียมโอน + ค่าจดจำนอง + ภาษี + ค่าใช้จ่ายอื่น = ค่าใช้จ่ายรวม',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName={pageTitle}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article class="prose prose-gray max-w-none">

    <h1>วิธีคำนวณค่าธรรมเนียมโอนบ้าน — คำแนะนำฉบับสมบูรณ์</h1>

    <p>การซื้อขายทรัพย์สินมีค่าใช้จ่ายมากมายนอกเหนือจากราคาซื้อขาย บทความนี้จะอธิบายค่าธรรมเนียมโอน ค่าจดจำนอง ภาษี และค่าใช้จ่ายอื่นๆ ที่ต้องจ่ายเมื่อซื้อขายบ้าน</p>

    <h2>ค่าใช้จ่ายหลักในการโอนทรัพย์สิน</h2>

    <ul>
      <li><strong>ค่าธรรมเนียมโอน:</strong> 2% ของราคาสูงสุด (ปกติ)</li>
      <li><strong>ค่าจดจำนอง:</strong> 1% ของวงเงินกู้ (ปกติ)</li>
      <li><strong>ภาษีธุรกิจเฉพาะ:</strong> 3.3% ของราคา (สำหรับบ้านมือสองถือครองน้อยกว่า 5 ปี)</li>
      <li><strong>อากรแสตมป์:</strong> 0.5% ของราคา (สำหรับบ้านถือครอง 5 ปีขึ้นไป)</li>
      <li><strong>ภาษีหัก ณ ที่จ่าย:</strong> 1% ของราคา (สำหรับผู้ขายบุคคลธรรมดา)</li>
    </ul>

    <h2>ตัวอย่างการคำนวณ (ซื้อบ้านมือสอง)</h2>

    <p>ซื้อบ้านราคา 2,000,000 บาท (ราคาประเมินเท่ากัน) กู้เงิน 1,500,000 บาท:</p>

    <h3>ค่าใช้จ่ายของผู้ซื้อ:</h3>

    <ul>
      <li>ค่าธรรมเนียมโอน: 2,000,000 × 2% = 40,000 บาท</li>
      <li>ค่าจดจำนอง: 1,500,000 × 1% = 15,000 บาท</li>
      <li>ภาษีธุรกิจเฉพาะ (ถ้าถือครองน้อยกว่า 5 ปี): 2,000,000 × 3.3% = 66,000 บาท</li>
      <li>ค่าประเมินราคาและค่าอื่นๆ: ประมาณ 2,000-5,000 บาท</li>
      <li><strong>รวมค่าใช้จ่าย: ประมาณ 123,000-126,000 บาท</strong></li>
    </ul>

    <h3>ค่าใช้จ่ายของผู้ขาย:</h3>

    <ul>
      <li>ภาษีหัก ณ ที่จ่าย: 2,000,000 × 1% = 20,000 บาท</li>
      <li>ค่าธรรมเนียมโอนผู้ขาย: ปกติสูงสุด 1.1% = 22,000 บาท</li>
      <li><strong>รวม: ประมาณ 42,000 บาท</strong></li>
    </ul>

    <h2>มาตรการช่วยเหลือ 2569</h2>

    <ul>
      <li>ค่าธรรมเนียมโอนลด 0.01% (จากปกติ 2%) สำหรับที่อยู่อาศัยราคาไม่เกิน 3 ล้านบาท จนถึง 31 ธ.ค. 2568</li>
      <li>ค่าจดจำนองลดเหลือ 0.01% สำหรับกู้ไม่เกิน 3 ล้านบาท</li>
      <li>สนับสนุนสำหรับโครงการขนส่งมวลชนและพื้นที่พัฒนา</li>
    </ul>

    <h2>สิ่งที่ต้องจำ</h2>

    <ul>
      <li>เตรียมเงินทั้งราคาซื้อและค่าใช้จ่ายเพิ่มเติม</li>
      <li>ตรวจสอบราคาประเมินกรมที่ดินก่อนซื้อขาย</li>
      <li>ปรึกษานิติยกับธนาคารเพื่อให้ได้อัตราดีสุด</li>
      <li>ถ้าเป็นบ้านนำเข้าจะมีค่าใช้จ่ายเพิ่มเติม</li>
    </ul>


    <h2>คำถามที่พบบ่อย (FAQ)</h2>

    <h3>ค่าอากรแสตมป์คำนวณจากราคาจริงหรือประเมิน?</h3>
    <p>ใช้มูลค่าที่สูงกว่าของทั้ง 2 อย่าง</p>

  </article>
</BaseLayout>