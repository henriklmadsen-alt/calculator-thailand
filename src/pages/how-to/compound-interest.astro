---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const pageTitle = 'วิธีคำนวณดอกเบี้ยทบต้น — คำแนะนำฉบับสมบูรณ์';
const pageDescription = 'เรียนรู้วิธีคำนวณดอกเบี้ยทบต้น (Compound Interest) วิธี Rule of 72 และการวางแผนการเงินระยะยาว';
const canonical = `${siteUrl}/how-to/compound-interest/`;
const authorDate = '2026-05-01';

const jsonLdArticle = {
