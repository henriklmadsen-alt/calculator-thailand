---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณรวมหนี้ (Debt Consolidation) 2569 | Kamnuanlek';
const pageDescription = 'คำนวณว่าควรรวมหนี้หลายก้อนเป็นก้อนเดียวไหม เปรียบเทียบค่างวดเดิมรวมกับค่างวดใหม่ ดอกเบี้ยรวม และเงินที่ประหยัดหรือแพงกว่า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณรวมหนี้/`;

const faqData = [
  {
    question: 'การรวมหนี้คืออะไร?',
    answer: 'การรวมหนี้ (Debt Consolidation) คือการนำหนี้หลายก้อนมารวมเป็นสินเชื่อก้อนเดียว โดยมักมีดอกเบี้ยต่ำกว่าและค่างวดรายเดือนที่จัดการได้ง่ายกว่า เหมาะสำหรับผู้ที่มีหนี้บัตรเครดิตหลายใบหรือสินเชื่อส่วนบุคคลหลายสัญญา',
  },
  {
    question: 'รวมหนี้แล้วประหยัดจริงไหม?',
    answer: 'ขึ้นอยู่กับดอกเบี้ยสินเชื่อรวมหนี้ใหม่เทียบกับดอกเบี้ยเฉลี่ยของหนี้เดิม หากดอกเบี้ยใหม่ต่ำกว่า และระยะเวลาไม่นานเกินไป มักประหยัดได้ แต่หากยืดระยะเวลาออกมาก อาจจ่ายดอกเบี้ยรวมมากกว่าเดิมแม้ค่างวดรายเดือนจะน้อยกว่า',
  },
  {
    question: 'ดอกเบี้ยสินเชื่อรวมหนี้อยู่ที่เท่าไร?',
    answer: 'สินเชื่อรวมหนี้ในไทยมักมีดอกเบี้ยประมาณ 10-18% ต่อปี ขึ้นอยู่กับสถาบันการเงินและโปรไฟล์ผู้กู้ หากคุณมีประวัติเครดิตดีอาจได้ดอกเบี้ยต่ำกว่า ควรสอบถามหลายแห่งเพื่อเปรียบเทียบ',
  },
  {
    question: 'ค่าธรรมเนียมรวมหนี้มีอะไรบ้าง?',
    answer: 'ค่าธรรมเนียมที่พบบ่อยได้แก่ ค่าธรรมเนียมการจัดการสินเชื่อ (1-3% ของวงเงิน) ค่าประกัน และค่าปิดบัญชีก่อนกำหนดของสินเชื่อเดิม ควรนำค่าใช้จ่ายเหล่านี้มาคำนวณรวมเพื่อดูว่าคุ้มค่าหรือไม่',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณรวมหนี้',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณรวมหนี้ 🔗">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🔗 คำนวณรวมหนี้ — ควรรวมหนี้หลายก้อนไหม?
    </h1>

    <p class="text-gray-600 mb-6">
      เปรียบเทียบค่างวดและดอกเบี้ยรวมระหว่างการจ่ายหนี้แยกก้อนกับการรวมเป็นสินเชื่อใหม่ก้อนเดียว
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="consolidation-form" class="space-y-6">

        <!-- Current Debts Section -->
        <div>
          <h2 class="text-sm font-semibold text-gray-900 mb-3">หนี้ปัจจุบัน</h2>

          <div class="grid gap-4 sm:grid-cols-3 mb-4">
            <div>
              <label for="total-balance" class="block text-sm font-medium text-gray-700 mb-1">
                ยอดหนี้รวม (บาท)
              </label>
              <input
                type="text"
                id="total-balance"
                inputmode="numeric"
                placeholder="เช่น 200000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="current-rate" class="block text-sm font-medium text-gray-700 mb-1">
                ดอกเบี้ยเฉลี่ยหนี้เดิม (%/ปี)
              </label>
              <input
                type="text"
                id="current-rate"
                inputmode="decimal"
                placeholder="เช่น 18"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="current-payment" class="block text-sm font-medium text-gray-700 mb-1">
                ค่างวดรวมต่อเดือนปัจจุบัน (บาท)
              </label>
              <input
                type="text"
                id="current-payment"
                inputmode="numeric"
                placeholder="เช่น 8000"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
          </div>
        </div>

        <hr class="border-gray-200" />

        <!-- New Consolidation Loan Section -->
        <div>
          <h2 class="text-sm font-semibold text-gray-900 mb-3">เงื่อนไขสินเชื่อรวมหนี้ใหม่</h2>

          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <label for="new-rate" class="block text-sm font-medium text-gray-700 mb-1">
                ดอกเบี้ยสินเชื่อใหม่ (%/ปี)
              </label>
              <input
                type="text"
                id="new-rate"
                inputmode="decimal"
                placeholder="เช่น 12"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="new-term" class="block text-sm font-medium text-gray-700 mb-1">
                ระยะเวลาผ่อน (ปี)
              </label>
              <input
                type="text"
                id="new-term"
                inputmode="decimal"
                placeholder="เช่น 3"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
            <div>
              <label for="fee" class="block text-sm font-medium text-gray-700 mb-1">
                ค่าธรรมเนียม (บาท)
              </label>
              <input
                type="text"
                id="fee"
                inputmode="numeric"
                placeholder="เช่น 2000"
                value="0"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
              />
            </div>
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          เปรียบเทียบ
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการเปรียบเทียบ</h2>

        <!-- Verdict Banner -->
        <div id="verdict-banner" class="rounded-lg px-4 py-3 mb-5 text-sm font-medium"></div>

        <!-- Comparison Table -->
        <div class="overflow-x-auto mb-4">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-gray-500 border-b border-gray-200">
                <th class="pb-2 pr-4 font-medium"></th>
                <th class="pb-2 pr-4 font-medium text-right">หนี้เดิม (รวม)</th>
                <th class="pb-2 font-medium text-right">สินเชื่อรวมหนี้ใหม่</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr>
                <td class="py-3 pr-4 text-gray-600">ค่างวดต่อเดือน</td>
                <td id="old-monthly" class="py-3 pr-4 text-right font-medium">-</td>
                <td id="new-monthly" class="py-3 text-right font-medium text-primary-700">-</td>
              </tr>
              <tr>
                <td class="py-3 pr-4 text-gray-600">ระยะเวลา</td>
                <td id="old-term" class="py-3 pr-4 text-right font-medium">-</td>
                <td id="new-term-display" class="py-3 text-right font-medium text-primary-700">-</td>
              </tr>
              <tr>
                <td class="py-3 pr-4 text-gray-600">ดอกเบี้ยรวม</td>
                <td id="old-interest" class="py-3 pr-4 text-right font-medium text-red-600">-</td>
                <td id="new-interest" class="py-3 text-right font-medium text-red-600">-</td>
              </tr>
              <tr>
                <td class="py-3 pr-4 text-gray-600">ค่าธรรมเนียม</td>
                <td class="py-3 pr-4 text-right text-gray-400">-</td>
                <td id="fee-display" class="py-3 text-right font-medium">-</td>
              </tr>
              <tr class="font-semibold">
                <td class="py-3 pr-4 text-gray-900">ยอดจ่ายรวมทั้งหมด</td>
                <td id="old-total" class="py-3 pr-4 text-right">-</td>
                <td id="new-total" class="py-3 text-right text-primary-700">-</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Summary Cards -->
        <div class="grid gap-3 sm:grid-cols-2">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประหยัดค่างวดต่อเดือน</div>
            <div id="monthly-savings" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประหยัด/แพงกว่ารวม</div>
            <div id="total-savings" class="text-xl font-bold">-</div>
          </div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">การรวมหนี้ — เมื่อไรควรทำ?</h2>

      <p>
        การรวมหนี้เป็นกลยุทธ์ที่เหมาะสมเมื่อคุณมีหนี้หลายก้อนที่มีดอกเบี้ยสูง เช่น บัตรเครดิตหลายใบ
        และสามารถหาสินเชื่อใหม่ที่มีดอกเบี้ยต่ำกว่าได้ การรวมหนี้ช่วยลดความซับซ้อนในการจัดการ
        และอาจลดดอกเบี้ยรวมได้มาก
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ควรรวมหนี้เมื่อ</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ดอกเบี้ยสินเชื่อใหม่ต่ำกว่าดอกเบี้ยเฉลี่ยหนี้เดิมอย่างมีนัยสำคัญ</li>
        <li>ต้องการลดจำนวนการชำระเงินจากหลายก้อนเหลือก้อนเดียว</li>
        <li>ค่างวดรวมปัจจุบันสูงเกินไปจนกระทบกระแสเงินสด</li>
        <li>มีแผนวินัยทางการเงินที่ชัดเจนหลังรวมหนี้</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ควรระวัง</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>หากยืดระยะเวลาออกนาน อาจจ่ายดอกเบี้ยรวมมากกว่าเดิม แม้ค่างวดต่อเดือนลดลง</li>
        <li>ระวังค่าธรรมเนียมปิดบัญชีก่อนกำหนดของสินเชื่อเดิม</li>
        <li>หลังรวมหนี้ ต้องหยุดก่อหนี้ใหม่จากบัตรเครดิตที่ปิดไป</li>
        <li>เปรียบเทียบข้อเสนอจากหลายสถาบันก่อนตัดสินใจ</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณรวมหนี้/" />
    <RelatedCalculators currentHref="/คำนวณรวมหนี้/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการเท่านั้น
      ตัวเลขจริงอาจแตกต่างตามเงื่อนไขของสถาบันการเงิน ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('consolidation-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const totalBalance = parseNum((document.getElementById('total-balance') as HTMLInputElement).value);
      const currentRate = parseFloat((document.getElementById('current-rate') as HTMLInputElement).value.replace(/,/g, '')) || 0;
      const currentPayment = parseNum((document.getElementById('current-payment') as HTMLInputElement).value);
      const newRate = parseFloat((document.getElementById('new-rate') as HTMLInputElement).value.replace(/,/g, '')) || 0;
      const newTermYears = parseFloat((document.getElementById('new-term') as HTMLInputElement).value.replace(/,/g, '')) || 0;
      const fee = parseNum((document.getElementById('fee') as HTMLInputElement).value);

      if (totalBalance <= 0 || newRate <= 0 || newTermYears <= 0 || currentPayment <= 0) return;

      // Current debt: estimate months remaining from payment and balance (reducing balance)
      const currentMonthlyRate = currentRate / 100 / 12;
      let currentMonths: number;
      let currentTotalInterest: number;

      if (currentMonthlyRate <= 0) {
        currentMonths = Math.ceil(totalBalance / currentPayment);
        currentTotalInterest = 0;
      } else if (currentPayment <= totalBalance * currentMonthlyRate) {
        // Payment doesn't cover interest — can't pay off
        currentMonths = 999;
        currentTotalInterest = 0;
      } else {
        currentMonths = Math.ceil(-Math.log(1 - totalBalance * currentMonthlyRate / currentPayment) / Math.log(1 + currentMonthlyRate));
        currentTotalInterest = currentPayment * currentMonths - totalBalance;
      }

      const currentTotal = totalBalance + currentTotalInterest;

      // New consolidated loan
      const newTermMonths = Math.round(newTermYears * 12);
      const newMonthlyRate = newRate / 100 / 12;
      let newMonthlyPayment: number;

      if (newMonthlyRate <= 0) {
        newMonthlyPayment = totalBalance / newTermMonths;
      } else {
        newMonthlyPayment = totalBalance * (newMonthlyRate * Math.pow(1 + newMonthlyRate, newTermMonths)) /
          (Math.pow(1 + newMonthlyRate, newTermMonths) - 1);
      }

      const newTotalInterest = newMonthlyPayment * newTermMonths - totalBalance;
      const newTotal = totalBalance + newTotalInterest + fee;

      const monthlySavings = currentPayment - newMonthlyPayment;
      const totalSavings = currentTotal - newTotal;

      // Fill table
      (document.getElementById('old-monthly') as HTMLElement).textContent = fmt(currentPayment) + ' บาท';
      (document.getElementById('new-monthly') as HTMLElement).textContent = fmt(newMonthlyPayment) + ' บาท';
      (document.getElementById('old-term') as HTMLElement).textContent =
        currentMonths < 900 ? `${currentMonths} เดือน` : 'ไม่สามารถปิดได้';
      (document.getElementById('new-term-display') as HTMLElement).textContent = `${newTermMonths} เดือน`;
      (document.getElementById('old-interest') as HTMLElement).textContent = fmt(currentTotalInterest) + ' บาท';
      (document.getElementById('new-interest') as HTMLElement).textContent = fmt(newTotalInterest) + ' บาท';
      (document.getElementById('fee-display') as HTMLElement).textContent = fmt(fee) + ' บาท';
      (document.getElementById('old-total') as HTMLElement).textContent = fmt(currentTotal) + ' บาท';
      (document.getElementById('new-total') as HTMLElement).textContent = fmt(newTotal) + ' บาท';

      const monthlySavingsEl = document.getElementById('monthly-savings') as HTMLElement;
      const totalSavingsEl = document.getElementById('total-savings') as HTMLElement;

      if (monthlySavings >= 0) {
        monthlySavingsEl.textContent = fmt(monthlySavings) + ' บาท/เดือน';
        monthlySavingsEl.className = 'text-xl font-bold text-blue-700';
      } else {
        monthlySavingsEl.textContent = 'จ่ายเพิ่ม ' + fmt(-monthlySavings) + ' บาท/เดือน';
        monthlySavingsEl.className = 'text-xl font-bold text-red-600';
      }

      if (totalSavings >= 0) {
        totalSavingsEl.textContent = 'ประหยัด ' + fmt(totalSavings) + ' บาท';
        totalSavingsEl.className = 'text-xl font-bold text-green-700';
      } else {
        totalSavingsEl.textContent = 'แพงกว่า ' + fmt(-totalSavings) + ' บาท';
        totalSavingsEl.className = 'text-xl font-bold text-red-600';
      }

      // Verdict banner
      const banner = document.getElementById('verdict-banner') as HTMLElement;
      if (totalSavings > 0 && monthlySavings > 0) {
        banner.textContent = '✓ การรวมหนี้คุ้มค่า — ประหยัดทั้งค่างวดรายเดือนและดอกเบี้ยรวม';
        banner.className = 'rounded-lg px-4 py-3 mb-5 text-sm font-medium bg-green-50 text-green-800 border border-green-200';
      } else if (totalSavings > 0 && monthlySavings <= 0) {
        banner.textContent = '~ ประหยัดดอกเบี้ยรวมได้ แต่ค่างวดต่อเดือนสูงกว่าเดิม — เหมาะถ้าต้องการปิดหนี้เร็วขึ้น';
        banner.className = 'rounded-lg px-4 py-3 mb-5 text-sm font-medium bg-yellow-50 text-yellow-800 border border-yellow-200';
      } else if (totalSavings <= 0 && monthlySavings > 0) {
        banner.textContent = '~ ค่างวดรายเดือนลดลง แต่ดอกเบี้ยรวมสูงกว่าเดิม — เหมาะถ้าต้องการลดภาระรายเดือนก่อน';
        banner.className = 'rounded-lg px-4 py-3 mb-5 text-sm font-medium bg-yellow-50 text-yellow-800 border border-yellow-200';
      } else {
        banner.textContent = '✗ การรวมหนี้ไม่คุ้มค่าในกรณีนี้ — ลองปรับดอกเบี้ยหรือระยะเวลาสินเชื่อใหม่';
        banner.className = 'rounded-lg px-4 py-3 mb-5 text-sm font-medium bg-red-50 text-red-800 border border-red-200';
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('debt-consolidation');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          trackResultViewed('debt-consolidation');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
