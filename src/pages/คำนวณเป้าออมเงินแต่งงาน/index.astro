---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเป้าหมายออมเงินแต่งงาน 2569 | วางแผนแต่งงาน | Kamnuanlek';
const pageDescription = 'คำนวณเงินออมรายเดือนที่ต้องออมเพื่องานแต่งงาน จากงบประมาณเป้าหมาย ระยะเวลา และเงินออมปัจจุบัน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเป้าออมเงินแต่งงาน/`;

const faqData = [
  {
    question: 'ควรเริ่มออมเงินแต่งงานล่วงหน้านานแค่ไหน?',
    answer: 'แนะนำให้เริ่มออมล่วงหน้าอย่างน้อย 1-2 ปี เพื่อกระจายภาระรายเดือนให้ไม่หนักเกินไป หากงบประมาณงานแต่งงานอยู่ที่ 300,000-500,000 บาท การออม 2 ปีล่วงหน้าจะใช้เงินออมประมาณ 12,500-20,800 บาทต่อเดือน ซึ่งจัดการได้ง่ายกว่าการออมระยะสั้น',
  },
  {
    question: 'งบประมาณงานแต่งงานโดยเฉลี่ยในไทยเป็นเท่าไหร่?',
    answer: 'งานแต่งงานในไทยโดยเฉลี่ยอยู่ที่ 200,000-600,000 บาท ขึ้นอยู่กับขนาดงาน สถานที่ และจำนวนแขก งานขนาดเล็ก 50-100 คนอาจใช้งบ 150,000-250,000 บาท ส่วนงานใหญ่ 200-300 คนอาจสูงถึง 500,000-800,000 บาทหรือมากกว่า',
  },
  {
    question: 'ควรนำเงินออมแต่งงานไปฝากที่ไหน?',
    answer: 'แนะนำฝากในบัญชีออมทรัพย์พิเศษหรือบัญชีเงินฝากประจำที่ให้ดอกเบี้ยสูงกว่าออมทรัพย์ทั่วไป เช่น บัญชีที่ให้ดอกเบี้ย 1.5-2% ต่อปี หากมีระยะเวลา 1 ปีขึ้นไปอาจพิจารณาเงินฝากประจำรายไตรมาสเพื่อผลตอบแทนที่ดีกว่า',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเป้าหมายออมเงินแต่งงาน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเป้าออมเงินแต่งงาน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณเป้าหมายออมเงินแต่งงาน 2569 — วางแผนงบก้าวแรกสู่ชีวิตคู่
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณเงินออมรายเดือนที่ต้องออมเพื่องานแต่งงาน จากงบประมาณเป้าหมาย ระยะเวลา และเงินออมปัจจุบัน
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="wedding-savings-form" class="space-y-5">
        <p id="wedding-savings-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ws-target" class="block text-sm font-medium text-gray-700 mb-1">เป้าหมายงบแต่งงาน (บาท)</label>
            <input type="text" id="ws-target" inputmode="numeric" placeholder="เช่น 300,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="ws-target-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ws-current" class="block text-sm font-medium text-gray-700 mb-1">เงินออมปัจจุบัน (บาท)</label>
            <input type="text" id="ws-current" inputmode="numeric" placeholder="เช่น 50,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ws-months" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (เดือน)</label>
            <input type="text" id="ws-months" inputmode="numeric" placeholder="เช่น 24"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="ws-months-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ws-rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราดอกเบี้ย (% ต่อปี)</label>
            <input type="text" id="ws-rate" inputmode="decimal" placeholder="เช่น 1.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
          </div>
        </div>

        <button type="submit" id="wedding-savings-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินออมรายเดือนที่ต้องออม</div>
            <div id="res-monthly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยสะสม</div>
            <div id="res-interest" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดรวมเมื่อถึงเป้า</div>
            <div id="res-total" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณเงินออมเพื่องานแต่งงาน</h2>
      <p>การออมเงินเพื่องานแต่งงานต้องการการวางแผนที่ชัดเจน เครื่องคำนวณนี้ใช้สูตร PMT เพื่อหาเงินออมรายเดือนที่เหมาะสม โดยคำนึงถึงดอกเบี้ยทบต้นและเงินออมที่มีอยู่แล้ว</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณ PMT</h3>
      <p>PMT = (เป้าหมาย - เงินออมปัจจุบัน × (1+r/12)^n) / (((1+r/12)^n - 1) / (r/12))<br />โดย r = อัตราดอกเบี้ยต่อปี/100 และ n = จำนวนเดือน หากไม่มีดอกเบี้ย PMT = (เป้าหมาย - เงินออมปัจจุบัน) / จำนวนเดือน</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ปัจจัยที่ส่งผลต่องบแต่งงาน</h3>
      <p>งบประมาณงานแต่งงานขึ้นอยู่กับสถานที่ จำนวนแขก ชุดแต่งงาน ช่างภาพ และของชำร่วย การวางแผนล่วงหน้าช่วยลดภาระการกู้เงินและเริ่มต้นชีวิตคู่อย่างมั่นคง</p>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณเป้าออมเงินแต่งงาน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น อัตราดอกเบี้ยจริงอาจแตกต่างตามเงื่อนไขของธนาคาร ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }
    const form = document.getElementById('wedding-savings-form') as HTMLFormElement;
    const submitBtn = document.getElementById('wedding-savings-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('wedding-savings-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const targetInput = document.getElementById('ws-target') as HTMLInputElement;
    const currentInput = document.getElementById('ws-current') as HTMLInputElement;
    const monthsInput = document.getElementById('ws-months') as HTMLInputElement;
    const rateInput = document.getElementById('ws-rate') as HTMLInputElement;
    function setFieldError(id: string, msg: string) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.remove('hidden'); }
    function clearFieldError(id: string) { const el = document.getElementById(id); if (!el) return; el.textContent = ''; el.classList.add('hidden'); }
    function clearValidation() { formError.classList.add('hidden'); ['ws-target-error', 'ws-months-error'].forEach(clearFieldError); }
    [targetInput, currentInput, monthsInput, rateInput].forEach(input => { input.addEventListener('input', clearValidation); });
    form.addEventListener('submit', (e) => {
      e.preventDefault(); clearValidation();
      const target = parseNum(targetInput.value);
      const current = parseNum(currentInput.value);
      const months = parseInt(monthsInput.value.replace(/,/g, '')) || 0;
      const annualRate = parseFloat(rateInput.value.replace(/,/g, '')) || 0;
      let hasError = false;
      if (target <= 0) { setFieldError('ws-target-error', 'กรุณากรอกเป้าหมายงบแต่งงาน'); hasError = true; }
      if (months <= 0) { setFieldError('ws-months-error', 'กรุณากรอกระยะเวลาออม'); hasError = true; }
      if (hasError) { formError.classList.remove('hidden'); return; }
      submitBtn.disabled = true; submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('wedding-savings-goal');
      const r = annualRate / 100;
      let monthlyPmt: number;
      if (r === 0) {
        const needed = target - current;
        monthlyPmt = needed > 0 ? needed / months : 0;
      } else {
        const rm = r / 12;
        const factor = Math.pow(1 + rm, months);
        const currentFV = current * factor;
        const needed = target - currentFV;
        monthlyPmt = needed <= 0 ? 0 : needed / ((factor - 1) / rm);
      }
      monthlyPmt = Math.max(0, monthlyPmt);
      const totalContributions = current + monthlyPmt * months;
      const totalInterest = Math.max(0, target - totalContributions);
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthlyPmt) + ' บาท/เดือน';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(target) + ' บาท';
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false; submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('wedding-savings-goal');
      trackCalculatorUsed('wedding-savings-goal');
    });
  </script>
</BaseLayout>
