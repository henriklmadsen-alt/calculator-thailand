---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณงบเที่ยวต่างประเทศ 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าเดินทางและงบเที่ยวต่างประเทศ 2569 ฟรี — ประมาณตั๋ว ที่พัก อาหาร ขนส่ง รู้งบรวมก่อนจองทริป';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าเดินทาง/`;

const faqData = [
  {
    question: 'รวมค่าวีซ่าไหม?',
    answer:
      'เครื่องมือนี้ไม่รวมค่าวีซ่า เนื่องจากค่าธรรมเนียมวีซ่าต่างกันในแต่ละประเทศ แนะนำให้ตรวจสอบค่าวีซ่าจากสถานทูตและบวกเพิ่มในงบเดินทางเอง',
  },
  {
    question: 'ค่าที่พักกรอกยังไง?',
    answer:
      'กรอกราคาต่อห้องต่อคืน ระบบจะคูณตามจำนวนห้องและจำนวนคืน (จำนวนวัน - 1) เช่น เที่ยว 5 วัน = พัก 4 คืน ถ้าพัก 2 ห้อง ห้องละ 2,500 บาท ระบบคิด 2,500 × 4 × 2 = 20,000 บาท',
  },
  {
    question: 'ค่าอาหารประมาณเท่าไร?',
    answer:
      'ขึ้นอยู่กับจุดหมาย ญี่ปุ่นประมาณ 1,000-3,000 บาท/วัน ยุโรปประมาณ 2,000-4,000 บาท/วัน อาเซียนประมาณ 500-1,000 บาท/วัน ตัวเลขนี้รวมทุกมื้อต่อวันต่อคน',
  },
  {
    question: 'นับจำนวนวันยังไง?',
    answer:
      'นับจำนวนวันที่อยู่ต่างประเทศ สำหรับค่าที่พัก ระบบจะคิดจำนวนคืน = จำนวนวัน - 1 เช่น เที่ยว 5 วัน = พัก 4 คืน ส่วนค่าอาหารและค่าขนส่งจะคิดตามจำนวนวันเต็ม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าเดินทาง',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'TravelApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'เครื่องมือทั่วไป', item: `${siteUrl}/หมวดหมู่/แปลง/` },
    { '@type': 'ListItem', position: 3, name: 'คำนวณค่าเดินทาง', item: canonical },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเดินทาง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">อ้างอิงข้อมูลปี 2569</p>
      <p class="mt-1 text-sm text-slate-700">ประมาณค่าใช้จ่ายรวม ตั๋วเครื่องบิน โรงแรม อาหาร ขนส่ง ประกัน สำหรับคนไทยเที่ยวต่างประเทศ</p>
      <p class="mt-1 text-xs font-medium text-sky-800">ผลลัพธ์นี้เป็นการประมาณการเพื่อวางแผนงบเดินทาง</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณค่าเดินทาง ปี 2569 — วางแผนงบเที่ยวต่างประเทศ</h1>

    <p class="mb-6 text-gray-600">
      กรอกจำนวนวัน จำนวนคน และค่าใช้จ่ายแต่ละหมวด เพื่อคำนวณงบเดินทางรวมและค่าใช้จ่ายต่อคน
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="travel-form" class="space-y-5">
        <p id="travel-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลที่กรอกให้ครบถ้วน
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="destination" class="mb-1 block text-sm font-medium text-gray-700">จุดหมายปลายทาง</label>
            <select
              id="destination"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">เลือกจุดหมาย</option>
              <option value="japan">ญี่ปุ่น</option>
              <option value="south_korea">เกาหลีใต้</option>
              <option value="china">จีน</option>
              <option value="vietnam">เวียดนาม</option>
              <option value="singapore">สิงคโปร์</option>
              <option value="malaysia">มาเลเซีย</option>
              <option value="indonesia">อินโดนีเซีย</option>
              <option value="philippines">ฟิลิปปินส์</option>
              <option value="india">อินเดีย</option>
              <option value="europe">ยุโรป</option>
              <option value="australia">ออสเตรเลีย</option>
              <option value="usa">สหรัฐอเมริกา</option>
              <option value="other">อื่นๆ</option>
            </select>
            <p id="destination-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="days" class="mb-1 block text-sm font-medium text-gray-700">จำนวนวัน</label>
            <input
              type="text"
              id="days"
              inputmode="numeric"
              placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p id="days-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="travelers" class="mb-1 block text-sm font-medium text-gray-700">จำนวนคน</label>
            <input
              type="text"
              id="travelers"
              inputmode="numeric"
              placeholder="เช่น 2"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p id="travelers-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="trip-type" class="mb-1 block text-sm font-medium text-gray-700">รูปแบบการเดินทาง</label>
            <select
              id="trip-type"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">เลือกรูปแบบ</option>
              <option value="budget">ประหยัด</option>
              <option value="moderate">ปานกลาง</option>
              <option value="luxury">หรูหรา</option>
            </select>
            <p id="trip-type-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <p class="text-sm font-semibold text-gray-700">ค่าใช้จ่ายโดยประมาณ (บาท)</p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="flight-cost" class="mb-1 block text-sm font-medium text-gray-700">ค่าตั๋วเครื่องบิน (ไป-กลับ/คน)</label>
            <input
              type="text"
              id="flight-cost"
              inputmode="numeric"
              placeholder="เช่น 15,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ราคาตั๋วไป-กลับต่อคน</p>
            <p id="flight-cost-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="hotel-cost" class="mb-1 block text-sm font-medium text-gray-700">ค่าที่พักต่อคืน (ต่อห้อง)</label>
            <input
              type="text"
              id="hotel-cost"
              inputmode="numeric"
              placeholder="เช่น 2,500"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ราคาห้องต่อคืน แชร์ได้</p>
            <p id="hotel-cost-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="food-cost" class="mb-1 block text-sm font-medium text-gray-700">ค่าอาหารต่อวัน (ต่อคน)</label>
            <input
              type="text"
              id="food-cost"
              inputmode="numeric"
              placeholder="เช่น 1,500"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">รวมทุกมื้อต่อวัน</p>
            <p id="food-cost-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="transport-cost" class="mb-1 block text-sm font-medium text-gray-700">ค่าขนส่งในพื้นที่ต่อวัน (ต่อคน)</label>
            <input
              type="text"
              id="transport-cost"
              inputmode="numeric"
              placeholder="เช่น 500"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">รถไฟ แท็กซี่ BTS ฯลฯ</p>
            <p id="transport-cost-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="insurance-cost" class="mb-1 block text-sm font-medium text-gray-700">ค่าประกันเดินทาง (ต่อคน)</label>
            <input
              type="text"
              id="insurance-cost"
              inputmode="numeric"
              placeholder="เช่น 500"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ประกันตลอดทริป</p>
            <p id="insurance-cost-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="activities-cost" class="mb-1 block text-sm font-medium text-gray-700">ค่ากิจกรรม/ช้อปปิ้ง (ต่อคน)</label>
            <input
              type="text"
              id="activities-cost"
              inputmode="numeric"
              placeholder="เช่น 3,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ค่าเข้าชม ช้อปปิ้ง ตลอดทริป</p>
            <p id="activities-cost-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="rooms" class="mb-1 block text-sm font-medium text-gray-700">จำนวนห้องพัก</label>
            <input
              type="text"
              id="rooms"
              inputmode="numeric"
              placeholder="1"
              value="1"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ค่าเริ่มต้น 1 ห้อง</p>
            <p id="rooms-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button
          type="submit"
          id="travel-submit-btn"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          กรอกข้อมูลให้ครบ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>

        <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รวมทั้งหมด</div>
            <div id="res-grand-total" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าใช้จ่ายต่อคน</div>
            <div id="res-per-person" class="text-lg font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าใช้จ่ายต่อคนต่อวัน</div>
            <div id="res-per-person-day" class="text-lg font-bold text-sky-700">-</div>
          </div>
        </div>

        <h3 class="mb-2 text-base font-semibold text-gray-900">รายละเอียดค่าใช้จ่าย</h3>
        <div class="overflow-x-auto rounded-md border border-gray-200">
          <table class="min-w-full text-sm">
            <thead class="bg-gray-50 text-gray-700">
              <tr>
                <th class="px-3 py-2 text-left font-medium">หมวดค่าใช้จ่าย</th>
                <th class="px-3 py-2 text-right font-medium">ต่อหน่วย</th>
                <th class="px-3 py-2 text-right font-medium">จำนวน</th>
                <th class="px-3 py-2 text-right font-medium">รวม (บาท)</th>
              </tr>
            </thead>
            <tbody id="breakdown-body" class="divide-y divide-gray-100 bg-white"></tbody>
            <tfoot>
              <tr class="bg-gray-50 font-bold">
                <td class="px-3 py-2 text-gray-900" colspan="3">รวมทั้งหมด</td>
                <td id="res-table-total" class="px-3 py-2 text-right text-gray-900">-</td>
              </tr>
            </tfoot>
          </table>
        </div>

        <div id="trip-summary" class="mt-4 rounded-md bg-sky-50 px-3 py-2 text-xs text-sky-800"></div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าตั๋วเครื่องบิน (รวม) = ราคาตั๋วไป-กลับต่อคน × จำนวนคน</li>
        <li>ค่าที่พัก (รวม) = ค่าที่พักต่อคืน × จำนวนคืน (วัน - 1) × จำนวนห้อง</li>
        <li>ค่าอาหาร (รวม) = ค่าอาหารต่อวันต่อคน × จำนวนวัน × จำนวนคน</li>
        <li>ค่าขนส่ง (รวม) = ค่าขนส่งต่อวันต่อคน × จำนวนวัน × จำนวนคน</li>
        <li>ค่าประกัน (รวม) = ค่าประกันต่อคน × จำนวนคน</li>
        <li>ค่ากิจกรรม (รวม) = ค่ากิจกรรมต่อคน × จำนวนคน</li>
        <li>รวมทั้งหมด = ผลรวมทุกหมวด</li>
        <li>ต่อคน = รวมทั้งหมด ÷ จำนวนคน</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <section class="mb-8 rounded-lg border border-primary-200 bg-primary-50 p-4">
      <p class="text-sm font-semibold text-primary-800">วางแผนเที่ยวต่างประเทศอย่างมืออาชีพ</p>
      <p class="mt-1 text-sm text-primary-700">ดูเคล็ดลับวางแผนงบเดินทาง แยกค่าใช้จ่ายรายหมวด พร้อมตัวอย่างจริง</p>
      <div class="mt-3">
        <a href="/คำนวณอัตราแลกเปลี่ยน/" class="inline-flex min-h-11 items-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-700">
          คำนวณอัตราแลกเปลี่ยนเงินตรา
        </a>
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณค่าเดินทาง/" />
    <RelatedCalculators currentHref="/คำนวณค่าเดินทาง/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <section class="mb-8 rounded-lg border border-gray-200 bg-white p-4 text-sm text-gray-700 shadow-sm sm:p-6">
      <h2 class="mb-2 text-base font-semibold text-gray-900">แหล่งอ้างอิง</h2>
      <ul class="list-disc space-y-1 pl-5">
        <li>ข้อมูลค่าใช้จ่ายเป็นค่าประมาณ อ้างอิงจากแหล่งท่องเที่ยวและสายการบินหลัก</li>
        <li>ค่าประกันเดินทางอ้างอิงจากบริษัทประกันภัยชั้นนำในประเทศไทย</li>
        <li>อัตราแลกเปลี่ยนและค่าใช้จ่ายจริงอาจแตกต่างจากที่ประมาณ</li>
      </ul>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>หมายเหตุสำคัญ:</strong> เครื่องมือนี้เป็นการคำนวณเบื้องต้นเพื่อช่วยประมาณงบเดินทาง
      ค่าใช้จ่ายจริงอาจแตกต่างขึ้นอยู่กับช่วงเวลา สายการบิน ที่พัก และอัตราแลกเปลี่ยน ณ วันเดินทาง
    </div>
  </article>

  <script type="module">
    import { calculateTravelCost, DESTINATIONS, TRIP_TYPES } from '../../lib/travel-cost-calculator';

    function parseNum(value) {
      const normalized = String(value).replace(/,/g, '').trim();
      if (normalized === '') return NaN;
      const n = Number(normalized);
      return Number.isFinite(n) ? n : NaN;
    }

    function fmtMoney(amount) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(amount)} บาท`;
    }

    const form = document.getElementById('travel-form');
    const submitBtn = document.getElementById('travel-submit-btn');
    const formError = document.getElementById('travel-form-error');
    const resultsDiv = document.getElementById('results');
    const breakdownBody = document.getElementById('breakdown-body');

    const fields = {
      destination: document.getElementById('destination'),
      days: document.getElementById('days'),
      travelers: document.getElementById('travelers'),
      tripType: document.getElementById('trip-type'),
      flightCost: document.getElementById('flight-cost'),
      hotelCost: document.getElementById('hotel-cost'),
      foodCost: document.getElementById('food-cost'),
      transportCost: document.getElementById('transport-cost'),
      insuranceCost: document.getElementById('insurance-cost'),
      activitiesCost: document.getElementById('activities-cost'),
      rooms: document.getElementById('rooms'),
    };

    const validDestinations = DESTINATIONS.map((d) => d.value);
    const validTripTypes = TRIP_TYPES.map((t) => t.value);
    const destLabels = Object.fromEntries(DESTINATIONS.map((d) => [d.value, d.label]));
    const tripLabels = Object.fromEntries(TRIP_TYPES.map((t) => [t.value, t.label]));

    function setFieldError(id, message) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearFieldError(id) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      ['destination', 'days', 'travelers', 'trip-type', 'flight-cost', 'hotel-cost', 'food-cost', 'transport-cost', 'insurance-cost', 'activities-cost', 'rooms'].forEach(
        (id) => clearFieldError(id + '-error'),
      );
    }

    function updateSubmitState() {
      const requiredFilled = [
        fields.destination.value,
        fields.days.value,
        fields.travelers.value,
        fields.tripType.value,
        fields.flightCost.value,
        fields.hotelCost.value,
        fields.foodCost.value,
      ].every((v) => String(v).trim() !== '');

      const daysVal = parseNum(fields.days.value);
      const travelersVal = parseNum(fields.travelers.value);
      const hasValidNums = Number.isFinite(daysVal) && daysVal >= 1 && Number.isFinite(travelersVal) && travelersVal >= 1;

      const ready = requiredFilled && hasValidNums;
      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณค่าเดินทาง' : 'กรอกข้อมูลให้ครบ';
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
      submitBtn.classList.toggle('opacity-70', !ready);
    }

    Object.values(fields).forEach((field) => {
      field.addEventListener('input', () => { clearValidation(); updateSubmitState(); });
      field.addEventListener('change', () => { clearValidation(); updateSubmitState(); });
    });

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    updateSubmitState();

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      clearValidation();

      const destination = String(fields.destination.value || '');
      const days = parseNum(fields.days.value);
      const travelers = parseNum(fields.travelers.value);
      const tripType = String(fields.tripType.value || '');
      const flightCost = parseNum(fields.flightCost.value);
      const hotelCost = parseNum(fields.hotelCost.value);
      const foodCost = parseNum(fields.foodCost.value);
      const transportCost = parseNum(fields.transportCost.value) || 0;
      const insuranceCost = parseNum(fields.insuranceCost.value) || 0;
      const activitiesCost = parseNum(fields.activitiesCost.value) || 0;
      const roomsInput = String(fields.rooms.value).trim();
      const rooms = roomsInput === '' ? 1 : parseNum(roomsInput);

      const validity = {
        destination: validDestinations.includes(destination),
        days: Number.isFinite(days) && days >= 1,
        travelers: Number.isFinite(travelers) && travelers >= 1,
        tripType: validTripTypes.includes(tripType),
        flightCost: Number.isFinite(flightCost) && flightCost >= 0,
        hotelCost: Number.isFinite(hotelCost) && hotelCost >= 0,
        foodCost: Number.isFinite(foodCost) && foodCost >= 0,
        rooms: Number.isFinite(rooms) && rooms >= 1,
      };

      if (!validity.destination) setFieldError('destination-error', 'กรุณาเลือกจุดหมายปลายทาง');
      if (!validity.days) setFieldError('days-error', 'กรุณากรอกจำนวนวัน (1 วันขึ้นไป)');
      if (!validity.travelers) setFieldError('travelers-error', 'กรุณากรอกจำนวนคน (1 คนขึ้นไป)');
      if (!validity.tripType) setFieldError('trip-type-error', 'กรุณาเลือกรูปแบบการเดินทาง');
      if (!validity.flightCost) setFieldError('flight-cost-error', 'กรุณากรอกค่าตั๋วเครื่องบิน');
      if (!validity.hotelCost) setFieldError('hotel-cost-error', 'กรุณากรอกค่าที่พัก');
      if (!validity.foodCost) setFieldError('food-cost-error', 'กรุณากรอกค่าอาหาร');
      if (!validity.rooms) setFieldError('rooms-error', 'จำนวนห้องต้องเป็น 1 ขึ้นไป');

      if (!Object.values(validity).every(Boolean)) {
        formError.classList.remove('hidden');
        updateSubmitState();
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('travel_cost');

      const result = calculateTravelCost({
        destination,
        days,
        travelers,
        tripType,
        flightCost,
        hotelCostPerNight: hotelCost,
        foodPerDay: foodCost,
        transportPerDay: transportCost,
        insurance: insuranceCost,
        activities: activitiesCost,
        rooms,
      });

      setText('res-grand-total', fmtMoney(result.grandTotal));
      setText('res-per-person', fmtMoney(result.perPerson));
      setText('res-per-person-day', fmtMoney(result.perPersonPerDay));
      setText('res-table-total', fmtMoney(result.grandTotal));

      breakdownBody.innerHTML = '';
      result.breakdown.forEach((item) => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td class="px-3 py-2 text-gray-700">${item.label}</td>
          <td class="px-3 py-2 text-right text-gray-700">${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 2 }).format(item.unitCost)} ${item.unitLabel}</td>
          <td class="px-3 py-2 text-right text-gray-700">${new Intl.NumberFormat('th-TH').format(item.quantity)}</td>
          <td class="px-3 py-2 text-right font-medium text-gray-900">${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(item.total)}</td>
        `;
        breakdownBody.appendChild(row);
      });

      const destName = destLabels[result.destination] || result.destination;
      const tripName = tripLabels[result.tripType] || result.tripType;
      const summaryParts = [
        `จุดหมาย: ${destName}`,
        `${result.days} วัน ${result.nights} คืน`,
        `${result.travelers} คน`,
        `${result.rooms} ห้อง`,
        `รูปแบบ: ${tripName}`,
      ];
      setText('trip-summary', summaryParts.join(' | '));

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณค่าเดินทาง';
      trackCalculatorComplete('travel_cost', result.grandTotal);
      trackCalculatorUsed('travel_cost');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          trackResultViewed('travel_cost');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
