---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณจำนวนเงินออมต่อเดือน 2569 | ต้องออมเดือนละเท่าไรถึงเป้าหมาย | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณเงินออมรายเดือนที่จำเป็นต้องออมเพื่อให้ถึงเป้าหมายเงินก้อนในระยะเวลาที่กำหนด คำนวณรวมดอกเบี้ยทบต้น อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณจำนวนเงินออมต่อเดือน/`;

const faqData = [
  {
    question: 'ต้องออมเดือนละเท่าไรเพื่อให้มีเงิน 1 ล้านบาท?',
    answer: 'ขึ้นอยู่กับระยะเวลาและอัตราดอกเบี้ย ตัวอย่าง: ถ้าดอกเบี้ย 3% ต่อปี ออม 10 ปีต้องออมประมาณ 7,200 บาท/เดือน ออม 15 ปีต้องออมประมาณ 4,300 บาท/เดือน ออม 20 ปีต้องออมประมาณ 3,000 บาท/เดือน ใช้เครื่องคำนวณนี้เพื่อหาตัวเลขที่แม่นยำ',
  },
  {
    question: 'สูตรคำนวณเงินออมรายเดือนคืออะไร?',
    answer: 'PMT = (FV − PV×(1+r)^n) × r / ((1+r)^n − 1) โดย FV คือเป้าหมายเงินก้อน PV คือเงินต้นที่มีอยู่แล้ว r คืออัตราดอกเบี้ยรายเดือน และ n คือจำนวนเดือน',
  },
  {
    question: 'มีเงินต้นอยู่แล้วส่งผลต่อการออมรายเดือนอย่างไร?',
    answer: 'เงินต้นที่มีอยู่แล้วจะช่วยลดเงินออมรายเดือนลงได้มาก เพราะเงินต้นจะเติบโตพร้อมดอกเบี้ยทบต้นตลอดระยะเวลา ยิ่งมีเงินต้นมากและระยะเวลานาน ยิ่งลดภาระการออมรายเดือนได้มากขึ้น',
  },
  {
    question: 'ควรเพิ่มเงินออมรายเดือนหรือหาผลตอบแทนสูงขึ้น?',
    answer: 'ทั้งสองวิธีส่งผลดีต่อเป้าหมาย แต่ในระยะสั้น (ต่ำกว่า 5 ปี) การเพิ่มเงินออมรายเดือนให้ผลชัดเจนกว่า ในระยะยาว (มากกว่า 10 ปี) การเพิ่มอัตราผลตอบแทน 1-2% สามารถสร้างผลต่างได้มากกว่าการเพิ่มเงินออม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณจำนวนเงินออมต่อเดือน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณจำนวนเงินออมต่อเดือน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณจำนวนเงินออมต่อเดือน 2569 — ต้องออมเดือนละเท่าไรถึงเป้าหมาย
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกเป้าหมายเงินก้อน เงินต้นที่มีอยู่ อัตราดอกเบี้ย และระยะเวลา แล้วระบบจะคำนวณว่าต้องออมเดือนละเท่าไร
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="monthly-savings-form" class="space-y-5">
        <p id="monthly-savings-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ms-goal" class="block text-sm font-medium text-gray-700 mb-1">
              เป้าหมายเงินก้อน (บาท)
            </label>
            <input
              type="text"
              id="ms-goal"
              inputmode="numeric"
              placeholder="เช่น 1,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="ms-goal-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ms-principal" class="block text-sm font-medium text-gray-700 mb-1">
              เงินต้นที่มีอยู่แล้ว (บาท)
            </label>
            <input
              type="text"
              id="ms-principal"
              inputmode="numeric"
              placeholder="เช่น 100,000 (ใส่ 0 หากยังไม่มี)"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="ms-principal-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ms-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราดอกเบี้ยต่อปี (%)
            </label>
            <input
              type="text"
              id="ms-rate"
              inputmode="decimal"
              placeholder="เช่น 3.0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="ms-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ms-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลา (ปี)
            </label>
            <input
              type="text"
              id="ms-years"
              inputmode="numeric"
              placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p id="ms-years-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button
          type="submit"
          id="monthly-savings-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินออมรายเดือน</div>
            <div id="res-monthly-payment" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยที่จะได้รับ</div>
            <div id="res-interest" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินออมรวม</div>
            <div id="res-total-saved" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ยอดรวมเมื่อครบกำหนด</div>
            <div id="res-final" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เป้าหมายเงินก้อน</span>
            <span id="res-goal" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินต้นเริ่มต้น</span>
            <span id="res-pv" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">อัตราดอกเบี้ย</span>
            <span id="res-rate-display" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ระยะเวลา</span>
            <span id="res-term-display" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณเงินออมรายเดือน</h2>

      <p>
        การคำนวณเงินออมรายเดือนช่วยให้รู้ว่าต้องวางแผนออมเดือนละเท่าไรจึงจะถึงเป้าหมายในเวลาที่กำหนด
        โดยคำนึงถึงดอกเบี้ยทบต้นและเงินต้นที่มีอยู่แล้ว
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณ</h3>
      <p>
        PMT = (FV − PV×(1+r)^n) × r / ((1+r)^n − 1)
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>FV = เป้าหมายเงินก้อน</li>
        <li>PV = เงินต้นที่มีอยู่แล้ว</li>
        <li>r = อัตราดอกเบี้ยรายเดือน (ต่อปี ÷ 12)</li>
        <li>n = จำนวนเดือนทั้งหมด</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการคำนวณ</h3>
      <p>ต้องการเงิน 1,000,000 บาท ใน 10 ปี มีเงินต้น 100,000 บาท ดอกเบี้ย 3% ต่อปี:</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>เงินต้นเติบโตเป็น: ≈ 134,935 บาท</li>
        <li>ส่วนที่ต้องออมเพิ่ม: ≈ 865,065 บาท</li>
        <li>ต้องออมรายเดือน: ≈ <strong>6,010 บาท</strong></li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณจำนวนเงินออมต่อเดือน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      อัตราดอกเบี้ยจริงอาจแตกต่างตามเงื่อนไขของสถาบันการเงิน ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    function hasInvalidNumber(v: string): boolean {
      const normalized = v.replace(/,/g, '').trim();
      return normalized !== '' && Number.isNaN(Number(normalized));
    }

    const form = document.getElementById('monthly-savings-form') as HTMLFormElement;
    const submitBtn = document.getElementById('monthly-savings-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('monthly-savings-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    const goalInput = document.getElementById('ms-goal') as HTMLInputElement;
    const principalInput = document.getElementById('ms-principal') as HTMLInputElement;
    const rateInput = document.getElementById('ms-rate') as HTMLInputElement;
    const yearsInput = document.getElementById('ms-years') as HTMLInputElement;

    function setFieldError(id: string, msg: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.remove('hidden');
    }

    function clearFieldError(id: string) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      ['ms-goal-error', 'ms-principal-error', 'ms-rate-error', 'ms-years-error'].forEach(clearFieldError);
    }

    [goalInput, principalInput, rateInput, yearsInput].forEach(input => {
      input.addEventListener('input', clearValidation);
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearValidation();

      const fv = parseNum(goalInput.value);
      const pv = parseNum(principalInput.value);
      const annualRate = parseFloat(rateInput.value.replace(/,/g, '')) || 0;
      const years = parseInt(yearsInput.value.replace(/,/g, '')) || 0;

      let hasError = false;
      if (fv <= 0) { setFieldError('ms-goal-error', 'กรุณากรอกเป้าหมายเงินก้อนที่ถูกต้อง'); hasError = true; }
      if (hasInvalidNumber(principalInput.value)) { setFieldError('ms-principal-error', 'รูปแบบข้อมูลไม่ถูกต้อง'); hasError = true; }
      if (annualRate <= 0) { setFieldError('ms-rate-error', 'กรุณากรอกอัตราดอกเบี้ยที่ถูกต้อง'); hasError = true; }
      if (years <= 0 || years > 50) { setFieldError('ms-years-error', 'กรุณากรอกระยะเวลา 1-50 ปี'); hasError = true; }
      if (pv >= fv) { setFieldError('ms-principal-error', 'เงินต้นต้องน้อยกว่าเป้าหมาย'); hasError = true; }

      if (hasError) {
        formError.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('monthly-savings');

      const r = annualRate / 100 / 12;
      const n = years * 12;
      const factor = Math.pow(1 + r, n);

      // PMT = (FV - PV*(1+r)^n) * r / ((1+r)^n - 1)
      let pmt: number;
      if (r === 0) {
        pmt = (fv - pv) / n;
      } else {
        pmt = (fv - pv * factor) * r / (factor - 1);
      }
      pmt = Math.max(0, pmt);

      const totalSaved = pv + pmt * n;
      const interest = fv - totalSaved;
      const actualFinal = pv * factor + (r > 0 ? pmt * (factor - 1) / r : pmt * n);

      (document.getElementById('res-monthly-payment') as HTMLElement).textContent = fmt(pmt) + ' บาท/เดือน';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(Math.max(0, actualFinal - totalSaved)) + ' บาท';
      (document.getElementById('res-total-saved') as HTMLElement).textContent = fmt(totalSaved) + ' บาท';
      (document.getElementById('res-final') as HTMLElement).textContent = fmt(actualFinal) + ' บาท';
      (document.getElementById('res-goal') as HTMLElement).textContent = fmt(fv) + ' บาท';
      (document.getElementById('res-pv') as HTMLElement).textContent = fmt(pv) + ' บาท';
      (document.getElementById('res-rate-display') as HTMLElement).textContent = annualRate.toFixed(2) + '% ต่อปี';
      (document.getElementById('res-term-display') as HTMLElement).textContent = years + ' ปี (' + n + ' เดือน)';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('monthly-savings');
      trackCalculatorUsed('monthly-savings');
    });
  </script>
</BaseLayout>
