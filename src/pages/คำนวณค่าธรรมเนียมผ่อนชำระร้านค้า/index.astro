---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าธรรมเนียมผ่อนชำระร้านค้า ปี 2569 — Installment Merchant Fee | Kamnuanlek';
const pageDescription = 'คำนวณค่าธรรมเนียมผ่อนชำระสำหรับร้านค้าที่รับผ่อน 0% ป้อนยอดซื้อ จำนวนงวด และอัตราค่าธรรมเนียม ทราบต้นทุนรับผ่อนทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าธรรมเนียมผ่อนชำระร้านค้า/`;

const faqData = [
  {
    question: 'ร้านค้ารับผ่อน 0% เสียค่าธรรมเนียมเท่าไหร่?',
    answer: 'ร้านค้าที่รับผ่อน 0% กับธนาคารมักเสียค่าธรรมเนียม 1.5–4% ของยอดขาย ขึ้นอยู่กับจำนวนงวดและธนาคาร ยิ่งงวดมากค่าธรรมเนียมยิ่งสูง',
  },
  {
    question: 'ค่าธรรมเนียมผ่อนชำระร้านค้าคิดอย่างไร?',
    answer: 'คิดจากยอดขาย × อัตราค่าธรรมเนียม (%) ตามจำนวนงวด เช่น ผ่อน 3 เดือนอาจคิด 1.5% ผ่อน 10 เดือนอาจคิด 4% ของยอดขาย',
  },
  {
    question: 'ควรรับผ่อน 0% หรือไม่?',
    answer: 'ขึ้นอยู่กับ margin สินค้า หากสินค้ามี margin สูงกว่าค่าธรรมเนียม การรับผ่อนช่วยเพิ่มยอดขาย แต่หาก margin ต่ำอาจขาดทุน ควรคำนวณก่อนตัดสินใจ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าธรรมเนียมผ่อนชำระร้านค้า',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าธรรมเนียมผ่อนชำระร้านค้า">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-purple-100 bg-purple-50 p-4">
      <p class="text-sm font-semibold text-purple-700">คำนวณค่าธรรมเนียมผ่อนชำระร้านค้า — Installment Merchant Fee</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: ค่าธรรมเนียม = ยอดขาย × อัตรา% | ยอดรับจริง = ยอดขาย − ค่าธรรมเนียม</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าธรรมเนียมผ่อนชำระร้านค้า ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนยอดขาย จำนวนงวด และอัตราค่าธรรมเนียมผ่อน 0% เพื่อดูต้นทุนที่แท้จริงสำหรับร้านค้า
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="inst-form" class="space-y-5">
        <p id="inst-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="inst-amount" class="mb-1 block text-sm font-medium text-gray-700">ยอดขาย (บาท)</label>
            <input type="text" id="inst-amount" inputmode="numeric" placeholder="เช่น 10,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="inst-amount-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="inst-months" class="mb-1 block text-sm font-medium text-gray-700">จำนวนงวด (เดือน)</label>
            <select id="inst-months" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="3">3 เดือน</option>
              <option value="6">6 เดือน</option>
              <option value="10">10 เดือน</option>
              <option value="12">12 เดือน</option>
              <option value="18">18 เดือน</option>
              <option value="24">24 เดือน</option>
            </select>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="inst-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราค่าธรรมเนียม (%)</label>
            <input type="text" id="inst-rate" inputmode="decimal" placeholder="เช่น 2.0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="inst-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
            <p class="mt-1 text-xs text-gray-500">ทั่วไป 1.5–4% ขึ้นกับงวดและธนาคาร</p>
          </div>
          <div>
            <label for="inst-margin" class="mb-1 block text-sm font-medium text-gray-700">Gross Margin ของสินค้า (%) — ไม่บังคับ</label>
            <input type="text" id="inst-margin" inputmode="decimal" placeholder="เช่น 30"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณค่าธรรมเนียม
        </button>
      </form>
    </div>

    <div id="inst-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าธรรมเนียม</div>
            <div id="res-inst-fee" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ยอดรับจริง</div>
            <div id="res-inst-net" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div id="inst-verdict-box" class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ผลต่าง Margin</div>
            <div id="res-inst-verdict" class="text-xl font-bold text-blue-700">-</div>
          </div>
        </div>
        <p id="inst-status" class="mt-2 rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าธรรมเนียม = ยอดขาย × (อัตรา% ÷ 100)</li>
        <li>ยอดรับจริง = ยอดขาย − ค่าธรรมเนียม</li>
        <li>กำไรสุทธิ = (ยอดขาย × margin%) − ค่าธรรมเนียม</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณ-MDR-ค่าธรรมเนียมร้านค้า/">คำนวณ MDR ค่าธรรมเนียมร้านค้า</a></li>
        <li><a href="/คำนวณ-cashback/">คำนวณมูลค่า Cashback</a></li>
        <li><a href="/คำนวณเปรียบเทียบจ่ายสดกับบัตร/">เปรียบเทียบจ่ายสดกับบัตร</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#inst-results" />

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณค่าธรรมเนียมผ่อนชำระร้านค้า/" />
    <RelatedCalculators currentHref="/คำนวณค่าธรรมเนียมผ่อนชำระร้านค้า/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> อัตราค่าธรรมเนียมผ่อนชำระอาจแตกต่างตามธนาคารและเงื่อนไขสัญญา ควรยืนยันกับธนาคารที่ให้บริการ
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('inst-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('inst-error').classList.add('hidden');
      ['inst-amount-error','inst-rate-error'].forEach(id => setErr(id, ''));

      const amount = parseNum(document.getElementById('inst-amount').value);
      const rate = parseNum(document.getElementById('inst-rate').value);
      const margin = parseNum(document.getElementById('inst-margin').value);

      let hasError = false;
      if (!Number.isFinite(amount) || amount <= 0) { setErr('inst-amount-error', 'กรอกยอดขายมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(rate) || rate <= 0 || rate >= 100) { setErr('inst-rate-error', 'กรอกอัตราค่าธรรมเนียม 0.01–99.99%'); hasError = true; }
      if (hasError) { document.getElementById('inst-error').classList.remove('hidden'); document.getElementById('inst-results').classList.add('hidden'); return; }

      const fee = amount * rate / 100;
      const net = amount - fee;
      setText('res-inst-fee', fmt(fee));
      setText('res-inst-net', fmt(net));

      const statusEl = document.getElementById('inst-status');
      const verdictBox = document.getElementById('inst-verdict-box');
      const verdictEl = document.getElementById('res-inst-verdict');

      if (Number.isFinite(margin) && margin > 0) {
        const grossProfit = amount * margin / 100;
        const netProfit = grossProfit - fee;
        setText('res-inst-verdict', fmt(netProfit));
        if (netProfit > 0) {
          verdictBox.className = 'rounded-lg bg-green-50 p-4 text-center';
          verdictEl.className = 'text-xl font-bold text-green-700';
          statusEl.className = 'mt-2 rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800 border border-green-200';
          statusEl.textContent = `กำไรสุทธิหลังหักค่าธรรมเนียม ${fmt(netProfit)} — รับผ่อนได้คุ้มค่า`;
        } else {
          verdictBox.className = 'rounded-lg bg-red-50 p-4 text-center';
          verdictEl.className = 'text-xl font-bold text-red-700';
          statusEl.className = 'mt-2 rounded-lg bg-red-50 p-3 text-sm font-medium text-red-800 border border-red-200';
          statusEl.textContent = `ขาดทุน ${fmt(Math.abs(netProfit))} — ค่าธรรมเนียมสูงกว่า Gross Margin`;
        }
        verdictBox.classList.remove('hidden');
        statusEl.classList.remove('hidden');
      } else {
        verdictEl.textContent = 'ไม่ได้ระบุ';
        statusEl.textContent = '';
        statusEl.className = '';
      }

      document.getElementById('inst-results').classList.remove('hidden');
      document.getElementById('inst-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
