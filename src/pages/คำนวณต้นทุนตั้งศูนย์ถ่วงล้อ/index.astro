---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณต้นทุนตั้งศูนย์ถ่วงล้อรถยนต์ ปี 2569 | Wheel Alignment | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนตั้งศูนย์ถ่วงล้อรถยนต์ พร้อมวิเคราะห์ความคุ้มค่าของการดูแลล้อเป็นระยะ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนตั้งศูนย์ถ่วงล้อ/`;

const faqData = [
  {
    question: 'ตั้งศูนย์ล้อกับถ่วงล้อต่างกันอย่างไร?',
    answer: 'ตั้งศูนย์ล้อ (Wheel Alignment) คือการปรับมุมของล้อให้ตรงตามสเปคโรงงาน เพื่อให้รถวิ่งตรงและยางสึกหรอสม่ำเสมอ ส่วนถ่วงล้อ (Wheel Balancing) คือการเพิ่มตะกั่วถ่วงน้ำหนักที่ขอบล้อเพื่อลดการสั่นสะเทือน ทั้งสองอย่างควรทำพร้อมกันเมื่อเปลี่ยนยาง',
  },
  {
    question: 'ควรตั้งศูนย์ล้อบ่อยแค่ไหน?',
    answer: 'แนะนำตั้งศูนย์ล้อทุก 20,000-30,000 กม. หรือทุกครั้งที่เปลี่ยนยาง เปลี่ยนชิ้นส่วนช่วงล่าง หรือหากรู้สึกว่ารถวิ่งไม่ตรง รถดิ่งไปด้านใดด้านหนึ่ง หรือยางสึกไม่สม่ำเสมอ',
  },
  {
    question: 'ราคาตั้งศูนย์ถ่วงล้อในไทยเท่าไร?',
    answer: 'ตั้งศูนย์ 2 ล้อ (หน้า) ราคา 500-800 บาท ตั้งศูนย์ 4 ล้อราคา 800-1,200 บาท ถ่วงล้อราคา 200-400 บาท/ล้อ หรือ 800-1,600 บาท/ชุด 4 ล้อ ราคาขึ้นอยู่กับประเภทเครื่องมือและสถานที่',
  },
  {
    question: 'ศูนย์ล้อเพี้ยนทำให้เสียเงินมากแค่ไหน?',
    answer: 'ศูนย์ล้อเพี้ยนทำให้ยางสึกเร็วขึ้นประมาณ 10-20% หากยาง 1 ชุดราคา 15,000 บาท อายุปกติ 50,000 กม. ศูนย์เพี้ยนอาจทำให้ยางอยู่ได้เพียง 40,000-45,000 กม. เสียค่ายางเร็วขึ้น 3,000-7,500 บาทต่อรอบ นอกจากนี้ยังเพิ่มการสิ้นเปลืองน้ำมันเชื้อเพลิงอีกด้วย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนตั้งศูนย์ถ่วงล้อรถยนต์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนตั้งศูนย์ถ่วงล้อ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณต้นทุนตั้งศูนย์ถ่วงล้อรถยนต์
    </h1>
    <p class="text-gray-600 mb-6">
      คำนวณค่าใช้จ่ายตั้งศูนย์ถ่วงล้อต่อปี พร้อมวิเคราะห์ความคุ้มค่าเทียบกับค่ายางที่ประหยัดได้จากการดูแลล้ออย่างสม่ำเสมอ
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-5">
        <div>
          <label for="alignment-type" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทการตั้งศูนย์
          </label>
          <select
            id="alignment-type"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="2wheel">ตั้งศูนย์ 2 ล้อ (ล้อหน้า)</option>
            <option value="4wheel" selected>ตั้งศูนย์ 4 ล้อ (ครบชุด) — แนะนำ</option>
          </select>
        </div>
        <div>
          <label for="alignment-cost" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าตั้งศูนย์ต่อครั้ง (บาท)
          </label>
          <input
            type="text"
            id="alignment-cost"
            inputmode="decimal"
            value="900"
            placeholder="เช่น 900"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="alignment-interval" class="block text-sm font-medium text-gray-700 mb-1">
            ความถี่ตั้งศูนย์ (ทุกกี่ กม.)
          </label>
          <select
            id="alignment-interval"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="10000">ทุก 10,000 กม.</option>
            <option value="20000" selected>ทุก 20,000 กม. — แนะนำ</option>
            <option value="30000">ทุก 30,000 กม.</option>
            <option value="40000">ทุก 40,000 กม.</option>
          </select>
        </div>
        <div>
          <label for="monthly-km" class="block text-sm font-medium text-gray-700 mb-1">
            ระยะทางขับต่อเดือน (กม.)
          </label>
          <input
            type="text"
            id="monthly-km"
            inputmode="decimal"
            value="2000"
            placeholder="เช่น 2000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="last-alignment" class="block text-sm font-medium text-gray-700 mb-1">
            ตั้งศูนย์ครั้งล่าสุดเมื่อกี่ กม. ที่แล้ว
          </label>
          <input
            type="text"
            id="last-alignment"
            inputmode="decimal"
            value="5000"
            placeholder="เช่น 5000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="tire-price" class="block text-sm font-medium text-gray-700 mb-1">
            ราคายาง 1 ชุด 4 เส้น (บาท)
          </label>
          <input
            type="text"
            id="tire-price"
            inputmode="decimal"
            value="15000"
            placeholder="เช่น 15000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full px-6 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณต้นทุนและความคุ้มค่า
      </button>

      <!-- Results -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-blue-700 font-medium mb-1">ค่าตั้งศูนย์ต่อปี</div>
            <div id="res-annual-cost" class="text-2xl font-bold text-blue-800">-</div>
            <div id="res-times-per-year" class="text-xs text-blue-600 mt-1">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4">
            <div class="text-sm text-amber-700 font-medium mb-1">ถึงตั้งศูนย์ครั้งถัดไปใน</div>
            <div id="res-next-km" class="text-2xl font-bold text-amber-800">-</div>
            <div id="res-next-months" class="text-xs text-amber-600 mt-1">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4">
            <div class="text-sm text-green-700 font-medium mb-1">ประหยัดค่ายางต่อปี (10% ลดการสึก)</div>
            <div id="res-tire-savings" class="text-2xl font-bold text-green-800">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4">
            <div class="text-sm text-primary-700 font-medium mb-1">ผลตอบแทนสุทธิต่อปี</div>
            <div id="res-net-benefit" class="text-2xl font-bold text-primary-800">-</div>
            <div id="res-roi" class="text-xs text-primary-600 mt-1">-</div>
          </div>
        </div>
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div class="text-sm font-semibold text-gray-700 mb-2">สรุปการวิเคราะห์ความคุ้มค่า</div>
          <div id="res-summary" class="text-sm text-gray-600">-</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ทำไมต้องตั้งศูนย์ล้อเป็นประจำ</h2>
      <p>
        การตั้งศูนย์ล้อเป็นประจำเป็นการดูแลรักษาที่คุ้มค่ามากที่สุดอย่างหนึ่ง
        ศูนย์ล้อที่ถูกต้องช่วยให้ยางสึกสม่ำเสมอ รถวิ่งตรง ประหยัดน้ำมัน และเพิ่มความปลอดภัย
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ราคาตั้งศูนย์ถ่วงล้อในตลาดไทย 2569</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b border-gray-200">
              <th class="py-2 pr-4">บริการ</th>
              <th class="py-2 pr-4">ราคาอู่ทั่วไป (บาท)</th>
              <th class="py-2">ราคาศูนย์บริการ (บาท)</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ตั้งศูนย์ล้อ 2 ล้อ</td>
              <td class="py-2 pr-4">500 - 800</td>
              <td class="py-2">600 - 1,000</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ตั้งศูนย์ล้อ 4 ล้อ</td>
              <td class="py-2 pr-4">800 - 1,200</td>
              <td class="py-2">1,000 - 1,800</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">ถ่วงล้อ (ต่อเส้น)</td>
              <td class="py-2 pr-4">50 - 100</td>
              <td class="py-2">100 - 200</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">ตั้งศูนย์ + ถ่วงล้อ 4 ล้อ</td>
              <td class="py-2 pr-4">1,000 - 1,600</td>
              <td class="py-2">1,400 - 2,500</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ผลของศูนย์ล้อเพี้ยนต่อค่าใช้จ่าย</h3>
      <p>
        การศึกษาพบว่าศูนย์ล้อเพี้ยนทำให้ยางสึกหรอเร็วขึ้น 10-20%
        หากยางชุด 4 เส้นราคา 15,000 บาท มีอายุปกติ 50,000 กม.
        ศูนย์เพี้ยนจะทำให้ยางอยู่ได้เพียง 40,000-45,000 กม. เสียเงินค่ายางเพิ่มปีละ 3,000-7,500 บาท
        เมื่อเทียบกับค่าตั้งศูนย์ 4 ล้อ 900 บาท/ครั้ง ถือว่าคุ้มค่ามาก
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สัญญาณที่บอกว่าต้องตั้งศูนย์ล้อ</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>รถวิ่งไม่ตรง เบี่ยงซ้ายหรือขวาโดยไม่บังคับ</li>
        <li>พวงมาลัยไม่อยู่กึ่งกลางเมื่อรถวิ่งตรง</li>
        <li>ยางสึกเฉพาะด้านใดด้านหนึ่งหรือเฉพาะขอบ</li>
        <li>รู้สึกสั่นที่พวงมาลัยที่ความเร็วต่างๆ</li>
        <li>หลังเปลี่ยนหรือซ่อมชิ้นส่วนช่วงล่าง</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณต้นทุนตั้งศูนย์ถ่วงล้อ/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนตั้งศูนย์ถ่วงล้อ/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการเพื่อช่วยวางแผนเบื้องต้น
      การประหยัดค่ายางจริงขึ้นอยู่กับสภาพถนน พฤติกรรมการขับ และยี่ห้อยาง
      กรุณาสอบถามช่างผู้เชี่ยวชาญเพื่อการประเมินที่แม่นยำ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    function fmtDec(n: number, d = 1): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: d, maximumFractionDigits: d }).format(n);
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const alignmentType = (document.getElementById('alignment-type') as HTMLSelectElement).value;
      const alignmentCost = parseNum((document.getElementById('alignment-cost') as HTMLInputElement).value) || (alignmentType === '2wheel' ? 650 : 900);
      const alignmentInterval = parseInt((document.getElementById('alignment-interval') as HTMLSelectElement).value, 10);
      const monthlyKm = parseNum((document.getElementById('monthly-km') as HTMLInputElement).value) || 2000;
      const lastAlignmentKm = parseNum((document.getElementById('last-alignment') as HTMLInputElement).value);
      const tirePrice = parseNum((document.getElementById('tire-price') as HTMLInputElement).value) || 15000;

      const annualKm = monthlyKm * 12;
      const timesPerYear = annualKm / alignmentInterval;
      const annualAlignmentCost = alignmentCost * timesPerYear;

      // km remaining until next alignment
      const kmRemaining = Math.max(0, alignmentInterval - lastAlignmentKm);
      const monthsRemaining = monthlyKm > 0 ? kmRemaining / monthlyKm : 0;

      // Tire wear savings: misalignment causes ~10% extra tire wear
      // Annual tire wear = tirePrice / (tireLifeKm / annualKm)
      const tireLifeKm = 50000; // typical tire life
      const annualTireCost = (tirePrice / tireLifeKm) * annualKm;
      const tireSavingsPerYear = annualTireCost * 0.10; // 10% savings

      const netBenefit = tireSavingsPerYear - annualAlignmentCost;
      const roi = annualAlignmentCost > 0 ? (tireSavingsPerYear / annualAlignmentCost) * 100 : 0;

      (document.getElementById('res-annual-cost') as HTMLElement).textContent = `฿${fmt(Math.round(annualAlignmentCost))}`;
      (document.getElementById('res-times-per-year') as HTMLElement).textContent = `${fmtDec(timesPerYear)} ครั้ง/ปี (ทุก ${alignmentInterval.toLocaleString('th-TH')} กม.)`;
      (document.getElementById('res-next-km') as HTMLElement).textContent = `${fmt(kmRemaining)} กม.`;
      (document.getElementById('res-next-months') as HTMLElement).textContent = `ประมาณ ${fmtDec(monthsRemaining)} เดือน ที่ ${fmt(monthlyKm)} กม./เดือน`;
      (document.getElementById('res-tire-savings') as HTMLElement).textContent = `฿${fmt(Math.round(tireSavingsPerYear))}`;

      const netEl = document.getElementById('res-net-benefit') as HTMLElement;
      if (netBenefit >= 0) {
        netEl.textContent = `+฿${fmt(Math.round(netBenefit))}`;
        netEl.className = 'text-2xl font-bold text-green-700';
      } else {
        netEl.textContent = `-฿${fmt(Math.round(Math.abs(netBenefit)))}`;
        netEl.className = 'text-2xl font-bold text-orange-700';
      }
      (document.getElementById('res-roi') as HTMLElement).textContent = `ROI: ${fmtDec(roi, 0)}% (ทุก ฿1 ลงทุนตั้งศูนย์ ได้คืน ฿${fmtDec(roi / 100, 2)} จากค่ายาง)`;

      const summaryEl = document.getElementById('res-summary') as HTMLElement;
      if (netBenefit >= 0) {
        summaryEl.textContent = `การตั้งศูนย์ล้อทุก ${alignmentInterval.toLocaleString('th-TH')} กม. คุ้มค่า ประหยัดค่ายางได้ ฿${fmt(Math.round(tireSavingsPerYear))} ต่อปี มากกว่าค่าตั้งศูนย์ ฿${fmt(Math.round(annualAlignmentCost))} ได้กำไรสุทธิ ฿${fmt(Math.round(netBenefit))} ต่อปี`;
      } else {
        summaryEl.textContent = `ค่าตั้งศูนย์สูงกว่าค่ายางที่ประหยัดได้ แต่ยังคุ้มค่าด้านความปลอดภัยและอายุการใช้งานรถ แนะนำตั้งศูนย์ทุก 20,000-30,000 กม. เป็นอย่างน้อย`;
      }

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
    });

    document.querySelectorAll('#result ~ * input, input').forEach(input => {
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
