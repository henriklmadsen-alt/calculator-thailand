---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ ROI เช่าที่ดิน/บ้าน ปี 2569 | ผลตอบแทนการให้เช่า | Kamnuanlek';
const pageDescription = 'คำนวณผลตอบแทนรายปี (ROI) จากการให้เช่าที่ดิน บ้าน โดยเทียบรายได้เช่ากับเงินลงทุนเริ่มต้น ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-roi-เช่า/`;

const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "วิธีคำนวณอัตราผลตอบแทน ROI เช่าที่ดิน",
  "description": "วิธีคำนวณอัตราผลตอบแทนต่อปีจากการเช่าที่ดิน และการเปรียบเทียบความสามารถในการทำกำไร",
  "author": {
    "@type": "Organization",
    "name": "Kamnuanlek.com",
    "url": "https://kamnuanlek.com"
  },
  "totalTime": "PT5M",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "กำหนดรายได้เช่าต่อปี",
      "text": "คำนวณรายได้เช่าต่อเดือน × 12 เดือน เช่น ที่ดินเช่า 30,000 บาท/เดือน × 12 = 360,000 บาท/ปี"
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "หักค่าใช้ดำเนินการ",
      "text": "หักค่าโภคนำ ค่าประกันภัย ค่าอสม. ค่าบำรุงรักษา (โดยทั่วไป 20-30% ของรายได้รวม)"
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "คำนวณรายได้สุทธิ",
      "text": "รายได้เช่า - ค่าใช้ = รายได้สุทธิ เช่น 360,000 - 72,000 = 288,000 บาท"
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "ใช้สูตรคำนวณ Cap Rate",
      "text": "ROI = (รายได้สุทธิ ÷ ราคาซื้อ) × 100 เช่น (288,000 ÷ 3,000,000) × 100 = 9.6%"
    },
    {
      "@type": "HowToStep",
      "position": 5,
      "name": "เปรียบเทียบกับอื่น ๆ",
      "text": "เปรียบเทียบ ROI กับเงินฝากธนาคาร (~2%) พันธบัตร (~3-4%) และลงทุนอื่น ๆ เพื่อวัดความสามารถในการทำกำไร"
    }
  ]
};

const faqData = [
  { question: 'ROI คืออะไรและคำนวณอย่างไร?', answer: 'ROI (Return on Investment) = (กำไรสุทธิ / ต้นทุนรวม) x 100% ตัวอย่าง: ลงทุน 100,000 บาท ได้กำไร 20,000 บาท ROI = 20%' },
  { question: 'ROI ที่ดีควรเป็นเท่าไร?', answer: 'ขึ้นอยู่กับอุตสาหกรรมและความเสี่ยง โดยทั่วไป ROI 10-20% ต่อปีถือว่าดีสำหรับการลงทุนทั่วไป ความเสี่ยงสูงต้องการ ROI สูงกว่า' },
  { question: 'ความแตกต่างระหว่าง ROI และ IRR คืออะไร?', answer: 'ROI วัดผลตอบแทนรวม IRR (Internal Rate of Return) คำนึงถึงมูลค่าเงินตามเวลา เหมาะสำหรับโครงการระยะยาว' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกเงินลงทุนเริ่มต้นและผลตอบแทนที่คาดหวัง เครื่องคำนวณจะแสดง ROI และระยะเวลาคืนทุน' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ ROI เช่า">    <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณ ROI การให้เช่าที่ดิน/บ้าน ปี 2569</h1>
    <p class="text-gray-600 mb-6">วิเคราะห์ผลตอบแทนรายปีจากการให้เช่า เทียบกับเงินลงทุนเบื้องต้น</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="roi-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="purchase-price" class="block text-sm font-medium text-gray-700 mb-1">ราคาซื้อ (บาท)</label>
            <input id="purchase-price" type="text" inputmode="numeric" placeholder="เช่น 5,000,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="annual-rent" class="block text-sm font-medium text-gray-700 mb-1">รายได้เช่า/ปี (บาท)</label>
            <input id="annual-rent" type="text" inputmode="numeric" placeholder="เช่น 300,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>
        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณ ROI
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8 border-2 border-primary-600 bg-primary-50 rounded-lg p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="grid gap-3 sm:grid-cols-2 mb-6">
        <div class="rounded-lg bg-white p-4 text-center border border-gray-200">
          <div class="text-sm text-gray-600 mb-1">ROI ต่อปี</div>
          <div id="res-roi" class="text-2xl sm:text-3xl lg:text-4xl font-bold text-primary-700">-</div>
        </div>
        <div class="rounded-lg bg-white p-4 text-center border border-gray-200">
          <div class="text-sm text-gray-600 mb-1">ระยะเวลาคืนทุน</div>
          <div id="res-payback" class="text-2xl sm:text-3xl lg:text-4xl font-bold text-sky-700">-</div>
        </div>
      </div>

      <details class="mt-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4">
        <summary class="font-semibold text-yellow-900 cursor-pointer select-none hover:text-yellow-800 transition-colors">
          ⚠️ สำคัญ: หมายเหตุเกี่ยวกับการคำนวณ
        </summary>
        <div class="mt-3 text-sm text-yellow-800 space-y-2">
          <p>• ผลการคำนวณนี้เป็นการประมาณการพื้นฐาน ไม่รวมปัจจัยอื่น เช่น ค่าใช้บำรุง ค่าซ่อมแซม โภคนำ</p>
          <p>• ผลตอบแทนจริงขึ้นอยู่กับการเก็บค่าเช่า ค่าใช้ดำเนินการ และการเปลี่ยนแปลงราคาอสังหาริมทรัพย์</p>
          <p>• ไม่คำนึงถึงภาษีอากร ค่าธรรมเนียม และต้นทุนอื่นๆ ของผู้ให้เช่า</p>
          <p>• สำหรับการลงทุนจริง ควรปรึกษานักบัญชี และอสังหาริมทรัพย์เพื่อข้อมูลที่แม่นยำ</p>
        </div>
      </details>
    </div>

    <div class="my-8 border-t-2 border-gray-200"></div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <RelatedCalculators currentHref="/คำนวณ-roi-เช่า/" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  const form = document.querySelector('#roi-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const purchasePrice = parseNumber(document.querySelector('#purchase-price')?.value || '');
    const annualRent = parseNumber(document.querySelector('#annual-rent')?.value || '');

    if (!(Number.isFinite(purchasePrice) && purchasePrice > 0 && Number.isFinite(annualRent) && annualRent > 0)) {
      results?.classList.add('hidden');
      return;
    }

    const roi = (annualRent / purchasePrice) * 100;
    const paybackYears = purchasePrice / annualRent;

    document.querySelector('#res-roi').textContent = roi.toFixed(2) + '%';
    document.querySelector('#res-payback').textContent = paybackYears.toFixed(1) + ' ปี';

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
