---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณภาษีเจ้าของกิจการ SME 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณภาษีเจ้าของกิจการรายย่อย 40(2) 40(8) 2569 ฟรี — เปรียบเทียบหักเหมาหรือหักจริง รู้ว่าแบบไหนประหยัดภาษีกว่า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีผู้ประกอบการรายย่อย/`;

const faqData = [
  {
    question: 'ผู้ประกอบการรายย่อยยื่นภาษีแบบใด?',
    answer: 'ผู้มีรายได้ประเภท 40(2) ที่มีรายได้จากค่าจ้างทำงาน และ 40(8) รายได้จากธุรกิจอื่นๆ ต้องยื่นแบบ ภ.ง.ด.90 ภายใน 31 มีนาคมของปีถัดไป',
  },
  {
    question: 'ค่าใช้จ่ายเหมาประเภท 40(2) หักได้เท่าไร?',
    answer: 'รายได้ประเภท 40(2) หักค่าใช้จ่ายเหมาได้ 50% ของรายได้ แต่ไม่เกิน 100,000 บาท เช่นเดียวกับเงินเดือน',
  },
  {
    question: 'ค่าใช้จ่ายเหมาประเภท 40(8) หักได้เท่าไร?',
    answer: 'รายได้ประเภท 40(8) จากธุรกิจพาณิชย์/อุตสาหกรรม หักได้ 60% ส่วนธุรกิจบริการหักได้ 60% หรือ 50% แล้วแต่ประเภท แต่ถ้าหักค่าใช้จ่ายจริงได้มากกว่า ให้ใช้จริงดีกว่า',
  },
  {
    question: 'ผู้ประกอบการรายย่อยต้องจด VAT ไหม?',
    answer: 'ถ้ารายได้เกิน 1.8 ล้านบาทต่อปีต้องจด VAT ถ้าต่ำกว่า 1.8 ล้านบาทสามารถเลือกจดหรือไม่จดก็ได้',
  },
  {
    question: 'ถ้ามีทั้งรายได้ 40(2) และ 40(8) ยื่นอย่างไร?',
    answer: 'ต้องรวมรายได้ทุกประเภทในแบบ ภ.ง.ด.90 เดียวกัน แต่หักค่าใช้จ่ายแยกตามอัตราของแต่ละประเภทรายได้',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณภาษีเงินได้ผู้ประกอบการรายย่อย 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีผู้ประกอบการรายย่อย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">สำหรับเจ้าของกิจการและผู้ประกอบอาชีพอิสระ</p>
      <p class="mt-1 text-sm text-slate-700">ประเภท 40(2) ค่าจ้าง และ 40(8) ธุรกิจทั่วไป</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณภาษีเงินได้ผู้ประกอบการรายย่อย 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณภาษีเงินได้สำหรับผู้มีรายได้จากธุรกิจหรืออาชีพอิสระ
      เปรียบเทียบการหักค่าใช้จ่ายเหมากับค่าใช้จ่ายจริง
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูลรายได้และค่าใช้จ่าย</h2>
      <form id="sme-form" class="space-y-5">
        <div>
          <label for="income-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทรายได้หลัก</label>
          <select id="income-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="40_2">40(2) ค่าจ้าง / รับจ้างทำงาน (หักเหมา 50% สูงสุด 100,000)</option>
            <option value="40_8_commerce">40(8) พาณิชย์ / อุตสาหกรรม (หักเหมา 60%)</option>
            <option value="40_8_service">40(8) บริการ (หักเหมา 60%)</option>
          </select>
        </div>

        <div>
          <label for="annual-revenue" class="block text-sm font-medium text-gray-700 mb-1">รายได้ทั้งปีก่อนหักค่าใช้จ่าย (บาท)</label>
          <input type="text" id="annual-revenue" inputmode="numeric" placeholder="เช่น 800,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>

        <div>
          <label for="actual-expense" class="block text-sm font-medium text-gray-700 mb-1">ค่าใช้จ่ายจริงทั้งปี (บาท) — ไม่บังคับ</label>
          <input type="text" id="actual-expense" inputmode="numeric" placeholder="เช่น 250,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">กรอกเพื่อเปรียบเทียบกับค่าใช้จ่ายเหมา ระบบจะแนะนำวิธีที่เสียภาษีน้อยกว่า</p>
        </div>

        <div>
          <label for="total-deductions" class="block text-sm font-medium text-gray-700 mb-1">ค่าลดหย่อนรวมทั้งปี (บาท)</label>
          <input type="text" id="total-deductions" inputmode="numeric" placeholder="เช่น 100,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">ค่าลดหย่อนส่วนตัว 60,000 + ประกันสังคม 9,000 = 69,000 บาทขั้นต่ำ</p>
        </div>

        <button type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div id="r-recommendation" class="rounded-xl p-4 mb-6 bg-primary-50 border border-primary-100 hidden">
          <div id="r-rec-text" class="text-sm font-semibold text-primary-800"></div>
        </div>
        <div class="grid gap-3 sm:grid-cols-2 mb-4">
          <div class="border border-blue-200 rounded-lg p-4 bg-blue-50">
            <div class="text-sm font-semibold text-blue-800 mb-2">หักค่าใช้จ่ายเหมา</div>
            <div class="text-xs text-gray-500 mb-2" id="r-std-rate">-</div>
            <div class="space-y-1 text-sm">
              <div class="flex justify-between"><span class="text-gray-600">ค่าใช้จ่ายเหมา</span><span id="r-std-expense" class="font-medium text-red-600">-</span></div>
              <div class="flex justify-between"><span class="text-gray-600">รายได้สุทธิ</span><span id="r-std-net" class="font-medium">-</span></div>
              <div class="flex justify-between font-bold"><span>ภาษีที่ต้องชำระ</span><span id="r-std-tax" class="text-primary-700">-</span></div>
            </div>
          </div>
          <div id="actual-col" class="border border-green-200 rounded-lg p-4 bg-green-50 hidden">
            <div class="text-sm font-semibold text-green-800 mb-2">หักค่าใช้จ่ายจริง</div>
            <div class="text-xs text-gray-500 mb-2">ตามหลักฐานจริง</div>
            <div class="space-y-1 text-sm">
              <div class="flex justify-between"><span class="text-gray-600">ค่าใช้จ่ายจริง</span><span id="r-act-expense" class="font-medium text-red-600">-</span></div>
              <div class="flex justify-between"><span class="text-gray-600">รายได้สุทธิ</span><span id="r-act-net" class="font-medium">-</span></div>
              <div class="flex justify-between font-bold"><span>ภาษีที่ต้องชำระ</span><span id="r-act-tax" class="text-green-700">-</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">อัตราค่าใช้จ่ายเหมาตามประเภทรายได้</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-3 py-2 text-left border-b">ประเภทรายได้</th>
              <th class="px-3 py-2 text-right border-b">อัตราเหมา</th>
              <th class="px-3 py-2 text-right border-b">เพดาน</th>
            </tr>
          </thead>
          <tbody>
            <tr><td class="px-3 py-2 border-b">40(1) เงินเดือน / 40(2) ค่าจ้าง</td><td class="px-3 py-2 text-right border-b">50%</td><td class="px-3 py-2 text-right border-b">100,000 บาท</td></tr>
            <tr><td class="px-3 py-2 border-b">40(8) พาณิชย์ / อุตสาหกรรม</td><td class="px-3 py-2 text-right border-b">60%</td><td class="px-3 py-2 text-right border-b">ไม่มีเพดาน</td></tr>
            <tr><td class="px-3 py-2">40(8) บริการทั่วไป</td><td class="px-3 py-2 text-right">60%</td><td class="px-3 py-2 text-right">ไม่มีเพดาน</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.rd.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมสรรพากร (rd.go.th)</a> — อัตราภาษีเงินได้บุคคลธรรมดาและนิติบุคคล</li>
        <li><a href="https://www.rd.go.th/publish/20595.0.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ตารางภาษีเงินได้บุคคลธรรมดา — กรมสรรพากร 2567/2568</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณภาษีผู้ประกอบการรายย่อย/" />
    <RelatedCalculators currentHref="/คำนวณภาษีผู้ประกอบการรายย่อย/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ อ้างอิงอัตราภาษีปี 2569 จากกรมสรรพากร กรุณาปรึกษานักบัญชีหรือผู้เชี่ยวชาญด้านภาษีสำหรับกรณีเฉพาะ
    </div>
  </article>

  <script>
    const TAX_BRACKETS = [
      { min: 0, max: 150_000, rate: 0 },
      { min: 150_000, max: 300_000, rate: 0.05 },
      { min: 300_000, max: 500_000, rate: 0.10 },
      { min: 500_000, max: 750_000, rate: 0.15 },
      { min: 750_000, max: 1_000_000, rate: 0.20 },
      { min: 1_000_000, max: 2_000_000, rate: 0.25 },
      { min: 2_000_000, max: 5_000_000, rate: 0.30 },
      { min: 5_000_000, max: Infinity, rate: 0.35 },
    ];

    const EXPENSE_RATES: Record<string, { rate: number; cap: number; label: string }> = {
      '40_2': { rate: 0.5, cap: 100_000, label: '50% สูงสุด 100,000 บาท' },
      '40_8_commerce': { rate: 0.6, cap: Infinity, label: '60% ไม่มีเพดาน' },
      '40_8_service': { rate: 0.6, cap: Infinity, label: '60% ไม่มีเพดาน' },
    };

    function parseNum(v: string) { return Math.max(0, parseFloat((v || '0').replace(/,/g, '')) || 0); }
    function fmt(n: number) { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' บาท'; }

    function calcTax(netIncome: number): number {
      let remaining = Math.max(0, netIncome);
      let tax = 0;
      for (const b of TAX_BRACKETS) {
        const w = b.max === Infinity ? Infinity : b.max - b.min;
        const taxable = Math.min(remaining, w);
        tax += taxable * b.rate;
        remaining -= taxable;
        if (remaining <= 0) break;
      }
      return tax;
    }

    const form = document.getElementById('sme-form') as HTMLFormElement;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const incomeType = (document.getElementById('income-type') as HTMLSelectElement).value;
      const annualRevenue = parseNum((document.getElementById('annual-revenue') as HTMLInputElement).value);
      const actualExpense = parseNum((document.getElementById('actual-expense') as HTMLInputElement).value);
      const deductions = parseNum((document.getElementById('total-deductions') as HTMLInputElement).value);

      if (annualRevenue <= 0) return;

      const er = EXPENSE_RATES[incomeType];
      const stdExpense = er.cap === Infinity ? annualRevenue * er.rate : Math.min(annualRevenue * er.rate, er.cap);
      const stdNet = Math.max(0, annualRevenue - stdExpense - deductions);
      const stdTax = calcTax(stdNet);

      (document.getElementById('r-std-rate') as HTMLElement).textContent = `อัตราเหมา: ${er.label}`;
      (document.getElementById('r-std-expense') as HTMLElement).textContent = '-' + fmt(stdExpense);
      (document.getElementById('r-std-net') as HTMLElement).textContent = fmt(stdNet);
      (document.getElementById('r-std-tax') as HTMLElement).textContent = fmt(stdTax);

      const recEl = document.getElementById('r-recommendation') as HTMLElement;
      const recText = document.getElementById('r-rec-text') as HTMLElement;
      const actualCol = document.getElementById('actual-col') as HTMLElement;

      if (actualExpense > 0) {
        const actNet = Math.max(0, annualRevenue - actualExpense - deductions);
        const actTax = calcTax(actNet);

        (document.getElementById('r-act-expense') as HTMLElement).textContent = '-' + fmt(actualExpense);
        (document.getElementById('r-act-net') as HTMLElement).textContent = fmt(actNet);
        (document.getElementById('r-act-tax') as HTMLElement).textContent = fmt(actTax);
        actualCol.classList.remove('hidden');

        const saving = Math.abs(stdTax - actTax);
        if (actTax < stdTax) {
          recText.textContent = `✅ แนะนำ: หักค่าใช้จ่ายจริง ประหยัดภาษีได้ ${fmt(saving)}`;
        } else if (stdTax < actTax) {
          recText.textContent = `✅ แนะนำ: หักค่าใช้จ่ายเหมา ประหยัดภาษีได้ ${fmt(saving)}`;
        } else {
          recText.textContent = `ทั้งสองวิธีให้ผลเท่ากัน`;
        }
        recEl.classList.remove('hidden');
      } else {
        actualCol.classList.add('hidden');
        recEl.classList.add('hidden');
      }

      const resultsDiv = document.getElementById('results') as HTMLElement;
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('self_employed_tax');
      trackCalculatorUsed('self_employed_tax');
    });

    form.addEventListener('input', () => { trackCalculatorStart('self_employed_tax'); }, { once: true });
  </script>
</BaseLayout>
