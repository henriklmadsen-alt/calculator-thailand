---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าเอกสารวีซ่าเด็ก | Calculator Thailand';
const pageDescription = 'คำนวณค่าปกครองเด็ก ค่าวีซ่า ค่าพาสปอร์ต';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0613-ค่าใบอนุญาตเด็ก/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าใบอนุญาตเด็ก">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเอกสารวีซ่าเด็ก</h1>
    <div class="mb-4 inline-block rounded-lg border border-amber-200 bg-amber-50 px-3 py-2"><p class="text-xs font-semibold text-amber-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าปกครอง ค่าวีซ่า พาสปอร์ต กรรมการเด็ก</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="passport" class="block text-sm font-medium text-gray-700 mb-1">ค่าทำพาสปอร์ต (บาท)</label><input type="text" id="passport" inputmode="decimal" placeholder="เช่น 400" value="400" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="visa" class="block text-sm font-medium text-gray-700 mb-1">ค่าวีซ่า (บาท)</label><input type="text" id="visa" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="guardianship" class="block text-sm font-medium text-gray-700 mb-1">ค่าปกครองเด็ก (บาท)</label><input type="text" id="guardianship" inputmode="decimal" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="other" class="block text-sm font-medium text-gray-700 mb-1">ค่าอื่นๆ (บาท)</label><input type="text" id="other" inputmode="decimal" placeholder="เช่น 200" value="200" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-amber-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-amber-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมค่าใบอนุญาต</p>
            <p id="total" class="font-bold">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">พาสปอร์ตเด็กใช้ได้นานเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">พาสปอร์ตเด็กไทย อายุ 5 ปี (ต่างจากผู้ใหญ่ 10 ปี) ยังต้องมีผู้ปกครองลง นาม</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">วีซ่าใด์อายุกี่ปี?</h3>
            <p class="text-gray-600 text-sm">วีซ่า Dependent ใช้ได้ตามวีซ่าผู้ปกครอง บ้านต้องยื่นเอกสารปกครอง</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่าปกครองเด็กระดับเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">ตามสถานทูต ประมาณ 500-1,000 บาท ตัดสินจากประเทศ และเงื่อนไข</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const passport = parseFloat((document.getElementById('passport') as HTMLInputElement).value) || 0;
      const visa = parseFloat((document.getElementById('visa') as HTMLInputElement).value) || 0;
      const guardianship = parseFloat((document.getElementById('guardianship') as HTMLInputElement).value) || 0;
      const other = parseFloat((document.getElementById('other') as HTMLInputElement).value) || 0;

      const total = passport + visa + guardianship + other;

      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('dependent-documents');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
