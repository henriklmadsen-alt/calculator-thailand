---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณผลตอบแทนจริงหลังภาษีและเงินเฟ้อ 2569 | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณผลตอบแทนที่แท้จริงหลังหักทั้งภาษีและเงินเฟ้อ เพื่อเปรียบเทียบทางเลือกลงทุน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณผลตอบแทนจริง/`;

const faqData = [
  {
    question: 'ภาษีดอกเบี้ยและเงินปันผลในไทยเป็นเท่าไหร่?',
    answer: 'ดอกเบี้ยเงินฝากและตราสารหนี้ถูกหักภาษี ณ ที่จ่าย 15% เงินปันผลหุ้นถูกหัก 10% แต่สามารถเลือกนำมารวมในการคำนวณภาษีเงินได้บุคคลธรรมดาเพื่อขอคืนได้ กองทุนรวมหุ้นไทยบางประเภทได้รับยกเว้นภาษีกำไร',
  },
  {
    question: 'ทำไมผลตอบแทนหลังภาษีและเงินเฟ้อถึงสำคัญ?',
    answer: 'เพราะเป็นตัวเลขที่สะท้อนความมั่งคั่งที่แท้จริง ผลตอบแทนก่อนภาษีอาจดูน่าสนใจ แต่หลังหักภาษีและเงินเฟ้อแล้วอาจได้กำลังซื้อเพิ่มขึ้นน้อยมาก การเปรียบเทียบทางเลือกลงทุนต่างๆ ด้วยตัวเลขหลังภาษีและเงินเฟ้อจะแม่นยำกว่า',
  },
  {
    question: 'จะลดภาระภาษีการลงทุนได้อย่างไร?',
    answer: 'ลงทุนในกองทุน SSF/RMF เพื่อลดหย่อนภาษีเงินได้ ใช้กองทุนรวมตราสารทุนแทนดอกเบี้ยตรง พิจารณาลงทุนในหุ้นระยะยาวซึ่งกำไรส่วนทุนไม่ถูกเก็บภาษีในไทย และกระจายสินทรัพย์เพื่อใช้สิทธิ์ยกเว้นภาษีอย่างมีประสิทธิภาพ',
  },
];

const taxRates = [0, 5, 10, 15, 20, 25, 30, 35];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผลตอบแทนจริงหลังภาษีและเงินเฟ้อ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผลตอบแทนจริง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณผลตอบแทนจริงหลังภาษีและเงินเฟ้อ 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณผลตอบแทนที่แท้จริงหลังหักทั้งภาษีและเงินเฟ้อ เพื่อเปรียบเทียบทางเลือกลงทุน
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="real-return-form" class="space-y-5">
        <p id="real-return-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="rr-nominal" class="block text-sm font-medium text-gray-700 mb-1">ผลตอบแทนก่อนภาษี (%/ปี)</label>
            <input type="text" id="rr-nominal" inputmode="decimal" placeholder="เช่น 7"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="rr-nominal-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="rr-tax" class="block text-sm font-medium text-gray-700 mb-1">อัตราภาษี (%)</label>
            <select id="rr-tax" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
              {taxRates.map(t => (
                <option value={t} selected={t === 15}>{t}%</option>
              ))}
            </select>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="rr-inflation" class="block text-sm font-medium text-gray-700 mb-1">อัตราเงินเฟ้อ (%/ปี)</label>
            <input type="text" id="rr-inflation" inputmode="decimal" placeholder="เช่น 3.5" value="3.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
            <p id="rr-inflation-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" id="real-return-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-2 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ผลตอบแทนหลังภาษี (%/ปี)</div>
            <div id="res-after-tax" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ผลตอบแทนจริงหลังภาษีและเงินเฟ้อ (%/ปี)</div>
            <div id="res-real" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="overflow-x-auto mt-4">
          <h3 class="text-sm font-semibold text-gray-700 mb-2">ตารางเปรียบเทียบอัตราภาษี</h3>
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-gray-500 border-b border-gray-200">
                <th class="py-2 pr-3">อัตราภาษี</th>
                <th class="py-2 pr-3 text-right">หลังภาษี</th>
                <th class="py-2 text-right">หลังภาษี+เงินเฟ้อ</th>
              </tr>
            </thead>
            <tbody id="rr-comparison-body"></tbody>
          </table>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณผลตอบแทนจริงหลังภาษีและเงินเฟ้อ</h2>
      <p>ผลตอบแทนหลังภาษี = ผลตอบแทนก่อนภาษี × (1 - อัตราภาษี/100)<br />ผลตอบแทนจริงหลังภาษี = ((1 + ผลตอบแทนหลังภาษี/100) / (1 + เงินเฟ้อ/100)) - 1</p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการเปรียบเทียบ</h3>
      <p>หากได้ผลตอบแทน 7%/ปี ภาษี 15% เงินเฟ้อ 3.5%<br />ผลตอบแทนหลังภาษี = 7% × 0.85 = 5.95%<br />ผลตอบแทนจริง = (1.0595/1.035) - 1 = 2.37%</p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณผลตอบแทนจริง/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น อัตราภาษีจริงขึ้นอยู่กับชนิดของรายได้และสถานการณ์ส่วนบุคคล ไม่ถือเป็นคำแนะนำทางการเงินหรือภาษี
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return parseFloat(v.replace(/,/g, '')) || 0; }
    function fmt2(n: number): string { return n.toFixed(2); }
    const form = document.getElementById('real-return-form') as HTMLFormElement;
    const submitBtn = document.getElementById('real-return-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('real-return-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const nominalInput = document.getElementById('rr-nominal') as HTMLInputElement;
    const inflationInput = document.getElementById('rr-inflation') as HTMLInputElement;
    function setFieldError(id: string, msg: string) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.remove('hidden'); }
    function clearFieldError(id: string) { const el = document.getElementById(id); if (!el) return; el.textContent = ''; el.classList.add('hidden'); }
    function clearValidation() { formError.classList.add('hidden'); ['rr-nominal-error','rr-inflation-error'].forEach(clearFieldError); }
    [nominalInput, inflationInput].forEach(input => { input.addEventListener('input', clearValidation); });
    form.addEventListener('submit', (e) => {
      e.preventDefault(); clearValidation();
      const nominal = parseNum(nominalInput.value);
      const taxRate = parseFloat((document.getElementById('rr-tax') as HTMLSelectElement).value) || 0;
      const inflation = parseNum(inflationInput.value);
      let hasError = false;
      if (isNaN(nominal) || nominalInput.value.trim() === '') { setFieldError('rr-nominal-error', 'กรุณากรอกผลตอบแทนก่อนภาษี'); hasError = true; }
      if (isNaN(inflation) || inflationInput.value.trim() === '') { setFieldError('rr-inflation-error', 'กรุณากรอกอัตราเงินเฟ้อ'); hasError = true; }
      if (hasError) { formError.classList.remove('hidden'); return; }
      submitBtn.disabled = true; submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('real-after-tax-return');
      const afterTax = nominal * (1 - taxRate / 100);
      const realAfterTax = ((1 + afterTax / 100) / (1 + inflation / 100) - 1) * 100;
      (document.getElementById('res-after-tax') as HTMLElement).textContent = fmt2(afterTax) + '%';
      (document.getElementById('res-real') as HTMLElement).textContent = fmt2(realAfterTax) + '%';
      const tbody = document.getElementById('rr-comparison-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';
      const allRates = [0, 5, 10, 15, 20, 25, 30, 35];
      allRates.forEach(t => {
        const at = nominal * (1 - t / 100);
        const rat = ((1 + at / 100) / (1 + inflation / 100) - 1) * 100;
        const tr = document.createElement('tr');
        tr.className = t === taxRate ? 'border-b border-gray-100 bg-primary-50 font-semibold' : 'border-b border-gray-100';
        tr.innerHTML = `<td class="py-2 pr-3">${t}%</td><td class="py-2 pr-3 text-right">${fmt2(at)}%</td><td class="py-2 text-right ${rat < 0 ? 'text-red-600' : ''}">${fmt2(rat)}%</td>`;
        tbody.appendChild(tr);
      });
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false; submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('real-after-tax-return');
      trackCalculatorUsed('real-after-tax-return');
    });
  </script>
</BaseLayout>
