---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณอัตราการออม 2569 | เช็คเป้าหมายออมเงิน | Kamnuanlek';
const pageDescription = 'คำนวณอัตราการออมจากรายได้และรายจ่ายรายเดือน พร้อมเปรียบเทียบกับเป้าหมายแนะนำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณอัตราออม/`;

const faqData = [
  {
    question: 'อัตราการออมที่ดีควรเป็นเท่าไร?',
    answer: 'ตามกฎ 50-30-20 แนะนำให้ออมอย่างน้อย 20% ของรายได้สุทธิ แบ่งเป็นกองฉุกเฉิน ออมเกษียณ และเป้าหมายระยะกลาง หากออมได้ 30% ขึ้นไปถือว่าดีมาก',
  },
  {
    question: 'หากออมไม่ถึง 20% ควรทำอย่างไร?',
    answer: 'เริ่มจากตรวจสอบรายจ่ายที่ลดได้ เช่น ค่าสมาชิก ค่าอาหารนอกบ้าน หรือค่าบันเทิง จากนั้นตั้งเป้าหมายเพิ่มอัตราออมทีละ 1-2% ต่อเดือนจนถึง 20% และตั้งโอนเงินอัตโนมัติเข้าบัญชีออม',
  },
  {
    question: 'กฎ 50-30-20 คืออะไร?',
    answer: 'กฎ 50-30-20 คือหลักการจัดสรรเงินเดือน โดยใช้ 50% สำหรับความจำเป็น (ค่าเช่า อาหาร เดินทาง), 30% สำหรับต้องการ (บันเทิง ช้อปปิ้ง), และ 20% สำหรับออมและลงทุน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณอัตราการออม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณอัตราออม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณอัตราการออม 2569</h1>
    <p class="mb-6 text-gray-600">กรอกรายได้และรายจ่ายต่อเดือนเพื่อดูว่าคุณออมได้กี่เปอร์เซ็นต์ และเทียบกับเป้าหมาย 20% ตามกฎ 50-30-20 หากต้องการวางแผนเกษียณเพิ่มเติม ดูที่ <a href="/คำนวณเงินสมทบเกษียณ/" class="text-primary-600 underline hover:text-primary-800">คำนวณเงินสมทบเกษียณ</a> หรือ <a href="/คำนวณเป้าลดค่าใช้จ่าย/" class="text-primary-600 underline hover:text-primary-800">คำนวณเป้าลดค่าใช้จ่าย</a></p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="savings-form" class="space-y-4">
        <div>
          <label for="income" class="mb-1 block text-sm font-medium text-gray-700">รายได้ต่อเดือน (บาท)</label>
          <input id="income" type="text" inputmode="numeric" placeholder="เช่น 40000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="expense" class="mb-1 block text-sm font-medium text-gray-700">รายจ่ายทั้งหมดต่อเดือน (บาท)</label>
          <input id="expense" type="text" inputmode="numeric" placeholder="เช่น 30000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินออมต่อเดือน</div>
            <div id="res-saved" class="text-3xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">อัตราออม</div>
            <div id="res-rate" class="text-3xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เทียบเป้า 20%</div>
            <div id="res-vs-target" class="text-2xl font-bold text-orange-700">-</div>
          </div>
        </div>
        <div id="res-msg" class="rounded-lg p-3 text-sm font-medium"></div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณอัตราออม/" categoryId="budget" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('savings-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const income = parseNum((document.getElementById('income') as HTMLInputElement).value);
    const expense = parseNum((document.getElementById('expense') as HTMLInputElement).value);

    if (income <= 0) return;

    const saved = Math.max(0, income - expense);
    const rate = (saved / income) * 100;
    const target20 = income * 0.2;
    const diff = saved - target20;

    document.getElementById('res-saved')!.textContent = fmt(saved);
    document.getElementById('res-rate')!.textContent = rate.toFixed(1) + '%';

    const vsEl = document.getElementById('res-vs-target')!;
    if (diff >= 0) {
      vsEl.textContent = 'เกินเป้า ' + fmt(diff);
      vsEl.className = 'text-2xl font-bold text-green-700';
    } else {
      vsEl.textContent = 'ขาด ' + fmt(Math.abs(diff));
      vsEl.className = 'text-2xl font-bold text-red-600';
    }

    const msgEl = document.getElementById('res-msg')!;
    if (rate >= 30) {
      msgEl.textContent = '🎉 ยอดเยี่ยม! คุณออมได้มากกว่า 30% ถือว่าดีมาก';
      msgEl.className = 'rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800';
    } else if (rate >= 20) {
      msgEl.textContent = '✅ ดี! คุณออมได้ถึงเป้า 20% ตามกฎ 50-30-20 แล้ว';
      msgEl.className = 'rounded-lg bg-blue-50 p-3 text-sm font-medium text-blue-800';
    } else if (rate >= 10) {
      msgEl.textContent = '⚠️ พอใช้ได้ แต่ควรพยายามเพิ่มอัตราออมให้ถึง 20%';
      msgEl.className = 'rounded-lg bg-yellow-50 p-3 text-sm font-medium text-yellow-800';
    } else {
      msgEl.textContent = '❌ อัตราออมยังน้อย ลองตรวจสอบรายจ่ายที่ลดได้เพื่อเพิ่มการออม';
      msgEl.className = 'rounded-lg bg-red-50 p-3 text-sm font-medium text-red-800';
    }

    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
