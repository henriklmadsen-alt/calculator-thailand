---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณรายได้งานพาร์ทไทม์ ปี 2569 ค่าชั่วโมง × ชั่วโมง × วัน/เดือน | Kamnuanlek';
const pageDescription = 'คำนวณรายได้งานพาร์ทไทม์ จากอัตราค่าจ้างต่อชั่วโมง × ชั่วโมงต่อวัน × วันทำงานต่อเดือน พร้อมสรุปรายได้รวมต่อเดือนและต่อปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณรายได้งานพาร์ทไทม์/`;

const faqData = [
  {
    question: 'งานพาร์ทไทม์ต้องมีสัญญาจ้างไหม?',
    answer: 'แนะนำให้มีสัญญาจ้างเพื่อป้องกันข้อพิพาท แต่กฎหมายไม่ได้บังคับว่าต้องเป็นลายลักษณ์อักษร ควรระบุอัตราค่าจ้าง ชั่วโมงทำงาน และเงื่อนไขการจ้างให้ชัดเจน',
  },
  {
    question: 'งานพาร์ทไทม์ต้องเสียภาษีไหม?',
    answer: 'ถ้ารายได้เกิน 60,000 บาทต่อปี (ค่าลดหย่อนส่วนตัว) ต้องยื่นแบบภาษีเงินได้บุคคลธรรมดา รายได้จากงานประจำ + พาร์ทไทม์รวมกัน',
  },
  {
    question: 'พาร์ทไทม์มีสิทธิ์ประกันสังคมไหม?',
    answer: 'ลูกจ้างที่ทำงานพาร์ทไทม์กับนายจ้างในระบบ (มาตรา 33) มีสิทธิ์ประกันสังคม แต่ถ้าเป็นงานอิสระต้องสมัครมาตรา 40 เอง',
  },
  {
    question: 'อัตราค่าจ้างพาร์ทไทม์ขั้นต่ำเท่าไร?',
    answer: 'ต้องไม่น้อยกว่าค่าแรงขั้นต่ำตามประกาศคณะกรรมการค่าจ้าง ซึ่งปี 2569 แตกต่างตามจังหวัด ตั้งแต่ 330-400+ บาท/วัน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณรายได้งานพาร์ทไทม์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณรายได้งานพาร์ทไทม์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณรายได้พาร์ทไทม์ได้หลายแบบ</p>
      <p class="mt-1 text-sm text-slate-700">อัตราชั่วโมง × ชั่วโมง/วัน × วัน/เดือน = รายได้รายเดือน</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับนักศึกษา พนักงานพาร์ทไทม์ และผู้ที่มีงานเสริม</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณรายได้งานพาร์ทไทม์ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกอัตราค่าจ้างต่อชั่วโมง จำนวนชั่วโมงต่อวัน และวันทำงานต่อเดือน ระบบจะคำนวณรายได้รวม
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="parttime-form" class="space-y-5">
        <p id="parttime-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="pt-hourly-rate" class="mb-1 block text-sm font-medium text-gray-700">ค่าจ้างต่อชั่วโมง (บาท)</label>
            <input type="text" id="pt-hourly-rate" inputmode="numeric" placeholder="เช่น 60"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="pt-hourly-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="pt-hours-day" class="mb-1 block text-sm font-medium text-gray-700">ชั่วโมงทำงานต่อวัน</label>
            <input type="text" id="pt-hours-day" inputmode="decimal" placeholder="เช่น 4"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="pt-hours-day-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="pt-days-month" class="mb-1 block text-sm font-medium text-gray-700">วันทำงานต่อเดือน</label>
            <input type="text" id="pt-days-month" inputmode="numeric" placeholder="เช่น 20"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="pt-days-month-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณรายได้พาร์ทไทม์
        </button>
      </form>
    </div>

    <div id="parttime-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายได้รายเดือน</div>
            <div id="res-pt-monthly" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายได้รายวัน</div>
            <div id="res-pt-daily" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">รายได้รายปี (ประมาณ)</div>
            <div id="res-pt-annual" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ชั่วโมงทำงานรวม/เดือน</span>
            <span id="res-pt-hours" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>รายได้รายวัน = ค่าจ้าง/ชั่วโมง × ชั่วโมงทำงาน/วัน</li>
        <li>รายได้รายเดือน = รายได้รายวัน × วันทำงาน/เดือน</li>
        <li>รายได้รายปี = รายได้รายเดือน × 12</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณรายได้ฟรีแลนซ์รายเดือน/">คำนวณรายได้ฟรีแลนซ์รายเดือน</a></li>
        <li><a href="/คำนวณค่าจ้างรายวัน/">คำนวณค่าจ้างรายวัน</a></li>
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#parttime-results" />
    <RelatedArticles currentHref="/คำนวณรายได้งานพาร์ทไทม์/" />
    <RelatedCalculators currentHref="/คำนวณรายได้งานพาร์ทไทม์/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ รายได้จริงขึ้นอยู่กับชั่วโมงทำงานจริงและเงื่อนไขในสัญญา
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('parttime-form');
    const formError = document.getElementById('parttime-form-error');
    const resultBox = document.getElementById('parttime-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['pt-hourly-rate-error','pt-hours-day-error','pt-days-month-error'].forEach((id) => setErr(id, ''));

      const hourlyRate = parseNum(document.getElementById('pt-hourly-rate').value);
      const hoursDay = parseNum(document.getElementById('pt-hours-day').value);
      const daysMonth = parseNum(document.getElementById('pt-days-month').value);

      let hasError = false;
      if (!Number.isFinite(hourlyRate) || hourlyRate <= 0) { setErr('pt-hourly-rate-error', 'กรอกค่าจ้าง/ชั่วโมงมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(hoursDay) || hoursDay <= 0 || hoursDay > 24) { setErr('pt-hours-day-error', 'กรอกชั่วโมง 1-24'); hasError = true; }
      if (!Number.isFinite(daysMonth) || daysMonth <= 0 || daysMonth > 31) { setErr('pt-days-month-error', 'กรอกวันทำงาน 1-31 วัน'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const dailyIncome = hourlyRate * hoursDay;
      const monthlyIncome = dailyIncome * daysMonth;
      const annualIncome = monthlyIncome * 12;
      const totalHours = hoursDay * daysMonth;

      setText('res-pt-monthly', formatMoney(monthlyIncome));
      setText('res-pt-daily', formatMoney(dailyIncome));
      setText('res-pt-annual', formatMoney(annualIncome));
      setText('res-pt-hours', `${new Intl.NumberFormat('th-TH').format(totalHours)} ชั่วโมง`);

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
