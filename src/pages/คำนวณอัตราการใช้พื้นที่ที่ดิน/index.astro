---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณอัตราการใช้พื้นที่ที่ดิน (Lot Coverage) 2569 | พื้นที่อาคาร | Kamnuanlek';
const pageDescription = 'คำนวณ Lot Coverage Ratio (อัตราการใช้พื้นที่ที่ดิน) = พื้นที่อาคาร ÷ พื้นที่ที่ดินทั้งหมด เพื่อวิเคราะห์การใช้พื้นที่ ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณอัตราการใช้พื้นที่ที่ดิน/`;

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ Lot Coverage Ratio',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณอัตราการใช้พื้นที่ที่ดิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณ Lot Coverage Ratio ปี 2569</h1>
    <p class="text-gray-600 mb-6">คำนวณอัตราการใช้พื้นที่ที่ดินสำหรับการออกแบบโครงการและการปฏิบัติตามข้อบังคับการใช้ที่ดิน</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="lot-coverage-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="building-area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่อาคาร (ตร.ม. หรือ ตร.ว.)</label>
            <input id="building-area" type="text" inputmode="numeric" placeholder="เช่น 400" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="land-area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่ที่ดิน (ตร.ม. หรือ ตร.ว.)</label>
            <input id="land-area" type="text" inputmode="numeric" placeholder="เช่น 1000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณอัตราการใช้พื้นที่
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="rounded-lg bg-primary-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">Lot Coverage Ratio</div>
          <div id="res-lot-coverage" class="text-2xl font-bold text-primary-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">พื้นที่อาคาร</span>
            <span id="res-building-area" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">พื้นที่ที่ดิน</span>
            <span id="res-land-area" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">Lot Coverage Ratio (พื้นที่อาคาร ÷ พื้นที่ที่ดิน)</span>
            <span id="res-calc-coverage" class="font-bold text-lg text-primary-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <RelatedCalculators currentHref="/คำนวณอัตราการใช้พื้นที่ที่ดิน/" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  const form = document.querySelector('#lot-coverage-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const buildingArea = parseNumber(document.querySelector('#building-area')?.value || '');
    const landArea = parseNumber(document.querySelector('#land-area')?.value || '');

    if (!(Number.isFinite(buildingArea) && buildingArea > 0 && Number.isFinite(landArea) && landArea > 0 && landArea >= buildingArea)) {
      results?.classList.add('hidden');
      return;
    }

    const lotCoverage = (buildingArea / landArea) * 100;

    document.querySelector('#res-lot-coverage').textContent = lotCoverage.toFixed(2) + '%';
    document.querySelector('#res-building-area').textContent = buildingArea.toFixed(2) + ' ตร.ม./ว.';
    document.querySelector('#res-land-area').textContent = landArea.toFixed(2) + ' ตร.ม./ว.';
    document.querySelector('#res-calc-coverage').textContent = lotCoverage.toFixed(2) + '%';

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
