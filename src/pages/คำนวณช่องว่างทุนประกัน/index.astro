---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณช่องว่างทุนประกัน (Sum Assured Gap) 2569 | ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณช่องว่างทุนประกันชีวิต 2569 เปรียบเทียบทุนประกันที่มีอยู่กับที่ต้องการตามรายได้ หนี้สิน และภาระครอบครัว รู้ว่าควรซื้อประกันเพิ่มเท่าไร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณช่องว่างทุนประกัน/`;

const faqData = [
  { question: 'ช่องว่างทุนประกันคืออะไร?', answer: 'ช่องว่างทุนประกัน (Sum Assured Gap) คือส่วนต่างระหว่างทุนประกันที่ควรมีกับที่มีอยู่จริง หากมีช่องว่าง แสดงว่าครอบครัวจะได้รับเงินไม่เพียงพอหากเกิดเหตุ' },
  { question: 'ทุนประกันควรเป็นกี่เท่าของรายได้?', answer: 'กฎทั่วไปคือ 5-10 เท่าของรายได้ต่อปี บวกหนี้สินทั้งหมด และค่าใช้จ่ายครอบครัวที่ต้องการคุ้มครอง เช่น ค่าเล่าเรียนบุตร' },
  { question: 'ควรนับประกันกลุ่มจากที่ทำงานไหม?', answer: 'ควรนับ แต่ประกันกลุ่มมักได้แค่ 1-3 เท่าของเงินเดือน และหมดอายุเมื่อออกจากงาน ดังนั้นควรมีประกันส่วนตัวเพิ่มเติม' },
  { question: 'วิธีลดช่องว่างทุนประกัน?', answer: 'ซื้อประกันเพิ่มเติม โดยเริ่มจากประกันชั่วระยะเวลา (Term Life) ที่เบี้ยถูกที่สุดต่อหน่วยทุนประกัน เพื่อปิดช่องว่างให้เร็วที่สุดในงบประมาณที่มี' },
];

const jsonLdWebApp = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'เครื่องคำนวณช่องว่างทุนประกัน 2569', description: pageDescription, url: canonical, applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' }, inLanguage: 'th' };
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณช่องว่างทุนประกัน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">วิเคราะห์ช่องว่างทุนประกันชีวิต</p>
      <p class="mt-1 text-sm text-slate-700">ตรวจสอบว่าประกันที่มีอยู่เพียงพอหรือยัง</p>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณช่องว่างทุนประกัน 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">เปรียบเทียบทุนประกันที่ควรมีกับที่มีอยู่จริง และคำนวณว่าต้องซื้อประกันเพิ่มเท่าไร</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูล</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>
        <div>
          <label for="annual-income" class="block text-sm font-medium text-gray-700 mb-1">รายได้ต่อปี (บาท)</label>
          <input type="text" id="annual-income" inputmode="numeric" placeholder="เช่น 600,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="income-multiplier" class="block text-sm font-medium text-gray-700 mb-1">จำนวนปีรายได้ที่ต้องการคุ้มครอง</label>
          <select id="income-multiplier" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="5">5 ปี (ขั้นต่ำ)</option>
            <option value="7" selected>7 ปี (แนะนำ)</option>
            <option value="10">10 ปี (ปลอดภัย)</option>
          </select>
        </div>
        <div>
          <label for="total-debt" class="block text-sm font-medium text-gray-700 mb-1">หนี้สินรวม (บาท)</label>
          <input type="text" id="total-debt" inputmode="numeric" placeholder="เช่น 2,000,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="existing-coverage" class="block text-sm font-medium text-gray-700 mb-1">ทุนประกันที่มีอยู่แล้ว (บาท)</label>
          <input type="text" id="existing-coverage" inputmode="numeric" placeholder="เช่น 500,000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">คำนวณช่องว่างทุนประกัน</button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการวิเคราะห์</h2>
      <div class="grid gap-4 sm:grid-cols-3 mb-4">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-center"><p class="text-xs text-blue-700 mb-1">ทุนประกันที่ควรมี</p><p class="text-2xl font-bold text-blue-700" id="needed">-</p></div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center"><p class="text-xs text-green-700 mb-1">ทุนประกันที่มีอยู่</p><p class="text-2xl font-bold text-green-700" id="existing">-</p></div>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-center"><p class="text-xs text-red-700 mb-1">ช่องว่าง (ต้องซื้อเพิ่ม)</p><p class="text-2xl font-bold text-red-700" id="gap">-</p></div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณทุนประกันที่ควรมี</h2>
      <p>สูตรที่ใช้กันทั่วไป: <strong>ทุนประกันที่ต้องการ = (รายได้ต่อปี × จำนวนปีที่คุ้มครอง) + หนี้สินทั้งหมด</strong></p>
      <p>นำทุนที่ต้องการมาลบด้วยทุนประกันที่มีอยู่แล้ว จะได้ช่องว่างที่ต้องปิด</p>
    </section>
    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />
    <RelatedCalculators currentHref="/คำนวณช่องว่างทุนประกัน/" />
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800"><strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ ควรปรึกษาที่ปรึกษาการเงินเพื่อการวางแผนที่เหมาะสม</div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const income = parseNum((document.getElementById('annual-income') as HTMLInputElement).value);
      const mult = parseFloat((document.getElementById('income-multiplier') as HTMLSelectElement).value);
      const debt = parseNum((document.getElementById('total-debt') as HTMLInputElement).value);
      const existing = parseNum((document.getElementById('existing-coverage') as HTMLInputElement).value);
      const err = document.getElementById('form-error')!;
      if (income < 60000) { err.textContent = 'กรุณากรอกรายได้ต่อปี'; err.classList.remove('hidden'); return; }
      err.classList.add('hidden');

      const incomeCoverage = income * mult;
      const totalNeeded = incomeCoverage + debt;
      const gap = Math.max(0, totalNeeded - existing);

      const rows = [
        ['รายได้ต่อปี', '', `${fmt(income)} บาท`],
        ['คุ้มครองรายได้', `× ${mult} ปี`, `${fmt(incomeCoverage)} บาท`],
        ['หนี้สินรวม', '', `+ ${fmt(debt)} บาท`],
        ['ทุนประกันที่ควรมี', '', `${fmt(totalNeeded)} บาท`],
        ['ทุนประกันที่มีอยู่', '', `- ${fmt(existing)} บาท`],
        ['ช่องว่างที่ต้องซื้อเพิ่ม', '', `<strong>${fmt(gap)} บาท</strong>`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td><td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td></tr>`).join('');

      (document.getElementById('needed') as HTMLElement).textContent = fmt(totalNeeded) + ' บาท';
      (document.getElementById('existing') as HTMLElement).textContent = fmt(existing) + ' บาท';
      (document.getElementById('gap') as HTMLElement).textContent = fmt(gap) + ' บาท';
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
