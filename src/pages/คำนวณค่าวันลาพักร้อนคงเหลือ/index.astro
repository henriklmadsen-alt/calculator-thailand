---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณค่าวันลาพักร้อนคงเหลือ ปี 2569 วันลาสะสมที่ยังไม่ได้ใช้ | Kamnuanlek';
const pageDescription = 'คำนวณค่าตอบแทนวันลาพักร้อนคงเหลือที่ยังไม่ได้ใช้ งวดสุดท้ายหรือเมื่อออกจากงาน คำนวณจากค่าจ้างรายวัน × จำนวนวันลาสะสม';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าวันลาพักร้อนคงเหลือ/`;

const faqData = [
  {
    question: 'วันลาพักร้อนที่ไม่ได้ใช้มีสิทธิ์รับเงินชดเชยไหม?',
    answer: 'ตามกฎหมายแรงงานไทย ลูกจ้างมีสิทธิ์รับค่าจ้างสำหรับวันลาพักร้อนที่สะสมไว้และยังไม่ได้ใช้ เมื่อออกจากงาน หรือตามข้อตกลงในสัญญาจ้าง',
  },
  {
    question: 'คำนวณค่าจ้างรายวันจากเงินเดือนอย่างไร?',
    answer: 'ค่าจ้างรายวัน = เงินเดือนรายเดือน ÷ จำนวนวันทำงานต่อเดือน (หรือ ÷ 30 ตามที่นายจ้างกำหนด)',
  },
  {
    question: 'สิทธิ์วันลาพักร้อนขั้นต่ำตามกฎหมายคือเท่าไร?',
    answer: 'ตามมาตรา 30 พ.ร.บ.คุ้มครองแรงงาน ลูกจ้างที่ทำงานครบ 1 ปีมีสิทธิ์หยุดพักผ่อนประจำปีไม่น้อยกว่า 6 วันทำงาน',
  },
  {
    question: 'ถ้าออกก่อนครบปีจะได้วันลาเฉลี่ยตามสัดส่วนไหม?',
    answer: 'ขึ้นอยู่กับนโยบายบริษัท กฎหมายไม่ได้บังคับให้คิดสัดส่วน แต่บางองค์กรคิดตามเดือนที่ทำงาน เช่น 6 วัน/ปี = 0.5 วัน/เดือน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าวันลาพักร้อนคงเหลือ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าวันลาพักร้อนคงเหลือ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณค่าวันลาพักร้อนที่ยังไม่ได้ใช้</p>
      <p class="mt-1 text-sm text-slate-700">ค่าตอบแทน = จำนวนวันลาคงเหลือ × ค่าจ้างรายวัน</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับพนักงานที่จะออกงาน หรือ HR ที่ต้องการคำนวณยอดจ่าย</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าวันลาพักร้อนคงเหลือ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือน วันทำงานต่อเดือน และจำนวนวันลาพักร้อนคงเหลือ ระบบจะคำนวณค่าตอบแทนที่พึงได้รับ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="leave-pay-form" class="space-y-5">
        <p id="leave-pay-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="lp-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือน (บาท/เดือน)</label>
            <input type="text" id="lp-salary" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="lp-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="lp-work-days" class="mb-1 block text-sm font-medium text-gray-700">วันทำงานต่อเดือน (วัน)</label>
            <input type="text" id="lp-work-days" inputmode="decimal" placeholder="เช่น 26"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="lp-work-days-error" class="mt-1 hidden text-sm text-red-600"></p>
            <p class="mt-1 text-xs text-gray-500">หรือใช้ 30 สำหรับวันปฏิทิน</p>
          </div>
          <div>
            <label for="lp-leave-days" class="mb-1 block text-sm font-medium text-gray-700">วันลาพักร้อนคงเหลือ (วัน)</label>
            <input type="text" id="lp-leave-days" inputmode="decimal" placeholder="เช่น 8"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="lp-leave-days-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณค่าวันลา
        </button>
      </form>
    </div>

    <div id="leave-pay-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าวันลาพักร้อนคงเหลือ</div>
            <div id="res-lp-total" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าจ้างรายวัน</div>
            <div id="res-lp-daily" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">จำนวนวันลาคงเหลือ</div>
            <div id="res-lp-days" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าจ้างรายวัน = เงินเดือน ÷ วันทำงานต่อเดือน</li>
        <li>ค่าวันลาพักร้อนคงเหลือ = ค่าจ้างรายวัน × วันลาคงเหลือ</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณค่าชดเชย/">คำนวณค่าชดเชย</a></li>
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
        <li><a href="/คำนวณค่าจ้างรายวัน/">คำนวณค่าจ้างรายวัน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#leave-pay-results" />
    <RelatedArticles currentHref="/คำนวณค่าวันลาพักร้อนคงเหลือ/" />
    <RelatedCalculators currentHref="/คำนวณค่าวันลาพักร้อนคงเหลือ/" />

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการตามสูตรที่ระบุ การจ่ายจริงขึ้นอยู่กับนโยบายบริษัทและสัญญาจ้าง ควรตรวจสอบกับฝ่าย HR ของบริษัท
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('leave-pay-form');
    const formError = document.getElementById('leave-pay-form-error');
    const resultBox = document.getElementById('leave-pay-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['lp-salary-error','lp-work-days-error','lp-leave-days-error'].forEach((id) => setErr(id, ''));

      const salary = parseNum(document.getElementById('lp-salary').value);
      const workDays = parseNum(document.getElementById('lp-work-days').value);
      const leaveDays = parseNum(document.getElementById('lp-leave-days').value);

      let hasError = false;
      if (!Number.isFinite(salary) || salary <= 0) { setErr('lp-salary-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(workDays) || workDays <= 0 || workDays > 31) { setErr('lp-work-days-error', 'กรอกวันทำงาน 1-31 วัน'); hasError = true; }
      if (!Number.isFinite(leaveDays) || leaveDays < 0) { setErr('lp-leave-days-error', 'กรอกวันลาคงเหลือ (ตัวเลขมากกว่าหรือเท่ากับ 0)'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const dailyRate = salary / workDays;
      const leavePay = dailyRate * leaveDays;

      setText('res-lp-total', formatMoney(leavePay));
      setText('res-lp-daily', formatMoney(dailyRate));
      setText('res-lp-days', `${leaveDays} วัน`);

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
