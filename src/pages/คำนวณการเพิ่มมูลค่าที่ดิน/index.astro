---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณการเพิ่มมูลค่าที่ดิน ปี 2569 | โครงการเติบโตที่ดิน | Kamnuanlek';
const pageDescription = 'คำนวณมูลค่าที่ดินในอนาคต ตามอัตราการเติบโตรายปี เพื่อประเมินผลตอบแทนการลงทุน ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณการเพิ่มมูลค่าที่ดิน/`;

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณการเพิ่มมูลค่าที่ดิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const faqData = [
  { question: 'Cap Rate ที่ดีสำหรับอสังหาริมทรัพย์ไทยคือเท่าไร?', answer: 'Cap Rate ที่ดีในไทยมักอยู่ที่ 5-8% ต่อปี ขึ้นอยู่กับทำเลและประเภทอสังหาฯ ทำเลกรุงเทพฯ ชั้นในมักได้ cap rate ต่ำกว่าต่างจังหวัด' },
  { question: 'ค่าใช้จ่ายแฝงในการซื้ออสังหาฯ มีอะไรบ้าง?', answer: 'ค่าโอน ค่าจดจำนอง ค่าอากรแสตมป์ ภาษีธุรกิจเฉพาะ ค่านายหน้า ค่าซ่อมแซม รวมกันอาจสูงถึง 3-7% ของราคาซื้อ' },
  { question: 'ผลตอบแทนการลงทุนอสังหาฯ ที่ดีต้องเป็นเท่าไร?', answer: 'นักลงทุนส่วนใหญ่ต้องการ IRR อย่างน้อย 8-12% ต่อปี หรือ Yield ค่าเช่า 5-7% ขึ้นอยู่กับทำเลและเป้าหมาย' },
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกราคาซื้อ ค่าเช่า ค่าใช้จ่ายรายเดือน เครื่องจะคำนวณ Yield, Cash Flow และ Cap Rate ให้อัตโนมัติ' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณการเพิ่มมูลค่าที่ดิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-purple-100 bg-purple-50 p-4">
      <p class="text-sm font-semibold text-purple-700">การเติบโตมูลค่าที่ดิน</p>
      <p class="mt-1 text-sm text-slate-700">ประเมินมูลค่าที่ดินในอนาคต โดยใช้อัตราการเติบโตรายปี ตามตำแหน่งและสถานการณ์พัฒนา</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณการเพิ่มมูลค่าที่ดิน ปี 2569
    </h1>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="appreciation-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="current-value" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าปัจจุบัน (บาท)</label>
            <input id="current-value" type="text" inputmode="numeric" placeholder="เช่น 5,000,000" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="annual-growth" class="block text-sm font-medium text-gray-700 mb-1">อัตราเติบโต/ปี (%)</label>
            <input id="annual-growth" type="text" inputmode="numeric" placeholder="เช่น 5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div>
          <label for="years" class="block text-sm font-medium text-gray-700 mb-1">จำนวนปี</label>
          <input id="years" type="text" inputmode="numeric" placeholder="เช่น 5" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 mb-6">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">มูลค่าประมาณ</div>
            <div id="res-future-value" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">กำไรที่คาด</div>
            <div id="res-gain" class="text-xl font-bold text-sky-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">มูลค่าปัจจุบัน</span>
            <span id="res-current" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">อัตราเติบโต</span>
            <span id="res-rate" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ระยะเวลา</span>
            <span id="res-period" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">มูลค่าประมาณ</span>
            <span id="res-calc-future" class="font-bold">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-700 font-semibold">กำไร</span>
            <span id="res-calc-gain" class="font-bold text-emerald-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <RelatedArticles currentHref="/คำนวณการเพิ่มมูลค่าที่ดิน/" />
    <RelatedCalculators currentHref="/คำนวณการเพิ่มมูลค่าที่ดิน/" />
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return NaN;
    return Number(String(value).replace(/,/g, '').trim());
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#appreciation-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const currentValue = parseNumber(document.querySelector('#current-value')?.value || '');
    const annualGrowth = parseNumber(document.querySelector('#annual-growth')?.value || '');
    const years = parseNumber(document.querySelector('#years')?.value || '');

    if (!(Number.isFinite(currentValue) && currentValue > 0 && Number.isFinite(annualGrowth) && annualGrowth >= 0 && Number.isFinite(years) && years > 0)) {
      results?.classList.add('hidden');
      return;
    }

    const rate = annualGrowth / 100;
    const futureValue = currentValue * Math.pow(1 + rate, years);
    const gain = futureValue - currentValue;

    document.querySelector('#res-future-value').textContent = formatCurrency(futureValue);
    document.querySelector('#res-gain').textContent = formatCurrency(gain);
    document.querySelector('#res-current').textContent = formatCurrency(currentValue);
    document.querySelector('#res-rate').textContent = `${annualGrowth.toFixed(2)}%`;
    document.querySelector('#res-period').textContent = `${years.toFixed(0)} ปี`;
    document.querySelector('#res-calc-future').textContent = formatCurrency(futureValue);
    document.querySelector('#res-calc-gain').textContent = formatCurrency(gain);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
