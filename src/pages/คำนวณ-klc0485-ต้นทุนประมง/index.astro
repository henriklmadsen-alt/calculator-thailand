---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณต้นทุนการเลี้ยงปลาและกุ้ง | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการเลี้ยงปลา กุ้ง ค่าพันธุ์สัตว์น้ำ อาหาร ยา ไฟฟ้า กำไรต่อบ่อ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0485-ต้นทุนประมง/`;
const faqData = [
  { question: 'ต้นทุนการเลี้ยงกุ้งขาวต่อกิโลกรัมเฉลี่ยเท่าไหร่?', answer: 'ต้นทุนเลี้ยงกุ้งขาวแวนนาไม 60-80 บาท/กก. รอบการเลี้ยง 90-100 วัน ผลผลิต 10-15 ตัน/ไร่ ราคาขายปัจจุบัน 80-120 บาท/กก.' },
  { question: 'ปลานิลเลี้ยงกี่เดือนจึงจับขาย?', answer: 'ปลานิลเลี้ยง 4-6 เดือน ได้น้ำหนัก 400-600 กรัม/ตัว ความหนาแน่น 1-3 ตัว/ตร.ม. ผลผลิต 5-15 ตัน/ไร่ ขึ้นกับระบบการเลี้ยง' },
  { question: 'ค่าไฟฟ้าเครื่องเติมอากาศคิดเป็นกี่เปอร์เซ็นต์ของต้นทุน?', answer: 'ค่าไฟฟ้าเครื่องเติมอากาศในบ่อกุ้ง 15-25% ของต้นทุน โซลาร์เซลล์ช่วยลดค่าไฟได้ 30-50% คืนทุนใน 3-5 ปี' },
  { question: 'มาตรฐาน GAP / ASC สำคัญอย่างไรต่อการส่งออก?', answer: 'GAP และ ASC เป็นมาตรฐานที่ตลาดยุโรป อเมริกา ญี่ปุ่นต้องการ ช่วยเพิ่มราคาขาย 5-15% และเปิดตลาดส่งออกโดยตรง' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนการเลี้ยงปลาและกุ้ง">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนประมงและสัตว์น้ำ</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนและกำไรการเลี้ยงสัตว์น้ำต่อรอบการผลิต</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="pond_area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่บ่อ (ไร่)</label><input type="text" id="pond_area" inputmode="decimal" placeholder="เช่น 2" value="2" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="seed_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าพันธุ์สัตว์น้ำ (บาท)</label><input type="text" id="seed_cost" inputmode="decimal" placeholder="เช่น 20000" value="20000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="feed_fish_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่าอาหารสัตว์น้ำ (บาท)</label><input type="text" id="feed_fish_cost" inputmode="decimal" placeholder="เช่น 60000" value="60000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="fish_sell_kg" class="block text-sm font-medium text-gray-700 mb-1">ผลผลิตที่ขายได้ (กก.)</label><input type="number" id="fish_sell_kg" min="1" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="fish_price" class="block text-sm font-medium text-gray-700 mb-1">ราคาขาย (บาท/กก.)</label><input type="text" id="fish_price" inputmode="decimal" placeholder="เช่น 60" value="60" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวม</p><p id="fish_total_cost" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">กำไรต่อรอบ</p><p id="fish_profit" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const seed = parseFloat((document.getElementById('seed_cost') as HTMLInputElement).value) || 0;
      const feed = parseFloat((document.getElementById('feed_fish_cost') as HTMLInputElement).value) || 0;
      const yieldKg = parseFloat((document.getElementById('fish_sell_kg') as HTMLInputElement).value) || 0;
      const price = parseFloat((document.getElementById('fish_price') as HTMLInputElement).value) || 0;
      const totalCost = seed + feed;
      const revenue = yieldKg * price;
      const profit = revenue - totalCost;
      (document.getElementById('fish_total_cost') as HTMLElement).textContent = Math.round(totalCost).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('fish_profit') as HTMLElement).textContent = Math.round(profit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('aquaculture-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
