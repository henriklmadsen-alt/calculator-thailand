---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ ค่าลงทะเบียนโดเมน 2569 | Kamnuanlek';
const pageDescription = 'คำนวณค่าลงทะเบียน ต่ออายุ และซ่อมแซมโดเมน รวมค่า WHOIS Privacy และ DNS Management ช่วยวางแผนงบประมาณจัดตั้งเว็บไซต์';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าลงทะเบียนโดเมน/`;

const faqData = [
  {
    question: 'ค่าลงทะเบียนโดเมนแตกต่างจากค่าโฮสติ้งอย่างไร?',
    answer: 'โดเมนคือชื่อเว็บไซต์ (เช่น example.com) ขณะที่โฮสติ้งคือพื้นที่จัดเก็บไฟล์เว็บ โดเมนทำให้ผู้คนหาเว็บไซต์ของคุณได้ ส่วนโฮสติ้งคือที่อยู่ของเนื้อหา ทั้งคู่จำเป็นสำหรับการมีเว็บไซต์',
  },
  {
    question: 'WHOIS Privacy คืออะไร มีความจำเป็นหรือไม่?',
    answer: 'WHOIS Privacy ซ่อนข้อมูลส่วนตัวของคุณ (ชื่อ ที่อยู่ อีเมล) ออกจากฐานข้อมูลสาธารณะ ป้องกันสแปม เรียกร้องการจดทะเบียน และการกำหนดเป้าหมายของแฮกเกอร์ สำหรับองค์กรธุรกิจแนะนำให้ใช้',
  },
  {
    question: 'ควรเลือกโดเมน .com .co.th หรืออื่นๆ?',
    answer: '.com เป็นโดเมนที่น่าเชื่อถือมากที่สุดทั่วโลก .co.th เหมาะสำหรับธุรกิจไทย ค่าอาจแตกต่างกัน .com ส่วนใหญ่ 400-500 บาท/ปี .co.th อาจแพงกว่า โดเมนเฉพาะหมวดหมู่เช่น .shop .online อาจถูกกว่า',
  },
  {
    question: 'ควรต่ออายุโดเมนกี่ปีพอดี?',
    answer: 'ส่วนใหญ่แนะนำ 2-3 ปี เพื่อป้องกันลืมต่ออายุ บางบริการอนุญาตให้ต่อได้สูงสุด 10 ปีพร้อมกัน ระยะเวลานานขึ้นมีข้อดีด้านความเสถียรและการไม่ทำให้เสียโดเมน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าลงทะเบียนโดเมน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าลงทะเบียนโดเมน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🌐 คำนวณค่าลงทะเบียนโดเมน
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าลงทะเบียน ต่ออายุ และเสริมเติมพิเศษ รวม WHOIS Privacy และ DNS Management
      เพื่อวางแผนงบประมาณจัดตั้งเว็บไซต์ของคุณอย่างถูกต้อง
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="domain-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="domain-count" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนโดเมน
            </label>
            <input
              type="text"
              id="domain-count"
              inputmode="numeric"
              placeholder="เช่น 1"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="domain-price" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าลงทะเบียนต่อโดเมน (บาท/ปี)
            </label>
            <input
              type="text"
              id="domain-price"
              inputmode="numeric"
              placeholder="เช่น 450"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="renewal-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาต่ออายุ (ปี)
            </label>
            <input
              type="text"
              id="renewal-years"
              inputmode="numeric"
              placeholder="เช่น 2"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="whois-price" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า WHOIS Privacy (บาท/ปี)
              <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
            </label>
            <input
              type="text"
              id="whois-price"
              inputmode="numeric"
              placeholder="เช่น 100"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="dns-price" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า DNS Management (บาท/ปี)
              <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
            </label>
            <input
              type="text"
              id="dns-price"
              inputmode="numeric"
              placeholder="เช่น 0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="email-price" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Email ที่เชื่อมโยง (บาท/ปี)
              <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
            </label>
            <input
              type="text"
              id="email-price"
              inputmode="numeric"
              placeholder="เช่น 0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณค่าโดเมน
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณค่าโดเมน</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">โดเมนต่อปี</div>
            <div id="res-domain-annual" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">บริการเพิ่มเติม</div>
            <div id="res-addon-total" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รวมต่อปี</div>
            <div id="res-total-annual" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รวมทั้งหมด</div>
            <div id="res-total-cost" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนโดเมน</span>
            <span id="res-count" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่าลงทะเบียนโดเมน</span>
            <span id="res-domain-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่า WHOIS Privacy</span>
            <span id="res-whois-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่า DNS Management</span>
            <span id="res-dns-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่า Email ที่เชื่อมโยง</span>
            <span id="res-email-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">ระยะเวลา</span>
            <span id="res-years" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ค่าลงทะเบียนโดเมนที่สำคัญต่อเว็บไซต์</h2>

      <p>
        โดเมนเป็นองค์ประกอบสำคัญของเว็บไซต์ ทำหน้าที่ให้ผู้คนสามารถเข้าถึงเว็บไซต์ของคุณได้ง่าย
        ค่าลงทะเบียนโดเมนมีความหลากหลาย ขึ้นอยู่กับประเภทโดเมน (.com, .co.th ฯลฯ) และบริการเพิ่มเติม
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประเภทโดเมนทั่วไป</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>.com</strong> — ประสิทธิ์สูงสุด 400-500 บาท/ปี ใช้ได้ทั่วโลก</li>
        <li><strong>.co.th</strong> — สำหรับธุรกิจไทย 600-800 บาท/ปี เพิ่มความไว้วางใจ</li>
        <li><strong>.online, .shop, .site</strong> — โดเมนทั่วไป 200-400 บาท/ปี ราคาถูก</li>
        <li><strong>.io, .dev</strong> — สำหรับ Startup/เทคโนโลยี 600-1,000 บาท/ปี</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">บริการเพิ่มเติมสำหรับโดเมน</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>WHOIS Privacy</strong> — ซ่อนข้อมูลส่วนตัว 100-150 บาท/ปี สำคัญมากสำหรับป้องกันสแปม</li>
        <li><strong>DNS Management</strong> — บริหารบันทึก DNS ส่วนใหญ่ฟรี บางบริการคิดค่า 50-100 บาท/ปี</li>
        <li><strong>Email Domain</strong> — ใช้อีเมลของชื่อบริษัท 100-300 บาท/ปี เพิ่มความเป็นมืออาชีพ</li>
        <li><strong>SSL Certificate</strong> — รักษาความปลอดภัยเว็บ ฟรีจาก Let's Encrypt บางบริการคิดค่า</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เคล็ดลับการเลือกโดเมน</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>เลือกโดเมนที่จำง่าย สั้น และสัมพันธ์กับชื่อธุรกิจ</li>
        <li>หลีกเลี่ยงตัวเลขและสัญลักษณ์พิเศษ ยากต่อการจำและให้คำแนะนำด้วยปาก</li>
        <li>ตรวจสอบว่าสามารถใช้ได้บน Social Media เดียวกัน เพื่อความสม่ำเสมอของแบรนด์</li>
        <li>หลีกเลี่ยงโดเมนที่อาจจะหมดอายุในไม่ช้า เลือกต่ออายุหลายปี</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณ-ค่าลงทะเบียนโดเมน/" />
    <RelatedCalculators currentHref="/คำนวณ-ค่าลงทะเบียนโดเมน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ราคาโดเมนอาจแตกต่างขึ้นอยู่กับผู้ให้บริการ โปรโมชัน และตลาด
      ผลการคำนวณเป็นการประมาณการเท่านั้น ไม่ถือเป็นราคาแน่นอน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('domain-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const domainCount = parseNum((document.getElementById('domain-count') as HTMLInputElement).value);
      const domainPrice = parseNum((document.getElementById('domain-price') as HTMLInputElement).value);
      const renewalYears = parseNum((document.getElementById('renewal-years') as HTMLInputElement).value);
      const whoisPrice = parseNum((document.getElementById('whois-price') as HTMLInputElement).value);
      const dnsPrice = parseNum((document.getElementById('dns-price') as HTMLInputElement).value);
      const emailPrice = parseNum((document.getElementById('email-price') as HTMLInputElement).value);

      if (domainCount <= 0) { (document.getElementById('domain-count') as HTMLInputElement).focus(); return; }
      if (domainPrice <= 0) { (document.getElementById('domain-price') as HTMLInputElement).focus(); return; }
      if (renewalYears <= 0) { (document.getElementById('renewal-years') as HTMLInputElement).focus(); return; }

      const domainAnnual = domainCount * domainPrice;
      const addonTotal = domainCount * (whoisPrice + dnsPrice + emailPrice);
      const totalAnnual = domainAnnual + addonTotal;
      const totalCost = totalAnnual * renewalYears;

      (document.getElementById('res-domain-annual') as HTMLElement).textContent = fmt(domainAnnual) + ' บาท';
      (document.getElementById('res-addon-total') as HTMLElement).textContent = fmt(addonTotal) + ' บาท';
      (document.getElementById('res-total-annual') as HTMLElement).textContent = fmt(totalAnnual) + ' บาท';
      (document.getElementById('res-total-cost') as HTMLElement).textContent = fmt(totalCost) + ' บาท';
      (document.getElementById('res-count') as HTMLElement).textContent = domainCount.toFixed(0);
      (document.getElementById('res-domain-cost') as HTMLElement).textContent = fmt(domainAnnual) + ' บาท';
      (document.getElementById('res-whois-cost') as HTMLElement).textContent = fmt(domainCount * whoisPrice) + ' บาท';
      (document.getElementById('res-dns-cost') as HTMLElement).textContent = fmt(domainCount * dnsPrice) + ' บาท';
      (document.getElementById('res-email-cost') as HTMLElement).textContent = fmt(domainCount * emailPrice) + ' บาท';
      (document.getElementById('res-years') as HTMLElement).textContent = renewalYears.toFixed(0) + ' ปี';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('domain-registration');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('domain-registration');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
