---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณตารางเปลี่ยนแบตเตอรี่รถยนต์ ปี 2569 | อายุแบต | Kamnuanlek';
const pageDescription = 'คำนวณอายุการใช้งานแบตเตอรี่รถยนต์ และช่วงเวลาที่ควรเปลี่ยน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณตารางเปลี่ยนแบตเตอรี่/`;

const faqData = [
  {
    question: 'แบตเตอรี่รถยนต์ในประเทศไทยมีอายุการใช้งานกี่ปี?',
    answer: 'ในสภาพอากาศร้อนของประเทศไทย แบตเตอรี่มาตรฐาน (Lead-Acid) มักมีอายุการใช้งาน 2–3 ปี แบตเตอรี่แบบ AGM (Absorbent Glass Mat) อยู่ได้ 3–5 ปี และ EFB (Enhanced Flooded Battery) อยู่ได้ 3–4 ปี อุณหภูมิสูงเป็นปัจจัยหลักที่ทำให้แบตเตอรี่เสื่อมเร็วกว่าประเทศที่มีอากาศเย็นกว่า',
  },
  {
    question: 'สัญญาณอะไรบ่งบอกว่าแบตเตอรี่ใกล้หมดอายุ?',
    answer: 'อาการที่ควรระวัง ได้แก่ เครื่องยนต์สตาร์ทช้าหรือกระตุก ไฟส่องสว่างหรี่ลงขณะสตาร์ท ต้องชาร์จแบตบ่อย ไฟเตือนแบตเตอรี่ติดบนแผงหน้าปัด เครื่องใช้ไฟฟ้าทำงานผิดปกติ และแบตเตอรี่มีอายุเกิน 3 ปีในสภาพอากาศร้อน ควรตรวจสอบแรงดันแบตเตอรี่ด้วยมัลติมิเตอร์เป็นประจำ',
  },
  {
    question: 'แบตเตอรี่ AGM และ EFB แตกต่างจากแบบมาตรฐานอย่างไร?',
    answer: 'แบตเตอรี่ AGM มีโครงสร้างที่แข็งแรงกว่า ทนทานต่อการชาร์จ-คายประจุซ้ำได้ดีกว่า เหมาะสำหรับรถที่มีระบบ Start-Stop และใช้ไฟฟ้ามาก มีอายุยาวกว่าและชาร์จไฟเร็วกว่า ส่วน EFB เป็นรุ่นกลางระหว่างมาตรฐานและ AGM มีประสิทธิภาพดีกว่ามาตรฐานในราคาที่เข้าถึงได้มากกว่า AGM',
  },
  {
    question: 'ควรเปลี่ยนแบตเตอรี่เองหรือให้ช่างเปลี่ยน?',
    answer: 'รถยนต์รุ่นใหม่หลายรุ่นต้องการการรีเซ็ตระบบอิเล็กทรอนิกส์หลังเปลี่ยนแบตเตอรี่ โดยเฉพาะรถที่มีระบบ Start-Stop หรือระบบจัดการพลังงาน BMS (Battery Management System) แนะนำให้ให้ช่างศูนย์บริการหรือผู้เชี่ยวชาญดำเนินการเพื่อป้องกันปัญหาระบบไฟและการรับประกัน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณตารางเปลี่ยนแบตเตอรี่รถยนต์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณตารางเปลี่ยนแบตเตอรี่รถยนต์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณตารางเปลี่ยนแบตเตอรี่รถยนต์
    </h1>
    <p class="text-gray-600 mb-6">
      คำนวณอายุการใช้งานแบตเตอรี่รถยนต์ตามประเภทและสภาพอากาศ พร้อมคาดการณ์ช่วงเวลาที่ควรเปลี่ยน
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="calculator-form" class="space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="install-year" class="block text-sm font-medium text-gray-700 mb-1">
              ปีที่ติดตั้งแบตเตอรี่ (พ.ศ.)
            </label>
            <input
              type="text"
              id="install-year"
              inputmode="numeric"
              placeholder="เช่น 2566"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="install-month" class="block text-sm font-medium text-gray-700 mb-1">
              เดือนที่ติดตั้ง
            </label>
            <select
              id="install-month"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              <option value="1">มกราคม</option>
              <option value="2">กุมภาพันธ์</option>
              <option value="3">มีนาคม</option>
              <option value="4" selected>เมษายน</option>
              <option value="5">พฤษภาคม</option>
              <option value="6">มิถุนายน</option>
              <option value="7">กรกฎาคม</option>
              <option value="8">สิงหาคม</option>
              <option value="9">กันยายน</option>
              <option value="10">ตุลาคม</option>
              <option value="11">พฤศจิกายน</option>
              <option value="12">ธันวาคม</option>
            </select>
          </div>
          <div>
            <label for="battery-type" class="block text-sm font-medium text-gray-700 mb-1">
              ประเภทแบตเตอรี่
            </label>
            <select
              id="battery-type"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              <option value="standard">มาตรฐาน (Lead-Acid)</option>
              <option value="efb">EFB (Enhanced Flooded Battery)</option>
              <option value="agm">AGM (Absorbent Glass Mat)</option>
            </select>
          </div>
          <div>
            <label for="climate" class="block text-sm font-medium text-gray-700 mb-1">
              เขตภูมิอากาศ
            </label>
            <select
              id="climate"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              <option value="hot">ร้อนมาก (ภาคกลาง/ใต้/กรุงเทพฯ)</option>
              <option value="moderate">ร้อนปานกลาง (ภาคเหนือ/ตะวันออกเฉียงเหนือ)</option>
              <option value="mild">ร้อนน้อย (ที่สูง/ภูเขา)</option>
            </select>
          </div>
          <div>
            <label for="battery-price" class="block text-sm font-medium text-gray-700 mb-1">
              ราคาแบตเตอรี่ (บาท)
            </label>
            <input
              type="text"
              id="battery-price"
              inputmode="decimal"
              placeholder="เช่น 2500"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>
        <button
          type="button"
          id="btn-calculate"
          class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ
        </button>
      </form>

      <!-- Result -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-blue-700 font-medium mb-1">อายุการใช้งานที่คาดได้</div>
            <div id="res-expected-life" class="text-2xl font-bold text-blue-800">-</div>
            <div class="text-xs text-blue-600 mt-1">ปี</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4">
            <div class="text-sm text-purple-700 font-medium mb-1">ปีที่แนะนำให้เปลี่ยน (พ.ศ.)</div>
            <div id="res-replace-year" class="text-2xl font-bold text-purple-800">-</div>
            <div id="res-replace-month" class="text-xs text-purple-600 mt-1">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4">
            <div class="text-sm text-green-700 font-medium mb-1">เวลาจนถึงกำหนดเปลี่ยน</div>
            <div id="res-months-until" class="text-2xl font-bold text-green-800">-</div>
            <div class="text-xs text-green-600 mt-1">เดือน</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4">
            <div class="text-sm text-orange-700 font-medium mb-1">ค่าใช้จ่ายที่คาดการณ์</div>
            <div id="res-cost" class="text-2xl font-bold text-orange-800">-</div>
            <div class="text-xs text-orange-600 mt-1">บาท</div>
          </div>
        </div>
        <div id="status-panel" class="rounded-lg p-4 border">
          <div id="status-label" class="text-sm font-medium mb-1">สถานะแบตเตอรี่</div>
          <div id="status-message" class="text-base font-semibold">-</div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">อายุแบตเตอรี่รถยนต์และผลกระทบของอุณหภูมิ</h2>
      <p>
        แบตเตอรี่รถยนต์เป็นหนึ่งในชิ้นส่วนที่ได้รับผลกระทบมากที่สุดจากสภาพอากาศ
        อุณหภูมิสูงในประเทศไทยทำให้กระบวนการทางเคมีภายในแบตเตอรี่เร่งขึ้น
        ส่งผลให้เสื่อมสภาพเร็วกว่าในประเทศที่มีอากาศเย็น
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">อายุแบตเตอรี่ตามประเภทและภูมิอากาศ</h3>
      <div class="bg-gray-50 rounded-lg p-4 my-4 space-y-2">
        <p class="font-medium">มาตรฐาน: 2.5–3 ปี (ร้อนมาก) / 3–4 ปี (ปานกลาง) / 3.5–4.5 ปี (ร้อนน้อย)</p>
        <p class="font-medium">EFB: 3–4 ปี (ร้อนมาก) / 3.5–5 ปี (ปานกลาง) / 4–5.5 ปี (ร้อนน้อย)</p>
        <p class="font-semibold text-primary-700">AGM: 3.5–5 ปี (ร้อนมาก) / 4–6 ปี (ปานกลาง) / 4.5–7 ปี (ร้อนน้อย)</p>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธียืดอายุแบตเตอรี่</h3>
      <p>
        เพื่อยืดอายุแบตเตอรี่ ควรจอดรถในที่ร่มหรือโรงจอดเพื่อลดความร้อน
        หลีกเลี่ยงการใช้ไฟฟ้าเมื่อเครื่องยนต์ดับ ขับรถเป็นระยะทางไกลพอที่จะชาร์จแบตได้เต็มที่
        และตรวจสอบขั้วแบตเตอรี่ให้สะอาดอยู่เสมอ
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณตารางเปลี่ยนแบตเตอรี่/" />
    <RelatedCalculators currentHref="/คำนวณตารางเปลี่ยนแบตเตอรี่/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการตามประเภทแบตเตอรี่และภูมิอากาศ
      อายุจริงขึ้นอยู่กับพฤติกรรมการใช้งาน ยี่ห้อแบตเตอรี่ และปัจจัยเฉพาะของแต่ละรถ
      ควรให้ช่างตรวจสอบค่าแรงดันและความจุแบตเตอรี่เป็นประจำทุกปี
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number, decimals = 2): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: decimals, maximumFractionDigits: decimals }).format(n);
    }

    const THAI_MONTHS = [
      'มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน',
      'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม',
    ];

    // Base life in years (midpoint) per battery type
    const BASE_LIFE: Record<string, number> = {
      standard: 2.75,
      efb: 3.5,
      agm: 4.5,
    };

    // Climate multipliers
    const CLIMATE_MULT: Record<string, number> = {
      hot: 0.80,      // -20%
      moderate: 0.90, // -10%
      mild: 1.00,
    };

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const installYear = parseNum((document.getElementById('install-year') as HTMLInputElement).value);
      const installMonth = parseInt((document.getElementById('install-month') as HTMLSelectElement).value, 10);
      const batteryType = (document.getElementById('battery-type') as HTMLSelectElement).value;
      const climate = (document.getElementById('climate') as HTMLSelectElement).value;
      const batteryPrice = parseNum((document.getElementById('battery-price') as HTMLInputElement).value);

      if (installYear <= 0) {
        alert('กรุณากรอกปีที่ติดตั้งแบตเตอรี่');
        return;
      }

      const baseLife = BASE_LIFE[batteryType] ?? 2.75;
      const climMult = CLIMATE_MULT[climate] ?? 0.80;
      const expectedLifeYears = baseLife * climMult;
      const expectedLifeMonths = expectedLifeYears * 12;

      // Replacement date
      const totalInstallMonths = installYear * 12 + (installMonth - 1);
      const totalReplaceMonths = totalInstallMonths + Math.round(expectedLifeMonths);
      const replaceYear = Math.floor(totalReplaceMonths / 12);
      const replaceMonth = (totalReplaceMonths % 12) + 1;

      // Current date in BE
      const now = new Date();
      const currentYear = now.getFullYear() + 543;
      const currentMonth = now.getMonth() + 1;
      const currentTotalMonths = currentYear * 12 + (currentMonth - 1);
      const monthsUntil = totalReplaceMonths - currentTotalMonths;

      (document.getElementById('res-expected-life') as HTMLElement).textContent = fmt(expectedLifeYears, 1);
      (document.getElementById('res-replace-year') as HTMLElement).textContent = `${replaceYear}`;
      (document.getElementById('res-replace-month') as HTMLElement).textContent = THAI_MONTHS[replaceMonth - 1];
      (document.getElementById('res-months-until') as HTMLElement).textContent =
        monthsUntil > 0 ? fmt(monthsUntil, 0) : '0';
      (document.getElementById('res-cost') as HTMLElement).textContent =
        batteryPrice > 0 ? fmt(batteryPrice, 0) : 'ไม่ระบุ';

      const panel = document.getElementById('status-panel') as HTMLElement;
      const label = document.getElementById('status-label') as HTMLElement;
      const message = document.getElementById('status-message') as HTMLElement;

      if (monthsUntil <= 0) {
        panel.className = 'rounded-lg p-4 border border-red-300 bg-red-50';
        label.className = 'text-sm font-medium mb-1 text-red-700';
        label.textContent = 'สถานะแบตเตอรี่ — เกินอายุการใช้งาน!';
        message.className = 'text-base font-semibold text-red-800';
        message.textContent = `เกินกำหนดมาแล้ว ${Math.abs(monthsUntil)} เดือน — ควรตรวจสอบและเปลี่ยนแบตเตอรี่โดยเร็ว`;
      } else if (monthsUntil <= 3) {
        panel.className = 'rounded-lg p-4 border border-orange-300 bg-orange-50';
        label.className = 'text-sm font-medium mb-1 text-orange-700';
        label.textContent = 'สถานะแบตเตอรี่ — ใกล้ถึงกำหนดเปลี่ยน';
        message.className = 'text-base font-semibold text-orange-800';
        message.textContent = `อีกประมาณ ${monthsUntil} เดือนถึงกำหนด — ควรเริ่มวางแผนเปลี่ยนแบตเตอรี่`;
      } else {
        panel.className = 'rounded-lg p-4 border border-green-300 bg-green-50';
        label.className = 'text-sm font-medium mb-1 text-green-700';
        label.textContent = 'สถานะแบตเตอรี่ — ยังอยู่ในเกณฑ์ดี';
        message.className = 'text-base font-semibold text-green-800';
        message.textContent = `แบตเตอรี่ยังใช้งานได้อีกประมาณ ${monthsUntil} เดือน (${fmt(monthsUntil / 12, 1)} ปี)`;
      }

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
    });

    document.querySelectorAll('#calculator-form input').forEach(input => {
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
