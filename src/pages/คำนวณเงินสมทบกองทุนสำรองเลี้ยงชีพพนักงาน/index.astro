---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน อัตรา 2-15% ลดหย่อนภาษีได้ ปี 2569 | Kamnuanlek';
const pageDescription = 'คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพ (PVD) ฝั่งพนักงาน อัตรา 2-15% ของเงินเดือน คำนวณเงินสมทบรายเดือน รายปี และวงเงินลดหย่อนภาษีสูงสุด 500,000 บาท';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน/`;

const faqData = [
  {
    question: 'กองทุนสำรองเลี้ยงชีพ (PVD) คืออะไร?',
    answer: 'กองทุนสำรองเลี้ยงชีพ (Provident Fund: PVD) คือกองทุนที่นายจ้างและลูกจ้างร่วมกันจัดตั้งขึ้นโดยสมัครใจ เพื่อออมเงินระยะยาวสำหรับลูกจ้างเมื่อออกจากงานหรือเกษียณอายุ',
  },
  {
    question: 'พนักงานสมทบกองทุนได้เท่าไร?',
    answer: 'พนักงานสามารถเลือกสมทบได้ตั้งแต่ 2% ถึง 15% ของเงินเดือน โดยต้องไม่ต่ำกว่าอัตราขั้นต่ำที่กำหนดในข้อบังคับกองทุน และต้องไม่เกิน 15% ของค่าจ้าง',
  },
  {
    question: 'เงินสมทบกองทุนสำรองเลี้ยงชีพลดหย่อนภาษีได้เท่าไร?',
    answer: 'เงินสมทบกองทุนสำรองเลี้ยงชีพของพนักงานสามารถนำมาหักลดหย่อนภาษีได้ แต่ไม่เกิน 500,000 บาทต่อปี (รวมกับเงินสะสมกองทุนการออมแห่งชาติ กบข. และเบี้ยประกันชีวิตแบบบำนาญ)',
  },
  {
    question: 'เงินในกองทุน PVD สามารถถอนได้เมื่อใด?',
    answer: 'ลูกจ้างจะได้รับเงินกองทุนเมื่อออกจากงาน ลาออก เกษียณอายุ หรือเสียชีวิต โดยเงินที่ได้รับประกอบด้วยเงินสะสม เงินสมทบของนายจ้าง และผลประโยชน์จากการลงทุน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">💰 กองทุนสำรองเลี้ยงชีพพนักงาน (PVD) อัตรา 2-15%</p>
      <p class="mt-1 text-sm text-slate-700">พนักงานเลือกสมทบได้ 2-15% ของเงินเดือน ลดหย่อนภาษีได้สูงสุด 500,000 บาท/ปี</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับพนักงานที่ต้องการวางแผนออมเงินระยะยาวและประหยัดภาษี</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือนและอัตราสมทบที่ต้องการ ระบบจะคำนวณเงินสมทบรายเดือน รายปี และวงเงินที่ใช้ลดหย่อนภาษีได้
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="pvd-emp-form" class="space-y-5">
        <p id="pvd-emp-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="pvde-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือน (บาท/เดือน)</label>
            <input type="text" id="pvde-salary" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="pvde-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="pvde-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราสมทบพนักงาน (%)</label>
            <input type="text" id="pvde-rate" inputmode="decimal" placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">เลือกได้ 2-15% ของเงินเดือน</p>
            <p id="pvde-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณเงินสมทบ
        </button>
      </form>
    </div>

    <div id="pvd-emp-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินสมทบรายเดือน</div>
            <div id="res-pvde-monthly" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินสมทบรายปี</div>
            <div id="res-pvde-annual" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ลดหย่อนภาษีได้</div>
            <div id="res-pvde-tax" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">เงินเดือน</span>
            <span id="res-pvde-salary-display" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">อัตราสมทบ</span>
            <span id="res-pvde-rate-display" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">วงเงินลดหย่อนคงเหลือ (500,000 - ที่สมทบแล้ว)</span>
            <span id="res-pvde-remaining" class="font-medium">-</span>
          </div>
        </div>
        <p id="res-pvde-cap-note" class="mt-3 hidden rounded-md bg-yellow-50 px-3 py-2 text-sm text-yellow-800"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>เงินสมทบรายเดือน = เงินเดือน × อัตราสมทบ ÷ 100</li>
        <li>เงินสมทบรายปี = เงินสมทบรายเดือน × 12</li>
        <li>ลดหย่อนภาษีได้ = เงินสมทบรายปี (แต่ไม่เกิน 500,000 บาท/ปี)</li>
        <li>อัตราสมทบที่เลือกได้: 2% ถึง 15% ของเงินเดือน</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพนายจ้าง/">คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพนายจ้าง</a></li>
        <li><a href="/คำนวณลดหย่อนกองทุนสำรองเลี้ยงชีพ/">คำนวณลดหย่อนกองทุนสำรองเลี้ยงชีพ</a></li>
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#pvd-emp-results" />
    <RelatedArticles currentHref="/คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน/" />
    <RelatedCalculators currentHref="/คำนวณเงินสมทบกองทุนสำรองเลี้ยงชีพพนักงาน/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการเบื้องต้น วงเงินลดหย่อนภาษี 500,000 บาท/ปี เป็นการรวมกับกองทุนอื่น เช่น กบข. และประกันชีวิตแบบบำนาญ กรุณาปรึกษาผู้เชี่ยวชาญด้านภาษีเพื่อการวางแผนที่แม่นยำ
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }
    function setErr(id, msg) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.toggle('hidden', !msg);
    }

    const form = document.getElementById('pvd-emp-form');
    const formError = document.getElementById('pvd-emp-form-error');
    const resultBox = document.getElementById('pvd-emp-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['pvde-salary-error', 'pvde-rate-error'].forEach((id) => setErr(id, ''));

      const salary = parseNum(document.getElementById('pvde-salary').value);
      const rate = parseNum(document.getElementById('pvde-rate').value);

      let hasError = false;
      if (!Number.isFinite(salary) || salary <= 0) { setErr('pvde-salary-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(rate) || rate < 2 || rate > 15) { setErr('pvde-rate-error', 'กรอกอัตราสมทบ 2-15%'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const monthly = salary * (rate / 100);
      const annual = monthly * 12;
      const TAX_CAP = 500000;
      const taxDeductible = Math.min(annual, TAX_CAP);
      const remaining = Math.max(0, TAX_CAP - annual);

      setText('res-pvde-monthly', formatMoney(monthly));
      setText('res-pvde-annual', formatMoney(annual));
      setText('res-pvde-tax', formatMoney(taxDeductible));
      setText('res-pvde-salary-display', formatMoney(salary));
      setText('res-pvde-rate-display', `${rate}%`);
      setText('res-pvde-remaining', formatMoney(remaining));

      const capNote = document.getElementById('res-pvde-cap-note');
      if (annual > TAX_CAP) {
        capNote.textContent = `เงินสมทบรายปี ${formatMoney(annual)} เกินวงเงินลดหย่อน จึงลดหย่อนได้สูงสุด ${formatMoney(TAX_CAP)}`;
        capNote.classList.remove('hidden');
      } else {
        capNote.classList.add('hidden');
      }

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
