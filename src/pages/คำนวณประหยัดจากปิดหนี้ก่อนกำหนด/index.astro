---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณประหยัดจากปิดหนี้ก่อนกำหนด 2569 | Calculator Thailand';
const pageDescription = 'คำนวณเงินที่ประหยัดได้จากการปิดหนี้ก่อนกำหนด หักค่าปรับปิดก่อนกำหนด เพื่อตัดสินใจว่าคุ้มค่าหรือไม่ สำหรับสินเชื่อบ้าน รถ และสินเชื่อส่วนบุคคล';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณประหยัดจากปิดหนี้ก่อนกำหนด/`;

const faqData = [
  {
    question: 'ปิดหนี้ก่อนกำหนดมีค่าปรับหรือไม่?',
    answer: 'สินเชื่อบ้านมักมีค่าปรับปิดก่อน 0-3% ของยอดคงเหลือในช่วง 3-5 ปีแรก หลังจากนั้นมักไม่มีค่าปรับ สินเชื่อรถและสินเชื่อส่วนบุคคลแบบ flat rate มักมีค่าปรับตามสูตรของแต่ละแห่ง ควรตรวจสอบเงื่อนไขก่อน',
  },
  {
    question: 'ควรปิดหนี้ก่อนกำหนดหรือนำเงินไปลงทุน?',
    answer: 'ขึ้นอยู่กับเปรียบเทียบดอกเบี้ยสินเชื่อกับผลตอบแทนการลงทุน ถ้าดอกเบี้ยสินเชื่อสูงกว่าผลตอบแทนคาดหวัง ควรปิดหนี้ก่อน ถ้าผลตอบแทนการลงทุนสูงกว่าดอกเบี้ย ควรลงทุนและผ่อนต่อ สินเชื่อบ้านดอกเบี้ย 6-7% vs หุ้นระยะยาวเฉลี่ย 8-10%',
  },
  {
    question: 'โปะเงินต้นบางส่วนดีกว่าปิดทั้งหมดหรือไม่?',
    answer: 'การโปะบางส่วนช่วยลดต้นและดอกเบี้ยในอนาคตโดยไม่ต้องใช้เงินก้อนใหญ่ และส่วนใหญ่ไม่มีค่าปรับ เป็นตัวเลือกที่ดีสำหรับผู้ที่มีเงินสดสะสมบ้างแต่ไม่มากพอปิดหมด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณประหยัดจากปิดหนี้ก่อนกำหนด',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณประหยัดจากปิดหนี้ก่อนกำหนด">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      คำนวณประหยัดจากปิดหนี้ก่อนกำหนด — คุ้มค่าแค่ไหน?
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">คำนวณดอกเบี้ยที่ประหยัดได้ หักค่าปรับ เพื่อตัดสินใจว่าควรปิดหนี้ก่อนกำหนดหรือไม่</p>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6 mb-8">
      <form id="early-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="balance" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ยอดเงินต้นคงเหลือ (บาท)</label>
            <input type="text" id="balance" inputmode="numeric" placeholder="เช่น 1,500,000"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
          <div>
            <label for="rate" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ดอกเบี้ย (%/ปี)</label>
            <input type="text" id="rate" inputmode="decimal" placeholder="เช่น 6.5"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="remaining-months" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">งวดที่เหลือ (เดือน)</label>
            <input type="text" id="remaining-months" inputmode="numeric" placeholder="เช่น 240"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
          <div>
            <label for="prepay-penalty" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ค่าปรับปิดก่อนกำหนด (%)</label>
            <input type="text" id="prepay-penalty" inputmode="decimal" placeholder="เช่น 2"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
            <p class="text-xs text-gray-500 mt-1">ใส่ 0 ถ้าไม่มีค่าปรับ</p>
          </div>
        </div>
        <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-4">
          <div class="bg-green-50 dark:bg-green-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ดอกเบี้ยที่ประหยัดได้</div>
            <div id="res-saved" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-red-50 dark:bg-red-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ค่าปรับ</div>
            <div id="res-penalty" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="bg-primary-50 dark:bg-primary-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ประหยัดสุทธิ</div>
            <div id="res-net" class="text-xl font-bold text-primary-700 dark:text-primary-300">-</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ต้องใช้เงิน</div>
            <div id="res-needed" class="text-xl font-bold text-gray-700 dark:text-gray-300">-</div>
          </div>
        </div>
        <div id="verdict" class="p-3 rounded-lg text-sm"></div>
      </div>
    </div>

    <GuardedAdSlot />

    <section class="prose prose-gray dark:prose-invert max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-3">เมื่อไรควรปิดหนี้ก่อนกำหนด?</h2>
      <p>ปิดหนี้ก่อนกำหนดคุ้มค่าเมื่อ: (1) ดอกเบี้ยประหยัดได้มากกว่าค่าปรับ (2) ไม่มีทางลงทุนที่ให้ผลตอบแทนสูงกว่าดอกเบี้ยสินเชื่อ (3) ต้องการลดภาระทางการเงินระยะยาว และ (4) มีเงินสำรองฉุกเฉินเหลือเพียงพอหลังปิดหนี้แล้ว</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 dark:text-gray-100 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600 dark:text-gray-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณประหยัดจากปิดหนี้ก่อนกำหนด/" />
    <RelatedCalculators currentHref="/คำนวณประหยัดจากปิดหนี้ก่อนกำหนด/" />

    <div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg text-sm text-yellow-800 dark:text-yellow-300">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ ค่าปรับจริงขึ้นอยู่กับเงื่อนไขสัญญา
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }

    document.getElementById('early-form')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const balance = parseNum((document.getElementById('balance') as HTMLInputElement).value);
      const rate = parseNum((document.getElementById('rate') as HTMLInputElement).value) || 6.5;
      const months = parseNum((document.getElementById('remaining-months') as HTMLInputElement).value) || 240;
      const penaltyPct = parseNum((document.getElementById('prepay-penalty') as HTMLInputElement).value);
      if (!balance) return;

      const r = rate / 100 / 12;
      const monthlyPayment = r === 0 ? balance / months : balance * (r * Math.pow(1 + r, months)) / (Math.pow(1 + r, months) - 1);
      const remainingInterest = monthlyPayment * months - balance;
      const penaltyAmount = balance * penaltyPct / 100;
      const netSaving = remainingInterest - penaltyAmount;
      const totalNeeded = balance + penaltyAmount;

      (document.getElementById('res-saved') as HTMLElement).textContent = fmt(remainingInterest) + ' บาท';
      (document.getElementById('res-penalty') as HTMLElement).textContent = fmt(penaltyAmount) + ' บาท';
      (document.getElementById('res-net') as HTMLElement).textContent = fmt(netSaving) + ' บาท';
      (document.getElementById('res-needed') as HTMLElement).textContent = fmt(totalNeeded) + ' บาท';

      const verdict = document.getElementById('verdict') as HTMLElement;
      if (netSaving > 0) {
        verdict.className = 'p-3 rounded-lg text-sm bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-300';
        verdict.textContent = `✓ คุ้มค่า — ประหยัดสุทธิ ${fmt(netSaving)} บาท หลังหักค่าปรับแล้ว`;
      } else {
        verdict.className = 'p-3 rounded-lg text-sm bg-orange-50 dark:bg-orange-900/20 text-orange-800 dark:text-orange-300';
        verdict.textContent = `✗ ไม่คุ้มค่า — ค่าปรับสูงกว่าดอกเบี้ยที่ประหยัดได้ ${fmt(Math.abs(netSaving))} บาท`;
      }

      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('early-settlement');
    });
  </script>
</BaseLayout>
