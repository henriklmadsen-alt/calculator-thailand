---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าห้องฉุกเฉิน | Kamnuanlek';
const pageDescription = 'คำนวณค่าห้องฉุกเฉิน ER ค่าแพทย์ ค่ายา ค่าหัตถการ ตามความรุนแรงของอาการ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0416-ค่าฉุกเฉิน/`;

const faqData = [
  { question: 'ค่าห้องฉุกเฉินโรงพยาบาลเอกชนเท่าไหร่?', answer: 'ค่าบริการ ER โรงพยาบาลเอกชน 500-2,000 บาทต่อครั้ง ไม่รวมค่ายา ค่าตรวจ ค่าหัตถการ ยอดรวมอาจถึง 5,000-50,000 บาท ขึ้นอยู่กับความรุนแรง' },
  { question: 'UCEP นโยบาย 72 ชั่วโมงคืออะไร?', answer: 'UCEP (Universal Coverage for Emergency Patients) คนไข้ฉุกเฉินวิกฤตรักษาได้ทุกโรงพยาบาลฟรี 72 ชั่วโมงแรก โดยไม่ต้องสำรองจ่าย ตามนโยบาย สปสช.' },
  { question: 'อาการไหนถือว่าฉุกเฉินจริง?', answer: 'อาการฉุกเฉินวิกฤต เช่น หัวใจหยุดเต้น หมดสติ หายใจลำบาก เลือดออกมาก กระดูกหัก อุบัติเหตุรุนแรง ควรโทร 1669 หรือไปห้องฉุกเฉินทันที' },
  { question: 'ประกันคลุมค่าห้องฉุกเฉินไหม?', answer: 'ประกันสุขภาพส่วนใหญ่ครอบคลุมค่าห้องฉุกเฉิน แต่อาจมีเงื่อนไขการแจ้ง Pre-auth และเพดานค่าใช้จ่าย ควรตรวจสอบกรมธรรม์ก่อน' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าห้องฉุกเฉิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าห้องฉุกเฉิน</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">ประมาณการค่าใช้จ่ายห้องฉุกเฉิน ตามความรุนแรงของอาการ</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="er_fee" class="block text-sm font-medium text-gray-700 mb-1">ค่าบริการห้องฉุกเฉิน (บาท)</label><input type="text" id="er_fee" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="er_doctor" class="block text-sm font-medium text-gray-700 mb-1">ค่าแพทย์ฉุกเฉิน (บาท)</label><input type="text" id="er_doctor" inputmode="decimal" placeholder="เช่น 800" value="800" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="er_tests" class="block text-sm font-medium text-gray-700 mb-1">ค่าตรวจและแล็บ (บาท)</label><input type="text" id="er_tests" inputmode="decimal" placeholder="เช่น 3000" value="3000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="er_procedure" class="block text-sm font-medium text-gray-700 mb-1">ค่าหัตถการและยา (บาท)</label><input type="text" id="er_procedure" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="ambulance" class="block text-sm font-medium text-gray-700 mb-1">ค่ารถพยาบาล (บาท)</label><input type="text" id="ambulance" inputmode="decimal" placeholder="เช่น 1500" value="1500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าบริการ ER</p>
            <p id="er_subtotal" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมค่าฉุกเฉินทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const erFee = parseFloat((document.getElementById('er_fee') as HTMLInputElement).value) || 0;
      const erDoctor = parseFloat((document.getElementById('er_doctor') as HTMLInputElement).value) || 0;
      const erTests = parseFloat((document.getElementById('er_tests') as HTMLInputElement).value) || 0;
      const erProcedure = parseFloat((document.getElementById('er_procedure') as HTMLInputElement).value) || 0;
      const ambulance = parseFloat((document.getElementById('ambulance') as HTMLInputElement).value) || 0;

      const erSubtotal = erFee + erDoctor + erTests + erProcedure;
      const total = erSubtotal + ambulance;

      (document.getElementById('er_subtotal') as HTMLElement).textContent = erSubtotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('emergency-room-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
