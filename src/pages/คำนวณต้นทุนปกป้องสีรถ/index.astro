---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณต้นทุนปกป้องสีรถยนต์ ปี 2569 | Paint Protection Film vs Ceramic | Calculator Thailand';
const pageDescription = 'เปรียบเทียบต้นทุนการปกป้องสีรถระหว่าง PPF ฟิล์มใส แว็กซ์ และ Ceramic Coating';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนปกป้องสีรถ/`;

const faqData = [
  {
    question: 'PPF กับ Ceramic Coating ต่างกันอย่างไร?',
    answer: 'PPF (Paint Protection Film) หรือฟิล์มใสกันรอยเป็นแผ่นฟิล์มโพลิเมอร์ที่ติดบนสีรถ ป้องกันรอยขีดข่วน หินกระเด็น และความเสียหายทางกายภาพได้ดีมาก อายุใช้งาน 5-10 ปี ส่วน Ceramic Coating เป็นสารเคลือบแก้วระดับนาโนที่ทำให้สีรถเงา ป้องกันสิ่งสกปรก น้ำ และรังสี UV อายุใช้งาน 2-5 ปี ราคาถูกกว่า PPF แต่ป้องกันรอยทางกายภาพได้น้อยกว่า',
  },
  {
    question: 'แว็กซ์รถคุ้มค่ากว่า Ceramic หรือไม่?',
    answer: 'แว็กซ์มีราคาถูกกว่ามาก (500-1,000 บาทต่อครั้ง) แต่อายุใช้งานสั้นเพียง 1-3 เดือน ต้องทำซ้ำบ่อย ค่าใช้จ่ายต่อปีอาจสูงถึง 2,000-6,000 บาท เทียบกับ Ceramic ที่ค่าใช้จ่ายต่อปีต่ำกว่า Ceramic ยังให้ความเงา ความกันน้ำ และการป้องกัน UV ที่ดีกว่าแว็กซ์มาก ถ้ารักษารถระยะยาว Ceramic คุ้มกว่า',
  },
  {
    question: 'PPF เต็มคันราคาเท่าไร?',
    answer: 'PPF เต็มคันในไทยปี 2569 ราคาประมาณ 25,000-80,000 บาท ขึ้นอยู่กับขนาดรถและแบรนด์ฟิล์ม ฟิล์มจากแบรนด์ดังอย่าง XPEL หรือ 3M ราคาสูงกว่า ส่วน PPF เฉพาะด้านหน้า (บังโคลน ฝากระโปรง กันชนหน้า) ราคา 8,000-20,000 บาท ซึ่งเป็นจุดที่รอยขีดข่วนและหินกระเด็นมากที่สุด',
  },
  {
    question: 'ควรเลือกประเภทการปกป้องสีแบบไหน?',
    answer: 'ขึ้นอยู่กับงบประมาณและวัตถุประสงค์ หากรถใหม่มูลค่าสูงและต้องการรักษาสภาพสมบูรณ์แนะนำ PPF เต็มคัน ถ้างบจำกัดทำ PPF เฉพาะด้านหน้า + Ceramic ทั้งคัน หากต้องการความเงาและป้องกัน UV แต่ไม่กังวลรอยเล็กๆ ใช้ Ceramic เพียงอย่างเดียว และถ้ารถเก่าหรืองบน้อย แว็กซ์คุณภาพดีก็เพียงพอ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนปกป้องสีรถยนต์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนปกป้องสีรถ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณต้นทุนปกป้องสีรถยนต์
    </h1>
    <p class="text-gray-600 mb-6">
      เปรียบเทียบต้นทุนระหว่าง PPF ฟิล์มใส Ceramic Coating และแว็กซ์ พร้อมวิเคราะห์ค่าใช้จ่ายต่อปีและมูลค่าการปกป้องสีรถ
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-5">
        <div>
          <label for="vehicle-size" class="block text-sm font-medium text-gray-700 mb-1">
            ขนาดรถยนต์
          </label>
          <select
            id="vehicle-size"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="small">รถเล็ก (เก๋งเล็ก/อีโค่คาร์)</option>
            <option value="medium" selected>รถกลาง (เก๋งกลาง/กระบะ)</option>
            <option value="large">รถใหญ่ (SUV/MPV/Van)</option>
          </select>
        </div>
        <div>
          <label for="protection-type" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทการปกป้องสี
          </label>
          <select
            id="protection-type"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="ppf-full">PPF เต็มคัน</option>
            <option value="ppf-partial">PPF เฉพาะด้านหน้า</option>
            <option value="ceramic" selected>Ceramic Coating เต็มคัน</option>
            <option value="wax">แว็กซ์ (ต่อครั้ง)</option>
          </select>
        </div>
        <div>
          <label for="vehicle-value" class="block text-sm font-medium text-gray-700 mb-1">
            มูลค่ารถยนต์ (บาท)
          </label>
          <input
            type="text"
            id="vehicle-value"
            inputmode="decimal"
            value="800000"
            placeholder="เช่น 800000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="wax-frequency" class="block text-sm font-medium text-gray-700 mb-1">
            ความถี่ทำแว็กซ์ต่อปี (ครั้ง) — สำหรับแว็กซ์เท่านั้น
          </label>
          <select
            id="wax-frequency"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
          >
            <option value="3">3 ครั้ง/ปี (ทุก 4 เดือน)</option>
            <option value="4" selected>4 ครั้ง/ปี (ทุก 3 เดือน)</option>
            <option value="6">6 ครั้ง/ปี (ทุก 2 เดือน)</option>
            <option value="12">12 ครั้ง/ปี (ทุกเดือน)</option>
          </select>
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full px-6 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณต้นทุนและเปรียบเทียบ
      </button>

      <!-- Results -->
      <div id="result" class="hidden mt-6 space-y-4">
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-blue-700 font-medium mb-1">ค่าใช้จ่ายการปกป้องสี</div>
            <div id="res-cost" class="text-2xl font-bold text-blue-800">-</div>
            <div id="res-type-label" class="text-xs text-blue-600 mt-1">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4">
            <div class="text-sm text-green-700 font-medium mb-1">อายุใช้งาน / ระยะเวลาคืนทุน</div>
            <div id="res-lifespan" class="text-2xl font-bold text-green-800">-</div>
          </div>
          <div class="bg-amber-50 rounded-lg p-4">
            <div class="text-sm text-amber-700 font-medium mb-1">ค่าใช้จ่ายต่อปี</div>
            <div id="res-annual" class="text-2xl font-bold text-amber-800">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4">
            <div class="text-sm text-primary-700 font-medium mb-1">มูลค่าสีรถที่ปกป้องได้</div>
            <div id="res-paint-value" class="text-2xl font-bold text-primary-800">-</div>
            <div id="res-paint-pct" class="text-xs text-primary-600 mt-1">-</div>
          </div>
        </div>
        <div id="comparison-section" class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div class="text-sm font-semibold text-gray-700 mb-3">เปรียบเทียบทุกประเภท</div>
          <div id="comparison-table" class="space-y-2 text-sm"></div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">เปรียบเทียบการปกป้องสีรถยนต์ 2569</h2>
      <p>
        การปกป้องสีรถยนต์มีหลายวิธีที่ต่างกันในด้านราคา อายุใช้งาน และระดับการปกป้อง
        การเลือกที่เหมาะสมขึ้นอยู่กับงบประมาณ มูลค่ารถ และความต้องการของเจ้าของรถ
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ราคาการปกป้องสีรถในตลาดไทย 2569</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b border-gray-200">
              <th class="py-2 pr-3">ประเภท</th>
              <th class="py-2 pr-3">รถเล็ก (บาท)</th>
              <th class="py-2 pr-3">รถกลาง (บาท)</th>
              <th class="py-2">รถใหญ่ (บาท)</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-3">PPF เต็มคัน</td>
              <td class="py-2 pr-3">25,000</td>
              <td class="py-2 pr-3">40,000</td>
              <td class="py-2">60,000</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-3">PPF เฉพาะหน้า</td>
              <td class="py-2 pr-3">8,000</td>
              <td class="py-2 pr-3">12,000</td>
              <td class="py-2">16,000</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-3">Ceramic Coating</td>
              <td class="py-2 pr-3">8,000</td>
              <td class="py-2 pr-3">12,000</td>
              <td class="py-2">18,000</td>
            </tr>
            <tr>
              <td class="py-2 pr-3">แว็กซ์ (ต่อครั้ง)</td>
              <td class="py-2 pr-3">500</td>
              <td class="py-2 pr-3">700</td>
              <td class="py-2">1,000</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ข้อดี-ข้อเสียของแต่ละประเภท</h3>
      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li><strong>PPF เต็มคัน:</strong> ป้องกันได้สูงสุด อายุ 7-10 ปี แต่ราคาสูง เหมาะกับรถใหม่มูลค่าสูง</li>
        <li><strong>PPF เฉพาะด้านหน้า:</strong> ป้องกันจุดเสี่ยงที่สุด ราคาพอสมควร คุ้มค่าสำหรับรถทุกระดับ</li>
        <li><strong>Ceramic Coating:</strong> ความเงาสูง กันน้ำกันสิ่งสกปรก ป้องกัน UV ดี อายุ 2-5 ปี ราคากลาง</li>
        <li><strong>แว็กซ์:</strong> ราคาถูก หาง่าย แต่อายุสั้น ต้องทำซ้ำบ่อย ค่าใช้จ่ายสะสมสูงในระยะยาว</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณต้นทุนปกป้องสีรถ/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนปกป้องสีรถ/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ราคาและอายุใช้งานเป็นการประมาณการจากตลาดทั่วไป
      ราคาจริงขึ้นอยู่กับแบรนด์ผลิตภัณฑ์ ช่างผู้ติดตั้ง และสภาพรถ
      กรุณาสอบถามราคาจากผู้ให้บริการหลายเจ้าก่อนตัดสินใจ
    </div>
  </article>

  <script>
    interface ProtectionData {
      label: string;
      lifespan: number; // years
      paintProtectPct: number; // % of car value preserved
      costBySize: { small: number; medium: number; large: number };
    }

    const protections: Record<string, ProtectionData> = {
      'ppf-full':    { label: 'PPF เต็มคัน', lifespan: 8, paintProtectPct: 2.0, costBySize: { small: 25000, medium: 40000, large: 60000 } },
      'ppf-partial': { label: 'PPF เฉพาะด้านหน้า', lifespan: 7, paintProtectPct: 1.0, costBySize: { small: 8000, medium: 12000, large: 16000 } },
      'ceramic':     { label: 'Ceramic Coating', lifespan: 3, paintProtectPct: 1.0, costBySize: { small: 8000, medium: 12000, large: 18000 } },
      'wax':         { label: 'แว็กซ์ (ต่อครั้ง)', lifespan: 0.25, paintProtectPct: 0.5, costBySize: { small: 500, medium: 700, large: 1000 } },
    };

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
    }

    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const size = (document.getElementById('vehicle-size') as HTMLSelectElement).value as 'small' | 'medium' | 'large';
      const type = (document.getElementById('protection-type') as HTMLSelectElement).value;
      const vehicleValue = parseNum((document.getElementById('vehicle-value') as HTMLInputElement).value) || 800000;
      const waxFreq = parseInt((document.getElementById('wax-frequency') as HTMLSelectElement).value, 10);

      const prot = protections[type];
      const unitCost = prot.costBySize[size];
      const isWax = type === 'wax';
      const totalCost = isWax ? unitCost * waxFreq : unitCost;
      const annualCost = isWax ? unitCost * waxFreq : (unitCost / prot.lifespan);
      const lifespanLabel = isWax ? `${(1 / prot.lifespan / waxFreq * 12).toFixed(1)} เดือน/ครั้ง` : `${prot.lifespan} ปี`;

      const paintValue = vehicleValue * (prot.paintProtectPct / 100) * (isWax ? prot.lifespan * waxFreq : prot.lifespan);
      const paintValueAnnual = vehicleValue * (prot.paintProtectPct / 100);

      const sizeLabel = size === 'small' ? 'รถเล็ก' : size === 'medium' ? 'รถกลาง' : 'รถใหญ่';
      (document.getElementById('res-cost') as HTMLElement).textContent = `฿${fmt(totalCost)}`;
      (document.getElementById('res-type-label') as HTMLElement).textContent = `${prot.label} | ${sizeLabel}`;
      (document.getElementById('res-lifespan') as HTMLElement).textContent = lifespanLabel;
      (document.getElementById('res-annual') as HTMLElement).textContent = `฿${fmt(Math.round(annualCost))} / ปี`;
      (document.getElementById('res-paint-value') as HTMLElement).textContent = `฿${fmt(Math.round(paintValueAnnual))} / ปี`;
      (document.getElementById('res-paint-pct') as HTMLElement).textContent = `ช่วยรักษามูลค่าสี ${prot.paintProtectPct}% ของรถ (฿${fmt(vehicleValue)})`;

      // Comparison table
      const compEl = document.getElementById('comparison-table') as HTMLElement;
      const rows = Object.entries(protections).map(([k, p]) => {
        const c = p.costBySize[size];
        const isW = k === 'wax';
        const annC = isW ? c * waxFreq : c / p.lifespan;
        const selected = k === type ? ' font-bold text-primary-700' : ' text-gray-600';
        return `<div class="flex justify-between items-center py-1 border-b border-gray-100 last:border-0">
          <span class="text-gray-700${selected}">${p.label}</span>
          <span class="${selected}">฿${fmt(Math.round(annC))} / ปี</span>
        </div>`;
      }).join('');
      compEl.innerHTML = rows;

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
    });
  </script>
</BaseLayout>
