---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAVariants from '../components/CTAVariants.astro';
import FormVariants from '../components/FormVariants.astro';

// Phase 3: Variant Testing Showcase
// This page demonstrates all conversion optimization variants
---

<BaseLayout
  title="Phase 3: Conversion Optimization Variants"
  description="Live A/B testing variants for conversion rate optimization"
>
  <div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-50 py-12">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 mb-3">Phase 3: Conversion Optimization</h1>
        <p class="text-xl text-gray-600">Testing 4 CTA variants and 3 form layouts to maximize conversions</p>
        <p class="text-sm text-blue-600 mt-2">
          Each variant is tracked for conversions. Winner variants will be rolled out to 100% traffic.
        </p>
      </div>

      <!-- CTA Variants Section -->
      <div class="mb-16">
        <div class="bg-white rounded-lg shadow-lg p-8 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-2">CTA Button Variants (Test 1)</h2>
          <p class="text-gray-600 mb-8">
            Testing 4 different button styles, colors, and copy to find the highest conversion rate.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="border-l-4 border-blue-600 pl-6 py-4">
              <h3 class="font-bold text-gray-900 mb-3">Control (Baseline)</h3>
              <CTAVariants variant="control" testId="phase3-cta-test" />
            </div>

            <div class="border-l-4 border-green-600 pl-6 py-4">
              <h3 class="font-bold text-gray-900 mb-3">Variant A (Green + Copy)</h3>
              <CTAVariants variant="variant_a" testId="phase3-cta-test" />
            </div>

            <div class="border-l-4 border-orange-600 pl-6 py-4">
              <h3 class="font-bold text-gray-900 mb-3">Variant B (Orange + Size)</h3>
              <CTAVariants variant="variant_b" testId="phase3-cta-test" />
            </div>

            <div class="border-l-4 border-indigo-600 pl-6 py-4">
              <h3 class="font-bold text-gray-900 mb-3">Variant C (Indigo + Proof)</h3>
              <CTAVariants variant="variant_c" testId="phase3-cta-test" />
            </div>
          </div>
        </div>
      </div>

      <!-- Form Variants Section -->
      <div class="mb-16">
        <div class="bg-white rounded-lg shadow-lg p-8 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Form Friction Variants (Test 2)</h2>
          <p class="text-gray-600 mb-8">
            Testing 3 different form lengths to find the optimal balance between data collection and conversion.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="border-t-4 border-blue-600 pt-6">
              <h3 class="font-bold text-gray-900 mb-3">Control (Full Form)</h3>
              <FormVariants variant="control" />
            </div>

            <div class="border-t-4 border-green-600 pt-6">
              <h3 class="font-bold text-gray-900 mb-3">Variant A (Minimal)</h3>
              <FormVariants variant="variant_a" />
            </div>

            <div class="border-t-4 border-indigo-600 pt-6">
              <h3 class="font-bold text-gray-900 mb-3">Variant B (Progressive)</h3>
              <FormVariants variant="variant_b" />
            </div>
          </div>
        </div>
      </div>

      <!-- Results Dashboard Link -->
      <div class="bg-white rounded-lg shadow-lg p-8 text-center">
        <h3 class="text-xl font-bold text-gray-900 mb-4">Live Test Results</h3>
        <p class="text-gray-600 mb-6">
          All variants are tracked in real-time. View performance metrics and statistical significance.
        </p>
        <a
          href="/admin/conversion-dashboard"
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg transition-colors"
        >
          View Conversion Dashboard →
        </a>
      </div>

      <!-- Tracking Info -->
      <div class="mt-8 bg-blue-50 border-l-4 border-blue-600 rounded p-6">
        <h4 class="font-bold text-blue-900 mb-2">📊 Tracking Active</h4>
        <p class="text-sm text-blue-800">
          All variants are instrumented with conversion tracking. Each button click and form submission is recorded
          with timestamp, user session, and page URL. Winner variants will be determined by conversion rate and
          statistical confidence (95%+).
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
