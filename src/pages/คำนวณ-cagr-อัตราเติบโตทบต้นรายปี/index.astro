---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ CAGR อัตราเติบโตรายปี 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณ CAGR อัตราเติบโตทบต้นรายปี 2569 ฟรี — เปรียบเทียบผลตอบแทนพอร์ต กองทุน หรือยอดขายได้อย่างแม่นยำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-cagr-อัตราเติบโตทบต้นรายปี/`;

const faqData = [
  {
    question: 'CAGR คืออะไร และใช้เมื่อไร?',
    answer: 'CAGR (Compound Annual Growth Rate) หรืออัตราการเติบโตทบต้นรายปี คืออัตราการเติบโตเฉลี่ยต่อปีที่สม่ำเสมอ โดยสมมติว่าการเติบโตทบต้นทุกปี ใช้เปรียบเทียบผลตอบแทนการลงทุน การเติบโตของรายได้ หรือขนาดตลาด ดีกว่าค่าเฉลี่ยธรรมดาเพราะคำนึงถึงผลทบต้น',
  },
  {
    question: 'CAGR ต่างจากค่าเฉลี่ยการเติบโตอย่างไร?',
    answer: 'ค่าเฉลี่ยธรรมดา (Arithmetic Mean) รวมอัตราเติบโตแต่ละปีแล้วหาร ส่วน CAGR ใช้ค่าเริ่มต้นและสิ้นสุดเท่านั้น ไม่สนใจความผันผวนระหว่างทาง ตัวอย่าง: ถ้าหุ้นขึ้น 100% แล้วลง 50% ค่าเฉลี่ย = 25% แต่ CAGR = 0% เพราะกลับมาเท่าเดิม',
  },
  {
    question: 'CAGR ที่ดีสำหรับการลงทุนในหุ้น SET คือเท่าไร?',
    answer: 'ดัชนี SET ไทยมี CAGR ย้อนหลัง 10 ปีประมาณ 5-8% ต่อปี กองทุนรวมหุ้นคุณภาพดีมักให้ CAGR 8-15% ต่อปี นักลงทุนส่วนตัวที่ใช้ value investing อาจทำได้ 10-20% ต่อปี การลงทุนที่ CAGR > 15% ถือว่าดีมากและมักมีความเสี่ยงสูง',
  },
  {
    question: 'ข้อจำกัดของ CAGR คืออะไร?',
    answer: 'CAGR มีข้อจำกัด: (1) ไม่แสดงความผันผวนระหว่างทาง โครงการที่ CAGR เท่ากันอาจมีความเสี่ยงต่างกันมาก (2) สมมติว่ากำไรทบต้นได้ทันทีตลอด ไม่เหมาะกับกระแสเงินสดที่ถอนออกระหว่างทาง (3) ค่าเริ่มต้นผิดปกติ (ต่ำหรือสูงมาก) ทำให้ CAGR บิดเบือน',
  },
  {
    question: 'ใช้ CAGR คำนวณเป้าหมายการลงทุนได้ไหม?',
    answer: 'ได้ ถ้ารู้ CAGR เป้าหมายและระยะเวลา สามารถหา End Value ได้: End Value = Start Value × (1 + CAGR)^n เช่น ลงทุน 100,000 บาท CAGR 10% เป็นเวลา 10 ปี → End Value = 100,000 × 1.1^10 = 259,374 บาท',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ CAGR อัตราเติบโตทบต้นรายปี',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณ CAGR อัตราเติบโตทบต้นรายปี',
  description: 'ขั้นตอนการคำนวณ CAGR สำหรับการลงทุน รายได้ หรือขนาดตลาด',
  step: [
    {
      '@type': 'HowToStep',
      name: 'กรอกมูลค่าเริ่มต้น',
      text: 'ระบุมูลค่าเริ่มต้น เช่น เงินลงทุนเริ่มต้น รายได้ปีแรก หรือขนาดตลาดในปีฐาน',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกมูลค่าสิ้นสุด',
      text: 'ระบุมูลค่าสิ้นสุด เช่น มูลค่าพอร์ตปัจจุบัน รายได้ปีสุดท้าย หรือขนาดตลาดปีปัจจุบัน',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกจำนวนปี',
      text: 'ระบุจำนวนปีระหว่างมูลค่าเริ่มต้นและสิ้นสุด เช่น 5 ปี หรือ 10 ปี',
    },
    {
      '@type': 'HowToStep',
      name: 'อ่านผล CAGR',
      text: 'ระบบแสดง CAGR % ต่อปี และการเติบโตรวม (Total Growth %) เปรียบเทียบกับอัตราตลาดอ้างอิง',
    },
  ],
};
---

<BaseLayout noGenericHowTo={true} title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-cagr-อัตราเติบโตทบต้นรายปี">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณ CAGR — อัตราเติบโตทบต้นรายปี</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: CAGR = (End/Start)^(1/n) − 1</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณ CAGR อัตราเติบโตทบต้นรายปี (Compound Annual Growth Rate) 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณ CAGR สำหรับการลงทุน รายได้ธุรกิจ หรือขนาดตลาด พร้อมการเติบโตรวมและการเปรียบเทียบกับ SET Index
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'ตลาดหลักทรัพย์แห่งประเทศไทย (SET): ผลตอบแทนดัชนีย้อนหลัง',
        'กองทุนบัวหลวง: คู่มือการลงทุน CAGR',
      ]}
      assumptions={[
        'สูตร: CAGR = (End Value ÷ Start Value)^(1÷Years) − 1',
        'สมมติการทบต้นต่อเนื่อง ไม่มีการถอนกลางทาง',
      ]}
      references={[
        { label: 'SET: ผลตอบแทนดัชนี SET', href: 'https://www.set.or.th' },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="cagr-form" class="space-y-5">
        <p id="cagr-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="cagr-start" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าเริ่มต้น (บาท)</label>
            <input type="text" id="cagr-start" inputmode="numeric" placeholder="เช่น 100,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="cagr-end" class="block text-sm font-medium text-gray-700 mb-1">มูลค่าสิ้นสุด (บาท)</label>
            <input type="text" id="cagr-end" inputmode="numeric" placeholder="เช่น 200,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="cagr-years" class="block text-sm font-medium text-gray-700 mb-1">จำนวนปี</label>
            <input type="text" id="cagr-years" inputmode="decimal" placeholder="เช่น 5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
        </div>

        <button type="submit" id="cagr-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณ CAGR
        </button>
      </form>
    </div>

    <div id="cagr-results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ CAGR</h2>
        <div class="grid gap-3 sm:grid-cols-2 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">CAGR</div>
            <div id="res-cagr" class="text-2xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">การเติบโตรวม (Total Growth)</div>
            <div id="res-cagr-total" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">มูลค่าเริ่มต้น</span>
            <span id="res-cagr-sv" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">มูลค่าสิ้นสุด</span>
            <span id="res-cagr-ev" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ระยะเวลา</span>
            <span id="res-cagr-yrs" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">กำไร/ขาดทุน</span>
            <span id="res-cagr-gain" class="font-medium">-</span>
          </div>
        </div>
        <div class="mt-4 rounded-lg bg-blue-50 p-3">
          <p id="res-cagr-benchmark" class="text-sm text-blue-800"></p>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#cagr-results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรและวิธีคำนวณ CAGR</h2>
      <div class="bg-gray-50 rounded-lg p-4 my-4">
        <p class="font-semibold mb-1">สูตร CAGR:</p>
        <p class="text-sm">CAGR = (มูลค่าสิ้นสุด ÷ มูลค่าเริ่มต้น)^(1 ÷ จำนวนปี) − 1</p>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">ตัวอย่าง: ลงทุน 100,000 บาท ได้ 200,000 บาทใน 5 ปี</h3>
      <div class="bg-blue-50 rounded-lg p-4 text-sm mb-4">
        <ul class="list-disc pl-6 text-gray-700 space-y-1">
          <li>CAGR = (200,000 ÷ 100,000)^(1/5) − 1</li>
          <li>= (2)^0.2 − 1</li>
          <li>= 1.1487 − 1</li>
          <li><strong>= 14.87% ต่อปี (Total Growth = 100%)</strong></li>
        </ul>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        <strong>แหล่งอ้างอิง:</strong>
        <a href="https://www.set.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">ตลาดหลักทรัพย์แห่งประเทศไทย (SET)</a>
      </p>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-cagr-อัตราเติบโตทบต้นรายปี/" />
    <RelatedCalculators currentHref="/คำนวณ-cagr-อัตราเติบโตทบต้นรายปี/" slugs={['คำนวณ-ดอกเบี้ยทบต้น', 'คำนวณ-มูลค่าอนาคต-future-value', 'คำนวณ-roe-ผลตอบแทนผู้ถือหุ้น']} />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ ผลตอบแทนในอดีตไม่ได้รับประกันผลตอบแทนในอนาคต
    </div>
  </article>
</BaseLayout>

<script>
  function parseNum(v: string): number {
    return parseFloat(String(v).replace(/,/g, '').trim()) || 0;
  }
  function fmt(n: number): string {
    return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
  }

  const form = document.getElementById('cagr-form') as HTMLFormElement;
  const formError = document.getElementById('cagr-form-error') as HTMLElement;
  const resultsDiv = document.getElementById('cagr-results') as HTMLElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    formError.classList.add('hidden');

    const startVal = parseNum((document.getElementById('cagr-start') as HTMLInputElement).value);
    const endVal = parseNum((document.getElementById('cagr-end') as HTMLInputElement).value);
    const years = parseNum((document.getElementById('cagr-years') as HTMLInputElement).value);

    if (startVal <= 0 || endVal <= 0 || years <= 0) {
      formError.classList.remove('hidden');
      formError.textContent = 'กรุณากรอกมูลค่าเริ่มต้น มูลค่าสิ้นสุด และจำนวนปีให้ถูกต้อง (ต้องมากกว่า 0)';
      return;
    }

    const cagr = Math.pow(endVal / startVal, 1 / years) - 1;
    const totalGrowth = (endVal / startVal - 1) * 100;
    const gain = endVal - startVal;

    (document.getElementById('res-cagr') as HTMLElement).textContent = (cagr * 100).toFixed(2) + '% ต่อปี';
    (document.getElementById('res-cagr-total') as HTMLElement).textContent = totalGrowth.toFixed(2) + '%';
    (document.getElementById('res-cagr-sv') as HTMLElement).textContent = fmt(startVal) + ' บาท';
    (document.getElementById('res-cagr-ev') as HTMLElement).textContent = fmt(endVal) + ' บาท';
    (document.getElementById('res-cagr-yrs') as HTMLElement).textContent = years.toFixed(1) + ' ปี';

    const gainEl = document.getElementById('res-cagr-gain') as HTMLElement;
    gainEl.textContent = (gain >= 0 ? '+' : '') + fmt(gain) + ' บาท';
    gainEl.className = 'font-medium ' + (gain >= 0 ? 'text-green-700' : 'text-red-600');

    const cagrPct = cagr * 100;
    let benchmark = '';
    if (cagrPct < 0) benchmark = 'ผลตอบแทนติดลบ — ขาดทุนจากการลงทุน';
    else if (cagrPct < 5) benchmark = `CAGR ${cagrPct.toFixed(2)}% — ต่ำกว่า SET Index เฉลี่ย (~5-8%) ควรพิจารณาทางเลือกอื่น`;
    else if (cagrPct < 10) benchmark = `CAGR ${cagrPct.toFixed(2)}% — ใกล้เคียง SET Index เฉลี่ย (~5-8%) ผลตอบแทนพอใช้`;
    else if (cagrPct < 15) benchmark = `CAGR ${cagrPct.toFixed(2)}% — สูงกว่า SET Index เฉลี่ย ผลตอบแทนดี`;
    else benchmark = `CAGR ${cagrPct.toFixed(2)}% — ผลตอบแทนดีเยี่ยม สูงกว่าตลาดมาก (มักมีความเสี่ยงสูง)`;

    (document.getElementById('res-cagr-benchmark') as HTMLElement).textContent = benchmark;

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
