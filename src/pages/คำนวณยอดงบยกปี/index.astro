---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณยอดงบยกปีถัดไป 2569 | ยกยอดงบประมาณ | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณยอดงบประมาณคงเหลือจากปีนี้ที่สามารถยกไปปีหน้า ตามหมวดค่าใช้จ่าย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณยอดงบยกปี/`;

const faqData = [
  {
    question: 'การยกยอดงบประมาณ (Budget Rollover) คืออะไร?',
    answer: 'Budget Rollover คือการนำเงินงบประมาณที่ใช้ไม่หมดในปีนี้ยกไปใช้ในปีหน้าหรือเดือนถัดไป วิธีนี้ช่วยไม่ให้เงิน "หาย" เมื่อสิ้นงวด และให้ความยืดหยุ่นในการบริหารค่าใช้จ่ายตามฤดูกาล',
  },
  {
    question: 'ควรยกยอดงบประมาณทุกหมวดหรือไม่?',
    answer: 'ไม่จำเป็น ควรยกยอดเฉพาะหมวดที่ค่าใช้จ่ายไม่สม่ำเสมอ เช่น ค่าซ่อมบำรุง ค่าเดินทางท่องเที่ยว หรือของขวัญเทศกาล ส่วนหมวดที่ค่าใช้จ่ายสม่ำเสมออย่างค่าเช่าหรือค่าอาหาร ไม่จำเป็นต้องยกยอด',
  },
  {
    question: 'หากใช้เงินเกินงบจะทำอย่างไร?',
    answer: 'หากใช้เกินงบในหมวดใด ควรปรับลดงบหมวดอื่นที่ยังมีเงินเหลือ หรือวางแผนเพิ่มงบในหมวดนั้นสำหรับปีหน้า การติดตามยอดใช้จริงทุกเดือนจะช่วยให้คาดการณ์ได้แม่นยำขึ้น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณยอดงบยกปี',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณยอดงบยกปี">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณยอดงบยกปีถัดไป 2569</h1>
    <p class="mb-6 text-gray-600">กรอกงบตั้งต้น ยอดใช้จริงสะสม และเดือนที่เหลือในปี เพื่อดูว่างบจะเหลือหรือขาด สามารถดูการวางแผนลดค่าใช้จ่ายได้ที่ <a href="/คำนวณเป้าลดค่าใช้จ่าย/" class="text-primary-600 underline hover:text-primary-800">คำนวณเป้าลดค่าใช้จ่าย</a> หรือ <a href="/คำนวณงบซองเงินสด/" class="text-primary-600 underline hover:text-primary-800">คำนวณงบซองเงินสด</a></p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="rollover-form" class="space-y-4">
        <div>
          <label for="annual-budget" class="mb-1 block text-sm font-medium text-gray-700">งบที่ตั้งไว้ต่อปี (บาท)</label>
          <input id="annual-budget" type="text" inputmode="numeric" placeholder="เช่น 120000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="spent-so-far" class="mb-1 block text-sm font-medium text-gray-700">ยอดใช้จริงสะสมถึงตอนนี้ (บาท)</label>
          <input id="spent-so-far" type="text" inputmode="numeric" placeholder="เช่น 70000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="months-left" class="mb-1 block text-sm font-medium text-gray-700">เดือนที่เหลือในปี (1-12)</label>
          <input id="months-left" type="text" inputmode="numeric" placeholder="เช่น 4"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
          <div class="rounded-lg bg-primary-50 p-3 text-center">
            <div class="mb-1 text-xs text-gray-600">งบคงเหลือ</div>
            <div id="res-remaining" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-3 text-center">
            <div class="mb-1 text-xs text-gray-600">งบเฉลี่ย/เดือนที่เหลือ</div>
            <div id="res-avg-mo" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-3 text-center">
            <div class="mb-1 text-xs text-gray-600">คาดการณ์ใช้จริงสิ้นปี</div>
            <div id="res-forecast" class="text-xl font-bold text-orange-700">-</div>
          </div>
          <div class="rounded-lg bg-purple-50 p-3 text-center">
            <div class="mb-1 text-xs text-gray-600">ยอดที่จะยกหรือขาด</div>
            <div id="res-rollover" class="text-xl font-bold text-purple-700">-</div>
          </div>
        </div>
        <div id="res-msg" class="rounded-lg p-3 text-sm font-medium"></div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณยอดงบยกปี/" categoryId="budget" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(Math.abs(v)).toLocaleString('th-TH');

  document.getElementById('rollover-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const budget = parseNum((document.getElementById('annual-budget') as HTMLInputElement).value);
    const spent = parseNum((document.getElementById('spent-so-far') as HTMLInputElement).value);
    const monthsLeft = parseNum((document.getElementById('months-left') as HTMLInputElement).value);

    if (budget <= 0 || monthsLeft <= 0) return;

    const monthsPassed = 12 - monthsLeft;
    const avgSpentPerMonth = monthsPassed > 0 ? spent / monthsPassed : 0;
    const forecastTotal = spent + avgSpentPerMonth * monthsLeft;
    const remaining = budget - spent;
    const avgPerRemaining = remaining / monthsLeft;
    const rollover = budget - forecastTotal;

    document.getElementById('res-remaining')!.textContent = fmt(remaining);
    document.getElementById('res-avg-mo')!.textContent = fmt(avgPerRemaining);
    document.getElementById('res-forecast')!.textContent = fmt(forecastTotal);

    const rolloverEl = document.getElementById('res-rollover')!;
    if (rollover >= 0) {
      rolloverEl.textContent = '+' + fmt(rollover) + ' (ยกได้)';
      rolloverEl.className = 'text-xl font-bold text-green-700';
    } else {
      rolloverEl.textContent = '-' + fmt(rollover) + ' (ขาด)';
      rolloverEl.className = 'text-xl font-bold text-red-600';
    }

    const msgEl = document.getElementById('res-msg')!;
    if (rollover >= 0) {
      msgEl.textContent = `✅ คาดว่าจะเหลืองบ ${fmt(rollover)} ยกไปปีหน้าได้`;
      msgEl.className = 'rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800';
    } else {
      msgEl.textContent = `⚠️ คาดว่าจะใช้เกินงบ ${fmt(Math.abs(rollover))} ควรลดค่าใช้จ่ายใน ${monthsLeft} เดือนที่เหลือ`;
      msgEl.className = 'rounded-lg bg-yellow-50 p-3 text-sm font-medium text-yellow-800';
    }

    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
