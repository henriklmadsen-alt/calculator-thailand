---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณผลกระทบ Spread แลกเงิน 2569 | ค่าใช้จ่ายแฝงแลกเปลี่ยน | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณผลกระทบของ spread ในการแลกเปลี่ยนเงินตรา เปรียบเทียบอัตรา mid-rate กับอัตราธนาคาร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณผลกระทบสเปรดแลกเงิน/`;

const faqData = [
  {
    question: 'Spread ในการแลกเงินคืออะไร?',
    answer: 'Spread คือส่วนต่างระหว่างอัตราซื้อและอัตราขายเงินตราต่างประเทศ ซึ่งเป็นแหล่งรายได้หลักของธนาคารและร้านแลกเงิน ยิ่ง spread กว้าง ยิ่งเสียค่าใช้จ่ายมาก',
  },
  {
    question: 'Mid-rate คืออะไร และทำไมถึงสำคัญ?',
    answer: 'Mid-rate คืออัตราแลกเปลี่ยนกลาง ซึ่งเป็นค่าเฉลี่ยระหว่างอัตราซื้อและอัตราขาย ใช้เป็นเกณฑ์อ้างอิงเพื่อวัดว่าเราเสีย spread ไปเท่าไร บริการเช่น Wise (TransferWise) มักใช้ mid-rate',
  },
  {
    question: 'จะลด spread ในการแลกเงินได้อย่างไร?',
    answer: 'เปรียบเทียบอัตราจากหลายแหล่ง เลือกร้านแลกเงินที่มี spread แคบ ใช้บริการโอนเงินออนไลน์ที่ใช้ mid-rate เช่น Wise หรือแลกเงินในปริมาณมากครั้งเดียวเพื่อลดต้นทุนต่อหน่วย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผลกระทบ Spread แลกเงิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผลกระทบสเปรดแลกเงิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณผลกระทบ Spread แลกเงิน 2569</h1>
    <p class="mb-6 text-gray-600">คำนวณต้นทุนแฝงจาก spread ในการแลกเงิน เปรียบเทียบอัตรา mid-rate กับอัตราธนาคาร</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc-form" class="space-y-4">
        <div>
          <label for="amount-usd" class="mb-1 block text-sm font-medium text-gray-700">จำนวนเงิน (USD)</label>
          <input id="amount-usd" type="text" inputmode="numeric" placeholder="เช่น 1000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="mid-rate" class="mb-1 block text-sm font-medium text-gray-700">Mid-rate (บาท/USD)</label>
          <input id="mid-rate" type="text" inputmode="decimal" placeholder="เช่น 36.00"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="bank-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราซื้อธนาคาร (บาท/USD)</label>
          <input id="bank-rate" type="text" inputmode="decimal" placeholder="เช่น 35.20"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
          <p class="mt-1 text-xs text-gray-500">อัตราที่ธนาคารจ่ายให้คุณเมื่อแลก USD เป็นบาท</p>
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">Spread (บาท/USD)</div>
            <div id="res-spread" class="text-3xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุน spread รวม (บาท)</div>
            <div id="res-cost" class="text-3xl font-bold text-red-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">% ค่าธรรมเนียมแฝง</div>
            <div id="res-pct" class="text-3xl font-bold text-orange-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณผลกระทบสเปรดแลกเงิน/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n > 0 ? n : 0;
  };

  document.getElementById('calc-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const amount = parseNum((document.getElementById('amount-usd') as HTMLInputElement).value);
    const midRate = parseNum((document.getElementById('mid-rate') as HTMLInputElement).value);
    const bankRate = parseNum((document.getElementById('bank-rate') as HTMLInputElement).value);
    if (!amount || !midRate || !bankRate) return;

    const spread = midRate - bankRate;
    const cost = spread * amount;
    const pct = (spread / midRate) * 100;

    document.getElementById('res-spread')!.textContent = spread.toFixed(2) + ' ฿';
    document.getElementById('res-cost')!.textContent = '฿' + Math.round(cost).toLocaleString('th-TH');
    document.getElementById('res-pct')!.textContent = pct.toFixed(2) + '%';
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
