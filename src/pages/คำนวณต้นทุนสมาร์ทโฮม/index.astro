---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณต้นทุนสมาร์ทโฮม 2569 | ระบบบ้านอัจฉริยะ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนติดตั้งระบบสมาร์ทโฮม รวมวัสดุ แรงงาน และอุปกรณ์อัตโนมัติ พร้อมประมาณการรอบสิบ สำหรับบ้านทั่วประเทศ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนสมาร์ทโฮม/`;

const faqData = [
  {
    question: 'สมาร์ทโฮมคืออะไร และต้นทุนการติดตั้งประมาณเท่าไหร่?',
    answer: 'สมาร์ทโฮมเป็นระบบอัตโนมัติที่ควบคุมอุปกรณ์ต่างๆ ในบ้านผ่านโทรศัพท์หรือเสียง เช่น ไฟ แอร์ กล้อง และล็อคประตู ต้นทุนเริ่มต้นสำหรับบ้านขนาดเล็ก (1-2 ห้อง) ประมาณ 50,000-100,000 บาท ส่วนบ้านขนาดใหญ่อาจถึง 200,000-500,000 บาท ขึ้นอยู่กับอุปกรณ์ที่เลือก',
  },
  {
    question: 'ส่วนประกอบหลักของระบบสมาร์ทโฮมมีอะไรบ้าง?',
    answer: 'ส่วนประกอบหลักได้แก่ (1) Hub/Controller กลาง ควบคุมทั้งระบบ (2) Smart Devices เช่น สวิตช์ไฟ หลอดไฟ เซ็นเซอร์ (3) การเชื่อมต่ออินเทอร์เน็ต WiFi หรือ Zigbee (4) การติดตั้งระบบไฟฟ้าและสายไฟ (5) แอปพลิเคชันบนมือถือสำหรับควบคุม',
  },
  {
    question: 'ควรติดตั้งสมาร์ทโฮมระหว่างการสร้างบ้านหรือหลังจากสร้างเสร็จแล้ว?',
    answer: 'ติดตั้งระหว่างการสร้างจะประหยัดกว่า เพราะสามารถวางสายไฟฟ้าลงในผนังได้สะดวก หากติดตั้งหลังสร้างเสร็จต้องขุดผนัง ซ่อมแซม และเสียค่าแรงมากขึ้น อย่างไรก็ตาม สมาร์ทโฮมแบบไร้สายก็มีให้เลือก ซึ่งติดตั้งได้ทันที',
  },
  {
    question: 'ต้นทุนรายปีสำหรับดูแลรักษาระบบสมาร์ทโฮมประมาณเท่าไหร่?',
    answer: 'ต้นทุนรายปีโดยทั่วไป 3,000-10,000 บาท หรือ 250-833 บาทต่อเดือน ขึ้นอยู่กับการสมัครใช้งาน Cloud Service การซ่อมบำรุง และการเปลี่ยนอุปกรณ์ที่หมดอายุ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนสมาร์ทโฮม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนสมาร์ทโฮม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณต้นทุนสมาร์ทโฮม
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2">
      <p class="text-xs font-semibold text-blue-800">[อัปเดต 2569 - ราคาตลาดปัจจุบัน]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณต้นทุนการติดตั้งระบบสมาร์ทโฮม สำหรับบ้านส่วนตัว รวมวัสดุ อุปกรณ์ แรงงาน และติดตั้งทั้งระบบ
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="homeSize" class="block text-sm font-medium text-gray-700 mb-1">
            ขนาดบ้าน (ตร.ม.)
          </label>
          <input
            type="number"
            id="homeSize"
            placeholder="เช่น 150"
            min="10"
            max="1000"
            value="150"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          />
        </div>
        <div>
          <label for="rooms" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนห้อง
          </label>
          <input
            type="number"
            id="rooms"
            placeholder="เช่น 4"
            min="1"
            max="20"
            value="4"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="lightingDevices" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนจุดไฟ (สวิตช์)
          </label>
          <input
            type="number"
            id="lightingDevices"
            placeholder="เช่น 15"
            min="5"
            max="50"
            value="15"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          />
        </div>
        <div>
          <label for="securityDevices" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนกล้องรักษาความปลอดภัย
          </label>
          <input
            type="number"
            id="securityDevices"
            placeholder="เช่น 4"
            min="1"
            max="20"
            value="4"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="hasAC" class="block text-sm font-medium text-gray-700 mb-1">
            เพิ่มระบบแอร์อัจฉริยะ
          </label>
          <select
            id="hasAC"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          >
            <option value="no">ไม่ใช่</option>
            <option value="yes">ใช่</option>
          </select>
        </div>
        <div>
          <label for="installationType" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทการติดตั้ง
          </label>
          <select
            id="installationType"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
          >
            <option value="wired">ระบบสายไฟ (มีเสถียรภาพสูง)</option>
            <option value="wireless">ระบบไร้สาย WiFi (ทำการติดตั้งง่าย)</option>
          </select>
        </div>
      </div>

      <button
        id="calculateBtn"
        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-md transition-colors"
      >
        คำนวณต้นทุน
      </button>
    </div>

    <!-- Results -->
    <div id="results" class="bg-blue-50 rounded-lg border border-blue-200 p-6 mb-8 hidden">
      <h2 class="text-xl font-bold text-gray-900 mb-4">ผลการคำนวณ</h2>

      <div class="bg-white rounded-lg p-4 mb-4 border border-blue-100">
        <p class="text-sm text-gray-600 mb-2">ต้นทุนรวมโดยประมาณ</p>
        <p id="totalCost" class="text-3xl font-bold text-blue-600 mb-2">0 บาท</p>
        <p class="text-xs text-gray-500">ราคาอาจแตกต่างตามสภาพบ้าน วัสดุ และเหตุการณ์ตามท้องที่</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-3 mb-4">
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <p class="text-xs text-gray-600 mb-1">ต้นทุนอุปกรณ์</p>
          <p id="deviceCost" class="text-lg font-bold text-gray-900">0 บาท</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <p class="text-xs text-gray-600 mb-1">ต้นทุนแรงงาน</p>
          <p id="laborCost" class="text-lg font-bold text-gray-900">0 บาท</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <p class="text-xs text-gray-600 mb-1">ต้นทุนติดตั้ง</p>
          <p id="installationCost" class="text-lg font-bold text-gray-900">0 บาท</p>
        </div>
      </div>

      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-4">
        <p class="text-sm text-gray-700">
          <strong>หมายเหตุ:</strong> ต้นทุนคำนวณจากอัตราตลาดปจจุบันในประเทศไทย ราคาอาจเปลี่ยนแปลงตามเวลา และอาจแตกต่างไปตามการออกแบบและหรูหราของระบบที่เลือก
        </p>
      </div>
    </div>

    <!-- Explanation -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">ข้อมูลเพิ่มเติมเกี่ยวกับต้นทุนสมาร์ทโฮม</h2>

      <div class="space-y-4 text-gray-700">
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">ต้นทุนอุปกรณ์ (Hardware)</h3>
          <p>
            หลัก อุปกรณ์ สวิตช์อัจฉริยะ 700-1,500 บาท/ชุด, หลอดไฟอัจฉริยะ 400-800 บาท/หลอด, กล้องวงจรปิด 2,000-5,000 บาท/ตัว, กล็อกประตูอัจฉริยะ 3,000-8,000 บาท, Hub/Controller 2,000-6,000 บาท
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">ต้นทุนแรงงาน (Labor)</h3>
          <p>
            การติดตั้งระบบสมาร์ทโฮมต้องอาศัยช่างผู้เชี่ยวชาญ โดยคิดค่าแรงขึ้นอยู่กับความซับซ้อน โดยทั่วไป 200-500 บาท/ชั่วโมง หรือเหมาจ่ายราคาคงที่ 15,000-40,000 บาท สำหรับบ้านขนาดปกติ
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-2">ต้นทุนเพิ่มเติม</h3>
          <p>
            การเซ็ตอัป Cloud Service ประมาณ 1,000-3,000 บาทต่อปี, ประกัน 5-10% ของต้นทุนรวม, อุปกรณ์เพิ่มเติมและการขยายระบบ
          </p>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="mb-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((item) => (
          <details class="border border-gray-300 rounded-lg p-4 cursor-pointer group">
            <summary class="font-semibold text-gray-900 group-open:text-blue-600 transition-colors">
              {item.question}
            </summary>
            <p class="text-gray-700 mt-3">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <RelatedCalculators exclude="smart-home" />
    <RelatedArticles category="home" />
  </article>

  <script define:vars={{ pageTitle }}>
    const calculateBtn = document.getElementById('calculateBtn');
    const resultsDiv = document.getElementById('results');
    const totalCostSpan = document.getElementById('totalCost');
    const deviceCostSpan = document.getElementById('deviceCost');
    const laborCostSpan = document.getElementById('laborCost');
    const installationCostSpan = document.getElementById('installationCost');

    calculateBtn.addEventListener('click', () => {
      const homeSize = parseInt(document.getElementById('homeSize').value) || 100;
      const rooms = parseInt(document.getElementById('rooms').value) || 3;
      const lightingDevices = parseInt(document.getElementById('lightingDevices').value) || 10;
      const securityDevices = parseInt(document.getElementById('securityDevices').value) || 2;
      const hasAC = document.getElementById('hasAC').value === 'yes';
      const installationType = document.getElementById('installationType').value;

      // Device costs (Thailand market rates, 2569)
      let deviceCost = 0;
      deviceCost += lightingDevices * 1000; // Smart switches/bulbs avg 1,000 baht
      deviceCost += securityDevices * 3000; // Cameras avg 3,000 baht
      deviceCost += 5000; // Hub/Controller
      deviceCost += 500 * rooms; // Sensors
      if (hasAC) {
        deviceCost += 8000; // Smart AC system
      }

      // Labor cost (varies by installation type)
      const laborHours = homeSize / 20 + rooms * 2; // Estimate based on area and rooms
      const hourlyRate = installationType === 'wired' ? 400 : 250;
      let laborCost = laborHours * hourlyRate;
      laborCost = Math.max(15000, Math.min(laborCost, 45000)); // Min 15k, Max 45k

      // Installation materials
      let installationCost = deviceCost * 0.15; // 15% for wiring, tools, materials
      if (installationType === 'wireless') {
        installationCost = deviceCost * 0.08; // Cheaper for wireless
      }

      const totalCost = deviceCost + laborCost + installationCost;

      // Display results
      resultsDiv.classList.remove('hidden');
      totalCostSpan.textContent = new Intl.NumberFormat('th-TH', {
        style: 'currency',
        currency: 'THB',
        maximumFractionDigits: 0,
      }).format(totalCost);
      deviceCostSpan.textContent = new Intl.NumberFormat('th-TH', {
        style: 'currency',
        currency: 'THB',
        maximumFractionDigits: 0,
      }).format(deviceCost);
      laborCostSpan.textContent = new Intl.NumberFormat('th-TH', {
        style: 'currency',
        currency: 'THB',
        maximumFractionDigits: 0,
      }).format(laborCost);
      installationCostSpan.textContent = new Intl.NumberFormat('th-TH', {
        style: 'currency',
        currency: 'THB',
        maximumFractionDigits: 0,
      }).format(installationCost);
    });
  </script>
</BaseLayout>
