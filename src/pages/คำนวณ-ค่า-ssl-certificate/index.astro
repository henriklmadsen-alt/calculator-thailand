---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณ ค่า SSL Certificate 2569 | Kamnuanlek';
const pageDescription = 'คำนวณค่าใบรับรอง SSL Certificate รวมการต่ออายุหลายปี ประเมินค่ารักษาความปลอดภัยเว็บไซต์อย่างแม่นยำ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่า-ssl-certificate/`;

const faqData = [
  {
    question: 'SSL Certificate คืออะไร เหตุใดจึงจำเป็น?',
    answer: 'SSL (Secure Sockets Layer) เข้ารหัสข้อมูลระหว่างเบราว์เซอร์ผู้ใช้และเซิร์ฟเวอร์เว็บ ปกป้องข้อมูลบ้านคน อีเมล รหัสผ่าน และการชำระเงินไม่ให้ถูกขโมย Google และเบราว์เซอร์อื่นๆ ให้ลำดับความสำคัญสูงกับเว็บไซต์ที่มี HTTPS',
  },
  {
    question: 'ความแตกต่างระหว่าง DV, OV, EV SSL Certificate คืออะไร?',
    answer: 'DV (Domain Validation) — ถูกที่สุด ตรวจสอบเฉพาะการเป็นเจ้าของโดเมน โอเค = 0-500 บาท OV (Organization Validation) — บันทึกอย่างเป็นทางการขององค์กร 1,500-5,000 บาท EV (Extended Validation) — ตรวจสอบเต็มที่ แสดง "Secure" สีเขียว 5,000-30,000 บาท',
  },
  {
    question: 'Let\'s Encrypt ฟรี ทำไมต้องจ่าย?',
    answer: 'Let\'s Encrypt ให้ DV SSL ฟรี เหมาะสำหรับบล็อกและเว็บสาธารณะ สำหรับเว็บอีคอมเมิร์สและธุรกิจ OV/EV มีความน่าเชื่อถือสูงกว่า บ้านคนเห็นเครื่องหมายล็อก และรหัส "Secure" ซึ่งเพิ่มการแปลง OV/EV มี Warranty ที่ครอบคลุมการละเมิด',
  },
  {
    question: 'ควรต่ออายุ SSL ประจำปีหรือสองปี?',
    answer: 'ประจำปีคือเทรนด์ปัจจุบัน เพิ่มความปลอดภัย (ต่ออายุ = ตรวจสอบใหม่) และความสะดวกในการจัดการ โปรแกรมจัดการใบรับรอง (ACME) สามารถต่ออายุโดยอัตโนมัติได้ สองปี = ราคาถูกกว่า 10% แต่มีความเสี่ยงหากลืม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่า SSL Certificate',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่า SSL Certificate">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🔒 คำนวณค่า SSL Certificate
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าใบรับรอง SSL Certificate สำหรับเว็บไซต์ของคุณ รวมการต่ออายุหลายปี
      ประเมินค่ารักษาความปลอดภัยเว็บไซต์อย่างแม่นยำ
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="ssl-form" class="space-y-5">
        <div>
          <label for="ssl-type" class="block text-sm font-medium text-gray-700 mb-2">
            ประเภท SSL Certificate
          </label>
          <select
            id="ssl-type"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          >
            <option value="dv">DV (Domain Validation) - ถูก</option>
            <option value="ov">OV (Organization Validation) - กลาง</option>
            <option value="ev">EV (Extended Validation) - แพง</option>
          </select>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="cert-count" class="block text-sm font-medium text-gray-700 mb-1">
              จำนวนใบรับรอง
            </label>
            <input
              type="text"
              id="cert-count"
              inputmode="numeric"
              placeholder="เช่น 1"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="cert-price" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า SSL ต่อใบ (บาท/ปี)
            </label>
            <input
              type="text"
              id="cert-price"
              inputmode="numeric"
              placeholder="เช่น 1500"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="renewal-years" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาต่ออายุ (ปี)
            </label>
            <input
              type="text"
              id="renewal-years"
              inputmode="numeric"
              placeholder="เช่น 1"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="wildcard-price" class="block text-sm font-medium text-gray-700 mb-1">
              ค่า Wildcard SSL เพิ่มเติม (บาท/ปี)
              <span class="text-gray-400 font-normal">— ไม่บังคับ</span>
            </label>
            <input
              type="text"
              id="wildcard-price"
              inputmode="numeric"
              placeholder="เช่น 0"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณค่า SSL
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณค่า SSL</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">SSL ต่อปี</div>
            <div id="res-ssl-annual" class="text-xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Wildcard เพิ่มเติม</div>
            <div id="res-wildcard-total" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รวมต่อปี</div>
            <div id="res-total-annual" class="text-xl font-bold text-purple-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">รวมทั้งหมด</div>
            <div id="res-total-cost" class="text-xl font-bold text-primary-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ประเภท SSL</span>
            <span id="res-type" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนใบรับรอง</span>
            <span id="res-count" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่า SSL ต่อปี</span>
            <span id="res-ssl-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่า Wildcard ต่อปี</span>
            <span id="res-wildcard-cost" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">ระยะเวลา</span>
            <span id="res-years" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ความสำคัญของ SSL Certificate</h2>

      <p>
        SSL Certificate เป็นสิ่งจำเป็นสำหรับเว็บไซต์สมัยใหม่ ไม่เพียงแต่เข้ารหัสข้อมูลเท่านั้น
        แต่ยังช่วยเพิ่มความไว้วางใจให้ผู้เยี่ยมชม ตั้งแต่ปี 2018 Google Chrome แสดงว่าเว็บไซต์ที่ไม่มี HTTPS เป็นสัญญาณอันตรายของเบราว์เซอร์
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ประเภท SSL Certificate</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>Single Domain (DV)</strong> — ตรวจสอบเฉพาะโดเมนเดียว 0-500 บาท/ปี</li>
        <li><strong>Wildcard (Wildcard DV)</strong> — ครอบคลุม *.example.com 500-2,000 บาท/ปี</li>
        <li><strong>Multi-Domain (SAN)</strong> — สำหรับหลายโดเมน 1,000-5,000 บาท/ปี</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ราคา SSL โดยทั่วไป</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>DV SSL</strong> — ถูกที่สุด ฟรี-500 บาท เหมาะสำหรับบล็อก</li>
        <li><strong>OV SSL</strong> — ราคากลาง 1,000-5,000 บาท สำหรับธุรกิจขนาดกลาง</li>
        <li><strong>EV SSL</strong> — แพงที่สุด 5,000-30,000+ บาท สำหรับธนาคาร E-commerce</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ควรลงทุนใน SSL ประเภทใด?</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>บล็อก → Let's Encrypt (ฟรี) หรือ DV SSL ถูก</li>
        <li>เว็บนิยม → OV SSL เช่นการเพิ่มความน่าเชื่อถือ</li>
        <li>E-commerce/ธนาคาร → EV SSL เพื่อเพิ่มความเชื่อมั่น</li>
      </ul>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณ-ค่า-ssl-certificate/" />
    <RelatedCalculators currentHref="/คำนวณ-ค่า-ssl-certificate/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ราคา SSL อาจแตกต่างขึ้นอยู่กับผู้ให้บริการและโปรโมชัน
      ผลการคำนวณเป็นการประมาณการเท่านั้น ไม่ถือเป็นราคาแน่นอน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('ssl-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const sslType = (document.getElementById('ssl-type') as HTMLSelectElement).value;
      const certCount = parseNum((document.getElementById('cert-count') as HTMLInputElement).value);
      const certPrice = parseNum((document.getElementById('cert-price') as HTMLInputElement).value);
      const renewalYears = parseNum((document.getElementById('renewal-years') as HTMLInputElement).value);
      const wildcardPrice = parseNum((document.getElementById('wildcard-price') as HTMLInputElement).value);

      if (certCount <= 0) { (document.getElementById('cert-count') as HTMLInputElement).focus(); return; }
      if (certPrice <= 0) { (document.getElementById('cert-price') as HTMLInputElement).focus(); return; }
      if (renewalYears <= 0) { (document.getElementById('renewal-years') as HTMLInputElement).focus(); return; }

      const sslAnnual = certCount * certPrice;
      const wildcardTotal = certCount * wildcardPrice;
      const totalAnnual = sslAnnual + wildcardTotal;
      const totalCost = totalAnnual * renewalYears;

      const typeLabel = sslType === 'dv' ? 'DV' : sslType === 'ov' ? 'OV' : 'EV';

      (document.getElementById('res-ssl-annual') as HTMLElement).textContent = fmt(sslAnnual) + ' บาท';
      (document.getElementById('res-wildcard-total') as HTMLElement).textContent = fmt(wildcardTotal) + ' บาท';
      (document.getElementById('res-total-annual') as HTMLElement).textContent = fmt(totalAnnual) + ' บาท';
      (document.getElementById('res-total-cost') as HTMLElement).textContent = fmt(totalCost) + ' บาท';
      (document.getElementById('res-type') as HTMLElement).textContent = typeLabel;
      (document.getElementById('res-count') as HTMLElement).textContent = certCount.toFixed(0);
      (document.getElementById('res-ssl-cost') as HTMLElement).textContent = fmt(sslAnnual) + ' บาท';
      (document.getElementById('res-wildcard-cost') as HTMLElement).textContent = fmt(wildcardTotal) + ' บาท';
      (document.getElementById('res-years') as HTMLElement).textContent = renewalYears.toFixed(0) + ' ปี';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('ssl-certificate');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('ssl-certificate');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
