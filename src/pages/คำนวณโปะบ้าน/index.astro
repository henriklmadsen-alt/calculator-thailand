---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณโปะบ้าน 2569 | ประหยัดดอกเบี้ยและปิดหนี้เร็วขึ้น | Kamnuanlek';
const pageDescription = 'คำนวณโปะบ้านปี 2569 ฟรี ดูว่าโปะเพิ่มต่อเดือนช่วยประหยัดดอกเบี้ยได้เท่าไร ปิดหนี้เร็วขึ้นกี่เดือน และระยะเวลาใหม่หลังโปะ ผลลัพธ์ทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณโปะบ้าน/`;

const faqData = [
  {
    question: 'โปะบ้านคืออะไร และดีกว่ารีไฟแนนซ์อย่างไร?',
    answer: 'โปะบ้านคือการจ่ายเงินต้นเพิ่มเกินค่างวดปกติในแต่ละเดือน ช่วยลดยอดเงินต้นเร็วขึ้น ทำให้ดอกเบี้ยในงวดถัดไปลดลง โปะบ้านไม่มีค่าธรรมเนียมต่างจากรีไฟแนนซ์ จึงคุ้มกว่าในกรณีที่ดอกเบี้ยตลาดไม่ต่างกันมาก',
  },
  {
    question: 'โปะบ้านทุกเดือนกับโปะเป็นก้อนต่างกันไหม?',
    answer: 'ทั้งคู่ช่วยลดเงินต้นเหมือนกัน แต่โปะทุกเดือนให้ผลทบต้นในการลดดอกเบี้ยได้เร็วกว่า เพราะลดฐานดอกเบี้ยต่อเนื่องทุกงวด ขณะที่โปะเป็นก้อนปีละครั้งให้ผลเฉพาะช่วงที่โปะ',
  },
  {
    question: 'ต้องแจ้งธนาคารก่อนโปะไหม?',
    answer: 'สินเชื่อบ้านส่วนใหญ่อนุญาตให้โปะได้โดยไม่ต้องแจ้งล่วงหน้า แต่ควรตรวจสอบเงื่อนไขสัญญา บางธนาคารมีข้อกำหนดเรื่องยอดโปะขั้นต่ำหรือช่วงเวลาห้ามโปะในปีแรก',
  },
  {
    question: 'โปะบ้านกี่บาทต่อเดือนถึงคุ้ม?',
    answer: 'ไม่มีตัวเลขตายตัว ขึ้นอยู่กับยอดหนี้และดอกเบี้ย แต่แม้โปะเพียง 500–1,000 บาท/เดือน ก็ช่วยประหยัดดอกเบี้ยได้หลักหมื่นบาทในระยะยาว ยิ่งโปะเร็วยิ่งได้ผลมากกว่า',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณโปะบ้าน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณโปะบ้าน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">💰 รู้ผลทันที — ไม่บันทึกข้อมูล</p>
      <p class="mt-1 text-sm text-slate-700">ดูว่าโปะเพิ่มต่อเดือนช่วยประหยัดดอกเบี้ยและปิดหนี้เร็วขึ้นเท่าไร</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณโปะบ้าน — ประหยัดดอกเบี้ยและปิดหนี้เร็วขึ้น 2569
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกเงินกู้คงเหลือ ดอกเบี้ย งวดคงเหลือ และยอดโปะเพิ่มต่อเดือน
      เครื่องมือจะคำนวณให้เห็นชัดว่าปิดหนี้เร็วขึ้นกี่เดือน และประหยัดดอกเบี้ยได้เท่าไร
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="prepay-form" class="space-y-5">
        <p id="prepay-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="prepay-balance" class="block text-sm font-medium text-gray-700 mb-1">
              เงินกู้คงเหลือ (บาท)
            </label>
            <input
              type="text"
              id="prepay-balance"
              inputmode="numeric"
              value="2000000"
              placeholder="เช่น 2,000,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="prepay-rate" class="block text-sm font-medium text-gray-700 mb-1">
              ดอกเบี้ย (% ต่อปี)
            </label>
            <input
              type="text"
              id="prepay-rate"
              inputmode="decimal"
              value="5.5"
              placeholder="เช่น 5.5"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="prepay-remaining-months" class="block text-sm font-medium text-gray-700 mb-1">
              งวดคงเหลือ (เดือน)
            </label>
            <input
              type="text"
              id="prepay-remaining-months"
              inputmode="numeric"
              value="240"
              placeholder="เช่น 240"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="prepay-extra" class="block text-sm font-medium text-gray-700 mb-1">
              โปะเพิ่มต่อเดือน (บาท)
            </label>
            <input
              type="text"
              id="prepay-extra"
              inputmode="numeric"
              value="3000"
              placeholder="เช่น 3,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="prepay-results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณโปะบ้าน</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 mb-6">
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่างวดปกติ</div>
            <div id="res-prepay-pmt" class="text-xl font-bold text-gray-800">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ระยะเวลาใหม่</div>
            <div id="res-prepay-new-months" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประหยัดเวลา</div>
            <div id="res-prepay-time-saved" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>

        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยรวมแบบปกติ</span>
            <span id="res-prepay-old-interest" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยรวมเมื่อโปะ</span>
            <span id="res-prepay-new-interest" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ประหยัดดอกเบี้ย</span>
            <span id="res-prepay-interest-saved" class="font-semibold text-green-700">-</span>
          </div>
        </div>

        <div id="res-prepay-summary" class="p-3 rounded-lg text-sm bg-primary-50 border border-primary-200 text-primary-900">-</div>
      </div>
    </div>

    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#prepay-results"
    />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีใช้เครื่องคำนวณโปะบ้าน</h2>
      <ol class="list-decimal pl-6 space-y-1 text-gray-700">
        <li>กรอก <strong>เงินกู้คงเหลือ</strong> จากใบแจ้งยอดธนาคาร</li>
        <li>ระบุ <strong>ดอกเบี้ยปัจจุบัน</strong> และ <strong>งวดคงเหลือ</strong></li>
        <li>ใส่ยอด <strong>โปะเพิ่มต่อเดือน</strong> ที่คุณทำได้จริง</li>
        <li>กดคำนวณเพื่อดูว่าปิดหนี้เร็วขึ้นกี่เดือนและประหยัดดอกเบี้ยเท่าไร</li>
      </ol>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีโปะบ้านให้ได้ผลสูงสุด</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>โปะให้เร็วที่สุดเท่าที่ทำได้ เพราะยิ่งเงินต้นลดเร็ว ดอกเบี้ยทบต้นยิ่งน้อย</li>
        <li>แจ้งธนาคารว่าต้องการให้เงินส่วนที่โปะตัดเงินต้น ไม่ใช่ดอกเบี้ยหรือค่างวดล่วงหน้า</li>
        <li>เปรียบเทียบกับรีไฟแนนซ์ว่าอย่างไหนให้ผลตอบแทนดีกว่าตามสถานการณ์ดอกเบี้ยปัจจุบัน</li>
        <li>โปะสม่ำเสมอทุกเดือนให้ผลดีกว่าโปะเป็นก้อนไม่สม่ำเสมอ</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedArticles currentHref="/คำนวณโปะบ้าน/" />
    <RelatedCalculators currentHref="/คำนวณโปะบ้าน/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลคำนวณเป็นการประมาณการเพื่อวางแผนเท่านั้น ตัวเลขจริงอาจต่างจากธนาคาร
      ตามเงื่อนไขสัญญา วันตัดรอบ และรายละเอียดเฉพาะกรณี โปรดตรวจสอบกับสถาบันการเงินก่อนตัดสินใจ
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    function calcPMT(principal: number, annualRate: number, months: number): number {
      if (months <= 0 || principal <= 0) return 0;
      const r = annualRate / 100 / 12;
      if (r === 0) return principal / months;
      const factor = Math.pow(1 + r, months);
      return principal * (r * factor) / (factor - 1);
    }

    function monthLabel(months: number): string {
      const years = Math.floor(months / 12);
      const rem = months % 12;
      if (years <= 0) return `${months} เดือน`;
      if (rem === 0) return `${years} ปี`;
      return `${years} ปี ${rem} เดือน`;
    }

    interface SimResult {
      totalInterest: number;
      payoffMonths: number;
    }

    function simulateWithExtra(principal: number, annualRate: number, scheduledMonths: number, extra: number): SimResult {
      const r = annualRate / 100 / 12;
      const pmt = calcPMT(principal, annualRate, scheduledMonths);
      let balance = principal;
      let totalInterest = 0;
      let months = 0;
      const maxLoops = scheduledMonths + 600;

      while (balance > 0.01 && months < maxLoops) {
        const interestPart = r > 0 ? balance * r : 0;
        const payment = Math.min(pmt + extra, balance + interestPart);
        const principalPart = Math.max(0, payment - interestPart);
        totalInterest += interestPart;
        balance = Math.max(0, balance - principalPart);
        months += 1;
      }

      return { totalInterest, payoffMonths: months };
    }

    const form = document.getElementById('prepay-form') as HTMLFormElement;
    const formError = document.getElementById('prepay-form-error') as HTMLElement;
    const resultsDiv = document.getElementById('prepay-results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      const balance = parseNum((document.getElementById('prepay-balance') as HTMLInputElement).value);
      const rate = parseNum((document.getElementById('prepay-rate') as HTMLInputElement).value);
      const remainingMonths = parseNum((document.getElementById('prepay-remaining-months') as HTMLInputElement).value);
      const extra = parseNum((document.getElementById('prepay-extra') as HTMLInputElement).value);

      if (balance <= 0 || remainingMonths <= 0) {
        formError.classList.remove('hidden');
        return;
      }

      trackCalculatorUsed('mortgage-prepay');

      const pmt = calcPMT(balance, rate, remainingMonths);
      const normalResult = simulateWithExtra(balance, rate, remainingMonths, 0);
      const prepayResult = simulateWithExtra(balance, rate, remainingMonths, extra);

      const timeSaved = normalResult.payoffMonths - prepayResult.payoffMonths;
      const interestSaved = normalResult.totalInterest - prepayResult.totalInterest;

      (document.getElementById('res-prepay-pmt') as HTMLElement).textContent = fmt(pmt) + ' บาท/เดือน';
      (document.getElementById('res-prepay-new-months') as HTMLElement).textContent = monthLabel(prepayResult.payoffMonths);
      (document.getElementById('res-prepay-time-saved') as HTMLElement).textContent =
        timeSaved > 0 ? monthLabel(timeSaved) : 'ไม่มีการโปะ';
      (document.getElementById('res-prepay-old-interest') as HTMLElement).textContent = fmt(normalResult.totalInterest) + ' บาท';
      (document.getElementById('res-prepay-new-interest') as HTMLElement).textContent = fmt(prepayResult.totalInterest) + ' บาท';
      (document.getElementById('res-prepay-interest-saved') as HTMLElement).textContent =
        '+' + fmt(interestSaved) + ' บาท';

      const summary = document.getElementById('res-prepay-summary') as HTMLElement;
      if (extra > 0 && interestSaved > 0) {
        summary.className = 'p-3 rounded-lg text-sm bg-green-50 border border-green-200 text-green-900';
        summary.textContent =
          `โปะเพิ่ม ${fmt(extra)} บาท/เดือน ช่วยปิดหนี้เร็วขึ้น ${monthLabel(timeSaved)} ` +
          `และประหยัดดอกเบี้ยประมาณ ${fmt(interestSaved)} บาท`;
      } else {
        summary.className = 'p-3 rounded-lg text-sm bg-primary-50 border border-primary-200 text-primary-900';
        summary.textContent = 'ลองปรับยอดโปะเพิ่มเพื่อดูผลประหยัดดอกเบี้ย';
      }

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackResultViewed('mortgage-prepay');
    });
  </script>
</BaseLayout>
