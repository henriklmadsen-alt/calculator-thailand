---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณรากที่สอง รากที่สาม และรากที่ n ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณรากที่สอง รากที่สาม และรากที่ n ของจำนวนใดก็ได้ พร้อมแสดงขั้นตอน ฟรี ไม่ต้องสมัคร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณรากที่สอง/`;

const faqData = [
  {
    question: 'รากที่สองของจำนวนลบคำนวณได้ไหม?',
    answer: 'รากที่สองของจำนวนลบในระบบจำนวนจริงไม่มีคำตอบ เพราะไม่มีจำนวนจริงใดยกกำลังสองแล้วได้ค่าลบ หากต้องการคำนวณต้องใช้จำนวนเชิงซ้อน (complex number) ซึ่งอยู่นอกขอบเขตของเครื่องคำนวณนี้',
  },
  {
    question: 'รากที่สองของ 2 คือเท่าไหร่?',
    answer: 'รากที่สองของ 2 (√2) มีค่าประมาณ 1.414214 ซึ่งเป็นจำนวนอตรรกยะ (irrational number) ไม่สามารถแสดงเป็นเศษส่วนที่แน่นอนได้',
  },
  {
    question: 'ความแตกต่างระหว่างรากที่สองและรากที่สามคืออะไร?',
    answer: 'รากที่สอง (√x) คือจำนวนที่ยกกำลังสองแล้วได้ x เช่น √9 = 3 เพราะ 3² = 9 ส่วนรากที่สาม (∛x) คือจำนวนที่ยกกำลังสามแล้วได้ x เช่น ∛27 = 3 เพราะ 3³ = 27 รากที่สามสามารถหาค่าของจำนวนลบได้ด้วย',
  },
  {
    question: 'รากที่ n ของจำนวนคำนวณยังไง?',
    answer: 'รากที่ n ของ x คือจำนวน y ที่เมื่อยก y กำลัง n แล้วได้ x นั่นคือ yⁿ = x สูตรคำนวณคือ y = x^(1/n) ตัวอย่างเช่น รากที่ 4 ของ 81 = 81^(1/4) = 3 เพราะ 3⁴ = 81',
  },
  {
    question: 'ทำไมรากที่สองของตัวเลขใหญ่ๆ ถึงคำนวณได้ง่าย?',
    answer: 'สมัยนี้มีเครื่องคำนวณและซอฟต์แวร์ที่ใช้อัลกอริทึม Newton-Raphson หรือ Babylonian method ซึ่งหาค่ารากที่สองได้รวดเร็วและแม่นยำ แต่หากคำนวณมือควรใช้วิธีลองหาตัวเลขที่ยกกำลังสองแล้วใกล้เคียงค่าที่ต้องการ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณรากที่สอง รากที่สาม และรากที่ n',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'EducationApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณรากที่สองของจำนวนใดก็ได้',
  description: 'ขั้นตอนการคำนวณรากที่สอง รากที่สาม และรากที่ n โดยใช้เครื่องคำนวณออนไลน์',
  step: [
    {
      '@type': 'HowToStep',
      name: 'เลือกประเภทราก',
      text: 'เลือกว่าต้องการคำนวณรากที่สอง (√x), รากที่สาม (∛x) หรือรากที่ n โดยกดปุ่มแท็บที่ต้องการ',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกจำนวนที่ต้องการหาราก',
      text: 'พิมพ์ตัวเลขที่ต้องการหาค่าราก เช่น 144 สำหรับรากที่สอง หรือ -8 สำหรับรากที่สาม (รากที่สองรองรับเฉพาะจำนวนบวก)',
    },
    {
      '@type': 'HowToStep',
      name: 'กรอกค่า n (สำหรับรากที่ n)',
      text: 'หากเลือกรากที่ n ให้กรอกค่า n เช่น 4 สำหรับรากที่สี่ หรือ 5 สำหรับรากที่ห้า ค่า n ต้องมากกว่า 0',
    },
    {
      '@type': 'HowToStep',
      name: 'กดคำนวณและดูผลลัพธ์',
      text: 'กดปุ่ม "คำนวณ" เพื่อดูผลลัพธ์ที่แสดงทศนิยม 6 ตำแหน่ง พร้อมสูตรที่ใช้คำนวณ',
    },
  ],
};
---

<BaseLayout noGenericHowTo={true} title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณรากที่สอง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณรากที่สอง รากที่สาม และรากที่ n ในหน้าเดียว</p>
      <p class="mt-1 text-sm text-slate-700">รองรับจำนวนบวก ลบ และเศษส่วน พร้อมผลลัพธ์ทศนิยม 6 ตำแหน่ง</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเนื้อหาปี 2569 • อัปเดตเมื่อ: 21 เม.ย. 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณรากที่สอง รากที่สาม และรากที่ n ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่ารากของจำนวนใดก็ได้ ทั้งรากที่สอง (√x) รากที่สาม (∛x) และรากที่ n ใช้ในงานคณิตศาสตร์
      วิทยาศาสตร์ วิศวกรรม และการศึกษา พร้อมแสดงสูตรที่ใช้คำนวณ
    </p>

    <PublicTrustPanel
      lastUpdated="21 เม.ย. 2569"
      sources={[
        'สสวท. (SciMath): คณิตศาสตร์ระดับมัธยมศึกษา เรื่องรากและเลขยกกำลัง',
        'ECMAScript Math object specification: Math.sqrt, Math.cbrt, Math.pow',
      ]}
      assumptions={[
        'ผลลัพธ์คำนวณจากข้อมูลที่ผู้ใช้กรอกเท่านั้น',
        'รากที่สองของจำนวนลบจะแสดงข้อผิดพลาด เนื่องจากอยู่นอกระบบจำนวนจริง',
      ]}
      references={[
        {
          label: 'SciMath (สสวท.): รากที่สองและรากที่ n',
          href: 'https://www.scimath.org/article-mathematics/item/11474-3',
        },
      ]}
    />

    <!-- Mode 1: Square Root -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">1) รากที่สอง (√x)</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: √144 = 12, √2 ≈ 1.414214</p>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="sm:col-span-2">
          <label for="sqrt-x" class="block text-sm font-medium text-gray-700 mb-1">ตัวเลข x (ต้องไม่ติดลบ)</label>
          <input id="sqrt-x" type="text" inputmode="decimal" placeholder="เช่น 144" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div class="flex items-end">
          <button id="btn-sqrt" type="button" class="w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700">คำนวณ</button>
        </div>
      </div>
      <p id="sqrt-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="sqrt-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="sqrt-result-value" class="text-xl font-bold text-primary-700">-</p>
      </div>
    </div>

    <!-- Mode 2: Cube Root -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">2) รากที่สาม (∛x)</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: ∛27 = 3, ∛(-8) = -2 (รองรับจำนวนลบ)</p>
      <div class="grid gap-3 sm:grid-cols-3">
        <div class="sm:col-span-2">
          <label for="cbrt-x" class="block text-sm font-medium text-gray-700 mb-1">ตัวเลข x</label>
          <input id="cbrt-x" type="text" inputmode="decimal" placeholder="เช่น 27 หรือ -8" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div class="flex items-end">
          <button id="btn-cbrt" type="button" class="w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700">คำนวณ</button>
        </div>
      </div>
      <p id="cbrt-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="cbrt-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="cbrt-result-value" class="text-xl font-bold text-primary-700">-</p>
      </div>
    </div>

    <!-- Mode 3: nth Root -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">3) รากที่ n (ⁿ√x)</h2>
      <p class="text-sm text-gray-500 mb-4">ตัวอย่าง: รากที่ 4 ของ 81 = 3, รากที่ 5 ของ 32 = 2</p>
      <div class="grid gap-3 sm:grid-cols-3">
        <div>
          <label for="nroot-x" class="block text-sm font-medium text-gray-700 mb-1">ตัวเลข x</label>
          <input id="nroot-x" type="text" inputmode="decimal" placeholder="เช่น 81" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label for="nroot-n" class="block text-sm font-medium text-gray-700 mb-1">ค่า n (ลำดับราก)</label>
          <input id="nroot-n" type="text" inputmode="decimal" placeholder="เช่น 4" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div class="flex items-end">
          <button id="btn-nroot" type="button" class="w-full rounded-md bg-primary-600 px-4 py-2 font-semibold text-white hover:bg-primary-700">คำนวณ</button>
        </div>
      </div>
      <p id="nroot-error" class="mt-2 hidden text-sm text-red-600"></p>
      <div id="nroot-result" class="mt-4 hidden rounded-lg bg-primary-50 p-4">
        <p class="text-sm text-gray-600">ผลลัพธ์</p>
        <p id="nroot-result-value" class="text-xl font-bold text-primary-700">-</p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#nroot-result" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรและทฤษฎีที่เกี่ยวข้อง</h2>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>รากที่สอง: √x = x^(1/2) — ผลลัพธ์เสมอเป็นจำนวนบวกหรือศูนย์ (principal root)</li>
        <li>รากที่สาม: ∛x = x^(1/3) — คำนวณได้ทั้งจำนวนบวกและลบ</li>
        <li>รากที่ n: ⁿ√x = x^(1/n) — สำหรับ n คี่ รองรับ x ติดลบ, n คู่ต้องการ x ≥ 0</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">ตัวอย่างการคำนวณ</h3>
      <div class="space-y-3 text-sm">
        <div class="bg-blue-50 rounded-lg p-4">
          <p class="font-semibold text-gray-900 mb-1">√225 = ?</p>
          <p class="text-gray-700">√225 = 15 เพราะ 15² = 225</p>
        </div>
        <div class="bg-green-50 rounded-lg p-4">
          <p class="font-semibold text-gray-900 mb-1">∛(-125) = ?</p>
          <p class="text-gray-700">∛(-125) = -5 เพราะ (-5)³ = -125</p>
        </div>
        <div class="bg-orange-50 rounded-lg p-4">
          <p class="font-semibold text-gray-900 mb-1">รากที่ 4 ของ 256 = ?</p>
          <p class="text-gray-700">⁴√256 = 256^(1/4) = 4 เพราะ 4⁴ = 256</p>
        </div>
      </div>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณรากที่สอง/" />
    <RelatedCalculators currentHref="/คำนวณรากที่สอง/" />
  </article>
</BaseLayout>

<script>
  const parseNum = (v) => parseFloat(String(v).replace(/,/g, '').trim());

  const setError = (id, msg) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg || '';
    msg ? el.classList.remove('hidden') : el.classList.add('hidden');
  };

  const showResult = (containerId, valueId, text) => {
    const c = document.getElementById(containerId);
    const v = document.getElementById(valueId);
    if (!c || !v) return;
    v.textContent = text;
    c.classList.remove('hidden');
  };

  document.getElementById('btn-sqrt')?.addEventListener('click', () => {
    setError('sqrt-error', '');
    const x = parseNum(document.getElementById('sqrt-x')?.value);
    if (!Number.isFinite(x)) { setError('sqrt-error', 'กรุณากรอกตัวเลขที่ถูกต้อง'); return; }
    if (x < 0) { setError('sqrt-error', 'รากที่สองของจำนวนลบไม่มีค่าในระบบจำนวนจริง'); return; }
    const result = Math.sqrt(x);
    showResult('sqrt-result', 'sqrt-result-value', `√${x} = ${result.toFixed(6)}`);
  });

  document.getElementById('btn-cbrt')?.addEventListener('click', () => {
    setError('cbrt-error', '');
    const x = parseNum(document.getElementById('cbrt-x')?.value);
    if (!Number.isFinite(x)) { setError('cbrt-error', 'กรุณากรอกตัวเลขที่ถูกต้อง'); return; }
    const result = Math.cbrt(x);
    showResult('cbrt-result', 'cbrt-result-value', `∛${x} = ${result.toFixed(6)}`);
  });

  document.getElementById('btn-nroot')?.addEventListener('click', () => {
    setError('nroot-error', '');
    const x = parseNum(document.getElementById('nroot-x')?.value);
    const n = parseNum(document.getElementById('nroot-n')?.value);
    if (!Number.isFinite(x) || !Number.isFinite(n)) { setError('nroot-error', 'กรุณากรอกตัวเลขให้ครบทั้ง x และ n'); return; }
    if (n === 0) { setError('nroot-error', 'ค่า n ห้ามเป็น 0'); return; }
    const isOddN = Math.abs(n % 2) > 0.9999;
    if (x < 0 && !isOddN) { setError('nroot-error', 'รากลำดับคู่ของจำนวนลบไม่มีค่าในระบบจำนวนจริง'); return; }
    const sign = x < 0 ? -1 : 1;
    const result = sign * Math.pow(Math.abs(x), 1 / n);
    showResult('nroot-result', 'nroot-result-value', `${n}√${x} = ${result.toFixed(6)}`);
  });
</script>
