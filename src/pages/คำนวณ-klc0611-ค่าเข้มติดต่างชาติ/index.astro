---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าเข้มติดต่างชาติ | Kamnuanlek';
const pageDescription = 'คำนวณค่าอบรมเข้มฟื้นฟูพูด การศึกษาต่างประเทศ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0611-ค่าเข้มติดต่างชาติ/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเข้มติดต่างชาติ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าเข้มติดต่างชาติ</h1>
    <div class="mb-4 inline-block rounded-lg border border-sky-200 bg-sky-50 px-3 py-2"><p class="text-xs font-semibold text-sky-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าการศึกษาต่างประเทศ ค่าเข้มฟื้นฟู ค่าที่พักรายปี</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="tuition" class="block text-sm font-medium text-gray-700 mb-1">ค่าเรียนต่อปี (USD)</label><input type="text" id="tuition" inputmode="decimal" placeholder="เช่น 20000" value="20000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="accommodation" class="block text-sm font-medium text-gray-700 mb-1">ค่าที่พักต่อเดือน (USD)</label><input type="text" id="accommodation" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="exchange_rate" class="block text-sm font-medium text-gray-700 mb-1">อัตราแลกเปลี่ยน USD/THB</label><input type="text" id="exchange_rate" inputmode="decimal" placeholder="เช่น 35" value="35" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-sky-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-sky-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าที่พักต่อปี (THB)</p>
            <p id="accommodation_yearly" class="font-bold">-</p>
          </div>
          <div class="bg-sky-50 rounded p-3">
            <p class="text-sm text-gray-600">รวมค่าต่อปี (THB)</p>
            <p id="total" class="font-bold">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่าการศึกษาต่างประเทศประมาณเท่าไหร่?</h3>
            <p class="text-gray-600 text-sm">ประเทศแพง: สหรัฐ สหราชอาณาจักร 1.5-2 ล้านบาท/ปี ประเทศถูก: เวียดนาม 400-600 พันบาท</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">มีทุนการศึกษาต่างประเทศหรือไม่?</h3>
            <p class="text-gray-600 text-sm">มี: ทุน JPA กสศ.อ. AFS ประเทศเจ้าภาพ ต้องสมัครประมาณ 2 ปีก่อน</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ได้ลดหย่อนภาษีได้หรือไม่?</h3>
            <p class="text-gray-600 text-sm">หากเป็นการศึกษาดูแลเด็ก บางส่วนลดหย่อนได้ ตรวจสอบเงื่อนไขผู้ให้บริการ</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const tuition = parseFloat((document.getElementById('tuition') as HTMLInputElement).value) || 0;
      const accommodation = parseFloat((document.getElementById('accommodation') as HTMLInputElement).value) || 0;
      const exchangeRate = parseFloat((document.getElementById('exchange_rate') as HTMLInputElement).value) || 35;

      const accommodationYearly = accommodation * 12 * exchangeRate;
      const tuitionThb = tuition * exchangeRate;
      const total = tuitionThb + accommodationYearly;

      (document.getElementById('accommodation_yearly') as HTMLElement).textContent = accommodationYearly.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('study-abroad');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
