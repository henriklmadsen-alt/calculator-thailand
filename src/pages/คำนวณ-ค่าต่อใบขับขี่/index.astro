---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculateDriverLicenseRenewal, EXAMPLE_1, EXAMPLE_2, EXAMPLE_3 } from '../../lib/driver-license-renewal-calculator';

const pageTitle = 'คำนวณค่าต่อใบขับขี่ 2569 | ค่าธรรมเนียมต่อใบขับขี่ | Calculator Thailand';
const pageDescription = 'คำนวณค่าต่อใบขับขี่ออนไลน์ฟรี สำหรับรถยนต์ จักรยานยนต์ รถบรรทุก (5 ปี 10 ปี) โดยระบบจะคำนวณค่าธรรมเนียมตามประเภทใบขับขี่ ระยะเวลา บริการด่วน ตามอัตรา 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าต่อใบขับขี่/`;

const faqData = [
  {
    question: 'ค่าต่อใบขับขี่แตกต่างกันตามประเภทรถหรือไม่?',
    answer: 'ใช่ ค่าต่อแตกต่างกันตามประเภทใบขับขี่: รถยนต์ 225 บาท (5 ปี) / 450 บาท (10 ปี) จักรยานยนต์ 200 บาท (5 ปี) / 400 บาท (10 ปี) รถบรรทุก 325 บาท (5 ปี) / 650 บาท (10 ปี)',
  },
  {
    question: 'ต่อใบขับขี่ 5 ปี กับ 10 ปี มีความแตกต่างอะไร?',
    answer: 'ใบขับขี่ 5 ปี ถูกกว่า แต่ต้องต่อบ่อยกว่า ใบขับขี่ 10 ปี แพงกว่า แต่ใช้ได้นานขึ้นและสะดวกกว่า สูงอายุ 60 ปีขึ้นไป สามารถขอได้เฉพาะ 5 ปี',
  },
  {
    question: 'บริการด่วนค่าเท่าไหร่?',
    answer: 'บริการด่วน (เดียวกันวันหรือต่อวันถัดไป) เพิ่มค่า 200 บาท คุณจะได้รับใบขับขี่ในเวลา 1 วันทำการแทนที่จะ 3-7 วัน',
  },
  {
    question: 'ต่อใบขับขี่สูญหาย ค่าเท่าไหร่?',
    answer: 'ต่อใบขับขี่สูญหาย/ชำรุด ใช้ค่าเดิมบวก 50 บาท (ค่าสำหรับสูญหาย) นอกจากนี้อาจต้องเตรียมเอกสารเพิ่มเติมตามขั้นตอนของสำนักขนส่ง',
  },
  {
    question: 'ต้องเตรียมเอกสารอะไรเมื่อต่อใบขับขี่?',
    answer: 'เอกสารหลัก: ใบขับขี่เดิม บัตรประชาชน สำหรับเปลี่ยนรูป/ข้อมูล: รูปถ่าย 4x6 ซม. 1 รูป สำหรับสูญหาย: บันทึกการสูญหาย และข้อมูลอื่นตามที่สำนักขนส่งขอ',
  },
  {
    question: 'ต่อใบขับขี่ออนไลน์ได้หรือไม่?',
    answer: 'ได้ แต่ต้องไปยืนยันตัวตนและถ่ายรูปที่สำนักขนส่ง (ยื่นออนไลน์ 1 ครั้ง ไป 1 ครั้ง) ระยะเวลา 5-10 วัน พร้อมจัดส่งทางไปรษณีย์',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าต่อใบขับขี่',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'วิธีคำนวณค่าต่อใบขับขี่',
  description: 'ขั้นตอนการคำนวณค่าธรรมเนียมต่อใบขับขี่ตามประเภทและระยะเวลา',
  step: [
    {
      '@type': 'HowToStep',
      name: 'เลือกประเภทใบขับขี่',
      text: 'ระบุประเภท: รถยนต์ จักรยานยนต์ หรือรถบรรทุก',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกระยะเวลา',
      text: 'เลือกระหว่าง 5 ปี (ถูกกว่า) หรือ 10 ปี (ใช้นานขึ้น)',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกประเภทบริการ',
      text: 'ปกติ บริการด่วน (1 วัน) เปลี่ยนรูป (ต่อแบบสูญหาย) หรือออนไลน์',
    },
    {
      '@type': 'HowToStep',
      name: 'เลือกบริการเพิ่มเติม',
      text: 'เลือกหากต้อง: อัปเดตรูป (50 บาท) หรือข้อมูลชีวมิติ (100 บาท)',
    },
    {
      '@type': 'HowToStep',
      name: 'ดูผลการคำนวณ',
      text: 'ระบบจะแสดงค่าธรรมเนียมรวมทั้งสิ้นและระยะเวลาประมวลผล',
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าต่อใบขับขี่">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าต่อใบขับขี่
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-indigo-200 bg-indigo-50 px-3 py-2">
      <p class="text-xs font-semibold text-indigo-800">[อัปเดตอัตรา สำนักการขนส่งทางบก 2569]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าต่อใบขับขี่ออนไลน์ฟรี สำหรับรถยนต์ จักรยานยนต์ รถบรรทุก (5 ปี/10 ปี) ตามอัตราปัจจุบันของสำนักการขนส่งทางบก
    </p>

    <!-- Calculator Section -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <!-- License Type -->
      <div class="mb-6">
        <label for="license-type" class="block text-sm font-medium text-gray-700 mb-2">
          ประเภทใบขับขี่
        </label>
        <select
          id="license-type"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-base"
        >
          <option value="car">รถยนต์ (Car)</option>
          <option value="motorcycle">จักรยานยนต์ (Motorcycle)</option>
          <option value="truck">รถบรรทุก (Truck)</option>
        </select>
      </div>

      <!-- License Duration -->
      <div class="mb-6">
        <label for="duration" class="block text-sm font-medium text-gray-700 mb-2">
          ระยะเวลา
        </label>
        <select
          id="duration"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-base"
        >
          <option value="5year">5 ปี (ถูกกว่า)</option>
          <option value="10year">10 ปี (ยาวนานขึ้น)</option>
        </select>
      </div>

      <!-- Service Type -->
      <div class="mb-6">
        <label for="service-type" class="block text-sm font-medium text-gray-700 mb-2">
          ประเภทบริการ
        </label>
        <select
          id="service-type"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-base"
        >
          <option value="standard">ต่อปกติ (3-7 วัน)</option>
          <option value="rush">บริการด่วน (+200 บาท, 1 วัน)</option>
          <option value="replacement">ต่อแบบสูญหาย (+50 บาท)</option>
          <option value="online">ยื่นออนไลน์ (5-10 วัน)</option>
        </select>
      </div>

      <!-- Additional Services -->
      <div class="mb-6 space-y-3">
        <label class="block text-sm font-medium text-gray-700">บริการเพิ่มเติม (ถ้าต้องการ)</label>
        <div class="flex items-center">
          <input
            type="checkbox"
            id="photo-update"
            class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
          />
          <label for="photo-update" class="ml-2 block text-sm text-gray-700">
            อัปเดตรูปถ่าย (+50 บาท)
          </label>
        </div>
        <div class="flex items-center">
          <input
            type="checkbox"
            id="biometric-update"
            class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500"
          />
          <label for="biometric-update" class="ml-2 block text-sm text-gray-700">
            ข้อมูลชีวมิติ (บายโอเมตริกส์) (+100 บาท)
          </label>
        </div>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-indigo-600 text-white font-semibold rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณค่าต่อใบขับขี่
      </button>

      <!-- Results -->
      <div id="result" class="hidden mt-6 pt-6 border-t border-gray-200">
        <!-- Cost Breakdown -->
        <div class="grid gap-4 sm:grid-cols-2 mb-6">
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-sm text-gray-600">ค่าพื้นฐาน</div>
            <div id="base-fee" class="text-2xl font-bold text-gray-900">0 บาท</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-sm text-gray-600">ค่าเพิ่มเติม</div>
            <div id="extra-fees" class="text-2xl font-bold text-gray-900">0 บาท</div>
          </div>
        </div>

        <!-- Total -->
        <div class="bg-indigo-50 rounded-lg p-4 border border-indigo-200 mb-6">
          <div class="text-sm text-indigo-600 font-semibold mb-1">ค่าธรรมเนียมรวมทั้งสิ้น</div>
          <div id="total-fee" class="text-4xl font-bold text-indigo-900">0 บาท</div>
        </div>

        <!-- Processing Time -->
        <div class="bg-blue-50 rounded-lg p-4 border border-blue-200 mb-6">
          <div class="text-sm text-blue-600 font-semibold mb-1">ระยะเวลาประมวลผล</div>
          <div id="processing-time" class="text-lg font-semibold text-blue-900">-</div>
        </div>

        <!-- Details -->
        <div id="details-table" class="bg-gray-50 rounded-lg p-4 text-sm"></div>
      </div>
    </div>

    <!-- Content Section -->
    <div class="grid gap-6 sm:grid-cols-2 mb-8">
      <!-- License Types -->
      <div class="bg-blue-50 rounded-lg border border-blue-200 p-6">
        <h2 class="text-lg font-semibold text-blue-900 mb-4">📋 ประเภทใบขับขี่</h2>
        <ul class="space-y-2 text-sm text-gray-700">
          <li><strong>รถยนต์:</strong> 225 บาท (5ปี) / 450 บาท (10ปี)</li>
          <li><strong>จักรยานยนต์:</strong> 200 บาท (5ปี) / 400 บาท (10ปี)</li>
          <li><strong>รถบรรทุก:</strong> 325 บาท (5ปี) / 650 บาท (10ปี)</li>
          <li><strong>หมายเหตุ:</strong> ผู้สูงอายุ 60+ ได้เฉพาะ 5 ปี</li>
        </ul>
      </div>

      <!-- Services -->
      <div class="bg-green-50 rounded-lg border border-green-200 p-6">
        <h2 class="text-lg font-semibold text-green-900 mb-4">🚀 ประเภทบริการ</h2>
        <ul class="space-y-2 text-sm text-gray-700">
          <li><strong>ปกติ:</strong> 3-7 วัน (ฟรี)</li>
          <li><strong>บริการด่วน:</strong> +200 บาท (1 วัน)</li>
          <li><strong>สูญหาย/ชำรุด:</strong> +50 บาท</li>
          <li><strong>ออนไลน์:</strong> 5-10 วัน + ค่าจัดส่ง</li>
        </ul>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="bg-gray-50 rounded-lg p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-6">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg border border-gray-200 p-4">
            <summary class="font-semibold text-gray-900 cursor-pointer">
              {faq.question}
            </summary>
            <p class="text-gray-600 mt-3 text-sm">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <!-- Trust Section -->
    <div class="bg-yellow-50 rounded-lg border border-yellow-200 p-6 mb-8">
      <h2 class="text-lg font-semibold text-yellow-900 mb-3">⚖️ ความน่าเชื่อถือ</h2>
      <p class="text-sm text-gray-700 mb-3">
        เครื่องคำนวณนี้อ้างอิงจากอัตราราคาปัจจุบัน:
      </p>
      <ul class="text-sm text-gray-700 space-y-1">
        <li>• <strong>แหล่งที่มา:</strong> สำนักการขนส่งทางบก (Land Transportation Office)</li>
        <li>• <strong>อัปเดต:</strong> ปี 2569 (2026)</li>
        <li>• <strong>หมายเหตุ:</strong> ค่าอาจเปลี่ยนแปลงตามนโยบาย โปรดยืนยันกับสำนักขนส่งก่อนไป</li>
      </ul>
    </div>

    <!-- Related Calculators -->
    <RelatedCalculators categoryId="government" />
  </article>
</BaseLayout>

<script>
  import { calculateDriverLicenseRenewal } from '../../lib/driver-license-renewal-calculator';

  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const licenseType = (document.getElementById('license-type') as HTMLSelectElement)
      .value as 'car' | 'motorcycle' | 'truck';
    const licenseDuration = (document.getElementById('duration') as HTMLSelectElement)
      .value as '5year' | '10year';
    const serviceType = (document.getElementById('service-type') as HTMLSelectElement)
      .value as 'standard' | 'rush' | 'replacement' | 'online';
    const needsPhotoUpdate = (document.getElementById('photo-update') as HTMLInputElement)
      .checked;
    const needsBiometricUpdate = (document.getElementById('biometric-update') as HTMLInputElement)
      .checked;

    const result = calculateDriverLicenseRenewal({
      licenseType,
      licenseDuration,
      serviceType,
      needsPhotoUpdate,
      needsBiometricUpdate,
    });

    // Display results
    const resultDiv = document.getElementById('result');
    if (resultDiv) {
      resultDiv.classList.remove('hidden');

      document.getElementById('base-fee')!.textContent =
        result.baseLicenseFee.toLocaleString('th-TH') + ' บาท';
      document.getElementById('extra-fees')!.textContent =
        (result.photoUpdateFee +
          result.biometricUpdateFee +
          result.rushServiceFee +
          result.replacementSurcharge).toLocaleString('th-TH') + ' บาท';
      document.getElementById('total-fee')!.textContent =
        result.total.toLocaleString('th-TH') + ' บาท';
      document.getElementById('processing-time')!.textContent = result.processingTime;

      const detailsTable = document.getElementById('details-table')!;
      detailsTable.innerHTML = `
        <div class="space-y-2">
          <div class="flex justify-between"><span>ประเภท:</span><strong>${result.licenseTypeName}</strong></div>
          <div class="flex justify-between"><span>ระยะเวลา:</span><strong>${result.durationYears} ปี</strong></div>
          <div class="flex justify-between"><span>บริการ:</span><strong>${result.serviceTypeName}</strong></div>
          <div class="flex justify-between"><span>อัปเดตรูป:</span><strong>${result.needsPhotoUpdate ? 'ใช่ (+50 บาท)' : 'ไม่'}</strong></div>
          <div class="flex justify-between"><span>ข้อมูลชีวมิติ:</span><strong>${result.needsBiometricUpdate ? 'ใช่ (+100 บาท)' : 'ไม่'}</strong></div>
        </div>
      `;
    }
  });
</script>
