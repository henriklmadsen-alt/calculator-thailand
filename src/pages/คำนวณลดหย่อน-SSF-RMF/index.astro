---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณลดหย่อน SSF RMF 2569 | กองทุนเพื่อการออม ลดภาษี | Kamnuanlek';
const pageDescription = 'คำนวณค่าลดหย่อน SSF (กองทุนรวมเพื่อการออม) และ RMF (กองทุนรวมเพื่อการเลี้ยงชีพ) สูงสุด 200,000 และ 500,000 บาท อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณลดหย่อน-SSF-RMF/`;

const faqData = [
  {
    question: 'SSF ลดหย่อนได้สูงสุดเท่าไร?',
    answer: 'กองทุนรวมเพื่อการออม (SSF) ลดหย่อนภาษีได้สูงสุด 30% ของเงินได้พึงประเมิน แต่ไม่เกิน 200,000 บาทต่อปี และต้องถือหน่วยลงทุน SSF ไว้อย่างน้อย 10 ปีนับจากวันที่ซื้อ',
  },
  {
    question: 'RMF ลดหย่อนได้เท่าไรและมีเงื่อนไขอย่างไร?',
    answer: 'กองทุนรวมเพื่อการเลี้ยงชีพ (RMF) ลดหย่อนได้สูงสุด 30% ของเงินได้พึงประเมิน โดยต้องรวมกับ SSF กองทุนสำรองเลี้ยงชีพ กองทุนบำเหน็จบำนาญข้าราชการ และประกันชีวิตแบบบำนาญแล้วไม่เกิน 500,000 บาท ต้องซื้อต่อเนื่องและไถ่ถอนได้เมื่ออายุ 55 ปี',
  },
  {
    question: 'SSF และ RMF ซื้อพร้อมกันได้ไหม?',
    answer: 'ซื้อพร้อมกันได้ SSF มีเพดานเฉพาะ 200,000 บาท ส่วน RMF อยู่ในกลุ่มเพดานรวม 500,000 บาท (รวม SSF, PVD, กบข., ประกันบำนาญ) ดังนั้นหากซื้อ SSF 200,000 บาทแล้ว ยังสามารถซื้อ RMF ได้อีกในวงเงิน 30% ของรายได้ แต่ยอดรวมทั้งหมดในกลุ่มนั้นต้องไม่เกิน 500,000 บาท',
  },
  {
    question: 'ถ้าขาย SSF/RMF ก่อนกำหนด จะเสียภาษีไหม?',
    answer: 'หากขาย SSF ก่อนครบ 10 ปี หรือ RMF ก่อนอายุ 55 ปีและถือไม่ครบ 5 ปี ต้องคืนเงินภาษีที่ได้ลดหย่อนไปพร้อมเบี้ยปรับและดอกเบี้ย ซึ่งอาจทำให้ต้นทุนสูงขึ้นมาก',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณลดหย่อน SSF/RMF 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณลดหย่อน SSF/RMF">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">SSF สูงสุด 200,000 บาท | RMF รวมกลุ่มสูงสุด 500,000 บาท</p>
      <p class="mt-1 text-sm text-slate-700">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณลดหย่อน SSF / RMF 2569
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าลดหย่อนกองทุน SSF และ RMF พร้อมตรวจสอบว่าเกินเพดานกำหนดหรือไม่
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูล</h2>
      <div class="space-y-4">
        <div>
          <label for="ssfrmf-income" class="block text-sm font-medium text-gray-700 mb-1">
            เงินได้พึงประเมินต่อปี (บาท)
          </label>
          <input type="text" id="ssfrmf-income" inputmode="numeric" placeholder="เช่น 600,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ssf-amount" class="block text-sm font-medium text-gray-700 mb-1">
              ซื้อ SSF (บาท/ปี)
            </label>
            <input type="text" id="ssf-amount" inputmode="numeric" placeholder="เช่น 100,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="rmf-amount" class="block text-sm font-medium text-gray-700 mb-1">
              ซื้อ RMF (บาท/ปี)
            </label>
            <input type="text" id="rmf-amount" inputmode="numeric" placeholder="เช่น 100,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="pvd-amount" class="block text-sm font-medium text-gray-700 mb-1">
              กองทุนสำรองเลี้ยงชีพ (PVD) (บาท/ปี) <span class="text-gray-400 font-normal">— ถ้ามี</span>
            </label>
            <input type="text" id="pvd-amount" inputmode="numeric" placeholder="เช่น 24,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
          <div>
            <label for="pension-ins" class="block text-sm font-medium text-gray-700 mb-1">
              ประกันชีวิตแบบบำนาญ (บาท/ปี) <span class="text-gray-400 font-normal">— ถ้ามี</span>
            </label>
            <input type="text" id="pension-ins" inputmode="numeric" placeholder="เช่น 50,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          </div>
        </div>
        <button type="button" id="btn-ssfrmf-calc"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 transition-colors text-base">
          คำนวณทันที
        </button>
      </div>

      <div id="ssfrmf-result" class="hidden mt-6">
        <div class="grid gap-3 sm:grid-cols-3 mb-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ลดหย่อน SSF ที่ใช้ได้</div>
            <div id="sr-ssf" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-blue-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ลดหย่อน RMF ที่ใช้ได้</div>
            <div id="sr-rmf" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ลดหย่อนรวม SSF+RMF</div>
            <div id="sr-total" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>
        <div class="space-y-1 text-sm bg-gray-50 rounded-lg p-3">
          <div class="flex justify-between"><span class="text-gray-500">เพดาน 30% ของรายได้</span><span id="sr-30pct" class="font-medium"></span></div>
          <div class="flex justify-between"><span class="text-gray-500">เพดาน SSF สูงสุด</span><span class="font-medium">200,000 บาท</span></div>
          <div class="flex justify-between"><span class="text-gray-500">ยอดรวมกลุ่ม (SSF+RMF+PVD+บำนาญ)</span><span id="sr-group-total" class="font-medium"></span></div>
          <div class="flex justify-between"><span class="text-gray-500">เพดานรวมกลุ่ม</span><span class="font-medium">500,000 บาท</span></div>
        </div>
        <p id="sr-warning" class="hidden mt-3 text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded p-2"></p>
      </div>
    </div>

    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">[โฆษณา — AdSense]</div>

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">SSF และ RMF คืออะไร?</h2>
      <p><strong>SSF (Super Savings Fund)</strong> หรือกองทุนรวมเพื่อการออม เป็นกองทุนที่ช่วยส่งเสริมการออมระยะยาว ลดหย่อนได้สูงสุด 30% ของรายได้ แต่ไม่เกิน 200,000 บาท ต้องถือหน่วยลงทุนอย่างน้อย 10 ปี</p>
      <p class="mt-3"><strong>RMF (Retirement Mutual Fund)</strong> หรือกองทุนรวมเพื่อการเลี้ยงชีพ เป็นกองทุนสำหรับออมเงินเพื่อเกษียณอายุ อยู่ในกลุ่มเพดานรวม 500,000 บาท (รวมกับ PVD กบข. และประกันบำนาญ)</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณลดหย่อน-SSF-RMF/" />
    <RelatedCalculators currentHref="/คำนวณลดหย่อน-SSF-RMF/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางการเงินหรือกฎหมาย กรุณาปรึกษาผู้เชี่ยวชาญก่อนตัดสินใจลงทุน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' บาท';
    }

    document.getElementById('btn-ssfrmf-calc')!.addEventListener('click', () => {
      const income = parseNum((document.getElementById('ssfrmf-income') as HTMLInputElement).value);
      const ssf = parseNum((document.getElementById('ssf-amount') as HTMLInputElement).value);
      const rmf = parseNum((document.getElementById('rmf-amount') as HTMLInputElement).value);
      const pvd = parseNum((document.getElementById('pvd-amount') as HTMLInputElement).value);
      const pensionIns = parseNum((document.getElementById('pension-ins') as HTMLInputElement).value);
      if (income <= 0) return;

      const limit30 = income * 0.30;
      // SSF: min(actual, 30% income, 200k)
      const ssfDeduction = Math.min(ssf, limit30, 200000);
      // Combined group cap: 500k, but also each item capped at 30% of income
      // RMF: min(actual, 30% income), then group total capped at 500k
      const groupBeforeCap = ssfDeduction + rmf + pvd + pensionIns;
      const groupCap = Math.min(groupBeforeCap, 500000);
      // Distribute the group cap: SSF already deducted, rest goes to RMF+PVD+pension
      const remainingForRmf = Math.max(0, groupCap - ssfDeduction - pvd - pensionIns);
      const rmfDeduction = Math.min(rmf, Math.min(limit30, remainingForRmf));
      const totalDeduction = ssfDeduction + rmfDeduction;

      (document.getElementById('sr-ssf') as HTMLElement).textContent = fmt(ssfDeduction);
      (document.getElementById('sr-rmf') as HTMLElement).textContent = fmt(rmfDeduction);
      (document.getElementById('sr-total') as HTMLElement).textContent = fmt(totalDeduction);
      (document.getElementById('sr-30pct') as HTMLElement).textContent = fmt(limit30);
      (document.getElementById('sr-group-total') as HTMLElement).textContent = fmt(ssfDeduction + rmf + pvd + pensionIns);

      const warn = document.getElementById('sr-warning') as HTMLElement;
      if (ssfDeduction + rmf + pvd + pensionIns > 500000) {
        warn.textContent = '⚠️ ยอดรวมกลุ่มเกิน 500,000 บาท — RMF บางส่วนถูกตัดออกจากการลดหย่อน';
        warn.classList.remove('hidden');
      } else {
        warn.classList.add('hidden');
      }

      (document.getElementById('ssfrmf-result') as HTMLDivElement).classList.remove('hidden');
      trackCalculatorUsed('ssf-rmf');
    });
  </script>
</BaseLayout>
