---
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณเปรียบเทียบ Deductible กับเบี้ย 2569 | Kamnuanlek';
const pageDescription = 'คำนวณและเปรียบเทียบระหว่างเบี้ยประกับและเงินหักตัวเอง (deductible) เพื่อเลือกตัวเลือกที่เหมาะสมกับงบประมาณและความต้องการ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเปรียบเทียบ-deductible-กับเบี้ย/`;

const faqData = [
  {
    question: 'Deductible คืออะไร?',
    answer: 'Deductible คือเงินที่ผู้เอาประกันต้องจ่ายเองเมื่อเกิดความเสียหาย บริษัทประกันจะชดเชยเฉพาะส่วนที่เกิน Deductible เท่านั้น',
  },
  {
    question: 'ทำไมต้องมี Deductible?',
    answer: 'Deductible ช่วยลดต้นทุนของบริษัทประกัน ทำให้เบี้ยประกันต่ำลง และป้องกันการเคลมเล็กน้อย',
  },
  {
    question: 'ควรเลือก Deductible เท่าไร?',
    answer: 'ควรพิจารณาความสามารถในการจ่ายเงินสด และจำนวนเงินที่สูญเสีย โดยทั่วไป Deductible ที่สูงจะทำให้เบี้ยต่ำลง แต่ต้องแลกกับการจ่ายเงินมากขึ้นเมื่อเกิดเคลม',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณเปรียบเทียบ Deductible กับเบี้ย',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเปรียบเทียบ Deductible กับเบี้ย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณเปรียบเทียบ Deductible กับเบี้ย</h1>
    <p class="text-gray-600 mb-6">เปรียบเทียบระหว่างเบี้ยประกันและเงินหักตัวเอง เพื่อหาตัวเลือกที่ดีที่สุด</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูล</h2>
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="totalPremium" class="block text-sm font-medium text-gray-700 mb-1">เบี้ยรวมต่อปี (บาท)</label>
          <input type="text" id="totalPremium" inputmode="decimal" placeholder="เช่น 10,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
        <div>
          <label for="deductible" class="block text-sm font-medium text-gray-700 mb-1">เงินหักตัวเอง (บาท)</label>
          <input type="text" id="deductible" inputmode="decimal" placeholder="เช่น 5,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
        </div>
      </div>

      <button type="button" id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">
        คำนวณ
      </button>

      <div id="result" class="hidden mt-6">
        <div class="text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ค่าใช้จ่ายรวม</div>
          <div id="total-cost" class="text-5xl font-bold mb-2 text-primary-600">-</div>
          <div class="text-lg font-semibold text-gray-700">บาท/ปี</div>
        </div>

        <div class="bg-gray-50 rounded-lg p-4 mb-4">
          <h3 class="font-semibold text-gray-900 mb-3">รายละเอียด</h3>
          <div class="text-sm text-gray-700 space-y-2">
            <div class="flex justify-between">
              <span>เบี้ยประกัน:</span>
              <span id="detail-premium" class="font-semibold">-</span>
            </div>
            <div class="flex justify-between">
              <span>เงินหักตัวเอง:</span>
              <span id="detail-deductible" class="font-semibold">-</span>
            </div>
            <div class="flex justify-between border-t pt-2 mt-2">
              <span>ค่าใช้จ่ายรวม:</span>
              <span id="detail-total" class="font-semibold text-primary-600">-</span>
            </div>
          </div>
        </div>

        <div class="p-4 bg-blue-50 rounded-lg">
          <h3 class="font-semibold text-gray-900 mb-2">เคล็ดลับ</h3>
          <p class="text-sm text-gray-600">เมื่อเลือก Deductible สูง เบี้ยจะต่ำ แต่ต้องเตรียมเงินสดเมื่อเกิดเคลม ควรตัดสินใจตามความสามารถจ่ายและความเสี่ยง</p>
        </div>
      </div>
    </div>

    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">Deductible กับเบี้ย</h2>
      <p>
        การเลือก Deductible ที่เหมาะสมเป็นสิ่งสำคัญในการวางแผนประกัน
        เนื่องจากมีผลต่อต้นทุนประกันและความสามารถในการจ่ายเงินเมื่อเกิดความเสียหาย
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ความสัมพันธ์ระหว่าง Deductible และเบี้ย</h3>
      <div class="bg-gray-50 rounded-lg p-4 text-center my-4">
        <p class="text-lg font-semibold">ค่าใช้จ่ายรวม = เบี้ยประกัน + เงินหักตัวเอง</p>
      </div>

      <p>
        โดยทั่วไปเมื่อ Deductible สูงขึ้น เบี้ยประกันจะต่ำลง เพราะบริษัทประกันมีความเสี่ยงน้อยลง
        ในทางกลับกัน เมื่อ Deductible ต่ำ เบี้ยจะสูงขึ้น
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีเลือก Deductible ที่เหมาะสม</h3>
      <ul class="list-disc pl-6 space-y-2 text-gray-700">
        <li>พิจารณาความสามารถในการจ่ายเงินสด หากเกิดอุบัติเหตุ</li>
        <li>ลองคำนวณค่าใช้จ่ายรวมต่างๆ เพื่อหาจุดสมดุล</li>
        <li>มองหาความประหยัด แต่อย่าเลือก Deductible สูงจนเกินไป</li>
        <li>เปรียบเทียบเสนอราคาจากบริษัทประกันต่างๆ</li>
      </ul>
    </section>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณเปรียบเทียบ-deductible-กับเบี้ย/" />
    <RelatedCalculators currentHref="/คำนวณเปรียบเทียบ-deductible-กับเบี้ย/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ไม่ถือเป็นคำแนะนำทางการเงิน กรุณาปรึกษาบริษัทประกันสำหรับรายละเอียด
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    const premiumInput = document.getElementById('totalPremium') as HTMLInputElement;
    const deductibleInput = document.getElementById('deductible') as HTMLInputElement;

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const premium = parseNum(premiumInput.value);
      const deductible = parseNum(deductibleInput.value);

      if (premium <= 0) { premiumInput.focus(); return; }
      if (deductible < 0) { deductibleInput.focus(); return; }

      const totalCost = premium + deductible;
      const fmt = new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

      (document.getElementById('total-cost') as HTMLElement).textContent = fmt.format(totalCost);
      (document.getElementById('detail-premium') as HTMLElement).textContent = fmt.format(premium);
      (document.getElementById('detail-deductible') as HTMLElement).textContent = fmt.format(deductible);
      (document.getElementById('detail-total') as HTMLElement).textContent = fmt.format(totalCost);

      (document.getElementById('result') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('deductible_comparison');
    });

    [premiumInput, deductibleInput].forEach(input => {
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          document.getElementById('btn-calculate')!.click();
        }
      });
    });
  </script>
</BaseLayout>
