---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณค่าปุ๋ย 2569 | คำนวณปริมาณปุ๋ยตามชนิดพืชและพื้นที่ | Calculator Thailand';
const pageDescription = 'คำนวณค่าปุ๋ยออนไลน์ฟรี เลือกชนิดพืช พื้นที่ (ไร่) ประเภทดิน คำนวณปริมาณปุ๋ยที่ต้องใช้ ค่าใช้จ่าย พร้อมคำแนะนำสูตรปุ๋ย NPK ตามกรมวิชาการเกษตร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าปุ๋ย/`;

const faqData = [
  {
    question: 'ปุ๋ยสูตร NPK คืออะไร?',
    answer: 'NPK คือตัวเลข 3 ตัวบนกระสอบปุ๋ย แสดงสัดส่วนธาตุอาหารหลัก 3 ชนิด ได้แก่ ไนโตรเจน (N) ฟอสฟอรัส (P) และโพแทสเซียม (K) เช่น สูตร 16-20-0 หมายถึง ไนโตรเจน 16% ฟอสฟอรัส 20% โพแทสเซียม 0% สูตรที่เหมาะสมขึ้นอยู่กับชนิดพืชและสภาพดิน',
  },
  {
    question: 'ใช้ปุ๋ยกี่กิโลกรัมต่อไร่?',
    answer: 'ปริมาณปุ๋ยขึ้นอยู่กับชนิดพืชและสภาพดิน โดยทั่วไป ข้าวใช้ 25-50 กก./ไร่ ข้าวโพดใช้ 50-75 กก./ไร่ อ้อยใช้ 50-100 กก./ไร่ มันสำปะหลังใช้ 25-50 กก./ไร่ ยางพาราใช้ 50-100 กก./ไร่ ผักใช้ 30-60 กก./ไร่ ข้อมูลอ้างอิงจากคำแนะนำของกรมวิชาการเกษตร',
  },
  {
    question: 'ดินแต่ละประเภทต้องใช้ปุ๋ยต่างกันอย่างไร?',
    answer: 'ดินทรายมีธาตุอาหารน้อย ต้องใช้ปุ๋ยมากกว่าปกติ 20-30% ดินร่วนเป็นดินที่สมดุล ใช้ปุ๋ยตามอัตราแนะนำปกติ ดินเหนียวกักเก็บธาตุอาหารได้ดี อาจใช้ปุ๋ยน้อยกว่าปกติ 10-15% ควรตรวจวิเคราะห์ดินก่อนใส่ปุ๋ยเพื่อความแม่นยำ',
  },
  {
    question: 'ควรแบ่งใส่ปุ๋ยกี่ครั้ง?',
    answer: 'โดยทั่วไปแนะนำให้แบ่งใส่ปุ๋ย 2-3 ครั้งต่อฤดูกาล เพื่อให้พืชได้รับธาตุอาหารอย่างต่อเนื่อง ครั้งที่ 1 ใส่รองพื้นก่อนหรือตอนปลูก ครั้งที่ 2 ใส่แต่งหน้าช่วงพืชเจริญเติบโต ครั้งที่ 3 ใส่เสริมช่วงออกดอก/ติดผล (ถ้าจำเป็น)',
  },
  {
    question: 'ราคาปุ๋ยเคมีปัจจุบันเท่าไร?',
    answer: 'ราคาปุ๋ยเคมีจะผันผวนตามตลาดโลก โดยราคาเฉลี่ยปี 2569 ปุ๋ยสูตร 46-0-0 (ยูเรีย) ประมาณ 18-22 บาท/กก. ปุ๋ยสูตร 16-20-0 ประมาณ 16-20 บาท/กก. ปุ๋ยสูตร 15-15-15 ประมาณ 18-22 บาท/กก. ราคาจริงอาจแตกต่างตามพื้นที่และผู้จำหน่าย',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าปุ๋ย',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าปุ๋ย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณค่าปุ๋ย (Fertilizer Calculator)
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณปริมาณปุ๋ยและค่าใช้จ่ายสำหรับการเกษตร เลือกชนิดพืช พื้นที่ (ไร่) และประเภทดิน
      พร้อมคำแนะนำสูตรปุ๋ย NPK ตามแนวทางกรมวิชาการเกษตร
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <!-- Crop Type -->
      <div class="mb-5">
        <label for="crop-type" class="block text-sm font-medium text-gray-700 mb-1">
          ชนิดพืช
        </label>
        <select
          id="crop-type"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
        >
          <option value="">-- เลือกชนิดพืช --</option>
          <option value="rice">🌾 ข้าว</option>
          <option value="corn">🌽 ข้าวโพด</option>
          <option value="sugarcane">🎋 อ้อย</option>
          <option value="cassava">🥔 มันสำปะหลัง</option>
          <option value="rubber">🌳 ยางพารา</option>
          <option value="palm">🌴 ปาล์มน้ำมัน</option>
          <option value="vegetable">🥬 ผักทั่วไป</option>
          <option value="fruit">🍉 ไม้ผล</option>
        </select>
      </div>

      <!-- Land Area -->
      <div class="mb-5">
        <label for="land-area" class="block text-sm font-medium text-gray-700 mb-1">
          พื้นที่ (ไร่)
        </label>
        <input
          type="text"
          id="land-area"
          inputmode="decimal"
          placeholder="เช่น 10"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
        />
      </div>

      <!-- Soil Type -->
      <div class="mb-5">
        <label class="block text-sm font-medium text-gray-700 mb-2">
          ประเภทดิน
        </label>
        <div class="flex flex-wrap gap-2" id="soil-presets">
          <button type="button" data-soil="loam" class="soil-btn px-4 py-2 rounded-md text-sm font-medium border-2 border-primary-500 bg-primary-50 text-primary-700 transition-colors">
            🟤 ดินร่วน
          </button>
          <button type="button" data-soil="clay" class="soil-btn px-4 py-2 rounded-md text-sm font-medium border border-gray-300 text-gray-700 hover:border-primary-500 hover:text-primary-700 transition-colors">
            🔴 ดินเหนียว
          </button>
          <button type="button" data-soil="sandy" class="soil-btn px-4 py-2 rounded-md text-sm font-medium border border-gray-300 text-gray-700 hover:border-primary-500 hover:text-primary-700 transition-colors">
            🟡 ดินทราย
          </button>
        </div>
      </div>

      <!-- Fertilizer Price -->
      <div class="mb-5">
        <label for="fertilizer-price" class="block text-sm font-medium text-gray-700 mb-1">
          ราคาปุ๋ย (บาท/กก.) <span class="text-gray-400 font-normal">— ไม่บังคับ ใช้ราคาเฉลี่ยหากไม่กรอก</span>
        </label>
        <input
          type="text"
          id="fertilizer-price"
          inputmode="decimal"
          placeholder="เช่น 20 (ค่าเริ่มต้น: ราคาเฉลี่ยตลาด)"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
        />
      </div>

      <!-- Calculate Button -->
      <button
        type="button"
        id="btn-calculate"
        class="w-full px-6 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณ
      </button>

      <!-- Results -->
      <div id="fert-result" class="hidden mt-6">
        <!-- Recommended Formula -->
        <div class="mb-4 p-4 bg-blue-50 rounded-lg border border-blue-100">
          <div class="text-sm text-blue-600 font-medium mb-1">สูตรปุ๋ยแนะนำ</div>
          <div id="res-formula" class="text-lg font-bold text-blue-800">-</div>
          <div id="res-formula-desc" class="text-sm text-blue-600 mt-1">-</div>
        </div>

        <!-- Main Results Grid -->
        <div class="grid gap-3 sm:grid-cols-2">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ปุ๋ยรองพื้น (ครั้งที่ 1)</div>
            <div id="res-base" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ปุ๋ยแต่งหน้า (ครั้งที่ 2)</div>
            <div id="res-top" class="text-xl font-bold text-green-700">-</div>
          </div>
        </div>

        <!-- Totals -->
        <div class="grid gap-3 sm:grid-cols-3 mt-3">
          <div class="bg-amber-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ปุ๋ยรวมทั้งหมด</div>
            <div id="res-total-kg" class="text-xl font-bold text-amber-700">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าใช้จ่ายโดยประมาณ</div>
            <div id="res-total-cost" class="text-xl font-bold text-red-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">จำนวนกระสอบ (50 กก.)</div>
            <div id="res-bags" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>

        <!-- Breakdown Table -->
        <div class="mt-4 overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="text-left text-gray-500 border-b border-gray-200">
                <th class="py-2 pr-3">รายการ</th>
                <th class="py-2 pr-3 text-right">กก./ไร่</th>
                <th class="py-2 pr-3 text-right">รวม (กก.)</th>
                <th class="py-2 text-right">ค่าใช้จ่าย (บาท)</th>
              </tr>
            </thead>
            <tbody id="res-breakdown" class="text-gray-700">
            </tbody>
          </table>
        </div>

        <!-- Application Tips -->
        <div id="res-tips" class="mt-4 p-3 bg-green-50 rounded-lg text-sm text-green-800">
        </div>

        <!-- Summary -->
        <div class="mt-3 p-3 bg-gray-50 rounded-lg text-sm text-gray-600">
          <div id="res-summary"></div>
        </div>
      </div>
    </div>

    <!-- AdSense placeholder -->
    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">
      [โฆษณา — AdSense]
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">คู่มือการใช้ปุ๋ยสำหรับเกษตรกรไทย</h2>

      <p>
        ปุ๋ยเคมีเป็นปัจจัยสำคัญในการเพิ่มผลผลิตทางการเกษตร การใช้ปุ๋ยในปริมาณที่เหมาะสม
        ช่วยลดต้นทุน เพิ่มผลผลิต และรักษาคุณภาพดินในระยะยาว เครื่องคำนวณค่าปุ๋ยนี้
        ช่วยให้เกษตรกรประมาณปริมาณและค่าใช้จ่ายปุ๋ยได้อย่างรวดเร็ว
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ธาตุอาหารหลัก NPK คืออะไร?</h3>

      <p>
        ปุ๋ยเคมีประกอบด้วยธาตุอาหารหลัก 3 ชนิด ที่จำเป็นต่อการเจริญเติบโตของพืช:
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>ไนโตรเจน (N)</strong> — ช่วยในการเจริญเติบโตของลำต้นและใบ ทำให้ใบเขียวสมบูรณ์</li>
        <li><strong>ฟอสฟอรัส (P)</strong> — ช่วยในการพัฒนาราก การออกดอก และการติดเมล็ด</li>
        <li><strong>โพแทสเซียม (K)</strong> — ช่วยเพิ่มความต้านทานโรค ความแข็งแรงของลำต้น และคุณภาพผลผลิต</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรปุ๋ยแนะนำตามชนิดพืช</h3>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b border-gray-200">
              <th class="py-2 pr-4">ชนิดพืช</th>
              <th class="py-2 pr-4">สูตรรองพื้น</th>
              <th class="py-2 pr-4">สูตรแต่งหน้า</th>
              <th class="py-2">ปริมาณรวม (กก./ไร่)</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">🌾 ข้าว</td>
              <td class="py-2 pr-4">16-20-0</td>
              <td class="py-2 pr-4">46-0-0 (ยูเรีย)</td>
              <td class="py-2">25-50</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">🌽 ข้าวโพด</td>
              <td class="py-2 pr-4">15-15-15</td>
              <td class="py-2 pr-4">46-0-0 (ยูเรีย)</td>
              <td class="py-2">50-75</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">🎋 อ้อย</td>
              <td class="py-2 pr-4">15-15-15</td>
              <td class="py-2 pr-4">21-0-0</td>
              <td class="py-2">50-100</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">🥔 มันสำปะหลัง</td>
              <td class="py-2 pr-4">15-15-15</td>
              <td class="py-2 pr-4">15-15-15</td>
              <td class="py-2">25-50</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">🌳 ยางพารา</td>
              <td class="py-2 pr-4">15-15-15</td>
              <td class="py-2 pr-4">20-8-20</td>
              <td class="py-2">50-100</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">🌴 ปาล์มน้ำมัน</td>
              <td class="py-2 pr-4">15-15-15</td>
              <td class="py-2 pr-4">0-0-60</td>
              <td class="py-2">50-100</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">🥬 ผักทั่วไป</td>
              <td class="py-2 pr-4">15-15-15</td>
              <td class="py-2 pr-4">46-0-0 (ยูเรีย)</td>
              <td class="py-2">30-60</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">🍉 ไม้ผล</td>
              <td class="py-2 pr-4">15-15-15</td>
              <td class="py-2 pr-4">13-13-21</td>
              <td class="py-2">50-100</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-500 mt-1">
        * อ้างอิง: คำแนะนำการใช้ปุ๋ย กรมวิชาการเกษตร กระทรวงเกษตรและสหกรณ์
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ผลของประเภทดินต่อการใส่ปุ๋ย</h3>

      <p>
        ดินแต่ละประเภทมีความสามารถในการกักเก็บธาตุอาหารต่างกัน ส่งผลต่อปริมาณปุ๋ยที่ต้องใช้:
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>ดินร่วน</strong> — ดินที่สมดุลที่สุดสำหรับการเกษตร กักเก็บน้ำและธาตุอาหารได้ดี ใช้ปุ๋ยตามอัตราแนะนำปกติ</li>
        <li><strong>ดินเหนียว</strong> — กักเก็บธาตุอาหารได้ดีแต่ระบายน้ำไม่ดี อาจใช้ปุ๋ยน้อยกว่าปกติ 10-15%</li>
        <li><strong>ดินทราย</strong> — ระบายน้ำดีแต่กักเก็บธาตุอาหารน้อย ต้องใช้ปุ๋ยมากกว่าปกติ 20-30% และควรแบ่งใส่หลายครั้ง</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เคล็ดลับการใส่ปุ๋ยอย่างมีประสิทธิภาพ</h3>

      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ตรวจวิเคราะห์ดินก่อนใส่ปุ๋ยทุกฤดูกาลเพื่อทราบธาตุอาหารที่ขาด</li>
        <li>ใส่ปุ๋ยขณะดินมีความชื้น ไม่ใส่ขณะฝนตกหนักเพราะปุ๋ยจะถูกชะล้าง</li>
        <li>แบ่งใส่ปุ๋ย 2-3 ครั้งต่อฤดูกาล ดีกว่าใส่ครั้งเดียวปริมาณมาก</li>
        <li>ใช้ปุ๋ยอินทรีย์ร่วมกับปุ๋ยเคมีเพื่อบำรุงดินระยะยาว</li>
        <li>เก็บปุ๋ยในที่แห้ง ไม่โดนแดดและฝน ปิดปากกระสอบให้สนิท</li>
      </ul>

      <p class="mt-4">
        เครื่องคำนวณค่าปุ๋ยนี้ช่วยให้เกษตรกรไทยวางแผนต้นทุนปุ๋ยได้ล่วงหน้า
        ลดการใช้ปุ๋ยเกินความจำเป็น และเพิ่มผลผลิตอย่างคุ้มค่า
        สามารถใช้ร่วมกับ <a href="/คำนวณเปอร์เซ็นต์/" data-preserve-utm class="text-primary-600 hover:text-primary-700">เครื่องคำนวณเปอร์เซ็นต์</a>
        เพื่อคำนวณสัดส่วนธาตุอาหารเพิ่มเติม
      </p>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณค่าปุ๋ย/" />
    <RelatedCalculators currentHref="/คำนวณค่าปุ๋ย/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong>
      ผลการคำนวณเป็นการประมาณการเท่านั้น ปริมาณปุ๋ยที่เหมาะสมจริงขึ้นอยู่กับผลวิเคราะห์ดิน
      สภาพอากาศ พันธุ์พืช และปัจจัยอื่นๆ ควรปรึกษาเจ้าหน้าที่เกษตรในพื้นที่หรือตรวจวิเคราะห์ดิน
      ก่อนใส่ปุ๋ยจริง ราคาปุ๋ยเป็นราคาเฉลี่ยตลาดและอาจแตกต่างตามพื้นที่
      อ้างอิงข้อมูลจากกรมวิชาการเกษตร กระทรวงเกษตรและสหกรณ์
    </div>
  </article>

  <script>
    // ── Crop data: fertilizer recommendations per rai ──
    // Reference: กรมวิชาการเกษตร (Department of Agriculture, Thailand)
    interface CropData {
      name: string;
      baseFormula: string;
      baseFormulaName: string;
      topFormula: string;
      topFormulaName: string;
      baseKgPerRai: number;
      topKgPerRai: number;
      basePrice: number;  // avg baht/kg
      topPrice: number;   // avg baht/kg
      tips: string;
    }

    const cropData: Record<string, CropData> = {
      rice: {
        name: 'ข้าว',
        baseFormula: '16-20-0',
        baseFormulaName: 'ปุ๋ยสูตร 16-20-0',
        topFormula: '46-0-0',
        topFormulaName: 'ยูเรีย (46-0-0)',
        baseKgPerRai: 25,
        topKgPerRai: 15,
        basePrice: 18,
        topPrice: 20,
        tips: 'ใส่ปุ๋ยรองพื้นก่อนปักดำ 1 วัน ใส่ปุ๋ยแต่งหน้าหลังปักดำ 25-30 วัน และอาจเพิ่มครั้งที่ 3 ก่อนข้าวตั้งท้อง',
      },
      corn: {
        name: 'ข้าวโพด',
        baseFormula: '15-15-15',
        baseFormulaName: 'ปุ๋ยสูตร 15-15-15',
        topFormula: '46-0-0',
        topFormulaName: 'ยูเรีย (46-0-0)',
        baseKgPerRai: 30,
        topKgPerRai: 25,
        basePrice: 20,
        topPrice: 20,
        tips: 'ใส่ปุ๋ยรองพื้นพร้อมปลูก โรยข้างแถวห่างโคนต้น 5-10 ซม. ใส่ปุ๋ยแต่งหน้าเมื่อข้าวโพดอายุ 25-30 วัน',
      },
      sugarcane: {
        name: 'อ้อย',
        baseFormula: '15-15-15',
        baseFormulaName: 'ปุ๋ยสูตร 15-15-15',
        topFormula: '21-0-0',
        topFormulaName: 'แอมโมเนียมซัลเฟต (21-0-0)',
        baseKgPerRai: 50,
        topKgPerRai: 30,
        basePrice: 20,
        topPrice: 12,
        tips: 'ใส่ปุ๋ยรองพื้นก้นร่องก่อนปลูก ใส่ปุ๋ยแต่งหน้าเมื่ออ้อยอายุ 2-3 เดือน กลบดินหลังใส่ปุ๋ยทุกครั้ง',
      },
      cassava: {
        name: 'มันสำปะหลัง',
        baseFormula: '15-15-15',
        baseFormulaName: 'ปุ๋ยสูตร 15-15-15',
        topFormula: '15-15-15',
        topFormulaName: 'ปุ๋ยสูตร 15-15-15',
        baseKgPerRai: 25,
        topKgPerRai: 25,
        basePrice: 20,
        topPrice: 20,
        tips: 'ใส่ปุ๋ยครั้งที่ 1 หลังปลูก 1 เดือน ครั้งที่ 2 หลังปลูก 3 เดือน โรยข้างแถวห่างโคนต้น 10-15 ซม.',
      },
      rubber: {
        name: 'ยางพารา',
        baseFormula: '15-15-15',
        baseFormulaName: 'ปุ๋ยสูตร 15-15-15',
        topFormula: '20-8-20',
        topFormulaName: 'ปุ๋ยสูตร 20-8-20',
        baseKgPerRai: 40,
        topKgPerRai: 40,
        basePrice: 20,
        topPrice: 22,
        tips: 'แบ่งใส่ปีละ 2 ครั้ง ต้นฤดูฝน (เม.ย.-พ.ค.) และปลายฤดูฝน (ก.ย.-ต.ค.) โรยรอบทรงพุ่มห่างโคนต้น 1-2 เมตร',
      },
      palm: {
        name: 'ปาล์มน้ำมัน',
        baseFormula: '15-15-15',
        baseFormulaName: 'ปุ๋ยสูตร 15-15-15',
        topFormula: '0-0-60',
        topFormulaName: 'โพแทสเซียมคลอไรด์ (0-0-60)',
        baseKgPerRai: 40,
        topKgPerRai: 25,
        basePrice: 20,
        topPrice: 18,
        tips: 'แบ่งใส่ 2-3 ครั้งต่อปี โรยรอบทรงพุ่ม ปาล์มต้องการโพแทสเซียมสูง ควรเสริม 0-0-60 เป็นพิเศษ',
      },
      vegetable: {
        name: 'ผักทั่วไป',
        baseFormula: '15-15-15',
        baseFormulaName: 'ปุ๋ยสูตร 15-15-15',
        topFormula: '46-0-0',
        topFormulaName: 'ยูเรีย (46-0-0)',
        baseKgPerRai: 30,
        topKgPerRai: 15,
        basePrice: 20,
        topPrice: 20,
        tips: 'ใส่ปุ๋ยรองพื้นก่อนปลูก 3-5 วัน คลุกเคล้ากับดิน ใส่ปุ๋ยแต่งหน้าหลังปลูก 15-20 วัน ควรรดน้ำหลังใส่ปุ๋ยทุกครั้ง',
      },
      fruit: {
        name: 'ไม้ผล',
        baseFormula: '15-15-15',
        baseFormulaName: 'ปุ๋ยสูตร 15-15-15',
        topFormula: '13-13-21',
        topFormulaName: 'ปุ๋ยสูตร 13-13-21',
        baseKgPerRai: 50,
        topKgPerRai: 40,
        basePrice: 20,
        topPrice: 22,
        tips: 'ใส่ปุ๋ยหลังเก็บเกี่ยว ก่อนออกดอก และช่วงติดผล โรยรอบทรงพุ่มและพรวนดินกลบ',
      },
    };

    // Soil adjustment factors
    const soilFactors: Record<string, { factor: number; label: string }> = {
      loam: { factor: 1.0, label: 'ดินร่วน (อัตราปกติ)' },
      clay: { factor: 0.88, label: 'ดินเหนียว (ลด 12%)' },
      sandy: { factor: 1.25, label: 'ดินทราย (เพิ่ม 25%)' },
    };

    let selectedSoil = 'loam';
    const soilBtns = document.querySelectorAll<HTMLButtonElement>('.soil-btn');

    soilBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedSoil = btn.dataset.soil || 'loam';
        updateSoilBtnStyles();
      });
    });

    function updateSoilBtnStyles() {
      soilBtns.forEach((btn) => {
        const btnSoil = btn.dataset.soil || '';
        if (btnSoil === selectedSoil) {
          btn.className = 'soil-btn px-4 py-2 rounded-md text-sm font-medium border-2 border-primary-500 bg-primary-50 text-primary-700 transition-colors';
        } else {
          btn.className = 'soil-btn px-4 py-2 rounded-md text-sm font-medium border border-gray-300 text-gray-700 hover:border-primary-500 hover:text-primary-700 transition-colors';
        }
      });
    }

    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 1 }).format(n);
    }

    function fmtBaht(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    function calculate() {
      const cropSelect = document.getElementById('crop-type') as HTMLSelectElement;
      const cropKey = cropSelect.value;
      if (!cropKey) { cropSelect.focus(); return; }

      const areaInput = document.getElementById('land-area') as HTMLInputElement;
      const area = parseNum(areaInput.value);
      if (area <= 0) { areaInput.focus(); return; }

      const crop = cropData[cropKey];
      const soil = soilFactors[selectedSoil];

      // Custom price or default
      const priceInput = document.getElementById('fertilizer-price') as HTMLInputElement;
      const customPrice = parseNum(priceInput.value);

      // Apply soil factor
      const adjBaseKg = crop.baseKgPerRai * soil.factor;
      const adjTopKg = crop.topKgPerRai * soil.factor;

      const totalBaseKg = adjBaseKg * area;
      const totalTopKg = adjTopKg * area;
      const totalKg = totalBaseKg + totalTopKg;

      // Prices
      const basePricePerKg = customPrice > 0 ? customPrice : crop.basePrice;
      const topPricePerKg = customPrice > 0 ? customPrice : crop.topPrice;
      const baseCost = totalBaseKg * basePricePerKg;
      const topCost = totalTopKg * topPricePerKg;
      const totalCost = baseCost + topCost;

      // Bags (50 kg standard)
      const totalBags = Math.ceil(totalKg / 50);

      // Display results
      (document.getElementById('res-formula') as HTMLElement).textContent =
        `${crop.baseFormula} + ${crop.topFormula}`;
      (document.getElementById('res-formula-desc') as HTMLElement).textContent =
        `${crop.baseFormulaName} (รองพื้น) + ${crop.topFormulaName} (แต่งหน้า) — ${soil.label}`;

      (document.getElementById('res-base') as HTMLElement).textContent =
        `${fmt(totalBaseKg)} กก.`;
      (document.getElementById('res-top') as HTMLElement).textContent =
        `${fmt(totalTopKg)} กก.`;
      (document.getElementById('res-total-kg') as HTMLElement).textContent =
        `${fmt(totalKg)} กก.`;
      (document.getElementById('res-total-cost') as HTMLElement).textContent =
        `฿${fmtBaht(totalCost)}`;
      (document.getElementById('res-bags') as HTMLElement).textContent =
        `${totalBags} กระสอบ`;

      // Breakdown table
      const tbody = document.getElementById('res-breakdown') as HTMLElement;
      tbody.innerHTML = `
        <tr class="border-b border-gray-100">
          <td class="py-2 pr-3">${crop.baseFormulaName}</td>
          <td class="py-2 pr-3 text-right">${fmt(adjBaseKg)}</td>
          <td class="py-2 pr-3 text-right">${fmt(totalBaseKg)}</td>
          <td class="py-2 text-right">${fmtBaht(baseCost)}</td>
        </tr>
        <tr class="border-b border-gray-100">
          <td class="py-2 pr-3">${crop.topFormulaName}</td>
          <td class="py-2 pr-3 text-right">${fmt(adjTopKg)}</td>
          <td class="py-2 pr-3 text-right">${fmt(totalTopKg)}</td>
          <td class="py-2 text-right">${fmtBaht(topCost)}</td>
        </tr>
        <tr class="font-semibold">
          <td class="py-2 pr-3">รวมทั้งหมด</td>
          <td class="py-2 pr-3 text-right">${fmt(adjBaseKg + adjTopKg)}</td>
          <td class="py-2 pr-3 text-right">${fmt(totalKg)}</td>
          <td class="py-2 text-right">${fmtBaht(totalCost)}</td>
        </tr>
      `;

      // Tips
      (document.getElementById('res-tips') as HTMLElement).innerHTML =
        `<strong>💡 คำแนะนำสำหรับ${crop.name}:</strong> ${crop.tips}`;

      // Summary
      (document.getElementById('res-summary') as HTMLElement).textContent =
        `${crop.name} พื้นที่ ${fmt(area)} ไร่ (${soil.label}) — ปุ๋ยรวม ${fmt(totalKg)} กก. (${totalBags} กระสอบ) ค่าใช้จ่ายประมาณ ${fmtBaht(totalCost)} บาท`;

      (document.getElementById('fert-result') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('fertilizer');
    }

    document.getElementById('btn-calculate')!.addEventListener('click', calculate);

    // Enter key on area input
    (document.getElementById('land-area') as HTMLInputElement).addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        calculate();
      }
    });

    // Track when result section enters viewport
    const fertResultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('fertilizer');
          fertResultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    fertResultObserver.observe(document.getElementById('fert-result')!);
  </script>
</BaseLayout>
