---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณ ROI Membership Salon | Package vs Pay per Visit';
const pageDescription = 'เปรียบเทียบราคา Membership/Package salon กับการจ่ายเงินสดแต่ละครั้ง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-salon-membership-roi/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="Salon Membership ROI">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณ ROI Membership Salon</h1>
    <div class="mb-4 inline-block rounded-lg border border-fuchsia-200 bg-fuchsia-50 px-3 py-2">
      <p class="text-xs font-semibold text-fuchsia-800">[KLC-0780]</p>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ราคา Membership/เดือน (บาท)</label>
          <input type="text" id="membership-price" inputmode="decimal" placeholder="1500" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (เดือน)</label>
          <input type="text" id="membership-duration" inputmode="decimal" placeholder="3" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ค่าบริการต่อครั้ง (บาท)</label>
          <input type="text" id="per-visit-cost" inputmode="decimal" placeholder="300" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้ง/เดือน</label>
          <input type="text" id="visits-per-month" inputmode="decimal" placeholder="4" class="w-full px-3 py-2 border border-gray-300 rounded-md text-base" />
        </div>
      </div>

      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 text-base">เปรียบเทียบ</button>

      <div id="result" class="hidden mt-6">
        <div class="grid gap-4 sm:grid-cols-2 mb-6">
          <div class="bg-blue-50 rounded-lg p-4">
            <div class="text-sm text-gray-600 mb-1">ค่า Membership รวม</div>
            <div id="membership-total" class="text-2xl font-bold text-blue-600">-</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4">
            <div class="text-sm text-gray-600 mb-1">จ่ายเงินสดรวม</div>
            <div id="paypervisit-total" class="text-2xl font-bold text-orange-600">-</div>
          </div>
        </div>
        <div class="bg-green-50 rounded-lg p-4 text-center">
          <div class="text-sm text-gray-600 mb-1">ประหยัดได้</div>
          <div id="savings" class="text-3xl font-bold text-green-600">-</div>
        </div>
      </div>
    </div>

    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">[โฆษณา]</div>

    <section class="prose prose-gray max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ว่า Membership Salon คุ้มหรือไม่?</h2>
      <p>Membership Salon อาจคุ้มถ้าคุณไปบ่อยและใช้บริการตรงกับสิ่งที่ได้</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เงื่อนไขที่ Membership คุ้ม</h3>
      <ul class="list-disc pl-6 text-gray-700">
        <li>ไปบริการตามความถี่ที่กำหนด</li>
        <li>ใช้บริการทั้งหมดตามประเภท</li>
        <li>ต่างหลัง membership ไม่หมดอายุ</li>
        <li>เปรียบเทียบราคากับร้านอื่น</li>
      </ul>
    </section>
  </article>

  <script>
    function formatCurrency(value: number): string {
      return new Intl.NumberFormat('th-TH', {
        style: 'currency',
        currency: 'THB',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(value);
    }

    document.getElementById('btn-calculate')?.addEventListener('click', () => {
      const membershipPrice = parseFloat((document.getElementById('membership-price') as HTMLInputElement)?.value) || 0;
      const membershipDuration = parseFloat((document.getElementById('membership-duration') as HTMLInputElement)?.value) || 1;
      const perVisitCost = parseFloat((document.getElementById('per-visit-cost') as HTMLInputElement)?.value) || 0;
      const visitsPerMonth = parseFloat((document.getElementById('visits-per-month') as HTMLInputElement)?.value) || 0;

      const membershipTotal = membershipPrice * membershipDuration;
      const payPerVisitTotal = perVisitCost * visitsPerMonth * membershipDuration;
      const savings = payPerVisitTotal - membershipTotal;

      document.getElementById('membership-total')!.textContent = formatCurrency(membershipTotal);
      document.getElementById('paypervisit-total')!.textContent = formatCurrency(payPerVisitTotal);
      document.getElementById('savings')!.textContent = savings > 0 ? formatCurrency(savings) : 'ไม่คุ้ม';
      document.getElementById('result')!.classList.remove('hidden');
    });
  </script>
</BaseLayout>
