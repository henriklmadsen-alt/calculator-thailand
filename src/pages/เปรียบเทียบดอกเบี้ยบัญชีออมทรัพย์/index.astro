---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'เปรียบเทียบดอกเบี้ยบัญชีออมทรัพย์ 2569 | ออมที่ไหนได้มากสุด | Kamnuanlek';
const pageDescription = 'เปรียบเทียบดอกเบี้ยบัญชีออมทรัพย์ ประจำ และตลาดเงินของธนาคารไทย ดูว่าควรฝากที่ไหน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/เปรียบเทียบดอกเบี้ยบัญชีออมทรัพย์/`;

const faqData = [
  {
    question: 'บัญชีออมทรัพย์กับบัญชีฝากประจำต่างกันอย่างไร?',
    answer: 'บัญชีออมทรัพย์ถอนได้ทุกเมื่อแต่ดอกเบี้ยต่ำกว่า (ประมาณ 0.5-1.5% ต่อปี) ส่วนบัญชีฝากประจำต้องฝากครบกำหนด (3, 6, 12 เดือน) แลกกับดอกเบี้ยสูงกว่า (1.5-3% ต่อปี) หากถอนก่อนกำหนดอาจได้ดอกเบี้ยน้อยลงหรือไม่ได้เลย',
  },
  {
    question: 'ดอกเบี้ยเงินฝากถูกหักภาษีเท่าไร?',
    answer: 'ดอกเบี้ยเงินฝากในไทยถูกหักภาษี ณ ที่จ่าย 15% ทันที ยกเว้นบัญชีออมทรัพย์ที่ได้ดอกเบี้ยไม่เกิน 20,000 บาทต่อปีได้รับการยกเว้น (สำหรับผู้เสียภาษีบุคคลธรรมดา)',
  },
  {
    question: 'บัญชีตลาดเงิน (Money Market) คืออะไร?',
    answer: 'บัญชีตลาดเงินเป็นบัญชีเงินฝากประเภทหนึ่งที่ให้ดอกเบี้ยสูงกว่าออมทรัพย์แต่ต่ำกว่าฝากประจำ บางธนาคารกำหนดยอดขั้นต่ำในการฝาก มีความยืดหยุ่นในการถอนเงินมากกว่าฝากประจำ เหมาะกับผู้ต้องการผลตอบแทนดีขึ้นแต่ยังต้องการสภาพคล่อง',
  },
,
  { question: 'ดอกเบี้ยทบต้น (Compound Interest) คืออะไร?', answer: 'ดอกเบี้ยที่คำนวณจากเงินต้นบวกดอกเบี้ยสะสม ทำให้เงินงอกเร็วกว่าดอกเบี้ยธรรมดา สูตร: A = P(1+r/n)^(nt) โดย P=เงินต้น, r=อัตราดอกเบี้ย, n=ครั้งที่ทบต่อปี, t=จำนวนปี' },
  { question: 'กฎ 72 ใช้คำนวณอะไร?', answer: 'ใช้ประมาณจำนวนปีที่เงินจะเพิ่มเป็น 2 เท่า: จำนวนปี = 72 ÷ อัตราดอกเบี้ย เช่น ดอกเบี้ย 6% ต่อปี เงินจะเป็น 2 เท่าใน 72÷6 = 12 ปี เป็นกฎง่ายสำหรับการวางแผนการเงิน' },
  { question: 'อัตราดอกเบี้ยเงินฝากออมทรัพย์ในไทยปัจจุบันอยู่ที่เท่าไร?', answer: 'ออมทรัพย์ทั่วไปอยู่ที่ 0.5-1.0% ต่อปี ฝากประจำ 12 เดือนอยู่ที่ 1.5-2.5% ต่อปี บัญชีออมทรัพย์พิเศษบางแห่งให้สูงถึง 1.5-3% ตรวจสอบอัตราปัจจุบันจากธนาคารแห่งประเทศไทย bot.or.th' },
  { question: 'ดอกเบี้ยเงินฝากเสียภาษีไหม?', answer: 'ใช่ ดอกเบี้ยเงินฝากธนาคารถูกหักภาษี ณ ที่จ่าย 15% โดยธนาคาร ยกเว้นดอกเบี้ยเงินฝากออมทรัพย์ที่ไม่เกิน 20,000 บาทต่อปีรวมทุกบัญชี สามารถขอคืนหรือเครดิตกับภาษีสิ้นปีได้' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องเปรียบเทียบดอกเบี้ยบัญชีออมทรัพย์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="เปรียบเทียบดอกเบี้ยบัญชีออมทรัพย์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">เปรียบเทียบดอกเบี้ยบัญชีออมทรัพย์ 2569</h1>
    <p class="mb-6 text-gray-600">เปรียบเทียบดอกเบี้ยรับสุทธิหลังหักภาษีจาก 3 ประเภทบัญชีเงินฝาก</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="calc-form" class="space-y-4">
        <div>
          <label for="deposit" class="mb-1 block text-sm font-medium text-gray-700">เงินฝาก (บาท)</label>
          <input id="deposit" type="text" inputmode="numeric" placeholder="เช่น 100000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <div>
          <label for="years" class="mb-1 block text-sm font-medium text-gray-700">ระยะเวลา (ปี)</label>
          <input id="years" type="text" inputmode="numeric" value="1"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div>
            <label for="savings-rate" class="mb-1 block text-sm font-medium text-gray-700">ออมทรัพย์ (% ต่อปี)</label>
            <input id="savings-rate" type="text" inputmode="decimal" value="1.5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="fixed-rate" class="mb-1 block text-sm font-medium text-gray-700">ฝากประจำ (% ต่อปี)</label>
            <input id="fixed-rate" type="text" inputmode="decimal" value="2.5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
          <div>
            <label for="mm-rate" class="mb-1 block text-sm font-medium text-gray-700">ตลาดเงิน (% ต่อปี)</label>
            <input id="mm-rate" type="text" inputmode="decimal" value="2.0"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          เปรียบเทียบ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ตารางเปรียบเทียบดอกเบี้ย</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 bg-gray-50">
                <th class="px-3 py-2 text-left font-semibold text-gray-700">ประเภทบัญชี</th>
                <th class="px-3 py-2 text-right font-semibold text-gray-700">ดอกเบี้ยก่อนภาษี</th>
                <th class="px-3 py-2 text-right font-semibold text-gray-700">หักภาษี 15%</th>
                <th class="px-3 py-2 text-right font-semibold text-gray-700">รับสุทธิ</th>
              </tr>
            </thead>
            <tbody id="res-table" class="divide-y divide-gray-100"></tbody>
          </table>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/เปรียบเทียบดอกเบี้ยบัญชีออมทรัพย์/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('calc-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const deposit = parseNum((document.getElementById('deposit') as HTMLInputElement).value);
    const years = parseNum((document.getElementById('years') as HTMLInputElement).value) || 1;
    const savingsRate = parseNum((document.getElementById('savings-rate') as HTMLInputElement).value);
    const fixedRate = parseNum((document.getElementById('fixed-rate') as HTMLInputElement).value);
    const mmRate = parseNum((document.getElementById('mm-rate') as HTMLInputElement).value);
    if (!deposit) return;

    const TAX = 0.15;
    const accounts = [
      { name: 'ออมทรัพย์', rate: savingsRate },
      { name: 'ฝากประจำ', rate: fixedRate },
      { name: 'ตลาดเงิน', rate: mmRate },
    ];

    const tbody = document.getElementById('res-table')!;
    tbody.innerHTML = accounts.map(a => {
      const gross = deposit * (a.rate / 100) * years;
      const tax = gross * TAX;
      const net = gross - tax;
      return `<tr class="hover:bg-gray-50"><td class="px-3 py-2 text-gray-800">${a.name} (${a.rate}%)</td><td class="px-3 py-2 text-right text-gray-800">${fmt(gross)}</td><td class="px-3 py-2 text-right text-red-600">-${fmt(tax)}</td><td class="px-3 py-2 text-right font-semibold text-primary-700">${fmt(net)}</td></tr>`;
    }).join('');

    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
