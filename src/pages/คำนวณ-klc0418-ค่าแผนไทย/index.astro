---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าแพทย์แผนไทย | Kamnuanlek';
const pageDescription = 'คำนวณค่าแพทย์แผนไทย ค่านวดไทย ค่าสมุนไพร ค่าฝังเข็ม ค่าประคบสมุนไพร';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0418-ค่าแผนไทย/`;

const faqData = [
  { question: 'ค่านวดแผนไทยต่อครั้งเท่าไหร่?', answer: 'นวดแผนไทยทั่วไป 200-500 บาทต่อชั่วโมง นวดน้ำมัน 400-800 บาท นวดประคบสมุนไพร 400-700 บาท โรงพยาบาลรัฐถูกกว่าคลินิกเอกชน 2-3 เท่า' },
  { question: 'ฝังเข็มในไทยราคาเท่าไหร่?', answer: 'ฝังเข็มโรงพยาบาลรัฐ 300-500 บาทต่อครั้ง โรงพยาบาลเอกชน 800-2,000 บาทต่อครั้ง แพทย์จีน 500-1,500 บาท แนะนำทำ 5-10 ครั้งต่อคอร์ส' },
  { question: 'ประกันสังคมครอบคลุมแพทย์แผนไทยไหม?', answer: 'บางโรงพยาบาลในเครือข่ายประกันสังคมให้บริการแพทย์แผนไทย รวมนวดรักษาและสมุนไพรบางชนิด ขึ้นอยู่กับโรงพยาบาลที่เลือก' },
  { question: 'ยาสมุนไพรแผนไทยราคาเท่าไหร่?', answer: 'ยาสมุนไพรแผนไทยพื้นฐาน 100-500 บาทต่อชุด ยาสมุนไพรชนิดแคปซูล 200-800 บาทต่อกล่อง ยาต้มสมุนไพร 300-1,000 บาทต่อหม้อ' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าแพทย์แผนไทย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าแพทย์แผนไทย</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าใช้จ่ายแพทย์แผนไทย นวด สมุนไพร ฝังเข็ม</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="massage_cost" class="block text-sm font-medium text-gray-700 mb-1">ค่านวดแผนไทยต่อครั้ง (บาท)</label><input type="text" id="massage_cost" inputmode="decimal" placeholder="เช่น 400" value="400" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="massage_times" class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้งต่อเดือน</label><input type="number" id="massage_times" min="0" max="30" placeholder="เช่น 4" value="4" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="acupuncture" class="block text-sm font-medium text-gray-700 mb-1">ค่าฝังเข็มต่อครั้ง (บาท)</label><input type="text" id="acupuncture" inputmode="decimal" placeholder="เช่น 0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="acupuncture_times" class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้งต่อเดือน</label><input type="number" id="acupuncture_times" min="0" max="20" placeholder="เช่น 0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="herbal_meds" class="block text-sm font-medium text-gray-700 mb-1">ค่ายาสมุนไพรต่อเดือน (บาท)</label><input type="text" id="herbal_meds" inputmode="decimal" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อเดือน</p>
            <p id="monthly_thai" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อปี</p>
            <p id="yearly_thai" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const massageCost = parseFloat((document.getElementById('massage_cost') as HTMLInputElement).value) || 0;
      const massageTimes = parseInt((document.getElementById('massage_times') as HTMLInputElement).value) || 0;
      const acupuncture = parseFloat((document.getElementById('acupuncture') as HTMLInputElement).value) || 0;
      const acupunctureTimes = parseInt((document.getElementById('acupuncture_times') as HTMLInputElement).value) || 0;
      const herbalMeds = parseFloat((document.getElementById('herbal_meds') as HTMLInputElement).value) || 0;

      const monthlyThai = (massageCost * massageTimes) + (acupuncture * acupunctureTimes) + herbalMeds;
      const yearlyThai = monthlyThai * 12;

      (document.getElementById('monthly_thai') as HTMLElement).textContent = monthlyThai.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('yearly_thai') as HTMLElement).textContent = yearlyThai.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('thai-medicine-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
