---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณเบี้ยประกันสุขภาพผู้สูงอายุ 2569 | Senior Health Insurance ฟรี | Calculator Thailand';
const pageDescription = 'คำนวณเบี้ยประกันสุขภาพผู้สูงอายุ 2569 อายุ 60-80 ปี ประมาณการเบี้ยตามอายุ โรคประจำตัว วงเงินคุ้มครอง เพื่อวางแผนค่ารักษาพยาบาลในวัยเกษียณ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณเบี้ยประกันสุขภาพผู้สูงอายุ/`;

const faqData = [
  { question: 'ผู้สูงอายุสามารถซื้อประกันสุขภาพได้ถึงอายุเท่าไร?', answer: 'แต่ละบริษัทแตกต่างกัน บางบริษัทรับสมัครสูงสุดถึงอายุ 70-80 ปี บางบริษัทรับถึง 75 ปี โดยทั่วไปยิ่งซื้อช้าเบี้ยยิ่งแพงและเงื่อนไขยิ่งมาก ควรต่ออายุกรมธรรม์ต่อเนื่องดีที่สุด' },
  { question: 'ประกันสุขภาพผู้สูงอายุแพงกว่าคนหนุ่มสาวมากไหม?', answer: 'ใช่อย่างมาก เบี้ยสำหรับผู้อายุ 70 ปีอาจแพงกว่าอายุ 30 ปีถึง 5-8 เท่า สำหรับวงเงินเดียวกัน เพราะความเสี่ยงด้านสุขภาพและความถี่ในการใช้บริการสูงกว่ามาก' },
  { question: 'ผู้สูงอายุที่มีโรคประจำตัวซื้อประกันได้ไหม?', answer: 'ได้ แต่บริษัทอาจกำหนดเงื่อนไขพิเศษ เช่น ไม่คุ้มครองโรคที่เป็นมาก่อน เบี้ยสูงขึ้น หรือกำหนดวงเงินจำกัดสำหรับบางโรค บางบริษัทมีแผนพิเศษสำหรับผู้มีโรคประจำตัว' },
  { question: 'ผู้สูงอายุควรซื้อประกันสุขภาพวงเงินเท่าไร?', answer: 'แนะนำวงเงินอย่างน้อย 500,000-1,000,000 บาท เนื่องจากค่ารักษาโรคของผู้สูงอายุมักสูงกว่า เช่น โรคหัวใจ มะเร็ง สมองเสื่อม อาจมีค่าใช้จ่ายหลักแสนถึงหลักล้านบาท' },
];

const jsonLdWebApp = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'เครื่องคำนวณเบี้ยประกันสุขภาพผู้สูงอายุ 2569', description: pageDescription, url: canonical, applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' }, inLanguage: 'th' };
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณเบี้ยประกันสุขภาพผู้สูงอายุ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">ประมาณการเบี้ยประกันสุขภาพผู้สูงอายุ</p>
      <p class="mt-1 text-sm text-slate-700">อ้างอิงอัตราตลาดประกันภัยไทยสำหรับอายุ 60-80 ปี</p>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณเบี้ยประกันสุขภาพผู้สูงอายุ 2569 (2026)</h1>
    <p class="text-gray-600 mb-6">ประมาณเบี้ยประกันสุขภาพสำหรับผู้สูงอายุ ตามอายุ สภาพสุขภาพ และวงเงินคุ้มครอง</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูล</h2>
      <form id="calc-form" class="space-y-5">
        <p id="form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">กรุณากรอกข้อมูลให้ครบถ้วน</p>
        <div>
          <label for="age" class="block text-sm font-medium text-gray-700 mb-1">อายุ (ปี)</label>
          <input type="text" id="age" inputmode="numeric" placeholder="เช่น 65" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">รับสมัคร 60-80 ปี</p>
        </div>
        <div>
          <label for="sum-insured" class="block text-sm font-medium text-gray-700 mb-1">วงเงินคุ้มครองต่อปี (บาท)</label>
          <select id="sum-insured" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="300000">300,000 บาท</option>
            <option value="500000" selected>500,000 บาท</option>
            <option value="1000000">1,000,000 บาท</option>
          </select>
        </div>
        <div>
          <label for="health-status" class="block text-sm font-medium text-gray-700 mb-1">สภาพสุขภาพ</label>
          <select id="health-status" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base bg-white">
            <option value="1.0">สุขภาพดี ไม่มีโรคประจำตัว</option>
            <option value="1.3">มีโรคประจำตัวเล็กน้อย (ความดัน คอเลสเตอรอล)</option>
            <option value="1.7">มีโรคประจำตัวปานกลาง (เบาหวาน โรคหัวใจระยะแรก)</option>
          </select>
        </div>
        <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 transition-colors text-base">คำนวณเบี้ยประกัน</button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
      <div class="bg-primary-50 border border-primary-200 rounded-lg p-5 mb-4 text-center">
        <p class="text-sm text-primary-700 mb-1">เบี้ยประกันประมาณการรายปี</p>
        <p class="text-4xl font-bold text-primary-700" id="total-premium">-</p>
        <p class="text-sm text-primary-600 mt-1" id="monthly-premium">-</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <h3 class="px-4 py-3 bg-gray-50 font-semibold text-gray-900 border-b">รายละเอียดการคำนวณ</h3>
        <table class="w-full text-sm"><tbody id="breakdown-body"></tbody></table>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ทำไมผู้สูงอายุต้องการประกันสุขภาพ?</h2>
      <p>ค่ารักษาพยาบาลในวัยสูงอายุมีแนวโน้มสูงขึ้นมากเนื่องจากโรคเรื้อรัง การผ่าตัด และการฟื้นฟู ประกันสุขภาพช่วยให้ผู้สูงอายุเข้าถึงการรักษาที่ดีโดยไม่ต้องพึ่งพาบุตรหลานทั้งหมด และรักษาเงินเกษียณไว้ใช้ยามจำเป็น</p>
    </section>
    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (<details class="bg-white rounded-lg shadow-sm border border-gray-200"><summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary><div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div></details>))}
      </div>
    </section>
    <RelatedCalculators currentHref="/คำนวณเบี้ยประกันสุขภาพผู้สูงอายุ/" />
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800"><strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ เบี้ยจริงขึ้นกับผลการตรวจสุขภาพและบริษัทประกัน</div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH').format(Math.round(n)); }

    // Base premium per 100k sum insured by age
    function getBaseRate(age: number): number {
      if (age < 60) return 0.04;
      if (age < 65) return 0.06;
      if (age < 70) return 0.09;
      if (age < 75) return 0.13;
      return 0.18;
    }

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const age = parseNum((document.getElementById('age') as HTMLInputElement).value);
      const sumInsured = parseFloat((document.getElementById('sum-insured') as HTMLSelectElement).value);
      const healthFactor = parseFloat((document.getElementById('health-status') as HTMLSelectElement).value);
      const err = document.getElementById('form-error')!;
      if (age < 60 || age > 80) { err.textContent = 'กรุณากรอกอายุ 60-80 ปี'; err.classList.remove('hidden'); return; }
      err.classList.add('hidden');

      const baseRate = getBaseRate(age);
      const basePremium = sumInsured * baseRate;
      const total = basePremium * healthFactor;

      const rows = [
        ['วงเงินคุ้มครอง', '', `${fmt(sumInsured)} บาท`],
        ['อัตราเบี้ยตามอายุ', `${(baseRate*100).toFixed(0)}% (อายุ ${age} ปี)`, `${fmt(basePremium)} บาท`],
        ['ตัวคูณสภาพสุขภาพ', `× ${healthFactor}`, `${fmt(total)} บาท`],
        ['เบี้ยรวมประมาณการ/ปี', '', `<strong>${fmt(total)} บาท</strong>`],
      ];

      (document.getElementById('breakdown-body') as HTMLTableSectionElement).innerHTML = rows.map((r, i) => `
        <tr class="${i < rows.length - 1 ? 'border-b border-gray-100' : 'bg-green-50'}">
          <td class="px-4 py-3 text-gray-600">${r[0]}</td><td class="px-4 py-3 text-gray-500 text-xs">${r[1]}</td>
          <td class="px-4 py-3 text-right font-medium text-gray-900">${r[2]}</td></tr>`).join('');

      (document.getElementById('total-premium') as HTMLElement).textContent = fmt(total) + ' บาท/ปี';
      (document.getElementById('monthly-premium') as HTMLElement).textContent = `≈ ${fmt(total/12)} บาท/เดือน`;
      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
