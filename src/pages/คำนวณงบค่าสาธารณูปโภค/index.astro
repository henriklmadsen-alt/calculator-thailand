---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณงบค่าสาธารณูปโภค 2569 | รวมค่าไฟ ค่าน้ำ อินเทอร์เน็ต โทรศัพท์ | Kamnuanlek';
const pageDescription = 'รวมงบค่าไฟ ค่าน้ำ ค่าอินเทอร์เน็ต ค่าโทรศัพท์รายเดือน คำนวณสัดส่วนต่อรายได้และวางแผนลดค่าสาธารณูปโภค';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบค่าสาธารณูปโภค/`;

const faqData = [
  {
    question: 'ค่าไฟต่อเดือนสำหรับอพาร์ตเมนต์คนเดียวควรเท่าไร?',
    answer: 'สำหรับอพาร์ตเมนต์คนเดียวที่ใช้เครื่องปรับอากาศเป็นครั้งคราว ค่าไฟเฉลี่ยอยู่ที่ 500-1,000 บาทต่อเดือน หากใช้แอร์ทุกวัน อาจสูงถึง 1,500-3,000 บาท',
  },
  {
    question: 'ค่าสาธารณูปโภครวมไม่ควรเกินเท่าไรของรายได้?',
    answer: 'แนะนำให้ค่าสาธารณูปโภครวม (ค่าไฟ ค่าน้ำ อินเทอร์เน็ต โทรศัพท์) ไม่เกิน 10-15% ของรายได้สุทธิต่อเดือน',
  },
  {
    question: 'วิธีลดค่าไฟทำอย่างไร?',
    answer: 'ตั้งอุณหภูมิแอร์ที่ 25-26 องศา ปิดเครื่องใช้ไฟฟ้าเมื่อไม่ใช้ เปลี่ยนหลอดไฟเป็น LED ถอดปลั๊กอุปกรณ์ที่ไม่ใช้ และซักผ้าด้วยน้ำเย็นแทนน้ำอุ่น',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบค่าสาธารณูปโภค',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "วิธีคำนวณค่าสาธารณูปโภครายเดือน ปี 2569",
  "description": "ขั้นตอนการคำนวณค่าใช้จ่ายสาธารณูปโภครวมทั้งหมด (ไฟฟ้า, น้ำ, แก๊ส, อินเทอร์เน็ต) เพื่อวางแผนงบประมาณอย่างมีประสิทธิภาพ",
  "step": [
    {
      "@type": "HowToStep",
      "name": "บันทึกใบเรียกเก็บค่าไฟฟ้า",
      "text": "ดูใบเรียกเก็บจาก บปภ. (กฟผ.) รวมค่าไฟฟ้า + ค่าบริการ ตัวอย่าง: ค่าไฟฟ้า 800 บาท + ค่าบริการ 28 บาท = 828 บาท/เดือน"
    },
    {
      "@type": "HowToStep",
      "name": "บันทึกค่าน้ำ แก๊ส และสื่อสาร",
      "text": "ค่าน้ำปกติ 50-200 บาท/เดือน (บ้านทั่วไป), ค่าแก๊ส 100-300 บาท/เดือน, ค่าอินเทอร์เน็ต 250-499 บาท/เดือน, ค่าโทรศัพท์ 50-100 บาท/เดือน ตัวอย่าง: น้ำ 100 + แก๊ส 150 + อินเทอร์เน็ต 299 + โทรศัพท์ 50"
    },
    {
      "@type": "HowToStep",
      "name": "คำนวณรวมค่าสาธารณูปโภค",
      "text": "รวมทั้งหมด = ไฟฟ้า + น้ำ + แก๊ส + อินเทอร์เน็ต + โทรศัพท์ = 828 + 100 + 150 + 299 + 50 = 1,427 บาท/เดือน ≈ 17,124 บาท/ปี"
    }
  ]
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบค่าสาธารณูปโภค">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณงบค่าสาธารณูปโภค 2569</h1>
    <p class="mb-6 text-gray-600">รวมงบค่าไฟ ค่าน้ำ ค่าอินเทอร์เน็ต ค่าโทรศัพท์รายเดือน</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="utility-form" class="space-y-4">
        <div>
          <label for="electricity" class="mb-1 block text-sm font-medium text-gray-700">💡 ค่าไฟฟ้า (บาท/เดือน)</label>
          <input id="electricity" type="text" inputmode="numeric" placeholder="เช่น 800"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="water" class="mb-1 block text-sm font-medium text-gray-700">💧 ค่าน้ำประปา (บาท/เดือน)</label>
          <input id="water" type="text" inputmode="numeric" placeholder="เช่น 150"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="internet" class="mb-1 block text-sm font-medium text-gray-700">🌐 ค่าอินเทอร์เน็ตบ้าน (บาท/เดือน)</label>
          <input id="internet" type="text" inputmode="numeric" placeholder="เช่น 600"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="mobile" class="mb-1 block text-sm font-medium text-gray-700">📱 ค่ามือถือ (บาท/เดือน)</label>
          <input id="mobile" type="text" inputmode="numeric" placeholder="เช่น 399"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="income2" class="mb-1 block text-sm font-medium text-gray-700">รายได้สุทธิต่อเดือน (บาท) — ไม่บังคับ</label>
          <input id="income2" type="text" inputmode="numeric" placeholder="เช่น 25,000"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-64" />
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 rounded-lg bg-primary-50 p-4 text-center">
          <div class="mb-1 text-sm text-gray-600">ค่าสาธารณูปโภครวมต่อเดือน</div>
          <div id="res-total" class="text-4xl font-bold text-primary-700 sm:text-5xl">-</div>
          <div class="mt-1 text-sm text-gray-500">บาท</div>
        </div>
        <div class="space-y-0">
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">💡 ค่าไฟฟ้า</span>
            <span id="res-electricity" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">💧 ค่าน้ำประปา</span>
            <span id="res-water" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🌐 ค่าอินเทอร์เน็ต</span>
            <span id="res-internet" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">📱 ค่ามือถือ</span>
            <span id="res-mobile" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-700">ค่าสาธารณูปโภคต่อปี</span>
            <span id="res-yearly" class="text-sm font-medium text-gray-900">-</span>
          </div>
        </div>
        <div id="income-section" class="mt-4 hidden rounded-lg bg-blue-50 p-3 text-sm text-blue-800">
          <span id="income-ratio-text"></span>
        </div>
      </div>
    </div>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedCalculators currentHref="/คำนวณงบค่าสาธารณูปโภค/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n >= 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('utility-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const electricity = parseNum((document.getElementById('electricity') as HTMLInputElement).value);
    const water = parseNum((document.getElementById('water') as HTMLInputElement).value);
    const internet = parseNum((document.getElementById('internet') as HTMLInputElement).value);
    const mobile = parseNum((document.getElementById('mobile') as HTMLInputElement).value);
    const income = parseNum((document.getElementById('income2') as HTMLInputElement).value);

    const total = electricity + water + internet + mobile;
    const yearly = total * 12;

    document.getElementById('res-total')!.textContent = fmt(total);
    document.getElementById('res-electricity')!.textContent = fmt(electricity);
    document.getElementById('res-water')!.textContent = fmt(water);
    document.getElementById('res-internet')!.textContent = fmt(internet);
    document.getElementById('res-mobile')!.textContent = fmt(mobile);
    document.getElementById('res-yearly')!.textContent = fmt(yearly);

    if (income > 0) {
      const ratio = (total / income) * 100;
      const status = ratio <= 10 ? 'อยู่ในเกณฑ์ดี' : ratio <= 15 ? 'พอรับได้' : 'สูงกว่าที่แนะนำ ควรพิจารณาลดค่าใช้จ่าย';
      document.getElementById('income-ratio-text')!.textContent = `ค่าสาธารณูปโภคคิดเป็น ${ratio.toFixed(1)}% ของรายได้ — ${status}`;
      document.getElementById('income-section')!.classList.remove('hidden');
    }

    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
