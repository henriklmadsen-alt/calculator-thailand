---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณผ่อนมอเตอร์ไซค์ 2569 | ฟรี รู้ค่างวดทันที | Calculator Thailand';
const pageDescription = 'คำนวณค่างวดมอเตอร์ไซค์ เงินดาวน์ ดอกเบี้ย flat rate ปี 2569 ฟรี ใช้งานง่าย เห็นยอดผ่อนต่อเดือนและดอกเบี้ยรวมทันที';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณผ่อนมอเตอร์ไซค์/`;

const faqData = [
  {
    question: 'ดอกเบี้ยผ่อนมอเตอร์ไซค์ในไทยปี 2569 กี่เปอร์เซ็นต์?',
    answer: 'ดอกเบี้ยสินเชื่อมอเตอร์ไซค์ใหม่ในไทยปี 2569 อยู่ที่ประมาณ 1.25-3% ต่อปี (flat rate) สำหรับรถใหม่ และ 3-6% สำหรับรถมือสอง ขึ้นอยู่กับยี่ห้อ รุ่น และเครดิตของผู้กู้',
  },
  {
    question: 'เงินดาวน์มอเตอร์ไซค์ควรจ่ายเท่าไร?',
    answer: 'เงินดาวน์มอเตอร์ไซค์ขั้นต่ำอยู่ที่ประมาณ 10-15% ของราคารถ บางรุ่นหรือแคมเปญพิเศษอาจดาวน์ 0% ได้ แนะนำให้ดาวน์ 15-25% เพื่อลดค่างวดและดอกเบี้ยรวม',
  },
  {
    question: 'ผ่อนมอเตอร์ไซค์กี่ปีดีที่สุด?',
    answer: 'สินเชื่อมอเตอร์ไซค์ผ่อนได้ 1-5 ปี (12-60 งวด) รุ่นเล็กนิยมผ่อน 2-3 ปี รุ่นใหญ่ (Big Bike) ผ่อนได้สูงสุด 5 ปี ผ่อนสั้นจ่ายดอกเบี้ยน้อย แต่ค่างวดสูงกว่า เลือกระยะเวลาที่ค่างวดไม่เกิน 20% ของรายได้',
  },
  {
    question: 'ผ่อนมอเตอร์ไซค์กับผ่อนรถยนต์ต่างกันอย่างไร?',
    answer: 'ทั้งคู่ใช้ดอกเบี้ย flat rate เหมือนกัน แต่มอเตอร์ไซค์ราคาถูกกว่า ระยะผ่อนสั้นกว่า (สูงสุด 5 ปี vs 7 ปี) เงินดาวน์ขั้นต่ำต่ำกว่า และดอกเบี้ยอาจสูงกว่ารถยนต์เล็กน้อย',
  },
  {
    question: 'ค่างวดมอเตอร์ไซค์ไม่ควรเกินเท่าไร?',
    answer: 'ค่างวดมอเตอร์ไซค์ไม่ควรเกิน 15-20% ของรายได้ต่อเดือน และภาระหนี้ทั้งหมดรวมกันไม่ควรเกิน 40% ของรายได้ เพื่อให้มีเงินเหลือใช้จ่ายและออมเพียงพอ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผ่อนมอเตอร์ไซค์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผ่อนมอเตอร์ไซค์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก และใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณผ่อนมอเตอร์ไซค์ — ค่างวด เงินดาวน์ ดอกเบี้ย
    </h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าผ่อนมอเตอร์ไซค์รายเดือน เงินดาวน์ ดอกเบี้ยรวม ด้วยอัตราดอกเบี้ยแบบคงที่ (flat rate) ที่ใช้กับสินเชื่อมอเตอร์ไซค์ในไทย รองรับทั้งรถจักรยานยนต์ทั่วไปและ Big Bike
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="moto-form" class="space-y-5">
        <p id="moto-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรอกข้อมูลให้ครบก่อนคำนวณ
        </p>
        <div>
          <label for="moto-price" class="block text-sm font-medium text-gray-700 mb-1">
            ราคามอเตอร์ไซค์ (บาท)
          </label>
          <input
            type="text"
            id="moto-price"
            inputmode="numeric"
            placeholder="เช่น 65,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
          <p id="moto-price-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="moto-down" class="block text-sm font-medium text-gray-700 mb-1">
              เงินดาวน์ (%)
            </label>
            <input
              type="text"
              id="moto-down"
              inputmode="decimal"
              placeholder="เช่น 15"
              value="15"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
          <div>
            <label for="moto-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราดอกเบี้ย (% ต่อปี)
            </label>
            <input
              type="text"
              id="moto-rate"
              inputmode="decimal"
              placeholder="เช่น 1.75"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p class="mt-1 text-xs text-gray-500">ใส่อัตราแบบ flat rate ตามไฟแนนซ์มอเตอร์ไซค์ไทย</p>
            <p id="moto-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="moto-term" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาผ่อน (ปี)
            </label>
            <select
              id="moto-term"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white"
            >
              <option value="1">1 ปี (12 งวด)</option>
              <option value="2">2 ปี (24 งวด)</option>
              <option value="3" selected>3 ปี (36 งวด)</option>
              <option value="4">4 ปี (48 งวด)</option>
              <option value="5">5 ปี (60 งวด)</option>
            </select>
          </div>
        </div>

        <!-- Down payment amount display -->
        <div id="moto-down-display" class="text-sm text-gray-500 hidden">
          เงินดาวน์: <span id="moto-down-text" class="font-medium text-gray-700"></span> บาท | ยอดจัด: <span id="moto-finance-text" class="font-medium text-gray-700"></span> บาท
        </div>

        <button
          type="submit"
          id="moto-submit-btn"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณทันที
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <!-- Summary Cards -->
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่างวดต่อเดือน</div>
            <div id="res-monthly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">เงินดาวน์</div>
            <div id="res-down" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ดอกเบี้ยรวม</div>
            <div id="res-interest" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ค่าใช้จ่ายทั้งหมด</div>
            <div id="res-total-cost" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>

        <!-- Summary Details -->
        <div class="space-y-2 text-sm mb-6">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ราคามอเตอร์ไซค์</span>
            <span id="res-moto-price" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">เงินดาวน์</span>
            <span id="res-down-detail" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ยอดจัดไฟแนนซ์</span>
            <span id="res-finance" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">อัตราดอกเบี้ย (flat rate)</span>
            <span id="res-rate" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">จำนวนงวด</span>
            <span id="res-term" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ยอดผ่อนรวม (เงินต้น+ดอกเบี้ย)</span>
            <span id="res-total-paid" class="font-medium">-</span>
          </div>
        </div>

        <!-- Amortization Schedule -->
        <details class="mt-4">
          <summary class="cursor-pointer font-semibold text-gray-900 hover:text-primary-600 mb-2">
            ตารางผ่อนชำระ (คลิกเพื่อดู)
          </summary>
          <div class="overflow-x-auto mt-2">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-gray-500 border-b border-gray-200">
                  <th class="py-2 pr-2">งวดที่</th>
                  <th class="py-2 pr-2 text-right">ค่างวด</th>
                  <th class="py-2 pr-2 text-right">เงินต้น</th>
                  <th class="py-2 pr-2 text-right">ดอกเบี้ย</th>
                  <th class="py-2 text-right">ยอดคงเหลือ</th>
                </tr>
              </thead>
              <tbody id="schedule-body"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
    <div id="moto-next-action" class="hidden mb-6 rounded-xl border border-primary-200 bg-primary-50 p-4">
      <p class="text-sm font-semibold text-primary-800">ทำต่อ: คำนวณค่าภาษีรถและประกัน</p>
      <p class="mt-1 text-sm text-primary-700">อย่าลืมรวมค่าภาษี พ.ร.บ. และประกันภัยในการวางแผนค่าใช้จ่ายรถ</p>
      <div class="mt-3 flex flex-wrap gap-3">
        <a data-next-action-link href="/คำนวณค่าภาษีรถยนต์/" class="inline-flex min-h-11 items-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-700">ทำต่อ: คำนวณค่าภาษีรถ+พ.ร.บ.</a>
        <a data-next-action-link href="/คำนวณผ่อนรถ/" class="inline-flex min-h-11 items-center rounded-lg border border-primary-300 bg-white px-4 py-2 text-sm font-semibold text-primary-700 hover:border-primary-400">เทียบ: คำนวณผ่อนรถยนต์</a>
      </div>
    </div>
    <GuardedAdSlot
      templateType="calculator"
      slotId="C1"
      revealAfterSelector="#results"
    />
    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณค่าผ่อนมอเตอร์ไซค์</h2>

      <p>
        มอเตอร์ไซค์เป็นพาหนะยอดนิยมในไทย เครื่องคำนวณผ่อนมอเตอร์ไซค์นี้ช่วยให้คุณวางแผนค่าใช้จ่ายก่อนตัดสินใจ
        รองรับทั้งมอเตอร์ไซค์ทั่วไป (เช่น Honda Wave, Yamaha Fino) และ Big Bike คำนวณด้วยอัตราดอกเบี้ยแบบคงที่ (flat rate)
        ซึ่งเป็นวิธีที่ไฟแนนซ์มอเตอร์ไซค์ในไทยใช้เป็นมาตรฐาน
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณค่างวดมอเตอร์ไซค์</h3>

      <p>
        สินเชื่อมอเตอร์ไซค์ในไทยใช้ดอกเบี้ยแบบ flat rate เช่นเดียวกับรถยนต์:
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>ยอดจัดไฟแนนซ์</strong> = ราคามอเตอร์ไซค์ - เงินดาวน์</li>
        <li><strong>ดอกเบี้ยรวม</strong> = ยอดจัด x อัตราดอกเบี้ย x จำนวนปี</li>
        <li><strong>ค่างวด</strong> = (ยอดจัด + ดอกเบี้ยรวม) / จำนวนงวด</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตัวอย่างการคำนวณ</h3>

      <p>
        ซื้อมอเตอร์ไซค์ราคา 65,000 บาท ดาวน์ 15% ดอกเบี้ย 1.75% ผ่อน 3 ปี:
      </p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>เงินดาวน์: 65,000 x 15% = <strong>9,750 บาท</strong></li>
        <li>ยอดจัด: 65,000 - 9,750 = <strong>55,250 บาท</strong></li>
        <li>ดอกเบี้ยรวม: 55,250 x 1.75% x 3 = <strong>2,900.63 บาท</strong></li>
        <li>ยอดผ่อนรวม: 55,250 + 2,900.63 = <strong>58,150.63 บาท</strong></li>
        <li>ค่างวด: 58,150.63 / 36 = <strong>1,615.29 บาท/เดือน</strong></li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">อัตราดอกเบี้ยมอเตอร์ไซค์ในไทย 2569</h3>

      <p>อัตราดอกเบี้ย flat rate เฉลี่ยในไทยปี 2569:</p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>มอเตอร์ไซค์ใหม่ (รุ่นเล็ก):</strong> 1.25-2.5% ต่อปี</li>
        <li><strong>มอเตอร์ไซค์ใหม่ (Big Bike):</strong> 2-4% ต่อปี</li>
        <li><strong>มอเตอร์ไซค์มือสอง:</strong> 3-6% ต่อปี</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">เคล็ดลับการผ่อนมอเตอร์ไซค์</h3>

      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ค่างวดมอเตอร์ไซค์ไม่ควรเกิน 15-20% ของรายได้</li>
        <li>ดาวน์ 15% ขึ้นไปช่วยลดภาระดอกเบี้ยได้มาก</li>
        <li>เปรียบเทียบข้อเสนอจากหลายไฟแนนซ์ก่อนตัดสินใจ</li>
        <li>อย่าลืมรวมค่า พ.ร.บ. ประกันภัย และค่าบำรุงรักษาในการวางแผน</li>
        <li>หากผ่อนไหว แนะนำผ่อนสั้น 2-3 ปี ประหยัดดอกเบี้ยมากกว่า</li>
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <RelatedArticles currentHref="/คำนวณผ่อนมอเตอร์ไซค์/" />
    <RelatedCalculators currentHref="/คำนวณผ่อนมอเตอร์ไซค์/" />

    <!-- Disclaimer -->
    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      ค่างวดจริงอาจแตกต่างตามเงื่อนไขของสถาบันการเงินและไฟแนนซ์ ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function hasInvalidNumber(v: string): boolean {
      const normalized = v.replace(/,/g, '').trim();
      return normalized !== '' && Number.isNaN(Number(normalized));
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    const form = document.getElementById('moto-form') as HTMLFormElement;
    const submitBtn = document.getElementById('moto-submit-btn') as HTMLButtonElement;
    const formError = document.getElementById('moto-form-error') as HTMLElement;
    const nextActionCard = document.getElementById('moto-next-action') as HTMLElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;
    const priceInput = document.getElementById('moto-price') as HTMLInputElement;
    const downInput = document.getElementById('moto-down') as HTMLInputElement;
    const rateInput = document.getElementById('moto-rate') as HTMLInputElement;
    let hasTrackedStart = false;

    function setFieldError(elementId: string, message: string) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearFieldError(elementId: string) {
      const el = document.getElementById(elementId);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      clearFieldError('moto-price-error');
      clearFieldError('moto-rate-error');
      formError.classList.add('hidden');
    }

    function updateSubmitState() {
      const ready = parseNum(priceInput.value) > 0 && parseNum(rateInput.value) > 0;
      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณทันที' : 'กรอกข้อมูลให้ครบ';
      submitBtn.classList.toggle('opacity-70', !ready);
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
    }

    // Live preview of down payment amount
    function updateDownPreview() {
      const price = parseNum(priceInput.value);
      const pct = parseFloat(downInput.value) || 0;
      const display = document.getElementById('moto-down-display') as HTMLElement;
      if (price > 0 && pct > 0) {
        const down = price * pct / 100;
        const finance = price - down;
        (document.getElementById('moto-down-text') as HTMLElement).textContent = fmt(down);
        (document.getElementById('moto-finance-text') as HTMLElement).textContent = fmt(finance);
        display.classList.remove('hidden');
      } else {
        display.classList.add('hidden');
      }
    }

    priceInput.addEventListener('input', updateDownPreview);
    downInput.addEventListener('input', updateDownPreview);
    priceInput.addEventListener('input', () => {
      clearFieldError('moto-price-error');
      formError.classList.add('hidden');
      updateSubmitState();
    });
    rateInput.addEventListener('input', () => {
      clearFieldError('moto-rate-error');
      formError.classList.add('hidden');
      updateSubmitState();
    });
    updateSubmitState();

    form.addEventListener('input', () => {
      if (!hasTrackedStart) {
        trackCalculatorStart('motorcycle');
        hasTrackedStart = true;
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearValidation();

      const motoPrice = parseNum(priceInput.value);
      const downPct = parseFloat(downInput.value) || 0;
      const annualRate = parseFloat(rateInput.value.replace(/,/g, '')) || 0;
      const termYears = parseInt((document.getElementById('moto-term') as HTMLSelectElement).value) || 3;
      const termMonths = termYears * 12;

      if (hasInvalidNumber(priceInput.value) || hasInvalidNumber(rateInput.value)) {
        formError.classList.remove('hidden');
        if (hasInvalidNumber(priceInput.value)) {
          setFieldError('moto-price-error', 'รูปแบบข้อมูลไม่ถูกต้อง');
          priceInput.focus();
        }
        if (hasInvalidNumber(rateInput.value)) {
          setFieldError('moto-rate-error', 'รูปแบบข้อมูลไม่ถูกต้อง');
          if (!hasInvalidNumber(priceInput.value)) {
            rateInput.focus();
          }
        }
        updateSubmitState();
        return;
      }

      if (motoPrice <= 0) {
        formError.classList.remove('hidden');
        setFieldError('moto-price-error', 'กรุณากรอกจำนวนเงินมากกว่า 0');
        priceInput.focus();
        updateSubmitState();
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      if (!hasTrackedStart) {
        trackCalculatorStart('motorcycle');
        hasTrackedStart = true;
      }

      const downPayment = motoPrice * (downPct / 100);
      const financeAmount = motoPrice - downPayment;
      const totalInterest = financeAmount * (annualRate / 100) * termYears;
      const totalPaid = financeAmount + totalInterest;
      const monthlyPayment = termMonths > 0 ? totalPaid / termMonths : 0;
      const totalCost = downPayment + totalPaid;

      // Update summary
      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthlyPayment) + ' บาท';
      (document.getElementById('res-down') as HTMLElement).textContent = fmt(downPayment) + ' บาท';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total-cost') as HTMLElement).textContent = fmt(totalCost) + ' บาท';
      (document.getElementById('res-moto-price') as HTMLElement).textContent = fmt(motoPrice) + ' บาท';
      (document.getElementById('res-down-detail') as HTMLElement).textContent = fmt(downPayment) + ' บาท (' + downPct.toFixed(0) + '%)';
      (document.getElementById('res-finance') as HTMLElement).textContent = fmt(financeAmount) + ' บาท';
      (document.getElementById('res-rate') as HTMLElement).textContent = annualRate.toFixed(2) + '% ต่อปี';
      (document.getElementById('res-term') as HTMLElement).textContent = termMonths + ' งวด (' + termYears + ' ปี)';
      (document.getElementById('res-total-paid') as HTMLElement).textContent = fmt(totalPaid) + ' บาท';

      // Amortization table
      const monthlyPrincipal = financeAmount / termMonths;
      const monthlyInterest = totalInterest / termMonths;
      const tbody = document.getElementById('schedule-body') as HTMLTableSectionElement;
      tbody.innerHTML = '';

      let balance = financeAmount;
      for (let m = 1; m <= termMonths; m++) {
        balance = Math.max(0, balance - monthlyPrincipal);
        const show = m <= 12 || m % 12 === 0 || m === termMonths;
        if (!show) continue;

        if (m > 13 && (m - 1) % 12 !== 0) {
          const sep = document.createElement('tr');
          sep.innerHTML = '<td colspan="5" class="py-1 text-center text-gray-400 text-xs">⋮</td>';
          tbody.appendChild(sep);
        }

        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';
        tr.innerHTML = `
          <td class="py-2 pr-2 text-gray-600">${m}</td>
          <td class="py-2 pr-2 text-right">${fmt(monthlyPayment)}</td>
          <td class="py-2 pr-2 text-right">${fmt(monthlyPrincipal)}</td>
          <td class="py-2 pr-2 text-right">${fmt(monthlyInterest)}</td>
          <td class="py-2 text-right">${fmt(balance)}</td>
        `;
        tbody.appendChild(tr);
      }

      resultsDiv.classList.remove('hidden');
      nextActionCard.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณทันที';
      trackCalculatorComplete('motorcycle');
      trackCalculatorUsed('motorcycle');
    });

    document.querySelectorAll('[data-next-action-link]').forEach((link) => {
      link.addEventListener('click', () => {
        if (typeof window.gtag === 'function') {
          const href = (link as HTMLAnchorElement).getAttribute('href') || '';
          window.gtag('event', 'next_action_click', {
            calculator: 'motorcycle',
            target_href: href,
          });
        }
      });
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('motorcycle');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
