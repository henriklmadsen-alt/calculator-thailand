---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าตรวจมะเร็ง | Kamnuanlek';
const pageDescription = 'คำนวณค่าตรวจคัดกรองมะเร็ง มะเร็งเต้านม มะเร็งปากมดลูก มะเร็งลำไส้ ตามอัตราไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0415-ค่าตรวจมะเร็ง/`;

const faqData = [
  { question: 'ตรวจมะเร็งเต้านมราคาเท่าไหร่?', answer: 'Mammogram ราคา 1,500-4,000 บาท อัลตราซาวด์เต้านม 800-2,000 บาท MRI เต้านม 8,000-20,000 บาท ควรตรวจหลังอายุ 40 ปีทุก 1-2 ปี' },
  { question: 'ตรวจมะเร็งปากมดลูกราคาเท่าไหร่?', answer: 'Pap Smear 300-800 บาท HPV DNA Test 1,500-3,000 บาท Colposcopy 2,000-5,000 บาท บัตรทองให้ Pap Smear ฟรีทุก 5 ปีสำหรับผู้หญิงอายุ 30-60 ปี' },
  { question: 'ตรวจมะเร็งลำไส้ใหญ่ราคาเท่าไหร่?', answer: 'Colonoscopy ราคา 8,000-20,000 บาท ตรวจเลือดในอุจจาระ (FOBT) 500-1,500 บาท แนะนำตรวจเมื่ออายุ 45-50 ปีขึ้นไป หรือมีประวัติครอบครัว' },
  { question: 'ตรวจเลือดหามะเร็งได้ไหม?', answer: 'Tumor Markers ในเลือด เช่น PSA, CEA, CA125 ราคา 500-2,000 บาทต่อตัว แต่ความแม่นยำอาจไม่สูง ควรใช้ร่วมกับการตรวจอื่น' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าตรวจมะเร็ง">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าตรวจคัดกรองมะเร็ง</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">ประมาณการค่าตรวจคัดกรองมะเร็งตามประเภทที่เลือก</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="mammogram" class="block text-sm font-medium text-gray-700 mb-1">Mammogram ตรวจเต้านม (บาท)</label><input type="text" id="mammogram" inputmode="decimal" placeholder="เช่น 2500" value="2500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="pap_smear" class="block text-sm font-medium text-gray-700 mb-1">Pap Smear มะเร็งปากมดลูก (บาท)</label><input type="text" id="pap_smear" inputmode="decimal" placeholder="เช่น 600" value="600" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="colonoscopy" class="block text-sm font-medium text-gray-700 mb-1">Colonoscopy มะเร็งลำไส้ (บาท)</label><input type="text" id="colonoscopy" inputmode="decimal" placeholder="เช่น 0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="tumor_marker" class="block text-sm font-medium text-gray-700 mb-1">Tumor Markers เลือด (บาท)</label><input type="text" id="tumor_marker" inputmode="decimal" placeholder="เช่น 1500" value="1500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าตรวจทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">เฉลี่ยต่อปี (ตรวจทุก 2 ปี)</p>
            <p id="per_year" class="font-bold">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const mammogram = parseFloat((document.getElementById('mammogram') as HTMLInputElement).value) || 0;
      const papSmear = parseFloat((document.getElementById('pap_smear') as HTMLInputElement).value) || 0;
      const colonoscopy = parseFloat((document.getElementById('colonoscopy') as HTMLInputElement).value) || 0;
      const tumorMarker = parseFloat((document.getElementById('tumor_marker') as HTMLInputElement).value) || 0;

      const total = mammogram + papSmear + colonoscopy + tumorMarker;
      const perYear = total / 2;

      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('per_year') as HTMLElement).textContent = perYear.toLocaleString('th-TH') + ' บาท/ปี';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('cancer-screening-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
