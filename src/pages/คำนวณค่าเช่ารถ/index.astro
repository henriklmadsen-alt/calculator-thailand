---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณค่าเช่ารถ รวมค่าใช้จ่าย 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณค่าเช่ารถยนต์ 2569 ฟรี — รวมค่าประกัน น้ำมัน GPS ค่าคืนช้า รู้ต้นทุนจริงก่อนเช่า';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าเช่ารถ/`;

const faqData = [
  {
    question: 'ค่าเช่ารถประกอบด้วยอะไรบ้าง?',
    answer: 'ค่าเช่ารถประกอบด้วย: (1) ค่าเช่าพื้นฐาน (2) ค่าประกันรถ (ถ้ามี) (3) ค่า GPS/นำทาง (4) ค่าเชื้อเพลิง (โดยปกติคิดเองตามการใช้) (5) ค่าปรับคืนรถช้า',
  },
  {
    question: 'ค่าประกันรถมีกี่ประเภท?',
    answer: 'ค่าประกันรถปกติมี 2 ประเภท: (1) Basic Insurance - ประมาณ 250 บาท/วัน ครอบคลุมความเสียหายหลัก (2) Premium Insurance - ประมาณ 450 บาท/วัน ครอบคลุมทั้งหมดมีการหักลดหย่อมน้อยกว่า',
  },
  {
    question: 'ค่าเชื้อเพลิงคิดอย่างไร?',
    answer: 'โดยปกติค่าเชื้อเพลิงคิดตามการใช้งานจริง บริษัทเช่ารถจะเก็บรถที่มีเชื้อเพลิงเต็มแล้ว คุณต้องคืนรถเต็มเช่นกัน หรือจะต้องชำระค่าเชื้อเพลิงที่ขาดหาย',
  },
  {
    question: 'มีค่าปรับสำหรับคืนรถช้าหรือไม่?',
    answer: 'ใช่ โดยปกติคิดเป็น 300-500 บาท/ชั่วโมง หรือ 50% ของค่าเช่ารายวันสำหรับการคืนที่ช้า',
  },
  {
    question: 'ต้องมีใบขับขี่สัญชาติไทยหรือ?',
    answer: 'โดยปกติบริษัทเช่ารถต้องการใบขับขี่ที่ยังใช้ได้ สำหรับนักท่องเที่ยวต่างชาติ ใบขับขี่สัญชาติของตนเองหรือ International Driving Permit (IDP) ก็สามารถใช้ได้',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าเช่ารถ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเช่ารถ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">
      คำนวณค่าเช่ารถ
    </h1>

    <div class="mb-4 inline-block rounded-lg border border-blue-200 bg-blue-50 px-3 py-2">
      <p class="text-xs font-semibold text-blue-800">[ปี 2569 — อัปเดต]</p>
    </div>

    <p class="text-gray-600 mb-6">
      คำนวณค่าเช่ารถ ค่าประกัน ค่าเชื้อเพลิง ค่า GPS และค่าบริการเพิ่มเติม ออนไลน์ฟรี
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="carType" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทรถ
          </label>
          <select
            id="carType"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          >
            <option value="economy">รถเก๋ง Economy (เช่น Toyota Vios)</option>
            <option value="sedan">รถเก๋ง Sedan (เช่น Honda Accord)</option>
            <option value="suv">รถ SUV/MPV (เช่น Honda CRV)</option>
            <option value="van">รถตู้/Van (เช่น Toyota Commuter)</option>
          </select>
        </div>
        <div>
          <label for="dailyRate" class="block text-sm font-medium text-gray-700 mb-1">
            ค่าเช่ารายวัน (บาท)
          </label>
          <input
            type="text"
            id="dailyRate"
            inputmode="decimal"
            placeholder="เช่น 1200"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="days" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนวัน
          </label>
          <input
            type="number"
            id="days"
            min="1"
            max="30"
            value="1"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          />
        </div>
        <div>
          <label for="fuelType" class="block text-sm font-medium text-gray-700 mb-1">
            ประเภทเชื้อเพลิง
          </label>
          <select
            id="fuelType"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
          >
            <option value="petrol">แกโซลีน (Petrol)</option>
            <option value="diesel">ดีเซล (Diesel)</option>
          </select>
        </div>
      </div>

      <div class="mb-6">
        <label for="insurance" class="block text-sm font-medium text-gray-700 mb-3">
          ประเภทประกัน
        </label>
        <select
          id="insurance"
          class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
        >
          <option value="none">ไม่มีประกัน</option>
          <option value="basic">ประกันพื้นฐาน (250 บาท/วัน)</option>
          <option value="premium">ประกันฉบับสมบูรณ์ (450 บาท/วัน)</option>
        </select>
      </div>

      <div class="mb-6 space-y-2">
        <label class="flex items-center">
          <input
            type="checkbox"
            id="includeGPS"
            class="w-4 h-4 border-gray-300 rounded focus:ring-2 focus:ring-primary-500"
          />
          <span class="ml-2 text-sm text-gray-700">เพิ่มระบบ GPS/นำทาง (250 บาท)</span>
        </label>
        <label class="flex items-center">
          <input
            type="checkbox"
            id="lateReturn"
            class="w-4 h-4 border-gray-300 rounded focus:ring-2 focus:ring-primary-500"
          />
          <span class="ml-2 text-sm text-gray-700">มีค่าปรับคืนรถช้า</span>
        </label>
      </div>

      <button
        type="button"
        id="btn-calculate"
        class="w-full sm:w-auto px-6 py-2 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
      >
        คำนวณค่าเช่า
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6">
        <div class="mb-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
          <h3 class="font-semibold text-gray-900 mb-4">สรุปค่าเช่ารถ</h3>

          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าเช่าพื้นฐาน</span>
              <span id="fee-rental" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าประกันรถ (ถ้ามี)</span>
              <span id="fee-insurance" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าระบบ GPS (ถ้ามี)</span>
              <span id="fee-gps" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าเชื้อเพลิง (ประมาณ)</span>
              <span id="fee-fuel" class="font-medium text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-700">ค่าปรับคืนรถช้า (ถ้ามี)</span>
              <span id="fee-late" class="font-medium text-gray-900">-</span>
            </div>
          </div>

          <div class="border-t border-blue-300 my-3"></div>

          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-sm font-medium text-gray-700">รวมก่อน VAT</span>
              <span id="subtotal" class="font-semibold text-gray-900">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm font-medium text-gray-700">ภาษี VAT 7%</span>
              <span id="vat-amount" class="font-semibold text-gray-900">-</span>
            </div>
          </div>

          <div class="border-t-2 border-blue-400 my-3"></div>

          <div class="flex justify-between">
            <span class="text-base font-bold text-gray-900">รวมค่าเช่าทั้งหมด</span>
            <span id="total" class="text-2xl font-bold text-primary-600">-</span>
          </div>
        </div>

        <!-- Note -->
        <div class="bg-yellow-50 rounded-lg p-4 border border-yellow-200">
          <p class="text-sm text-gray-700">
            <strong>หมายเหตุ:</strong> ค่าเช่าข้างต้นเป็นการประมาณตามอัตราทั่วไป ค่าเชื้อเพลิงคิดจากการใช้ 200 กม./วัน อาจแตกต่างตามสถานการณ์จริง
            โปรดตรวจสอบกับบริษัทเช่ารถเพื่อยืนยันราคาที่แน่นอน
          </p>
        </div>
      </div>
    </div>

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ค่าเช่ารถประกอบด้วยอะไรบ้าง?</h2>
      <p>ค่าเช่ารถ (Total Car Rental Cost) ประกอบด้วยค่าต่างๆ หลากหลาย นอกเหนือจากค่าเช่าพื้นฐาน</p>

      <h3>1. ค่าเช่าพื้นฐาน (Daily Rate)</h3>
      <p>เป็นค่าเช่ารายวันที่บริษัทเช่ารถกำหนด ซึ่งแตกต่างกันตามประเภทรถและช่วงเวลาการเช่า</p>

      <h3>2. ค่าประกันรถ (Car Insurance)</h3>
      <p>ประกันพื้นฐาน (Basic) ประมาณ 250 บาท/วัน คุ้มครองความเสียหายหลัก หรือประกันแบบสมบูรณ์ (Premium) ประมาณ 450 บาท/วัน คุ้มครองทั้งหมด</p>

      <h3>3. ค่า GPS/ระบบนำทาง (GPS Navigation)</h3>
      <p>บริษัทเช่ารถหลายแห่งให้เช่าระบบ GPS เพิ่มเติมจากค่าเช่าปกติ ประมาณ 250 บาท</p>

      <h3>4. ค่าเชื้อเพลิง (Fuel Cost)</h3>
      <p>โดยปกติการเช่ารถจะเก็บรถที่เต็มแล้ว คุณต้องคืนรถเต็มเช่นกัน หรือต้องชำระค่าเชื้อเพลิงที่ขาดหาย</p>

      <h3>5. ค่าปรับคืนรถช้า (Late Return Fee)</h3>
      <p>หากคืนรถนอกเวลาที่ตกลงกัน จะมีค่าปรับประมาณ 300-500 บาท/ชั่วโมง</p>
    </section>

    <!-- FAQ Section -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((item) => (
          <div class="border border-gray-200 rounded-lg p-4 hover:border-gray-300 transition-colors">
            <h3 class="font-semibold text-gray-900 mb-2">{item.question}</h3>
            <p class="text-gray-600 text-sm">{item.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Trust Panel -->
    <section class="bg-gray-50 rounded-lg p-4 sm:p-6 mb-8 border border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">📌 แหล่งข้อมูลอ้างอิง</h2>
      <ul class="text-sm text-gray-700 space-y-2">
        <li>• สมาคมเช่ารถยนต์ของไทย (Thai Car Rental Association)</li>
        <li>• กระทรวงคมนาคม — ระเบียบการเช่าโรงแรมรถยนต์</li>
        <li>• สมาคมประกันภัยไทย (Insurance Association of Thailand)</li>
        <li>• กรมสรรพากร — อัตราภาษี VAT บริการเช่ารถ</li>
      </ul>
    </section>
  </article>
</BaseLayout>

<script>
  import { calculateCarRental } from '../../lib/car-rental-cost-calculator';

  const btnCalculate = document.getElementById('btn-calculate');
  const carTypeSelect = document.getElementById('carType');
  const dailyRateInput = document.getElementById('dailyRate');
  const daysInput = document.getElementById('days');
  const fuelTypeSelect = document.getElementById('fuelType');
  const insuranceSelect = document.getElementById('insurance');
  const includeGPSCheckbox = document.getElementById('includeGPS');
  const lateReturnCheckbox = document.getElementById('lateReturn');
  const resultDiv = document.getElementById('result');

  function formatCurrency(value: number): string {
    return new Intl.NumberFormat('th-TH', {
      style: 'currency',
      currency: 'THB',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(value);
  }

  function handleCalculate() {
    const dailyRateStr = dailyRateInput.value.replace(/,/g, '');
    const dailyRate = parseFloat(dailyRateStr);
    const days = parseInt(daysInput.value);

    if (!dailyRate || dailyRate <= 0 || isNaN(dailyRate)) {
      alert('โปรดระบุค่าเช่ารายวันที่ถูกต้อง');
      return;
    }

    if (!days || days < 1) {
      alert('โปรดระบุจำนวนวันที่ถูกต้อง');
      return;
    }

    const result = calculateCarRental({
      carType: carTypeSelect.value as any,
      dailyRate: dailyRate,
      rentalDays: days,
      insuranceType: insuranceSelect.value as any,
      fuelType: fuelTypeSelect.value as any,
      includingGPS: includeGPSCheckbox.checked,
      lateReturn: lateReturnCheckbox.checked,
    });

    // Update UI
    document.getElementById('fee-rental').textContent = formatCurrency(result.rentalCost);
    document.getElementById('fee-insurance').textContent = formatCurrency(result.insuranceCost);
    document.getElementById('fee-gps').textContent = formatCurrency(result.gpsCost);
    document.getElementById('fee-fuel').textContent = formatCurrency(result.fuelCost);
    document.getElementById('fee-late').textContent = formatCurrency(result.lateReturnFee);
    document.getElementById('subtotal').textContent = formatCurrency(result.subtotal);
    document.getElementById('vat-amount').textContent = formatCurrency(result.vat);
    document.getElementById('total').textContent = formatCurrency(result.total);

    resultDiv.classList.remove('hidden');
  }

  btnCalculate.addEventListener('click', handleCalculate);

  // Allow Enter key to calculate
  dailyRateInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleCalculate();
  });
</script>
