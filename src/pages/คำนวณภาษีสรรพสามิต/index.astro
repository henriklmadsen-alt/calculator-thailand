---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณภาษีสรรพสามิต 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณภาษีสรรพสามิต 2569 ฟรี — สุรา บุหรี่ น้ำมัน น้ำหวาน รถยนต์ รู้ยอดภาษีตามอัตรากรมสรรพสามิตล่าสุด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีสรรพสามิต/`;

const faqData = [
  {
    question: 'ภาษีสรรพสามิตคืออะไร?',
    answer: 'ภาษีสรรพสามิตเป็นภาษีที่กรมสรรพสามิตจัดเก็บจากสินค้าและบริการบางประเภทที่อาจส่งผลกระทบต่อสังคมหรือสิ่งแวดล้อม เช่น สุรา บุหรี่ น้ำมัน รถยนต์ เครื่องดื่มรสหวาน เพื่อลดการบริโภคสินค้าเหล่านี้และหารายได้ให้รัฐ',
  },
  {
    question: 'ภาษีสรรพสามิตสุราคำนวณอย่างไร?',
    answer: 'ภาษีสรรพสามิตสุราคำนวณตามปริมาณแอลกอฮอล์และราคาขายปลีก โดยใช้อัตราตามตาราง เช่น เบียร์ 155 บาท/ลิตรของแอลกอฮอล์บริสุทธิ์ หรือคิดจากราคาขายในอัตรา % แล้วแต่อย่างใดสูงกว่า',
  },
  {
    question: 'ภาษีสรรพสามิตรถยนต์คิดอย่างไร?',
    answer: 'รถยนต์นั่งส่วนบุคคลเสียภาษีสรรพสามิตตามปริมาตรกระบอกสูบและมาตรฐานการปล่อยมลพิษ ตั้งแต่ 17% สำหรับรถยนต์ขนาดเล็ก eco-car ไปจนถึง 40% สำหรับรถยนต์ขนาดใหญ่',
  },
  {
    question: 'น้ำอัดลมหวานต้องเสียภาษีสรรพสามิตไหม?',
    answer: 'ใช่ เครื่องดื่มที่มีน้ำตาล (ซูโครส กลูโคส ฟรุกโตส) ต้องเสียภาษีสรรพสามิตตามปริมาณน้ำตาล เครื่องดื่มที่มีน้ำตาล 6-8 กรัมต่อ 100 มล. เสีย 1 บาท/ลิตร หากเกิน 10 กรัม/100 มล. เสีย 5 บาท/ลิตร',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณภาษีสรรพสามิต',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

const jsonLdHowTo = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "วิธีคำนวณภาษีสรรพสามิต (Excise Tax) ปี 2569",
  "description": "ขั้นตอนการคำนวณภาษีสรรพสามิต (Excise Duty) ที่เก็บจากสินค้าเฉพาะ เช่น บุหรี่ เหล้า น้ำมันเชื้อเพลิง ตามอัตราที่กำหนดของกรมสรรพสามิต",
  "step": [
    {"@type": "HowToStep", "name": "ตรวจสอบว่าสินค้าต้องเสียภาษีสรรพสามิต", "text": "สินค้าต้องเสียภาษีสรรพสามิต: (1) บุหรี่, (2) เหล้า/เบียร์, (3) น้ำมันเชื้อเพลิง, (4) ยานยนต์, (5) เครื่องดื่มน้ำตาลสูง ตรวจสอบว่าสินค้าของคุณอยู่ในรายการ"},
    {"@type": "HowToStep", "name": "ตรวจสอบอัตราภาษี (Excise Rate)", "text": "อัตราภาษีตามประเภทสินค้า: บุหรี่ 85%, เบียร์ 70%, เหล้า 60-80%, น้ำมันเบนซิน 3 บาท/ลิตร, ดีเซล 3 บาท/ลิตร"},
    {"@type": "HowToStep", "name": "คำนวณภาษีสรรพสามิต (Ad Valorem Method)", "text": "ภาษี = มูลค่าสินค้า × อัตราภาษี (%) ตัวอย่าง: บุหรี่ 100 บาท × 85% = 85 บาท"},
    {"@type": "HowToStep", "name": "คำนวณภาษีสรรพสามิต (Specific Duty Method)", "text": "ภาษี = ปริมาณ × อัตราภาษี (บาท/หน่วย) ตัวอย่าง: น้ำมันเบนซิน 1,000 ลิตร × 3 บาท/ลิตร = 3,000 บาท"},
    {"@type": "HowToStep", "name": "บันทึกและส่งแบบประเมินภาษี", "text": "ผู้ผลิต/นำเข้าต้องจดทะเบียนกับกรมสรรพสามิต, บันทึกรายการ, และส่งแบบประเมินภาษีประจำเดือน พร้อมชำระภาษี"}
  ]
};
---

<BaseLayout noGenericHowTo={true} title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีสรรพสามิต">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <script type="application/ld+json" set:html={JSON.stringify(jsonLdHowTo)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณภาษีสรรพสามิต (ประมาณการ)
    </h1>
    <p class="text-gray-600 mb-6">
      ประมาณการภาษีสรรพสามิตสำหรับสินค้าประเภทต่างๆ ตามอัตรากรมสรรพสามิต ปี 2569
    </p>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">เลือกประเภทสินค้า</h2>

      <div class="space-y-4">
        <div>
          <label for="product-type" class="block text-sm font-medium text-gray-700 mb-1">ประเภทสินค้า</label>
          <select id="product-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base bg-white">
            <option value="beer">เบียร์</option>
            <option value="spirits">สุรากลั่น (วิสกี้ บรั่นดี)</option>
            <option value="wine">ไวน์</option>
            <option value="tobacco">บุหรี่</option>
            <option value="petrol">น้ำมันเบนซิน</option>
            <option value="diesel">น้ำมันดีเซล</option>
            <option value="car_small">รถยนต์ขนาดเล็ก (Eco Car ≤1,300cc)</option>
            <option value="car_mid">รถยนต์ขนาดกลาง (1,301–1,800cc)</option>
            <option value="car_large">รถยนต์ขนาดใหญ่ (>1,800cc)</option>
            <option value="sugary">เครื่องดื่มน้ำตาลสูง (>10g/100ml)</option>
          </select>
        </div>

        <div id="field-value-wrap">
          <label for="product-value" id="value-label" class="block text-sm font-medium text-gray-700 mb-1">ราคาขาย (บาท)</label>
          <input type="text" id="product-value" inputmode="numeric" placeholder="เช่น 100,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base" />
        </div>
      </div>

      <div id="rate-info" class="mt-3 p-3 bg-blue-50 rounded-md text-sm text-blue-800"></div>

      <button type="button" id="btn-calculate"
        class="mt-5 w-full sm:w-auto px-8 py-2.5 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
        ประมาณการภาษี
      </button>

      <!-- Result -->
      <div id="result" class="hidden mt-6 p-4 bg-primary-50 rounded-lg border border-primary-200">
        <h3 class="font-semibold text-primary-900 mb-3">ผลการประมาณการ</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-700">ประเภทสินค้า</span>
            <span id="res-type" class="font-semibold text-gray-900">-</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-700">มูลค่า / ฐานคำนวณ</span>
            <span id="res-base" class="font-semibold text-gray-900">-</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-700">อัตราภาษีที่ใช้</span>
            <span id="res-rate" class="font-semibold text-gray-900">-</span>
          </div>
          <div class="flex justify-between border-t border-primary-300 pt-2 mt-2">
            <span class="font-bold text-primary-900">ภาษีสรรพสามิต (ประมาณการ)</span>
            <span id="res-tax" class="font-bold text-primary-700 text-lg">-</span>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-3">* ตัวเลขเป็นการประมาณการเบื้องต้น อัตราจริงอาจแตกต่างตามชนิดผลิตภัณฑ์และเงื่อนไขเฉพาะ</p>
      </div>
    </div>

    <div class="my-8 p-4 bg-gray-100 rounded text-center text-gray-400 text-sm">[โฆษณา — AdSense]</div>

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ภาษีสรรพสามิตในไทย</h2>
      <p>
        กรมสรรพสามิตจัดเก็บภาษีสรรพสามิตตามพระราชบัญญัติภาษีสรรพสามิต พ.ศ. 2560
        โดยแบ่งสินค้าออกเป็นหลายประเภท แต่ละประเภทมีอัตราภาษีที่แตกต่างกัน
      </p>
      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สินค้าที่ต้องเสียภาษีสรรพสามิต</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>สุราทุกชนิด (เบียร์ ไวน์ สุรากลั่น)</li>
        <li>บุหรี่และผลิตภัณฑ์ยาสูบ</li>
        <li>น้ำมันและผลิตภัณฑ์น้ำมัน</li>
        <li>รถยนต์และรถจักรยานยนต์</li>
        <li>เรือยอช์ต</li>
        <li>เครื่องดื่มที่มีน้ำตาล</li>
        <li>ไพ่ไทย</li>
        <li>สถานบริการ (ไนต์คลับ ดิสโก้เธค)</li>
      </ul>
    </section>


    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">สูตรที่ใช้คำนวณ</h2>
      <p><strong>ภาษีสรรพสามิต = ราคาสินค้า × อัตราภาษี</strong></p>
      <p>อัตรา 5%−30% ขึ้นอยู่กับประเภทสินค้า เช่น รถยนต์ เหล้า บุหรี่ เครื่องดื่มชูกำลัง เป็นต้น</p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-3">ตัวอย่างการคำนวณ</h3>
      <p><strong>ตัวอย่างที่ 1: ซื้อรถยนต์ราคา 1,000,000 บาท (อัตรา 5%)</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>ราคารถยนต์</strong> = 1,000,000 บาท</li>
        <li><strong>อัตราภาษีสรรพสามิต</strong> = 5%</li>
        <li><strong>ภาษีสรรพสามิต</strong> = 1,000,000 × 5% = <strong>50,000 บาท</strong></li>
      </ul>

      <p class="mt-4"><strong>ตัวอย่างที่ 2: เหล้าราคา 500 บาท/ขวด (อัตรา 20%)</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li><strong>ราคาสินค้า</strong> = 500 บาท</li>
        <li><strong>อัตราภาษีสรรพสามิต</strong> = 20%</li>
        <li><strong>ภาษีสรรพสามิต</strong> = 500 × 20% = <strong>100 บาท</strong></li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สรุป</h3>
      <p>ภาษีสรรพสามิตเป็นภาษีการบริโภคที่เก็บจากสินค้าเฉพาะประเภท เพื่อควบคุมการบริโภคและเก็บรายได้ของรัฐ ผู้ซื้อเป็นผู้แบกรับภาษีในที่สุด</p>
      <p class="text-sm text-gray-500 mt-2"><strong>อ้างอิง:</strong> <a href="https://www.rd.go.th" class="text-primary-600 hover:underline" target="_blank" rel="noopener">กรมสรรพากร: ภาษีสรรพสามิต</a> [อัปเดต 2569]</p>
    </section>
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณภาษีสรรพสามิต/" />
    <RelatedCalculators currentHref="/คำนวณภาษีสรรพสามิต/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการเท่านั้น
      อัตราภาษีจริงขึ้นอยู่กับชนิดสินค้าเฉพาะและประกาศกรมสรรพสามิต กรุณาตรวจสอบกับกรมสรรพสามิตโดยตรง
    </div>
  </article>

  <script>
    interface ProductInfo {
      label: string;
      rateText: string;
      ratePct: number;
      infoText: string;
      valueLabel: string;
      placeholder: string;
    }

    const PRODUCTS: Record<string, ProductInfo> = {
      beer:      { label: 'เบียร์', rateText: '22%', ratePct: 0.22, infoText: 'อัตรา 22% ของราคาขายปลีก (หรือ 155 บาท/ลิตรแอลกอฮอล์บริสุทธิ์ แล้วแต่อย่างสูงกว่า)', valueLabel: 'ราคาขายปลีกรวม (บาท)', placeholder: 'เช่น 50,000' },
      spirits:   { label: 'สุรากลั่น', rateText: '25%', ratePct: 0.25, infoText: 'อัตรา 25% ของราคาขายปลีก (หรือ 400 บาท/ลิตรแอลกอฮอล์บริสุทธิ์)', valueLabel: 'ราคาขายปลีกรวม (บาท)', placeholder: 'เช่น 100,000' },
      wine:      { label: 'ไวน์', rateText: '10%', ratePct: 0.10, infoText: 'อัตรา 10% ของราคาขายปลีก (หรืออัตราตามปริมาณ แล้วแต่อย่างสูงกว่า)', valueLabel: 'ราคาขายปลีกรวม (บาท)', placeholder: 'เช่น 30,000' },
      tobacco:   { label: 'บุหรี่', rateText: '20%', ratePct: 0.20, infoText: 'อัตรา 20% ของราคาขายปลีก + 1.25 บาท/มวน (เป็นการประมาณการ)', valueLabel: 'ราคาขายปลีกรวม (บาท)', placeholder: 'เช่น 80,000' },
      petrol:    { label: 'น้ำมันเบนซิน', rateText: '~7 บาท/ลิตร', ratePct: 0, infoText: 'อัตราตามปริมาณ ประมาณ 7 บาท/ลิตร (ปรับได้ตามประกาศ)', valueLabel: 'ปริมาณน้ำมัน (ลิตร)', placeholder: 'เช่น 1,000' },
      diesel:    { label: 'น้ำมันดีเซล', rateText: '~5.99 บาท/ลิตร', ratePct: 0, infoText: 'อัตราตามปริมาณ ประมาณ 5.99 บาท/ลิตร (ปรับได้ตามประกาศ)', valueLabel: 'ปริมาณน้ำมัน (ลิตร)', placeholder: 'เช่น 1,000' },
      car_small: { label: 'รถยนต์ Eco Car (≤1,300cc)', rateText: '20%', ratePct: 0.20, infoText: 'รถยนต์นั่งขนาดเล็ก eco car อัตรา 20% ของราคาขายปลีก', valueLabel: 'ราคาขายปลีกรถยนต์ (บาท)', placeholder: 'เช่น 500,000' },
      car_mid:   { label: 'รถยนต์ขนาดกลาง (1,301–1,800cc)', rateText: '30%', ratePct: 0.30, infoText: 'รถยนต์นั่งขนาดกลาง 1,301–1,800cc อัตราประมาณ 30%', valueLabel: 'ราคาขายปลีกรถยนต์ (บาท)', placeholder: 'เช่น 800,000' },
      car_large: { label: 'รถยนต์ขนาดใหญ่ (>1,800cc)', rateText: '40%', ratePct: 0.40, infoText: 'รถยนต์นั่งขนาดใหญ่ >1,800cc อัตราประมาณ 40%', valueLabel: 'ราคาขายปลีกรถยนต์ (บาท)', placeholder: 'เช่น 1,500,000' },
      sugary:    { label: 'เครื่องดื่มน้ำตาลสูง', rateText: '5 บาท/ลิตร', ratePct: 0, infoText: 'น้ำตาล >10g/100ml อัตรา 5 บาท/ลิตร', valueLabel: 'ปริมาณ (ลิตร)', placeholder: 'เช่น 10,000' },
    };

    const FIXED_RATES: Record<string, number> = { petrol: 7, diesel: 5.99, sugary: 5 };

    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }
    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' บาท';
    }

    const sel = document.getElementById('product-type') as HTMLSelectElement;
    const rateInfo = document.getElementById('rate-info') as HTMLElement;
    const valueLabel = document.getElementById('value-label') as HTMLLabelElement;
    const valueInput = document.getElementById('product-value') as HTMLInputElement;

    function updateUI() {
      const p = PRODUCTS[sel.value];
      rateInfo.textContent = p.infoText;
      valueLabel.textContent = p.valueLabel;
      valueInput.placeholder = p.placeholder;
    }
    sel.addEventListener('change', updateUI);
    updateUI();

    document.getElementById('btn-calculate')!.addEventListener('click', () => {
      const val = parseNum(valueInput.value);
      if (val <= 0) { valueInput.focus(); return; }

      const p = PRODUCTS[sel.value];
      let tax = 0;
      let rateDisplay = p.rateText;

      if (sel.value in FIXED_RATES) {
        tax = val * FIXED_RATES[sel.value];
        rateDisplay = FIXED_RATES[sel.value] + ' บาท/หน่วย';
      } else {
        tax = val * p.ratePct;
      }

      (document.getElementById('res-type') as HTMLElement).textContent = p.label;
      (document.getElementById('res-base') as HTMLElement).textContent = fmt(val);
      (document.getElementById('res-rate') as HTMLElement).textContent = rateDisplay;
      (document.getElementById('res-tax') as HTMLElement).textContent = fmt(tax);
      document.getElementById('result')!.classList.remove('hidden');
      trackCalculatorUsed('excise-tax');
    });
  </script>
</BaseLayout>
