---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าปุ๋ยเคมีและปุ๋ยอินทรีย์ | Kamnuanlek';
const pageDescription = 'คำนวณค่าใช้จ่ายปุ๋ยเคมี ปุ๋ยอินทรีย์ต่อไร่ต่อฤดูกาล ต้นทุนปุ๋ยทั้งหมด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0478-ค่าปุ๋ย/`;
const faqData = [
  { question: 'ปุ๋ยเคมีกับปุ๋ยอินทรีย์ต่างกันอย่างไร?', answer: 'ปุ๋ยเคมีให้ธาตุอาหารเร็ว ราคาถูกกว่าต่อหน่วยธาตุอาหาร ปุ๋ยอินทรีย์ปรับโครงสร้างดิน ยั่งยืนกว่า ราคาสูงกว่าแต่ลดต้นทุนระยะยาว' },
  { question: 'อัตราการใส่ปุ๋ยข้าวเหมาะสมเท่าไหร่?', answer: 'ข้าวนาปี: ปุ๋ยรองพื้น 16-20-0 อัตรา 25-30 กก./ไร่ ปุ๋ยแต่งหน้า 46-0-0 อัตรา 10-15 กก./ไร่ ควรวิเคราะห์ดินก่อนเพื่อความแม่นยำ' },
  { question: 'ปุ๋ยชีวภาพใช้แทนปุ๋ยเคมีได้ไหม?', answer: 'ปุ๋ยชีวภาพ เช่น ไรโซเบียม ไมโคไรซา ช่วยเพิ่มการดูดซึมธาตุอาหาร ลดปุ๋ยเคมีได้ 20-30% แต่ไม่สามารถใช้แทนได้ 100% ควรใช้ร่วมกัน' },
  { question: 'ซื้อปุ๋ยผ่านสหกรณ์ประหยัดได้แค่ไหน?', answer: 'การซื้อปุ๋ยผ่านสหกรณ์การเกษตรหรือโครงการรัฐ ประหยัดได้ 10-20% เมื่อเทียบกับร้านค้าทั่วไป และมั่นใจด้านคุณภาพมาตรฐาน' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าปุ๋ยเคมีและปุ๋ยอินทรีย์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าปุ๋ย</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนปุ๋ยเคมีและปุ๋ยอินทรีย์ต่อฤดูกาล</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="fert_area" class="block text-sm font-medium text-gray-700 mb-1">พื้นที่ (ไร่)</label><input type="number" id="fert_area" min="1" placeholder="เช่น 20" value="20" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="chem_fert_per_rai" class="block text-sm font-medium text-gray-700 mb-1">ค่าปุ๋ยเคมีต่อไร่ (บาท)</label><input type="text" id="chem_fert_per_rai" inputmode="decimal" placeholder="เช่น 350" value="350" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="org_fert_per_rai" class="block text-sm font-medium text-gray-700 mb-1">ค่าปุ๋ยอินทรีย์ต่อไร่ (บาท)</label><input type="text" id="org_fert_per_rai" inputmode="decimal" placeholder="เช่น 150" value="150" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="fert_seasons" class="block text-sm font-medium text-gray-700 mb-1">จำนวนฤดูกาล/ปี</label><input type="number" id="fert_seasons" min="1" max="3" placeholder="เช่น 2" value="2" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ค่าปุ๋ยต่อฤดูกาล</p><p id="fert_per_season" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">ค่าปุ๋ยรวมต่อปี</p><p id="fert_annual" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const area = parseFloat((document.getElementById('fert_area') as HTMLInputElement).value) || 0;
      const chemPerRai = parseFloat((document.getElementById('chem_fert_per_rai') as HTMLInputElement).value) || 0;
      const orgPerRai = parseFloat((document.getElementById('org_fert_per_rai') as HTMLInputElement).value) || 0;
      const seasons = parseInt((document.getElementById('fert_seasons') as HTMLInputElement).value) || 1;
      const perSeason = area * (chemPerRai + orgPerRai);
      const annual = perSeason * seasons;
      (document.getElementById('fert_per_season') as HTMLElement).textContent = Math.round(perSeason).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('fert_annual') as HTMLElement).textContent = Math.round(annual).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('fertilizer-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
