---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณ Hedge FX สำหรับนำเข้า ปี 2569 — Import FX Hedge Estimate | เครื่องคำนวณไทย';
const pageDescription = 'ประมาณการ FX Hedge สำหรับผู้นำเข้า ป้อนยอดสั่งซื้อ อัตรา Spot อัตรา Forward และระยะเวลา ทราบต้นทุนป้องกันความเสี่ยง FX';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-hedge-fx-นำเข้า/`;

const faqData = [
  {
    question: 'FX Hedge คืออะไร?',
    answer: 'FX Hedge คือการป้องกันความเสี่ยงจากการเปลี่ยนแปลงอัตราแลกเปลี่ยน เช่น ผู้นำเข้าทำ Forward Contract ล็อคอัตราแลกเปลี่ยนล่วงหน้า เพื่อกำหนดต้นทุนนำเข้าที่แน่นอน',
  },
  {
    question: 'Forward Rate ต่างกับ Spot Rate อย่างไร?',
    answer: 'Spot Rate คืออัตราแลกเปลี่ยนปัจจุบัน Forward Rate คืออัตราที่ธนาคารเสนอสำหรับแลกเงินในอนาคต (เช่น 3 เดือนข้างหน้า) ซึ่งรวมส่วนต่างอัตราดอกเบี้ยระหว่างสกุลเงิน',
  },
  {
    question: 'ผู้นำเข้าควร Hedge FX 100% ไหม?',
    answer: 'ไม่จำเป็นต้อง 100% ขึ้นอยู่กับนโยบายความเสี่ยงของกิจการ หลายบริษัท Hedge 50–80% เพื่อลดความเสี่ยงแต่ยังมีโอกาสได้ประโยชน์หากอัตราเปลี่ยนไปในทางที่ดี',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณ Hedge FX สำหรับนำเข้า',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณ-hedge-fx-นำเข้า">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-indigo-100 bg-indigo-50 p-4">
      <p class="text-sm font-semibold text-indigo-700">คำนวณ FX Hedge สำหรับผู้นำเข้า</p>
      <p class="mt-1 text-sm text-slate-700">เปรียบเทียบต้นทุนนำเข้าที่ Spot Rate vs Forward Rate และค่า Hedge</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณ Hedge FX สำหรับนำเข้า ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนยอดสั่งซื้อต่างประเทศ อัตรา Spot และ Forward เพื่อเปรียบเทียบต้นทุนนำเข้าและค่า Hedge
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="hfx-form" class="space-y-5">
        <p id="hfx-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="hfx-amount" class="mb-1 block text-sm font-medium text-gray-700">ยอดสั่งซื้อ (สกุลเงินต่างประเทศ)</label>
            <input type="text" id="hfx-amount" inputmode="numeric" placeholder="เช่น 50,000 USD"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hfx-amount-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="hfx-hedge-pct" class="mb-1 block text-sm font-medium text-gray-700">สัดส่วนที่ต้องการ Hedge (%)</label>
            <input type="text" id="hfx-hedge-pct" inputmode="decimal" placeholder="เช่น 100"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">0–100%</p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="hfx-spot" class="mb-1 block text-sm font-medium text-gray-700">Spot Rate (บาท/1 หน่วย)</label>
            <input type="text" id="hfx-spot" inputmode="decimal" placeholder="เช่น 34.00"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hfx-spot-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="hfx-forward" class="mb-1 block text-sm font-medium text-gray-700">Forward Rate (บาท/1 หน่วย)</label>
            <input type="text" id="hfx-forward" inputmode="decimal" placeholder="เช่น 34.50"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hfx-forward-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ FX Hedge
        </button>
      </form>
    </div>

    <div id="hfx-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนที่ Spot Rate</div>
            <div id="res-hfx-spot-cost" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-indigo-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนที่ Forward Rate (ส่วน Hedge)</div>
            <div id="res-hfx-fwd-cost" class="text-xl font-bold text-indigo-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่า Hedge Premium/Discount</div>
            <div id="res-hfx-premium" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ยอด Hedge</span>
            <span id="res-hfx-hedge-amt" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ยอดที่ไม่ Hedge (ใช้ Spot)</span>
            <span id="res-hfx-unhedge-amt" class="font-medium">-</span>
          </div>
        </div>
        <p id="hfx-verdict" class="mt-3 text-sm text-gray-600"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ต้นทุน Spot = ยอดรวม × Spot Rate</li>
        <li>ยอด Hedge = ยอดรวม × Hedge%</li>
        <li>ต้นทุน Hedge = ยอด Hedge × Forward Rate</li>
        <li>Hedge Premium = (Forward − Spot) × ยอด Hedge</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณแปลงรายรับส่งออก/">คำนวณแปลงรายรับส่งออกเป็นบาท</a></li>
        <li><a href="/คำนวณต้นทุนชำระเงินข้ามประเทศ/">คำนวณต้นทุนชำระเงินข้ามประเทศ</a></li>
        <li><a href="/คำนวณ-wire-transfer/">เปรียบเทียบ Wire Transfer</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#hfx-results" />
    <RelatedArticles currentHref="/คำนวณ-hedge-fx-นำเข้า/" />
    <RelatedCalculators currentHref="/คำนวณ-hedge-fx-นำเข้า/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> การคำนวณนี้เป็นการประมาณการเบื้องต้น Forward Rate จริงและเงื่อนไข Hedge ควรยืนยันกับธนาคารผู้ให้บริการ
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('hfx-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      ['hfx-amount-error','hfx-spot-error','hfx-forward-error'].forEach(id => setErr(id, ''));

      const amount = parseNum(document.getElementById('hfx-amount').value);
      const hedgePct = parseNum(document.getElementById('hfx-hedge-pct').value) || 100;
      const spot = parseNum(document.getElementById('hfx-spot').value);
      const forward = parseNum(document.getElementById('hfx-forward').value);

      let hasError = false;
      if (!Number.isFinite(amount) || amount <= 0) { setErr('hfx-amount-error', 'กรอกยอดสั่งซื้อมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(spot) || spot <= 0) { setErr('hfx-spot-error', 'กรอก Spot Rate มากกว่า 0'); hasError = true; }
      if (!Number.isFinite(forward) || forward <= 0) { setErr('hfx-forward-error', 'กรอก Forward Rate มากกว่า 0'); hasError = true; }
      if (hasError) { document.getElementById('hfx-error').classList.remove('hidden'); document.getElementById('hfx-results').classList.add('hidden'); return; }
      document.getElementById('hfx-error').classList.add('hidden');

      const hedgeAmount = amount * hedgePct / 100;
      const unhedgeAmount = amount - hedgeAmount;
      const spotCostTotal = amount * spot;
      const hedgeCost = hedgeAmount * forward;
      const unhedgeCost = unhedgeAmount * spot;
      const totalFwdCost = hedgeCost + unhedgeCost;
      const premium = hedgeCost - hedgeAmount * spot;

      setText('res-hfx-spot-cost', fmt(spotCostTotal));
      setText('res-hfx-fwd-cost', fmt(totalFwdCost));
      setText('res-hfx-premium', fmt(Math.abs(premium)));
      setText('res-hfx-hedge-amt', `${new Intl.NumberFormat('th-TH').format(hedgeAmount)} (${hedgePct}%)`);
      setText('res-hfx-unhedge-amt', `${new Intl.NumberFormat('th-TH').format(unhedgeAmount)} (${100-hedgePct}%)`);

      const verdictEl = document.getElementById('hfx-verdict');
      if (forward > spot) {
        verdictEl.textContent = `Forward Rate สูงกว่า Spot ${fmt(premium)} — Hedge มีต้นทุนเพิ่ม แต่ช่วยป้องกันความเสี่ยงอัตราแลกเปลี่ยน`;
      } else {
        verdictEl.textContent = `Forward Rate ต่ำกว่า Spot ${fmt(Math.abs(premium))} — Hedge ช่วยประหยัดต้นทุนในครั้งนี้`;
      }

      document.getElementById('hfx-results').classList.remove('hidden');
      document.getElementById('hfx-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
