---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณผลตอบแทนหลังเงินเฟ้อ ปี 2569 ผลตอบแทนจริงที่ได้รับ | Kamnuanlek';
const pageDescription = 'คำนวณผลตอบแทนที่แท้จริงหลังหักเงินเฟ้อ มูลค่าจริงของเงินออมในอนาคต และกำลังซื้อที่เหลืออยู่';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณผลตอบแทนหลังเงินเฟ้อ/`;

const faqData = [
  {
    question: 'อัตราเงินเฟ้อในไทยอยู่ที่เท่าไหร่?',
    answer: 'อัตราเงินเฟ้อในไทยโดยเฉลี่ยระยะยาวอยู่ที่ประมาณ 2–3% ต่อปี ในช่วงปี 2565–2566 สูงถึง 5–7% แต่ในปี 2567–2569 ลดลงมาอยู่ที่ประมาณ 1–2%',
  },
  {
    question: 'ทำไมผลตอบแทนจริงจึงสำคัญ?',
    answer: 'ผลตอบแทนจริงบอกว่าเงินของคุณเติบโตมากกว่าหรือน้อยกว่าอัตราเงินเฟ้อ ถ้าดอกเบี้ยน้อยกว่าเงินเฟ้อ หมายความว่ากำลังซื้อของเงินลดลงแม้จะมีดอกเบี้ย',
  },
  {
    question: 'จะทำอย่างไรให้ผลตอบแทนชนะเงินเฟ้อ?',
    answer: 'ลงทุนในสินทรัพย์ที่ให้ผลตอบแทนสูงกว่าเงินเฟ้อ เช่น หุ้น กองทุนรวม อสังหาริมทรัพย์ หรือพันธบัตรเงินเฟ้อ (ILBs) บัญชีออมทรัพย์ปกติมักไม่ชนะเงินเฟ้อในระยะยาว',
  },
  {
    question: 'มูลค่าเงิน 1 ล้านบาทในอีก 20 ปีจะเหลือเท่าไหร่?',
    answer: 'ที่อัตราเงินเฟ้อ 3% ต่อปี เงิน 1 ล้านบาทในวันนี้จะมีกำลังซื้อเพียง 553,676 บาท (ในมูลค่าปัจจุบัน) ในอีก 20 ปีข้างหน้า นี่คือเหตุผลที่ต้องลงทุนให้ชนะเงินเฟ้อ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผลตอบแทนหลังเงินเฟ้อ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผลตอบแทนหลังเงินเฟ้อ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-orange-100 bg-orange-50 p-4">
      <p class="text-sm font-semibold text-orange-700">📉 คำนวณผลตอบแทนหลังเงินเฟ้อ</p>
      <p class="mt-1 text-sm text-slate-700">สูตร Fisher: (1 + ผลตอบแทนจริง) = (1 + ผลตอบแทนนาม) ÷ (1 + เงินเฟ้อ)</p>
      <p class="mt-1 text-xs font-medium text-orange-800">รู้จริงว่าเงินของคุณเติบโตหรือหดหลังหักเงินเฟ้อ</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณผลตอบแทนหลังเงินเฟ้อ ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกผลตอบแทนนาม (ก่อนหักเงินเฟ้อ) อัตราเงินเฟ้อ และระยะเวลา เพื่อดูผลตอบแทนจริงและมูลค่ากำลังซื้อ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="infl-form" class="space-y-5">
        <p id="infl-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="infl-amount" class="mb-1 block text-sm font-medium text-gray-700">เงินลงทุนเริ่มต้น (บาท)</label>
            <input type="text" id="infl-amount" inputmode="numeric" placeholder="เช่น 100,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="infl-amount-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="infl-nominal" class="mb-1 block text-sm font-medium text-gray-700">ผลตอบแทนนาม (% ต่อปี)</label>
            <input type="text" id="infl-nominal" inputmode="numeric" placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="infl-nominal-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="infl-rate" class="mb-1 block text-sm font-medium text-gray-700">อัตราเงินเฟ้อ (% ต่อปี)</label>
            <input type="text" id="infl-rate" inputmode="numeric" placeholder="เช่น 3"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="infl-rate-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="infl-years" class="mb-1 block text-sm font-medium text-gray-700">ระยะเวลา (ปี)</label>
            <input type="text" id="infl-years" inputmode="numeric" placeholder="เช่น 10"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="infl-years-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณผลตอบแทนจริง
        </button>
      </form>
    </div>

    <div id="infl-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-4">
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">มูลค่านาม (อนาคต)</div>
            <div id="res-infl-nominal-fv" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">มูลค่าจริง (กำลังซื้อ)</div>
            <div id="res-infl-real-fv" class="text-xl font-bold text-orange-700">-</div>
          </div>
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ผลตอบแทนจริง (%/ปี)</div>
            <div id="res-infl-real-rate" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">กำลังซื้อที่สูญ</div>
            <div id="res-infl-loss" class="text-xl font-bold text-red-700">-</div>
          </div>
        </div>
        <p id="infl-status" class="rounded-lg p-3 text-sm font-medium"></p>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้คำนวณ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>มูลค่านาม = เงินต้น × (1 + ผลตอบแทนนาม)^n</li>
        <li>ผลตอบแทนจริง = [(1 + นาม) ÷ (1 + เงินเฟ้อ)] − 1 (สูตร Fisher)</li>
        <li>มูลค่าจริง = เงินต้น × (1 + ผลตอบแทนจริง)^n</li>
        <li>กำลังซื้อที่สูญ = มูลค่านาม − มูลค่าจริง</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#infl-results" />
    <RelatedArticles currentHref="/คำนวณผลตอบแทนหลังเงินเฟ้อ/" />
    <RelatedCalculators currentHref="/คำนวณผลตอบแทนหลังเงินเฟ้อ/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ อัตราเงินเฟ้อและผลตอบแทนจริงอาจแตกต่างจากประมาณการ
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      return Number(s);
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('infl-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('infl-error').classList.add('hidden');
      ['infl-amount-error','infl-nominal-error','infl-rate-error','infl-years-error'].forEach(id => setErr(id, ''));

      const amount = parseNum(document.getElementById('infl-amount').value);
      const nominal = parseNum(document.getElementById('infl-nominal').value);
      const inflRate = parseNum(document.getElementById('infl-rate').value);
      const years = parseNum(document.getElementById('infl-years').value);

      let hasError = false;
      if (!amount || amount <= 0) { setErr('infl-amount-error', 'กรอกเงินลงทุน'); hasError = true; }
      if (isNaN(nominal)) { setErr('infl-nominal-error', 'กรอกผลตอบแทนนาม'); hasError = true; }
      if (isNaN(inflRate)) { setErr('infl-rate-error', 'กรอกอัตราเงินเฟ้อ'); hasError = true; }
      if (!years || years <= 0) { setErr('infl-years-error', 'กรอกระยะเวลา'); hasError = true; }
      if (hasError) { document.getElementById('infl-error').classList.remove('hidden'); document.getElementById('infl-results').classList.add('hidden'); return; }

      const nominalDecimal = nominal / 100;
      const inflDecimal = inflRate / 100;
      const realRate = (1 + nominalDecimal) / (1 + inflDecimal) - 1;
      const nominalFV = amount * Math.pow(1 + nominalDecimal, years);
      const realFV = amount * Math.pow(1 + realRate, years);
      const loss = nominalFV - realFV;

      setText('res-infl-nominal-fv', formatMoney(nominalFV));
      setText('res-infl-real-fv', formatMoney(realFV));
      setText('res-infl-real-rate', `${(realRate * 100).toFixed(2)}%`);
      setText('res-infl-loss', formatMoney(loss));

      const statusEl = document.getElementById('infl-status');
      if (realRate >= 0) {
        statusEl.className = 'rounded-lg bg-green-50 p-3 text-sm font-medium text-green-800 border border-green-200';
        statusEl.textContent = `ผลตอบแทนจริง ${(realRate * 100).toFixed(2)}%/ปี ชนะเงินเฟ้อ กำลังซื้อเพิ่มขึ้นจาก ${formatMoney(amount)} เป็น ${formatMoney(realFV)}`;
      } else {
        statusEl.className = 'rounded-lg bg-red-50 p-3 text-sm font-medium text-red-800 border border-red-200';
        statusEl.textContent = `ผลตอบแทนจริง ${(realRate * 100).toFixed(2)}%/ปี แพ้เงินเฟ้อ กำลังซื้อลดลงจาก ${formatMoney(amount)} เหลือ ${formatMoney(realFV)}`;
      }

      document.getElementById('infl-results').classList.remove('hidden');
      document.getElementById('infl-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
