---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าสุขภาพผู้สูงอายุ | Kamnuanlek';
const pageDescription = 'คำนวณค่าใช้จ่ายสุขภาพผู้สูงอายุ ค่ายาโรคเรื้อรัง ค่าตรวจ ค่าดูแลรายเดือนและรายปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0424-ค่าสุขภาพผู้สูงอายุ/`;

const faqData = [
  { question: 'ค่าใช้จ่ายสุขภาพผู้สูงอายุเดือนละเท่าไหร่?', answer: 'ผู้สูงอายุไทยมีค่าใช้จ่ายสุขภาพเฉลี่ย 2,000-8,000 บาทต่อเดือน ขึ้นอยู่กับโรคเรื้อรัง ยา การตรวจ และการดูแล' },
  { question: 'ควรวางแผนค่าสุขภาพผู้สูงอายุไว้เท่าไหร่?', answer: 'แนะนำเตรียมงบสุขภาพผู้สูงอายุ 50,000-200,000 บาทต่อปี หรือมีประกันสุขภาพที่ครอบคลุม รวมทั้งมีเงินสำรองฉุกเฉิน 500,000 บาทขึ้นไป' },
  { question: 'บ้านพักผู้สูงอายุราคาเท่าไหร่?', answer: 'บ้านพักผู้สูงอายุรัฐบาล 3,000-8,000 บาทต่อเดือน เอกชนทั่วไป 15,000-40,000 บาทต่อเดือน เอกชนระดับพรีเมียม 40,000-100,000 บาทต่อเดือน' },
  { question: 'เบี้ยผู้สูงอายุจากรัฐบาลได้รับเท่าไหร่?', answer: 'เบี้ยยังชีพผู้สูงอายุ 600 บาท/เดือน (อายุ 60-69 ปี) 700 บาท (70-79 ปี) 800 บาท (80-89 ปี) 1,000 บาท (90 ปีขึ้นไป) ตามพระราชบัญญัติผู้สูงอายุ' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าสุขภาพผู้สูงอายุ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าสุขภาพผู้สูงอายุ</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าใช้จ่ายดูแลสุขภาพผู้สูงอายุรายเดือนและรายปี</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="chronic_meds" class="block text-sm font-medium text-gray-700 mb-1">ค่ายาโรคเรื้อรังต่อเดือน (บาท)</label><input type="text" id="chronic_meds" inputmode="decimal" placeholder="เช่น 3000" value="3000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="doctor_elderly" class="block text-sm font-medium text-gray-700 mb-1">ค่าพบแพทย์ต่อเดือน (บาท)</label><input type="text" id="doctor_elderly" inputmode="decimal" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="care_monthly" class="block text-sm font-medium text-gray-700 mb-1">ค่าผู้ดูแลต่อเดือน (บาท)</label><input type="text" id="care_monthly" inputmode="decimal" placeholder="เช่น 15000" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="supplements" class="block text-sm font-medium text-gray-700 mb-1">ค่าอาหารเสริมต่อเดือน (บาท)</label><input type="text" id="supplements" inputmode="decimal" placeholder="เช่น 2000" value="2000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อเดือน</p>
            <p id="monthly_elderly" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อปี</p>
            <p id="yearly_elderly" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const chronicMeds = parseFloat((document.getElementById('chronic_meds') as HTMLInputElement).value) || 0;
      const doctorElderly = parseFloat((document.getElementById('doctor_elderly') as HTMLInputElement).value) || 0;
      const careMonthly = parseFloat((document.getElementById('care_monthly') as HTMLInputElement).value) || 0;
      const supplements = parseFloat((document.getElementById('supplements') as HTMLInputElement).value) || 0;

      const monthlyElderly = chronicMeds + doctorElderly + careMonthly + supplements;
      const yearlyElderly = monthlyElderly * 12;

      (document.getElementById('monthly_elderly') as HTMLElement).textContent = monthlyElderly.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('yearly_elderly') as HTMLElement).textContent = yearlyElderly.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('senior-health-costs');
    });
    document.getElementById('btn')!.click();
  </script>

    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.anamai.moph.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">กรมอนามัย (anamai.moph.go.th)</a> — เกณฑ์สุขภาพและตัวชี้วัดสำหรับคนไทย</li>
        <li><a href="https://www.moph.go.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">กระทรวงสาธารณสุข (moph.go.th)</a> — นโยบายและข้อมูลสุขภาพแห่งชาติ</li>
      </ul>
    </div>
</BaseLayout>
