---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'คำนวณต้นทุนเพาะเห็ด | Calculator Thailand';
const desc = 'คำนวณต้นทุนการเพาะเห็ด วัสดุเพาะ ผลผลิด ROI';
const url = 'https://www.kamnuanlek.com/คำนวณ-เห็ด/';
---
<BaseLayout title={title} description={desc} canonical={url} pageName="คำนวณเห็ด">
<article><h1 class="text-2xl font-bold mb-3">คำนวณต้นทุนเพาะเห็ด</h1><p class="text-gray-600 mb-6">คำนวณต้นทุน ผลผลิด กำไร</p>
<div class="bg-white p-6 rounded border"><div class="space-y-3 mb-4"><input type="text" id="s" placeholder="สปอร์น(กก.)" value="50" class="w-full px-3 py-2 border rounded"/><input type="text" id="d" placeholder="วัน" value="60" class="w-full px-3 py-2 border rounded"/><input type="text" id="h" placeholder="เก็บ(กก.)" value="250" class="w-full px-3 py-2 border rounded"/><input type="text" id="p" placeholder="ราคา/กก." value="40" class="w-full px-3 py-2 border rounded"/></div>
<button onclick="calc()" class="px-6 py-2 bg-blue-600 text-white rounded">คำนวณ</button><div id="r" class="hidden mt-4 bg-blue-50 p-4 rounded"><p>ต้นทุน: <span id="c">-</span></p><p>รายได้: <span id="i">-</span></p><p>กำไร: <span id="pf">-</span></p></div></div></article>
<script>
function calc() {
  const c = (parseFloat((document.getElementById('s') as any).value) || 0) * 150 + (parseFloat((document.getElementById('s') as any).value) || 0) * 200 + ((parseFloat((document.getElementById('d') as any).value) || 0) / 30) * 5000;
  const i = (parseFloat((document.getElementById('h') as any).value) || 0) * (parseFloat((document.getElementById('p') as any).value) || 0);
  const pf = i - c;
  (document.getElementById('c') as any).textContent = Math.round(c).toLocaleString('th-TH') + ' บาท';
  (document.getElementById('i') as any).textContent = Math.round(i).toLocaleString('th-TH') + ' บาท';
  (document.getElementById('pf') as any).textContent = Math.round(pf).toLocaleString('th-TH') + ' บาท';
  (document.getElementById('r') as any).classList.remove('hidden');
}
calc();
</script></BaseLayout>
