    <!-- Disclaimer -->
    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการคำนวณเบื้องต้นตามสูตรทั่วไปและ พ.ร.บ. คุ้มครองแรงงาน พ.ศ. 2541
      จำนวนวันทำงานจริงอาจแตกต่างกันในแต่ละเดือนและแต่ละบริษัท ประกันสังคมเป็นอัตราสำหรับ ม.33 เท่านั้น
      กรุณาตรวจสอบกับฝ่ายบุคคลหรือสำนักงานประกันสังคมในพื้นที่
    </div>
  </article>

  <script type="module">
    import { calculateDailyWage } from '../../lib/daily-wage-calculator.ts';

    function parseNum(value) {
      const normalized = String(value).replace(/,/g, '').trim();
      if (normalized === '') return NaN;
      const num = Number(normalized);
      return Number.isFinite(num) ? num : NaN;
    }

    function formatMoney(num) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(num)} บาท`;
    }

    const form = document.getElementById('dw-form');
    const formError = document.getElementById('dw-form-error');
    const resultBox = document.getElementById('dw-results');
    const includeOtCheckbox = document.getElementById('include-ot');
    const otFields = document.getElementById('ot-fields');
    const amountLabel = document.getElementById('amount-label');
    const amountInput = document.getElementById('amount-input');
    const modeRadios = document.querySelectorAll('input[name="calc-mode"]');
    const modeM2dLabel = document.getElementById('mode-m2d-label');
    const modeD2mLabel = document.getElementById('mode-d2m-label');
    const submitBtn = document.getElementById('dw-submit-btn');

    let currentMode = 'monthly_to_daily';

    function updateModeUI() {
      if (currentMode === 'monthly_to_daily') {
        amountLabel.textContent = 'เงินเดือน (บาท)';
        amountInput.placeholder = 'เช่น 15000';
        submitBtn.textContent = 'คำนวณค่าจ้างรายวัน';
        modeM2dLabel.classList.add('border-primary-500', 'bg-primary-50', 'text-primary-700');
        modeM2dLabel.classList.remove('border-gray-200', 'bg-white', 'text-gray-600');
        modeD2mLabel.classList.remove('border-primary-500', 'bg-primary-50', 'text-primary-700');
        modeD2mLabel.classList.add('border-gray-200', 'bg-white', 'text-gray-600');
      } else {
        amountLabel.textContent = 'ค่าจ้างรายวัน (บาท)';
        amountInput.placeholder = 'เช่น 500';
        submitBtn.textContent = 'คำนวณเงินเดือน';
        modeD2mLabel.classList.add('border-primary-500', 'bg-primary-50', 'text-primary-700');
        modeD2mLabel.classList.remove('border-gray-200', 'bg-white', 'text-gray-600');
        modeM2dLabel.classList.remove('border-primary-500', 'bg-primary-50', 'text-primary-700');
        modeM2dLabel.classList.add('border-gray-200', 'bg-white', 'text-gray-600');
      }
    }

    modeRadios.forEach((radio) => {
      radio.addEventListener('change', (e) => {
        currentMode = e.target.value;
        updateModeUI();
      });
    });

    function clearFieldError(id) {
      const el = document.getElementById(id);
      if (!el) return;
      el.classList.add('hidden');
      el.textContent = '';
    }

    function setFieldError(id, message) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearErrors() {
      formError?.classList.add('hidden');
      clearFieldError('amount-error');
      clearFieldError('working-days-error');
      clearFieldError('weekday-ot-hours-error');
      clearFieldError('holiday-work-hours-error');
      clearFieldError('holiday-ot-hours-error');
    }

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    function showEl(id) {
      const el = document.getElementById(id);
      if (el) el.classList.remove('hidden');
    }

    function hideEl(id) {
      const el = document.getElementById(id);
      if (el) el.classList.add('hidden');
    }

    includeOtCheckbox?.addEventListener('change', () => {
      if (includeOtCheckbox.checked) {
        otFields?.classList.remove('hidden');
      } else {
        otFields?.classList.add('hidden');
      }
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      clearErrors();

      if (typeof window.trackCalculatorStart === 'function') {
        window.trackCalculatorStart('daily_wage');
      }

      const amount = parseNum(amountInput?.value || '');
      const workingDays = parseNum(document.getElementById('working-days')?.value || '');
      const includeOt = includeOtCheckbox?.checked || false;
      const deductSso = document.getElementById('deduct-sso')?.checked || false;
      const weekdayOtHours = parseNum(document.getElementById('weekday-ot-hours')?.value || '0');
      const holidayWorkHours = parseNum(document.getElementById('holiday-work-hours')?.value || '0');
      const holidayOtHours = parseNum(document.getElementById('holiday-ot-hours')?.value || '0');

      let hasError = false;

      if (!Number.isFinite(amount) || amount <= 0) {
        setFieldError('amount-error', currentMode === 'monthly_to_daily' ? 'กรุณากรอกเงินเดือนที่ถูกต้อง' : 'กรุณากรอกค่าจ้างรายวันที่ถูกต้อง');
        hasError = true;
      }

      if (!Number.isFinite(workingDays) || workingDays <= 0 || workingDays > 31) {
        setFieldError('working-days-error', 'กรอกวันทำงานต่อเดือนระหว่าง 1 - 31 วัน');
        hasError = true;
      }

      if (includeOt) {
        if (!Number.isFinite(weekdayOtHours) || weekdayOtHours < 0 || weekdayOtHours > 300) {
          setFieldError('weekday-ot-hours-error', 'กรอกชั่วโมง OT ระหว่าง 0 - 300');
          hasError = true;
        }
        if (!Number.isFinite(holidayWorkHours) || holidayWorkHours < 0 || holidayWorkHours > 300) {
          setFieldError('holiday-work-hours-error', 'กรอกชั่วโมงทำงานวันหยุดระหว่าง 0 - 300');
          hasError = true;
        }
        if (!Number.isFinite(holidayOtHours) || holidayOtHours < 0 || holidayOtHours > 300) {
          setFieldError('holiday-ot-hours-error', 'กรอกชั่วโมง OT วันหยุดระหว่าง 0 - 300');
          hasError = true;
        }
      }

      if (hasError) {
        formError?.classList.remove('hidden');
        resultBox?.classList.add('hidden');
        return;
      }

      try {
        const result = calculateDailyWage({
          mode: currentMode,
          amount,
          workingDaysPerMonth: workingDays,
          includeOt,
          weekdayOtHours: includeOt ? weekdayOtHours : 0,
          holidayWorkHours: includeOt ? holidayWorkHours : 0,
          holidayOtHours: includeOt ? holidayOtHours : 0,
          deductSocialSecurity: deductSso,
        });

        setText('res-net-income', formatMoney(result.netMonthlyIncome));
        setText('res-daily-wage', formatMoney(result.dailyWage));
        setText('res-monthly-wage', formatMoney(result.monthlyWage));
        setText('res-hourly-rate', formatMoney(result.hourlyRate));

        setText('res-base-monthly', formatMoney(result.monthlyWage));
        setText('res-total-income', formatMoney(result.totalMonthlyIncome));
        setText('res-net-income-bottom', formatMoney(result.netMonthlyIncome));

        if (includeOt) {
          setText('res-weekday-ot', `+${formatMoney(result.weekdayOtPay)}`);
          setText('res-holiday-work', `+${formatMoney(result.holidayWorkPay)}`);
          setText('res-holiday-ot', `+${formatMoney(result.holidayOtPay)}`);
          setText('res-total-ot', `+${formatMoney(result.totalOtPay)}`);
          showEl('ot-row-weekday');
          showEl('ot-row-holiday-work');
          showEl('ot-row-holiday-ot');
          showEl('ot-row-total');
        } else {
          hideEl('ot-row-weekday');
          hideEl('ot-row-holiday-work');
          hideEl('ot-row-holiday-ot');
          hideEl('ot-row-total');
        }

        if (deductSso) {
          setText('res-sso', `-${formatMoney(result.socialSecurityDeduction)}`);
          showEl('sso-row');
        } else {
          hideEl('sso-row');
        }

        resultBox?.classList.remove('hidden');
        resultBox?.scrollIntoView({ behavior: 'smooth', block: 'start' });

        if (typeof window.trackCalculatorComplete === 'function') {
          window.trackCalculatorComplete('daily_wage', result.netMonthlyIncome);
        }
      } catch (_error) {
        formError?.classList.remove('hidden');
        resultBox?.classList.add('hidden');
      }
    });
  </script>
</BaseLayout>
