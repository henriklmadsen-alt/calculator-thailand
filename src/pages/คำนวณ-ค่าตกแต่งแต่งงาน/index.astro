---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';

const pageTitle = 'คำนวณค่าตกแต่งแต่งงาน 2569 | ดอกไม้ ลูกโป่ง | Kamnuanlek';
const pageDescription = 'คำนวณค่าตกแต่ง ดอกไม้ การจัดเซ็นทรัลพีส สำหรับงานแต่งงาน ออนไลน์ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ค่าตกแต่งแต่งงาน/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าตกแต่งแต่งงาน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าตกแต่งแต่งงาน</h1>
    <div class="mb-4 inline-block rounded-lg border border-pink-200 bg-pink-50 px-3 py-2">
      <p class="text-xs font-semibold text-pink-800">[ค่าตกแต่ง 2569]</p>
    </div>
    <p class="text-gray-600 mb-6">คำนวณค่าตกแต่ง ดอกไม้ และแต่งเติมสำหรับงานแต่งงาน</p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="grid gap-4 sm:grid-cols-2 mb-6">
        <div>
          <label for="flowers" class="block text-sm font-medium text-gray-700 mb-1">ค่าดอกไม้/พวงหรี่ (บาท)</label>
          <input type="text" id="flowers" inputmode="decimal" placeholder="เช่น 60000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="centerpiece" class="block text-sm font-medium text-gray-700 mb-1">ค่าเซ็นทรัลพีส (บาท)</label>
          <input type="text" id="centerpiece" inputmode="decimal" placeholder="เช่น 30000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="balloon" class="block text-sm font-medium text-gray-700 mb-1">ค่าลูกโป่ง/ตกแต่ง (บาท)</label>
          <input type="text" id="balloon" inputmode="decimal" placeholder="เช่น 15000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
        <div>
          <label for="other-decor" class="block text-sm font-medium text-gray-700 mb-1">ค่าอื่นๆ (บาท)</label>
          <input type="text" id="other-decor" inputmode="decimal" placeholder="เช่น 10000" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-500 text-base" />
        </div>
      </div>
      <button type="button" id="btn-calculate" class="w-full sm:w-auto px-6 py-2 bg-pink-600 text-white font-semibold rounded-md hover:bg-pink-700 transition-colors text-base">คำนวณรวม</button>
      <div id="result" class="hidden mt-8 border-t pt-6">
        <div class="bg-pink-50 rounded-lg p-6 text-center">
          <div class="text-sm text-gray-600 mb-2">ค่าตกแต่งรวม</div>
          <div class="text-5xl font-bold text-pink-700"><span id="total">-</span></div>
          <div class="text-sm text-gray-600">บาท</div>
        </div>
      </div>
    </div>
    <RelatedCalculators />
    <RelatedArticles />
  </article>
</BaseLayout>

<script>
  document.getElementById('btn-calculate')?.addEventListener('click', () => {
    const flowers = parseFloat(document.getElementById('flowers')?.value || 0);
    const centerpiece = parseFloat(document.getElementById('centerpiece')?.value || 0);
    const balloon = parseFloat(document.getElementById('balloon')?.value || 0);
    const other = parseFloat(document.getElementById('other-decor')?.value || 0);
    const total = flowers + centerpiece + balloon + other;
    if (total === 0) { alert('กรุณาป้อนค่าใช้จ่าย'); return; }
    document.getElementById('total').textContent = total.toLocaleString('th-TH');
    document.getElementById('result').classList.remove('hidden');
  });
</script>
