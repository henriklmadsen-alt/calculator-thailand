---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณโบนัสประจำปี ปี 2569 เงินเดือน × เดือนโบนัส × สัดส่วนอายุงาน | Kamnuanlek';
const pageDescription = 'คำนวณโบนัสประจำปี จากเงินเดือน × จำนวนเดือนโบนัส × ตัวคูณตามอายุงาน พร้อมคำนวณสำหรับพนักงานที่ทำงานไม่ครบปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณโบนัสประจำปี/`;

const faqData = [
  {
    question: 'โบนัสประจำปีคำนวณอย่างไร?',
    answer: 'โบนัสประจำปี = เงินเดือน × จำนวนเดือนโบนัส × ตัวคูณ ตัวคูณสำหรับพนักงานที่ทำครบปี = 1.0 ส่วนพนักงานที่ทำไม่ครบปีจะได้รับตามสัดส่วนเดือนที่ทำงาน',
  },
  {
    question: 'พนักงานที่เข้างานกลางปีได้โบนัสไหม?',
    answer: 'ขึ้นอยู่กับนโยบายบริษัท โดยทั่วไปคิดตามสัดส่วน เช่น ทำงาน 6 เดือนได้ 50% ของโบนัสเต็ม แต่บางบริษัทกำหนดเงื่อนไขว่าต้องผ่านทดลองงานก่อน',
  },
  {
    question: 'โบนัสประจำปีต้องเสียภาษีไหม?',
    answer: 'โบนัสจากนายจ้างเดียวกับเงินเดือนจัดเป็นรายได้ 40(1) ต้องนำรวมกับเงินเดือนคำนวณภาษีเงินได้บุคคลธรรมดา',
  },
  {
    question: 'จำนวนเดือนโบนัสมาตรฐานในไทยเท่าไร?',
    answer: 'ไม่มีมาตรฐานตายตัว แต่โดยทั่วไปอยู่ที่ 1-3 เดือน ขึ้นอยู่กับผลประกอบการของบริษัทและระดับตำแหน่ง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณโบนัสประจำปี',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณโบนัสประจำปี">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">คำนวณโบนัสประจำปี รวมพนักงานที่ทำงานไม่ครบปี</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: เงินเดือน × เดือนโบนัส × (เดือนที่ทำงาน ÷ 12)</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับพนักงานและ HR ที่ต้องการตรวจสอบโบนัสประจำปี</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณโบนัสประจำปี ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือน จำนวนเดือนโบนัส และเดือนที่ทำงานในปีนี้ ระบบจะคำนวณโบนัสที่พึงได้รับ
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="annual-bonus-form" class="space-y-5">
        <p id="annual-bonus-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ab-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือน (บาท/เดือน)</label>
            <input type="text" id="ab-salary" inputmode="numeric" placeholder="เช่น 35,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ab-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="ab-bonus-months" class="mb-1 block text-sm font-medium text-gray-700">จำนวนเดือนโบนัส</label>
            <input type="text" id="ab-bonus-months" inputmode="decimal" placeholder="เช่น 2.5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ab-bonus-months-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="ab-months-worked" class="mb-1 block text-sm font-medium text-gray-700">เดือนที่ทำงานในปีนี้</label>
            <input type="text" id="ab-months-worked" inputmode="decimal" placeholder="เช่น 12 (ครบปี)"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="ab-months-worked-error" class="mt-1 hidden text-sm text-red-600"></p>
            <p class="mt-1 text-xs text-gray-500">กรอก 12 ถ้าทำงานครบทั้งปี</p>
          </div>
          <div>
            <label for="ab-perf-factor" class="mb-1 block text-sm font-medium text-gray-700">ตัวคูณผลงาน (ถ้ามี)</label>
            <input type="text" id="ab-perf-factor" inputmode="decimal" placeholder="เช่น 1.0 (ปกติ), 1.2 (ดีเยี่ยม)"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">ค่าเริ่มต้น 1.0 (ไม่มีตัวคูณพิเศษ)</p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณโบนัสประจำปี
        </button>
      </form>
    </div>

    <div id="annual-bonus-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">โบนัสที่ได้รับ</div>
            <div id="res-ab-bonus" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">โบนัสถ้าทำครบปี</div>
            <div id="res-ab-full" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">สัดส่วนที่ได้รับ</div>
            <div id="res-ab-ratio" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">เงินเดือน × เดือนโบนัส</span>
            <span id="res-ab-base" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ตัวคูณสัดส่วนอายุงาน</span>
            <span id="res-ab-factor" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>โบนัสเต็มปี = เงินเดือน × จำนวนเดือนโบนัส × ตัวคูณผลงาน</li>
        <li>ตัวคูณสัดส่วน = เดือนที่ทำงาน ÷ 12</li>
        <li>โบนัสจริง = โบนัสเต็มปี × ตัวคูณสัดส่วน</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณโบนัสการขาย/">คำนวณโบนัสการขาย</a></li>
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
        <li><a href="/คำนวณขึ้นเงินเดือน/">คำนวณขึ้นเงินเดือน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#annual-bonus-results" />
    <RelatedArticles currentHref="/คำนวณโบนัสประจำปี/" />
    <RelatedCalculators currentHref="/คำนวณโบนัสประจำปี/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ โบนัสจริงขึ้นอยู่กับนโยบายบริษัทและผลประกอบการประจำปี
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    const form = document.getElementById('annual-bonus-form');
    const formError = document.getElementById('annual-bonus-form-error');
    const resultBox = document.getElementById('annual-bonus-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['ab-salary-error','ab-bonus-months-error','ab-months-worked-error'].forEach((id) => setErr(id, ''));

      const salary = parseNum(document.getElementById('ab-salary').value);
      const bonusMonths = parseNum(document.getElementById('ab-bonus-months').value);
      const monthsWorked = parseNum(document.getElementById('ab-months-worked').value);
      const perfFactor = parseNum(document.getElementById('ab-perf-factor').value) || 1.0;

      let hasError = false;
      if (!Number.isFinite(salary) || salary <= 0) { setErr('ab-salary-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(bonusMonths) || bonusMonths <= 0) { setErr('ab-bonus-months-error', 'กรอกเดือนโบนัสมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(monthsWorked) || monthsWorked <= 0 || monthsWorked > 12) { setErr('ab-months-worked-error', 'กรอกเดือนที่ทำงาน 1-12 เดือน'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const fullBonus = salary * bonusMonths * perfFactor;
      const proRataFactor = monthsWorked / 12;
      const actualBonus = fullBonus * proRataFactor;

      setText('res-ab-bonus', formatMoney(actualBonus));
      setText('res-ab-full', formatMoney(fullBonus));
      setText('res-ab-ratio', `${(proRataFactor * 100).toFixed(1)}%`);
      setText('res-ab-base', formatMoney(salary * bonusMonths));
      setText('res-ab-factor', `${monthsWorked}/12 เดือน × ตัวคูณผลงาน ${perfFactor}`);

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
