---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณต้นทุนต่อทะเบียนรถรวม ปี 2569 พ.ร.บ. ประกันภัย ภาษีรถ | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณค่าใช้จ่ายรวมในการต่อทะเบียนรถประจำปี รวม พ.ร.บ. เบี้ยประกันภัย ภาษีรถ และค่าตรวจสภาพ';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนต่อทะเบียนรถรวม/`;

const faqData = [
  {
    question: 'ค่าต่อทะเบียนรถยนต์ประจำปีมีอะไรบ้าง?',
    answer: 'ค่าต่อทะเบียนรถประกอบด้วย 1) พ.ร.บ. ภาคบังคับ 2) ภาษีรถยนต์ประจำปี (ขึ้นอยู่กับ cc และน้ำหนัก) 3) ค่าตรวจสภาพรถ (สำหรับรถอายุมากกว่า 7 ปี) และ 4) ประกันภัยภาคสมัครใจ (ถ้าต้องการ)',
  },
  {
    question: 'ภาษีรถยนต์คิดจากอะไร?',
    answer: 'ภาษีรถยนต์คิดจากขนาดเครื่องยนต์ (cc) สำหรับรถเก๋ง และน้ำหนักรถสำหรับรถกระบะ รถที่ cc ต่ำกว่าและน้ำหนักเบากว่าจะเสียภาษีน้อยกว่า รถที่อายุมากกว่า 10 ปีอาจมีส่วนลด',
  },
  {
    question: 'ต่อทะเบียนรถสายได้หรือไม่?',
    answer: 'ต่อทะเบียนช้าจะมีค่าปรับ 1% ของภาษีรถประจำปีต่อเดือน และถ้าขับรถที่ทะเบียนหมดอายุมีโทษปรับไม่เกิน 2,000 บาท ควรต่อทะเบียนก่อนวันหมดอายุอย่างน้อย 1 เดือน',
  },
  {
    question: 'ต่อทะเบียนออนไลน์ได้หรือไม่?',
    answer: 'ได้ สามารถต่อทะเบียนรถออนไลน์ผ่านเว็บไซต์กรมการขนส่งทางบก (DLT Smart Queue) สำหรับรถที่ไม่ต้องตรวจสภาพ โดยต้องมี พ.ร.บ. และประกันภัยก่อน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนต่อทะเบียนรถรวม',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนต่อทะเบียนรถรวม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-orange-100 bg-orange-50 p-4">
      <p class="text-sm font-semibold text-orange-700">🔄 คำนวณต้นทุนต่อทะเบียนรถรวม</p>
      <p class="mt-1 text-sm text-slate-700">รวม: พ.ร.บ. + ภาษีรถ + ประกันภัย + ตรวจสภาพ (ถ้ามี)</p>
      <p class="mt-1 text-xs font-medium text-orange-800">รู้ค่าใช้จ่ายทั้งหมดก่อนต่อทะเบียนรถ</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณต้นทุนต่อทะเบียนรถรวม ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกข้อมูลรถเพื่อดูค่าใช้จ่ายทั้งหมดในการต่อทะเบียนประจำปี
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="renew-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="renew-type" class="mb-1 block text-sm font-medium text-gray-700">ประเภทรถ</label>
            <select id="renew-type" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
              <option value="car600">รถเก๋ง cc ≤ 600</option>
              <option value="car1800" selected>รถเก๋ง 601–1,800 cc</option>
              <option value="car2500">รถเก๋ง 1,801–2,500 cc</option>
              <option value="car3000">รถเก๋ง 2,501–3,000 cc</option>
              <option value="pickup">รถกระบะ (≤ 1,250 กก.)</option>
              <option value="motorcycle">มอเตอร์ไซค์</option>
            </select>
          </div>
          <div>
            <label for="renew-age" class="mb-1 block text-sm font-medium text-gray-700">อายุรถ (ปี)</label>
            <input type="text" id="renew-age" inputmode="numeric" placeholder="เช่น 5"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="renew-insurance" class="mb-1 block text-sm font-medium text-gray-700">เบี้ยประกันภัยสมัครใจ (บาท/ปี)</label>
            <input type="text" id="renew-insurance" inputmode="numeric" placeholder="0 ถ้าไม่ทำประกัน"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p class="mt-1 text-xs text-gray-500">ใส่ 0 ถ้าไม่ทำประกันภัยภาคสมัครใจ</p>
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-gray-700">ตรวจสภาพรถ (TIS)</label>
            <div class="mt-2 flex items-center gap-3">
              <label class="flex items-center gap-2 text-sm"><input type="radio" name="renew-tis" value="yes" class="text-primary-600" /> ต้องตรวจ (รถ >7 ปี)</label>
              <label class="flex items-center gap-2 text-sm"><input type="radio" name="renew-tis" value="no" checked class="text-primary-600" /> ไม่ต้องตรวจ</label>
            </div>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณค่าต่อทะเบียนรวม
        </button>
      </form>
    </div>

    <div id="renew-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">สรุปค่าใช้จ่ายต่อทะเบียน</h2>
        <div class="mb-4 space-y-2" id="renew-breakdown"></div>
        <div class="border-t pt-3">
          <div class="flex items-center justify-between text-lg font-bold">
            <span class="text-gray-900">รวมทั้งหมด</span>
            <span id="res-renew-total" class="text-primary-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">รายการค่าใช้จ่ายต่อทะเบียนรถ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>พ.ร.บ. (ภาคบังคับ) — ต้องทำก่อนต่อทะเบียน</li>
        <li>ภาษีรถยนต์ประจำปี — ขึ้นอยู่กับ cc/น้ำหนัก</li>
        <li>ประกันภัยสมัครใจ — ชั้น 1, 2+, 3+ ตามความต้องการ</li>
        <li>ตรวจสภาพรถ (TIS) — รถอายุมากกว่า 7 ปีต้องตรวจ ค่าตรวจ ~200–400 บาท</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#renew-results" />
    <RelatedArticles currentHref="/คำนวณต้นทุนต่อทะเบียนรถรวม/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนต่อทะเบียนรถรวม/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการประมาณการ อัตราภาษีและค่าธรรมเนียมอาจมีการเปลี่ยนแปลง ควรตรวจสอบกับกรมการขนส่งทางบก
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return 0;
      const n = Number(s);
      return Number.isFinite(n) && n >= 0 ? n : 0;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }

    // ภาษีรถ (บาท/ปี) ประมาณการ ปี 2569
    const taxRates = {
      car600: 300, car1800: 900, car2500: 1700, car3000: 2400,
      pickup: 350, motorcycle: 100,
    };
    // พ.ร.บ. (บาท รวม VAT แล้ว)
    const prbRates = {
      car600: 1035, car1800: 1035, car2500: 1035, car3000: 1035,
      pickup: 1035, motorcycle: 346,
    };

    document.getElementById('renew-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const type = document.getElementById('renew-type').value;
      const age = parseNum(document.getElementById('renew-age').value) || 0;
      const insurance = parseNum(document.getElementById('renew-insurance').value);
      const needTis = document.querySelector('input[name="renew-tis"]:checked').value === 'yes';
      const tisCost = needTis ? 350 : 0;

      const prb = prbRates[type];
      const tax = taxRates[type];
      const total = prb + tax + insurance + tisCost;

      const items = [
        { label: 'พ.ร.บ. (รวม VAT)', amount: prb },
        { label: `ภาษีรถยนต์ประจำปี`, amount: tax },
      ];
      if (insurance > 0) items.push({ label: 'เบี้ยประกันภัยสมัครใจ', amount: insurance });
      if (tisCost > 0) items.push({ label: 'ค่าตรวจสภาพรถ (TIS)', amount: tisCost });

      const container = document.getElementById('renew-breakdown');
      container.innerHTML = items.map(item => `
        <div class="flex justify-between text-sm">
          <span class="text-gray-600">${item.label}</span>
          <span class="font-medium text-gray-800">${formatMoney(item.amount)}</span>
        </div>`).join('');

      setText('res-renew-total', formatMoney(total));
      document.getElementById('renew-results').classList.remove('hidden');
      document.getElementById('renew-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
