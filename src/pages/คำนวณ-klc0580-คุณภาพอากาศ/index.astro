---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณต้นทุนคุณภาพอากาศ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนสุขภาพจากมลพิษอากาศ AQI มูลค่าการรักษา';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0580-คุณภาพอากาศ/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนคุณภาพอากาศ">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนคุณภาพอากาศ</h1>
    <div class="mb-4 inline-block rounded-lg border border-orange-200 bg-orange-50 px-3 py-2"><p class="text-xs font-semibold text-orange-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนสุขภาพจากมลพิษอากาศและค่ารักษาพยาบาล</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="aqi" class="block text-sm font-medium text-gray-700 mb-1">AQI (Air Quality Index)</label><input type="text" id="aqi" inputmode="numeric" placeholder="เช่น 150" value="150" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="days" class="block text-sm font-medium text-gray-700 mb-1">จำนวนวันต่อปี</label><input type="text" id="days" inputmode="numeric" placeholder="เช่น 200" value="200" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-orange-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-orange-50 rounded p-3"><p class="text-sm text-gray-600">ความเสี่ยงสุขภาพ</p><p id="risk" class="font-bold">-</p></div><div class="bg-red-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรักษาต่อปี</p><p id="cost" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const aqi = parseFloat((document.getElementById('aqi') as HTMLInputElement).value) || 0;
      const days = parseFloat((document.getElementById('days') as HTMLInputElement).value) || 0;
      const risk = aqi > 200 ? 'สูงมาก' : aqi > 150 ? 'สูง' : aqi > 100 ? 'ปานกลาง' : 'ต่ำ';
      const cost = aqi > 150 ? days * 500 : aqi > 100 ? days * 200 : days * 50;
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('risk') as HTMLElement).textContent = risk;
      (document.getElementById('cost') as HTMLElement).textContent = fmt(cost);
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('air-quality');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
