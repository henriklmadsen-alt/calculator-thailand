---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าทันตกรรม | Kamnuanlek';
const pageDescription = 'คำนวณค่าทันตกรรม ค่าอุดฟัน ถอนฟัน จัดฟัน รากฟันเทียม ตามอัตราโรงพยาบาลไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0403-ค่าทันตกรรม/`;

const faqData = [
  { question: 'ค่าจัดฟันในไทยประมาณเท่าไหร่?', answer: 'ค่าจัดฟันโลหะประมาณ 25,000-45,000 บาท จัดฟันใส (Invisalign) 80,000-150,000 บาท ขึ้นอยู่กับระยะเวลาและความซับซ้อน' },
  { question: 'ประกันสังคมครอบคลุมค่าทันตกรรมอะไรบ้าง?', answer: 'ผู้ประกันตนมาตรา 33 ได้รับสิทธิ์ค่าทันตกรรม 900 บาทต่อปี ครอบคลุมอุดฟัน ขูดหินปูน ถอนฟัน' },
  { question: 'รากฟันเทียมราคาเท่าไหร่?', answer: 'รากฟันเทียม (Dental Implant) ราคา 40,000-80,000 บาทต่อซี่ ขึ้นอยู่กับยี่ห้อ โรงพยาบาล และความยากของการผ่าตัด' },
  { question: 'ควรตรวจฟันบ่อยแค่ไหน?', answer: 'แนะนำตรวจฟันและขูดหินปูนทุก 6 เดือน เพื่อป้องกันปัญหาที่อาจมีค่าใช้จ่ายสูงในอนาคต' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าทันตกรรม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าทันตกรรม</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าทันตกรรมรวม อุดฟัน ถอนฟัน จัดฟัน ขูดหินปูน รากฟันเทียม</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="scaling" class="block text-sm font-medium text-gray-700 mb-1">ขูดหินปูน (บาท)</label><input type="text" id="scaling" inputmode="decimal" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="filling" class="block text-sm font-medium text-gray-700 mb-1">อุดฟัน (จำนวนซี่ × 500 บาท)</label><input type="number" id="filling" min="0" max="20" placeholder="เช่น 2" value="2" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="extraction" class="block text-sm font-medium text-gray-700 mb-1">ถอนฟัน (จำนวนซี่ × 300 บาท)</label><input type="number" id="extraction" min="0" max="10" placeholder="เช่น 1" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="braces" class="block text-sm font-medium text-gray-700 mb-1">ค่าจัดฟัน (บาท)</label><input type="text" id="braces" inputmode="decimal" placeholder="เช่น 35000" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="implant" class="block text-sm font-medium text-gray-700 mb-1">รากฟันเทียม (จำนวนซี่ × 50000 บาท)</label><input type="number" id="implant" min="0" max="10" placeholder="เช่น 0" value="0" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าบริการทั่วไป</p>
            <p id="basic_total" class="font-bold">-</p>
          </div>
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าจัดฟัน + รากเทียม</p>
            <p id="special_total" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">รวมค่าทันตกรรมทั้งหมด</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const scaling = parseFloat((document.getElementById('scaling') as HTMLInputElement).value) || 0;
      const filling = parseInt((document.getElementById('filling') as HTMLInputElement).value) || 0;
      const extraction = parseInt((document.getElementById('extraction') as HTMLInputElement).value) || 0;
      const braces = parseFloat((document.getElementById('braces') as HTMLInputElement).value) || 0;
      const implant = parseInt((document.getElementById('implant') as HTMLInputElement).value) || 0;

      const basicTotal = scaling + (filling * 500) + (extraction * 300);
      const specialTotal = braces + (implant * 50000);
      const total = basicTotal + specialTotal;

      (document.getElementById('basic_total') as HTMLElement).textContent = basicTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('special_total') as HTMLElement).textContent = specialTotal.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = total.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('dental-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
