---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่าส่งพัสดุ 2569 | เปรียบเทียบ ไปรษณีย์ไทย Kerry Flash J&T | Kamnuanlek';
const pageDescription = 'เครื่องคำนวณค่าส่งพัสดุ เปรียบเทียบราคา 4 ขนส่ง: ไปรษณีย์ไทย Kerry Express Flash Express J&T Express กรอกน้ำหนักและขนาดเพื่อหาตัวเลือกถูกที่สุด';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าส่งพัสดุ/`;

const faqData = [
  {
    question: 'น้ำหนักตามปริมาตร (Volumetric Weight) คืออะไร?',
    answer:
      'น้ำหนักตามปริมาตร = กว้าง × ยาว × สูง (ซม.) ÷ 5,000 ขนส่งจะคิดค่าส่งจากน้ำหนักจริงหรือน้ำหนักตามปริมาตร แล้วแต่ว่าอันไหนมากกว่า เพื่อให้สะท้อนพื้นที่จัดส่งจริง',
  },
  {
    question: 'ราคาที่แสดงเป็นราคาสุดท้ายหรือไม่?',
    answer:
      'ราคาที่แสดงเป็นการประมาณจากอัตราปกติ (walk-in rate) ราคาจริงอาจต่างออกไปตามโปรโมชัน สัญญาผู้ขาย หรือค่าบริการเพิ่มเติม เช่น COD หรือประกันภัย',
  },
  {
    question: 'ขนส่งไหนถูกที่สุดในปี 2569?',
    answer:
      'โดยทั่วไป Flash Express และ J&T Express มักมีราคาเริ่มต้นต่ำสุด ส่วนไปรษณีย์ไทย EMS มีข้อดีคือครอบคลุมทุกพื้นที่รวมทั้งพื้นที่ห่างไกล ขึ้นอยู่กับน้ำหนักและเส้นทาง',
  },
  {
    question: 'ส่งของจาก กทม. ไปต่างจังหวัด ใช้เวลากี่วัน?',
    answer:
      'ขนส่งเอกชน เช่น Kerry, Flash, J&T ส่งข้ามโซนส่วนใหญ่ใช้เวลา 2-3 วัน ไปรษณีย์ไทย EMS ข้ามโซนประมาณ 2-4 วัน พื้นที่ห่างไกลอาจนานกว่านี้',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าส่งพัสดุ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าส่งพัสดุ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">เปรียบเทียบค่าส่ง 4 ขนส่ง</p>
      <p class="mt-1 text-sm text-slate-700">ไปรษณีย์ไทย (EMS) · Kerry Express · Flash Express · J&T Express — ราคาประมาณการปี 2569</p>
      <p class="mt-1 text-xs font-medium text-sky-800">ราคาอ้างอิงอัตราปกติ อาจต่างจากโปรโมชันหรือสัญญาผู้ขาย</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณค่าส่งพัสดุ เปรียบเทียบ 4 ขนส่ง</h1>

    <p class="mb-6 text-gray-600">
      กรอกน้ำหนัก ขนาดพัสดุ และเส้นทาง เพื่อเปรียบเทียบค่าส่งจากไปรษณีย์ไทย Kerry Express Flash Express และ J&T Express
      พร้อมแสดงตัวเลือกถูกที่สุดและเร็วที่สุด
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="shipping-form" class="space-y-5">
        <p id="shipping-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลที่กรอกให้ครบถ้วน
        </p>

        <div>
          <label for="weight" class="mb-1 block text-sm font-medium text-gray-700">น้ำหนักพัสดุ (กิโลกรัม)</label>
          <input
            type="text"
            id="weight"
            inputmode="decimal"
            placeholder="เช่น 2.5"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
          <p id="weight-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div>
          <label class="mb-1 block text-sm font-medium text-gray-700">ขนาดพัสดุ (เซนติเมตร)</label>
          <div class="grid grid-cols-3 gap-3">
            <div>
              <input
                type="text"
                id="length"
                inputmode="decimal"
                placeholder="ยาว"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
              />
            </div>
            <div>
              <input
                type="text"
                id="width"
                inputmode="decimal"
                placeholder="กว้าง"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
              />
            </div>
            <div>
              <input
                type="text"
                id="height"
                inputmode="decimal"
                placeholder="สูง"
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
              />
            </div>
          </div>
          <p class="mt-1 text-xs text-gray-500">น้ำหนักตามปริมาตร = ยาว × กว้าง × สูง ÷ 5,000</p>
          <p id="dimensions-error" class="mt-1 hidden text-sm text-red-600"></p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="origin" class="mb-1 block text-sm font-medium text-gray-700">ต้นทาง</label>
            <select
              id="origin"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">เลือกต้นทาง</option>
              <option value="bangkok">กรุงเทพฯ / ปริมณฑล</option>
              <option value="province">ต่างจังหวัด</option>
            </select>
            <p id="origin-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="dest" class="mb-1 block text-sm font-medium text-gray-700">ปลายทาง</label>
            <select
              id="dest"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            >
              <option value="">เลือกปลายทาง</option>
              <option value="bangkok">กรุงเทพฯ / ปริมณฑล</option>
              <option value="province">ต่างจังหวัด</option>
            </select>
            <p id="dest-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button
          type="submit"
          id="shipping-submit-btn"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          กรอกข้อมูลให้ครบ
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการเปรียบเทียบค่าส่งพัสดุ</h2>

        <!-- Weight summary -->
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">น้ำหนักจริง</div>
            <div id="res-actual-weight" class="text-lg font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-sky-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">น้ำหนักตามปริมาตร</div>
            <div id="res-vol-weight" class="text-lg font-bold text-sky-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">น้ำหนักคิดค่าส่ง</div>
            <div id="res-charged-weight" class="text-lg font-bold text-amber-700">-</div>
          </div>
        </div>

        <!-- Route -->
        <div class="mb-6 flex items-center justify-between border-b border-gray-100 py-2 text-sm">
          <span class="text-gray-600">เส้นทาง</span>
          <span id="res-route" class="font-medium text-gray-900">-</span>
        </div>

        <!-- Best picks -->
        <div class="mb-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-lg border-2 border-green-200 bg-green-50 p-4">
            <div class="mb-1 text-xs font-semibold uppercase tracking-wide text-green-600">ถูกที่สุด</div>
            <div id="res-cheapest-name" class="text-base font-bold text-gray-900">-</div>
            <div id="res-cheapest-cost" class="mt-1 text-2xl font-extrabold text-green-700">-</div>
            <div id="res-cheapest-days" class="mt-1 text-sm text-gray-600">-</div>
          </div>
          <div class="rounded-lg border-2 border-blue-200 bg-blue-50 p-4">
            <div class="mb-1 text-xs font-semibold uppercase tracking-wide text-blue-600">เร็วที่สุด</div>
            <div id="res-fastest-name" class="text-base font-bold text-gray-900">-</div>
            <div id="res-fastest-cost" class="mt-1 text-2xl font-extrabold text-blue-700">-</div>
            <div id="res-fastest-days" class="mt-1 text-sm text-gray-600">-</div>
          </div>
        </div>

        <!-- Full comparison table -->
        <h3 class="mb-2 text-base font-semibold text-gray-900">เปรียบเทียบทุกขนส่ง</h3>
        <div class="overflow-x-auto rounded-md border border-gray-200">
          <table class="min-w-full text-sm">
            <thead class="bg-gray-50 text-gray-700">
              <tr>
                <th class="px-3 py-2 text-left font-medium">ขนส่ง</th>
                <th class="px-3 py-2 text-right font-medium">ค่าส่ง (บาท)</th>
                <th class="px-3 py-2 text-right font-medium">ระยะเวลา</th>
                <th class="hidden px-3 py-2 text-left font-medium sm:table-cell">หมายเหตุ</th>
              </tr>
            </thead>
            <tbody id="quotes-body" class="divide-y divide-gray-100 bg-white"></tbody>
          </table>
        </div>

        <p id="result-note" class="mt-4 rounded-md bg-sky-50 px-3 py-2 text-xs text-sky-800"></p>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">วิธีคำนวณค่าส่งพัสดุ</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>น้ำหนักตามปริมาตร = ยาว (ซม.) × กว้าง (ซม.) × สูง (ซม.) ÷ 5,000</li>
        <li>น้ำหนักคิดค่าส่ง = ค่ามากกว่าระหว่าง น้ำหนักจริง กับ น้ำหนักตามปริมาตร</li>
        <li>ค่าส่ง = อัตราตามขั้นน้ำหนักของแต่ละขนส่ง (เส้นทาง กทม. ↔ ต่างจังหวัด มีราคาต่างกัน)</li>
        <li>ขนส่งบางรายอาจมีค่าบริการเพิ่มเติม เช่น ค่า COD ค่าประกัน ค่ารับพัสดุถึงที่</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#results" />

    <RelatedArticles currentHref="/คำนวณค่าส่งพัสดุ/" />
    <RelatedCalculators currentHref="/คำนวณค่าส่งพัสดุ/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <section class="mb-8 rounded-lg border border-gray-200 bg-white p-4 text-sm text-gray-700 shadow-sm sm:p-6">
      <h2 class="mb-2 text-base font-semibold text-gray-900">แหล่งอ้างอิงทางการ</h2>
      <ul class="list-disc space-y-1 pl-5">
        <li><a href="https://www.thailandpost.co.th/index.php?page=index_fee" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">ไปรษณีย์ไทย — อัตราค่าบริการ EMS ในประเทศ</a></li>
        <li><a href="https://th.kerryexpress.com/th/rates/" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">Kerry Express — ตารางราคาค่าจัดส่ง</a></li>
        <li><a href="https://www.flashexpress.co.th/rates/" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">Flash Express — อัตราค่าจัดส่ง</a></li>
        <li><a href="https://www.jtexpress.co.th/service-rates" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">J&T Express — อัตราค่าบริการ</a></li>
      </ul>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>หมายเหตุสำคัญ:</strong> ราคาที่แสดงเป็นการประมาณจากอัตราปกติ (walk-in rate) ของแต่ละขนส่ง
      ราคาจริงอาจเปลี่ยนแปลงตามโปรโมชัน สัญญาผู้ขาย พื้นที่พิเศษ หรือค่าบริการเสริม (COD, ประกัน)
      กรุณาตรวจสอบราคากับขนส่งโดยตรงก่อนใช้งานจริง
    </div>
  </article>

  <script type="module">
    import { calculateShipping } from '../../lib/shipping-calculator';

    function parseNum(value) {
      const normalized = String(value).replace(/,/g, '').trim();
      if (normalized === '') return NaN;
      const n = Number(normalized);
      return Number.isFinite(n) ? n : NaN;
    }

    function fmtMoney(amount) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(amount)} บาท`;
    }

    function fmtWeight(kg) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(kg)} กก.`;
    }

    const form = document.getElementById('shipping-form');
    const submitBtn = document.getElementById('shipping-submit-btn');
    const formError = document.getElementById('shipping-form-error');
    const resultsDiv = document.getElementById('results');
    const quotesBody = document.getElementById('quotes-body');

    const fields = {
      weight: document.getElementById('weight'),
      length: document.getElementById('length'),
      width: document.getElementById('width'),
      height: document.getElementById('height'),
      origin: document.getElementById('origin'),
      dest: document.getElementById('dest'),
    };

    function setFieldError(id, message) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = message;
      el.classList.remove('hidden');
    }

    function clearFieldError(id) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = '';
      el.classList.add('hidden');
    }

    function clearValidation() {
      formError.classList.add('hidden');
      ['weight-error', 'dimensions-error', 'origin-error', 'dest-error'].forEach(clearFieldError);
    }

    function updateSubmitState() {
      const weight = parseNum(fields.weight.value);
      const length = parseNum(fields.length.value);
      const width = parseNum(fields.width.value);
      const height = parseNum(fields.height.value);
      const origin = fields.origin.value;
      const dest = fields.dest.value;

      const ready =
        Number.isFinite(weight) && weight > 0 &&
        Number.isFinite(length) && length > 0 &&
        Number.isFinite(width) && width > 0 &&
        Number.isFinite(height) && height > 0 &&
        origin !== '' && dest !== '';

      submitBtn.disabled = !ready;
      submitBtn.textContent = ready ? 'คำนวณค่าส่ง' : 'กรอกข้อมูลให้ครบ';
      submitBtn.classList.toggle('cursor-not-allowed', !ready);
      submitBtn.classList.toggle('opacity-70', !ready);
    }

    Object.values(fields).forEach((field) => {
      field.addEventListener('input', () => { clearValidation(); updateSubmitState(); });
      field.addEventListener('change', () => { clearValidation(); updateSubmitState(); });
    });

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    updateSubmitState();

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      clearValidation();

      const weight = parseNum(fields.weight.value);
      const length = parseNum(fields.length.value);
      const width = parseNum(fields.width.value);
      const height = parseNum(fields.height.value);
      const origin = fields.origin.value;
      const dest = fields.dest.value;

      const validity = {
        weight: Number.isFinite(weight) && weight > 0 && weight <= 50,
        dimensions: Number.isFinite(length) && length > 0 &&
                    Number.isFinite(width) && width > 0 &&
                    Number.isFinite(height) && height > 0,
        origin: origin === 'bangkok' || origin === 'province',
        dest: dest === 'bangkok' || dest === 'province',
      };

      if (!validity.weight) setFieldError('weight-error', 'กรุณากรอกน้ำหนักระหว่าง 0.01 - 50 กก.');
      if (!validity.dimensions) setFieldError('dimensions-error', 'กรุณากรอกขนาดพัสดุให้ครบทั้ง 3 ด้าน (มากกว่า 0)');
      if (!validity.origin) setFieldError('origin-error', 'กรุณาเลือกต้นทาง');
      if (!validity.dest) setFieldError('dest-error', 'กรุณาเลือกปลายทาง');

      if (!Object.values(validity).every(Boolean)) {
        formError.classList.remove('hidden');
        updateSubmitState();
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังคำนวณ...';
      trackCalculatorStart('shipping_cost');

      const result = calculateShipping({
        weightKg: weight,
        lengthCm: length,
        widthCm: width,
        heightCm: height,
        originZone: origin,
        destZone: dest,
      });

      // Weight summary
      setText('res-actual-weight', fmtWeight(result.actualWeight));
      setText('res-vol-weight', fmtWeight(result.volumetricWeight));
      setText('res-charged-weight', fmtWeight(result.chargedWeight));
      setText('res-route', result.route);

      // Best picks
      setText('res-cheapest-name', result.cheapest.carrierNameTh);
      setText('res-cheapest-cost', fmtMoney(result.cheapest.cost));
      setText('res-cheapest-days', `จัดส่ง ${result.cheapest.deliveryDays}`);

      setText('res-fastest-name', result.fastest.carrierNameTh);
      setText('res-fastest-cost', fmtMoney(result.fastest.cost));
      setText('res-fastest-days', `จัดส่ง ${result.fastest.deliveryDays}`);

      // Comparison table
      quotesBody.innerHTML = '';
      result.quotes.forEach((q, i) => {
        const isCheapest = q.carrierId === result.cheapest.carrierId;
        const row = document.createElement('tr');
        if (isCheapest) row.classList.add('bg-green-50');
        row.innerHTML = `
          <td class="px-3 py-2 text-gray-700">
            <span class="font-medium">${q.carrierNameTh}</span>
            ${isCheapest ? '<span class="ml-1 inline-block rounded bg-green-100 px-1.5 py-0.5 text-[10px] font-semibold text-green-700">ถูกสุด</span>' : ''}
          </td>
          <td class="px-3 py-2 text-right font-semibold text-gray-900">${new Intl.NumberFormat('th-TH').format(q.cost)}</td>
          <td class="px-3 py-2 text-right text-gray-700">${q.deliveryDays}</td>
          <td class="hidden px-3 py-2 text-gray-500 sm:table-cell">${q.note}</td>
        `;
        quotesBody.appendChild(row);
      });

      const volNote = result.volumetricWeight > result.actualWeight
        ? `น้ำหนักตามปริมาตร (${fmtWeight(result.volumetricWeight)}) มากกว่าน้ำหนักจริง จึงใช้น้ำหนักตามปริมาตรคิดค่าส่ง`
        : `น้ำหนักจริง (${fmtWeight(result.actualWeight)}) มากกว่าหรือเท่ากับน้ำหนักตามปริมาตร จึงใช้น้ำหนักจริงคิดค่าส่ง`;
      setText('result-note', volNote);

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });

      submitBtn.disabled = false;
      submitBtn.textContent = 'คำนวณค่าส่ง';
      trackCalculatorComplete('shipping_cost', result.cheapest.cost);
      trackCalculatorUsed('shipping_cost');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          trackResultViewed('shipping_cost');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
