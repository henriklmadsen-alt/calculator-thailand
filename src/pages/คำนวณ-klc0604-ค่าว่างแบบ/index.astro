---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่าว่างแบบ | Calculator Thailand';
const pageDescription = 'คำนวณค่าจ้างวุฒิบัตรยา พยาบาล สำหรับลูกบุณฑริก';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0604-ค่าว่างแบบ/`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าว่างแบบ">
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่าว่างแบบ</h1>
    <div class="mb-4 inline-block rounded-lg border border-teal-200 bg-teal-50 px-3 py-2"><p class="text-xs font-semibold text-teal-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าจ้างคนดูแลเด็ก พยาบาลในบ้าน ตามอัตรา ร.ป.ท.</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="hours_per_day" class="block text-sm font-medium text-gray-700 mb-1">ชั่วโมงต่อวัน (ชั่วโมง)</label><input type="number" id="hours_per_day" min="1" max="24" placeholder="เช่น 8" value="8" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="rate_per_hour" class="block text-sm font-medium text-gray-700 mb-1">ค่าจ้างต่อชั่วโมง (บาท)</label><input type="text" id="rate_per_hour" inputmode="decimal" placeholder="เช่น 200" value="200" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="days_per_week" class="block text-sm font-medium text-gray-700 mb-1">จำนวนวันต่อสัปดาห์</label><input type="number" id="days_per_week" min="1" max="7" placeholder="เช่น 6" value="6" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="weeks" class="block text-sm font-medium text-gray-700 mb-1">ระยะเวลา (สัปดาห์)</label><input type="number" id="weeks" min="1" max="52" placeholder="เช่น 52" value="52" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-teal-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-teal-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าจ้างต่อวัน</p>
            <p id="daily" class="font-bold">-</p>
          </div>
          <div class="bg-teal-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าจ้างต่อสัปดาห์</p>
            <p id="weekly" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">ค่าจ้างรวม</p>
            <p id="total" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ค่าจ้างพยาบาลในบ้านเท่าไหร่ต่อชั่วโมง?</h3>
            <p class="text-gray-600 text-sm">ตามสภาคณาแพทยสมาคม ค่าจ้างพยาบาลโดยทั่วไป 150-300 บาท/ชั่วโมง ขึ้นอยู่กับประสบการณ์และวุฒิ</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">ต้องเสียภาษี สลากหรือไม่?</h3>
            <p class="text-gray-600 text-sm">ใช่ หากจ่ายจำนวนเกิน 5,000 บาท/เดือน ต้องออกหนังสือให้ค่าบริการและหักภาษี 3%</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-2">สามารถนำหักลดหย่อนภาษีได้หรือไม่?</h3>
            <p class="text-gray-600 text-sm">ขึ้นอยู่กับประเภทเสียภาษี หากผู้ดูแลเป็นคนไทยและมีใบประกาศตัว สามารถนำหักเป็นค่าใช้จ่ายได้</p>
          </div>
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const hoursPerDay = parseInt((document.getElementById('hours_per_day') as HTMLInputElement).value) || 8;
      const ratePerHour = parseFloat((document.getElementById('rate_per_hour') as HTMLInputElement).value) || 0;
      const daysPerWeek = parseInt((document.getElementById('days_per_week') as HTMLInputElement).value) || 6;
      const weeks = parseInt((document.getElementById('weeks') as HTMLInputElement).value) || 52;

      const dailyWage = hoursPerDay * ratePerHour;
      const weeklyWage = dailyWage * daysPerWeek;
      const totalWage = weeklyWage * weeks;

      (document.getElementById('daily') as HTMLElement).textContent = dailyWage.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('weekly') as HTMLElement).textContent = weeklyWage.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('total') as HTMLElement).textContent = totalWage.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('caregiver-wages');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
