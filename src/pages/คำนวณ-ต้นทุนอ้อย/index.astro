---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณต้นทุนการปลูกอ้อย | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการปลูกอ้อย ต้นทุนพื้นที่ ชลประทาน ผลผลิต รายได้';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-ต้นทุนอ้อย/`;

const faqData = [
  { question: 'ใช้เครื่องคำนวณนี้อย่างไร?', answer: 'กรอกข้อมูลที่ต้องการในช่องที่กำหนด แล้วกดปุ่มคำนวณ ผลลัพธ์จะแสดงทันทีพร้อมรายละเอียด' },
  { question: 'ผลลัพธ์ที่ได้ถูกต้องแค่ไหน?', answer: 'เครื่องคำนวณใช้สูตรมาตรฐานและข้อมูลอัปเดต ผลลัพธ์เป็นการประมาณการเพื่อช่วยวางแผน ควรปรึกษาผู้เชี่ยวชาญสำหรับการตัดสินใจสำคัญ' },
  { question: 'ข้อมูลที่ใช้คำนวณมาจากไหน?', answer: 'อิงจากกฎหมายและระเบียบปัจจุบันของประเทศไทย อัตราที่ประกาศโดยหน่วยงานรัฐ และสูตรมาตรฐานที่ใช้กันทั่วไป' },
  { question: 'มีค่าใช้จ่ายในการใช้งานไหม?', answer: 'ใช้งานฟรีทั้งหมด ไม่ต้องสมัครสมาชิก ไม่มีค่าธรรมเนียม เครื่องคำนวณทั้งหมดบน Kamnuanlek ให้บริการฟรี' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนอ้อย">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนการปลูกอ้อย</h1>
    <div class="mb-4 inline-block rounded-lg border border-lime-200 bg-lime-50 px-3 py-2"><p class="text-xs font-semibold text-lime-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนการปลูกอ้อย ต้นทุนพื้นที่ ชลประทาน ผลผลิต</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="rai" class="block text-sm font-medium text-gray-700 mb-1">ขนาดที่ดิน (ไร่)</label><input type="text" id="rai" inputmode="decimal" placeholder="เช่น 10" value="10" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div class="flex items-center"><input type="checkbox" id="irrigated" checked class="h-4 w-4 border-gray-300 text-primary-600" /><label for="irrigated" class="ml-2 text-sm text-gray-700">มีระบบชลประทาน</label></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-primary-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2"><div class="grid grid-cols-2 gap-2"><div class="bg-blue-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวม</p><p id="cost" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ผลผลิต</p><p id="yield" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">รายได้</p><p id="income" class="font-bold">-</p></div><div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">กำไร</p><p id="profit" class="font-bold">-</p></div></div></div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const rai = parseFloat((document.getElementById('rai') as HTMLInputElement).value) || 0;
      const irrigated = (document.getElementById('irrigated') as HTMLInputElement).checked;
      if (rai <= 0) return;
      const baseCost = rai * 10000, waterCost = irrigated ? rai * 800 : 0;
      const totalCost = baseCost + waterCost;
      const yieldPerRai = 5000, yield_ = rai * yieldPerRai, pricePerTon = 850, income = (yield_ / 1000) * pricePerTon, profit = income - totalCost;
      const fmt = (n: number) => new Intl.NumberFormat('th-TH', { style: 'currency', currency: 'THB', maximumFractionDigits: 0 }).format(n);
      (document.getElementById('cost') as HTMLElement).textContent = fmt(totalCost);
      (document.getElementById('yield') as HTMLElement).textContent = Math.round(yield_) + ' กก.';
      (document.getElementById('income') as HTMLElement).textContent = fmt(income);
      (document.getElementById('profit') as HTMLElement).textContent = fmt(profit);
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('sugarcane-farming');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
