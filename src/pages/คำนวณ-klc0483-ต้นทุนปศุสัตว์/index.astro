---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';
const pageTitle = 'คำนวณต้นทุนการเลี้ยงปศุสัตว์ | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนการเลี้ยงปศุสัตว์ วัว หมู ไก่ อาหารสัตว์ ค่ายา ค่าแรง กำไรต่อตัว';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0483-ต้นทุนปศุสัตว์/`;
const faqData = [
  { question: 'ต้นทุนการเลี้ยงไก่เนื้อต่อตัวเฉลี่ยเท่าไหร่?', answer: 'ต้นทุนไก่เนื้อ 55-65 บาท/กก. น้ำหนักมีชีวิต รอบการเลี้ยง 42 วัน น้ำหนักเฉลี่ย 2.2 กก./ตัว ต้นทุนรวมประมาณ 121-143 บาท/ตัว' },
  { question: 'ราคาอาหารสัตว์คิดเป็นกี่เปอร์เซ็นต์ของต้นทุน?', answer: 'อาหารสัตว์คิดเป็น 60-75% ของต้นทุนการเลี้ยง การบริหารจัดการอาหารที่ดีจึงสำคัญที่สุด Feed Conversion Ratio (FCR) ยิ่งต่ำยิ่งประหยัด' },
  { question: 'การทำสัญญากับบริษัทอินทีเกรต (Contract Farming) ดีไหม?', answer: 'อินทีเกรตให้ความมั่นคงด้านราคาและตลาด ลดความเสี่ยง แต่กำไรอาจต่ำกว่าเลี้ยงอิสระ เหมาะผู้เริ่มต้น มีบ้านเรือน เงินลงทุนน้อย' },
  { question: 'ปศุสัตว์ที่ให้ผลตอบแทนดีที่สุดคืออะไร?', answer: 'ไก่ไข่ให้ผลตอบแทนสม่ำเสมอ ไก่เนื้อคืนทุนเร็ว 45-60 วัน สุกรให้กำไรสูงแต่ลงทุนมาก โคเนื้อใช้เวลานาน 2-3 ปี แต่ราคาตลาดสูง' }
];
const jsonLdFaq = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqData.map((faq) => ({ '@type': 'Question', name: faq.question, acceptedAnswer: { '@type': 'Answer', text: faq.answer } })) };
---
<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนการเลี้ยงปศุสัตว์">  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณต้นทุนการเลี้ยงปศุสัตว์</h1>
    <div class="mb-4 inline-block rounded-lg border border-green-200 bg-green-50 px-3 py-2"><p class="text-xs font-semibold text-green-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณต้นทุนและกำไรการเลี้ยงปศุสัตว์ต่อรอบการผลิต</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="livestock_count" class="block text-sm font-medium text-gray-700 mb-1">จำนวนสัตว์ (ตัว)</label><input type="number" id="livestock_count" min="1" placeholder="เช่น 1000" value="1000" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="feed_cost_head" class="block text-sm font-medium text-gray-700 mb-1">ค่าอาหารสัตว์ต่อตัว (บาท)</label><input type="text" id="feed_cost_head" inputmode="decimal" placeholder="เช่น 80" value="80" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="vet_cost_head" class="block text-sm font-medium text-gray-700 mb-1">ค่ายาและวัคซีนต่อตัว (บาท)</label><input type="text" id="vet_cost_head" inputmode="decimal" placeholder="เช่น 15" value="15" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="livestock_sell_price" class="block text-sm font-medium text-gray-700 mb-1">ราคาขายต่อตัว (บาท)</label><input type="text" id="livestock_sell_price" inputmode="decimal" placeholder="เช่น 130" value="130" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-green-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-green-50 rounded p-3"><p class="text-sm text-gray-600">ต้นทุนรวมทั้งฝูง</p><p id="livestock_total_cost" class="font-bold">-</p></div>
          <div class="bg-emerald-50 rounded p-3"><p class="text-sm text-gray-600">กำไรรวมต่อรอบ</p><p id="livestock_profit" class="font-bold text-lg">-</p></div>
        </div>
      </div>
    </div>
    <div class="mt-8 bg-gray-50 rounded-lg p-4 sm:p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
      <div class="space-y-4">{faqData.map((faq) => (<div><h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3><p class="text-gray-600 text-sm">{faq.answer}</p></div>))}</div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const count = parseFloat((document.getElementById('livestock_count') as HTMLInputElement).value) || 0;
      const feed = parseFloat((document.getElementById('feed_cost_head') as HTMLInputElement).value) || 0;
      const vet = parseFloat((document.getElementById('vet_cost_head') as HTMLInputElement).value) || 0;
      const sellPrice = parseFloat((document.getElementById('livestock_sell_price') as HTMLInputElement).value) || 0;
      const costPerHead = feed + vet;
      const totalCost = costPerHead * count;
      const totalRevenue = sellPrice * count;
      const profit = totalRevenue - totalCost;
      (document.getElementById('livestock_total_cost') as HTMLElement).textContent = Math.round(totalCost).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('livestock_profit') as HTMLElement).textContent = Math.round(profit).toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('livestock-cost');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
