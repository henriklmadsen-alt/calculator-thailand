---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import PublicTrustPanel from '../../components/templates/PublicTrustPanel.astro';

const pageTitle = 'คำนวณวันตกไข่ 2569 | วันไข่ตก ช่วงเวลาเจริญพันธุ์ ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณวันตกไข่และช่วงเวลาเจริญพันธุ์ (Fertile Window) จากวันแรกของประจำเดือนครั้งสุดท้ายและความยาวรอบเดือน เครื่องมือวางแผนครอบครัวออนไลน์ฟรี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณวันตกไข่/`;

const faqData = [
  {
    question: 'วันตกไข่คืออะไร?',
    answer: 'วันตกไข่ (Ovulation) คือวันที่รังไข่ปล่อยไข่ออกมา พร้อมให้อสุจิปฏิสนธิ โดยทั่วไปเกิดขึ้นประมาณ 14 วันก่อนวันแรกของประจำเดือนรอบถัดไป ไข่ที่ถูกปล่อยออกมาจะมีชีวิตอยู่ได้ประมาณ 12-24 ชั่วโมง',
  },
  {
    question: 'ช่วงเวลาเจริญพันธุ์ (Fertile Window) คืออะไร?',
    answer: 'ช่วงเวลาเจริญพันธุ์คือช่วงที่มีโอกาสตั้งครรภ์สูงที่สุด โดยทั่วไปคือ 5 วันก่อนวันตกไข่และวันตกไข่เอง รวม 6 วัน เนื่องจากอสุจิสามารถมีชีวิตอยู่ในร่างกายได้นานถึง 5 วัน',
  },
  {
    question: 'รอบเดือนไม่สม่ำเสมอ ใช้เครื่องมือนี้ได้ไหม?',
    answer: 'ได้ แต่ผลลัพธ์จะเป็นค่าประมาณเท่านั้น เครื่องมือนี้คำนวณจากความยาวรอบเดือนเฉลี่ยที่คุณระบุ หากรอบเดือนไม่สม่ำเสมอมาก ควรปรึกษาแพทย์หรือใช้ร่วมกับการตรวจชุดทดสอบตกไข่ (OPK)',
  },
  {
    question: 'ผลคำนวณตรงเสมอหรือไม่?',
    answer: 'ไม่เสมอไป สูตรนี้เป็นค่าประมาณทางสถิติ วันตกไข่จริงอาจเปลี่ยนแปลงได้จากปัจจัยหลายอย่าง เช่น ความเครียด การเจ็บป่วย หรือการเปลี่ยนแปลงของฮอร์โมน ควรใช้ร่วมกับการสังเกตอาการร่างกายและ/หรือชุดทดสอบตกไข่',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณวันตกไข่และช่วงเวลาเจริญพันธุ์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณวันตกไข่">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-pink-100 bg-pink-50 p-4">
      <p class="text-sm font-semibold text-pink-700">คำนวณวันตกไข่และช่วงเจริญพันธุ์ใน 1 หน้า</p>
      <p class="mt-1 text-sm text-slate-700">ระบุวันแรกของประจำเดือนครั้งสุดท้ายและความยาวรอบเดือน เพื่อดูวันตกไข่โดยประมาณและช่วงเวลาที่มีโอกาสตั้งครรภ์สูงสุด</p>
      <p class="mt-1 text-xs font-medium text-pink-800">ผลลัพธ์เป็นค่าประมาณเพื่อวางแผนเบื้องต้น</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณวันตกไข่ 2569 (Ovulation Calculator)
    </h1>

    <p class="text-gray-600 mb-6">
      ใช้เครื่องมือนี้เพื่อคาดการณ์วันตกไข่และช่วงเวลาเจริญพันธุ์ (Fertile Window) จากวันแรกของประจำเดือนครั้งสุดท้าย
      ช่วยวางแผนครอบครัว ไม่ว่าจะต้องการมีบุตรหรือต้องการหลีกเลี่ยงการตั้งครรภ์
    </p>

    <PublicTrustPanel
      lastUpdated="20 เม.ย. 2569"
      sources={[
        'American College of Obstetricians and Gynecologists (ACOG)',
        'NHS: How can I tell when I\'m ovulating?',
        'Mayo Clinic: Getting pregnant — Ovulation',
      ]}
      assumptions={[
        'ใช้เป็นการประเมินเบื้องต้น ไม่ใช่การวินิจฉัยทางการแพทย์',
        'สูตรคำนวณอ้างอิงจากค่าเฉลี่ยทางสถิติ วันตกไข่จริงอาจแตกต่างได้',
      ]}
      references={[
        {
          label: 'ACOG: Fertility Awareness-Based Methods',
          href: 'https://www.acog.org/womens-health/faqs/fertility-awareness-based-methods-of-family-planning',
        },
        {
          label: 'NHS: How can I tell when I\'m ovulating?',
          href: 'https://www.nhs.uk/common-health-questions/womens-health/how-can-i-tell-when-i-am-ovulating/',
        },
        {
          label: 'Mayo Clinic: Getting pregnant',
          href: 'https://www.mayoclinic.org/healthy-lifestyle/getting-pregnant/in-depth/how-to-get-pregnant/art-20047611',
        },
      ]}
    />

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="ovulation-form" class="space-y-5">
        <p id="ov-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณากรอกข้อมูลให้ครบและถูกต้อง
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="lmp-date" class="block text-sm font-medium text-gray-700 mb-1">
              วันแรกของประจำเดือนครั้งสุดท้าย (LMP)
            </label>
            <input
              id="lmp-date"
              type="date"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p id="lmp-date-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>

          <div>
            <label for="cycle-length" class="block text-sm font-medium text-gray-700 mb-1">
              ความยาวรอบเดือน (วัน)
            </label>
            <input
              id="cycle-length"
              type="text"
              inputmode="numeric"
              value="28"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
            <p class="mt-1 text-xs text-gray-500">ค่ามาตรฐาน 28 วัน ปรับได้ตามรอบเดือนจริง (21-45 วัน)</p>
            <p id="cycle-length-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div>
          <label for="num-cycles" class="block text-sm font-medium text-gray-700 mb-1">
            จำนวนรอบเดือนที่ต้องการดูล่วงหน้า
          </label>
          <select
            id="num-cycles"
            class="w-full sm:w-auto rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500"
          >
            <option value="1">1 รอบ</option>
            <option value="3" selected>3 รอบ</option>
            <option value="6">6 รอบ</option>
          </select>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
        >
          คำนวณวันตกไข่
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="ov-results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <!-- Current cycle highlight -->
        <div class="grid gap-3 sm:grid-cols-3 mb-6">
          <div class="rounded-lg bg-pink-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">วันตกไข่โดยประมาณ (รอบถัดไป)</div>
            <div id="res-ovulation-date" class="text-lg font-bold text-pink-700">-</div>
          </div>
          <div class="rounded-lg bg-rose-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ช่วงเจริญพันธุ์</div>
            <div id="res-fertile-window" class="text-lg font-bold text-rose-700">-</div>
          </div>
          <div class="rounded-lg bg-violet-50 p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">ประจำเดือนรอบถัดไป (ประมาณ)</div>
            <div id="res-next-period" class="text-lg font-bold text-violet-700">-</div>
          </div>
        </div>

        <!-- Multi-cycle table -->
        <div id="ov-multi-cycle" class="overflow-x-auto">
          <h3 class="text-base font-semibold text-gray-900 mb-3">ปฏิทินวันตกไข่ล่วงหน้า</h3>
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left border-b-2 border-gray-300">
                <th class="py-2 pr-4">รอบที่</th>
                <th class="py-2 pr-4">ประจำเดือนเริ่ม</th>
                <th class="py-2 pr-4">ช่วงเจริญพันธุ์</th>
                <th class="py-2 pr-4">วันตกไข่</th>
                <th class="py-2">ประจำเดือนถัดไป</th>
              </tr>
            </thead>
            <tbody id="ov-cycle-rows"></tbody>
          </table>
        </div>

        <!-- Summary details -->
        <div class="mt-6 space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ความยาวรอบเดือนที่ใช้คำนวณ</span>
            <span id="res-cycle-length" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">Luteal Phase ที่ใช้คำนวณ</span>
            <span id="res-luteal" class="font-medium">14 วัน</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">วันตกไข่ = วันแรกประจำเดือน + (รอบเดือน - 14)</span>
            <span class="font-medium text-gray-500">สูตรมาตรฐาน</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Next action CTA -->
    <div id="ov-next-action" class="hidden mb-6 rounded-xl border border-primary-200 bg-primary-50 p-4">
      <p class="text-sm font-semibold text-primary-800">วางแผนต่อ: เตรียมตัวสำหรับการตั้งครรภ์</p>
      <p class="mt-1 text-sm text-primary-700">เมื่อทราบวันตกไข่แล้ว คุณสามารถคำนวณวันกำหนดคลอดหรือประเมินค่าใช้จ่ายที่เกี่ยวข้องได้</p>
      <div class="mt-3 flex flex-wrap gap-3">
        <a data-next-action-link href="/คำนวณวันคลอด/" data-preserve-utm class="inline-flex min-h-11 items-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white hover:bg-primary-700">ทำต่อ: คำนวณวันคลอด</a>
        <a data-next-action-link href="/คำนวณค่าคลอดบุตร/" data-preserve-utm class="inline-flex min-h-11 items-center rounded-lg border border-primary-300 bg-white px-4 py-2 text-sm font-semibold text-primary-700 hover:border-primary-400">ประเมิน: ค่าคลอดบุตร</a>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#ov-next-action" />

    <!-- SEO Content -->
    <section class="mb-8 bg-white rounded-lg border border-gray-200 p-4 sm:p-6 prose prose-slate max-w-none">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วันตกไข่คืออะไร? ทำไมต้องคำนวณ?</h2>
      <p>
        วันตกไข่ (Ovulation) คือวันที่รังไข่ปล่อยไข่ที่สุกแล้วเข้าสู่ท่อนำไข่ เพื่อรอการปฏิสนธิกับอสุจิ
        การรู้วันตกไข่เป็นเรื่องสำคัญสำหรับทั้งผู้ที่ต้องการมีบุตรและผู้ที่ต้องการคุมกำเนิดแบบธรรมชาติ
        เพราะช่วงเวลาเจริญพันธุ์ (Fertile Window) มีเพียงไม่กี่วันในแต่ละรอบเดือน
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">สูตรคำนวณวันตกไข่</h3>
      <div class="bg-gray-50 rounded-lg p-4 text-center my-4">
        <p class="text-lg font-semibold">วันตกไข่ = วันแรกของประจำเดือน + (ความยาวรอบเดือน - 14 วัน)</p>
      </div>
      <p class="text-sm text-gray-600">
        สูตรนี้อ้างอิงจากหลักการที่ว่า Luteal Phase (ระยะหลังตกไข่ถึงวันเริ่มประจำเดือนรอบถัดไป)
        มีความยาวค่อนข้างคงที่ประมาณ 14 วัน ตามแนวทาง ACOG และ NHS
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ช่วงเวลาเจริญพันธุ์ (Fertile Window)</h3>
      <p>
        อสุจิสามารถมีชีวิตอยู่ในระบบสืบพันธุ์เพศหญิงได้นานถึง 5 วัน ขณะที่ไข่มีอายุเพียง 12-24 ชั่วโมงหลังตกไข่
        ดังนั้นช่วงเวลาเจริญพันธุ์จึงรวมถึง 5 วันก่อนวันตกไข่และวันตกไข่เอง รวมทั้งหมด 6 วัน
      </p>

      <div class="overflow-x-auto my-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left border-b-2 border-gray-300">
              <th class="py-2 pr-4">ความยาวรอบเดือน</th>
              <th class="py-2 pr-4">วันตกไข่โดยประมาณ (นับจากวันแรกของประจำเดือน)</th>
              <th class="py-2">ช่วงเจริญพันธุ์</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">21 วัน</td>
              <td class="py-2 pr-4">วันที่ 7</td>
              <td class="py-2">วันที่ 2-7</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">25 วัน</td>
              <td class="py-2 pr-4">วันที่ 11</td>
              <td class="py-2">วันที่ 6-11</td>
            </tr>
            <tr class="border-b border-gray-100 bg-green-50">
              <td class="py-2 pr-4 font-medium">28 วัน (มาตรฐาน)</td>
              <td class="py-2 pr-4 font-medium">วันที่ 14</td>
              <td class="py-2 font-medium">วันที่ 9-14</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">30 วัน</td>
              <td class="py-2 pr-4">วันที่ 16</td>
              <td class="py-2">วันที่ 11-16</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-2 pr-4">35 วัน</td>
              <td class="py-2 pr-4">วันที่ 21</td>
              <td class="py-2">วันที่ 16-21</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">อาการที่บอกว่ากำลังตกไข่</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>มูกปากมดลูกใส ยืดได้คล้ายไข่ขาว (Egg White Cervical Mucus)</li>
        <li>อุณหภูมิร่างกายพื้นฐาน (BBT) สูงขึ้นเล็กน้อยประมาณ 0.2-0.5°C หลังตกไข่</li>
        <li>อาจมีอาการปวดเสียดท้องน้อยข้างเดียว (Mittelschmerz)</li>
        <li>ชุดทดสอบตกไข่ (OPK) ให้ผลบวก แสดงว่าฮอร์โมน LH พุ่งสูงขึ้น</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ข้อจำกัดของการคำนวณวันตกไข่</h3>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>สูตรใช้ค่าเฉลี่ย Luteal Phase 14 วัน ซึ่งอาจแตกต่างได้ในแต่ละบุคคล (10-16 วัน)</li>
        <li>รอบเดือนที่ไม่สม่ำเสมอจะทำให้ผลคำนวณคลาดเคลื่อน</li>
        <li>ปัจจัยภายนอก เช่น ความเครียด การเจ็บป่วย ยา อาจทำให้ตกไข่เร็วหรือช้ากว่าปกติ</li>
        <li>ไม่ควรใช้เป็นวิธีคุมกำเนิดเพียงวิธีเดียว</li>
      </ul>
    </section>

    <!-- Related content -->
    <RelatedArticles currentHref="/คำนวณวันตกไข่/" />
    <RelatedCalculators currentHref="/คำนวณวันตกไข่/" />

    <!-- FAQ -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg border border-gray-200 shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นค่าประมาณเพื่อการวางแผนเท่านั้น ไม่ใช่ข้อสรุปทางการแพทย์
      ไม่ควรใช้เป็นวิธีคุมกำเนิดเพียงวิธีเดียว หากมีข้อสงสัยหรือต้องการคำแนะนำ ควรปรึกษาแพทย์
    </div>
  </article>

  <script>
    const MS_PER_DAY = 24 * 60 * 60 * 1000;

    const form = document.getElementById('ovulation-form') as HTMLFormElement;
    const formError = document.getElementById('ov-form-error') as HTMLElement;
    const resultsEl = document.getElementById('ov-results') as HTMLElement;
    const nextAction = document.getElementById('ov-next-action') as HTMLElement;

    const lmpDateEl = document.getElementById('lmp-date') as HTMLInputElement;
    const cycleLengthEl = document.getElementById('cycle-length') as HTMLInputElement;
    const numCyclesEl = document.getElementById('num-cycles') as HTMLSelectElement;

    const show = (el: HTMLElement | null) => el?.classList.remove('hidden');
    const hide = (el: HTMLElement | null) => el?.classList.add('hidden');

    const addDays = (date: Date, days: number): Date => {
      const d = new Date(date);
      d.setDate(d.getDate() + days);
      return d;
    };

    const formatThaiDate = (date: Date): string =>
      new Intl.DateTimeFormat('th-TH', { dateStyle: 'long' }).format(date);

    const formatShortDate = (date: Date): string =>
      new Intl.DateTimeFormat('th-TH', { day: 'numeric', month: 'short' }).format(date);

    const setFieldError = (id: string, message: string) => {
      const el = document.getElementById(id);
      if (!el) return;
      if (!message) {
        hide(el);
        el.textContent = '';
        return;
      }
      el.textContent = message;
      show(el);
    };

    const toDate = (value: string): Date | null => {
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return null;
      d.setHours(0, 0, 0, 0);
      return d;
    };

    interface CycleResult {
      cycleStart: Date;
      ovulationDay: Date;
      fertileStart: Date;
      fertileEnd: Date;
      nextPeriod: Date;
    }

    function calculateCycle(lmpDate: Date, cycleLength: number, cycleIndex: number): CycleResult {
      const cycleStart = addDays(lmpDate, cycleLength * cycleIndex);
      const ovulationDay = addDays(cycleStart, cycleLength - 14);
      const fertileStart = addDays(ovulationDay, -5);
      const fertileEnd = ovulationDay;
      const nextPeriod = addDays(cycleStart, cycleLength);

      return { cycleStart, ovulationDay, fertileStart, fertileEnd, nextPeriod };
    }

    form?.addEventListener('submit', (event: Event) => {
      event.preventDefault();

      hide(formError);
      setFieldError('lmp-date-error', '');
      setFieldError('cycle-length-error', '');

      const lmpDate = toDate(lmpDateEl?.value || '');
      if (!lmpDate) {
        setFieldError('lmp-date-error', 'กรุณาเลือกวันแรกของประจำเดือนครั้งสุดท้าย');
        return;
      }

      const cycleLength = Number(String(cycleLengthEl?.value || '').replace(/,/g, '').trim());
      if (!Number.isFinite(cycleLength) || cycleLength < 21 || cycleLength > 45) {
        setFieldError('cycle-length-error', 'ความยาวรอบเดือนควรอยู่ในช่วง 21-45 วัน');
        return;
      }

      const numCycles = Number(numCyclesEl?.value || '3');

      // Calculate all cycles
      const cycles: CycleResult[] = [];
      for (let i = 0; i < numCycles; i++) {
        cycles.push(calculateCycle(lmpDate, cycleLength, i));
      }

      // Display first cycle highlights
      const first = cycles[0];
      (document.getElementById('res-ovulation-date') as HTMLElement).textContent = formatThaiDate(first.ovulationDay);
      (document.getElementById('res-fertile-window') as HTMLElement).textContent =
        `${formatShortDate(first.fertileStart)} - ${formatShortDate(first.fertileEnd)}`;
      (document.getElementById('res-next-period') as HTMLElement).textContent = formatThaiDate(first.nextPeriod);
      (document.getElementById('res-cycle-length') as HTMLElement).textContent = `${cycleLength} วัน`;

      // Build multi-cycle table
      const tbody = document.getElementById('ov-cycle-rows') as HTMLElement;
      tbody.innerHTML = '';
      cycles.forEach((cycle, idx) => {
        const tr = document.createElement('tr');
        tr.className = 'border-b border-gray-100';

        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const isCurrentCycle = today >= cycle.cycleStart && today < cycle.nextPeriod;
        if (isCurrentCycle) {
          tr.className += ' bg-pink-50';
        }

        tr.innerHTML = `
          <td class="py-2 pr-4 font-medium">${idx + 1}${isCurrentCycle ? ' <span class="text-xs text-pink-600">(ปัจจุบัน)</span>' : ''}</td>
          <td class="py-2 pr-4">${formatShortDate(cycle.cycleStart)}</td>
          <td class="py-2 pr-4 text-rose-700 font-medium">${formatShortDate(cycle.fertileStart)} - ${formatShortDate(cycle.fertileEnd)}</td>
          <td class="py-2 pr-4 text-pink-700 font-bold">${formatShortDate(cycle.ovulationDay)}</td>
          <td class="py-2">${formatShortDate(cycle.nextPeriod)}</td>
        `;
        tbody.appendChild(tr);
      });

      show(resultsEl);
      show(nextAction);
      resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (typeof trackCalculatorStart === 'function') trackCalculatorStart('ovulation');
      if (typeof trackCalculatorComplete === 'function') trackCalculatorComplete('ovulation');
      if (typeof trackCalculatorUsed === 'function') trackCalculatorUsed('ovulation');
    });

    document.querySelectorAll('[data-next-action-link]').forEach((link) => {
      link.addEventListener('click', () => {
        const href = link.getAttribute('href') || '';
        const payload = {
          calculator_type: 'ovulation',
          route_from: window.location.pathname,
          route_to: href,
          placement: 'post_result',
        };
        if (typeof window.trackLanguageAwareEvent === 'function') {
          window.trackLanguageAwareEvent('next_action_click', payload);
          return;
        }
        if (typeof window.gtag === 'function') {
          window.gtag('event', 'next_action_click', payload);
        }
      });
    });
  </script>
</BaseLayout>
