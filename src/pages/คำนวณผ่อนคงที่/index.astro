---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณผ่อนคงที่ (Flat Rate) 2569 — สินเชื่อรถ สินเชื่อส่วนบุคคล | Kamnuanlek';
const pageDescription = 'คำนวณค่างวดและดอกเบี้ยรวมแบบผ่อนคงที่ (Flat Rate) สำหรับสินเชื่อรถยนต์และสินเชื่อส่วนบุคคล เทียบกับอัตราดอกเบี้ยที่แท้จริง (EIR)';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณผ่อนคงที่/`;

const faqData = [
  {
    question: 'Flat Rate 1.5% ต่อเดือนเทียบเท่า EIR เท่าไร?',
    answer: 'Flat Rate 1.5% ต่อเดือน (18% ต่อปี) เทียบเท่า EIR ประมาณ 32-36% ต่อปี เพราะ flat rate คิดจากเงินต้นเต็มก้อนตลอดสัญญา ไม่ใช่จากยอดคงเหลือ ทำให้ต้นทุนจริงสูงกว่ามาก',
  },
  {
    question: 'สินเชื่อรถยนต์ใช้ flat rate หรือ reducing balance?',
    answer: 'สินเชื่อรถยนต์ในไทยส่วนใหญ่ใช้ flat rate หรือ simple interest ทำให้คำนวณค่างวดง่าย ต่างจากสินเชื่อบ้านที่ใช้ reducing balance หากต้องการเปรียบเทียบต้องแปลงเป็น EIR ก่อน',
  },
  {
    question: 'ปิดสินเชื่อ flat rate ก่อนกำหนดคุ้มหรือไม่?',
    answer: 'โดยทั่วไปการปิดก่อนกำหนดไม่ค่อยคุ้มสำหรับ flat rate เพราะดอกเบี้ยคิดล่วงหน้าแล้ว แต่ขึ้นอยู่กับสัญญา บางแห่งคืนดอกเบี้ยส่วนที่เหลือ บางแห่งคิดค่าปรับ ต้องตรวจสอบเงื่อนไขก่อน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณผ่อนคงที่ (Flat Rate)',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณผ่อนคงที่">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      คำนวณผ่อนคงที่ (Flat Rate) — สินเชื่อรถ สินเชื่อส่วนบุคคล
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">คำนวณค่างวด ดอกเบี้ยรวม และดอกเบี้ยที่แท้จริง (EIR) สำหรับสินเชื่อแบบ Flat Rate</p>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6 mb-8">
      <form id="flat-form" class="space-y-5">
        <div>
          <label for="principal" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">วงเงินกู้ (บาท)</label>
          <input type="text" id="principal" inputmode="numeric" placeholder="เช่น 800,000"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="flat-rate" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Flat Rate (%/ปี)</label>
            <input type="text" id="flat-rate" inputmode="decimal" placeholder="เช่น 3.5"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
            <p class="text-xs text-gray-500 mt-1">ตัวอย่าง: รถ 2.49-3.5%, ส่วนบุคคล 18-28%/ปี</p>
          </div>
          <div>
            <label for="term" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ระยะเวลา (เดือน)</label>
            <input type="text" id="term" inputmode="numeric" placeholder="เช่น 60"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
        </div>
        <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-4">
          <div class="bg-primary-50 dark:bg-primary-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ค่างวด/เดือน</div>
            <div id="res-monthly" class="text-xl font-bold text-primary-700 dark:text-primary-300">-</div>
          </div>
          <div class="bg-red-50 dark:bg-red-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ดอกเบี้ยรวม</div>
            <div id="res-interest" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ชำระรวม</div>
            <div id="res-total" class="text-xl font-bold text-gray-700 dark:text-gray-300">-</div>
          </div>
          <div class="bg-orange-50 dark:bg-orange-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">EIR (ดอกเบี้ยจริง)</div>
            <div id="res-eir" class="text-xl font-bold text-orange-700 dark:text-orange-300">-</div>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot />

    <section class="prose prose-gray dark:prose-invert max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-3">Flat Rate คืออะไร?</h2>
      <p>Flat Rate คือการคำนวณดอกเบี้ยจากเงินต้นเต็มจำนวนตลอดสัญญา ค่างวดจะเท่ากันทุกเดือน สูตร: ค่างวด = (เงินต้น + เงินต้น × flat rate × ปี) ÷ จำนวนงวด ใช้กับสินเชื่อรถและสินเชื่อส่วนบุคคลเป็นหลัก ดอกเบี้ยที่แท้จริง (EIR) จะสูงกว่า flat rate ประมาณ 1.8-1.9 เท่า</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 dark:text-gray-100 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600 dark:text-gray-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณผ่อนคงที่/" />
    <RelatedCalculators currentHref="/คำนวณผ่อนคงที่/" />

    <div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg text-sm text-yellow-800 dark:text-yellow-300">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> EIR เป็นค่าประมาณ ตัวเลขจริงขึ้นอยู่กับวิธีคำนวณของสถาบันการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }

    // Estimate EIR using IRR approximation for flat rate
    function estimateEIR(principal: number, monthly: number, n: number): number {
      // Newton-Raphson to find monthly rate r such that PV of payments = principal
      let r = 0.01;
      for (let i = 0; i < 100; i++) {
        const f = monthly * (1 - Math.pow(1 + r, -n)) / r - principal;
        const df = monthly * ((1 - Math.pow(1 + r, -n)) / (r * r) - n * Math.pow(1 + r, -n - 1) / r);
        const rNew = r - f / df;
        if (Math.abs(rNew - r) < 1e-10) { r = rNew; break; }
        r = rNew;
      }
      return r * 12 * 100; // annual EIR %
    }

    document.getElementById('flat-form')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const P = parseNum((document.getElementById('principal') as HTMLInputElement).value);
      const flatRate = parseNum((document.getElementById('flat-rate') as HTMLInputElement).value) || 3.5;
      const n = parseNum((document.getElementById('term') as HTMLInputElement).value) || 60;
      if (!P) return;

      const totalInterest = P * (flatRate / 100) * (n / 12);
      const monthly = (P + totalInterest) / n;
      const eir = estimateEIR(P, monthly, n);

      (document.getElementById('res-monthly') as HTMLElement).textContent = fmt(monthly) + ' บาท';
      (document.getElementById('res-interest') as HTMLElement).textContent = fmt(totalInterest) + ' บาท';
      (document.getElementById('res-total') as HTMLElement).textContent = fmt(P + totalInterest) + ' บาท';
      (document.getElementById('res-eir') as HTMLElement).textContent = eir.toFixed(2) + '%/ปี';

      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('flat-rate');
    });
  </script>
</BaseLayout>
