---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณภาษีคืน / ภาษีจ่ายเพิ่ม 2569 | เช็กก่อนยื่น ภ.ง.ด.91 | Calculator Thailand';
const pageDescription = 'คำนวณว่าปีนี้ได้ภาษีคืนหรือต้องจ่ายเพิ่ม จากรายได้ รวมเงินได้ ค่าลดหย่อน และภาษีหัก ณ ที่จ่ายที่ถูกหักไปแล้วตลอดปี ตามแบบ ภ.ง.ด.91 ปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณภาษีคืน-ภาษีจ่ายเพิ่ม/`;

const faqData = [
  {
    question: 'ภาษีคืนคืออะไร?',
    answer: 'ภาษีคืน (Tax Refund) เกิดขึ้นเมื่อภาษีที่ถูกหัก ณ ที่จ่ายตลอดปีมากกว่าภาษีที่ต้องชำระจริง กรมสรรพากรจะคืนเงินส่วนต่างให้ภายใน 15–30 วันหลังยื่นแบบ ภ.ง.ด.91',
  },
  {
    question: 'ต้องยื่นแบบภาษีรายปีภายในวันใด?',
    answer: 'แบบ ภ.ง.ด.91 (สำหรับผู้มีเงินได้ประเภท 40(1)) ต้องยื่นภายในวันที่ 31 มีนาคมของปีถัดไป หรือยื่นออนไลน์ผ่านเว็บไซต์กรมสรรพากรได้ถึงวันที่ 8 เมษายน',
  },
  {
    question: 'ภาษีหัก ณ ที่จ่ายสะสมทั้งปีดูได้จากที่ไหน?',
    answer: 'ดูได้จากหนังสือรับรองการหักภาษี ณ ที่จ่าย (50 ทวิ) ที่นายจ้างต้องออกให้ทุกสิ้นปี หรือจากสลิปเงินเดือนสะสม หรือตรวจสอบในระบบ e-Filing ของกรมสรรพากร',
  },
  {
    question: 'หากต้องจ่ายภาษีเพิ่มจะมีค่าปรับหรือไม่?',
    answer: 'หากยื่นแบบและชำระภาษีครบภายในกำหนด ไม่มีค่าปรับ แต่หากยื่นล่าช้าจะมีค่าปรับไม่ยื่น 2,000 บาท และเสียเบี้ยปรับ 1–2 เท่าของภาษีที่ค้างชำระ',
  },
  {
    question: 'ผู้มีรายได้หลายประเภทใช้แบบไหน?',
    answer: 'ผู้มีรายได้ประเภท 40(1) เพียงอย่างเดียวใช้ ภ.ง.ด.91 ส่วนผู้มีรายได้หลายประเภทหรือรายได้ประเภทอื่นใช้แบบ ภ.ง.ด.90',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณภาษีคืน / ภาษีจ่ายเพิ่ม 2569',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณภาษีคืน-ภาษีจ่ายเพิ่ม">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">รู้ผลในไม่ถึง 30 วินาที</p>
      <p class="mt-1 text-sm text-slate-700">ข้อมูลไม่ถูกบันทึก ใช้เพื่อการคำนวณเท่านั้น</p>
      <p class="mt-1 text-xs font-medium text-sky-800">อัปเดตเกณฑ์ปี 2569 (ภ.ง.ด.91)</p>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      คำนวณภาษีคืน / ภาษีจ่ายเพิ่ม ปี 2569
    </h1>

    <p class="text-gray-600 mb-6">
      กรอกรายได้ ค่าลดหย่อน และภาษีที่ถูกหัก ณ ที่จ่ายสะสมทั้งปี
      ระบบจะบอกว่าคุณได้ภาษีคืนหรือต้องจ่ายเพิ่มเท่าไร
    </p>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">กรอกข้อมูลภาษีทั้งปี</h2>
      <form id="refund-form" class="space-y-5">
        <div>
          <label for="annual-income" class="block text-sm font-medium text-gray-700 mb-1">รายได้รวมทั้งปี (บาท)</label>
          <input type="text" id="annual-income" inputmode="numeric" placeholder="เช่น 540,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">เงินเดือน × 12 + โบนัส + รายได้อื่น</p>
        </div>

        <div>
          <label for="total-deductions" class="block text-sm font-medium text-gray-700 mb-1">ค่าลดหย่อนรวมทั้งปี (บาท)</label>
          <input type="text" id="total-deductions" inputmode="numeric" placeholder="เช่น 150,000"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">ส่วนตัว 60,000 + ประกันสังคม + ประกันชีวิต + กองทุน ฯลฯ</p>
        </div>

        <div>
          <label for="withheld-tax" class="block text-sm font-medium text-gray-700 mb-1">ภาษีหัก ณ ที่จ่ายสะสมทั้งปี (บาท)</label>
          <input type="text" id="withheld-tax" inputmode="numeric" placeholder="เช่น 18,500"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 text-base" />
          <p class="mt-1 text-xs text-gray-500">ดูจากหนังสือรับรองการหัก ณ ที่จ่าย (50 ทวิ) หรือสลิปเงินเดือนสะสม</p>
        </div>

        <button type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณทันที
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>
        <div id="verdict-card" class="rounded-xl p-5 mb-6 text-center">
          <div id="verdict-label" class="text-lg font-bold mb-1">-</div>
          <div id="verdict-amount" class="text-3xl font-extrabold">-</div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">รายได้ทั้งปี</span>
            <span id="r-annual-income" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">หักค่าใช้จ่าย (50% สูงสุด 100,000)</span>
            <span id="r-expense" class="font-medium text-red-600">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">หักค่าลดหย่อน</span>
            <span id="r-deduct" class="font-medium text-red-600">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-200 font-semibold">
            <span>รายได้สุทธิ</span>
            <span id="r-net">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ภาษีที่ต้องชำระ</span>
            <span id="r-tax-due" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ภาษีหัก ณ ที่จ่ายแล้ว</span>
            <span id="r-withheld" class="font-medium text-red-600">-</span>
          </div>
          <div class="flex justify-between py-2 font-bold text-base">
            <span id="r-balance-label">ยอดสุทธิ</span>
            <span id="r-balance">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">วิธีคำนวณภาษีคืน / ภาษีจ่ายเพิ่ม</h2>
      <p>สูตรพื้นฐาน: <strong>ยอดสุทธิ = ภาษีที่ต้องชำระ − ภาษีหัก ณ ที่จ่ายสะสม</strong></p>
      <ul class="list-disc pl-6 space-y-1 text-gray-700">
        <li>ถ้าผลลัพธ์เป็น <strong>ลบ</strong> → ได้ <span class="text-green-700 font-semibold">ภาษีคืน</span></li>
        <li>ถ้าผลลัพธ์เป็น <strong>บวก</strong> → ต้อง <span class="text-red-700 font-semibold">จ่ายเพิ่ม</span></li>
        <li>ถ้าผลลัพธ์ <strong>เป็นศูนย์</strong> → ไม่ต้องทำอะไรเพิ่ม</li>
      </ul>
      <p class="mt-3">ภาษีที่ต้องชำระคำนวณจากรายได้สุทธิ (รายได้ − ค่าใช้จ่าย − ค่าลดหย่อน) ตามอัตราขั้นบันได 5–35%</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white rounded-lg shadow-sm border border-gray-200">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณภาษีคืน-ภาษีจ่ายเพิ่ม/" />
    <RelatedCalculators currentHref="/คำนวณภาษีคืน-ภาษีจ่ายเพิ่ม/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นเพียงการประมาณการ อัตราภาษีอ้างอิงจากกรมสรรพากรปีภาษี 2569 กรุณาปรึกษาผู้เชี่ยวชาญด้านภาษีสำหรับกรณีเฉพาะ
    </div>
  </article>

  <script>
    const TAX_BRACKETS = [
      { min: 0, max: 150_000, rate: 0 },
      { min: 150_000, max: 300_000, rate: 0.05 },
      { min: 300_000, max: 500_000, rate: 0.10 },
      { min: 500_000, max: 750_000, rate: 0.15 },
      { min: 750_000, max: 1_000_000, rate: 0.20 },
      { min: 1_000_000, max: 2_000_000, rate: 0.25 },
      { min: 2_000_000, max: 5_000_000, rate: 0.30 },
      { min: 5_000_000, max: Infinity, rate: 0.35 },
    ];

    function parseNum(v: string) { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number) { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n) + ' บาท'; }

    function calcTax(netIncome: number): number {
      let remaining = netIncome;
      let tax = 0;
      for (const b of TAX_BRACKETS) {
        const w = b.max === Infinity ? Infinity : b.max - b.min;
        const taxable = Math.min(remaining, w);
        tax += taxable * b.rate;
        remaining -= taxable;
        if (remaining <= 0) break;
      }
      return tax;
    }

    const form = document.getElementById('refund-form') as HTMLFormElement;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const annualIncome = parseNum((document.getElementById('annual-income') as HTMLInputElement).value);
      const totalDeductions = parseNum((document.getElementById('total-deductions') as HTMLInputElement).value);
      const withheldTax = parseNum((document.getElementById('withheld-tax') as HTMLInputElement).value);
      if (annualIncome <= 0) return;

      const expense = Math.min(annualIncome * 0.5, 100_000);
      const netIncome = Math.max(0, annualIncome - expense - totalDeductions);
      const taxDue = calcTax(netIncome);
      const balance = taxDue - withheldTax;

      const verdictCard = document.getElementById('verdict-card') as HTMLElement;
      const verdictLabel = document.getElementById('verdict-label') as HTMLElement;
      const verdictAmount = document.getElementById('verdict-amount') as HTMLElement;
      const balanceLabel = document.getElementById('r-balance-label') as HTMLElement;
      const balanceEl = document.getElementById('r-balance') as HTMLElement;

      if (balance < -0.01) {
        verdictCard.className = 'rounded-xl p-5 mb-6 text-center bg-green-50 border border-green-200';
        verdictLabel.textContent = '🎉 คุณได้ภาษีคืน';
        verdictLabel.className = 'text-lg font-bold mb-1 text-green-800';
        verdictAmount.textContent = fmt(Math.abs(balance));
        verdictAmount.className = 'text-3xl font-extrabold text-green-700';
        balanceLabel.textContent = 'ภาษีที่ได้คืน';
        balanceEl.className = 'font-bold text-green-700';
      } else if (balance > 0.01) {
        verdictCard.className = 'rounded-xl p-5 mb-6 text-center bg-red-50 border border-red-200';
        verdictLabel.textContent = '⚠️ ต้องจ่ายภาษีเพิ่ม';
        verdictLabel.className = 'text-lg font-bold mb-1 text-red-800';
        verdictAmount.textContent = fmt(balance);
        verdictAmount.className = 'text-3xl font-extrabold text-red-700';
        balanceLabel.textContent = 'ต้องชำระเพิ่ม';
        balanceEl.className = 'font-bold text-red-700';
      } else {
        verdictCard.className = 'rounded-xl p-5 mb-6 text-center bg-gray-50 border border-gray-200';
        verdictLabel.textContent = '✅ ภาษีพอดี';
        verdictLabel.className = 'text-lg font-bold mb-1 text-gray-800';
        verdictAmount.textContent = '0.00 บาท';
        verdictAmount.className = 'text-3xl font-extrabold text-gray-700';
        balanceLabel.textContent = 'ยอดสุทธิ';
        balanceEl.className = 'font-bold text-gray-700';
      }

      (document.getElementById('r-annual-income') as HTMLElement).textContent = fmt(annualIncome);
      (document.getElementById('r-expense') as HTMLElement).textContent = '-' + fmt(expense);
      (document.getElementById('r-deduct') as HTMLElement).textContent = '-' + fmt(totalDeductions);
      (document.getElementById('r-net') as HTMLElement).textContent = fmt(netIncome);
      (document.getElementById('r-tax-due') as HTMLElement).textContent = fmt(taxDue);
      (document.getElementById('r-withheld') as HTMLElement).textContent = '-' + fmt(withheldTax);
      balanceEl.textContent = fmt(Math.abs(balance));

      const resultsDiv = document.getElementById('results') as HTMLElement;
      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorComplete('tax_refund_due');
      trackCalculatorUsed('tax_refund_due');
    });

    form.addEventListener('input', () => { trackCalculatorStart('tax_refund_due'); }, { once: true });
  </script>
</BaseLayout>
