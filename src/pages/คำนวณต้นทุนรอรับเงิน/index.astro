---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณต้นทุนการรอรับเงิน ปี 2569 — Merchant Payout Delay Cost | Kamnuanlek';
const pageDescription = 'คำนวณต้นทุนโอกาสจากการรอรับเงินจากช่องทางรับชำระ เช่น T+1, T+3, T+7 ป้อนยอดขาย วันรอ และต้นทุนเงินทุน ทราบต้นทุนที่แท้จริง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณต้นทุนรอรับเงิน/`;

const faqData = [
  {
    question: 'Payout Delay คืออะไร?',
    answer: 'Payout Delay คือจำนวนวันที่ร้านค้าต้องรอรับเงินหลังจากลูกค้าชำระ เช่น T+1 = รับเงินวันถัดไป, T+3 = รับเงินใน 3 วัน, T+7 = รับเงินใน 7 วัน',
  },
  {
    question: 'ต้นทุนการรอรับเงินคำนวณอย่างไร?',
    answer: 'ใช้หลักการ Cost of Capital: ต้นทุน = ยอดที่รอรับ × อัตราต้นทุนเงินทุน × (วันรอ ÷ 365) หรือ ÷ 360 แล้วแต่ฐาน',
  },
  {
    question: 'ควรเลือก Payout กี่วัน?',
    answer: 'ยิ่งรอน้อยวันยิ่งดี แต่บางช่องทางอาจคิดค่าธรรมเนียมเพิ่มสำหรับ Instant Payout ควรเปรียบเทียบค่าธรรมเนียม Instant Payout กับต้นทุนการรอรอ',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณต้นทุนการรอรับเงิน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณต้นทุนรอรับเงิน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-orange-100 bg-orange-50 p-4">
      <p class="text-sm font-semibold text-orange-700">คำนวณต้นทุนการรอรับเงิน — Payout Delay Cost</p>
      <p class="mt-1 text-sm text-slate-700">สูตร: ต้นทุน = ยอดค้างรับ × อัตราต้นทุนทุน% × (วันรอ ÷ 365)</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณต้นทุนการรอรับเงิน ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      ป้อนยอดขายที่รอรับ จำนวนวันรอ และต้นทุนเงินทุนของกิจการ เพื่อดูต้นทุนโอกาสจากการรอรับเงิน
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="pd-form" class="space-y-5">
        <p id="pd-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="pd-amount" class="mb-1 block text-sm font-medium text-gray-700">ยอดค้างรับ (บาท)</label>
            <input type="text" id="pd-amount" inputmode="numeric" placeholder="เช่น 500,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="pd-amount-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="pd-days" class="mb-1 block text-sm font-medium text-gray-700">จำนวนวันรอรับเงิน (วัน)</label>
            <input type="text" id="pd-days" inputmode="numeric" placeholder="เช่น 3"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="pd-days-error" class="mt-1 hidden text-sm text-red-600"></p>
            <p class="mt-1 text-xs text-gray-500">T+1=1, T+3=3, T+7=7</p>
          </div>
        </div>

        <div>
          <label for="pd-coc" class="mb-1 block text-sm font-medium text-gray-700">ต้นทุนเงินทุน (%/ปี)</label>
          <input type="text" id="pd-coc" inputmode="decimal" placeholder="เช่น 6"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
          <p id="pd-coc-error" class="mt-1 hidden text-sm text-red-600"></p>
          <p class="mt-1 text-xs text-gray-500">อัตรากู้ยืมหรือ Opportunity Cost ของกิจการ</p>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณต้นทุนรอรับเงิน
        </button>
      </form>
    </div>

    <div id="pd-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-4 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-orange-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุนโอกาส</div>
            <div id="res-pd-cost" class="text-xl font-bold text-orange-700">-</div>
          </div>
          <div class="rounded-lg bg-blue-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุน/วัน</div>
            <div id="res-pd-daily" class="text-xl font-bold text-blue-700">-</div>
          </div>
          <div class="rounded-lg bg-red-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ต้นทุน/ปี (ถ้าหมุน 12 รอบ)</div>
            <div id="res-pd-annual" class="text-xl font-bold text-red-700">-</div>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ต้นทุนโอกาส = ยอดค้างรับ × (CoC% ÷ 100) × (วันรอ ÷ 365)</li>
        <li>ต้นทุน/วัน = ยอดค้างรับ × (CoC% ÷ 100) ÷ 365</li>
        <li>ต้นทุน/ปี = ต้นทุนโอกาส × 12 รอบ</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณ-MDR-ค่าธรรมเนียมร้านค้า/">คำนวณ MDR ค่าธรรมเนียมร้านค้า</a></li>
        <li><a href="/คำนวณต้นทุน-chargeback/">คำนวณต้นทุน Chargeback</a></li>
        <li><a href="/คำนวณต้นทุนคืนเงิน/">คำนวณต้นทุนการคืนเงิน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#pd-results" />
    <RelatedArticles currentHref="/คำนวณต้นทุนรอรับเงิน/" />
    <RelatedCalculators currentHref="/คำนวณต้นทุนรอรับเงิน/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ต้นทุนโอกาสเป็นการประมาณการ ขึ้นอยู่กับต้นทุนเงินทุนจริงของแต่ละกิจการ
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function fmt(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
    function setErr(id, msg) { const el = document.getElementById(id); if (!el) return; el.textContent = msg; el.classList.toggle('hidden', !msg); }

    document.getElementById('pd-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('pd-error').classList.add('hidden');
      ['pd-amount-error','pd-days-error','pd-coc-error'].forEach(id => setErr(id, ''));

      const amount = parseNum(document.getElementById('pd-amount').value);
      const days = parseNum(document.getElementById('pd-days').value);
      const coc = parseNum(document.getElementById('pd-coc').value);

      let hasError = false;
      if (!Number.isFinite(amount) || amount <= 0) { setErr('pd-amount-error', 'กรอกยอดค้างรับมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(days) || days <= 0) { setErr('pd-days-error', 'กรอกวันรอมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(coc) || coc <= 0) { setErr('pd-coc-error', 'กรอกต้นทุนเงินทุนมากกว่า 0'); hasError = true; }
      if (hasError) { document.getElementById('pd-error').classList.remove('hidden'); document.getElementById('pd-results').classList.add('hidden'); return; }

      const dailyCost = amount * (coc / 100) / 365;
      const cost = dailyCost * days;
      const annual = cost * 12;

      setText('res-pd-cost', fmt(cost));
      setText('res-pd-daily', fmt(dailyCost));
      setText('res-pd-annual', fmt(annual));

      document.getElementById('pd-results').classList.remove('hidden');
      document.getElementById('pd-results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
