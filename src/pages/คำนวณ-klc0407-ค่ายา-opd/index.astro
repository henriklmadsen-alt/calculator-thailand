---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = 'คำนวณค่ายา OPD | Kamnuanlek';
const pageDescription = 'คำนวณค่ายาผู้ป่วยนอก OPD ค่าปรึกษาแพทย์ ค่ายา ค่าบริการ ตามอัตราโรงพยาบาลไทย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณ-klc0407-ค่ายา-opd/`;

const faqData = [
  { question: 'ค่าแพทย์ OPD โรงพยาบาลเอกชนเท่าไหร่?', answer: 'ค่าแพทย์ OPD โรงพยาบาลเอกชน 300-1,500 บาทต่อครั้ง ขึ้นอยู่กับโรงพยาบาลและความเชี่ยวชาญของแพทย์' },
  { question: 'ยาสามัญประจำบ้านราคาเฉลี่ยเท่าไหร่?', answer: 'ยาสามัญราคา 50-500 บาทต่อชุด ยาแบรนด์เนม 200-2,000 บาท ยาเรื้อรังที่ต้องใช้ต่อเนื่องอาจสูงถึง 5,000 บาทต่อเดือน' },
  { question: 'ประกันสังคมคุ้มครองค่ายา OPD ไหม?', answer: 'ผู้ประกันตนมาตรา 33 ได้รับยาและการรักษาฟรีที่โรงพยาบาลตามสิทธิ์ แต่ถ้าไม่ใช้โรงพยาบาลตามบัตรต้องจ่ายเอง' },
  { question: 'ยาชื่อสามัญกับยาแบรนด์ต่างกันอย่างไร?', answer: 'ยาชื่อสามัญมีสารออกฤทธิ์เดียวกันกับยาแบรนด์ แต่ราคาถูกกว่า 3-10 เท่า ประสิทธิภาพใกล้เคียงกัน ผ่านมาตรฐาน อย.' }
];

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่ายา OPD">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />
  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">คำนวณค่ายา OPD (ผู้ป่วยนอก)</h1>
    <div class="mb-4 inline-block rounded-lg border border-red-200 bg-red-50 px-3 py-2"><p class="text-xs font-semibold text-red-800">[อัปเดตปี 2569]</p></div>
    <p class="text-gray-600 mb-6">คำนวณค่าใช้จ่ายผู้ป่วยนอก รวมค่าแพทย์ ค่ายา และค่าบริการ</p>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <div class="space-y-4 mb-6">
        <div><label for="doctor_opd" class="block text-sm font-medium text-gray-700 mb-1">ค่าปรึกษาแพทย์ (บาท)</label><input type="text" id="doctor_opd" inputmode="decimal" placeholder="เช่น 500" value="500" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="medicine_opd" class="block text-sm font-medium text-gray-700 mb-1">ค่ายา (บาท)</label><input type="text" id="medicine_opd" inputmode="decimal" placeholder="เช่น 800" value="800" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="service_fee" class="block text-sm font-medium text-gray-700 mb-1">ค่าบริการโรงพยาบาล (บาท)</label><input type="text" id="service_fee" inputmode="decimal" placeholder="เช่น 300" value="300" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
        <div><label for="visits_month" class="block text-sm font-medium text-gray-700 mb-1">จำนวนครั้งต่อเดือน</label><input type="number" id="visits_month" min="1" max="30" placeholder="เช่น 1" value="1" class="w-full px-3 py-2 border border-gray-300 rounded-md" /></div>
      </div>
      <button type="button" id="btn" class="px-6 py-2 bg-red-600 text-white rounded-md">คำนวณ</button>
      <div id="res" class="hidden mt-6 space-y-2">
        <div class="grid grid-cols-2 gap-2">
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อครั้ง</p>
            <p id="per_visit" class="font-bold">-</p>
          </div>
          <div class="bg-red-50 rounded p-3">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อเดือน</p>
            <p id="monthly_opd" class="font-bold">-</p>
          </div>
          <div class="bg-orange-50 rounded p-3 col-span-2">
            <p class="text-sm text-gray-600">ค่าใช้จ่ายต่อปี</p>
            <p id="yearly_opd" class="font-bold text-lg">-</p>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-8 space-y-6">
      <div class="bg-gray-50 rounded-lg p-4 sm:p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">❓ คำถามที่พบบ่อย</h2>
        <div class="space-y-4">
          {faqData.map((faq) => (
            <div>
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-gray-600 text-sm">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </article>
  <script>
    document.getElementById('btn')!.addEventListener('click', () => {
      const doctorFee = parseFloat((document.getElementById('doctor_opd') as HTMLInputElement).value) || 0;
      const medicine = parseFloat((document.getElementById('medicine_opd') as HTMLInputElement).value) || 0;
      const serviceFee = parseFloat((document.getElementById('service_fee') as HTMLInputElement).value) || 0;
      const visitsMonth = parseInt((document.getElementById('visits_month') as HTMLInputElement).value) || 1;

      const perVisit = doctorFee + medicine + serviceFee;
      const monthlyOpd = perVisit * visitsMonth;
      const yearlyOpd = monthlyOpd * 12;

      (document.getElementById('per_visit') as HTMLElement).textContent = perVisit.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('monthly_opd') as HTMLElement).textContent = monthlyOpd.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('yearly_opd') as HTMLElement).textContent = yearlyOpd.toLocaleString('th-TH') + ' บาท';
      (document.getElementById('res') as HTMLElement).classList.remove('hidden');
      trackCalculatorUsed('opd-drug-costs');
    });
    document.getElementById('btn')!.click();
  </script>
</BaseLayout>
