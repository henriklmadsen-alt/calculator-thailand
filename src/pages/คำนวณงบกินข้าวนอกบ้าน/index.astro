---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'คำนวณงบกินข้าวนอกบ้าน 2569 | ค่าอาหารนอกบ้านต่อเดือน | Kamnuanlek';
const pageDescription = 'คำนวณค่ากินข้าวนอกบ้านรายเดือนตามจำนวนมื้อและราคาเฉลี่ยต่อมื้อ เปรียบเทียบกับการทำอาหารเองที่บ้าน';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบกินข้าวนอกบ้าน/`;

const faqData = [
  {
    question: 'ค่ากินข้าวนอกบ้านต่อมื้อเฉลี่ยเท่าไร?',
    answer: 'ในกรุงเทพฯ ค่ากินข้าวนอกบ้านต่อมื้อเฉลี่ยอยู่ที่ 60-120 บาทสำหรับร้านทั่วไป 150-300 บาทสำหรับร้านอาหารระดับกลาง และ 300 บาทขึ้นไปสำหรับร้านระดับสูง',
  },
  {
    question: 'ทำอาหารเองประหยัดกว่ากินนอกบ้านเท่าไร?',
    answer: 'โดยเฉลี่ยการทำอาหารเองที่บ้านประหยัดได้ประมาณ 40-60% เมื่อเทียบกับการกินนอกบ้าน หากคำนึงถึงเวลาและค่าแรงที่ใช้ในการทำอาหาร ความแตกต่างอาจลดลงบ้าง',
  },
  {
    question: 'ควรตั้งงบค่าอาหารนอกบ้านเท่าไรต่อเดือน?',
    answer: 'แนะนำให้ตั้งงบค่าอาหารนอกบ้านไม่เกิน 15-20% ของรายได้ต่อเดือน หากรายได้ 25,000 บาท ควรจำกัดค่าอาหารนอกบ้านที่ไม่เกิน 3,750-5,000 บาทต่อเดือน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบกินข้าวนอกบ้าน',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบกินข้าวนอกบ้าน">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณงบกินข้าวนอกบ้าน 2569</h1>
    <p class="mb-6 text-gray-600">คำนวณค่ากินข้าวนอกบ้านรายเดือนตามจำนวนมื้อและราคาเฉลี่ยต่อมื้อ</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="eating-form" class="space-y-4">
        <div>
          <label for="persons" class="mb-1 block text-sm font-medium text-gray-700">จำนวนคน</label>
          <input id="persons" type="text" inputmode="numeric" placeholder="เช่น 2"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="meals-week" class="mb-1 block text-sm font-medium text-gray-700">จำนวนมื้อที่กินนอกบ้านต่อสัปดาห์ (มื้อ)</label>
          <input id="meals-week" type="text" inputmode="numeric" placeholder="เช่น 10"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div>
          <label for="price-per-meal" class="mb-1 block text-sm font-medium text-gray-700">ราคาเฉลี่ยต่อมื้อต่อคน (บาท)</label>
          <input id="price-per-meal" type="text" inputmode="numeric" placeholder="เช่น 80"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48" />
        </div>
        <div class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3">
          <input type="checkbox" id="include-drinks" class="h-5 w-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
          <label for="include-drinks" class="text-sm font-medium text-gray-700">รวมค่าเครื่องดื่ม (+30 บาท/มื้อ/คน)</label>
        </div>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 rounded-lg bg-primary-50 p-4 text-center">
          <div class="mb-1 text-sm text-gray-600">ค่ากินนอกบ้านต่อเดือน</div>
          <div id="res-monthly" class="text-4xl font-bold text-primary-700 sm:text-5xl">-</div>
          <div class="mt-1 text-sm text-gray-500">บาท</div>
        </div>
        <div class="space-y-0">
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">ค่าอาหารต่อสัปดาห์</span>
            <span id="res-weekly" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">ค่าอาหารต่อปี</span>
            <span id="res-yearly" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-700">ประหยัดได้ถ้าทำเองที่บ้าน (~50%)</span>
            <span id="res-save" class="text-sm font-medium text-green-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />


    <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm">
      <p class="font-semibold text-gray-700 mb-2">แหล่งอ้างอิงทางการ</p>
      <ul class="space-y-1 text-gray-600">
        <li><a href="https://www.bot.or.th" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline font-medium">ธนาคารแห่งประเทศไทย (bot.or.th)</a> — อัตราดอกเบี้ยนโยบายและสินเชื่อ</li>
        <li><a href="https://www.bot.or.th/th/financial-consumer/loan.html" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">สิทธิผู้บริโภคด้านสินเชื่อ — ธนาคารแห่งประเทศไทย</a></li>
      </ul>
    </div>
    <RelatedCalculators currentHref="/คำนวณงบกินข้าวนอกบ้าน/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const parseNum = (v: string) => {
    const n = parseFloat(String(v ?? '').replace(/,/g, '').trim());
    return Number.isFinite(n) && n > 0 ? n : 0;
  };
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  document.getElementById('eating-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const persons = parseNum((document.getElementById('persons') as HTMLInputElement).value) || 1;
    const mealsWeek = parseNum((document.getElementById('meals-week') as HTMLInputElement).value) || 0;
    const pricePerMeal = parseNum((document.getElementById('price-per-meal') as HTMLInputElement).value) || 0;
    const includeDrinks = (document.getElementById('include-drinks') as HTMLInputElement).checked;

    const priceTotal = pricePerMeal + (includeDrinks ? 30 : 0);
    const weeklyTotal = mealsWeek * priceTotal * persons;
    const monthly = weeklyTotal * 4;
    const yearly = monthly * 12;
    const saving = monthly * 0.5;

    document.getElementById('res-monthly')!.textContent = fmt(monthly);
    document.getElementById('res-weekly')!.textContent = fmt(weeklyTotal);
    document.getElementById('res-yearly')!.textContent = fmt(yearly);
    document.getElementById('res-save')!.textContent = fmt(saving) + '/เดือน';
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
