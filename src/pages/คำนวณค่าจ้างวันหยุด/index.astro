---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่าจ้างวันหยุด ปี 2569 ตามพ.ร.บ.คุ้มครองแรงงาน มาตรา 62-63 | เครื่องคำนวณไทย';
const pageDescription = 'คำนวณค่าจ้างวันหยุด ทำงานวันหยุด 2 เท่า โอทีวันหยุด 3 เท่า ตามพระราชบัญญัติคุ้มครองแรงงาน พ.ศ.2541 มาตรา 62-63 อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าจ้างวันหยุด/`;

const faqData = [
  {
    question: 'ทำงานในวันหยุดได้รับค่าจ้างกี่เท่า?',
    answer: 'ตามมาตรา 62 พ.ร.บ.คุ้มครองแรงงาน นายจ้างต้องจ่ายค่าทำงานในวันหยุดไม่น้อยกว่า 2 เท่าของอัตราค่าจ้างต่อชั่วโมงในวันทำงาน สำหรับชั่วโมงปกติในวันหยุด',
  },
  {
    question: 'โอทีในวันหยุดได้รับค่าจ้างกี่เท่า?',
    answer: 'ตามมาตรา 63 โอทีในวันหยุดต้องได้รับไม่น้อยกว่า 3 เท่าของอัตราค่าจ้างต่อชั่วโมง',
  },
  {
    question: 'วันหยุดตามกฎหมายแรงงานมีกี่วัน?',
    answer: 'กฎหมายกำหนดให้ลูกจ้างมีสิทธิ์หยุดงานประจำสัปดาห์อย่างน้อย 1 วัน/สัปดาห์ และวันหยุดตามประเพณีอย่างน้อย 13 วัน/ปี รวมวันแรงงานแห่งชาติ',
  },
  {
    question: 'พนักงานรายเดือนคำนวณค่าแรงต่อชั่วโมงอย่างไร?',
    answer: 'ค่าแรง/ชั่วโมง = เงินเดือน ÷ (วันทำงาน/เดือน × ชั่วโมงทำงาน/วัน) แล้วนำไปคูณด้วย 2 หรือ 3 ตามประเภทชั่วโมงวันหยุด',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าจ้างวันหยุด',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าจ้างวันหยุด">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <div class="mb-4 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm font-semibold text-sky-700">อัปเดตปี 2569 — ตาม พ.ร.บ.คุ้มครองแรงงาน</p>
      <p class="mt-1 text-sm text-slate-700">ทำงานวันหยุด 2 เท่า (มาตรา 62) | โอทีวันหยุด 3 เท่า (มาตรา 63)</p>
      <p class="mt-1 text-xs font-medium text-sky-800">เหมาะสำหรับพนักงานและ HR ที่ต้องการตรวจสอบค่าจ้างวันหยุดให้ถูกต้อง</p>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าจ้างวันหยุด ปี 2569
    </h1>

    <p class="mb-6 text-gray-600">
      กรอกเงินเดือน วันทำงานต่อเดือน ชั่วโมงทำงานต่อวัน และชั่วโมงทำงาน/โอทีในวันหยุด ระบบจะคำนวณค่าจ้างตามกฎหมายแรงงาน
    </p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="holiday-pay-form" class="space-y-5">
        <p id="holiday-pay-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm font-medium text-red-700">
          กรุณาตรวจสอบข้อมูลให้ครบและถูกต้องก่อนคำนวณ
        </p>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="hp-salary" class="mb-1 block text-sm font-medium text-gray-700">เงินเดือน (บาท/เดือน)</label>
            <input type="text" id="hp-salary" inputmode="numeric" placeholder="เช่น 30,000"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hp-salary-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="hp-work-days" class="mb-1 block text-sm font-medium text-gray-700">วันทำงานต่อเดือน (วัน)</label>
            <input type="text" id="hp-work-days" inputmode="decimal" placeholder="เช่น 26"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hp-work-days-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="hp-hours-day" class="mb-1 block text-sm font-medium text-gray-700">ชั่วโมงทำงานต่อวัน</label>
            <input type="text" id="hp-hours-day" inputmode="decimal" placeholder="เช่น 8"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hp-hours-day-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="hp-holiday-hours" class="mb-1 block text-sm font-medium text-gray-700">ชั่วโมงทำงานในวันหยุด (2 เท่า, มาตรา 62)</label>
            <input type="text" id="hp-holiday-hours" inputmode="decimal" placeholder="เช่น 8"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hp-holiday-hours-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label for="hp-ot-hours" class="mb-1 block text-sm font-medium text-gray-700">ชั่วโมงโอทีในวันหยุด (3 เท่า, มาตรา 63)</label>
            <input type="text" id="hp-ot-hours" inputmode="decimal" placeholder="เช่น 4"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500" />
            <p id="hp-ot-hours-error" class="mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>

        <button type="submit" class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณค่าจ้างวันหยุด
        </button>
      </form>
    </div>

    <div id="holiday-pay-results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ผลการคำนวณ</h2>
        <div class="mb-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-lg bg-green-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าจ้างวันหยุดรวม</div>
            <div id="res-hp-total" class="text-xl font-bold text-green-700">-</div>
          </div>
          <div class="rounded-lg bg-primary-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">ค่าแรงต่อชั่วโมง</div>
            <div id="res-hp-hourly" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="rounded-lg bg-amber-50 p-4 text-center">
            <div class="mb-1 text-sm text-gray-600">เงินเดือน + วันหยุด</div>
            <div id="res-hp-grand" class="text-xl font-bold text-amber-700">-</div>
          </div>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">ทำงานวันหยุด 2 เท่า (มาตรา 62)</span>
            <span id="res-hp-2x" class="font-medium">-</span>
          </div>
          <div class="flex justify-between border-b border-gray-100 py-1">
            <span class="text-gray-600">โอทีวันหยุด 3 เท่า (มาตรา 63)</span>
            <span id="res-hp-3x" class="font-medium">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรและกฎหมายที่อ้างอิง</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าแรง/ชั่วโมง = เงินเดือน ÷ (วันทำงาน/เดือน × ชั่วโมงทำงาน/วัน)</li>
        <li>ค่าทำงานวันหยุด = ค่าแรง/ชั่วโมง × 2 × จำนวนชั่วโมง (มาตรา 62)</li>
        <li>ค่าโอทีวันหยุด = ค่าแรง/ชั่วโมง × 3 × จำนวนชั่วโมง (มาตรา 63)</li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">แหล่งอ้างอิง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="https://www.mol.go.th/wp-content/uploads/sites/2/2018/07/183.pdf" target="_blank" rel="noopener noreferrer">พ.ร.บ.คุ้มครองแรงงาน พ.ศ. 2541 มาตรา 62-63 (กระทรวงแรงงาน)</a></li>
      </ul>
      <h3 class="mb-2 mt-6 text-lg font-semibold text-gray-900">ลิงก์ที่เกี่ยวข้อง</h3>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li><a href="/คำนวณค่าโอที/">คำนวณค่าโอที</a> — OT วันธรรมดา 1.5 เท่า</li>
        <li><a href="/คำนวณเงินเดือนสุทธิ/">คำนวณเงินเดือนสุทธิ</a></li>
        <li><a href="/คำนวณค่าจ้างรายวัน/">คำนวณค่าจ้างรายวัน</a></li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" revealAfterSelector="#holiday-pay-results" />
    <RelatedArticles currentHref="/คำนวณค่าจ้างวันหยุด/" />
    <RelatedCalculators currentHref="/คำนวณค่าจ้างวันหยุด/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลลัพธ์เป็นการคำนวณตามกฎหมายแรงงานขั้นต่ำ นายจ้างบางรายอาจจ่ายสูงกว่ากฎหมายกำหนด ควรตรวจสอบสัญญาจ้างและข้อบังคับภายในองค์กร
    </div>
  </article>

  <script type="module">
    function parseNum(v) {
      const s = String(v).replace(/,/g, '').trim();
      if (s === '') return NaN;
      const n = Number(s);
      return Number.isFinite(n) ? n : NaN;
    }
    function formatMoney(n) {
      return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n)} บาท`;
    }
    function setText(id, val) {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    }
    function setErr(id, msg) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      el.classList.toggle('hidden', !msg);
    }

    const form = document.getElementById('holiday-pay-form');
    const formError = document.getElementById('holiday-pay-form-error');
    const resultBox = document.getElementById('holiday-pay-results');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      ['hp-salary-error','hp-work-days-error','hp-hours-day-error','hp-holiday-hours-error','hp-ot-hours-error'].forEach((id) => setErr(id, ''));

      const salary = parseNum(document.getElementById('hp-salary').value);
      const workDays = parseNum(document.getElementById('hp-work-days').value);
      const hoursDay = parseNum(document.getElementById('hp-hours-day').value);
      const holidayHours = parseNum(document.getElementById('hp-holiday-hours').value) || 0;
      const otHours = parseNum(document.getElementById('hp-ot-hours').value) || 0;

      let hasError = false;
      if (!Number.isFinite(salary) || salary <= 0) { setErr('hp-salary-error', 'กรอกเงินเดือนมากกว่า 0'); hasError = true; }
      if (!Number.isFinite(workDays) || workDays <= 0 || workDays > 31) { setErr('hp-work-days-error', 'กรอกวันทำงาน 1-31 วัน'); hasError = true; }
      if (!Number.isFinite(hoursDay) || hoursDay <= 0 || hoursDay > 24) { setErr('hp-hours-day-error', 'กรอกชั่วโมงทำงาน 1-24'); hasError = true; }

      if (hasError) { formError.classList.remove('hidden'); resultBox.classList.add('hidden'); return; }

      const hourlyRate = salary / (workDays * hoursDay);
      const pay2x = hourlyRate * 2 * holidayHours;
      const pay3x = hourlyRate * 3 * otHours;
      const total = pay2x + pay3x;

      setText('res-hp-total', formatMoney(total));
      setText('res-hp-hourly', formatMoney(hourlyRate));
      setText('res-hp-grand', formatMoney(salary + total));
      setText('res-hp-2x', formatMoney(pay2x));
      setText('res-hp-3x', formatMoney(pay3x));

      resultBox.classList.remove('hidden');
      resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
