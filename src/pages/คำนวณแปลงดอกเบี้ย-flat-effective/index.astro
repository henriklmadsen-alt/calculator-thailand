---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';
import FAQAccordion from '../../components/templates/FAQAccordion.astro';

const pageTitle = 'แปลงดอกเบี้ย Flat เป็น Effective (EIR) 2569 | Kamnuanlek';
const pageDescription = 'คำนวณแปลงอัตราดอกเบี้ยแบบคงที่ (Flat Rate) เป็นอัตราดอกเบี้ยที่แท้จริง (Effective Interest Rate / EIR) ช่วยผู้บริโภคไทยเปรียบเทียบต้นทุนสินเชื่อได้ถูกต้อง';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณแปลงดอกเบี้ย-flat-effective/`;

const faqData = [
  {
    question: 'ดอกเบี้ย Flat Rate กับ Effective Rate ต่างกันอย่างไร?',
    answer: 'Flat Rate คำนวณดอกเบี้ยจากเงินต้นเต็มจำนวนตลอดสัญญา ทำให้ดูเหมือนต่ำ แต่ Effective Rate (EIR) คือต้นทุนที่แท้จริง เพราะคำนวณจากเงินต้นที่ลดลงในแต่ละงวด โดยทั่วไป EIR ≈ Flat Rate × 1.8 ถึง 2 เท่า',
  },
  {
    question: 'ทำไม EIR ถึงสำคัญสำหรับผู้บริโภคไทย?',
    answer: 'ธนาคารแห่งประเทศไทยกำหนดให้สถาบันการเงินต้องแจ้ง EIR แก่ผู้กู้ แต่โฆษณามักเน้น Flat Rate ที่ดูต่ำกว่า การรู้ EIR ช่วยให้เปรียบเทียบข้อเสนอสินเชื่อจากหลายสถาบันได้อย่างยุติธรรม',
  },
  {
    question: 'Flat 1% ต่อเดือน เท่ากับ EIR เท่าไร?',
    answer: 'Flat 1% ต่อเดือน (12% ต่อปี) สำหรับสินเชื่อ 48 เดือน เท่ากับ EIR ประมาณ 21-22% ต่อปี ยิ่งระยะเวลากู้นานขึ้น อัตราส่วน EIR/Flat ยิ่งสูง',
  },
  {
    question: 'วิธีคำนวณแปลง Flat เป็น EIR ใช้สูตรอะไร?',
    answer: 'ใช้วิธี Newton-Raphson หา monthly rate r ที่ทำให้ P = PMT × [1-(1+r)^-n] / r โดย PMT คำนวณจาก Flat Rate แล้วหา Annual EIR = ((1+r)^12 - 1) × 100',
  },
,
  { question: 'ดอกเบี้ยทบต้น (Compound Interest) คืออะไร?', answer: 'ดอกเบี้ยที่คำนวณจากเงินต้นบวกดอกเบี้ยสะสม ทำให้เงินงอกเร็วกว่าดอกเบี้ยธรรมดา สูตร: A = P(1+r/n)^(nt) โดย P=เงินต้น, r=อัตราดอกเบี้ย, n=ครั้งที่ทบต่อปี, t=จำนวนปี' },
  { question: 'กฎ 72 ใช้คำนวณอะไร?', answer: 'ใช้ประมาณจำนวนปีที่เงินจะเพิ่มเป็น 2 เท่า: จำนวนปี = 72 ÷ อัตราดอกเบี้ย เช่น ดอกเบี้ย 6% ต่อปี เงินจะเป็น 2 เท่าใน 72÷6 = 12 ปี เป็นกฎง่ายสำหรับการวางแผนการเงิน' },
  { question: 'อัตราดอกเบี้ยเงินฝากออมทรัพย์ในไทยปัจจุบันอยู่ที่เท่าไร?', answer: 'ออมทรัพย์ทั่วไปอยู่ที่ 0.5-1.0% ต่อปี ฝากประจำ 12 เดือนอยู่ที่ 1.5-2.5% ต่อปี บัญชีออมทรัพย์พิเศษบางแห่งให้สูงถึง 1.5-3% ตรวจสอบอัตราปัจจุบันจากธนาคารแห่งประเทศไทย bot.or.th' },
  { question: 'ดอกเบี้ยเงินฝากเสียภาษีไหม?', answer: 'ใช่ ดอกเบี้ยเงินฝากธนาคารถูกหักภาษี ณ ที่จ่าย 15% โดยธนาคาร ยกเว้นดอกเบี้ยเงินฝากออมทรัพย์ที่ไม่เกิน 20,000 บาทต่อปีรวมทุกบัญชี สามารถขอคืนหรือเครดิตกับภาษีสิ้นปีได้' }
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องแปลงดอกเบี้ย Flat เป็น Effective Rate',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="แปลง Flat เป็น EIR">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
      🔢 แปลงดอกเบี้ย Flat Rate เป็น Effective Interest Rate (EIR)
    </h1>

    <p class="text-gray-600 mb-6">
      โฆษณาสินเชื่อมักแสดง Flat Rate ที่ดูต่ำ แต่ต้นทุนที่แท้จริงคือ EIR
      ใช้เครื่องมือนี้แปลงเพื่อเปรียบเทียบข้อเสนอสินเชื่อได้อย่างถูกต้อง
    </p>

    <!-- Calculator Form -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="flat-eir-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="flat-rate" class="block text-sm font-medium text-gray-700 mb-1">
              อัตราดอกเบี้ย Flat ต่อปี (%)
            </label>
            <input
              type="text"
              id="flat-rate"
              inputmode="decimal"
              placeholder="เช่น 10"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
            <p class="mt-1 text-xs text-gray-500">อัตราที่โฆษณาระบุ เช่น 10% ต่อปี หรือ 0.83% ต่อเดือน × 12</p>
          </div>
          <div>
            <label for="term-months" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลา (เดือน)
            </label>
            <input
              type="text"
              id="term-months"
              inputmode="numeric"
              placeholder="เช่น 48"
              value="48"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base"
            />
          </div>
        </div>

        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base"
        >
          คำนวณ EIR
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-6">
          <div class="bg-red-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">EIR ต่อปี (ดอกเบี้ยที่แท้จริง)</div>
            <div id="res-eir-annual" class="text-xl font-bold text-red-600">-</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">EIR ต่อเดือน</div>
            <div id="res-eir-monthly" class="text-xl font-bold text-orange-600">-</div>
          </div>
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">Flat Rate ที่ระบุ</div>
            <div id="res-flat" class="text-xl font-bold text-primary-700">-</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 mb-1">EIR สูงกว่า Flat</div>
            <div id="res-ratio" class="text-xl font-bold text-gray-700">-</div>
          </div>
        </div>

        <h3 class="font-semibold text-gray-900 mb-3">ตัวอย่าง: เงินกู้ 100,000 บาท</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ค่างวดต่อเดือน</span>
            <span id="res-pmt" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ดอกเบี้ยรวม</span>
            <span id="res-total-interest" class="font-medium text-red-600">-</span>
          </div>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="text-gray-600">ยอดชำระรวม</span>
            <span id="res-total-paid" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-1">
            <span class="text-gray-600">จำนวนงวด</span>
            <span id="res-term" class="font-medium">-</span>
          </div>
        </div>

        <div class="mt-4 p-3 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
          <strong>สรุป:</strong> Flat Rate <span id="res-summary-flat" class="font-bold">-</span> ต่อปี
          เท่ากับ EIR <span id="res-summary-eir" class="font-bold text-red-700">-</span> ต่อปี
          — ผู้กู้จ่ายดอกเบี้ยที่แท้จริงสูงกว่าที่โฆษณา
        </div>
      </div>
    </div>

    <!-- Ad -->
    <GuardedAdSlot />

    <!-- SEO Content -->
    <section class="prose prose-gray max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">ทำไมต้องรู้ EIR ก่อนกู้เงิน</h2>

      <p>
        ในประเทศไทย สินเชื่อรถยนต์และสินเชื่อส่วนบุคคลมักโฆษณาในรูปแบบ Flat Rate
        ซึ่งทำให้อัตราดอกเบี้ยดูต่ำกว่าความเป็นจริง ตัวอย่างเช่น
        Flat Rate 10% ต่อปี ผ่อน 48 เดือน แท้จริงแล้วมี EIR ประมาณ 18-19% ต่อปี
      </p>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">ตารางเปรียบเทียบ Flat vs EIR ที่พบบ่อย</h3>

      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200 rounded">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-3 py-2 text-left">Flat Rate (ต่อปี)</th>
              <th class="px-3 py-2 text-right">EIR 24 เดือน</th>
              <th class="px-3 py-2 text-right">EIR 36 เดือน</th>
              <th class="px-3 py-2 text-right">EIR 48 เดือน</th>
              <th class="px-3 py-2 text-right">EIR 60 เดือน</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr><td class="px-3 py-2">5%</td><td class="px-3 py-2 text-right">9.1%</td><td class="px-3 py-2 text-right">9.2%</td><td class="px-3 py-2 text-right">9.2%</td><td class="px-3 py-2 text-right">9.3%</td></tr>
            <tr class="bg-gray-50"><td class="px-3 py-2">10%</td><td class="px-3 py-2 text-right">17.9%</td><td class="px-3 py-2 text-right">18.2%</td><td class="px-3 py-2 text-right">18.5%</td><td class="px-3 py-2 text-right">18.7%</td></tr>
            <tr><td class="px-3 py-2">15%</td><td class="px-3 py-2 text-right">26.4%</td><td class="px-3 py-2 text-right">27.0%</td><td class="px-3 py-2 text-right">27.4%</td><td class="px-3 py-2 text-right">27.7%</td></tr>
            <tr class="bg-gray-50"><td class="px-3 py-2">20%</td><td class="px-3 py-2 text-right">34.6%</td><td class="px-3 py-2 text-right">35.5%</td><td class="px-3 py-2 text-right">36.2%</td><td class="px-3 py-2 text-right">36.7%</td></tr>
          </tbody>
        </table>
      </div>

      <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">วิธีคำนวณ EIR (Newton-Raphson)</h3>
      <p>
        เมื่อทราบ PMT จาก Flat Rate แล้ว หา monthly rate r ที่ทำให้สมการต่อไปนี้เป็นจริง:
      </p>
      <p class="font-mono text-sm bg-gray-50 p-3 rounded">
        P = PMT × [1 − (1+r)^(−n)] ÷ r
      </p>
      <p>
        จากนั้น Annual EIR = ((1+r)^12 − 1) × 100
        การหา r ใช้วิธี Newton-Raphson iteration จนกว่าจะได้ค่าที่แม่นยำ
      </p>
    </section>

    <!-- FAQ -->
    <FAQAccordion faqData={faqData} title="คำถามที่พบบ่อย" />

    <RelatedArticles currentHref="/คำนวณแปลงดอกเบี้ย-flat-effective/" />
    <RelatedCalculators currentHref="/คำนวณแปลงดอกเบี้ย-flat-effective/" />

    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการทางคณิตศาสตร์
      EIR ที่แท้จริงอาจแตกต่างตามค่าธรรมเนียมและเงื่อนไขสินเชื่อ ไม่ถือเป็นคำแนะนำทางการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number {
      return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0);
    }

    function fmt(n: number): string {
      return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
    }

    function fmtPct(n: number): string {
      return n.toFixed(4) + '%';
    }

    // Newton-Raphson to find monthly rate given PMT and P
    function findMonthlyRate(P: number, PMT: number, n: number): number {
      // Initial guess: flat/2 as monthly
      let r = PMT * n / P / n / 2;
      if (r <= 0) r = 0.01;

      for (let i = 0; i < 200; i++) {
        const factor = Math.pow(1 + r, n);
        const f = PMT * (1 - 1 / factor) / r - P;
        const df = PMT * (
          (1 - 1 / factor) / (-r * r) +
          (n / (r * (1 + r) * factor))
        );
        const rNew = r - f / df;
        if (Math.abs(rNew - r) < 1e-10) return rNew;
        r = Math.max(1e-8, rNew);
      }
      return r;
    }

    const form = document.getElementById('flat-eir-form') as HTMLFormElement;
    const resultsDiv = document.getElementById('results') as HTMLDivElement;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const flatRateAnnual = parseNum((document.getElementById('flat-rate') as HTMLInputElement).value);
      const n = parseNum((document.getElementById('term-months') as HTMLInputElement).value);

      if (flatRateAnnual <= 0) { (document.getElementById('flat-rate') as HTMLInputElement).focus(); return; }
      if (n <= 0) { (document.getElementById('term-months') as HTMLInputElement).focus(); return; }

      const P = 100000; // example principal
      const totalInterestFlat = P * (flatRateAnnual / 100) * (n / 12);
      const PMT = (P + totalInterestFlat) / n;
      const totalPaid = PMT * n;

      let eirMonthly: number;
      let eirAnnual: number;

      if (flatRateAnnual === 0) {
        eirMonthly = 0;
        eirAnnual = 0;
      } else {
        eirMonthly = findMonthlyRate(P, PMT, n);
        eirAnnual = (Math.pow(1 + eirMonthly, 12) - 1) * 100;
      }

      const ratio = eirAnnual / flatRateAnnual;

      (document.getElementById('res-eir-annual') as HTMLElement).textContent = eirAnnual.toFixed(2) + '%';
      (document.getElementById('res-eir-monthly') as HTMLElement).textContent = (eirMonthly * 100).toFixed(4) + '%';
      (document.getElementById('res-flat') as HTMLElement).textContent = flatRateAnnual.toFixed(2) + '%';
      (document.getElementById('res-ratio') as HTMLElement).textContent = ratio.toFixed(2) + 'x';
      (document.getElementById('res-pmt') as HTMLElement).textContent = fmt(PMT) + ' บาท';
      (document.getElementById('res-total-interest') as HTMLElement).textContent = fmt(totalInterestFlat) + ' บาท';
      (document.getElementById('res-total-paid') as HTMLElement).textContent = fmt(totalPaid) + ' บาท';
      (document.getElementById('res-term') as HTMLElement).textContent = n + ' งวด';
      (document.getElementById('res-summary-flat') as HTMLElement).textContent = flatRateAnnual.toFixed(2) + '%';
      (document.getElementById('res-summary-eir') as HTMLElement).textContent = eirAnnual.toFixed(2) + '%';

      resultsDiv.classList.remove('hidden');
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('flat-to-eir');
    });

    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          trackResultViewed('flat-to-eir');
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(resultsDiv);
  </script>
</BaseLayout>
