---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่าเรียนมหาวิทยาลัย ปี 2569 | วางแผนการศึกษา | Kamnuanlek';
const pageDescription = 'คำนวณค่าเรียนมหาวิทยาลัยรวม โปรแกรมปกติ หลักสูตรต่างประเทศ และปริญญาโท พร้อมวางแผนจัดเก็บค่าเรียนประจำปี';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าเรียนมหาวิทยาลัย/`;

const faqData = [
  {
    question: 'ค่าเรียนมหาวิทยาลัยในไทยเท่าไหร่?',
    answer: 'ค่าเรียนแตกต่างกันตามสถาบันและหลักสูตร โปรแกรมปกติ (สำหรับนักศึกษาระดับ 4 ปี) ประมาณ 60,000–150,000 บาท/ปี สำหรับมหาวิทยาลัยรัฐ ส่วนมหาวิทยาลัยเอกชนอาจสูงถึง 200,000–500,000 บาท/ปี หลักสูตรต่างประเทศ (International Program) อาจแพงกว่า 1.5–3 เท่า',
  },
  {
    question: 'ค่าเรียนปริญญาโทต่างจากปริญญาตรีหรือไม่?',
    answer: 'ใช่ ค่าเรียนปริญญาโท (Master\'s degree) มักแพงกว่าปริญญาตรี โดยทั่วไป 80,000–300,000 บาท/ปี ขึ้นอยู่กับสาขาวิชาและมหาวิทยาลัย โปรแกรม MBA และสาขาวิศวกรรมมักเป็นสาขาที่มีค่าเรียนสูงสุด',
  },
  {
    question: 'นอกจากค่าเรียน ยังมีค่าใช้จ่ายอะไรอีกบ้าง?',
    answer: 'นอกจากค่าเรียนแล้ว มีค่าลงทะเบียน ค่าหนังสือเรียน ค่าชุมนุม ค่าสัมมนา ค่าบีมา และค่าวัสดุการศึกษา โดยค่าเพิ่มเติมนี้มักอยู่ที่ 10,000–30,000 บาท/ปี ควรตรวจสอบกับมหาวิทยาลัยที่คุณสมัครเข้าเรียน',
  },
  {
    question: 'มีทุนการศึกษาหรือการลดหย่อนค่าเรียนหรือไม่?',
    answer: 'มหาวิทยาลัยส่วนใหญ่มีทุนเพื่อนักศึกษาเก่งหรือเรียนดี และอาจมีการลดค่าเรียนสำหรับนักศึกษาผลประเมินสูง (GPA 3.5+) นอกจากนี้ยังมีสินเชื่อการศึกษาจากสถาบันการเงิน ธ.ก.ส. และโครงการยืมเงินของรัฐ ซึ่งสามารถจ่ายคืนหลังจากสำเร็จการศึกษา',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าเรียนมหาวิทยาลัย',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};

---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าเรียนมหาวิทยาลัย">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">คำนวณค่าเรียนมหาวิทยาลัย ปี 2569</h1>

    <p class="text-gray-600 mb-6">
      คำนวณค่าเรียนมหาวิทยาลัยทั้งหมด ตั้งแต่ปริญญาตรี ถึงปริญญาโท และหลักสูตรต่างประเทศ พร้อมวางแผนจัดเก็บค่าใช้จ่ายรายปี
    </p>

    <!-- Info Box -->
    <div class="mb-6 rounded-lg border border-blue-200 bg-blue-50 p-4">
      <p class="text-sm font-medium text-blue-900">
        สูตร: ค่าเรียนรวมทั้งหมด = ค่าเรียน/ปี × จำนวนปี
      </p>
    </div>

    <!-- Calculator -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6 mb-8">
      <form id="tuition-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="tuition-yearly" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าเรียนต่อปี (บาท)
            </label>
            <input
              type="text"
              id="tuition-yearly"
              inputmode="numeric"
              placeholder="เช่น 80,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="years-study" class="block text-sm font-medium text-gray-700 mb-1">
              ระยะเวลาศึกษา (ปี)
            </label>
            <input
              type="text"
              id="years-study"
              inputmode="numeric"
              placeholder="เช่น 4"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="other-fees" class="block text-sm font-medium text-gray-700 mb-1">
              ค่าใช้จ่ายเพิ่มเติมต่อปี (บาท) — ไม่บังคับ
            </label>
            <input
              type="text"
              id="other-fees"
              inputmode="numeric"
              placeholder="เช่น 15,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
          <div>
            <label for="scholarship" class="block text-sm font-medium text-gray-700 mb-1">
              ทุนการศึกษาต่อปี (บาท) — ไม่บังคับ
            </label>
            <input
              type="text"
              id="scholarship"
              inputmode="numeric"
              placeholder="เช่น 20,000"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-base"
            />
          </div>
        </div>

        <button type="submit" class="w-full sm:w-auto rounded-md bg-blue-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-blue-700">
          คำนวณค่าเรียนทั้งหมด
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="hidden mb-8">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">ผลการคำนวณ</h2>

        <div class="rounded-lg bg-blue-50 p-4 text-center mb-6">
          <div class="text-sm text-gray-600 mb-1">ค่าเรียนรวมทั้งหมด</div>
          <div id="res-total-cost" class="text-3xl font-bold text-blue-700">-</div>
        </div>

        <div class="space-y-2 text-sm bg-gray-50 p-4 rounded-lg">
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าเรียน/ปี</span>
            <span id="res-yearly" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ค่าใช้จ่ายเพิ่มเติม/ปี</span>
            <span id="res-other" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">รวมต่อปี</span>
            <span id="res-per-year" class="font-medium text-gray-900">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-600">จำนวนปี</span>
            <span id="res-years" class="font-medium">-</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-gray-600">ทุนการศึกษา/ปี</span>
            <span id="res-scholar" class="font-medium text-green-600">-</span>
          </div>
          <div class="flex justify-between py-2 border-t border-gray-200 pt-2">
            <span class="text-gray-700 font-semibold">ต้องชำระจริง</span>
            <span id="res-final-cost" class="font-bold text-lg text-blue-700">-</span>
          </div>
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">สูตรที่ใช้</h2>
      <ul class="list-disc space-y-1 pl-6 text-gray-700">
        <li>ค่าเรียนรวมทั้งหมด = (ค่าเรียน + ค่าใช้จ่ายเพิ่มเติม) × จำนวนปี</li>
        <li>ต้องชำระจริง = ค่าเรียนรวม − (ทุนการศึกษา × จำนวนปี)</li>
      </ul>
    </section>

    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800 mb-8">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ค่าเรียนอาจเปลี่ยนแปลงตามนโยบายของแต่ละมหาวิทยาลัย การคำนวณนี้เป็นการประมาณเบื้องต้น ควรตรวจสอบค่าเรียนจริงกับมหาวิทยาลัยที่สนใจเข้าเรียน
    </div>

    <RelatedArticles currentHref="/คำนวณค่าเรียนมหาวิทยาลัย/" />
    <RelatedCalculators currentHref="/คำนวณค่าเรียนมหาวิทยาลัย/" />

    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-blue-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  function parseNumber(value) {
    if (!value) return 0;
    return Number(String(value).replace(/,/g, '').trim()) || 0;
  }

  function formatCurrency(value) {
    return `${new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(value)} บาท`;
  }

  const form = document.querySelector('#tuition-form');
  const results = document.querySelector('#results');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const tuitionYearly = parseNumber(document.querySelector('#tuition-yearly')?.value || '');
    const yearsStudy = parseNumber(document.querySelector('#years-study')?.value || '');
    const otherFees = parseNumber(document.querySelector('#other-fees')?.value || '');
    const scholarship = parseNumber(document.querySelector('#scholarship')?.value || '');

    if (!(tuitionYearly > 0 && yearsStudy > 0)) {
      results?.classList.add('hidden');
      return;
    }

    const yearlyTotal = tuitionYearly + otherFees;
    const totalCost = yearlyTotal * yearsStudy;
    const totalScholarship = scholarship * yearsStudy;
    const finalCost = totalCost - totalScholarship;

    document.querySelector('#res-total-cost').textContent = formatCurrency(totalCost);
    document.querySelector('#res-yearly').textContent = formatCurrency(tuitionYearly);
    document.querySelector('#res-other').textContent = otherFees > 0 ? formatCurrency(otherFees) : '0 บาท';
    document.querySelector('#res-per-year').textContent = formatCurrency(yearlyTotal);
    document.querySelector('#res-years').textContent = `${yearsStudy} ปี`;
    document.querySelector('#res-scholar').textContent = scholarship > 0 ? formatCurrency(scholarship) : '0 บาท';
    document.querySelector('#res-final-cost').textContent = formatCurrency(finalCost);

    results?.classList.remove('hidden');
    results?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
