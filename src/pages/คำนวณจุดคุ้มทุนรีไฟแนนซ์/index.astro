---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณรีไฟแนนซ์คุ้มหรือเปล่า 2569 ฟรี | Kamnuanlek';
const pageDescription = 'คำนวณจุดคุ้มทุนรีไฟแนนซ์ 2569 ฟรี — รู้ว่ารีไฟแนนซ์บ้าน รถ หรือสินเชื่อประหยัดดอกเบี้ยได้เท่าไร และกี่เดือนถึงคุ้มค่าค่าใช้จ่าย';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณจุดคุ้มทุนรีไฟแนนซ์/`;

const faqData = [
  {
    question: 'รีไฟแนนซ์บ้านมีค่าใช้จ่ายอะไรบ้าง?',
    answer: 'ค่าใช้จ่ายรีไฟแนนซ์บ้านประกอบด้วย: ค่าธรรมเนียมรีไฟแนนซ์ 0.5-1% ค่าประเมินราคา 2,000-5,000 บาท ค่าจดจำนองใหม่ 1% ค่าประกันอัคคีภัยและ MRF/MRTA ค่าปรับปิดก่อนกำหนดของธนาคารเดิม รวมอาจถึง 2-4% ของวงเงินกู้',
  },
  {
    question: 'ดอกเบี้ยต้องลดเท่าไรถึงควรรีไฟแนนซ์?',
    answer: 'หลักทั่วไปคือดอกเบี้ยควรลดลงอย่างน้อย 0.5-1% ต่อปี และควรเหลือเวลาผ่อนอย่างน้อย 5-10 ปี จุดคุ้มทุนมักอยู่ที่ 18-36 เดือน ถ้าวางแผนอยู่บ้านนานกว่านั้นจึงคุ้มค่า',
  },
  {
    question: 'รีไฟแนนซ์บ่อยแค่ไหนดี?',
    answer: 'ไม่มีกฎตายตัว แต่ส่วนใหญ่รีไฟแนนซ์ทุก 3-5 ปีเมื่อพ้นช่วงล็อกดอกเบี้ย ควรเปรียบเทียบข้อเสนอจากหลายธนาคารและคำนวณจุดคุ้มทุนก่อนทุกครั้ง',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณจุดคุ้มทุนรีไฟแนนซ์',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณจุดคุ้มทุนรีไฟแนนซ์">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      คำนวณจุดคุ้มทุนรีไฟแนนซ์ — ต้องรอกี่เดือนถึงคุ้ม?
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">คำนวณระยะเวลาคุ้มทุนรีไฟแนนซ์ เทียบค่าใช้จ่ายกับดอกเบี้ยที่ประหยัดได้รายเดือน</p>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6 mb-8">
      <form id="refi-form" class="space-y-5">
        <div>
          <label for="loan-balance" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ยอดสินเชื่อคงเหลือ (บาท)</label>
          <input type="text" id="loan-balance" inputmode="numeric" placeholder="เช่น 2,000,000"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="current-rate" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ดอกเบี้ยปัจจุบัน (%/ปี)</label>
            <input type="text" id="current-rate" inputmode="decimal" placeholder="เช่น 7.5"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
          <div>
            <label for="new-rate" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ดอกเบี้ยใหม่ (%/ปี)</label>
            <input type="text" id="new-rate" inputmode="decimal" placeholder="เช่น 5.99"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="remaining-term" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ระยะเวลาผ่อนที่เหลือ (ปี)</label>
            <input type="text" id="remaining-term" inputmode="numeric" placeholder="เช่น 20"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
          <div>
            <label for="refi-cost" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">ค่าใช้จ่ายรีไฟแนนซ์ทั้งหมด (บาท)</label>
            <input type="text" id="refi-cost" inputmode="numeric" placeholder="เช่น 50,000"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-base" />
          </div>
        </div>
        <button type="submit" class="w-full sm:w-auto px-8 py-3 bg-primary-600 text-white font-semibold rounded-md hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 transition-colors text-base">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="hidden mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">ผลการคำนวณ</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-4">
          <div class="bg-primary-50 dark:bg-primary-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ประหยัดค่างวด/เดือน</div>
            <div id="res-monthly-saving" class="text-xl font-bold text-primary-700 dark:text-primary-300">-</div>
          </div>
          <div class="bg-blue-50 dark:bg-blue-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">จุดคุ้มทุน</div>
            <div id="res-breakeven" class="text-xl font-bold text-blue-700 dark:text-blue-300">-</div>
          </div>
          <div class="bg-green-50 dark:bg-green-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ประหยัดดอกเบี้ยรวม</div>
            <div id="res-total-saving" class="text-xl font-bold text-green-600">-</div>
          </div>
          <div class="bg-orange-50 dark:bg-orange-900/30 rounded-lg p-4 text-center">
            <div class="text-sm text-gray-600 dark:text-gray-400 mb-1">ค่าใช้จ่ายรีไฟแนนซ์</div>
            <div id="res-cost" class="text-xl font-bold text-orange-700 dark:text-orange-300">-</div>
          </div>
        </div>
        <div id="verdict" class="p-3 rounded-lg text-sm"></div>
      </div>
    </div>

    <GuardedAdSlot />

    <section class="prose prose-gray dark:prose-invert max-w-none mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-3">วิธีคำนวณจุดคุ้มทุนรีไฟแนนซ์</h2>
      <p>จุดคุ้มทุน (Break-Even Point) = ค่าใช้จ่ายรีไฟแนนซ์ทั้งหมด ÷ ค่างวดที่ประหยัดได้ต่อเดือน หากวางแผนอยู่บ้านนานกว่าจุดคุ้มทุน การรีไฟแนนซ์คุ้มค่า หากจะย้ายหรือขายบ้านก่อนถึงจุดคุ้มทุน ควรพิจารณาใหม่</p>
    </section>

    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-4">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
            <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 dark:text-gray-100 hover:text-primary-600">{faq.question}</summary>
            <div class="px-4 pb-4 text-sm text-gray-600 dark:text-gray-400">{faq.answer}</div>
          </details>
        ))}
      </div>
    </section>

    <RelatedArticles currentHref="/คำนวณจุดคุ้มทุนรีไฟแนนซ์/" />
    <RelatedCalculators currentHref="/คำนวณจุดคุ้มทุนรีไฟแนนซ์/" />

    <div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg text-sm text-yellow-800 dark:text-yellow-300">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> ผลการคำนวณเป็นการประมาณการ เงื่อนไขจริงขึ้นอยู่กับนโยบายของสถาบันการเงิน
    </div>
  </article>

  <script>
    function parseNum(v: string): number { return Math.max(0, parseFloat(v.replace(/,/g, '')) || 0); }
    function fmt(n: number): string { return new Intl.NumberFormat('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }

    document.getElementById('refi-form')!.addEventListener('submit', (e) => {
      e.preventDefault();
      const bal = parseNum((document.getElementById('loan-balance') as HTMLInputElement).value);
      const curRate = parseNum((document.getElementById('current-rate') as HTMLInputElement).value) || 7.5;
      const newRate = parseNum((document.getElementById('new-rate') as HTMLInputElement).value) || 5.99;
      const years = parseNum((document.getElementById('remaining-term') as HTMLInputElement).value) || 20;
      const cost = parseNum((document.getElementById('refi-cost') as HTMLInputElement).value);
      if (!bal) return;

      const n = years * 12;
      const calcPmt = (r: number) => r === 0 ? bal / n : bal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);

      const curPmt = calcPmt(curRate / 100 / 12);
      const newPmt = calcPmt(newRate / 100 / 12);
      const monthlySaving = curPmt - newPmt;
      const breakEvenMonths = monthlySaving > 0 ? Math.ceil(cost / monthlySaving) : Infinity;
      const totalSaving = monthlySaving * n - cost;

      (document.getElementById('res-monthly-saving') as HTMLElement).textContent = fmt(monthlySaving) + ' บาท';
      (document.getElementById('res-breakeven') as HTMLElement).textContent = isFinite(breakEvenMonths) ? breakEvenMonths + ' เดือน' : 'ไม่คุ้ม';
      (document.getElementById('res-total-saving') as HTMLElement).textContent = fmt(totalSaving) + ' บาท';
      (document.getElementById('res-cost') as HTMLElement).textContent = fmt(cost) + ' บาท';

      const verdict = document.getElementById('verdict') as HTMLElement;
      if (monthlySaving <= 0) {
        verdict.className = 'p-3 rounded-lg text-sm bg-red-50 dark:bg-red-900/20 text-red-800 dark:text-red-300';
        verdict.textContent = 'อัตราดอกเบี้ยใหม่ไม่ต่ำกว่าเดิม ไม่มีประโยชน์ในการรีไฟแนนซ์';
      } else if (breakEvenMonths <= 24) {
        verdict.className = 'p-3 rounded-lg text-sm bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-300';
        verdict.textContent = `✓ คุ้มค่ามาก จุดคุ้มทุน ${breakEvenMonths} เดือน ประหยัดดอกเบี้ยสุทธิ ${fmt(totalSaving)} บาท`;
      } else if (breakEvenMonths <= 48) {
        verdict.className = 'p-3 rounded-lg text-sm bg-yellow-50 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-300';
        verdict.textContent = `จุดคุ้มทุน ${breakEvenMonths} เดือน (~${Math.ceil(breakEvenMonths/12)} ปี) คุ้มถ้าวางแผนอยู่บ้านนานกว่านั้น`;
      } else {
        verdict.className = 'p-3 rounded-lg text-sm bg-orange-50 dark:bg-orange-900/20 text-orange-800 dark:text-orange-300';
        verdict.textContent = `จุดคุ้มทุน ${breakEvenMonths} เดือน (~${Math.ceil(breakEvenMonths/12)} ปี) ค่อนข้างนาน พิจารณาให้รอบคอบ`;
      }

      document.getElementById('results')!.classList.remove('hidden');
      document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
      trackCalculatorUsed('refi-breakeven');
    });
  </script>
</BaseLayout>
