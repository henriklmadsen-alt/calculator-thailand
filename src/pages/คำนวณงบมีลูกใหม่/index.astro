---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'คำนวณงบมีลูกใหม่ 2569 | ค่าใช้จ่ายรองรับบุตรคนแรก ค่าคลอด | เครื่องคำนวณไทย';
const pageDescription = 'ประมาณค่าใช้จ่ายรองรับบุตรคนแรก ค่าคลอด ของใช้เด็ก นมผงหรือนมแม่ รายจ่ายต่อเดือนปีแรก เพื่อวางแผนการเงินก่อนมีลูก';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณงบมีลูกใหม่/`;

const faqData = [
  {
    question: 'ค่าคลอดในโรงพยาบาลเอกชนเท่าไร?',
    answer: 'ค่าคลอดในโรงพยาบาลเอกชนสำหรับการคลอดธรรมชาติอยู่ที่ประมาณ 30,000-80,000 บาท และการผ่าคลอดอยู่ที่ 50,000-150,000 บาท ขึ้นอยู่กับโรงพยาบาลและแพ็กเกจที่เลือก',
  },
  {
    question: 'ค่าใช้จ่ายเลี้ยงลูกปีแรกเท่าไร?',
    answer: 'ค่าใช้จ่ายเลี้ยงลูกปีแรกโดยไม่รวมค่าคลอดอยู่ที่ประมาณ 60,000-200,000 บาท ขึ้นอยู่กับการเลี้ยงด้วยนมแม่หรือนมผง ค่าเนอสเซอรี่ ค่าของใช้ และค่ารักษาพยาบาล',
  },
  {
    question: 'ควรเก็บเงินสำรองเท่าไรก่อนมีลูก?',
    answer: 'แนะนำให้มีเงินสำรองอย่างน้อย 200,000-500,000 บาทก่อนมีลูก เพื่อครอบคลุมค่าคลอด ค่าของใช้เด็กชุดแรก และค่าใช้จ่ายในช่วง 6-12 เดือนแรก รวมถึงกรณีฉุกเฉิน',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณงบมีลูกใหม่',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณงบมีลูกใหม่">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">คำนวณงบมีลูกใหม่ 2569</h1>
    <p class="mb-6 text-gray-600">ประมาณค่าใช้จ่ายรองรับบุตรคนแรก ค่าคลอด ของใช้เด็ก และรายจ่ายต่อเดือนปีแรก</p>

    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="baby-form" class="space-y-4">
        <fieldset>
          <legend class="mb-2 text-sm font-medium text-gray-700">ประเภทการคลอด</legend>
          <div class="flex flex-wrap gap-2">
            <label class="birth-pill cursor-pointer rounded-full border-2 border-primary-500 bg-primary-50 px-4 py-2 text-sm font-medium text-primary-700 transition-colors">
              <input type="radio" name="birthType" value="natural" class="sr-only" checked /> คลอดธรรมชาติ
            </label>
            <label class="birth-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors">
              <input type="radio" name="birthType" value="csection" class="sr-only" /> ผ่าคลอด
            </label>
          </div>
        </fieldset>
        <fieldset>
          <legend class="mb-2 text-sm font-medium text-gray-700">ประเภทโรงพยาบาล</legend>
          <div class="flex flex-wrap gap-2">
            <label class="hosp-pill cursor-pointer rounded-full border-2 border-primary-500 bg-primary-50 px-4 py-2 text-sm font-medium text-primary-700 transition-colors">
              <input type="radio" name="hospType" value="public" class="sr-only" checked /> โรงพยาบาลรัฐ
            </label>
            <label class="hosp-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors">
              <input type="radio" name="hospType" value="private" class="sr-only" /> โรงพยาบาลเอกชน
            </label>
          </div>
        </fieldset>
        <fieldset>
          <legend class="mb-2 text-sm font-medium text-gray-700">การเลี้ยงลูก</legend>
          <div class="flex flex-wrap gap-2">
            <label class="milk-pill cursor-pointer rounded-full border-2 border-primary-500 bg-primary-50 px-4 py-2 text-sm font-medium text-primary-700 transition-colors">
              <input type="radio" name="milkType" value="breast" class="sr-only" checked /> นมแม่
            </label>
            <label class="milk-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors">
              <input type="radio" name="milkType" value="formula" class="sr-only" /> นมผง
            </label>
          </div>
        </fieldset>
        <button type="submit"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto">
          คำนวณ
        </button>
      </form>
    </div>

    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ค่าใช้จ่ายโดยประมาณ</h2>
        <div class="mb-6 rounded-lg bg-primary-50 p-4 text-center">
          <div class="mb-1 text-sm text-gray-600">ค่าใช้จ่ายรวมปีแรก</div>
          <div id="res-total" class="text-4xl font-bold text-primary-700 sm:text-5xl">-</div>
          <div class="mt-1 text-sm text-gray-500">บาท</div>
        </div>
        <div class="space-y-0">
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🏥 ค่าคลอด</span>
            <span id="res-birth" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🛁 ของใช้เด็กชุดแรก</span>
            <span id="res-items" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🍼 ค่าอาหาร/นม (12 เดือน)</span>
            <span id="res-milk" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">💉 ค่าวัคซีนและตรวจสุขภาพ</span>
            <span id="res-vaccine" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-700">👶 รายจ่ายต่อเดือน (เดือนที่ 2+)</span>
            <span id="res-monthly" class="text-sm font-medium text-gray-900">-</span>
          </div>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <h2 class="mb-4 text-xl font-bold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <div class="rounded-lg border border-gray-200 p-4">
            <h3 class="mb-2 font-semibold text-gray-900">{faq.question}</h3>
            <p class="text-sm text-gray-600">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <RelatedCalculators currentHref="/คำนวณงบมีลูกใหม่/" categoryId="bills" maxItems={4} />
  </article>
</BaseLayout>

<script>
  const fmt = (v: number) => '฿' + Math.round(v).toLocaleString('th-TH');

  const BIRTH_COSTS: Record<string, Record<string, number>> = {
    public:  { natural: 10000, csection: 20000 },
    private: { natural: 50000, csection: 100000 },
  };
  const MILK_MONTHLY: Record<string, number> = { breast: 500, formula: 3500 };
  const ITEMS = 25000; // baby gear one-time
  const VACCINE = 8000;

  function setupPills(cls: string) {
    document.querySelectorAll<HTMLLabelElement>(`.${cls}`).forEach((pill) => {
      pill.querySelector('input')?.addEventListener('change', () => {
        document.querySelectorAll<HTMLLabelElement>(`.${cls}`).forEach((p) => {
          p.classList.remove('border-primary-500', 'bg-primary-50', 'text-primary-700');
          p.classList.add('border-gray-200', 'text-gray-700');
        });
        pill.classList.remove('border-gray-200', 'text-gray-700');
        pill.classList.add('border-primary-500', 'bg-primary-50', 'text-primary-700');
      });
    });
  }
  setupPills('birth-pill');
  setupPills('hosp-pill');
  setupPills('milk-pill');

  document.getElementById('baby-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const birthType = (document.querySelector('input[name="birthType"]:checked') as HTMLInputElement)?.value ?? 'natural';
    const hospType = (document.querySelector('input[name="hospType"]:checked') as HTMLInputElement)?.value ?? 'public';
    const milkType = (document.querySelector('input[name="milkType"]:checked') as HTMLInputElement)?.value ?? 'breast';

    const birthCost = BIRTH_COSTS[hospType][birthType];
    const milkMonthly = MILK_MONTHLY[milkType];
    const milkYear = milkMonthly * 12;
    const monthly = milkMonthly + 3000; // milk + diapers + misc
    const total = birthCost + ITEMS + milkYear + VACCINE;

    document.getElementById('res-total')!.textContent = fmt(total);
    document.getElementById('res-birth')!.textContent = fmt(birthCost);
    document.getElementById('res-items')!.textContent = fmt(ITEMS);
    document.getElementById('res-milk')!.textContent = fmt(milkYear);
    document.getElementById('res-vaccine')!.textContent = fmt(VACCINE);
    document.getElementById('res-monthly')!.textContent = fmt(monthly) + '/เดือน';
    document.getElementById('results')!.classList.remove('hidden');
  });
</script>
