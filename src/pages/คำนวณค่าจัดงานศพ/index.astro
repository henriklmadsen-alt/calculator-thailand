---
import RelatedCalculators from '../../components/templates/RelatedCalculators.astro';
import RelatedArticles from '../../components/templates/RelatedArticles.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuardedAdSlot from '../../components/templates/GuardedAdSlot.astro';

const pageTitle = 'คำนวณค่าจัดงานศพ 2569 | ประมาณค่าใช้จ่ายงานศพ สวด เผา อาหาร | Kamnuanlek';
const pageDescription = 'คำนวณค่าจัดงานศพออนไลน์ฟรี ประมาณค่าใช้จ่ายสวดอภิธรรม ฌาปนกิจ อาหาร ของชำร่วย แยกตามระดับงานและภูมิภาค อัปเดตปี 2569';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://www.kamnuanlek.com').replace(/\/$/, '');
const canonical = `${siteUrl}/คำนวณค่าจัดงานศพ/`;

const faqData = [
  {
    question: 'ค่าจัดงานศพเฉลี่ยเท่าไร?',
    answer: 'ค่าจัดงานศพในประเทศไทยมีตั้งแต่ประมาณ 30,000-50,000 บาท สำหรับงานประหยัด ไปจนถึง 200,000-500,000 บาท สำหรับงานสมบูรณ์แบบ ขึ้นอยู่กับจำนวนวันสวด ระดับงาน ภูมิภาค และจำนวนแขก ควรสอบถามวัดหรือสำนักสงฆ์โดยตรงเพื่อทราบราคาจริง',
  },
  {
    question: 'สวดกี่วันดี?',
    answer: 'ตามธรรมเนียมไทย นิยมสวดอภิธรรม 3 วัน 5 วัน หรือ 7 วัน โดย 3 วันเป็นที่นิยมมากที่สุดในปัจจุบัน สำหรับงานประหยัดอาจสวด 1 วัน ส่วน 5 หรือ 7 วันมักเป็นงานที่ครบพิธี หลายวัดมีโปรแกรมช่วยเหลือด้านค่าใช้จ่ายสำหรับผู้มีรายได้น้อย',
  },
  {
    question: 'วัดคิดค่าใช้จ่ายอย่างไร?',
    answer: 'ค่าใช้จ่ายวัดแต่ละแห่งแตกต่างกัน โดยทั่วไปประกอบด้วย ค่าใช้สถานที่วัด (ศาลา) ค่าสังฆทาน/นิมนต์พระ ค่าเผา/ฌาปนกิจ ค่าโลงศพ และค่าตกแต่ง บางวัดมีแพ็กเกจรวมให้เลือก ควรสอบถามวัดโดยตรงเพราะราคาจะแตกต่างกันมาก',
  },
  {
    question: 'ต้องเตรียมอะไรบ้างสำหรับงานศพ?',
    answer: 'สิ่งที่ต้องเตรียมหลักๆ ได้แก่ จองศาลาวัด เลือกโลงศพ จัดดอกไม้/พวงหรีด สั่งอาหาร/น้ำดื่มสำหรับแขก เตรียมของชำร่วย และประสานงานเรื่องฌาปนกิจ หลายวัดมีบริการจัดการครบวงจร ช่วยลดภาระในการจัดเตรียม',
  },
  {
    question: 'ค่าเผาศพเท่าไร?',
    answer: 'ค่าฌาปนกิจ/เผาศพแตกต่างกันตามวัดและภูมิภาค ตั้งแต่ประมาณ 3,000-5,000 บาท สำหรับงานประหยัด ไปจนถึง 15,000-50,000 บาท สำหรับงานสมบูรณ์แบบ ราคารวมค่าเชื้อเพลิง ค่าเตาเผา และค่าจัดเก็บอัฐิ บางวัดรวมค่าเผาในแพ็กเกจงานศพแล้ว',
  },
];

const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'เครื่องคำนวณค่าจัดงานศพ',
  description: pageDescription,
  url: canonical,
  applicationCategory: 'LifestyleApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'THB' },
  inLanguage: 'th',
};

const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonical} pageName="คำนวณค่าจัดงานศพ">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

  <article>
    <h1 class="mb-4 text-2xl font-bold text-gray-900 sm:text-3xl">
      คำนวณค่าจัดงานศพ (Funeral Cost Calculator)
    </h1>
    <p class="mb-6 text-gray-600">
      ประมาณค่าใช้จ่ายจัดงานศพ สวดอภิธรรม เผาศพ อาหาร ของชำร่วย คำนวณฟรีออนไลน์
    </p>

    <!-- Info Banner -->
    <div class="mb-6 rounded-xl border border-sky-100 bg-sky-50 p-4">
      <p class="text-sm text-sky-700">
        🙏 เครื่องมือนี้ช่วยประมาณค่าใช้จ่ายเพื่อการวางแผนเบื้องต้น ค่าใช้จ่ายจริงขึ้นอยู่กับวัด ภูมิภาค และรายละเอียดพิธี กรุณาสอบถามวัดหรือสำนักสงฆ์โดยตรง
      </p>
    </div>

    <!-- Calculator Card -->
    <div class="mb-8 rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <form id="funeral-form" class="space-y-5">

        <!-- A. Ceremony Scale -->
        <fieldset>
          <legend class="mb-3 text-sm font-semibold text-gray-700">ระดับงาน</legend>
          <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="เลือกระดับงาน">
            <label class="scale-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:border-primary-300">
              <input type="radio" name="scale" value="budget" class="sr-only" />
              ประหยัด
            </label>
            <label class="scale-pill cursor-pointer rounded-full border-2 border-primary-500 bg-primary-50 px-4 py-2 text-sm font-medium text-primary-700 transition-colors hover:border-primary-300">
              <input type="radio" name="scale" value="standard" class="sr-only" checked />
              ปานกลาง
            </label>
            <label class="scale-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:border-primary-300">
              <input type="radio" name="scale" value="premium" class="sr-only" />
              สมบูรณ์
            </label>
          </div>
        </fieldset>

        <!-- B. Chanting Days -->
        <fieldset>
          <legend class="mb-3 text-sm font-semibold text-gray-700">จำนวนวันสวดอภิธรรม</legend>
          <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="เลือกจำนวนวันสวด">
            <label class="days-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:border-primary-300">
              <input type="radio" name="days" value="1" class="sr-only" />
              1 วัน
            </label>
            <label class="days-pill cursor-pointer rounded-full border-2 border-primary-500 bg-primary-50 px-4 py-2 text-sm font-medium text-primary-700 transition-colors hover:border-primary-300">
              <input type="radio" name="days" value="3" class="sr-only" checked />
              3 วัน
            </label>
            <label class="days-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:border-primary-300">
              <input type="radio" name="days" value="5" class="sr-only" />
              5 วัน
            </label>
            <label class="days-pill cursor-pointer rounded-full border-2 border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:border-primary-300">
              <input type="radio" name="days" value="7" class="sr-only" />
              7 วัน
            </label>
          </div>
        </fieldset>

        <!-- C. Guest Count -->
        <div>
          <label for="guests" class="mb-1 block text-sm font-medium text-gray-700">จำนวนแขกโดยประมาณ (คน)</label>
          <input
            id="guests"
            type="text"
            inputmode="numeric"
            placeholder="เช่น 100"
            class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-48"
          />
        </div>

        <!-- D. Region -->
        <div>
          <label for="region" class="mb-1 block text-sm font-medium text-gray-700">ภูมิภาค</label>
          <select id="region" class="w-full rounded-md border border-gray-300 px-3 py-2 text-base focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500 sm:w-auto">
            <option value="bangkok" selected>กรุงเทพฯ และปริมณฑล</option>
            <option value="central">ภาคกลาง</option>
            <option value="north">ภาคเหนือ</option>
            <option value="northeast">ภาคตะวันออกเฉียงเหนือ</option>
            <option value="south">ภาคใต้</option>
          </select>
        </div>

        <!-- E. Cremation Checkbox -->
        <div class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3">
          <input type="checkbox" id="include-cremation" checked class="h-5 w-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
          <label for="include-cremation" class="text-sm font-medium text-gray-700">
            รวมค่าเผาศพ/ฌาปนกิจ
          </label>
        </div>

        <!-- F. Guest Meals Checkbox -->
        <div class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3">
          <input type="checkbox" id="include-meals" checked class="h-5 w-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500" />
          <label for="include-meals" class="text-sm font-medium text-gray-700">
            รวมค่าอาหารเลี้ยงแขก
          </label>
        </div>

        <button
          type="submit"
          id="btn-calculate"
          class="w-full rounded-md bg-primary-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 sm:w-auto"
        >
          คำนวณค่าใช้จ่าย
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="mb-8 hidden">
      <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <h2 class="mb-4 text-lg font-semibold text-gray-900">ค่าใช้จ่ายโดยประมาณ</h2>

        <!-- Total Summary -->
        <div class="mb-6 rounded-lg bg-primary-50 p-4 text-center">
          <div class="mb-1 text-sm text-gray-600">ค่าใช้จ่ายโดยประมาณ</div>
          <div id="res-total" class="text-4xl font-bold text-primary-700 sm:text-5xl">-</div>
          <div class="mt-1 text-sm text-gray-500">บาท (ช่วงราคา)</div>
        </div>

        <!-- Cost Breakdown -->
        <h3 class="mb-3 text-base font-semibold text-gray-900">รายละเอียดค่าใช้จ่าย</h3>
        <div class="space-y-0">
          <div id="row-venue" class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🏛️ ค่าใช้สถานที่วัด</span>
            <span id="cost-venue" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div id="row-monks" class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">📿 ค่าสังฆทาน/นิมนต์พระ</span>
            <span id="cost-monks" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div id="row-cremation" class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🔥 ค่าฌาปนกิจ/เผา</span>
            <span id="cost-cremation" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div id="row-coffin" class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">⚰️ ค่าโลงศพ</span>
            <span id="cost-coffin" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div id="row-meals" class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🍱 ค่าอาหารเลี้ยงแขก</span>
            <span id="cost-meals" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div id="row-flowers" class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">💐 ค่าดอกไม้/พวงหรีด/ตกแต่ง</span>
            <span id="cost-flowers" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div id="row-gifts" class="flex items-center justify-between border-b border-gray-100 py-3">
            <span class="text-sm text-gray-700">🎁 ค่าของชำร่วย</span>
            <span id="cost-gifts" class="text-sm font-medium text-gray-900">-</span>
          </div>
          <div id="row-misc" class="flex items-center justify-between py-3">
            <span class="text-sm text-gray-700">📋 ค่าใช้จ่ายอื่นๆ</span>
            <span id="cost-misc" class="text-sm font-medium text-gray-900">-</span>
          </div>
        </div>

        <!-- Tips -->
        <div id="tips-box" class="mt-6 rounded-lg bg-gray-50 p-4">
          <p class="text-sm font-medium text-gray-700">💡 คำแนะนำ</p>
          <p id="tips-text" class="mt-1 text-sm text-gray-600"></p>
        </div>

        <!-- Note -->
        <div class="mt-4 rounded-lg border border-blue-200 bg-blue-50 p-3 text-sm text-blue-800">
          <strong>หมายเหตุ:</strong> ราคาเป็นการประมาณจากข้อมูลตลาดเฉลี่ยในประเทศไทย (2568-2569)
          ค่าใช้จ่ายจริงขึ้นอยู่กับวัด ภูมิภาค และรายละเอียดพิธี กรุณาสอบถามวัดหรือสำนักสงฆ์โดยตรง
        </div>
      </div>
    </div>

    <GuardedAdSlot templateType="calculator" slotId="C1" revealAfterSelector="#results" />

    <!-- SEO Content -->
    <section class="prose prose-slate mb-8 max-w-none rounded-lg border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <h2 class="mb-3 text-xl font-semibold text-gray-900">ค่าจัดงานศพในประเทศไทย 2569</h2>
      <p>
        งานศพหรือพิธีฌาปนกิจเป็นพิธีกรรมสำคัญในวัฒนธรรมไทย ค่าใช้จ่ายจะแตกต่างกันไปตามปัจจัยหลายประการ
        ได้แก่ จำนวนวันสวดอภิธรรม ระดับงาน ภูมิภาค และจำนวนแขกที่มาร่วมงาน
        เครื่องมือนี้ช่วยให้ท่านสามารถประมาณค่าใช้จ่ายเบื้องต้นเพื่อวางแผนทางการเงิน
      </p>

      <h3 class="mb-2 text-lg font-semibold text-gray-900">องค์ประกอบค่าใช้จ่ายงานศพ</h3>
      <ul>
        <li><strong>ค่าใช้สถานที่วัด</strong> — ค่าเช่าศาลาสำหรับจัดงาน คิดเป็นรายวัน</li>
        <li><strong>ค่าสังฆทาน/นิมนต์พระ</strong> — ค่านิมนต์พระสงฆ์สวดอภิธรรม คิดเป็นรายวัน</li>
        <li><strong>ค่าฌาปนกิจ/เผา</strong> — ค่าเตาเผา เชื้อเพลิง และการจัดเก็บอัฐิ</li>
        <li><strong>ค่าโลงศพ</strong> — ค่าโลงศพตามระดับงาน</li>
        <li><strong>ค่าอาหาร</strong> — ค่าอาหารและเครื่องดื่มสำหรับแขก คิดต่อคนต่อวัน</li>
        <li><strong>ค่าดอกไม้/ตกแต่ง</strong> — ค่าดอกไม้จัดงาน พวงหรีด และการตกแต่งศาลา</li>
        <li><strong>ค่าของชำร่วย</strong> — หนังสือสวดมนต์ ของที่ระลึก คิดต่อคน</li>
        <li><strong>ค่าใช้จ่ายอื่นๆ</strong> — ค่าประสานงาน ค่าเดินทาง และค่าใช้จ่ายเบ็ดเตล็ด</li>
      </ul>

      <h3 class="mb-2 text-lg font-semibold text-gray-900">ค่าใช้จ่ายตามระดับงาน</h3>
      <div class="overflow-x-auto">
        <table>
          <thead>
            <tr>
              <th>รายการ</th>
              <th>ประหยัด</th>
              <th>ปานกลาง</th>
              <th>สมบูรณ์</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>ค่าใช้สถานที่วัด (ต่อวัน)</td>
              <td>1,000-3,000</td>
              <td>3,000-8,000</td>
              <td>8,000-20,000</td>
            </tr>
            <tr>
              <td>ค่าสังฆทาน (ต่อวัน)</td>
              <td>500-1,500</td>
              <td>1,500-4,000</td>
              <td>4,000-10,000</td>
            </tr>
            <tr>
              <td>ค่าฌาปนกิจ</td>
              <td>3,000-5,000</td>
              <td>5,000-15,000</td>
              <td>15,000-50,000</td>
            </tr>
            <tr>
              <td>ค่าโลงศพ</td>
              <td>3,000-8,000</td>
              <td>8,000-25,000</td>
              <td>25,000-80,000</td>
            </tr>
            <tr>
              <td>ค่าอาหาร (ต่อคนต่อวัน)</td>
              <td>80-120</td>
              <td>120-200</td>
              <td>200-400</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h3 class="mb-2 text-lg font-semibold text-gray-900">วิธีประหยัดค่าจัดงานศพ</h3>
      <ul>
        <li>สอบถามวัดเรื่องการลดค่าใช้จ่าย หลายวัดมีโปรแกรมช่วยเหลือ</li>
        <li>ขอใบเสนอราคาจากวัดและร้านจัดงานอย่างน้อย 2-3 แห่ง</li>
        <li>พิจารณาจำนวนวันสวดให้เหมาะสมกับงบประมาณ</li>
        <li>ตรวจสอบสิทธิช่วยเหลือจากประกันสังคมหรือหน่วยงานที่เกี่ยวข้อง</li>
      </ul>
    </section>

    <GuardedAdSlot templateType="calculator" slotId="C2" />

    <RelatedArticles currentHref="/คำนวณค่าจัดงานศพ/" />
    <RelatedCalculators currentHref="/คำนวณค่าจัดงานศพ/" />

    <!-- FAQ Section -->
    <section class="mb-8">
      <h2 class="mb-4 text-xl font-semibold text-gray-900">คำถามที่พบบ่อย</h2>
      <div class="space-y-4">
        {faqData.map((faq) => (
          <details class="rounded-lg border border-gray-200 bg-white shadow-sm">
            <summary class="cursor-pointer px-4 py-3 font-medium text-gray-900 hover:text-primary-600">
              {faq.question}
            </summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-4 text-sm text-yellow-800">
      <strong>ข้อจำกัดความรับผิดชอบ:</strong> เครื่องมือนี้ใช้เพื่อช่วยประมาณการค่าใช้จ่ายจัดงานศพเบื้องต้น
      ค่าใช้จ่ายจริงขึ้นอยู่กับวัด ภูมิภาค ระดับงาน และรายละเอียดพิธี ควรสอบถามวัดหรือสำนักสงฆ์โดยตรงเพื่อทราบราคาจริง
    </div>
  </article>

  <script>
    // ─── Cost Data ───
    interface CostRange { low: number; high: number }

    const SCALE_COSTS: Record<string, {
      venue: CostRange;    // per day
      monks: CostRange;    // per day
      cremation: CostRange; // one-time
      coffin: CostRange;   // one-time
      meals: CostRange;    // per guest per day
      flowers: CostRange;  // one-time
      gifts: CostRange;    // per guest
      misc: CostRange;     // one-time
    }> = {
      budget: {
        venue: { low: 1000, high: 3000 },
        monks: { low: 500, high: 1500 },
        cremation: { low: 3000, high: 5000 },
        coffin: { low: 3000, high: 8000 },
        meals: { low: 80, high: 120 },
        flowers: { low: 2000, high: 5000 },
        gifts: { low: 20, high: 50 },
        misc: { low: 1000, high: 3000 },
      },
      standard: {
        venue: { low: 3000, high: 8000 },
        monks: { low: 1500, high: 4000 },
        cremation: { low: 5000, high: 15000 },
        coffin: { low: 8000, high: 25000 },
        meals: { low: 120, high: 200 },
        flowers: { low: 5000, high: 15000 },
        gifts: { low: 50, high: 100 },
        misc: { low: 3000, high: 8000 },
      },
      premium: {
        venue: { low: 8000, high: 20000 },
        monks: { low: 4000, high: 10000 },
        cremation: { low: 15000, high: 50000 },
        coffin: { low: 25000, high: 80000 },
        meals: { low: 200, high: 400 },
        flowers: { low: 15000, high: 50000 },
        gifts: { low: 100, high: 300 },
        misc: { low: 8000, high: 20000 },
      },
    };

    const REGIONAL_MULTIPLIER: Record<string, number> = {
      bangkok: 1.0,
      central: 0.85,
      north: 0.75,
      northeast: 0.70,
      south: 0.80,
    };

    const TIPS: Record<string, string> = {
      budget: 'สอบถามวัดเรื่องการลดค่าใช้จ่าย หลายวัดมีโปรแกรมช่วยเหลือ',
      standard: 'ขอใบเสนอราคาจากวัดและร้านจัดงานอย่างน้อย 2-3 แห่ง',
      premium: 'พิจารณาจ้างผู้จัดงานมืออาชีพเพื่อดูแลรายละเอียดพิธี',
    };

    // ─── Helpers ───
    const parseNum = (v: string): number => {
      const n = parseInt(String(v ?? '').replace(/,/g, '').trim(), 10);
      return Number.isFinite(n) && n > 0 ? n : 0;
    };

    const fmtMoney = (v: number): string =>
      new Intl.NumberFormat('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(Math.round(v));

    const fmtRange = (low: number, high: number): string => `฿${fmtMoney(low)} — ${fmtMoney(high)}`;

    // ─── Pill Selection ───
    function setupPills(selector: string) {
      const pills = document.querySelectorAll<HTMLLabelElement>(selector);
      pills.forEach((pill) => {
        const radio = pill.querySelector<HTMLInputElement>('input[type="radio"]');
        if (!radio) return;
        radio.addEventListener('change', () => {
          pills.forEach((p) => {
            p.classList.remove('border-primary-500', 'bg-primary-50', 'text-primary-700');
            p.classList.add('border-gray-200', 'text-gray-700');
          });
          pill.classList.remove('border-gray-200', 'text-gray-700');
          pill.classList.add('border-primary-500', 'bg-primary-50', 'text-primary-700');
        });
      });
    }

    setupPills('.scale-pill');
    setupPills('.days-pill');

    // ─── Calculation ───
    function calculate() {
      const scaleRadio = document.querySelector<HTMLInputElement>('input[name="scale"]:checked');
      const daysRadio = document.querySelector<HTMLInputElement>('input[name="days"]:checked');
      const scale = scaleRadio?.value ?? 'standard';
      const days = parseInt(daysRadio?.value ?? '3', 10);
      const guests = parseNum((document.getElementById('guests') as HTMLInputElement).value) || 100;
      const region = (document.getElementById('region') as HTMLSelectElement).value;
      const includeCremation = (document.getElementById('include-cremation') as HTMLInputElement).checked;
      const includeMeals = (document.getElementById('include-meals') as HTMLInputElement).checked;

      const costs = SCALE_COSTS[scale];
      const mult = REGIONAL_MULTIPLIER[region] ?? 1.0;

      // Calculate each component
      const calc = (base: CostRange, multiplier: number = 1): CostRange => ({
        low: Math.round(base.low * mult * multiplier),
        high: Math.round(base.high * mult * multiplier),
      });

      const venue = calc(costs.venue, days);
      const monks = calc(costs.monks, days);
      const cremation = includeCremation ? calc(costs.cremation) : { low: 0, high: 0 };
      const coffin = calc(costs.coffin);
      const meals = includeMeals ? calc(costs.meals, guests * days) : { low: 0, high: 0 };
      const flowers = calc(costs.flowers);
      const gifts = calc(costs.gifts, guests);
      const misc = calc(costs.misc);

      const items = [venue, monks, cremation, coffin, meals, flowers, gifts, misc];
      const totalLow = items.reduce((s, i) => s + i.low, 0);
      const totalHigh = items.reduce((s, i) => s + i.high, 0);

      // Update DOM
      document.getElementById('res-total')!.textContent = `฿${fmtMoney(totalLow)} — ${fmtMoney(totalHigh)}`;
      document.getElementById('cost-venue')!.textContent = fmtRange(venue.low, venue.high);
      document.getElementById('cost-monks')!.textContent = fmtRange(monks.low, monks.high);
      document.getElementById('cost-cremation')!.textContent = includeCremation ? fmtRange(cremation.low, cremation.high) : '—';
      document.getElementById('cost-coffin')!.textContent = fmtRange(coffin.low, coffin.high);
      document.getElementById('cost-meals')!.textContent = includeMeals ? fmtRange(meals.low, meals.high) : '—';
      document.getElementById('cost-flowers')!.textContent = fmtRange(flowers.low, flowers.high);
      document.getElementById('cost-gifts')!.textContent = fmtRange(gifts.low, gifts.high);
      document.getElementById('cost-misc')!.textContent = fmtRange(misc.low, misc.high);

      // Conditional row visibility
      document.getElementById('row-cremation')!.classList.toggle('hidden', !includeCremation);
      document.getElementById('row-meals')!.classList.toggle('hidden', !includeMeals);

      // Tips
      document.getElementById('tips-text')!.textContent = TIPS[scale];

      // Show results
      document.getElementById('results')!.classList.remove('hidden');

      // Track analytics
      if (typeof (window as any).trackCalculatorUsed === 'function') {
        (window as any).trackCalculatorUsed('funeral-cost');
      }
    }

    // ─── Event Listeners ───
    document.getElementById('funeral-form')!.addEventListener('submit', (e) => {
      e.preventDefault();
      calculate();
    });

    // Enter key on guest input
    document.getElementById('guests')!.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        calculate();
      }
    });

    // Track result viewed
    const resultObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (typeof (window as any).trackResultViewed === 'function') {
            (window as any).trackResultViewed('funeral-cost');
          }
          resultObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    resultObserver.observe(document.getElementById('results')!);
  </script>
</BaseLayout>
