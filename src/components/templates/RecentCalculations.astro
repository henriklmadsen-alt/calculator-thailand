---
/**
 * Recent Calculations Component (Feature #1: History Auto-Save)
 *
 * Renders the last 5 calculator results from localStorage.
 * - Client-side only (uses is:inline pattern, same as ResultCardHub)
 * - Hidden if no history exists
 * - Each entry shows: emoji + calc name + result + relative time + click link
 *
 * Integration: wire up window.ctAddToHistory() so calculators auto-fire on result
 */
---

<div id="ct-recent-calculations" class="ct-recent-calculations" style="display: none;">
  <div class="ct-recent-header">
    <h3 class="ct-recent-title">📊 การคำนวณล่าสุด</h3>
    <button id="ct-recent-clear-btn" type="button" class="ct-recent-clear-btn" aria-label="ล้างประวัติ">
      ล้าง
    </button>
  </div>

  <ul id="ct-recent-list" class="ct-recent-list">
    <!-- Populated by is:inline script -->
  </ul>
</div>

<style>
  .ct-recent-calculations {
    margin-top: 1rem;
    padding: 1rem;
    background: #f3f4f6;
    border-radius: 0.6rem;
    border: 1px solid #e5e7eb;
  }

  .ct-recent-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .ct-recent-title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1f2937;
  }

  .ct-recent-clear-btn {
    padding: 0.25rem 0.6rem;
    font-size: 0.75rem;
    border: 1px solid #d1d5db;
    background: #fff;
    border-radius: 0.4rem;
    cursor: pointer;
    color: #6b7280;
    transition: all 0.15s;
  }

  .ct-recent-clear-btn:hover {
    background: #f9fafb;
    color: #374151;
  }

  .ct-recent-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ct-recent-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem;
    background: #fff;
    border-radius: 0.4rem;
    border: 1px solid #d1d5db;
    text-decoration: none;
    color: inherit;
    transition: all 0.15s;
    cursor: pointer;
  }

  .ct-recent-item:hover {
    border-color: #2563eb;
    background: #eff6ff;
  }

  .ct-recent-emoji {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .ct-recent-body {
    flex: 1;
    min-width: 0;
  }

  .ct-recent-name {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #1f2937;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ct-recent-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: #6b7280;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ct-recent-result {
    font-weight: 600;
    color: #2563eb;
  }

  .ct-recent-time {
    color: #9ca3af;
  }
</style>

<script is:inline>
(function initRecentCalculations() {
  const STORAGE_KEY = 'ct.history.v1';
  const MAX_DISPLAY = 5;

  // Helper to check localStorage availability
  function isLocalStorageAvailable() {
    try {
      const test = '__ct_storage_test__';
      window.localStorage.setItem(test, test);
      window.localStorage.removeItem(test);
      return true;
    } catch {
      return false;
    }
  }

  // Get all history entries
  function getHistory() {
    if (!isLocalStorageAvailable()) return [];
    try {
      const stored = window.localStorage.getItem(STORAGE_KEY);
      const data = stored ? JSON.parse(stored) : [];
      return Array.isArray(data) ? data : [];
    } catch {
      return [];
    }
  }

  // Format time difference
  function formatTimeDiff(timestamp) {
    const now = Date.now();
    const diffMs = now - timestamp;
    const diffSecs = Math.floor(diffMs / 1000);
    const diffMins = Math.floor(diffSecs / 60);
    const diffHours = Math.floor(diffMins / 60);
    const diffDays = Math.floor(diffHours / 24);

    if (diffSecs < 60) return 'เพิ่งเดี๋ยว';
    if (diffMins < 60) return diffMins + 'นาทีที่แล้ว';
    if (diffHours < 24) return diffHours + 'ชั่วโมงที่แล้ว';
    return diffDays + 'วันที่แล้ว';
  }

  // Render recent list
  function renderRecentList() {
    const container = document.getElementById('ct-recent-calculations');
    const list = document.getElementById('ct-recent-list');

    if (!container || !list) return;

    const history = getHistory().slice(0, MAX_DISPLAY);

    if (history.length === 0) {
      container.style.display = 'none';
      return;
    }

    container.style.display = 'block';
    list.innerHTML = '';

    history.forEach(function(entry) {
      const li = document.createElement('li');
      li.className = 'ct-recent-item';
      li.href = entry.calculatorPath;
      li.addEventListener('click', function() {
        window.location.href = entry.calculatorPath;
      });

      const emoji = document.createElement('span');
      emoji.className = 'ct-recent-emoji';
      emoji.setAttribute('aria-hidden', 'true');
      emoji.textContent = '🔢'; // Generic emoji, could be customized per calc

      const body = document.createElement('div');
      body.className = 'ct-recent-body';

      const name = document.createElement('span');
      name.className = 'ct-recent-name';
      name.textContent = entry.calculatorName;

      const meta = document.createElement('span');
      meta.className = 'ct-recent-meta';

      const result = document.createElement('span');
      result.className = 'ct-recent-result';
      result.textContent = String(entry.result).substring(0, 30);

      const time = document.createElement('span');
      time.className = 'ct-recent-time';
      time.textContent = formatTimeDiff(entry.timestamp);

      meta.appendChild(result);
      meta.appendChild(time);
      body.appendChild(name);
      body.appendChild(meta);
      li.appendChild(emoji);
      li.appendChild(body);
      list.appendChild(li);
    });
  }

  // Clear history button
  function bindClearBtn() {
    const btn = document.getElementById('ct-recent-clear-btn');
    if (!btn) return;

    if (btn.dataset.clearBound === '1') return;
    btn.dataset.clearBound = '1';

    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();

      if (isLocalStorageAvailable()) {
        try {
          window.localStorage.removeItem(STORAGE_KEY);
          renderRecentList();
        } catch {}
      }
    });
  }

  // Global function: add to history (called by calculators after result)
  window.ctAddToHistory = function(calculatorName, calculatorPath, result) {
    if (!isLocalStorageAvailable()) return;

    try {
      const history = getHistory();
      const id = 'hist_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);

      const entry = {
        id: id,
        calculatorName: calculatorName,
        calculatorPath: calculatorPath,
        result: result,
        timestamp: Date.now(),
      };

      history.unshift(entry);

      // FIFO: max 20 entries
      if (history.length > 20) {
        history.length = 20;
      }

      window.localStorage.setItem(STORAGE_KEY, JSON.stringify(history));
      renderRecentList();
    } catch {}
  };

  // Initialize on DOMContentLoaded
  function init() {
    renderRecentList();
    bindClearBtn();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // Export render function for potential dynamic updates
  window.ctRenderRecentList = renderRecentList;
})();
</script>
