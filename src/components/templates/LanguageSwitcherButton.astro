---
// Minimal language switcher button with client-side logic
// Loads English translations dynamically without requiring full page rebuild
---

<button
  id="lang-toggle-btn"
  class="fixed top-4 right-4 z-[51] inline-flex items-center gap-2 px-3 py-2 bg-white rounded-lg shadow-md border border-gray-200 hover:shadow-lg hover:border-primary-300 transition-all font-medium text-sm"
  aria-label="Toggle language"
  title="Click to switch between Thai and English"
>
  <span id="lang-toggle-flag" class="text-lg">🇹🇭</span>
  <span id="lang-toggle-label" class="hidden sm:inline">English</span>
</button>

<script is:inline define:vars={{ PUBLIC_SITE_URL: import.meta.env.PUBLIC_SITE_URL }}>
  (function initLanguageSwitcher() {
    const btn = document.getElementById('lang-toggle-btn');
    const flag = document.getElementById('lang-toggle-flag');
    const label = document.getElementById('lang-toggle-label');
    const LANG_KEY = 'ct.language.v1';

    function getCurrentLanguage() {
      return localStorage.getItem(LANG_KEY) || 'th';
    }

    function setLanguage(lang) {
      localStorage.setItem(LANG_KEY, lang);
      // Navigate to the correct language version of current page
      const currentPath = window.location.pathname;
      let newPath;

      if (lang === 'en') {
        // Switch to English: prepend /en if not already there
        newPath = currentPath.startsWith('/en/') ? currentPath : `/en${currentPath}`;
      } else {
        // Switch to Thai: remove /en prefix if present
        newPath = currentPath.replace(/^\/en/, '') || '/';
      }

      window.location.pathname = newPath;
    }

    function updateButton() {
      const current = getCurrentLanguage();
      const isEnglish = current === 'en';
      // Show the flag of the CURRENT language
      flag.textContent = isEnglish ? '🇬🇧' : '🇹🇭';
      // Show label for the language you can SWITCH TO
      if (label) label.textContent = isEnglish ? 'ไทย' : 'English';
      btn.title = isEnglish ? 'Switch to Thai (สลับเป็นไทย)' : 'Switch to English';
    }

    if (btn) {
      updateButton();
      btn.addEventListener('click', () => {
        const current = getCurrentLanguage();
        setLanguage(current === 'th' ? 'en' : 'th');
      });
    }
  })();
</script>
