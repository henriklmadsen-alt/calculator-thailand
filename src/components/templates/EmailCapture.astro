---
// EmailCapture.astro — CAL-1070
// Appears after save confirmation with Thai opt-in prompt.
// Listens for ct:calculation-saved custom event dispatched by SaveCompareDrawer.
// Sends captured email + calc context to /api/email/capture (Brevo).
---

<script>
  (function () {
    var STORAGE_KEY = 'ct.email-captured.v1';
    var PROMPT_SHOWN_KEY = 'ct.email-prompt-dismissed.v1';
    var API_ENDPOINT = '/api/email/capture';

    function hasOptedIn() {
      try { return !!localStorage.getItem(STORAGE_KEY); } catch { return false; }
    }

    function hasDismissed() {
      try { return !!localStorage.getItem(PROMPT_SHOWN_KEY); } catch { return false; }
    }

    function markOptedIn(email, calcId) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          email: email,
          calcId: calcId,
          optedInAt: new Date().toISOString(),
        }));
      } catch {}
    }

    function markDismissed() {
      try { localStorage.setItem(PROMPT_SHOWN_KEY, '1'); } catch {}
    }

    function removePrompt(el) {
      if (el && el.parentNode) {
        el.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
        el.style.opacity = '0';
        el.style.transform = 'translateY(8px)';
        setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 320);
      }
    }

    function showEmailPrompt(entry) {
      if (hasOptedIn() || hasDismissed()) return;

      // Small delay so save toast appears first
      setTimeout(function () {
        var existing = document.getElementById('ct-email-capture');
        if (existing) return;

        var prompt = document.createElement('div');
        prompt.id = 'ct-email-capture';
        prompt.setAttribute('role', 'dialog');
        prompt.setAttribute('aria-label', 'รับผลลัพธ์ทางอีเมล');
        prompt.style.cssText = [
          'position:fixed',
          'bottom:5.5rem',
          'left:50%',
          'transform:translateX(-50%) translateY(12px)',
          'width:min(92vw, 380px)',
          'background:#fff',
          'border:1.5px solid #bfdbfe',
          'border-radius:1rem',
          'padding:1.1rem 1.25rem 1rem',
          'box-shadow:0 8px 32px rgba(37,99,235,0.18)',
          'z-index:940',
          'font-family:inherit',
          'opacity:0',
          'transition:opacity 0.3s ease, transform 0.3s ease',
        ].join(';');

        prompt.innerHTML = [
          '<button id="ct-email-skip" style="',
            'position:absolute;top:0.6rem;right:0.75rem;',
            'background:none;border:none;cursor:pointer;',
            'font-size:1.1rem;color:#94a3b8;line-height:1;padding:0.25rem;',
            '" aria-label="ปิด">✕</button>',
          '<p style="margin:0 0 0.25rem;font-size:0.9rem;font-weight:700;color:#1e40af;">',
            'รับผลลัพธ์ทางอีเมล และดูประวัติการคำนวณบนทุกอุปกรณ์',
          '</p>',
          '<p style="margin:0 0 0.85rem;font-size:0.78rem;color:#64748b;line-height:1.45;">',
            'บันทึกไว้แล้ว! อยากรับผลทางอีเมลด้วยไหม? เราจะส่งสรุปผลและแจ้งเตือนเมื่อมีเครื่องคำนวณใหม่ที่เกี่ยวข้อง',
          '</p>',
          '<form id="ct-email-form" style="display:flex;gap:0.5rem;flex-wrap:wrap;">',
            '<input id="ct-email-input" type="email" required autocomplete="email" ',
              'placeholder="อีเมลของคุณ (ไม่บังคับ)" ',
              'style="',
                'flex:1;min-width:0;padding:0.55rem 0.75rem;',
                'border:1.5px solid #bfdbfe;border-radius:0.5rem;',
                'font-size:0.85rem;outline:none;',
                'font-family:inherit;',
              '"/>',
            '<button type="submit" style="',
              'padding:0.55rem 1rem;',
              'background:#2563eb;color:#fff;',
              'border:none;border-radius:0.5rem;',
              'font-size:0.85rem;font-weight:600;',
              'cursor:pointer;white-space:nowrap;',
              'font-family:inherit;',
            '">ส่งผลไปที่อีเมล</button>',
          '</form>',
          '<p style="margin:0.55rem 0 0;font-size:0.72rem;color:#94a3b8;text-align:center;">',
            'ไม่มีสแปม ยกเลิกได้ตลอดเวลา — ',
            '<button id="ct-email-no-thanks" style="',
              'background:none;border:none;cursor:pointer;',
              'color:#94a3b8;font-size:0.72rem;padding:0;text-decoration:underline;',
              'font-family:inherit;',
            '">ไม่ต้องการตอนนี้</button>',
          '</p>',
        ].join('');

        document.body.appendChild(prompt);

        // Animate in
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            prompt.style.opacity = '1';
            prompt.style.transform = 'translateX(-50%) translateY(0)';
          });
        });

        // ── Dark mode support ──────────────────────────────────
        if (document.documentElement.dataset.theme === 'dark' ||
            window.matchMedia('(prefers-color-scheme: dark)').matches) {
          prompt.style.background = '#1e293b';
          prompt.style.borderColor = '#334155';
          prompt.style.color = '#f1f5f9';
          var input = document.getElementById('ct-email-input');
          if (input) {
            input.style.background = '#0f172a';
            input.style.borderColor = '#334155';
            input.style.color = '#f1f5f9';
          }
        }

        // ── Event handlers ─────────────────────────────────────
        document.getElementById('ct-email-skip').addEventListener('click', function () {
          markDismissed();
          removePrompt(prompt);
        });

        document.getElementById('ct-email-no-thanks').addEventListener('click', function () {
          markDismissed();
          removePrompt(prompt);
        });

        document.getElementById('ct-email-form').addEventListener('submit', function (e) {
          e.preventDefault();
          var emailInput = document.getElementById('ct-email-input');
          var email = emailInput ? emailInput.value.trim() : '';
          if (!email) return;

          var submitBtn = prompt.querySelector('button[type="submit"]');
          if (submitBtn) { submitBtn.textContent = 'กำลังส่ง…'; submitBtn.disabled = true; }

          var payload = {
            email: email,
            calcId: entry.calcId || '',
            calcTitle: entry.calcTitle || '',
            calcCategory: entry.resultCategory || '',
            resultValue: entry.resultValue || '',
            resultLabel: entry.resultLabel || '',
            url: entry.url || window.location.pathname,
          };

          fetch(API_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          })
            .then(function (res) { return res.json(); })
            .then(function () {
              markOptedIn(email, entry.calcId);
              if (typeof window.trackLanguageAwareEvent === 'function') {
                window.trackLanguageAwareEvent('email_captured', {
                  calculator_type: entry.calcId,
                  language: 'th',
                });
              }
              // Show success state
              prompt.innerHTML = [
                '<p style="margin:0;text-align:center;font-size:0.9rem;font-weight:700;color:#1e40af;padding:0.5rem 0;">',
                  '✅ ส่งผลลัพธ์ทางอีเมลแล้ว!',
                '</p>',
              ].join('');
              setTimeout(function () { removePrompt(prompt); }, 2200);
            })
            .catch(function () {
              // Silent fail — never block the user
              markOptedIn(email, entry.calcId);
              removePrompt(prompt);
            });
        });

        // Auto-dismiss after 12s if no interaction
        setTimeout(function () {
          if (document.getElementById('ct-email-capture')) {
            markDismissed();
            removePrompt(prompt);
          }
        }, 12000);

      }, 600); // 600ms after save toast appears
    }

    window.addEventListener('ct:calculation-saved', function (e) {
      showEmailPrompt(e.detail || {});
    });
  })();
</script>
