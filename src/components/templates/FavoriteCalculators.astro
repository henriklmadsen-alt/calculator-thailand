---
// Favorite Calculators Widget
// Displays bookmarked calculators on the homepage
// Max 5 favorites, scrollable on mobile, grid on desktop

interface Props {
  // No required props - data is loaded via JavaScript from localStorage
}
---

<!-- Favorites Section (hidden by default, shown via JS if favorites exist) -->
<div id="favorites-section" class="hidden mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-bold text-gray-900 flex items-center gap-2">
      <span aria-hidden="true">⭐</span> เครื่องคำนวณที่ฉันใช้บ่อย
    </h2>
    <button
      id="favorites-clear"
      type="button"
      class="text-xs text-gray-400 hover:text-red-500 transition-colors"
    >
      ล้างรายการ
    </button>
  </div>

  <!-- Favorites Grid -->
  <div
    id="favorites-grid"
    class="grid gap-3 sm:gap-4 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5"
  >
    <!-- Favorite cards populated by JavaScript -->
  </div>

  <!-- Empty state (hidden by default) -->
  <div id="favorites-empty" class="hidden text-center py-8 bg-gray-50 rounded-lg">
    <span aria-hidden="true" style="font-size:2.5rem">⭐</span>
    <p class="text-gray-600 mt-2">คลิกไอคอนดาวบนเครื่องคำนวณเพื่อบันทึกรายการโปรด</p>
  </div>
</div>

<style>
  #favorites-section.hidden {
    display: none;
  }

  .ct-favorite-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    color: inherit;
  }

  .ct-favorite-card:hover {
    border-color: #3b82f6;
    background: #f0f9ff;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1);
  }

  .ct-favorite-emoji {
    font-size: 1.75rem;
    display: block;
  }

  .ct-favorite-title {
    font-size: 0.875rem;
    font-weight: 500;
    text-align: center;
    color: #1f2937;
    line-height: 1.3;
    word-break: break-word;
  }

  .ct-favorite-remove {
    position: absolute;
    top: 0.25rem;
    right: 0.25rem;
    display: none;
    width: 24px;
    height: 24px;
    padding: 0;
    background: rgba(239, 68, 68, 0.1);
    border: none;
    border-radius: 4px;
    color: #ef4444;
    cursor: pointer;
    font-size: 0.875rem;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease;
  }

  .ct-favorite-card:hover .ct-favorite-remove {
    display: flex;
  }

  .ct-favorite-remove:hover {
    background: rgba(239, 68, 68, 0.2);
  }

  .ct-favorite-wrapper {
    position: relative;
    flex: 1;
    width: 100%;
  }
</style>

<script>
  async function initFavoriteCalculators() {
    const favSection = document.getElementById('favorites-section');
    const favGrid = document.getElementById('favorites-grid');
    const favEmpty = document.getElementById('favorites-empty');
    const favClear = document.getElementById('favorites-clear');

    if (!favSection || !favGrid) return;

    const { getFavorites, clearFavorites, removeFavorite } =
      await import('../../lib/favorites.ts');

    function renderFavorites() {
      const favorites = getFavorites();

      // Show/hide sections
      if (favorites.length === 0) {
        favSection.classList.add('hidden');
        return;
      }

      favSection.classList.remove('hidden');
      favEmpty?.classList.add('hidden');

      // Clear grid
      favGrid.innerHTML = '';

      // Render each favorite
      favorites.forEach((fav) => {
        const card = document.createElement('a');
        card.href = fav.href;
        card.className = 'ct-favorite-card';
        card.setAttribute('aria-label', `ไปที่เครื่องคำนวณ ${fav.title}`);

        card.innerHTML = `
          <div class="ct-favorite-wrapper">
            <div class="ct-favorite-emoji">${fav.emoji || '🔢'}</div>
            <div class="ct-favorite-title">${fav.title}</div>
            <button
              class="ct-favorite-remove"
              type="button"
              aria-label="ลบ ${fav.title} ออกจากรายการโปรด"
              data-href="${fav.href}"
            >
              ✕
            </button>
          </div>
        `;

        // Handle remove button click
        const removeBtn = card.querySelector('.ct-favorite-remove');
        if (removeBtn) {
          removeBtn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            removeFavorite(fav.href);
            window.dispatchEvent(new CustomEvent('ct:favorites-changed'));
            renderFavorites();
          });
        }

        favGrid.appendChild(card);
      });
    }

    // Initial render
    renderFavorites();

    // Handle clear all
    if (favClear) {
      favClear.addEventListener('click', () => {
        if (
          confirm('ต้องการลบเครื่องคำนวณทั้งหมดจากรายการโปรดหรือไม่?')
        ) {
          clearFavorites();
          window.dispatchEvent(new CustomEvent('ct:favorites-changed'));
          renderFavorites();
        }
      });
    }

    // Listen for external changes (e.g., bookmark button)
    window.addEventListener('ct:favorites-changed', () => {
      renderFavorites();
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFavoriteCalculators);
  } else {
    initFavoriteCalculators();
  }
</script>
