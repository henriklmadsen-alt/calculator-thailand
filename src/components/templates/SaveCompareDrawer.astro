---
// Save & Compare Drawer — Phase 2 Feature 3
// Global component included in BaseLayout.
// Provides window.ctSaveCalculation(data) for per-calculator use.
// Stores last 5 calculations in localStorage (ct.saved-calcs.v2).
---

<!-- Save & Compare Drawer -->
<div id="ct-save-drawer" role="dialog" aria-label="การคำนวณที่บันทึกไว้" aria-hidden="true" class="ct-drawer-hidden">
  <!-- Backdrop -->
  <div id="ct-drawer-backdrop" class="ct-drawer-backdrop"></div>

  <!-- Drawer Panel -->
  <div id="ct-drawer-panel" class="ct-drawer-panel">
    <div class="ct-drawer-header">
      <h2 class="ct-drawer-title">
        <span aria-hidden="true">💾</span> การคำนวณที่บันทึกไว้
      </h2>
      <div class="ct-drawer-actions">
        <button id="ct-compare-toggle" class="ct-btn-secondary" type="button" aria-pressed="false">
          เปรียบเทียบ
        </button>
        <button id="ct-clear-all" class="ct-btn-danger" type="button">
          ล้างทั้งหมด
        </button>
        <button id="ct-drawer-close" class="ct-btn-icon" type="button" aria-label="ปิด">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Normal list view -->
    <div id="ct-saved-list" class="ct-saved-list"></div>

    <!-- Compare view -->
    <div id="ct-compare-view" class="ct-compare-view ct-hidden">
      <div class="ct-compare-hint">เลือก 2–5 รายการเพื่อเปรียบเทียบ</div>
      <div id="ct-compare-table-wrap" class="ct-compare-table-wrap ct-hidden"></div>
      <button id="ct-export-btn" class="ct-btn-primary ct-hidden" type="button">
        📋 คัดลอกข้อมูลเปรียบเทียบ
      </button>
    </div>

    <!-- Empty state -->
    <div id="ct-saved-empty" class="ct-saved-empty ct-hidden">
      <span aria-hidden="true" style="font-size:2.5rem">📊</span>
      <p>ยังไม่มีการคำนวณที่บันทึกไว้</p>
      <p class="ct-empty-hint">กดปุ่ม "บันทึก" หลังคำนวณเพื่อเก็บผลลัพธ์</p>
    </div>
  </div>
</div>

<!-- Floating save-history button (shown on calculator pages) -->
<button
  id="ct-open-drawer-fab"
  type="button"
  aria-label="เปิดการคำนวณที่บันทึกไว้"
  class="ct-fab ct-fab-hidden"
>
  <span aria-hidden="true">💾</span>
  <span id="ct-fab-count" class="ct-fab-count ct-fab-count-hidden">0</span>
</button>

<style>
  /* ── Drawer shell ─────────────────────────────────────────── */
  .ct-drawer-hidden { pointer-events: none; }
  .ct-drawer-open   { pointer-events: auto; }

  .ct-drawer-backdrop {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .ct-drawer-open .ct-drawer-backdrop { opacity: 1; }

  .ct-drawer-panel {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    max-height: 85dvh;
    background: var(--color-bg, #fff);
    border-radius: 1.25rem 1.25rem 0 0;
    box-shadow: 0 -8px 40px rgba(0,0,0,0.18);
    z-index: 1001;
    display: flex; flex-direction: column;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.34,1.28,0.64,1);
    overflow: hidden;
  }
  .ct-drawer-open .ct-drawer-panel { transform: translateY(0); }

  @media (min-width: 640px) {
    .ct-drawer-panel {
      left: auto; bottom: auto;
      top: 50%; right: 1.5rem;
      transform: translateX(110%) translateY(-50%);
      width: min(480px, calc(100vw - 2rem));
      max-height: 80dvh;
      border-radius: 1rem;
    }
    .ct-drawer-open .ct-drawer-panel {
      transform: translateX(0) translateY(-50%);
    }
  }

  /* ── Header ──────────────────────────────────────────────── */
  .ct-drawer-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.25rem 0.75rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    flex-shrink: 0;
    gap: 0.5rem;
  }
  .ct-drawer-title { font-size: 1rem; font-weight: 700; color: var(--color-text, #111827); margin: 0; display: flex; align-items: center; gap: 0.4rem; }
  .ct-drawer-actions { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }

  /* ── Buttons ─────────────────────────────────────────────── */
  .ct-btn-secondary {
    font-size: 0.75rem; font-weight: 600;
    padding: 0.35rem 0.75rem; border-radius: 0.5rem;
    border: 1.5px solid #2563eb; color: #2563eb; background: transparent;
    cursor: pointer; transition: background 0.15s;
    white-space: nowrap;
  }
  .ct-btn-secondary:hover, .ct-btn-secondary[aria-pressed="true"] {
    background: #eff6ff;
  }
  .ct-btn-danger {
    font-size: 0.75rem; font-weight: 600;
    padding: 0.35rem 0.75rem; border-radius: 0.5rem;
    border: 1.5px solid #ef4444; color: #ef4444; background: transparent;
    cursor: pointer; transition: background 0.15s;
    white-space: nowrap;
  }
  .ct-btn-danger:hover { background: #fef2f2; }
  .ct-btn-icon {
    padding: 0.35rem; border: none; background: transparent;
    cursor: pointer; border-radius: 0.4rem; color: #6b7280;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  .ct-btn-icon:hover { background: #f3f4f6; }
  .ct-btn-primary {
    display: block; width: calc(100% - 2.5rem); margin: 0.75rem auto;
    padding: 0.6rem 1rem; border-radius: 0.6rem; border: none;
    background: #2563eb; color: #fff; font-size: 0.875rem; font-weight: 600;
    cursor: pointer; transition: background 0.15s;
  }
  .ct-btn-primary:hover { background: #1d4ed8; }

  /* ── Saved list ──────────────────────────────────────────── */
  .ct-saved-list {
    overflow-y: auto; flex: 1;
    padding: 0.75rem 1.25rem;
    display: flex; flex-direction: column; gap: 0.6rem;
  }
  .ct-saved-empty {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 0.5rem;
    padding: 2rem;
    color: #9ca3af; text-align: center; font-size: 0.9rem;
  }
  .ct-empty-hint { font-size: 0.8rem; }

  .ct-card {
    border: 1.5px solid #e5e7eb; border-radius: 0.75rem;
    padding: 0.75rem 0.875rem; background: #f9fafb;
    display: flex; align-items: flex-start; gap: 0.75rem;
    transition: border-color 0.15s;
    position: relative;
  }
  .ct-card.ct-selected { border-color: #2563eb; background: #eff6ff; }
  .ct-card-emoji { font-size: 1.5rem; flex-shrink: 0; margin-top: 0.1rem; }
  .ct-card-body { flex: 1; min-width: 0; }
  .ct-card-title { font-weight: 600; font-size: 0.875rem; color: #1f2937; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ct-card-result { font-size: 1rem; font-weight: 700; color: #2563eb; margin: 0.15rem 0; }
  .ct-card-meta { font-size: 0.75rem; color: #6b7280; }
  .ct-card-remove {
    flex-shrink: 0; background: none; border: none; cursor: pointer;
    color: #9ca3af; font-size: 1rem; padding: 0.2rem;
    border-radius: 0.3rem; transition: color 0.15s, background 0.15s;
    align-self: flex-start;
  }
  .ct-card-remove:hover { color: #ef4444; background: #fef2f2; }
  .ct-card-link {
    display: block; margin-top: 0.3rem;
    font-size: 0.75rem; color: #2563eb; text-decoration: none;
    font-weight: 500;
  }
  .ct-card-link:hover { text-decoration: underline; }

  /* Compare checkbox */
  .ct-compare-check {
    position: absolute; top: 0.6rem; left: 0.6rem;
    width: 1.1rem; height: 1.1rem; cursor: pointer;
  }
  .ct-card.ct-compare-mode { padding-left: 2.1rem; }

  /* ── Compare view ────────────────────────────────────────── */
  .ct-compare-view {
    flex: 1; display: flex; flex-direction: column;
    padding: 0.75rem 1.25rem; overflow-y: auto;
  }
  .ct-compare-hint {
    font-size: 0.8rem; color: #6b7280; text-align: center;
    padding: 0.5rem 0 0.75rem;
  }
  .ct-compare-table-wrap { overflow-x: auto; border-radius: 0.5rem; border: 1px solid #e5e7eb; }
  .ct-compare-table {
    width: 100%; border-collapse: collapse; font-size: 0.8rem;
    min-width: 300px;
  }
  .ct-compare-table th {
    background: #2563eb; color: #fff; padding: 0.5rem 0.75rem;
    text-align: left; font-weight: 600;
  }
  .ct-compare-table td {
    padding: 0.45rem 0.75rem; border-top: 1px solid #f3f4f6; color: #374151;
  }
  .ct-compare-table tr:nth-child(even) td { background: #f9fafb; }
  .ct-compare-table .ct-result-cell { font-weight: 700; color: #2563eb; }

  /* ── FAB ─────────────────────────────────────────────────── */
  .ct-fab {
    position: fixed; bottom: 1.25rem; right: 1.25rem;
    z-index: 900;
    background: #2563eb; color: #fff;
    border: none; border-radius: 50%;
    width: 3.25rem; height: 3.25rem;
    font-size: 1.4rem;
    box-shadow: 0 4px 16px rgba(37,99,235,0.4);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.2s, box-shadow 0.2s, opacity 0.25s;
  }
  .ct-fab:hover { transform: scale(1.08); box-shadow: 0 6px 20px rgba(37,99,235,0.5); }
  .ct-fab-hidden { opacity: 0; pointer-events: none; }

  .ct-fab-count {
    position: absolute; top: -0.25rem; right: -0.25rem;
    background: #ef4444; color: #fff; border-radius: 999px;
    font-size: 0.65rem; font-weight: 700;
    min-width: 1.1rem; height: 1.1rem;
    display: flex; align-items: center; justify-content: center;
    padding: 0 0.2rem; border: 2px solid #fff;
  }
  .ct-fab-count-hidden { display: none; }

  /* ── Utilities ───────────────────────────────────────────── */
  .ct-hidden { display: none !important; }
</style>

<script is:inline>
(function initSaveCompare() {
  var SAVED_KEY = 'ct.saved-calcs.v2';
  var MAX_SAVED = 5;
  var isCompareMode = false;
  var compareSelected = [];

  // ── Storage helpers ───────────────────────────────────────
  function loadSaved() {
    try {
      var data = JSON.parse(localStorage.getItem(SAVED_KEY) || '[]');
      return Array.isArray(data) ? data.slice(0, MAX_SAVED) : [];
    } catch(e) { return []; }
  }

  function persistSaved(arr) {
    try { localStorage.setItem(SAVED_KEY, JSON.stringify(arr.slice(0, MAX_SAVED))); } catch(e) {}
  }

  // ── Public API ────────────────────────────────────────────
  /**
   * Call from any calculator page after a successful result:
   * window.ctSaveCalculation({
   *   calcId: 'bmi',
   *   calcTitle: 'BMI ดัชนีมวลกาย',
   *   calcEmoji: '⚖️',
   *   resultLabel: 'ค่า BMI',
   *   resultValue: '22.5',
   *   resultCategory: 'ปกติ',    // optional
   *   inputs: [                  // optional, up to 4 items
   *     { label: 'น้ำหนัก', value: '65 กก.' },
   *     { label: 'ส่วนสูง', value: '170 ซม.' },
   *   ],
   *   url: '/คำนวณ-bmi/',         // optional, defaults to current URL
   * });
   */
  window.ctSaveCalculation = function(data) {
    if (!data || !data.calcTitle || !data.resultValue) return;
    var saved = loadSaved();
    var entry = {
      id: 'ct-' + Date.now(),
      calcId:        data.calcId        || '',
      calcTitle:     data.calcTitle     || '',
      calcEmoji:     data.calcEmoji     || '🔢',
      resultLabel:   data.resultLabel   || 'ผลลัพธ์',
      resultValue:   data.resultValue   || '',
      resultCategory: data.resultCategory || '',
      inputs:        data.inputs        || [],
      url:           data.url           || window.location.pathname,
      savedAt:       new Date().toISOString(),
    };
    // Remove duplicate (same calcId + resultValue)
    saved = saved.filter(function(s) {
      return !(s.calcId === entry.calcId && s.resultValue === entry.resultValue);
    });
    saved.unshift(entry);
    persistSaved(saved);
    renderDrawer();
    showFab();
    showSaveToast();

    if (typeof window.trackLanguageAwareEvent === 'function') {
      window.trackLanguageAwareEvent('calculation_saved', { calculator_type: entry.calcId });
    }
  };

  // ── Toast ─────────────────────────────────────────────────
  function showSaveToast() {
    var toast = document.createElement('div');
    toast.style.cssText = [
      'position:fixed', 'bottom:5.5rem', 'right:1.25rem',
      'background:#1e40af', 'color:#fff',
      'border-radius:0.6rem', 'padding:0.6rem 1rem',
      'font-size:0.85rem', 'font-weight:600',
      'z-index:950', 'pointer-events:none',
      'animation:ctFadeInOut 2.2s ease forwards',
      'box-shadow:0 4px 16px rgba(37,99,235,0.35)',
    ].join(';');
    toast.textContent = '✅ บันทึกการคำนวณแล้ว';

    if (!document.getElementById('ct-toast-style')) {
      var s = document.createElement('style');
      s.id = 'ct-toast-style';
      s.textContent = '@keyframes ctFadeInOut{0%{opacity:0;transform:translateY(8px)}15%{opacity:1;transform:translateY(0)}80%{opacity:1}100%{opacity:0}}';
      document.head.appendChild(s);
    }
    document.body.appendChild(toast);
    setTimeout(function() { if (toast.parentNode) toast.remove(); }, 2300);
  }

  // ── Render ────────────────────────────────────────────────
  function formatDate(iso) {
    try {
      var d = new Date(iso);
      return d.toLocaleDateString('th-TH', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    } catch(e) { return ''; }
  }

  function renderCard(entry, idx) {
    var isChecked = compareSelected.indexOf(entry.id) !== -1;
    var card = document.createElement('div');
    card.className = 'ct-card' + (isCompareMode ? ' ct-compare-mode' : '') + (isChecked ? ' ct-selected' : '');
    card.dataset.id = entry.id;

    if (isCompareMode) {
      var cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.className = 'ct-compare-check';
      cb.checked = isChecked;
      cb.setAttribute('aria-label', 'เลือก ' + entry.calcTitle);
      cb.addEventListener('change', function() {
        if (cb.checked) {
          if (compareSelected.length < 5) compareSelected.push(entry.id);
          else { cb.checked = false; return; }
        } else {
          compareSelected = compareSelected.filter(function(id) { return id !== entry.id; });
        }
        // Track scenario_compared event when selections change
        if (typeof window.trackLanguageAwareEvent === 'function') {
          window.trackLanguageAwareEvent('scenario_compared', {
            calculator_type: entry.calcId,
            selected_count: compareSelected.length
          });
        }
        renderDrawer();
      });
      card.appendChild(cb);
    }

    var emoji = document.createElement('span');
    emoji.className = 'ct-card-emoji';
    emoji.setAttribute('aria-hidden', 'true');
    emoji.textContent = entry.calcEmoji || '🔢';
    card.appendChild(emoji);

    var body = document.createElement('div');
    body.className = 'ct-card-body';

    var title = document.createElement('div');
    title.className = 'ct-card-title';
    title.textContent = entry.calcTitle;
    body.appendChild(title);

    var result = document.createElement('div');
    result.className = 'ct-card-result';
    result.textContent = entry.resultLabel + ': ' + entry.resultValue + (entry.resultCategory ? ' (' + entry.resultCategory + ')' : '');
    body.appendChild(result);

    if (entry.inputs && entry.inputs.length > 0) {
      var meta = document.createElement('div');
      meta.className = 'ct-card-meta';
      meta.textContent = entry.inputs.map(function(i) { return i.label + ': ' + i.value; }).join(' · ');
      body.appendChild(meta);
    }

    var dateEl = document.createElement('div');
    dateEl.className = 'ct-card-meta';
    dateEl.textContent = formatDate(entry.savedAt);
    body.appendChild(dateEl);

    var link = document.createElement('a');
    link.className = 'ct-card-link';
    link.href = entry.url;
    link.textContent = '↗ ไปยังเครื่องคำนวณ';
    link.addEventListener('click', function() {
      // Track history_restored event when user restores a saved calculation
      if (typeof window.trackLanguageAwareEvent === 'function') {
        window.trackLanguageAwareEvent('history_restored', {
          calculator_type: entry.calcId,
          calculator_name: entry.calcTitle
        });
      }
    });
    body.appendChild(link);

    card.appendChild(body);

    if (!isCompareMode) {
      var removeBtn = document.createElement('button');
      removeBtn.className = 'ct-card-remove';
      removeBtn.type = 'button';
      removeBtn.setAttribute('aria-label', 'ลบ ' + entry.calcTitle);
      removeBtn.innerHTML = '&times;';
      removeBtn.addEventListener('click', function() {
        var saved = loadSaved().filter(function(s) { return s.id !== entry.id; });
        persistSaved(saved);
        compareSelected = compareSelected.filter(function(id) { return id !== entry.id; });
        renderDrawer();
      });
      card.appendChild(removeBtn);
    }

    return card;
  }

  function buildCompareTable(saved) {
    var selected = compareSelected.length > 0
      ? saved.filter(function(s) { return compareSelected.indexOf(s.id) !== -1; })
      : saved;

    if (selected.length < 2) return null;

    var table = document.createElement('table');
    table.className = 'ct-compare-table';

    // Header row
    var thead = document.createElement('thead');
    var headerRow = document.createElement('tr');
    var thLabel = document.createElement('th');
    thLabel.textContent = 'รายการ';
    headerRow.appendChild(thLabel);
    selected.forEach(function(s, i) {
      var th = document.createElement('th');
      th.textContent = s.calcEmoji + ' #' + (i + 1);
      headerRow.appendChild(th);
    });
    thead.appendChild(headerRow);
    table.appendChild(thead);

    var tbody = document.createElement('tbody');

    // Calculator row
    var titleRow = document.createElement('tr');
    var tdTitleLabel = document.createElement('td');
    tdTitleLabel.textContent = 'เครื่องคำนวณ';
    titleRow.appendChild(tdTitleLabel);
    selected.forEach(function(s) {
      var td = document.createElement('td');
      td.textContent = s.calcTitle;
      titleRow.appendChild(td);
    });
    tbody.appendChild(titleRow);

    // Result row
    var resultRow = document.createElement('tr');
    var tdResLabel = document.createElement('td');
    tdResLabel.textContent = 'ผลลัพธ์';
    resultRow.appendChild(tdResLabel);
    selected.forEach(function(s) {
      var td = document.createElement('td');
      td.className = 'ct-result-cell';
      td.textContent = s.resultValue + (s.resultCategory ? ' (' + s.resultCategory + ')' : '');
      resultRow.appendChild(td);
    });
    tbody.appendChild(resultRow);

    // Input rows (show all unique labels)
    var allLabels = [];
    selected.forEach(function(s) {
      (s.inputs || []).forEach(function(inp) {
        if (allLabels.indexOf(inp.label) === -1) allLabels.push(inp.label);
      });
    });
    allLabels.forEach(function(label) {
      var row = document.createElement('tr');
      var tdLabel = document.createElement('td');
      tdLabel.textContent = label;
      row.appendChild(tdLabel);
      selected.forEach(function(s) {
        var inp = (s.inputs || []).find(function(i) { return i.label === label; });
        var td = document.createElement('td');
        td.textContent = inp ? inp.value : '—';
        row.appendChild(td);
      });
      tbody.appendChild(row);
    });

    // Date row
    var dateRow = document.createElement('tr');
    var tdDateLabel = document.createElement('td');
    tdDateLabel.textContent = 'บันทึกเมื่อ';
    dateRow.appendChild(tdDateLabel);
    selected.forEach(function(s) {
      var td = document.createElement('td');
      td.textContent = formatDate(s.savedAt);
      dateRow.appendChild(td);
    });
    tbody.appendChild(dateRow);

    table.appendChild(tbody);
    return table;
  }

  function buildExportText(saved) {
    var selected = compareSelected.length > 0
      ? saved.filter(function(s) { return compareSelected.indexOf(s.id) !== -1; })
      : saved;
    var lines = ['การเปรียบเทียบการคำนวณ — kamnuanlek.com', ''];
    selected.forEach(function(s, i) {
      lines.push('รายการที่ ' + (i + 1) + ': ' + s.calcTitle);
      lines.push('ผลลัพธ์: ' + s.resultValue + (s.resultCategory ? ' (' + s.resultCategory + ')' : ''));
      (s.inputs || []).forEach(function(inp) {
        lines.push(inp.label + ': ' + inp.value);
      });
      lines.push('บันทึกเมื่อ: ' + formatDate(s.savedAt));
      lines.push('');
    });
    return lines.join('\n');
  }

  function renderDrawer() {
    var saved = loadSaved();
    var listEl = document.getElementById('ct-saved-list');
    var emptyEl = document.getElementById('ct-saved-empty');
    var compareView = document.getElementById('ct-compare-view');
    var listView = document.getElementById('ct-saved-list');

    if (!listEl) return;

    updateFabCount(saved.length);

    if (isCompareMode) {
      listView.classList.add('ct-hidden');
      compareView.classList.remove('ct-hidden');

      // Show cards with checkboxes in the compare view list
      var existingList = compareView.querySelector('.ct-compare-cards');
      if (!existingList) {
        existingList = document.createElement('div');
        existingList.className = 'ct-compare-cards';
        existingList.style.display = 'flex';
        existingList.style.flexDirection = 'column';
        existingList.style.gap = '0.5rem';
        existingList.style.marginBottom = '0.75rem';
        compareView.insertBefore(existingList, compareView.firstChild);
      }
      existingList.innerHTML = '';
      saved.forEach(function(entry, idx) {
        existingList.appendChild(renderCard(entry, idx));
      });

      var tableWrap = document.getElementById('ct-compare-table-wrap');
      var exportBtn = document.getElementById('ct-export-btn');
      var selectedSaved = compareSelected.length >= 2
        ? saved.filter(function(s) { return compareSelected.indexOf(s.id) !== -1; })
        : saved.length >= 2 ? saved : [];

      if (selectedSaved.length >= 2) {
        tableWrap.innerHTML = '';
        var table = buildCompareTable(saved);
        if (table) tableWrap.appendChild(table);
        tableWrap.classList.remove('ct-hidden');
        exportBtn.classList.remove('ct-hidden');
      } else {
        tableWrap.classList.add('ct-hidden');
        exportBtn.classList.add('ct-hidden');
      }
    } else {
      compareView.classList.add('ct-hidden');
      listView.classList.remove('ct-hidden');

      listEl.innerHTML = '';
      if (saved.length === 0) {
        emptyEl.classList.remove('ct-hidden');
      } else {
        emptyEl.classList.add('ct-hidden');
        saved.forEach(function(entry, idx) {
          listEl.appendChild(renderCard(entry, idx));
        });
      }
    }
  }

  // ── FAB ───────────────────────────────────────────────────
  function showFab() {
    var fab = document.getElementById('ct-open-drawer-fab');
    if (fab) fab.classList.remove('ct-fab-hidden');
  }

  function updateFabCount(count) {
    var badge = document.getElementById('ct-fab-count');
    if (!badge) return;
    if (count > 0) {
      badge.textContent = String(count);
      badge.classList.remove('ct-fab-count-hidden');
    } else {
      badge.classList.add('ct-fab-count-hidden');
    }
  }

  // ── Drawer open/close ─────────────────────────────────────
  function openDrawer() {
    var wrapper = document.getElementById('ct-save-drawer');
    if (wrapper) { wrapper.classList.remove('ct-drawer-hidden'); wrapper.classList.add('ct-drawer-open'); }
    document.body.style.overflow = 'hidden';
    renderDrawer();
  }

  function closeDrawer() {
    var wrapper = document.getElementById('ct-save-drawer');
    if (wrapper) { wrapper.classList.add('ct-drawer-hidden'); wrapper.classList.remove('ct-drawer-open'); }
    document.body.style.overflow = '';
  }

  // ── Bind events ───────────────────────────────────────────
  function bindEvents() {
    var fab = document.getElementById('ct-open-drawer-fab');
    if (fab) fab.addEventListener('click', openDrawer);

    var closeBtn = document.getElementById('ct-drawer-close');
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);

    var backdrop = document.getElementById('ct-drawer-backdrop');
    if (backdrop) backdrop.addEventListener('click', closeDrawer);

    var clearBtn = document.getElementById('ct-clear-all');
    if (clearBtn) clearBtn.addEventListener('click', function() {
      if (confirm('ลบการคำนวณที่บันทึกไว้ทั้งหมด?')) {
        persistSaved([]);
        compareSelected = [];
        renderDrawer();
      }
    });

    var compareToggle = document.getElementById('ct-compare-toggle');
    if (compareToggle) compareToggle.addEventListener('click', function() {
      isCompareMode = !isCompareMode;
      compareToggle.setAttribute('aria-pressed', isCompareMode ? 'true' : 'false');
      if (!isCompareMode) compareSelected = [];
      // Track scenario_compared event when compare mode is toggled
      if (typeof window.trackLanguageAwareEvent === 'function') {
        window.trackLanguageAwareEvent('scenario_compared', {
          compare_mode_enabled: isCompareMode,
          selected_count: compareSelected.length
        });
      }
      renderDrawer();
    });

    var exportBtn = document.getElementById('ct-export-btn');
    if (exportBtn) exportBtn.addEventListener('click', function() {
      var text = buildExportText(loadSaved());
      try {
        navigator.clipboard.writeText(text).then(function() {
          exportBtn.textContent = '✅ คัดลอกแล้ว!';
          setTimeout(function() { exportBtn.textContent = '📋 คัดลอกข้อมูลเปรียบเทียบ'; }, 2000);
        });
      } catch(e) {
        // Fallback: show text in a textarea
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.cssText = 'position:fixed;left:-9999px';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch(e2) {}
        ta.remove();
        exportBtn.textContent = '✅ คัดลอกแล้ว!';
        setTimeout(function() { exportBtn.textContent = '📋 คัดลอกข้อมูลเปรียบเทียบ'; }, 2000);
      }
    });
  }

  // ── Init ──────────────────────────────────────────────────
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      bindEvents();
      // Show FAB if there are saved calcs
      if (loadSaved().length > 0) showFab();
      updateFabCount(loadSaved().length);
    });
  } else {
    bindEvents();
    if (loadSaved().length > 0) showFab();
    updateFabCount(loadSaved().length);
  }
})();
</script>
