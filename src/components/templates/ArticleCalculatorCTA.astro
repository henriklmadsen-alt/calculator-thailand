---
interface Props {
  title: string;
  description?: string;
  href: string;
  buttonLabel: string;
}

const {
  title,
  description = 'กรอกข้อมูลไม่กี่ช่องและดูผลได้เลย',
  href,
  buttonLabel,
} = Astro.props;
---

<section class="not-prose my-6 rounded-2xl border border-primary-200 bg-primary-50 p-4 sm:p-5">
  <p class="text-sm font-semibold text-primary-800">{title}</p>
  <p class="mt-1 text-sm text-primary-700">{description}</p>
  <a
    href={href}
    data-preserve-utm
    class="mt-3 inline-flex min-h-11 items-center rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary-700"
  >
    {buttonLabel}
  </a>
</section>
