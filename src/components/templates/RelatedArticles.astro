---
import type { RelatedLink } from '../../lib/internal-links';
import { getCalculatorLinks } from '../../lib/internal-links';

interface Props {
  /** Current calculator href — used to auto-look up related articles. */
  currentHref: string;
  /** Override the auto-lookup with explicit links. */
  articles?: RelatedLink[];
  /** Section heading override. */
  heading?: string;
}

const {
  currentHref,
  articles: explicitArticles,
  heading = 'บทความที่เกี่ยวข้อง',
} = Astro.props;

const links = explicitArticles ?? getCalculatorLinks(currentHref).articles;
---

{links.length > 0 && (
  <section class="mb-8">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">{heading}</h2>
    <div class="grid gap-3 sm:grid-cols-1">
      {links.map((link) => (
        <a
          href={link.href}
          data-preserve-utm
          class="flex items-start gap-3 p-4 bg-white rounded-lg shadow-sm border border-gray-200 hover:border-primary-500 transition-colors"
        >
          <span class="text-lg leading-none mt-0.5">📖</span>
          <div>
            <span class="text-primary-600 font-medium">{link.title}</span>
            <span class="text-gray-400 text-sm block">{link.desc}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
