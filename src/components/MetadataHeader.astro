---
// MetadataHeader component for calculator pages
// Displays: updated date, data source, and author
// WCAG 2.1 compliance: 44×44px minimum tap target per item

interface Props {
  updated?: string; // ISO date or human-readable date
  source?: {
    name: string;
    url?: string;
  };
  author?: string; // Default: "Kamnuanlek Team"
}

const { updated, source, author = "Kamnuanlek Team" } = Astro.props;

// Format date for display
function formatDate(dateStr?: string): string {
  if (!dateStr) return "";
  // If it's already human-readable, return as-is
  if (dateStr.includes("เ") || dateStr.includes(" ")) return dateStr;
  const date = new Date(dateStr);
  return date.toLocaleDateString("th-TH", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const formattedDate = formatDate(updated);
---

<div class="metadata-header">
  <div class="metadata-items">
    {
      formattedDate && (
        <div class="metadata-item">
          <span class="icon" aria-hidden="true">
            ✅
          </span>
          <span class="text">
            Updated: {formattedDate}
          </span>
        </div>
      )
    }
    {
      source && (
        <div class="metadata-item">
          <span class="icon" aria-hidden="true">
            🏛️
          </span>
          {source.url ? (
            <a href={source.url} target="_blank" rel="noopener noreferrer" class="text link">
              {source.name}
            </a>
          ) : (
            <span class="text">{source.name}</span>
          )}
        </div>
      )
    }
    {
      author && (
        <div class="metadata-item">
          <span class="icon" aria-hidden="true">
            ✍️
          </span>
          <span class="text">Author: {author}</span>
        </div>
      )
    }
  </div>
</div>

<style define:vars={{ formattedDate, author, source }}>
  .metadata-header {
    background-color: #f0f9ff;
    border-top: 1px solid #d1d5db;
    border-bottom: 1px solid #d1d5db;
    padding: 12px 16px;
    margin: 16px 0;
    font-size: 13px;
    color: #6b7280;
  }

  .metadata-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .metadata-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 0;
    min-height: 44px;
    line-height: 1.4;
  }

  .icon {
    flex-shrink: 0;
    font-size: 16px;
    width: 20px;
    text-align: center;
  }

  .text {
    flex-grow: 1;
    word-break: break-word;
  }

  .link {
    color: #2563eb;
    text-decoration: underline;
    transition: color 0.2s;
  }

  .link:hover {
    color: #1d4ed8;
  }

  .link:focus {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Desktop: inline layout with separator */
  @media (min-width: 768px) {
    .metadata-items {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
    }

    .metadata-item {
      padding: 8px 0;
      min-height: 44px;
      white-space: nowrap;
    }

    .metadata-item:not(:last-child)::after {
      content: "•";
      margin-left: 12px;
      color: #d1d5db;
    }
  }

  /* Ensure sufficient contrast for accessibility */
  @media (prefers-color-scheme: dark) {
    .metadata-header {
      background-color: #111827;
      border-color: #374151;
      color: #d1d5db;
    }

    .link {
      color: #60a5fa;
    }

    .link:hover {
      color: #93c5fd;
    }
  }
</style>
