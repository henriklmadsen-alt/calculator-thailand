---
// Calculator Header with Bookmark Button
// Use this component in calculator pages to display the title with bookmark functionality
//
// Props:
//   - title: string — the calculator name
//   - emoji?: string — optional emoji for the favorite card

import BookmarkButton from './BookmarkButton.astro';

interface Props {
  title: string;
  emoji?: string;
}

const { title, emoji } = Astro.props;

// Get current pathname as the calculator href
const calcHref = Astro.url.pathname;
---

<div class="flex items-start justify-between gap-4 mb-6">
  <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 flex-1">
    {title}
  </h1>
  <BookmarkButton
    calcTitle={title}
    calcHref={calcHref}
    calcEmoji={emoji}
  />
</div>
