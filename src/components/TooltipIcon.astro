---
// TooltipIcon — Input field explanation tooltip
// Shows a (?) icon that reveals brief Thai field explanation on hover/click
// Props:
//   - text: Thai explanation text
//   - fieldName: HTML id or data attribute to link this tooltip
//   - Example: <TooltipIcon text="รวมเงินเดือน + โบนัส + รายได้พิเศษต่อปี" fieldName="income" />

interface Props {
  text: string;
  fieldName?: string;
}

const { text, fieldName = '' } = Astro.props;
const tooltipId = fieldName ? `tooltip-${fieldName}` : `tooltip-${Math.random().toString(36).substr(2, 9)}`;
---

<button
  type="button"
  class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-blue-100 hover:bg-blue-200 text-blue-600 hover:text-blue-700 transition-colors ml-1 flex-shrink-0"
  aria-label="ดูคำอธิบาย"
  role="button"
  tabindex="0"
  data-tooltip-trigger={tooltipId}
  title={text}
>
  <span class="text-sm font-semibold leading-none">?</span>
</button>

<div
  id={tooltipId}
  class="tooltip-content hidden absolute z-50 bg-gray-900 text-white text-sm rounded-lg shadow-lg py-2 px-3 max-w-xs pointer-events-none"
  role="tooltip"
  aria-hidden="true"
>
  {text}
  <div class="tooltip-arrow"></div>
</div>

<script define:vars={{ tooltipId }}>
  // Position tooltip near trigger button
  const trigger = document.querySelector(`[data-tooltip-trigger="${tooltipId}"]`);
  const tooltip = document.getElementById(tooltipId);

  if (trigger && tooltip) {
    // Show/hide on click and hover
    const showTooltip = () => {
      tooltip.classList.remove('hidden');
      tooltip.setAttribute('aria-hidden', 'false');
      positionTooltip();
    };

    const hideTooltip = () => {
      tooltip.classList.add('hidden');
      tooltip.setAttribute('aria-hidden', 'true');
    };

    const positionTooltip = () => {
      const triggerRect = trigger.getBoundingClientRect();
      const tooltipRect = tooltip.getBoundingClientRect();

      // Position above the trigger by default
      let top = triggerRect.top - tooltipRect.height - 8;
      let left = triggerRect.left + triggerRect.width / 2 - tooltipRect.width / 2;

      // Adjust if off-screen
      if (top < 0) {
        top = triggerRect.bottom + 8; // Position below
      }
      if (left < 0) {
        left = 8;
      }
      if (left + tooltipRect.width > window.innerWidth) {
        left = window.innerWidth - tooltipRect.width - 8;
      }

      tooltip.style.top = `${top + window.scrollY}px`;
      tooltip.style.left = `${left}px`;
    };

    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (tooltip.classList.contains('hidden')) {
        showTooltip();
      } else {
        hideTooltip();
      }
    });

    trigger.addEventListener('mouseenter', showTooltip);
    tooltip.addEventListener('mouseleave', hideTooltip);

    // Hide on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !tooltip.classList.contains('hidden')) {
        hideTooltip();
      }
    });

    // Hide when clicking outside
    document.addEventListener('click', (e) => {
      if (!trigger.contains(e.target) && !tooltip.contains(e.target)) {
        hideTooltip();
      }
    });
  }
</script>

<style>
  .tooltip-content {
    position: fixed;
  }

  .tooltip-arrow {
    position: absolute;
    width: 8px;
    height: 8px;
    background: inherit;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
  }

  /* Print media: hide tooltips */
  @media print {
    button[data-tooltip-trigger],
    .tooltip-content {
      display: none !important;
    }
  }
</style>
