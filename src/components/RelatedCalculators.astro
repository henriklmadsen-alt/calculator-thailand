  hubLinks.push({ href: '/เครื่องคำนวณการเงินชั้นยอด/', title: 'เครื่องคำนวณยอดนิยม', icon: '⭐' });
}
---

{links.length > 0 && (
  <section class="mb-8">
    <div class="mb-4 rounded-lg border border-blue-100 bg-blue-50/70 p-4 ai-quick-answer">
      <h3 class="text-sm font-semibold text-blue-900">{quickAnswer.heading}</h3>
      <p class="mt-1 text-sm text-blue-900">{quickAnswer.summary}</p>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-xs text-blue-800">
        {quickAnswer.assumptions.map((assumption) => <li>{assumption}</li>)}
      </ul>
      <div class="mt-3 flex flex-wrap gap-2">
        {quickAnswer.sources.map((source) => (
          <a
            href={source.href}
            class="inline-flex min-h-11 items-center rounded-lg border border-blue-200 bg-white px-3 py-2 text-xs font-semibold text-blue-700 hover:border-blue-400"
            target={source.href.startsWith('http') ? '_blank' : undefined}
            rel={source.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {source.label}
          </a>
        ))}
      </div>
    </div>

    <h2 class="text-xl font-semibold text-gray-900 mb-4">{heading}</h2>
    <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
      {links.slice(0, 5).map((link) => (
        <a
          href={link.href}
          data-preserve-utm
          data-ct-event="related_calc_click"
          class="block p-4 bg-white rounded-lg shadow-sm border border-gray-200 hover:border-primary-500 hover:shadow-md transition-all"
        >
          <span class="text-primary-600 font-medium block">{link.title}</span>
          {link.desc && <span class="text-gray-400 text-sm block">{link.desc}</span>}
        </a>
      ))}
    </div>
  </section>
)}

<section class="mb-8">
  <h2 class="text-xl font-semibold text-gray-900 mb-3">คู่มือและเครื่องมือที่เกี่ยวข้อง</h2>
  <div class="flex flex-wrap gap-2">
    {hubLinks.map((hub) => (
      <a
        href={hub.href}
        class="inline-flex items-center gap-1.5 px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-medium hover:bg-primary-100 transition-colors border border-primary-200"
      >
        <span>{hub.icon}</span>
        <span>{hub.title}</span>
      </a>
    ))}
    <a
      href="/เลือกเครื่องคำนวณ/"
      class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-50 text-gray-600 rounded-full text-sm font-medium hover:bg-gray-100 transition-colors border border-gray-200"
    >
      <span>🔍</span>
      <span>ช่วยเลือกเครื่องคำนวณ</span>
    </a>
  </div>
</section>
