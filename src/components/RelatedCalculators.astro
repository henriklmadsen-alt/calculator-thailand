  hubLinks.push({ href: '/เครื่องคำนวณเงินเดือนและค่าแรง/', title: 'เครื่องคำนวณเงินเดือนและค่าแรงทุกประเภท', icon: '💼' });
  hubLinks.push({ href: '/ตัวช่วยคำนวณการเงิน/', title: 'ศูนย์รวมเครื่องคำนวณการเงิน', icon: '💰' });
