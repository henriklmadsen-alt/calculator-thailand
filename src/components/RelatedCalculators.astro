const links = explicitCalcs ?? getCalculatorLinks(currentHref).calculators;

type HubLink = { href: string; title: string; icon: string };
const hubLinks: HubLink[] = [];

const href = currentHref.toLowerCase();
type QuickAnswer = {
  heading: string;
  summary: string;
