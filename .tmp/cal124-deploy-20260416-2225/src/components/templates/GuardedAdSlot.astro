---
import AdUnit from '../AdUnit.astro';

interface Props {
  templateType?: 'calculator' | 'article';
  slotId?: string;
  revealAfterSelector?: string;
  className?: string;
}

const {
  templateType = 'calculator',
  slotId = 'C1',
  revealAfterSelector,
  className = '',
} = Astro.props;

const adSlot = templateType === 'article' ? 'in-content' : 'below-calculator';
const shouldRevealLazily = Boolean(revealAfterSelector);
---

<div
  class:list={['guarded-ad-slot', className]}
  data-guarded-ad-slot
  data-template-type={templateType}
  data-slot-id={slotId}
  data-reveal-after={revealAfterSelector || ''}
  hidden={shouldRevealLazily}
>
  <AdUnit slot={adSlot} />
</div>

<script is:inline>
  (() => {
    if (typeof document === 'undefined') return;
    if (window.__ctGuardedAdSlotInit) return;
    window.__ctGuardedAdSlotInit = true;

    function revealSlot(slot: Element) {
      slot.removeAttribute('hidden');
    }

    function initGuardedSlots() {
      document.querySelectorAll('[data-guarded-ad-slot]').forEach((slot) => {
        const selector = slot.getAttribute('data-reveal-after');
        if (!selector) {
          revealSlot(slot);
          return;
        }

        const gate = document.querySelector(selector);
        if (!gate || typeof IntersectionObserver === 'undefined') {
          revealSlot(slot);
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              revealSlot(slot);
              observer.disconnect();
            });
          },
          { threshold: 0.1 },
        );
        observer.observe(gate);
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initGuardedSlots);
      return;
    }

    initGuardedSlots();
  })();
</script>
