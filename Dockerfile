FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ARG PUBLIC_ADSENSE_CLIENT_ID
ARG PUBLIC_ADSENSE_ENABLED
ARG PUBLIC_ADSENSE_EXPERIMENT_ID
ARG PUBLIC_ADSENSE_ROLLOUT_BELOW_CALCULATOR_PERCENT
ARG PUBLIC_ADSENSE_ROLLOUT_IN_CONTENT_PERCENT
ARG PUBLIC_ADSENSE_ROLLOUT_SIDEBAR_PERCENT
ARG PUBLIC_ADSENSE_ROLLOUT_STICKY_ANCHOR_PERCENT
ARG PUBLIC_ADSENSE_SLOT_BELOW_CALCULATOR
ARG PUBLIC_ADSENSE_SLOT_BELOW_CALCULATOR_ENABLED
ARG PUBLIC_ADSENSE_SLOT_IN_CONTENT
ARG PUBLIC_ADSENSE_SLOT_IN_CONTENT_ENABLED
ARG PUBLIC_ADSENSE_SLOT_SIDEBAR_ENABLED
ARG PUBLIC_ADSENSE_SLOT_STICKY_ANCHOR_ENABLED
ARG PUBLIC_ADSENSE_VARIANT_ID
ENV PUBLIC_ADSENSE_CLIENT_ID=$PUBLIC_ADSENSE_CLIENT_ID
ENV PUBLIC_ADSENSE_ENABLED=$PUBLIC_ADSENSE_ENABLED
ENV PUBLIC_ADSENSE_EXPERIMENT_ID=$PUBLIC_ADSENSE_EXPERIMENT_ID
ENV PUBLIC_ADSENSE_ROLLOUT_BELOW_CALCULATOR_PERCENT=$PUBLIC_ADSENSE_ROLLOUT_BELOW_CALCULATOR_PERCENT
ENV PUBLIC_ADSENSE_ROLLOUT_IN_CONTENT_PERCENT=$PUBLIC_ADSENSE_ROLLOUT_IN_CONTENT_PERCENT
ENV PUBLIC_ADSENSE_ROLLOUT_SIDEBAR_PERCENT=$PUBLIC_ADSENSE_ROLLOUT_SIDEBAR_PERCENT
ENV PUBLIC_ADSENSE_ROLLOUT_STICKY_ANCHOR_PERCENT=$PUBLIC_ADSENSE_ROLLOUT_STICKY_ANCHOR_PERCENT
ENV PUBLIC_ADSENSE_SLOT_BELOW_CALCULATOR=$PUBLIC_ADSENSE_SLOT_BELOW_CALCULATOR
ENV PUBLIC_ADSENSE_SLOT_BELOW_CALCULATOR_ENABLED=$PUBLIC_ADSENSE_SLOT_BELOW_CALCULATOR_ENABLED
ENV PUBLIC_ADSENSE_SLOT_IN_CONTENT=$PUBLIC_ADSENSE_SLOT_IN_CONTENT
ENV PUBLIC_ADSENSE_SLOT_IN_CONTENT_ENABLED=$PUBLIC_ADSENSE_SLOT_IN_CONTENT_ENABLED
ENV PUBLIC_ADSENSE_SLOT_SIDEBAR_ENABLED=$PUBLIC_ADSENSE_SLOT_SIDEBAR_ENABLED
ENV PUBLIC_ADSENSE_SLOT_STICKY_ANCHOR_ENABLED=$PUBLIC_ADSENSE_SLOT_STICKY_ANCHOR_ENABLED
ENV PUBLIC_ADSENSE_VARIANT_ID=$PUBLIC_ADSENSE_VARIANT_ID
RUN npm run build

FROM node:20-alpine AS runtime
WORKDIR /app
COPY --from=build /app/package.json ./package.json
COPY --from=build /app/package-lock.json ./package-lock.json
RUN npm ci --omit=dev
COPY --from=build /app/dist ./dist
COPY --from=build /app/server.mjs ./server.mjs
EXPOSE 3000
CMD ["node", "server.mjs"]
